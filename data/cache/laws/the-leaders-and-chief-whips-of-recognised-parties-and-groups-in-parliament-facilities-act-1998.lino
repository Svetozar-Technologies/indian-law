obj_root_law_sections_1:
  sectionId (10731)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. Subs. by Act 18 of2000, s.2, for sub-section (2) (w.e.f. 5-2-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00004_199905_1517807323998&sectionId=10731&sectionno=1&orderno=1&orgactid=AC_CEN_33_52_00004_199905_1517807323998
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Leaders and Chief Whips of`
  line `Recognised Parties and Groups in Parliament (Facilities) Act, 1998.`
  line
  line `^1[ (2) It shall be deemed to have come into force on the 5th day of February, 1999.]`
obj_root_law_sections_2:
  sectionId (10732)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Subs. by s.3,ibid., for section 2 (w.e.f. 7-6-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00004_199905_1517807323998&sectionId=10732&sectionno=2&orderno=2&orgactid=AC_CEN_33_52_00004_199905_1517807323998
obj_root_law_sections_2_content:
  string
  line `^1[2. Definitions.-- In this Act, unless the context otherwise requires,--`
  line
  line `(a)"recognised group" means,--`
  line
  line `(i) in relation to the Council of States, every party which has a strength of not less than fifteen`
  line `members and not more than twenty-four members in the Council;`
  line
  line `(ii) in relation to the House of the People, every party which has a strength of not less than`
  line `thirty members and not more than fifty-four members in the House;`
  line
  line `(b) "recognised party" means,--`
  line
  line `(i) in relation to the Council of States, every party which has a strength of not less than`
  line `twenty-five members in the Council;`
  line
  line `(ii) in relation to the House of the People, every party which has a strength of not less than`
  line `fifty-five members in the House.]`
obj_root_law_sections_3:
  sectionId (10733)
  sectionNo (3)
  orderNo 3
  title `Facilities to the Leaders and Chief Whips of recognised groups and parties.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by s.4, ibid., for section 3 (w.e.f. 7-6-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00004_199905_1517807323998&sectionId=10733&sectionno=3&orderno=3&orgactid=AC_CEN_33_52_00004_199905_1517807323998
obj_root_law_sections_3_content:
  string
  line `^1[3. Facilities to the Leaders and Chief Whips of recognised groups and parties.--Subject to any`
  line `rules made in this behalf by the Central Government, each leader, deputy leader and each Chief Whip of a`
  line `recognised group and a recognised party shall be entitled to telephone and secretarial facilities:`
  line
  line `Provided that such facilities shall not be provided to such leader, deputy leader or Chief Whip, as the`
  line `case may be, who--`
  line
  line `(i)holds an office of Minister as defined in section 2 of the Salaries and Allowances of Ministers`
  line `Act, 1952 (58 of 1952); or`
  line
  line `(ii)holds an office of the Leader of the Opposition as defined in section 2of the Salary and`
  line `Allowances of Leaders of Opposition in Parliament Act, 1977 (33 of 1977); or`
  line
  line `(iii)is entitled to similar telephone and secretarial facilities by virtue of holding any office of, or`
  line `representation in, a Parliamentary Committee or other Committee, Council, Board, Commission or`
  line `other body set up by the Government; or`
  line
  line `(iv)is entitled to similar telephone and secretarial facilities provided to him in any other capacity`
  line `by the Government or a local authority or Corporation owned or controlled by the Government or any`
  line `local authority.]`
obj_root_law_sections_4:
  sectionId (10734)
  sectionNo (4)
  orderNo 4
  title `Power to make rules.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00004_199905_1517807323998&sectionId=10734&sectionno=4&orderno=4&orgactid=AC_CEN_33_52_00004_199905_1517807323998
obj_root_law_sections_4_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the provisions of this Act.`
  line
  line `(2) Every rule made under sub-section (1) shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (10735)
  sectionNo (5)
  orderNo 5
  title `Amendment of section 3 of Act 10 of 1959.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by Act 18 of 2000, s. 5, for "each leader" (w.e.f. 5-2-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00004_199905_1517807323998&sectionId=10735&sectionno=5&orderno=5&orgactid=AC_CEN_33_52_00004_199905_1517807323998
obj_root_law_sections_5_content:
  string
  line `In the Parliament (Prevention of Disqualification)`
  line `Act, 1959, in section 3,--`
  line
  line `(i) after clause (ab),the following clause shall be inserted, namely:--`
  line
  line `"(ac) the office of ^1 [each leader and each deputy leader] of a recognised party and a`
  line `recognised group in either House of Parliament;";`
  line
  line `(ii) after Explanation 2, the following Explanation shall be inserted, namely:--`
  line
  line `Explanation 3.--.In clause (ac),the expressions "recognised party" and "recognised group"`
  line `shall have the meanings assigned to them in Leaders and Chief Whips of Recognised Parties and`
  line `Groups in Parliament (Facilities)Act, 1998.'.`
