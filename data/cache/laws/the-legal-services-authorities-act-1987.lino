obj_root_law:
  object
  (str slug) (str the-legal-services-authorities-act-1987)
  (str handle) (str 1925)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Legal Services Authorities Act, 1987`)
  (str actNumber) (str 39)
  (str enactmentDate) (str 1987-10-11)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1925`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `विधिक सेवा प्राधिकरण अधिनियम, 1987`)
  (str actYear) (str 1987)
  (str ministry) (str `Ministry of Law and Justice`)
  (str department) (str `Department of Justice`)
  (str longTitle) (str `An Act to constitute legal services authorities to provide free and competent legal services to the weaker sections of the society to ensure that opportunities for securing justice are not denied to any citizen by reason of economic or other disabilities, and to organise Lok Adalats to secure that the operation of the legal system promotes justice on a basis of equal opportunity.`)
  (str enforcementDate) (str 09-11-1995)
  (str notification) (str `9th November, 1995, vide notification No. S.O. 893(E), dated 9th November, 1995, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T21:28:40.799Z`)
  (str translations) obj_root_law_translations
