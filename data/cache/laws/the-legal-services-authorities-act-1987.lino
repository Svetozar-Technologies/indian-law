obj_root_law:
  slug the-legal-services-authorities-act-1987
  handle (1925)
  collectionHandle 123456789/1362
  title `The Legal Services Authorities Act, 1987`
  actNumber (39)
  enactmentDate 1987-10-11
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1925`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `विधिक सेवा प्राधिकरण अधिनियम, 1987`
  actYear (1987)
  ministry `Ministry of Law and Justice`
  department `Department of Justice`
  longTitle `An Act to constitute legal services authorities to provide free and competent legal services to the weaker sections of the society to ensure that opportunities for securing justice are not denied to any citizen by reason of economic or other disabilities, and to organise Lok Adalats to secure that the operation of the legal system promotes justice on a basis of equal opportunity.`
  enforcementDate 09-11-1995
  notification `9th November, 1995, vide notification No. S.O. 893(E), dated 9th November, 1995, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T21:28:40.799Z`
  translations obj_root_law_translations
