obj_root_law:
  object
  (str slug) (str the-coal-bearing-areas-acquisition-and-development-act-1957)
  (str handle) (str 13051)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Coal Bearing Areas (Acquisition and Development) Act, 1957`)
  (str actNumber) (str 20)
  (str enactmentDate) (str 1957-06-08)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/13051`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `कोयला धारक क्षेत्र (अर्जन और विकास) अधिनियम, 1957`)
  (str actYear) (str 1957)
  (str ministry) (str `Ministry of Coal`)
  (str department) (undefined)
  (str longTitle) (str `An Act to establish in the economic interest of India greater public control over the coal mining industry and its development by providing for the acquisition by the State of unworked land containing or likely to contain coal deposits or of rights in or over such land, for the extinguishment or modification of such rights accruing by virtue of any agreement, lease, licence or otherwise, and for matters connected therewith.`)
  (str enforcementDate) (str 12-06-1957)
  (str notification) (str `12th June, 1957, vide Notification No. S.R.O. 1931 (E), dated 10th June, 1957, see Gazette of India, Extraordinary, Part II, sec. 3(i).`)
  (str fetchedAt) (str `2026-05-09T20:32:41.265Z`)
