  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70558&sectionno=61&orderno=60&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_62:
  object
  (str sectionId) (str 70559)
  (str sectionNo) (str 62)
  (str orderNo) (int 61)
  (str title) (str `Commencement of Part III.`)
  (str content) (str `This part shall come into force on such day3
as the Lieutenant
Governor of the North-Western Provinces and Chief Commissioner of Oudh may, by notification in the
Official Gazette, direct.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70559&sectionno=62&orderno=61&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_63:
  object
  (str sectionId) (str 70560)
  (str sectionNo) (str 63)
  (str orderNo) (int 62)
  (str title) (str `Place where the Board may sit.`)
  (str content) (str `(1) Notwithstanding anything ^1
*** in section 128 of the
Oudh Rent Act, 1886 (22 of 1886), the Board of Revenue of the North-Western Provinces and Oudh
shall, for the disposal of cases under those Acts, sit in such place or places in the North-Western
Provinces or Oudh as ^2[
the State Government] may, by notification in the Official Gazette,6
appoint in
respect to cases under either of those Acts.

(2) For the disposal of cases other than those referred to in sub-section (1) the said Board may,
subject to the orders of ^2[the State Government], sit in any place in the North-Western Provinces or
Oudh that the Board thinks fit.`)
  (str footnotes) (str `1. Section 63, so far as it relates to Act 12 of 1881, that is the words “in s. 152 of the North-Western Provinces Rent
Act, 1881, or” were rep. by the Agra Tenancy Act, 1901 (U.P. 2 of 1901).

2.Subs. by the A.O. 1937 for “the said Lieutenant-Governor and Chief Commissioner”`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70560&sectionno=63&orderno=62&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_64:
  object
  (str sectionId) (str 70561)
  (str sectionNo) (str 64)
  (str orderNo) (int 63)
  (str title) (str [Repealed.].)
  (str content) (str `[Amendment of section 4, Act 19 of 1873.] Rep. by the United Provinces Land-revenue
Act, 1901 (U.P. Act 3 of 1901).`)
