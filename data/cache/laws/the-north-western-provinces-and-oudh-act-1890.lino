  sectionNo (62)
  orderNo 61
  title `Commencement of Part III.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70559&sectionno=62&orderno=61&orgactid=AC_CEN_5_5_00114_189020_1666335792135
obj_root_law_sections_62_content:
  string
  line `This part shall come into force on such day3`
  line `as the Lieutenant`
  line `Governor of the North-Western Provinces and Chief Commissioner of Oudh may, by notification in the`
  line `Official Gazette, direct.`
obj_root_law_sections_62_footnotes:
  string
  line
