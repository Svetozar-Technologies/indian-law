obj_root_law_sections_1:
  object
  (str sectionId) (str 70499)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str Title.)
  (str content) (str `This Act may be called the North-Western Provinces and Oudh Act, 1890.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70499&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_2:
  object
  (str sectionId) (str 70500)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Commencement of Part I.`)
  (str content) (str `This Part shall come into force on such day^1
as the said LieutenantGovernor may, by notification in the Official Gazette, direct.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70500&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_3:
  object
  (str sectionId) (str 70501)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `3 and 4 Repealed.`)
  (str content) (str `Amendment of Act 19 of 1873. Rep. by the United Provinces Land-revenue Act, 1901
(U.P. Act 3 of 1901).

And whereas it has been determined to annex the Jhansi Division, comprising the districts of Jhansi,
Jalaun and Lalatpur, to the Allahabad Division;
And whereas the said Jhansi Division is a Schedule District under the Scheduled Districts
Act, 1874; (14 of 1874);^2

And whereas it is expedient that the law in force in the same division should, on such annexation, be
the same as the law in force in the temporarily-settled districts comprised in the Allahabad Division, and
that the said division should cease to be a Schedule District;

It is hereby enacted as follows:—`)
  (str footnotes) (str `1. The 1st April, 1891, see North-Western Provinces and Oudh Gazette,1891, Pt. I, p. 130.

2. Since rep. by the A.O. 1937`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70501&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_5:
  object
  (str sectionId) (str 70502)
  (str sectionNo) (str 5)
  (str orderNo) (int 4)
  (str title) (str `Laws in force in certain districts of the Allahabad Division to apply to Jhansi.`)
  (str content) (str `(1) All
enactments which shall on the day^1 when this Part comes into force be in force in the said temporarilysettled districts and not in the said Jhansi Division shall be deemed to come into force in that Division
on and from the said day^1.
(2) Except the Jhansi Encumbered Estates Act, 1882, (16 of 1882)^2
and the Jhansi and Morar
Act, 1886,(17 of 1886)^3
all enactments which shall on the said day^1
be in force in the said division and
not in the said temporarily settled districts, including the Jhansi Courts Act, 1867 (18 of 1867), and
Act No. 27 of 1867, shall be deemed to be repealed on and from the said day^1
in the said division.`)
  (str footnotes) (str `1. That is, the 1st April, 1891.

2. Since rep. by the Bundelkhand
Encumbered Estates Act, 1903 (U.P. 1 of 1903).

3. Rep. by Act 42 of 1953.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70502&sectionno=5&orderno=4&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_6:
  object
  (str sectionId) (str 70503)
  (str sectionNo) (str 6)
  (str orderNo) (int 5)
  (str title) (str [Repealed.].)
  (str content) (str `Rep. by the Bundelkhand Encumbered Estates Act, 1903 (U.P.
Act 1 of 1903).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70503&sectionno=6&orderno=5&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_7:
  object
  (str sectionId) (str 70564)
  (str sectionNo) (str 7)
  (str orderNo) (int 6)
  (str title) (str `Discharge of functions assigned to Deputy Commissioner and Commissioner by Act 17 of 1866.`)
  (str content) (str `The functions assigned to the Deputy Commissioner and the Commissioner by the Jhansi and
Morar Act, 1886^1
(17 of 1886), shall be discharged by the District Judge and the High Court,
respectively, and references to Courts in the Jhansi district subordinate to the Commissioner shall be
deemed to apply to the Civil Courts established in that district under the Bengal, ^2North-Western
Provinces and Assam Civil Courts Act, 1887 (12 of 1887).`)
  (str footnotes) (str `1. Rep. by Act 42 of 1953.

2. “Agra” has been subs. for “North-Western Provinces” by Act 16 of 1911.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70564&sectionno=7&orderno=6&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_8:
  object
  (str sectionId) (str 70505)
  (str sectionNo) (str 8)
  (str orderNo) (int 7)
  (str title) (str `Jhansi Division to cease to be a Scheduled District.`)
  (str content) (str `(1) On and from the said day^1
the said
division shall cease to be a Schedule District ^2***.`)
  (str footnotes) (str `1. That is, the 1st April, 1891.

2. The second clause of sub-section (1), and sub-section (2) were rep. by Act 1 of 1938, s. 2 and Sch`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70505&sectionno=8&orderno=7&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_9:
  object
  (str sectionId) (str 70506)
  (str sectionNo) (str 9)
  (str orderNo) (int 8)
  (str title) (str `Application of Act 12 of 1887 to Jhansi, and disposal of pending cases.`)
  (str content) (str `^1***
(2) All cases or proceedings pending in any Civil Court in the said division on the said day^2
shall
be disposed of as follows:—

(a) if pending in theCourt of a Tahsildar or of an Assistant Commissioner of the second class—
by the Munsif;

(b) if pending in the Court of an Assistant Commissioner of the first class—by the Subordinate
Judge;

(c) if pending in the Court of a Deputy Commissioner—by the District Judge;

(d) if pending in the Court of the Commissioner—by the District Judge, unless the case
pending is an appeal from a decree or order of the Deputy Commissioner, in which case the appeal
shall be disposed of by the High Court.

(3) For the purposes of sections 20 to 22, both inclusive, of the Bengal, ^3North-Western Provinces
and Assam Civil Courts Act, 1887 (12 of 1887), all decrees and orders passed by Civil Courts in the
said division and not appealed against before the said day3
shall be deemed—

(a) if passed by the Court of a Tahsildar or an Assistant Commissioner of the second class—to
have been passed by a Munsif;

(b) if passed by the Court of an Assistant Commissioner of the first class—to have been passed
by a Subordinate Judge;

(c) if passed by the Court of a Deputy Commissioner or the Commissioner—to have been
passed by a District Judge.

(4) Where any Civil Court ceases by reason of the passing of this Act to have jurisdiction with
respect to any case, any proceeding in relation to that case which, if that Court had not ceased to have
jurisdiction, might have been had therein, may be had in the Court to which the business of the former
Court is transferred by sub-section (2); but this sub-section shall not apply to cases for which provision
is made in section 623 or section 649 of the Code of Civil Procedure1
(14 of 1882).

(5) In the case of appeals from the decrees and orders mentioned in sub-section (3) the period of
limitation shall be calculated in accordance with the provisions of section 15 of the Jhansi Courts
Act, 18672
(18 of 1867), as though this Act had not been passed.`)
  (str footnotes) (str `1.Sub-section (1) rep., by Act 1 of 1938.

2. That is, the 1st April, 1891.

3. “Agra” has been subs. for “North-Western Provinces” by Act 16 of 1911.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70506&sectionno=9&orderno=8&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_10:
  object
  (str sectionId) (str 70507)
  (str sectionNo) (str 10)
  (str orderNo) (int 9)
  (str title) (str `Commencement of Part II.`)
  (str content) (str `This Part shall come into force on such day^1
as the Chief
Commissioner of Oudh may, by notification in the Official Gazette, direct.`)
  (str footnotes) (str `1. 1st January, 1891, see the North-Western Provinces and Oudh
Gazette, 1890, Pt. I, p.661.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70507&sectionno=10&orderno=9&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
obj_root_law_sections_11:
  object
  (str sectionId) (str 70565)
  (str sectionNo) (str 11)
  (str orderNo) (int 10)
  (str title) (str `Board of Revenue of the North-Western Provinces to be the Board of Revenue of, and Chief Revenue-authority in, Oudh.`)
  (str content) (str `(1) On and from the day on which this Part comes into force
the Board of Revenue constituted under the North-Western Provinces Land-revenue Act, 1873^1
(19 of 1873), shall be deemed to be also the Board of Revenue for the territories administered by the Chief Commissioner of Oudh, and shall be known and designated as the Board of Revenue of the NorthWestern Provinces and Oudh^2.

(2) All references made in any enactment as amended by this Part to the Board of Revenue shall be
deemed, so far as they relate to Oudh, to refer to the said Board.

(3) In any enactment for the time being in force in the territories administered by the Chief
Commissioner of Oudh, in which the expression “Chief Revenue-authority” or “Chief Controlling
Revenue-authority” is used, the expression shall, subject to the provisions of any enactment passed
after the said day^3
, be construed, so far as the said territories are concerned, as referring to the Board
of Revenue of the North-Western Provinces and Oudh^2
.`)
  (str footnotes) (str `1. Since rep. by the U.P. Land-revenue Act,1901 (U.P. 3 of 1901), s. 2, but not so as to affect anything done under Act 19 of
1873, see s. 3.

2. Now the Board of Revenue of the U.P.

3. 1st January, 1891, see the North-Western Provinces and Oudh Gazette, 1890, Pt. I, p.661.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70565&sectionno=11&orderno=10&orgactid=AC_CEN_5_5_00114_189020_1666335792135)
