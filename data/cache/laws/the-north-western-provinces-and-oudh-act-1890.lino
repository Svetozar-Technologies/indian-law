obj_root_law_sections_54:
  sectionId (70551)
  sectionNo (54)
  orderNo 53
  title `Pending appeals.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_189020_1666335792135&sectionId=70551&sectionno=54&orderno=53&orgactid=AC_CEN_5_5_00114_189020_1666335792135
obj_root_law_sections_54_content:
  string
  line `All appeals pending when this Part comes into force^1`
  line `from decrees or`
  line `orders passed under the same Act shall be disposed of`
  line `as if this Act had not been passed:`
  line
  line `Provided that the ^2[`
  line `State Government] may, by order, transfer to the District Judge any appeals then`
  line `pending before the Commissioner or Collector in cases in which the appeal will, under the Oudh Rent`
  line `Act, 1886, (22 of 1886) as amended by this Part, lie to the District Judge.`
obj_root_law_sections_54_footnotes:
  string
  line `1. That is, the 1st January, 1891.`
  line
  line `2. Subs. by the A.O. 1937 for “Chief Commissioner”`
