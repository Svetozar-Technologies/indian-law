obj_root_law_sections_1:
  sectionId (39298)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00031_198802_1517807321952&sectionId=39298&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00031_198802_1517807321952
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Chandigarh (Delegation of Powers) Act,`
  line 1987.
  line
  line `(2) It extends to the whole of the Union territory of Chandigarh.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39299)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00031_198802_1517807321952&sectionId=39299&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00031_198802_1517807321952
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires, "Administrator" means the`
  line `administrator of the Union territory of Chandigarh appointed by the President under article 239 of the`
  line Constitution.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39300)
  sectionNo (3)
  orderNo 3
  title `Delegation of powers, etc., vested in Administrator.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00031_198802_1517807321952&sectionId=39300&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00031_198802_1517807321952
obj_root_law_sections_3_content:
  string
  line `(1) Any power, authority or jurisdiction or`
  line `any duty which the Administrator may exercise or discharge under any law in force in the Union territory`
  line `of Chandigarh may be exercised or discharged also by such officer or other authority as may be specified`
  line `in this behalf by the Central Government or the Administrator by notification in the Official Gazette.`
  line
  line `(2) The Administrator may transfer any appeal or application for revision or any other matter`
  line `pending before him for disposal to an officer or other authority competent under sub-section (1) to`
  line `dispose of the same.`
  line
  line `(3) The Administrator may withdraw for disposal by himself any appeal or application for revision or`
  line `any other matter pending before an officer or other authority competent under sub-section (1) to dispose`
  line `of the same.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39301)
  sectionNo (4)
  orderNo 4
  title Validation.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00031_198802_1517807321952&sectionId=39301&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00031_198802_1517807321952
obj_root_law_sections_4_content:
  string
  line `Notwithstanding any judgment, decree or order of any court or tribunal or other`
  line `authority to the contrary, where any power, authority or jurisdiction or any duty which the Administrator`
  line `may exercise or discharge under any law in force in the Union territory of Chandigarh had been exercised`
  line `or discharged by any officer or other authority before the commencement of this Act, such power,`
  line `authority, jurisdiction or duty shall be deemed to have been validly and effectively exercised or`
  line `discharged by such officer or other authority as if the provisions of sub-section (1) of section 3 were in`
  line `force at all material times when such power, authority or jurisdiction was exercised or such duty was`
  line `discharged and that officer or other authority had been specified as an officer or other authority by the`
  line `Central Government or the Administrator in that behalf under the said sub-section, and accordingly, no`
  line `suit or other proceeding shall be instituted, maintained or continued in any court or tribunal or before`
  line `other authority on the ground that such officer or other authority was not competent to exercise such`
  line `power, authority or jurisdiction or to discharge such duty.`
obj_root_law_sections_4_footnotes:
  string
  line
