obj_root_law_sections_1:
  sectionId (21401)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21401&sectionno=1&orderno=1&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Cinematograph`
  line `Act, 1952.`
  line
  line `(2) Parts I, II and IV extends to the whole of India ^1* * * and Part III extends to ^2`
  line `[the Union`
  line `territories] only.`
  line
  line `(3) This Act shall come into force on such date^3`
  line `as the Central Government may, by notification in`
  line `the Official Gazette, appoint:`
  line
  line `^4* * * * *`
  line
  line `STATE AMENDMENTS`
  line
  line `Ladakh (UT).--`
  line
  line `Section 1.---In sub-section (3), omit the proviso.`
  line
  line `[Vide Union Territory of Ladakh Reorganisation (Adaptation of Central Laws) Order, 2020, notification`
  line `No. S.O. 3774(E), dated (23-10-2020).]`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" omitted by Act 25 of 1973, s. 2.`
  line
  line `2. Subs. by Act 3 of 1959, s. 2, for "Part C States".`
  line
  line `3. 28th July, 1952, Information and Broadcasting Ministry's Notification No. S.R.O.`
  line
  line `1066, dated the 10th June, 1952, see Gazette`
  line `of India, 1952, Part II, s. 3.`
  line
  line `4. The Proviso omitted by Act 12 of 2023, s. 3 (w.e.f. 11-8-2023).`
obj_root_law_sections_2:
  sectionId (21402)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21402&sectionno=2&orderno=2&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) adult means a person who has completed his eighteenth year;`
  line
  line `^1[(b) Board means the Board of Film Certification constituted by the Central Government under`
  line `section 3;]`
  line
  line `^2[(bb) certificate means the certificate granted by the Board under section 5A;]`
  line
  line `(c) cinematograph includes any apparatus for the representation of moving pictures or series of`
  line pictures;
  line
  line `(d) district magistrate, in relation to a presidency-town, means the Commissioner of Police;`
  line
  line `^3[(dd) "film" means a cinematograph film;]`
  line
  line `^4[(ddd) "infringing copy" shall have the same meaning as assigned to it in sub-clause (ii) of clause (m) of`
  line `section 2 of the Copyright Act, 1957 (14 of 1957);]`
  line
  line `(e) place includes a house, building, tent and any description of transport, whether by sea, land`
  line `or air;`
  line
  line `(f) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^5[(g) "regional officer" means a regional officer appointed by the Central Government under`
  line `section 5 and includes an additional regional officer and an assistant regional officer;`
  line
  line `^6* * * * *.`
  line
  line `^7[(i) "UA marker" means an age-based indicator for a film which has received or is intended to`
  line `receive a "UA" Certificate under section 4 and such indicator may be "UA 7+" or "UA 13+" or "UA`
  line `16+":`
  line
  line `Provided that where the Central Government is satisfied that it is necessary or expedient so to do`
  line `in public interest, it may, by an order published in the Official Gazette and for the reasons to be`
  line `recorded in writing, declare such other indicators.]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 49 of 1981, s. 2, for clause (b) (w.e.f. 1-6-1983).`
  line
  line `2. Ins. by s. 2, ibid. (w.e.f. 1-6-1983).`
  line
  line `3. Ins. by Act 3 of 1959, s. 3.`
  line
  line `4. Ins. by Act 12 of 2023, s. 4 (w.e.f. 11-8-2023).`
  line
  line `5. Ins. by Act 49 of 1981, s. 2 (w.e.f. 1-6-1983).`
  line
  line `6. Clause (h) omitted by Act 33 of 2021, s. 9 (w.e.f.4-4-2021).`
  line
  line `7. Ins. by Act 12 of 2023, s. 4 (w.e.f. 11-8-2023).`
obj_root_law_sections_2_a:
  sectionId (21403)
  sectionNo 2A
  orderNo 3
  title `Construction of references to any law not in force or any functionary not in existence in the State of Jammu and Kashmir.`
  content obj_root_law_sections_2_a_content
  footnotes obj_root_law_sections_2_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21403&sectionno=2A&orderno=3&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_2_a_content:
  string
  line `2A. [Construction of references to any law not in force or any functionary not in existence in the`
  line `State of Jammu and Kashmir.]--Omitted by the Jammu and Kashmir Reorganization (Adaptation of`
  line `Central Laws) Order, 2020, vide notification No. S.O. 1123(E) dated (18-3-2020) and Vide Union`
  line `Territory of Ladakh Reorganisation (Adaptation of Central Laws) Order, 2020, notification No. S.O.`
  line `3774(E), dated (23-10-2020).`
obj_root_law_sections_2_a_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (21404)
  sectionNo (3)
  orderNo 4
  title `Board of film Certification.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21404&sectionno=3&orderno=4&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_3_content:
  string
  line `^1[3. Board of film Certification.--(1) For the purpose of sanctioning films for public exhibition, the`
  line `Central Government may, by notification in the Official Gazette, constitute a Board to be called the`
  line `^2[Board of Film Certification] which shall consist of a Chairman and ^3[not less than twelve and not more`
  line `than twenty-five] other members appointed by the Central Government.`
  line
  line `(2) The Chairman of the Board shall receive such salary and allowances as may be determined by the`
  line `Central Government, and the other members shall receive such allowances or fees for attending the`
  line `meetings of the Board as may be prescribed.`
  line
  line `(3) The other terms and conditions of service of the members of the Board shall be such as may be`
  line prescribed.]
  line
  line `^4[(4) Whoever aggrieved by any penalty imposed under clauses (d) to (f) of sub-section (1) or section`
  line `14, may prefer an appeal to such appellate authority within such period and in such form and manner as`
  line `may be prescribed.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 3 of 1959, s. 4, for sections 3 to 6.`
  line
  line `2. Subs. by Act 49 of 1981, s. 3, for "Board of Film Censors" (w.e.f. 1-6-1983).`
  line
  line `3. Subs. by s. 3, ibid., for "not more than nine" (w.e.f. 1-6-1983).`
  line
  line `4. Ins. by Act 18 of 2023, s. 2 and the Schedule (w.e.f. 1-9-2023).`
  line
  line `5. Subs. by Act 12 of 2023, s. 5, for section 4 (w.e.f. 11-8-2023).`
obj_root_law_sections_4:
  sectionId (21405)
  sectionNo (4)
  orderNo 5
  title `Examination of films.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 12 of 2023, s. 5, for section 4 (w.e.f. 11-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21405&sectionno=4&orderno=5&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_4_content:
  string
  line `^1[4. Examination of films.--(1) Any person desiring to exhibit any film shall make an application to`
  line `the Board for a certificate in such form and manner as may be prescribed.`
  line
  line `(2) The Board may, after examining the film in such manner as may be prescribed,--`
  line
  line `(i) sanction the film for unrestricted public exhibition:`
  line
  line `Provided that, having regard to any material in the film, if the Board is of the opinion that`
  line `viewing of such film by any child between seven to eighteen years of age is subject to guidance of`
  line `parents or lawful guardian, then the Board may sanction the film for unrestricted public exhibition`
  line `with an endorsement to that effect containing UA marker.`
  line
  line `Explanation.--For the removal of doubts, it is hereby clarified that--`
  line
  line `(a) the expression "seven" denotes completion of seven years of age and the expression`
  line `"eighteen" denotes before attaining the age of eighteen years;`
  line
  line `(b) an endorsement by the Board shall enable the parents and lawful guardian of the child to consider`
  line `whether such child should view such a film, and shall not be enforced by any person other than the parents`
  line `or lawful guardian of the child;`
  line
  line `(ii) sanction the film for public exhibition restricted to adults;`
  line
  line `(iii) sanction the film for public exhibition restricted to members of any profession or any class of persons`
  line `having regard to the nature, content and theme of the film;`
  line
  line `(iv) direct the applicant to carry out such excisions or modifications in the film as it may deem necessary`
  line `before sanctioning the film for public exhibition under clauses (i), (ii) and (iii); or`
  line
  line `(v) refuse to sanction the film for public exhibition:`
  line
  line `Provided that no action under this section shall be taken by the Board, unless the applicant has been given`
  line `an opportunity of being heard in the matter.`
  line
  line `(3) Any person desiring to exhibit on television or such other media as may be prescribed, any film which has`
  line `been sanctioned by the Board under clause (ii) or clause (iii) of sub-section (2), may make an application to the`
  line `Board in such form and manner as may be prescribed, and the Board may, for this purpose, sanction the film with a`
  line `separate certificate, after directing the applicant to carry out such excisions or modifications in the film as it may`
  line `think fit.]`
obj_root_law_sections_5:
  sectionId (21406)
  sectionNo (5)
  orderNo 6
  title `Advisory panels.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21406&sectionno=5&orderno=6&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_content:
  string
  line `(1) For the purpose of enabling the Board to efficiently discharge its functions`
  line `under this Act, the Central Government may establish at such regional centers as it thinks fit, advisory`
  line `panels each of which shall consist of such number of persons, being persons qualified in the opinion of`
  line `the Central Government to judge the effect of films on the public, as the Central Government may think`
  line `fit to appoint thereto.`
  line
  line `(2) At each regional center there shall be as many regional officers as the Central Government may`
  line `think fit to appoint, and rules made in this behalf may provide for the association of regional officers in`
  line `the examination of films.`
  line
  line `(3) The Board may consult in such manner as may be prescribed, any advisory panel in respect of any`
  line `film for which an application for a certificate has been made.`
  line
  line `(4) It shall be the duty of every such advisory panel whether acting as a body or in committees as may`
  line `be provided in the rules made in this behalf to examine the film and to make such recommendations to the`
  line `Board as it thinks fit.`
  line
  line `(5) The members of the advisory panel shall not be entitled to any salary but shall receive such fees or`
  line `allowances as may be prescribed.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_5_a:
  sectionId (21407)
  sectionNo 5A
  orderNo 7
  title `Certification of films.`
  content obj_root_law_sections_5_a_content
  footnotes `1. Subs. by s. 5, ibid., for sub-section (1) (w.e.f. 1-6-1983).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21407&sectionno=5A&orderno=7&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_a_content:
  string
  line `^1[(1) If, after examining a film or having it examined in the prescribed`
  line `manner, the Board considers that--`
  line
  line `(a) the film is suitable for unrestricted public exhibition, or, as the case may be, for unrestricted`
  line `public exhibition with an endorsement of the nature mentioned in the proviso to clause (i) of`
  line `sub-section (1) of section 4, it shall grant to the person applying for a certificate in respect of the film`
  line `a "U" certificate or, as the case may be, a "UA" certificate; or`
  line
  line `(b) the film is not suitable for unrestricted public exhibition, but is suitable for public exhibition`
  line `restricted to adults or, as the case may be, is suitable for public exhibition restricted to members of`
  line `any profession or any class of persons, it shall grant to the person applying for a certificate in respect`
  line `of the film an "A" certificate or, as the case may be, a "S" certificate,`
  line
  line `and cause the film to be so marked in the prescribed manner:`
  line
  line `Provided that the applicant for the certificate, any distributor or exhibitor or any other person to`
  line `whom the rights in the film have passed shall not be liable for punishment under any law relating to`
  line `obscenity in respect of any matter contained in the film for which certificate has been granted under`
  line `clause (a) or clause (b).]`
  line
  line `(2) A certificate granted or an order refusing to grant a certificate in respect of any film shall be`
  line `published in the Gazette of India.`
  line
  line `(3) Subject to the other provisions contained in this Act, a certificate granted by the Board under this`
  line `section shall be valid throughout India for a period of ten years.`
obj_root_law_sections_5_b:
  sectionId (21408)
  sectionNo 5B
  orderNo 8
  title `Principles of guidance in certifying films.`
  content obj_root_law_sections_5_b_content
  footnotes `1 Ins. by s. 6, ibid. (w.e.f. 1-6-1983).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21408&sectionno=5B&orderno=8&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_b_content:
  string
  line `(1) A film shall not be certified for public`
  line `exhibition if, in the opinion of the authority competent to grant the certificate, the film or any part of it is`
  line `against the interests of ^1[the sovereignty and integrity of India] the security of the State, friendly relations with foreign States, public order, decency or morality, or involves defamation or contempt of court or is`
  line `likely to incite the commission of any offence.`
  line
  line `(2) Subject to the provisions contained in sub-section (1), the Central Government may issue such`
  line `directions as it may think fit setting out the principles which shall guide the authority competent to grant`
  line `certificates under this Act in sanctioning films for public exhibition.`
obj_root_law_sections_5_c:
  sectionId (21409)
  sectionNo 5C
  orderNo 9
  title Appeals.
  content obj_root_law_sections_5_c_content
  footnotes obj_root_law_sections_5_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21409&sectionno=5C&orderno=9&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_c_content:
  string
  line `^1[5C. Appeals.--(1) Any person applying for a certificate in respect of a film who is aggrieved by`
  line `any order of the Board--`
  line
  line `(a) refusing to grant a certificate; or`
  line
  line `(b) granting only an A certificate; or`
  line
  line `(c) granting only a S certificate; or`
  line
  line `(d) granting only a UA certificate; or`
  line
  line `(e) directing the applicant to carry out any excisions or modifications,`
  line `may, within thirty days from the date of such order, prefer an appeal to the ^2[High Court]:`
  line
  line `Provided that the ^2[High Court] may, if it is satisfied that the appellant was prevented by sufficient cause`
  line `from filing the appeal within the aforesaid period of thirty days, allow such appeal to be admitted within a`
  line `further period of thirty days.`
  line
  line ^3*****
obj_root_law_sections_5_c_footnotes:
  string
  line `1. Subs. by Act 49 of 1981, s. 7, for section 5C (w.e.f. 1-6-1983).`
  line
  line `2. Subs. by Act 33 of 2021, s. 9, for "Tribunal" (w.e.f. 4-4-2021).`
  line
  line `3. Sub-section (2) omitted by s. 9, ibid. (w.e.f. 4-4-2021).`
obj_root_law_sections_5_d:
  sectionId (21410)
  sectionNo 5D
  orderNo 10
  title `Constitution of Appellate Tribunal.`
  content obj_root_law_sections_5_d_content
  footnotes `1. Ins. by s. 8, ibid. (w.e.f. 1-6-1983).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21410&sectionno=5D&orderno=10&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_d_content:
  string
  line `^1[5D. Constitution of Appellate Tribunal.--(1) For the purpose of hearing appeals against any order`
  line `of the Board under section 5C, the Central Government shall, by notification in the Official Gazette,`
  line `constitute an Appellate Tribunal.`
  line
  line `(2) The head office of the Tribunal shall be at New Delhi or at such other place as the Central`
  line `Government may, by notification in the Official Gazette, specify.`
  line
  line `(3) Such Tribunal shall consist of a Chairman and not more than four other members appointed by the`
  line `Central Government.`
  line
  line `(4) A person shall not be qualified for appointment as the Chairman of the Tribunal unless he is a`
  line `retired Judge of a High Court, or is a person who is qualified to be a Judge of a High Court.`
  line
  line `(5) The Central Government may appoint such persons who, in its opinion, are qualified to judge the`
  line `effect of films on the public, to be members of the Tribunal.`
  line
  line `(6) The Chairman of the Tribunal shall receive such salary and allowances as may be determined by`
  line `the Central Government and the members shall receive such allowances or fees as may be prescribed.`
  line
  line `(7) Subject to such rules as may be made in this behalf, the Central Government may appoint a`
  line `Secretary and such other employees as it may think necessary for the efficient performance of the`
  line `functions of the Tribunal under this Act.`
  line
  line `(8) The Secretary to, and other employees of, the Tribunal shall exercise such powers and perform`
  line `such duties as may be prescribed after consultation with the Chairman of the Tribunal.`
  line
  line `(9) The other terms and conditions of service of the Chairman and members of, and the Secretary to,`
  line `and other employees of, the Tribunal shall be such as may be prescribed.`
  line
  line `(10) Subject to the provisions of this Act, the Tribunal may regulate its own procedure.`
  line
  line `(11) The Tribunal may, after making such inquiry into the matter as it considers necessary, and after`
  line `giving the appellant and the Board an opportunity of being heard in the matter, make such order in`
  line `relation to a film as it thinks fit and the Board shall dispose of the matter in conformity with such order.]`
obj_root_law_sections_5_dd:
  sectionId (77196)
  sectionNo 5DD
  orderNo 11
  title Omitted.
  content obj_root_law_sections_5_dd_content
  footnotes obj_root_law_sections_5_dd_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=77196&sectionno=5DD&orderno=11&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_dd_content:
  string
  line `[Qualifications, terms and conditions of service of Chairman and Member]--Omitted by`
  line `s. 9, ibid., (w.e.f. 4-4-2021).`
obj_root_law_sections_5_dd_footnotes:
  string
  line
obj_root_law_sections_5_e:
  sectionId (21411)
  sectionNo 5E
  orderNo 12
  title `Suspension and revocation of certificate.`
  content obj_root_law_sections_5_e_content
  footnotes `1. Ins. by s. 8, ibid. (w.e.f. 1-6-1983).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21411&sectionno=5E&orderno=12&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_e_content:
  string
  line `^1[5E. Suspension and revocation of certificate.--(1) Notwithstanding anything contained in`
  line `sub-section (2) of section 6, the Central Government may, by notification in the Official Gazette, suspend`
  line `a certificate granted under this Part, for such period as it thinks fit or may revoke such certificate if it is`
  line `satisfied that--`
  line
  line `(i) the film in respect of which the certificate was granted, was being exhibited in a form other`
  line `than the one in which it was certified; or`
  line
  line `(ii) the film or any part thereof is being exhibited in contravention of the provisions of this Part or`
  line `the rules made thereunder.`
  line
  line `(2) Where a notification under sub-section (1) has been published, the Central Government may`
  line `require the applicant for certificate or any other person to whom the rights in the film have passed, or`
  line `both, to deliver up the certificate and all duplicate certificates, if any, granted in respect of the film to the`
  line `Board or to any person or authority specified in the said notification.`
  line
  line `(3) No action under this section shall be taken except after giving an opportunity to the person`
  line `concerned for representing his views in the matter.`
  line
  line `(4) During the period in which a certificate remains suspended under this section, the film shall be`
  line `deemed to be an uncertified film.]`
obj_root_law_sections_5_f:
  sectionId (21412)
  sectionNo 5F
  orderNo 13
  title `Review of orders by Central Government.`
  content obj_root_law_sections_5_f_content
  footnotes `1. Ins. by s. 8, ibid. (w.e.f. 1-6-1983).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21412&sectionno=5F&orderno=13&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_5_f_content:
  string
  line `^1[5F. Review of orders by Central Government.--(1) Where an applicant for a certificate or any`
  line `other person to whom the rights in the film have passed, is aggrieved by any order of the Central`
  line `Government under section 5E, he may, within sixty days of the date of publication of the notification in`
  line `the Official Gazette, make an application to the Central Government for review of the order, setting out in`
  line `such application the grounds on which he considers such review to be necessary:`
  line
  line `Provided that the Central Government may, if it is satisfied that the applicant for a certificate or that`
  line `other person was prevented by sufficient cause from filing an application for review within the aforesaid`
  line `period of sixty days, allow such application to be filed within a further period of sixty days.`
  line
  line `(2) On receipt of the application under sub-section (1), the Central Government may, after giving the`
  line `aggrieved person a reasonable opportunity of being heard, and after making such further inquiry, as it`
  line `may consider necessary, pass such order as it thinks fit, confirming, modifying or reversing its decision`
  line `and the Board shall dispose of the matter in conformity with such order.]`
obj_root_law_sections_6:
  sectionId (21413)
  sectionNo (6)
  orderNo 14
  title `Revisonal powers of the Central Government.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21413&sectionno=6&orderno=14&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_6_content:
  string
  line `6. Revisional powers of the Central Government.--2***`
  line `(2)`
  line `^2[Subject to the provisions of this Act], the Central Government may, by notification in the`
  line `Official Gazette, direct that--`
  line
  line `(a) a film which has been granted a certificate shall be deemed to be an uncertified film in the`
  line `whole or any part of India; or.`
  line
  line `(b) a film which has been granted a "U" certificate ^3]or a ^4[ ‘"UA" Certificate with any UA marker] or`
  line `a "S" certificate] shall be deemed to be a film in respect of which an "A" certificate has been granted;`
  line or
  line
  line `(c) the exhibition of any film be suspended for such period as may be specified in the direction:`
  line `Provided that no direction issued under clause (c) shall remain in force for more than two months`
  line `from the date of the notification.`
  line
  line `(3) No action shall be taken under clause (a) or clause (b) of sub-section (2) except after giving an`
  line `opportunity to the person concerned for representing his views in the matter.`
  line
  line `(4) During the period in which a film remains suspended under clause (c) of sub-section (2), the film`
  line `shall be deemed to be an uncertified film.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Sub-section (1) omitted by Act 12 of 2023, s. 7 (w.e.f. 11-8-2023).`
  line
  line `2. Subs. by s. 7, ibid., for "Without prejudice to the powers conferred on it under sub-section (1)" (w.e.f. 11-8-2023).`
  line
  line `3. Subs. by Act 49 of 1981, s. 9, for "may at any stage" (w.e.f. 1-6-1983).`
  line
  line `4. Subs. by Act 12 of 2023, s. 2, for ‘ "UA" certificate’ (w.e.f. 11-8-2023).`
obj_root_law_sections_6_a:
  sectionId (21414)
  sectionNo 6A
  orderNo 15
  title `Information and documents to be given to distributors and exhibitors with respect to certified films.`
  content obj_root_law_sections_6_a_content
  footnotes `1. Ins. by Act 19 of 1953, s. 3 (w.e.f. 1-6-1983).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21414&sectionno=6A&orderno=15&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_6_a_content:
  string
  line `^1[6A. Information and documents to be given to distributors and exhibitors with respect to`
  line `certified films.--Any person who delivers any certified film to any distributor or exhibitor shall, in such`
  line `manner as may be prescribed, notify to the distributor or exhibitor, as the case may be, the title, the length`
  line `of the film, the number and the nature of the certificate granted in respect thereof and the conditions, if`
  line `any, subject to which it has been so granted, and any other particulars respecting the film which may be`
  line prescribed.]
obj_root_law_sections_6_aa:
  sectionId (77197)
  sectionNo 6AA
  orderNo 16
  title `Prohibition of unauthorized recording`
  content obj_root_law_sections_6_aa_content
  footnotes `1. Ins. by Act 12 of 2023, s. 8 (w.e.f. 11-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=77197&sectionno=6AA&orderno=16&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_6_aa_content:
  string
  line `^1[6AA. Prohibition of unauthorised recording--No person shall use any audio-visual recording device in a`
  line `place licensed to exhibit films with the intention of making or transmitting or attempting to make or transmit or`
  line `abetting the making or transmission of an infringing copy of such film or a part thereof.`
  line
  line `Explanation.--For the purposes of this section, the expression "audio-visual recording device" means a digital`
  line `or analogue photographic or video camera, or any other technology or device capable of enabling the recording or`
  line `transmission of a copyrighted cinematographic film or any part thereof, regardless of whether audio-visual recording`
  line `is the sole or primary purpose of the device.]`
obj_root_law_sections_6_ab:
  sectionId (77198)
  sectionNo 6AB
  orderNo 17
  title `Prohibition of unauthorized exhibition of films.`
  content obj_root_law_sections_6_ab_content
  footnotes `1. Ins. by Act 12 of 2023, s. 8 (w.e.f. 11-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=77198&sectionno=6AB&orderno=17&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_6_ab_content:
  string
  line `^1[6AB. Prohibition of unauthorised exhibition of films.-- No person shall use or abet the use of an infringing`
  line `copy of any film to exhibit to the public for profit--`
  line
  line `(a) at a place of exhibition which has not been licensed under this Act or the rules made thereunder; or`
  line
  line `(b) in a manner that amounts to the infringement of copyright under the provisions of the Copyright Act, 1957`
  line `(14 of 1957) or any other law for the time being in force.]`
obj_root_law_sections_6_b:
  sectionId (21415)
  sectionNo 6B
  orderNo 18
  title [Omitted.].
  content obj_root_law_sections_6_b_content
  footnotes obj_root_law_sections_6_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21415&sectionno=6B&orderno=18&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_6_b_content:
  string
  line `[Offences to be cognizable]--Omitted by the Cinematograph (Amendment) Act, 1984 s. 2`
  line `(w.e.f. 27-8-1984).`
obj_root_law_sections_6_b_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (21416)
  sectionNo (7)
  orderNo 19
  title `Penalties for contraventions of this Part.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21416&sectionno=7&orderno=19&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_7_content:
  string
  line `^1[(1) If any person--`
  line
  line `(a) without lawful authority (the burden of proving which shall be on such person) alters or tampers`
  line `in any way any film after it has been certified, he shall be punishable with imprisonment for a term which`
  line `may extend to three years or with fine which shall not be less than ten lakh rupees, or with both;`
  line
  line `(b) exhibits or permits to be exhibited in any place, any`
  line
  line `(i) which has not been certified by the Board;`
  line
  line `(ii) which, when exhibited does not display the prescribed mark of the Board;`
  line
  line `(iii) which, when exhibited displays a mark of the Board which has since been altered or`
  line `tampered with, after the mark has been affixed, he shall be punishable with imprisonment for a term`
  line `which may extend to three years or with fine which may extend to ten lakh rupees, or with both and in`
  line `the case of a continuing offence with a further fine which may extend to one lakh rupees for each day`
  line `during which the offence continues;`
  line
  line `(c) exhibits or permits to be exhibited in any place, a video film in contravention of the provisions of`
  line `clause (a) or clause (b), he shall be punishable with imprisonment for a term which may extend to three`
  line `years or with fine which may extend to ten lakh rupees, or with both, and in the case of a continuing`
  line `offence with a further fine which may extend to one lakh rupees for each day during which the offence`
  line continues;
  line
  line `(d) exhibits or permits to be exhibited any film, which has been certified by the Board as "A" within`
  line `the meaning of this Act to any minor, such person shall be liable to penalty not exceeding ten thousand`
  line `rupees per person for every such exhibition, levied by the authorised officer in such manner as may be`
  line prescribed;
  line
  line `(e) exhibits or permits to be exhibited any film, which has been certified by the Board as "S" within`
  line `the meaning of this Act, to a person who is not a member of such profession or class, shall be liable to`
  line `penalty not exceeding ten thousand rupees per person for every such exhibition, levied by the authorised`
  line `officer in such manner as may be prescribed;`
  line
  line `(f) fails to comply with the provisions contained in section 6A or with any order made by the Central`
  line `Government or by the Board in the exercise of any of the powers or functions conferred on it by this Act`
  line `or the rules made thereunder, he shall be liable to penalty not exceeding five lakh rupees, levied by the`
  line `authorised officer and in such manner as may be prescribed:`
  line
  line `Provided that notwithstanding anything contained in section 29 of the Code of Criminal Procedure,`
  line `1973 (2 of 1974), it shall be lawful for any Metropolitan Magistrate, or any Judicial Magistrate of the`
  line `First Class specially empowered by the State Government in this behalf, to pass a sentence of fine`
  line `exceeding five thousand rupees on any person convicted of any offence punishable under this Part under`
  line `clauses (a) to (c):`
  line
  line `Provided further that no distributor or exhibitor or owner or employee of a cinema house shall be`
  line `liable to punishment for contravention of any condition of endorsement of caution that has been certified`
  line `as "UA" under this Part.`
  line
  line `^2[(1A) Save as otherwise provided in section 52 of the Copyright Act, 1957 (14 of 1957), if any`
  line `person contravenes the provisions of section 6AA or section 6AB, he shall be punishable with`
  line `imprisonment for a term which shall not be less than three months, but may extend to three years and with`
  line `a fine which shall not be less than three lakh rupees but may extend to five per cent. of the audited gross`
  line `production cost.`
  line
  line `(1B) Notwithstanding anything contained in this section--`
  line
  line `(i) a person aggrieved by a contravention under section 6AA or section 6AB shall not be`
  line `prevented from taking suitable action for an infringement under section 51 of the Copyright Act, 1957`
  line `(14 of 1957) or from taking suitable action for computer related offences under section 66 of the`
  line `Information Technology Act, 2000 (21 of 2000) or any other relevant laws for the time being in force;`
  line
  line `(ii) the appropriate Government or its agencies shall not be prevented from taking suitable action`
  line `against an intermediary as defined under clause (w) of sub-section (1) of section 2 of the Information Technology Act, 2000 (21 of 2000), where such intermediary acts in the manner as set out under`
  line `sub-section (3) of section 79 of the said Act or any other law for the time being in force.`
  line
  line `Explanation.--For the purposes of this sub-section, the expression "appropriate Government"`
  line `shall have the same meaning as assigned to it in clause (e) of sub-section (1) of section 2 of the`
  line `Information Technology Act, 2000 (21 of 2000).]`
  line
  line `(2) If any person is convicted of an offence punishable under this section committed by him in`
  line `respect of any film, the convicting court may further direct that the film shall be forfeited to the`
  line Government.
  line
  line `(3) The exhibition of a film, in respect of which an "A" certificate ^3[or a "S" certificate or a`
  line `^4["UA" Certificate with any UA marker]] has been granted, to children below the age of three years`
  line `accompanying their parents or guardians shall not be deemed to be an offence within the meaning of this`
  line section.
  line
  line `^5["(4) Whoever aggrieved by any imposed under clauses (d) to (f) of sub-section (1) or section 14, may`
  line `prefer an appeal to such appellate authority within such period and in such form and manner as may be`
  line prescribed.]
obj_root_law_sections_7_footnotes:
  string
  line `1. Subs. by Act 18 of 2023, s. 2 and the Schedule, for sub-section (1) (w.e.f. 1-9-2023).`
  line
  line `2. Ins. by Act 12 of 2023, s. 9 (w.e.f. 11-8-2023).`
  line
  line `3. Ins. by Act 49 of 1981, s. 11 (w.e.f. 1-6-1983).`
  line
  line `4. Subs. by Act 12 of 2023, s. 2, for "UA" certificate (w.e.f. 11-8-2023).`
  line
  line `5. Ins. by Act 18 of 2023, s. 2 and the Schedule (w.e.f. 1-9-2023).`
obj_root_law_sections_7_a:
  sectionId (21417)
  sectionNo 7A
  orderNo 20
  title `Power of seizure.`
  content obj_root_law_sections_7_a_content
  footnotes obj_root_law_sections_7_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21417&sectionno=7A&orderno=20&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_7_a_content:
  string
  line `^1[7A. Power of seizure.--(1) Where a film in respect of which no certificate has been granted under`
  line `this Act is exhibited, or a film certified as suitable for public exhibition restricted to adults is exhibited to`
  line `any person who is not an adult or a film is exhibited in contravention of any of the other provisions`
  line `contained in this Act or of any order made by the Central Government ^2[, the ^3[High Court] ] or the Board in the`
  line `exercise of any of the powers conferred on it, any police officer may, ^4* * * enter any place in which he`
  line `has reason to believe that the film has been or is being or is likely to be exhibited, search it and seize the`
  line film.
  line
  line `(2) All searches under this Act shall be carried out in accordance with the provisions of the ^5[Code of`
  line `Criminal Procedure, 1973 (2 of 1974)], relating to searches.]`
obj_root_law_sections_7_a_footnotes:
  string
  line `1. Ins. by Act 3 of 1959, s. 5.`
  line
  line `2. Ins. by Act 49 of 1981, s. 12 (w.e.f. 1-6-1983).`
  line
  line `3. Subs. by Act 33 of 2021, s. 9, for “Tribunal” (w.e.f. 4-4-2021).`
  line
  line `4. Certain words omitted by s. 12, ibid. (w.e.f. 1-6-1983).`
  line
  line `5. Subs. by s. 12, ibid., for Code of Criminal Procedure, 1898 (5 of 1898) (w.e.f. 1-6-1983).`
obj_root_law_sections_7_b:
  sectionId (21418)
  sectionNo 7B
  orderNo 21
  title `Delegation of powers by Board.`
  content obj_root_law_sections_7_b_content
  footnotes obj_root_law_sections_7_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21418&sectionno=7B&orderno=21&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_7_b_content:
  string
  line `^1[7B. Delegation of powers by Board.--^2[(1)] The Central Government may, by general or special`
  line `order, direct that any power, authority or jurisdiction exercisable by the Board under this Act shall, ^3[in`
  line `relation to the certification of the films under this Part] and subject to such condition, if any, as may be`
  line `specified in the order, be exercisable also by the Chairman or any other member of the Board, and`
  line `anything done or action taken by the Chairman or other member specified in the order shall be deemed to`
  line `be a thing done or action taken by the Board.`
  line
  line `^4[(2) The Central Government may, by order and subject to such conditions and restrictions as may be`
  line `prescribed, authorise the regional officers to issue provisional certificates.]]`
obj_root_law_sections_7_b_footnotes:
  string
  line `1. Ins. by Act 3 of 1959, s. 5.`
  line
  line `2 Section 7B re-numbered as sub-section (1) thereof by Act 49 of 1981, s. 13 (w.e.f. 1-6-1983).`
  line
  line `3 Subs. by s. 13, ibid., for "in relation to such matters" (w.e.f. 1-6-1983).`
  line
  line `4 Ins. by s. 13, ibid. (w.e.f. 1-6-1983).`
obj_root_law_sections_7_c:
  sectionId (21419)
  sectionNo 7C
  orderNo 22
  title `Power to direct exhibition of films for examination.`
  content obj_root_law_sections_7_c_content
  footnotes obj_root_law_sections_7_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21419&sectionno=7C&orderno=22&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_7_c_content:
  string
  line `^1[7C. Power to direct exhibition of films for examination. --- For the purpose of exercising any of the`
  line `powers conferred on it by this Act, the Central Government ^2[, the ^3[High Court] ]or the Board may require any`
  line `any film to be exhibited before it or before ^4[any person or authority] specified by it in this behalf.]`
obj_root_law_sections_7_c_footnotes:
  string
  line `1. Ins. by s. 8, ibid. (w.e.f. 1-6-1983).`
  line
  line `2. Ins. by s. 14, ibid. (w.e.f. 1-6-1983).`
  line
  line `3. Subs. by Act 33 of 2021, s. 9, for Tribunal (w.e.f. 4-4-2021).`
  line
  line `4. Subs. by s. 14, ibid., for any person (w.e.f. 1-6-1983).`
obj_root_law_sections_7_d:
  sectionId (21420)
  sectionNo 7D
  orderNo 23
  title `Vacancies, etc., not to invalidate proceeding.`
  content obj_root_law_sections_7_d_content
  footnotes obj_root_law_sections_7_d_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21420&sectionno=7D&orderno=23&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_7_d_content:
  string
  line `^1[7D. Vacancies, etc., not to invalidate proceeding.-- No act or proceeding of ^1***, the`
  line `Board or of any advisory panel shall be deemed to be invalid by reason only of a vacancy in, or any defect`
  line `in, the constitution of ^1*** the Board or panel, as the case may be.]`
obj_root_law_sections_7_d_footnotes:
  string
  line `1. Ins. by s. 8, ibid. (w.e.f. 1-6-1983).`
  line
  line `2. The words “the Tribunal” omitted by Act 33 of 2021, s. 9 (w.e.f. 4-4-2021).`
obj_root_law_sections_7_e:
  sectionId (21421)
  sectionNo 7E
  orderNo 24
  title `Members of the Board and advisory panels to be public servants.`
  content obj_root_law_sections_7_e_content
  footnotes obj_root_law_sections_7_e_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21421&sectionno=7E&orderno=24&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_7_e_content:
  string
  line `^1[7E. Members of the Board and advisory panels to be public servants.-- All members of ^2*** the Board and of any advisory panel shall, when acting or purporting to act in pursuance of any`
  line `of the provisions of this Act, be deemed to be public servants within the meaning of section 21 of the`
  line `Indian Penal Code (45 of 1860).]`
obj_root_law_sections_7_e_footnotes:
  string
  line `1. Ins. by s. 8, ibid. (w.e.f. 1-6-1983).`
  line
  line `2. The words “the Tribunal” omitted by Act 33 of 2021, s. 9 (w.e.f. 4-4-2021).`
obj_root_law_sections_7_f:
  sectionId (21422)
  sectionNo 7F
  orderNo 25
  title `Bar of legal proceedings.`
  content obj_root_law_sections_7_f_content
  footnotes obj_root_law_sections_7_f_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21422&sectionno=7F&orderno=25&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_7_f_content:
  string
  line `^1[7F. Bar of legal proceedings.-- No suit or other legal proceeding shall lie against ^2[the Central`
  line `Government, the ^3**** the Board], advisory panel or any officer or member of ^4[the Central`
  line `Government, the Tribunal, the Board or] advisory panel, as the case may be, in respect of anything which`
  line `is in good faith done or intended to be done under this Act.]`
obj_root_law_sections_7_f_footnotes:
  string
  line `1. Ins. by s. 8, ibid. (w.e.f. 1-6-1983).`
  line
  line `2. Subs. by s. 17, ibid., for the Central Government, the Board (w.e.f. 1-6-1983).`
  line
  line `3.The words the Tribunal omitted by Act 33 of 2021, s. 9 (w.e.f. 4-4-2021).`
  line
  line `4. Subs. by s. 17, ibid., for the Central Government, Board or (w.e.f. 1-6-1983).`
obj_root_law_sections_8:
  sectionId (21423)
  sectionNo (8)
  orderNo 26
  title `Power to make rules.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21423&sectionno=8&orderno=26&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_8_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for the purpose of carrying into effect the provisions of this Part.`
  line
  line `^1[(2) In particular, and without prejudice to the generality of the foregoing power, rules made under`
  line `this section may provide for--`
  line
  line `(a) the allowances or fees payable to the members of the Board;`
  line
  line `(b) the terms and conditions of service of the members of the Board;`
  line
  line `^2[(c) the form and manner of making an application to the Board for a certificate under`
  line `sub-section (1) of section 4;`
  line
  line `(ca) the manner of examination of film under sub-section (2) of section 4;`
  line
  line `(cb) the media for exhibition of film and the form and manner of making an application to the`
  line `Board in this regard under sub-section (3) of section 4;]`
  line
  line `^3[(cc) the authorised officer and the manner of levy of penalty by him in terms of clauses (d) to (f)`
  line `of sub-section (1) of section 7;`
  line
  line `(cd) the period, form and manner of preferring appeal and appellate authority under sub-section`
  line `(4) of section 7;]`
  line
  line `(d) the association of regional officers in the examination of films, the conditions and restrictions`
  line `subject to which regional officers may be authorised under section 7B to issue provisional certificates`
  line `and the period of validity of such certificates;`
  line
  line `(e) the manner in which the Board may consult any advisory panel in respect of any film;`
  line
  line `(f) the allowances or fees payable to the members of advisory panel;`
  line
  line `(g) the marking of the films;`
  line
  line `^4** * * *;`
  line
  line `(l) the conditions (including conditions relating to the length of films in general or any class of`
  line `films, in particular) subject to which any certificate may be granted, or the circumstances in which`
  line `any certificate shall be refused;`
  line
  line `(m) any other matter which is required to be or may be prescribed.]`
  line
  line `^5[(3) Every rule made by the Central Government under this Part shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall,`
  line `thereafter, have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
obj_root_law_sections_8_footnotes:
  string
  line `1. Subs. by Act 49 of 1981, s. 18, for sub-section (2) (w.e.f. 1-6-1983).`
  line
  line `2. Subs. by Act 12 of 2023, s. 10 for clause (c) (w.e.f. 11-8-2023).`
  line
  line `3. Ins. by Act 18 of 2023, s. 2 and the Schedule (w.e.f. 1-9-2023).`
  line
  line `4. Clauses (h), (i), (j) and (k) omitted by Act 33 of 2021, s. 9 (w.e.f. 4-4-2021).`
  line
  line `5. Subs. by Act 25 of 1973, s. 4, for sub-section (3).`
obj_root_law_sections_9:
  sectionId (21424)
  sectionNo (9)
  orderNo 27
  title `Power to exempt.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21424&sectionno=9&orderno=27&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_9_content:
  string
  line `The Central Government may, by order in writing exempt, subject to such`
  line `conditions and restrictions, if any, as it may impose, the exhibition of any film or class of films from any of`
  line `the provisions of this Part or of any rules made thereunder.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (21425)
  sectionNo (10)
  orderNo 28
  title `Cinematograph exhibitions to be licensed.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21425&sectionno=10&orderno=28&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_10_content:
  string
  line `Save as otherwise provided in this Part, no person`
  line `shall give an exhibition by means of a cinematograph elsewhere than in a place licensed under this Part or`
  line `otherwise than in compliance with any conditions and restrictions imposed by such licence.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (21426)
  sectionNo (11)
  orderNo 29
  title `Licensing authority.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 58 of 1960, s. 3 and Schedule II, for "Part C State".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21426&sectionno=11&orderno=29&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_11_content:
  string
  line `The authority having power to grant licences under this Part (hereinafter`
  line `referred to as the licensing authority) shall be the district magistrate:`
  line
  line `Provided that the State Government may, by notification in the Official Gazette, constitute, for the`
  line `whole or any part of a ^1[Union territory], such other authority as it may specify in the notification to be`
  line `the licensing authority for the purposes of this Part.`
obj_root_law_sections_12:
  sectionId (21427)
  sectionNo (12)
  orderNo 30
  title `Restrictions on powers of licensing authority.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21427&sectionno=12&orderno=30&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_12_content:
  string
  line `(1) The licensing authority shall not grant a`
  line `licence under this Part, unless it is satisfied that--`
  line
  line `(a) the rules made under this Part have been substantially complied with, and`
  line
  line `(b) adequate precautions have been taken in the place, in respect of which the licence is to be`
  line `given, to provide for the safety of persons attending exhibitions therein.`
  line
  line `(2) Subject to the foregoing provisions of this section and to the control of the State Government, the`
  line `licensing authority may grant licences under this Part to such persons as that authority thinks fit and on`
  line `such terms and conditions and subject to such restrictions as it may determine.`
  line
  line `(3) Any person aggrieved by the decision of a licensing authority refusing to grant a licence under this`
  line `Part may, within such time as may be prescribed, appeal to the State Government or to such officer as the`
  line `State Government may specify in this behalf and the State Government or the officer, as the case may be,`
  line `may make such order in the case as it or he thinks fit.`
  line
  line `(4) The Central Government may, from time to time, issue directions to licensees generally or to any`
  line `licensee in particular for the purpose of regulating the exhibition of any film or class of films, so that`
  line `scientific films, films intended for educational purposes, films dealing with news and current events,`
  line `documentary films or indigenous films secure an adequate opportunity of being exhibited, and where any`
  line `such directions have been issued those directions shall be deemed to be additional conditions and`
  line `restrictions subject to which the licence has been granted.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (21428)
  sectionNo (13)
  orderNo 31
  title `Power of Central Government or local authority to suspend exhibition of films in certain cases.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 58 of 1960, s. 3 and Schedule II, for "whole Part C State or any part thereof".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21428&sectionno=13&orderno=31&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_13_content:
  string
  line `(1) The Lieutenant-Governor or, as the case may be, the Chief Commissioner, in respect of the`
  line `^1[whole or any part of a Union territory], and the District Magistrate in respect of the district within his`
  line `jurisdiction, may, if he is of opinion that any film which is being publicly exhibited is likely to cause a`
  line `breach of the peace, by order, suspend the exhibition of the film and during such suspension the film shall`
  line `be deemed to be an uncertified film in the State, part or district, as the case may be.`
  line
  line `(2) Where an order under sub-section (1) has been issued by the Chief Commissioner or a District`
  line `Magistrate, as the case may be, a copy thereof, together with a statement of reasons therefore, shall`
  line `forthwith be forwarded by the person making the same to the Central Government, and the Central`
  line `Government may either confirm or discharge the order.`
  line
  line `(3) An order made under this section shall remain in force for a period of two months from the date`
  line `thereof, but the Central Government may, if it is of opinion that the order should continue in force, direct`
  line `that the period of suspension shall be extended by such further period as it thinks fit.`
obj_root_law_sections_14:
  sectionId (21429)
  sectionNo (14)
  orderNo 32
  title `Penalties for contravention of this Part.`
  content obj_root_law_sections_14_content
  footnotes `1. Subs. by Act 18 of 2023, s. 2 and the Schedule for the certain words (w.e.f. 1-9-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21429&sectionno=14&orderno=32&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_14_content:
  string
  line `If the owner or person in charge of a cinematograph`
  line `uses the same or allows it to be used, or if the owner or occupier of any place permits that place to be used`
  line `in contravention of the provisions of this Part or of the rule made thereunder, or of the conditions and`
  line `restrictions upon or subject to which any licence has been granted under this Part, he shall be ^1[liable to`
  line `penalty of one lakh rupees and, in the case of a continuing contravention, with a further penalty which`
  line `may extend to ten thousand rupees for each day during which the contravention continues.]`
obj_root_law_sections_15:
  sectionId (21430)
  sectionNo (15)
  orderNo 33
  title `Power to revoke or suspend licence.`
  content obj_root_law_sections_15_content
  footnotes `1. Subs. by s. 2 and the Schedule, ibid., for section 15 (w.e.f. 1-9-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21430&sectionno=15&orderno=33&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_15_content:
  string
  line `^1[15. Power to revoke or suspend licence.--(1) Where the holder of a licence has been convicted of`
  line `an offence under clauses (a) to (c) of sub-section (1) of section 7, the licence may be revoked by the`
  line `licensing authority.`
  line
  line `(2) Where the holder of a licence has been imposed penalty for contravention under clauses (d) to`
  line `(f) of sub-section (1) of section 7 or section 14, the licence may be suspended by the licensing authority`
  line `for a period not exceeding thirty days:`
  line
  line `Provided that in cases of more than three contraventions over a period of three years, the licensing`
  line `authority, may, for the reasons to be recorded in writing, by order, revoke the licence:`
  line
  line `Provided further that no order under this section shall be made without giving the holder of the`
  line `licence a reasonable opportunity of being heard.]`
obj_root_law_sections_16:
  sectionId (21431)
  sectionNo (16)
  orderNo 34
  title `Power to make rules.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21431&sectionno=16&orderno=34&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_16_content:
  string
  line `^1[(1)] The Central Government may, by notification in the Official`
  line `Gazette, make rules--`
  line
  line `(a) prescribing the terms, conditions and restrictions, if any, subject to which licences may be`
  line `granted under this Part;`
  line
  line `(b) providing for the regulation of cinematograph exhibitions for securing the public safety;`
  line
  line `(c) prescribing the time within which and the conditions subject to which an appeal under`
  line `sub-section (3) of section 12 may be preferred.`
  line
  line `^2[(2) Every rule made by the Central Government under this Part shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
obj_root_law_sections_16_footnotes:
  string
  line `1. Section 16 re-numbered as sub-section (1) thereof by Act 49 of 1981, s. 19 (w.e.f. 1-6-1983).`
  line
  line `2. Ins. by s. 19, ibid. (w.e.f. 1-6-1983).`
obj_root_law_sections_17:
  sectionId (21432)
  sectionNo (17)
  orderNo 35
  title `Power to exempt.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21432&sectionno=17&orderno=35&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_17_content:
  string
  line `The Central Government may, by order in writing exempt, subject to such`
  line `conditions and restrictions as it may impose, any cinematograph exhibition or class of cinematograph`
  line `exhibitions from any of the provisions of this Part or of any rules made thereunder.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (21433)
  sectionNo (18)
  orderNo 36
  title Repeal.
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_29_41_00011_195237_1517807328551&sectionId=21433&sectionno=18&orderno=36&orgactid=AC_CEN_29_41_00011_195237_1517807328551
obj_root_law_sections_18_content:
  string
  line `The Cinematograph Act, 1918 (2 of 1918) is hereby repealed:`
  line
  line `Provided that in relation to Part A States and Part B States the repeal shall have effect only in so far as`
  line `the said Act relates to the sanctioning of cinematograph films for exhibition.`
obj_root_law_sections_18_footnotes:
  string
  line
