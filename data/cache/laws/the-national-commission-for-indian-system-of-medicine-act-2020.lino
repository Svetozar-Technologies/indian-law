obj_root_law_sections_1:
  sectionId (51234)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51234&sectionno=1&orderno=1&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Commission`
  line `for Indian System of Medicine Act, 2020.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act and any reference`
  line `in any such provision to the commencement of this Act shall be construed as a reference to the coming`
  line `into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 7th October, 2020--- S. 3,4,5,6,8,11,18,19,20,21,54 and 55 vide notification No. S.O. 3483(E), dated 7th October, 2020, see`
  line `Gazette of India, Extraordinary, Part II, sec. 3 (ii).`
  line
  line `11th June, 2021--- (All the remaining provisions) vide notification No. S.O. 2278(E), dated 11th June, 2021. see`
  line `Gazette of India, Extraordinary, Part II, sec. 3 (ii).`
obj_root_law_sections_2:
  sectionId (51235)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51235&sectionno=2&orderno=2&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Autonomous Board" means any of the Autonomous Boards constituted under section 18;`
  line
  line `(b) "Board of Ayurveda" means the Board constituted under section 18;`
  line
  line `(c) "Board of Ethics and Registration for Indian System of Medicine" means the Board`
  line `constituted under section 18;`
  line
  line `(d) "Board of Unani, Siddha and Sowa-Rigpa" means the Board constituted under section 18;`
  line
  line `(e) "Chairperson" means the Chairperson of the National Commission for Indian System of`
  line `Medicine appointed under section 5;`
  line
  line `(f) "Commission" means the National Commission for Indian System of Medicine constituted`
  line `under section 3;`
  line
  line `(g) "Council" means the Advisory Council for Indian System of Medicine constituted under`
  line `section 11;`
  line
  line `(h) "Indian System of Medicine" means the Ashtang Ayurveda, Unani, Siddha and Sowa-Rigpa`
  line `Systems of Medicine supplemented by such modern advances, scientific and technological development as the Commission may, in consultation with the Central Government, declare by`
  line `notification from time to time;`
  line
  line `(i) "licence" means a licence to practice any of the Indian System of Medicine granted under`
  line `sub-section (1) of section 33;`
  line
  line `(j) "Medical Assessment and Rating Board for Indian System of Medicine" means the Board`
  line `constituted under section 18;`
  line
  line `(k) "medical institution" means any institution within or outside India which, grants degrees,`
  line `diplomas or licences in Indian System of Medicine and includes affiliated colleges and deemed to be`
  line Universities;
  line
  line `(l) "Member" means a Member of the Commission referred to in section 4 and includes the`
  line `Chairperson thereof;`
  line
  line `(m) "National Register" means a National Medical Register for Indian System of Medicine`
  line `maintained by the Board of Ethics and Registration for Indian System of Medicine under section 32;`
  line
  line `(n) "notification" means a notification published in the Official Gazette and the expression`
  line `"notify" shall be construed accordingly;`
  line
  line `(o) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(p) "President" means the President of an Autonomous Board appointed under section 20;`
  line
  line `(q) "regulations" means the regulations made by the Commission under this Act;`
  line
  line `(r) "State Medical Council" means a State Medical Council of Indian System of Medicine`
  line `constituted under any law for the time being in force in any State or Union territory for regulating the`
  line `practice and registration of practitioners of Indian System of Medicine in that State or Union territory;`
  line
  line `(s) "State Register" means a State Register for Indian System of Medicine maintained under any`
  line `law for the time being in force in any State or Union territory for registration of practitioners of`
  line `Indian System of Medicine;`
  line
  line `(t) "University" shall have the same meaning as assigned to it in clause (f) of section 2 of the`
  line `University Grants Commission Act, 1956 (3 of 1956) and includes a health university.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (51236)
  sectionNo (3)
  orderNo 3
  title `Constitution of National Commission for Indian System of Medicine.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51236&sectionno=3&orderno=3&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_3_content:
  string
  line `(1) The Central`
  line `Government shall, by notification, constitute a Commission, to be known as the National Commission for`
  line `Indian System of Medicine, to exercise the powers conferred upon, and to perform the functions assigned`
  line `to it, under this Act.`
  line
  line `(2) The Commission shall be a body corporate by the name aforesaid, having perpetual succession`
  line `and a common seal, with power, subject to the provisions of this Act, to acquire, hold and dispose of`
  line `property, both movable and immovable, and to contract, and shall, by the said name, sue or be sued.`
  line
  line `(3) The head office of the Commission shall be at New Delhi.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (51237)
  sectionNo (4)
  orderNo 4
  title `Composition of Commission.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51237&sectionno=4&orderno=4&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_4_content:
  string
  line `(1) The Commission shall consist of the following persons,`
  line `namely:--`
  line
  line `(a) a Chairperson;`
  line
  line `(b) fifteen ex officio Members; and`
  line
  line `(c) twenty-three part-time Members.`
  line
  line `(2) The Chairperson shall be a person of outstanding ability, proven administrative capacity and`
  line `integrity, possessing a postgraduate degree in any of the disciplines of Indian System of Medicine from a`
  line `recognised University and having experience of not less than twenty years in any field of Indian System`
  line `of Medicine, out of which at least ten years shall be as a leader in the area of healthcare delivery, growth`
  line `and development of Indian System of Medicine or its education.`
  line
  line `(3) The following persons shall be appointed by the Central Government as ex officio Members of the`
  line `Commission, namely:--`
  line
  line `(a) the President of the Board of Ayurveda;`
  line
  line `(b) the President of the Board of Unani, Siddha and Sowa-Rigpa;`
  line
  line `(c) the President of the Medical Assessment and Rating Board for Indian System of Medicine;`
  line
  line `(d) the President of the Board of Ethics and Registration for Indian System of Medicine;`
  line
  line `(e) Advisor (Ayurveda) or Joint Secretary to the Government of India in-charge of Ayurveda and`
  line `Advisor (Unani) or Joint Secretary to the Government of India in-charge of Unani, in the Ministry of`
  line AYUSH;
  line
  line `(f) the Director, All India Institute of Ayurveda, New Delhi;`
  line
  line `(g) the Director General, Central Council for Research in Ayurvedic Sciences, New Delhi;`
  line
  line `(h) the Director General, Central Council for Research in Unani Medicine, New Delhi;`
  line
  line `(i) the Director General, Central Council for Research in Siddha, Chennai;`
  line
  line `(j) the Director, National Institute of Siddha, Chennai;`
  line
  line `(k) the Director, National Institute of Unani, Bengaluru;`
  line
  line `(l) the Director, North Eastern Institute on Ayurveda and Homoeopathy, Shillong;`
  line
  line `(m) the Director, Institute of Post Graduate Teaching and Research in Ayurveda, Jamnagar; and`
  line
  line `(n) the Director, National Institute of Ayurveda, Jaipur.`
  line
  line `(4) The following persons shall be appointed by the Central Government as part-time Members of the`
  line `Commission, namely:--`
  line
  line `(a) four Members to be appointed from amongst persons of ability, integrity and standing, who`
  line `have special knowledge and professional experience in any of the disciplines of Indian System of`
  line `Medicine, Sanskrit, Urdu, Tamil, management, law, health research, science and technology and`
  line economics;
  line
  line `(b) ten Members to be appointed on rotational basis from amongst the nominees of the States and`
  line `Union territories in the Advisory Council for Indian System of Medicine for a term of two years in`
  line `such manner as may be prescribed;`
  line
  line `(c) six members from Ayurveda, one member each from Siddha, Unani and Sowa-Rigpa, to be`
  line `appointed from amongst the nominees of the States and Union territories, under clause (d) of`
  line `sub-section (2) of section 11, in the Advisory Council for Indian System of Medicine, for a term of`
  line `two years in such manner as may be prescribed:`
  line
  line `Provided that no Member shall either himself or through any of his family members, directly or`
  line `indirectly, own or be associated with or have any dealings with the managing body of a private or nongovernment medical institution which is regulated under this Act.`
  line
  line `Explanation.--For the purpose of this section and section 19, the term "leader" means the Head of a`
  line `Department or the Head of an Organisation.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (51238)
  sectionNo (5)
  orderNo 5
  title `Search Committee for appointment of Chairperson and Members.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51238&sectionno=5&orderno=5&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_5_content:
  string
  line `(1) The Central`
  line `Government shall appoint the Chairperson, referred to in section 4 and the President of the Autonomous`
  line `Boards referred to in section 20 on the recommendation of a Search Committee consisting of--`
  line
  line `(a) the Cabinet Secretary--Chairperson;`
  line
  line `(b) two experts, possessing outstanding qualifications and experience of not less than twenty-five`
  line `years in any of the fields of Indian System of Medicine, to be nominated by the Central`
  line Government--Members;
  line
  line `(c) one expert, from amongst the Members referred to in clause (c) of sub-section (4) of section 4,`
  line `to be nominated by the Central Government in such manner as may be prescribed--Member;`
  line
  line `(d) one person, possessing outstanding qualifications and experience of not less than twenty-five`
  line `years in the field of Sanskrit, Urdu, Tamil, health research, management, law, economics or science`
  line `and technology, to be nominated by the Central Government--Member;`
  line
  line `(e) the Secretary to the Government of India in charge of the Ministry of AYUSH, to be the`
  line `Convenor--Member:`
  line
  line `Provided that for selection of part-time Members of the Commission referred to in clause (a) of subsection (4) of section 4, the Secretary referred to in section 8 and other Members of the Autonomous`
  line `Boards referred to in section 20, the Search Committee shall consist of Members specified in the clauses`
  line `(b) to (d) and Joint Secretary to the Government of India in the Ministry of AYUSH as ConvenorMember and chaired by Secretary to the Government of India in charge of the Ministry of AYUSH.`
  line
  line `(2) The Central Government shall, within one month from the date of occurrence of any vacancy,`
  line `including by reason of death, resignation or removal of the Chairperson or a Member, or within three`
  line `months before the end of tenure of the Chairperson or Member, make a reference to the Search`
  line `Committee for filling up of the vacancy.`
  line
  line `(3) The Search Committee shall recommend a panel of at least three names for every vacancy referred`
  line `to it.`
  line
  line `(4) Before recommending any person for appointment as the Chairperson or a Member of the`
  line `Commission, the Search Committee shall satisfy itself that such person does not have any financial or`
  line `other interest which is likely to affect prejudicially his functions as such Chairperson or Member.`
  line
  line `(5) No appointment of the Chairperson or Member shall be invalid merely by reason of any vacancy`
  line `or absence of a Member in the Search Committee.`
  line
  line `(6) Subject to the provisions of sub-sections (2) to (5), the Search Committee may regulate its own`
  line procedure.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (51239)
  sectionNo (6)
  orderNo 6
  title `Term of office and conditions of service of Chairperson and Members.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51239&sectionno=6&orderno=6&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_6_content:
  string
  line `(1) The Chairperson`
  line `and Members (other than ex officio Members) and Members appointed under clauses (b) and (c) of`
  line `sub- section (4) of section 4 shall hold office for a term not exceeding four years and shall not be eligible`
  line `for any extension or re-appointment:`
  line
  line `Provided that such person shall cease to hold office after attaining the age of seventy years.`
  line
  line `(2) The term of office of an ex officio Member shall continue as long as he holds the office by virtue`
  line `of which he is such Member.`
  line
  line `(3) Where a Member, other than an ex officio Member, is absent from three consecutive ordinary`
  line `meetings of the Commission and the cause of such absence is not attributable to any valid reason in the`
  line `opinion of the Commission, such Member shall be deemed to have vacated the seat.`
  line
  line `(4) The salary and allowances payable to and other terms and conditions of service of the Chairperson`
  line `and Member, other than an ex officio Member, shall be such as may be prescribed.`
  line
  line `(5) The Chairperson or a Member may,--`
  line
  line `(a) relinquish his office by giving in writing a notice of not less than three months to the Central`
  line `Government; or`
  line
  line `(b) be removed from his office in accordance with the provisions of section 7:`
  line
  line `Provided that such person may be relieved from duties earlier than three months or allowed to`
  line `continue beyond three months until a successor is appointed, if the Central Government so decides.`
  line
  line `(6) The Chairperson and every Member of the Commission shall make declaration of his assets and`
  line `liabilities at the time of entering upon his office and at the time of demitting his office and also declare his`
  line `professional and commercial engagement or involvement, in such form and manner as may be prescribed,`
  line `and such declaration shall be published on the website of the Commission.`
  line
  line `(7) The Chairperson or a Member, ceasing to hold office as such, shall not accept, for a period of two`
  line `years from the date of demitting such office, any employment, in any capacity, including as a consultant`
  line `or an expert, in any private Medical institution of Indian System of Medicine or, whose matter has been`
  line `dealt with by such Chairperson or Member, directly or indirectly:`
  line
  line `Provided that nothing contained herein shall be construed as preventing such person from accepting`
  line `an employment in a body or institution including Medical institution of Indian System of Medicine,`
  line `controlled or maintained by the Central Government or a State Government.`
  line
  line `(8) Nothing in sub-section (7) shall prevent the Central Government from permitting the Chairperson`
  line `or a Member to accept any employment in any capacity, including as a consultant or an expert, in any`
  line `private Medical institution of Indian System of Medicine, whose matter has been dealt with by such`
  line `Chairperson or Member.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (51240)
  sectionNo (7)
  orderNo 7
  title `Removal of Chairperson and Members of Commission.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51240&sectionno=7&orderno=7&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_7_content:
  string
  line `(1) The Central Government may, by`
  line `order, remove from office, the Chairperson or any other Member, who--`
  line
  line `(a) has been adjudged an insolvent; or`
  line
  line `(b) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as the Chairperson or a Member; or`
  line
  line `(d) is of unsound mind and stands so declared by a competent court; or`
  line
  line `(e) has acquired such financial or other interest as is likely to affect prejudicially his functions as`
  line `a Member; or`
  line
  line `(f) has so abused his position as to render his continuance in office prejudicial to public interest.`
  line
  line `(2) No Member shall be removed under clauses (e) and (f) of sub-section (1) unless he has been`
  line `given a reasonable opportunity of being heard in the matter.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (51241)
  sectionNo (8)
  orderNo 8
  title `Appointment of Secretary, experts, professionals, officers and other employees of Commission.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51241&sectionno=8&orderno=8&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_8_content:
  string
  line `(1) There shall be a Secretariat for the Commission to be headed by a Secretary, to be`
  line `appointed by the Central Government in accordance with the provisions of section 5.`
  line
  line `(2) The Secretary of the Commission shall be a person of proven administrative capacity and`
  line `integrity, possessing such qualifications and experience as may be prescribed.`
  line
  line `(3) The Secretary shall be appointed by the Central Government for a term of four years and he shall`
  line `not be eligible for any extension or re-appointment.`
  line
  line `(4) The Secretary shall discharge such functions of the Commission as are assigned to him by the`
  line `Commission and as may be specified by regulations made under this Act.`
  line
  line `(5) The Commission may appoint such officers and other employees, as it considers necessary,`
  line `against the posts created by the Central Government for the efficient discharge of its functions under this`
  line Act.
  line
  line `(6) The salaries and allowances payable to, and other terms and conditions of service of the Secretary,`
  line `officers and other employees of the Commission shall be such as may be prescribed.`
  line
  line `(7) The Commission may engage, in accordance with the procedure specified by regulations, such`
  line `number of experts and professionals of integrity and outstanding ability, who have special knowledge of`
  line `Indian System of Medicine, and experience in fields including medical education in Indian System of`
  line `Medicine, public health, management, economics, accreditation, patient advocacy, health research,`
  line `science and technology, administration, finance, accounts or law as it deems necessary, to assist the`
  line `Commission in the discharge of its functions under this Act.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (51242)
  sectionNo (9)
  orderNo 9
  title `Meetings of Commission.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51242&sectionno=9&orderno=9&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_9_content:
  string
  line `(1) The Commission shall meet at least once every quarter at such`
  line `time and place as may be appointed by the Chairperson.`
  line
  line `(2) The Chairperson shall preside at the meeting of the Commission and if, for any reason, the`
  line `Chairperson is unable to attend a meeting of the Commission, any Member being the President of the`
  line `Autonomous Boards, nominated by the Chairperson shall preside at the meeting.`
  line
  line `(3) Unless the procedure to be followed at the meetings of the Commission is otherwise provided by`
  line `regulations, one-half of the total number of Members of the Commission including the Chairperson shall`
  line `constitute the quorum and all decisions of the Commission shall be taken by a majority of the members,`
  line `present and voting and in the event of equality of votes, the Chairperson or in his absence, the President`
  line `of the Autonomous Board nominated under sub-section (2), shall have the casting vote.`
  line
  line `(4) The general superintendence, direction and control of the administration of the Commission shall`
  line `vest in the Chairperson.`
  line
  line `(5) No act or proceeding of the Commission shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Commission; or`
  line
  line `(b) any defect in the appointment of a person acting as a Chairperson or as a Member.`
  line
  line `(6) A person who is aggrieved by any decision of the Commission, except the decision rendered`
  line `under sub-section (4) of section 31, may prefer an appeal to the Central Government against such decision`
  line `within fifteen days of the communication of such decision.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (51243)
  sectionNo (10)
  orderNo 10
  title `Power and functions of Commission.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51243&sectionno=10&orderno=10&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_10_content:
  string
  line `(1) The Commission shall perform the following`
  line `functions, namely:--`
  line
  line `(a) lay down policies for maintaining a high quality and high standards in education of Indian`
  line `System of Medicine and make necessary regulations in this behalf;`
  line
  line `(b) lay down policies for regulating medical institutions, medical researches and medical`
  line `professionals and make necessary regulations in this behalf;`
  line
  line `(c) assess the requirements in healthcare, including human resources for health and healthcare`
  line `infrastructure and develop a road map for meeting such requirements;`
  line
  line `(d) frame guidelines and lay down policies by making such regulations as may be necessary for`
  line `the proper functioning of the Commission, the Autonomous Boards and the State Medical Councils of`
  line `Indian System of Medicine;`
  line
  line `(e) ensure coordination among the Autonomous Boards;`
  line
  line `(f) take such measures, as may be necessary, to ensure compliance by the State Medical Councils`
  line `of Indian System of Medicine of the guidelines framed and regulations made under this Act for their`
  line `effective functioning under this Act;`
  line
  line `(g) exercise appellate jurisdiction with respect to decisions of the Autonomous Boards;`
  line
  line `(h) ensure observance of professional ethics in Medical profession and to promote ethical conduct`
  line `during the provision of care by medical practitioners;`
  line
  line `(i) frame guidelines for determination of fees and all other charges in respect of fifty per cent. of`
  line `seats in private medical institutions and deemed to be Universities which are governed under the`
  line `provisions of this Act;`
  line
  line `(j) exercise such other powers and perform such other functions as may be prescribed.`
  line
  line `(2) All orders and decisions of the Commission shall be authenticated by signature of the Secretary`
  line `and the Commission may delegate such of its powers on administrative and financial matters, as it deems`
  line `fit, to the Secretary.`
  line
  line `(3) The Commission may constitute sub-committees and delegate such of its powers to them as may`
  line `be necessary to enable them to accomplish specific tasks.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (51244)
  sectionNo (11)
  orderNo 11
  title `Constitution and composition of Advisory Council for Indian System of Medicine.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51244&sectionno=11&orderno=11&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_11_content:
  string
  line `(1) The`
  line `Central Government shall, by notification, constitute an advisory body to be known as the Advisory`
  line `Council for Indian System of Medicine.`
  line
  line `(2) The Council shall consist of a Chairperson and the following members, namely:--`
  line
  line `(a) the Chairperson of the Commission shall be the ex officio Chairperson of the Council;`
  line
  line `(b) every Member of the Commission shall be ex officio member of the Council;`
  line
  line `(c) one member, to represent each State, who is the Vice-Chancellor of a University in that State,`
  line `possessing qualifications in the Indian System of medicine, to be nominated by that State`
  line `Government, and one member to represent each Union territory, who is the Vice-chancellor of a`
  line `University in that Union territory, possessing qualifications in the Indian System of Medicine, to be`
  line `nominated by the Ministry of Home Affairs in the Government of India:`
  line
  line `Provided that where the Vice-Chancellor possessing qualifications in the Indian System of`
  line `Medicine is not available, a Dean or a Head of Faculty possessing qualifications in the Indian System`
  line `of Medicine shall be nominated;`
  line
  line `(d) one member to represent each State and each Union territory from amongst elected members`
  line `of the State Medical Council of Indian System of Medicine, to be nominated by that State Medical`
  line Council;
  line
  line `(e) the Chairman, University Grants Commission;`
  line
  line `(f) the Director, National Assessment and Accreditation Council;`
  line
  line `(g) four Members to be nominated by the Central Government from amongst persons holding the`
  line `post of Director in the Indian Institutes of Technology, Indian Institutes of Management and the`
  line `Indian Institutes of Science.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (51245)
  sectionNo (12)
  orderNo 12
  title `Functions of Advisory Council for Indian System of Medicine.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51245&sectionno=12&orderno=12&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_12_content:
  string
  line `(1) The Council shall be the`
  line `primary platform through which the States and Union territories may put forth their views and concerns before the Commission and help in shaping the overall agenda, policy and action relating to medical`
  line `education, training, research and development.`
  line
  line `(2) The Council shall advise the Commission on measures to determine and maintain, and to`
  line `coordinate maintenance of, the minimum standards in all matters relating to medical education, training,`
  line `research and development.`
  line
  line `(3) The Council shall advise the Commission on measures to enhance equitable access to medical`
  line education.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (51246)
  sectionNo (13)
  orderNo 13
  title `Meetings of Advisory Council for Indian System of Medicine.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51246&sectionno=13&orderno=13&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_13_content:
  string
  line `(1) The Council shall meet`
  line `atleast twice a year at such time and place as may be decided by the Chairperson.`
  line
  line `(2) The Chairperson shall preside at the meeting of the Council and if for any reason the Chairperson`
  line `is unable to attend a meeting of the Council, such other member as nominated by the Chairperson shall`
  line `preside over the meeting.`
  line
  line `(3) Unless the procedure is otherwise provided by regulations, one-half of the members of the`
  line `Council including the Chairperson shall form the quorum and all acts of the Council shall be decided by a`
  line `majority of the members present and voting.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (51247)
  sectionNo (14)
  orderNo 14
  title `National Eligibility-cum-Entrance Test.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51247&sectionno=14&orderno=14&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_14_content:
  string
  line `(1) There shall be a uniform National Eligibilitycum-Entrance Test for admission to the undergraduate courses in each of the disciplines of the Indian`
  line `System of Medicine in all medical institutions governed under this Act:`
  line
  line `Provided that National Eligibility-cum-Entrance Test shall be exempted for students who have taken`
  line `admission in--`
  line
  line `(i) Pre-tib for Bachelor of Unani Medicine and Surgery; and`
  line
  line `(ii) Pre-Ayurveda for Bachelor of Ayurvedic Medicine and Surgery.`
  line
  line `(2) The Commission shall conduct the National Eligibility-cum-Entrance Test in English and in such`
  line `other languages, through such designated authority and in such manner, as may be specified by`
  line regulations.
  line
  line `(3) The Commission shall specify by regulations the manner of conducting common counselling by`
  line `the designated authority for admission to all the medical institutions governed under this Act:`
  line
  line `Provided that the common counselling shall be conducted by the designated authority of--`
  line
  line `(i) the Central Government, for All India seats; and`
  line
  line `(ii) the State Government, for the remaining seats at the State level.`
  line
  line `(4) The Commission shall specify by regulations the manner of admission of students to`
  line `undergraduate courses who are exempted under sub-section (1).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (51248)
  sectionNo (15)
  orderNo 15
  title `National Exit Test.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51248&sectionno=15&orderno=15&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_15_content:
  string
  line `(1) A common final year undergraduate medical examination, to be known`
  line `as the National Exit Test, shall be held for granting licence to practice as medical practitioner of`
  line `respective disciplines of Indian System of Medicine and for enrollment in the State Register or National`
  line `Register, as the case may be.`
  line
  line `(2) The Commission shall conduct the National Exit Test for Indian System of Medicine in English`
  line `and in such other languages, through such designated authority and in such manner as may be specified`
  line `by regulations.`
  line
  line `(3) The National Exit Test shall become operational on such date, within three years from the date on`
  line `which this Act comes into force, as may be appointed by the Central Government, by notification.`
  line
  line `(4) Any person with a foreign medical qualification shall have to qualify national Exist Test for the`
  line `purpose of obtaining licence to practice as medical practitioner of Indian System of Medicine and for`
  line `enrollment in the State Register or the National Register, as the case may be, in such manner as may be`
  line `specified by regulations.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (51249)
  sectionNo (16)
  orderNo 16
  title `Post-Graduate National Entrance Test.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51249&sectionno=16&orderno=16&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_16_content:
  string
  line `(1) A uniform Post-Graduate National Entrance Test`
  line `shall be conducted separately for admission to postgraduate courses in each discipline of the Indian`
  line `System of Medicine in all medical institutions governed under this Act.`
  line
  line `(2) The Commission shall conduct the National Entrance Test for admission to postgraduate courses`
  line `in English and in such other languages, through such designated authority and in such manner, as may be`
  line `specified by regulations.`
  line
  line `(3) The Commission shall specify by regulations the manner of conducting common counselling by`
  line `the designated authority for admission to the postgraduate seats in all medical institutions governed under`
  line `this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (51250)
  sectionNo (17)
  orderNo 17
  title `National Teachers’ Eligibility Test for Indian System of Medicine.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51250&sectionno=17&orderno=17&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_17_content:
  string
  line `(1) A National Teachers'`
  line `Eligibility Test shall be conducted separately for the postgraduates of each discipline of Indian System of`
  line `Medicine who desire to take up teaching profession in that discipline.`
  line
  line `(2) The Commission shall conduct the National Teachers' Eligibility Test for Indian System of`
  line `Medicine through such designated authority and in such manner as may be specified by regulations.`
  line
  line `(3) The National Teachers’ Eligibility Test for Indian System of Medicine shall become operational`
  line `on such date, within three years from the date on which this Act comes into force, as may be notified by`
  line `the Central Government:`
  line
  line `Provided that nothing contained in this section shall apply to the teachers appointed prior to the date`
  line `notified under sub-section (3).`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (51251)
  sectionNo (18)
  orderNo 18
  title `Constitution of Autonomous Boards.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51251&sectionno=18&orderno=18&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_18_content:
  string
  line `(1) The Central Government shall, by notification,`
  line `constitute the following Autonomous Boards, under the overall supervision of the Commission, to`
  line `perform the functions assigned to such Boards under this Act, namely:--`
  line
  line `(a) the Board of Ayurveda;`
  line
  line `(b) the Board of Unani, Siddha and Sowa-Rigpa;`
  line
  line `(c) the Medical Assessment and Rating Board for Indian System of Medicine; and`
  line
  line `(d) the Board of Ethics and Registration for Indian System of Medicine.`
  line
  line `(2) Each Board referred to in sub-section (1) shall be an autonomous body which shall carry out its`
  line `functions under this Act in accordance with the regulations made by the Commission.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (51252)
  sectionNo (19)
  orderNo 19
  title `Composition of Autonomous Boards.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51252&sectionno=19&orderno=19&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_19_content:
  string
  line `(1) The composition of the Autonomous Boards shall be`
  line `as under, namely:--`
  line
  line `(a) the Board of Ayurveda shall consist of a President and four Members from the Ayurveda`
  line `discipline of Indian System of Medicine;`
  line
  line `(b) the Board of Unani, Siddha and Sowa-Rigpa shall consist of a President and two Members`
  line `from each of the Unani, Siddha and Sowa-Rigpa disciplines of Indian System of Medicine;`
  line
  line `(c) the Medical Assessment and Rating Board for Indian System of Medicine shall consist of a`
  line `President and eight Members:`
  line
  line `Provided that the President and six out of eight Members shall be chosen from the Ayurveda, Siddha,`
  line `Sowa-Rigpa and Unani disciplines of Indian System of Medicine in such manner that at least one Member`
  line `represents each such discipline separately, and the remaining two Members shall be accreditation experts;`
  line
  line `(d) the Board of Ethics and Registration for Indian System of Medicine shall consist of a`
  line `President and eight Members:`
  line
  line `Provided that the President and six out of eight Members shall be chosen from the Ayurveda, Siddha,`
  line `Sowa-Rigpa and Unani disciplines of Indian System of Medicine in such manner that at least one Member`
  line `represents each such discipline separately, and the remaining two Members shall be chosen from any of`
  line `the disciplines of quality assurance, public health, law or patient advocacy.`
  line
  line `(2) The President and Members of the Autonomous Boards to be chosen under sub-section (1) shall`
  line `be persons of outstanding ability, proven administrative capacity and integrity, possessing postgraduate`
  line `degree in respective disciplines from a recognised University and having experience of not less than`
  line `fifteen years in respective fields, out of which at least seven years shall be as a leader:`
  line
  line `Provided that seven years as leader in the case of the President and Member from Indian System of`
  line `Medicine shall be in the area of health, growth and development of education in Indian System of`
  line Medicine.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (51253)
  sectionNo (20)
  orderNo 20
  title `Search Committee for appointment of President and Members.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51253&sectionno=20&orderno=20&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_20_content:
  string
  line `The Central Government`
  line `shall appoint the President and Members of the Autonomous Boards on the basis of the recommendations`
  line `made in accordance with the procedure specified in section 5 by the Search Committee constituted`
  line thereunder.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (51254)
  sectionNo (21)
  orderNo 21
  title `Term of office and conditions of service of President and Members.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51254&sectionno=21&orderno=21&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_21_content:
  string
  line `(1) The President and`
  line `Members of each Autonomous Board shall hold the office for a term not exceeding four years and shall`
  line `not be eligible for any extension or re-appointment:`
  line
  line `Provided that such person shall cease to hold office after attaining the age of seventy years.`
  line
  line `(2) The salary and allowances payable to, and other terms and conditions of service of, the President`
  line `and Members of an Autonomous Boards shall be such as may be prescribed.`
  line
  line `(3) The provisions contained in sub-sections (3), (5), (6), (7) and (8) of section 6 relating to the terms`
  line `and conditions of service of, and in section 7 relating to removal from office, the Chairperson and`
  line `Members of the Commission shall also be applicable to the President and Members of the Autonomous`
  line Boards.
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (51255)
  sectionNo (22)
  orderNo 22
  title `Advisory Committees of experts.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51255&sectionno=22&orderno=22&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_22_content:
  string
  line `(1) Each Autonomous Board, except the Board of Ethics and`
  line `Registration for Indian System of Medicine, shall be assisted by such advisory Committees of experts, as`
  line `may be constituted by the Commission, for the efficient discharge of the functions of such Boards under`
  line `this Act.`
  line
  line `(2) The Board of Ethics and Registration for Indian System of Medicine shall be assisted by such`
  line `ethics committees of experts, as may be constituted by the Commission, for the efficient discharge of the`
  line `functions of that Boards under this Act.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (51256)
  sectionNo (23)
  orderNo 23
  title `Staff of Autonomous Boards.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51256&sectionno=23&orderno=23&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_23_content:
  string
  line `The experts, professionals, officers and other employees`
  line `appointed under section 8 shall be made available to the Autonomous Boards in such number and in such`
  line `manner, as may be specified by regulations made by the Commission.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (51257)
  sectionNo (24)
  orderNo 24
  title `Meetings, etc., of Autonomous Boards.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51257&sectionno=24&orderno=24&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_24_content:
  string
  line `(1) Every Autonomous Board shall meet at least once`
  line `a month at such time and place as it may appoint.`
  line
  line `(2) Subject to such regulations as may be made in this behalf, all decisions of the Autonomous Boards`
  line `shall be made by consensus and if consensus is not possible, decision shall be made by majority of votes`
  line `of the President and Members.`
  line
  line `(3) A person who is aggrieved by any decision of an Autonomous Board may prefer an appeal to the`
  line `Commission against such decision within thirty days of the communication of such decision.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (51258)
  sectionNo (25)
  orderNo 25
  title `Delegation of powers.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51258&sectionno=25&orderno=25&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_25_content:
  string
  line `(1) The Commission may delegate all or any of its administrative and`
  line `financial powers to the President of each Autonomous Board to enable such Board to function smoothly`
  line `and efficiently.`
  line
  line `(2) The President of an Autonomous Board may further delegate any of his powers to a Member or`
  line `officer of that Board.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (51259)
  sectionNo (26)
  orderNo 26
  title `Powers and functions of Autonomous Boards.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51259&sectionno=26&orderno=26&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_26_content:
  string
  line `(1) The Board of Ayurveda, in respect of the`
  line `discipline of Ayurveda, and the Board of Unani, Siddha and Sowa-Rigpa, in respect of the disciplines of`
  line `Unani, Siddha and Sowa-Rigpa, of the Indian System of Medicine, shall perform the following functions`
  line `in respect of their respective disciplines, namely:--`
  line
  line `(a) determine the standards of education at the undergraduate, postgraduate and super-speciality`
  line `levels and oversee all aspects relating thereto;`
  line
  line `(b) develop a competency based dynamic curriculum at all levels in accordance with the`
  line `regulations made under this Act, in such manner that it develops appropriate skill, knowledge,`
  line `attitude, values and ethics among the postgraduate and superspeciality students and enables them to`
  line `provide healthcare, to impart medical education and to conduct medical research;`
  line
  line `(c) frame guidelines on setting up of medical institutions for imparting undergraduate,`
  line `postgraduate and super-speciality courses in Ayurveda, Unani, Siddha and Sowa-Rigpa, having`
  line `regard to the needs of the country, the global norms and the regulations made under this Act;`
  line
  line `(d) determine minimum requirements and standards for conducting of courses and examinations`
  line `in medical institutions, having regard to the needs of creativity at local levels and the regulations`
  line `made under this Act;`
  line
  line `(e) determine standards and norms for infrastructure, faculty and quality of education and`
  line `research in medical institutions of Indian System of Medicine, in accordance with the regulations`
  line `made under this Act;`
  line
  line `(f) specify norms for compulsory annual disclosure, electronically or otherwise, by medical`
  line `institutions of Indian System of Medicine in respect of their functions that has a bearing on the`
  line `interest of various stakeholders including students, faculty, the Commission and the Government;`
  line
  line `(g) facilitate development and training of faculty members;`
  line
  line `(h) facilitate research programmes;`
  line
  line `(i) grant recognition to medical qualifications at all levels.`
  line
  line `(2) The Board of Ayurveda and the Board of Unani, Siddha and Sowa-Rigpa may, in the discharge of`
  line `their functions, make such recommendations to, and seek such directions from, the Commission, as it`
  line `deems necessary.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (51260)
  sectionNo (27)
  orderNo 27
  title `Powers and functions of Board of Ethics and Registration for Indian System of Medicine.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51260&sectionno=27&orderno=27&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_27_content:
  string
  line `(1) The Board of Ethics and Registration for Indian System of Medicine shall perform the following`
  line `functions, namely:--`
  line
  line `(a) maintain a National Register of all licensed practitioners of Indian System of Medicine in`
  line `accordance with the provisions of section 32;`
  line
  line `(b) regulate professional conduct and promote medical ethics in accordance with the regulations`
  line `made under this Act:`
  line
  line `Provided that the Board of Ethics and Registration for Indian System of Medicine shall ensure`
  line `compliance with the code of professional and ethical conduct through the State Medical Council, in a`
  line `case where such State Medical Council has been conferred power to take disciplinary actions in`
  line `respect of professional or ethical misconduct by medical practitioners under respective State Acts;`
  line
  line `(c) develop mechanisms to have continuous interaction with State Medical Councils of Indian`
  line `System of Medicine to effectively promote and regulate the conduct of medical practitioners of Indian`
  line `System of Medicine;`
  line
  line `(d) exercise appellate jurisdiction with respect to the actions taken by a State Medical Council`
  line `under section 31.`
  line
  line `(2) The Board of Ethics and Registration for Indian System of Medicine may, in the discharge of its`
  line `functions, make such recommendations to, and seek such directions from, the Commission, as it deems`
  line necessary.
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (51294)
  sectionNo (28)
  orderNo 28
  title `Powers and functions of Medical Assessment and Rating Board for Indian System of Medicine.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51294&sectionno=28&orderno=28&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_28_content:
  string
  line `(1) The Medical Assessment and Rating Board for Indian System of Medicine shall perform`
  line `the following functions, namely:--`
  line
  line `(a) determine the procedure for assessment and rating of medical institutions on the basis of their`
  line `compliance with the standards laid down by the Board of Ayurveda or, as the case may be, the Board`
  line `of Unani, Siddha and Sowa-Rigpa, in accordance with the regulations made under this Act;`
  line
  line `(b) grant permission for establishment of a new medical institution or to start any postgraduate`
  line `course or to increase number of seats, in accordance with the provisions of section 29;`
  line
  line `(c) carry out inspections of medical institutions for assessing and rating such institutions in`
  line `accordance with the regulations made under this Act:`
  line
  line `Provided that the Medical Assessment and Rating Board for Indian System of Medicine may, if it`
  line `deems necessary, hire and authorise any other third party agency or persons for carrying out`
  line `inspections of medical institutions for assessing and rating such institutions:`
  line
  line `Provided further that where inspection of medical institutions is carried out by such third party`
  line `agency or persons authorised by the Medical Assessment and Rating Board for Indian System of`
  line `Medicine, it shall be obligatory on such institutions to provide access to such agency or person;`
  line
  line `(d) conduct, or where it deems necessary, empanel independent rating agencies to conduct, assess`
  line `and rate all medical institutions, within such period of their opening, and every year thereafter, at such`
  line `time, and in such manner, as may be specified by regulations;`
  line
  line `(e) make available on its website or in public domain, the assessment and ratings of medical`
  line `institutions at regular intervals, in accordance with the regulations made under this Act;`
  line
  line `(f) take such measures, including issuing warning, imposition of monetary penalty, reducing`
  line `intake or stoppage of admissions and recommending to the Commission for withdrawal of`
  line `recognition, against a medical institution for its failure to maintain the minimum essential standards`
  line `specified by the Board of Ayurveda or, as the case may be, the Board of Unani, Siddha and SowaRigpa, in accordance with the regulations made under this Act.`
  line
  line `(2) The Medical Assessment and Rating Board for Indian System of Medicine may, in the discharge`
  line `of its functions, make such recommendations to, and seek such directions from, the Commission, as it`
  line `deems necessary.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (51262)
  sectionNo (29)
  orderNo 29
  title `Permission for establishment of new medical institution.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51262&sectionno=29&orderno=29&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_29_content:
  string
  line `(1) No person shall establish a new`
  line `medical institution or start any postgraduate course or increase number of seats without obtaining prior`
  line `permission of the Medical Assessment and Rating Board for Indian System of Medicine.`
  line
  line `Explanation.-- For the purpose of this sub-section, the term "person" includes any University, trust`
  line `or any other body, but does not include the Central Government.`
  line
  line `(2) For the purpose of obtaining permission under sub-section (1), a person may submit a scheme to`
  line `the Medical Assessment and Rating Board for Indian System of Medicine in such form, containing such`
  line `particulars, accompanied by such fee, and in such manner, as may be specified by regulations.`
  line
  line `(3) While considering the scheme received under sub-section (2), the Medical Assessment and Rating`
  line `Board for Indian System of Medicine shall have regard to the standards of education and research, the`
  line `standards and norms for infrastructure and faculty, the guidelines on setting up of medical institutions and`
  line `other requirements determined by the Board of Ayurveda or, as the case may be, the Board of Unani,`
  line `Siddha and Sowa-Rigpa under section 26, and pass an order either approving or disapproving the scheme`
  line `within three months from the date of receipt of such scheme:`
  line
  line `Provided that before disapproving such scheme, an opportunity to rectify the defects, if any, shall be`
  line `given to the person concerned.`
  line
  line `(4) Where a scheme is approved under sub-section (3), such approval shall be the permission under`
  line `sub-section (1) to establish a new medical institution.`
  line
  line `(5) Where a scheme is disapproved under sub-section (3), or where no order is passed within three`
  line `months of submitting a scheme under sub-section (2), the person concerned may prefer an appeal to the`
  line `Commission within fifteen days of such disapproval or, as the case may be, after lapse of three months, in`
  line `such manner as may be specified by regulations.`
  line
  line `(6) Where the Commission has disapproved the scheme or no order has been passed within fifteen`
  line `days from the date of preferring appeal under sub-section (5), the person concerned may prefer a second`
  line `appeal to the Central Government within seven days of communication of such disapproval or, as the case`
  line `may be, lapse of specified period of fifteen days.`
  line
  line `(7) The Medical Assessment and Rating Board for Indian System of Medicine may conduct`
  line `evaluation and assessment of any University or medical institution at any time, either directly or through`
  line `any other expert, having integrity and experience in medical profession, without any prior notice and`
  line `assess and evaluate the performance, standards and benchmarks of such University or medical institution.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (51263)
  sectionNo (30)
  orderNo 30
  title `Criteria for approving or disapproving scheme.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51263&sectionno=30&orderno=30&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_30_content:
  string
  line `While approving or disapproving a scheme`
  line `under section 29, the Medical Assessment and Rating Board for Indian System of Medicine, or the`
  line `Commission, as the case may be, shall take into consideration the following criteria, namely:--`
  line
  line `(a) adequacy of infrastructure and financial resources;`
  line
  line `(b) whether adequate academic faculty, non-teaching staff, and other necessary facilities have`
  line `been provided to ensure proper functioning of medical institution or would be provided within the`
  line `time-limit specified in the scheme;`
  line
  line `(c) whether adequate hospital facilities have been provided or would be provided within the timelimit specified in the scheme;`
  line
  line `(d) such other factors as may be prescribed:`
  line
  line `Provided that, subject to the previous approval of the Central Government, the criteria may be`
  line `relaxed for the medical institutions which are set up in such areas as may be specified by the`
  line regulations.
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (51264)
  sectionNo (31)
  orderNo 31
  title `State Medical Council.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51264&sectionno=31&orderno=31&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_31_content:
  string
  line `(1) The State Government shall, by notification, within three years of`
  line `the commencement of this Act, establish a State Medical Council for Indian System of Medicine in that`
  line `State if no such Council exists in that State.`
  line
  line `(2) Where a State Act confers power upon the State Medical Council to take disciplinary actions in`
  line `respect of any professional or ethical misconduct by a registered practitioner of Indian System of`
  line `Medicine, the State Medical Council shall act in accordance with the regulations made, and the guidelines`
  line `framed, under this Act:`
  line
  line `Provided that till such time as a State Medical Council for Indian System of Medicine is established`
  line `in a State, the Board of Ethics and Registration for Indian System of Medicine shall receive the`
  line `complaints and grievances relating to any professional or ethical misconduct against a registered`
  line `practitioner of Indian System of Medicine in that State in accordance with such procedure as may be`
  line `specified by regulations:`
  line
  line `Provided further that the Board of Ethics and Registration for Indian System of Medicine or, as the`
  line `case may be, the State Medical Council shall give an opportunity of hearing to such practitioner before`
  line `passing any order or taking any action, including imposition of any monetary penalty, against such`
  line person.
  line
  line `(3) A practitioner of Indian System of Medicine who is aggrieved by the order passed or the action`
  line `taken by--`
  line
  line `(a) the State Medical Council under sub-section (2) may prefer an appeal to the Board of Ethics`
  line `and Registration for Indian System of Medicine and the decision, if any, of the Board of Ethics and`
  line `Registration for Indian System of Medicine thereupon shall be binding on such State Medical`
  line `Council, unless a second appeal is preferred under sub-section (4);`
  line
  line `(b) the Board of Ethics and Registration for Indian System of Medicine under the first proviso to`
  line `sub-section (2) may prefer an appeal to the Commission.`
  line
  line `(4) A medical practitioner of Indian system of medicine who is aggrieved by the decision of the`
  line `Board of Ethics and Registration for Indian System of Medicine, may prefer an appeal to the Commission`
  line `within sixty days of communication of such decision.`
  line
  line `Explanation.--For the purposes of this Act,--`
  line
  line `(a) "State" includes Union territory and the expressions "State Government" and "State Medical`
  line `Council for Indian System of Medicine", in relation to a Union territory, shall respectively mean the`
  line `"Central Government" and "Union Territory Medical Council for Indian System of Medicine";`
  line
  line `(b) the expression "professional or ethical misconduct" includes any act of commission or`
  line `omission, as may be specified by regulations.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (51265)
  sectionNo (32)
  orderNo 32
  title `National Register and State Register of Indian System of Medicine.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51265&sectionno=32&orderno=32&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_32_content:
  string
  line `(1) The Board of Ethics`
  line `and Registration for Indian System of Medicine shall maintain a National Register containing the name,`
  line `address, all recognised qualifications possessed by a licensed medical practitioner of the Indian System of`
  line `Medicine and such other particulars as may be specified by regulations.`
  line
  line `(2) The National Register shall be maintained in such form, including in electronic form and in such`
  line `manner as may be specified by regulations.`
  line
  line `(3) The manner in which any name or qualification may be added to, or removed from, the National`
  line `Register and the grounds for removal thereof, shall be such as may be specified by the regulations.`
  line
  line `(4) The National Register shall be made available to the public by placing it on the website of the`
  line `Board of Ethics and Registration for Indian System of Medicine.`
  line
  line `(5) Every State Medical Council shall maintain and regularly update the State Register in the`
  line `specified electronic format and supply a physical copy of the same to the Board of Ethics and Registration`
  line `for Indian System of Medicine within three months of the commencement of this Act.`
  line
  line `(6) The Board of Ethics and Registration for Indian System of Medicine shall ensure electronic`
  line `synchronization of the National Register and the State Register in such a manner that any change in one`
  line `such register is automatically reflected in the other register.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (51266)
  sectionNo (33)
  orderNo 33
  title `Rights of persons to be enrolled in National Register and their obligations thereto.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51266&sectionno=33&orderno=33&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_33_content:
  string
  line `(1) Any`
  line `person who has a recognised qualification in Indian System of Medicine under this Act and qualifies the`
  line `National Exit Test held under section 15 shall be granted a licence to practice Indian System of Medicine`
  line `and shall have his name and qualifications enrolled first in the State Register and subsequently in the`
  line `National Register maintained under this Act:`
  line
  line `Provided that a person who has been registered in the Central Register of Indian System of Medicine`
  line `maintained under the Indian Medicine Central Council Act, 1970 (48 of 1970) prior to the coming into`
  line `force of this Act and before the National Exit Test becomes operational under sub-section (3) of section`
  line `15, shall be deemed to have been registered under this Act and be enrolled in the National Register`
  line `maintained under this Act.`
  line
  line `(2) No person who has obtained a qualification in Indian System of Medicine from a medical`
  line `institution established in any country outside India and is recognised as a medical practitioner of Indian`
  line `System of Medicine in that country, shall, after the commencement of this Act and the National Exit Test`
  line `for Indian System of Medicine becomes operational under sub-section (3) of section 15, be enrolled in the`
  line `National Register for Indian System of Medicine, unless he qualifies the National Exit Test for Indian`
  line `System of Medicine.`
  line
  line `(3) When a person whose name is entered in the State Register or the National Register, as the case`
  line `may be, obtains any title, diploma or qualification for proficiency in sciences or medicine which is a`
  line `recognised qualification under section 35 or section 36, as the case may be, he shall be entitled to have`
  line `such title, diploma or qualification entered against his name in the State Register or the National Register,`
  line `in such manner as may be specified by regulations.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (51267)
  sectionNo (34)
  orderNo 34
  title `Rights of persons to practice.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51267&sectionno=34&orderno=34&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_34_content:
  string
  line `(1) No person other than a person who is enrolled in the State`
  line `Register or the National Register, as the case may be, shall--`
  line
  line `(a) be allowed to practice Indian System of Medicine as a qualified practitioner;`
  line
  line `(b) hold office as a physician or surgeon or any other office, by whatever name called, which is`
  line `meant to be held by a physician or surgeon, as the case may be;`
  line
  line `(c) be entitled to sign or authenticate a medical or fitness certificate or any other certificate`
  line `required by any law to be signed or authenticated by a duly qualified medical practitioner;`
  line
  line `(d) be entitled to give evidence at any inquest or in any court of law as an expert under section 45`
  line `of the Indian Evidence Act, 1872 (1 of 1872) on any matter relating to Indian System of Medicine:`
  line
  line `Provided that the Commission shall submit a list of such practitioners to the Central Government`
  line `in such manner as may be prescribed:`
  line
  line `Provided further that a foreign citizen who is enrolled in his country as a practitioner of Indian`
  line `System of Medicine in accordance with the law regulating the registration of such practitioners in that`
  line `country may be permitted temporary registration in India for such period and in such manner as may`
  line `be specified by regulations.`
  line
  line `(2) Any person who acts in contravention of the provisions of this section shall be punished with`
  line `imprisonment for a term which may extend to one year, or with fine which may extend to five lakh`
  line `rupees, or with both.`
  line
  line `(3) Nothing contained in this section shall affect--`
  line
  line `(a) the right of a person enrolled in a State Register as practitioner of Indian System of Medicine`
  line `to practice in any State merely on the ground that he does not possess, as on the date of`
  line `commencement of this Act, a recognised medical qualification in the Indian System of Medicine;`
  line
  line `(b) the privileges, including the right to practice any system of medicine, conferred by or under`
  line `any law for the time being in force in a State on the practitioners of Indian System of Medicine`
  line `enrolled in the State register of that State;`
  line
  line `(c) the right of a person who has been practicing Indian System of Medicine for not less than five`
  line `years in a State, to continue to practice in that State in which a State Register of Indian System of`
  line `Medicine is not maintained as on the date of commencement of this Act.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (51268)
  sectionNo (35)
  orderNo 35
  title `Recognition of qualifications granted by Universities or medical institutions in India.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51268&sectionno=35&orderno=35&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_35_content:
  string
  line `(1)`
  line `The medical qualifications in Indian System of Medicine at undergraduate or postgraduate or`
  line `super-speciality level granted by any University or medical institution in India shall be listed and`
  line `maintained by the Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa, as the case may be,`
  line `in such manner as may be specified by regulations and such medical qualification shall be a recognised`
  line `medical qualification for the purposes of this Act.`
  line
  line `(2) Any University or medical institution in India which grants an undergraduate or postgraduate or`
  line `super-speciality qualification in Indian System of Medicine not included in the list maintained by the`
  line `Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa, as the case may be, may apply to that`
  line `Board for granting recognition to such qualification.`
  line
  line `(3) The Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa, as the case may be, shall`
  line `examine the application for grant of recognition to a qualification in Indian System of Medicine within a`
  line `period of six months in such manner as may be specified by regulations.`
  line
  line `(4) Where the Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa, as the case may be,`
  line `decides to grant recognition to the qualification in Indian System of Medicine, it shall include such`
  line `qualification in the list maintained by it and shall also specify therein the date of effect of such`
  line `recognition, otherwise it shall communicate its decision not to grant recognition to the medical`
  line `qualification to the concerned University or medical institution.`
  line
  line `(5) The aggrieved University or the medical institution may prefer an appeal to the Commission`
  line `within a period of sixty days from the date of communication of the decision of the Board of Ayurveda or`
  line `the Board of Unani, Siddha and Sowa-Rigpa, as the case may be, in such manner as may be specified by`
  line regulations.
  line
  line `(6) The Commission shall examine the appeal received under sub-section (5) within a period of two`
  line `months and if it decides that recognition may be granted to such medical qualification, it may direct the`
  line `concerned Board to include such qualification in the list maintained by that Board in such manner as may`
  line `be specified by regulations.`
  line
  line `(7) Where the Commission decides not to grant recognition under sub-section (6) or fails to decide`
  line `within the specified period, the aggrieved University or medical institution may prefer a second appeal to`
  line `the Central Government within a period of thirty days from the date of communication of such decision or`
  line `lapse of specified period, as the case may be.`
  line
  line `(8) All medical qualifications which have been recognised before the date of commencement of this`
  line `Act and are included in the Second Schedule and Third Schedule to the Indian Medicine Central Council Act, 1970 (48 of 1970), shall also be listed and maintained by the Board of Ayurveda or the Board of`
  line `Unani, Siddha and Sowa-Rigpa, as the case may be, in such manner as may be specified by regulations.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (51269)
  sectionNo (36)
  orderNo 36
  title `Recognition of medical qualifications granted by medical institutions outside India.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51269&sectionno=36&orderno=36&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_36_content:
  string
  line `(1)`
  line `Where an authority in any country outside India which, by the law of that country is entrusted with the`
  line `recognition of qualifications of Indian System of Medicine in that country, makes an application to the`
  line `Commission for granting recognition to such qualification in India, the Commission may, subject to such`
  line `verification as it deems necessary, either grant or refuse to grant recognition to that medical qualification.`
  line
  line `(2) Where the Commission grants recognition to any medical qualification under sub-section (1), such`
  line `qualification shall be a recognised qualification for the purposes of this Act and shall be included in the`
  line `list maintained by the Commission in such manner as may be specified:`
  line
  line `Provided that in case the Commission decides not to grant recognition to any qualification, the`
  line `Commission shall give a reasonable opportunity of being heard to such authority before refusing to grant`
  line `such recognition.`
  line
  line `(3) Where the Commission refuses to grant recognition to a medical qualification under`
  line `sub-section (2), the Authority concerned may prefer an appeal to the Central Government for grant of`
  line recognition.
  line
  line `(4) All qualifications which have been recognised before the date of commencement of this Act and`
  line `are included in the Fourth Schedule to the Indian Medicine Central Council Act, 1970 (48 of 1970) shall`
  line `also be recognised medical qualifications for the purposes of this Act and shall be listed and maintained`
  line `by the Commission in such manner as may be specified by the regulations.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (51270)
  sectionNo (37)
  orderNo 37
  title `Withdrawal of recognition or de-recognition of qualification.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51270&sectionno=37&orderno=37&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_37_content:
  string
  line `(1) Where, upon a report`
  line `received from the Medical Assessment and Rating Board for Indian System of Medicine or otherwise, it`
  line `appears to the Commission that--`
  line
  line `(a) the courses of study and examination to be undergone in, or the proficiency required from`
  line `candidates at any examination held by, a University or medical institution do not conform to the`
  line `standards specified by the Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa, as the`
  line `case may be; or`
  line
  line `(b) the standards and norms for infrastructure, faculty and quality of education in medical`
  line `institutions as determined by the Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa,`
  line `as the case may be, are not adhered to by any University or medical institution, and such University`
  line `or medical institution has failed to take necessary corrective action to maintain specified minimum`
  line standards,
  line
  line `the Commission may initiate action in accordance with the provisions of sub-section (2):`
  line
  line `Provided that the Commission shall, before, taking any action for suo motu withdrawal of recognition`
  line `granted to the medical qualification awarded by a University or medical institution, impose penalty in`
  line `accordance with the provisions of clause (f) of sub-section (1) of section 28.`
  line
  line `(2) The Commission shall, after making such further inquiry as it deems fit, and after holding`
  line `consultations with the State Government and the authority of the concerned University or medical`
  line `institution, comes to the conclusion that the recognition granted to a medical qualification ought to be`
  line `withdrawn, it may, by order, withdraw recognition granted to such medical qualification and direct the`
  line `Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa, as the case may be, to amend the`
  line `entries against the University or medical institution concerned in the list maintained by that Board to the`
  line `effect that the recognition granted to such qualification is withdrawn with effect from the date specified in`
  line `that order.`
  line
  line `(3) If the Commission, after verification with the authority in any country outside India, is of the`
  line `opinion that a recognised medical qualification which is included in the list maintained by it is to be`
  line `de-recognised, it may, by order, de-recognise such medical qualification and remove it from the list`
  line `maintained by the Commission with effect from the date of such order.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (51271)
  sectionNo (38)
  orderNo 38
  title `Special provision in certain cases for recognition of qualifications.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51271&sectionno=38&orderno=38&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_38_content:
  string
  line `Where the Commission`
  line `deems it necessary so to do, it may, by notification, direct that any qualification in Indian System of`
  line `Medicine granted by a medical institution outside India, after such date, as may be specified in that`
  line `notification, shall be recognised qualification for the purposes of this Act:`
  line
  line `Provided that medical practice by a person possessing such qualification shall be permitted only if`
  line `such person has been enrolled as a medical practitioner in accordance with the law regulating the`
  line `registration of medical practitioner for the time being in force in that country:`
  line
  line `Provided further that medical practice by a person possessing such qualification shall be limited to`
  line `such period as may be specified in that order:`
  line
  line `Provided also that medical practice by a person possessing such qualification shall be permitted only`
  line `if such person qualifies National Exit Test.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (51272)
  sectionNo (39)
  orderNo 39
  title `Grants by Central Government.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51272&sectionno=39&orderno=39&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_39_content:
  string
  line `The Central Government may, after due appropriation made`
  line `by Parliament by law in this behalf, make to the Commission grants of such sums of money as the Central`
  line `Government may think fit.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (51273)
  sectionNo (40)
  orderNo 40
  title `National Commission Fund for Indian System of Medicine.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51273&sectionno=40&orderno=40&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_40_content:
  string
  line `(1) There shall be constituted a`
  line `fund to be called “the National Commission Fund for Indian System of Medicine” and there shall be`
  line `credited thereto--`
  line
  line `(a) all Government grants, fees, penalties and charges received by the Commission and the`
  line `Autonomous Boards;`
  line
  line `(b) all sums received by the Commission from such other source as may be decided by it.`
  line
  line `(2) The fund shall be applied for making payment towards--`
  line
  line `(a) the salaries and allowances payable to the Chairperson and Members of the Commission, the`
  line `Presidents and Members of the Autonomous Boards and the administrative expenses including the`
  line `salaries and allowances payable to the officers and other employees of the Commission and`
  line `Autonomous Boards;`
  line
  line `(b) the expenses incurred or to be incurred in carrying out the provisions of this Act including in`
  line `connection with the discharge of the functions of the Commission and the Autonomous Boards.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (51274)
  sectionNo (41)
  orderNo 41
  title `Audit and accounts.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51274&sectionno=41&orderno=41&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_41_content:
  string
  line `(1) The Commission shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts in such form as may be prescribed, in consultation`
  line `with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Commission shall be audited by the Comptroller and Auditor-General of India`
  line `at such intervals as may be specified by him and any expenditure incurred in connection with such audit`
  line `shall be payable by the Commission to the Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any other persons appointed by him in`
  line `connection with the audit of the accounts of the Commission shall have the same rights and privileges and`
  line `authority in connection with such audit as the Comptroller and Auditor-General generally has in`
  line `connection with the audit of Government accounts and in particular, shall have the right to demand the production of, and complete access to, records, books, accounts, connected vouchers and other documents`
  line `and papers and to inspect the office of the Commission.`
  line
  line `(4) The accounts of the Commission as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf, together with the audit report thereon, shall be`
  line `forwarded annually by the Commission to the Central Government which shall cause the same to be laid,`
  line `as soon as may be after it is received, before each House of Parliament.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (51275)
  sectionNo (42)
  orderNo 42
  title `Furnishing of returns and reports to Central Government.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51275&sectionno=42&orderno=42&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_42_content:
  string
  line `(1) The Commission shall`
  line `furnish to the Central Government, at such time, in such form and in such manner, as may be prescribed`
  line `or as the Central Government may direct, such reports and statements and such particulars in regard to`
  line `any matter under the jurisdiction of the Commission, as the Central Government may, from time to time,`
  line require.
  line
  line `(2) The Commission shall prepare, once every year, in such form and at such time as may be`
  line `prescribed, an annual report, giving a summary of its activities during the previous year and copies of the`
  line `report shall be forwarded to the Central Government.`
  line
  line `(3) A copy of the report received under sub-section (2) shall be laid by the Central Government, as`
  line `soon as may be after it is received, before each House of Parliament.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (51276)
  sectionNo (43)
  orderNo 43
  title `Power of Central Government to give directions to Commission and Autonomous Boards.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51276&sectionno=43&orderno=43&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_43_content:
  string
  line `(1) Without prejudice to the foregoing provisions of this Act, the Commission and the Autonomous`
  line `Boards shall, in exercise of their powers and discharge of their functions under this Act be bound by such`
  line `directions on questions of policy as the Central Government may give in writing to them from time to`
  line `time:`
  line
  line `Provided that the Commission and the Autonomous Boards shall, as far as practicable, be given an`
  line `opportunity to express their views before any direction is given under this sub-section.`
  line
  line `(2) The decision of the Central Government whether a question is one of policy or not shall be final.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (51277)
  sectionNo (44)
  orderNo 44
  title `Power of Central Government to give directions to State Governments.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51277&sectionno=44&orderno=44&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_44_content:
  string
  line `The Central`
  line `Government may give such directions, as it may deem necessary, to a State Government for carrying out`
  line `all or any of the provisions of this Act and the State Government shall comply with such directions.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (51278)
  sectionNo (45)
  orderNo 45
  title `Information to be furnished by Commission and publication thereof.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51278&sectionno=45&orderno=45&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_45_content:
  string
  line `(1) The Commission`
  line `shall furnish such reports, copies of its minutes, abstracts of its accounts and other information to the`
  line `Central Government as that Government may require.`
  line
  line `(2) The Central Government may publish, in such manner as it may think fit, the reports, minutes,`
  line `abstracts of accounts and other information furnished to it under sub-section (1).`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (51279)
  sectionNo (46)
  orderNo 46
  title `Obligation of Universities and medical institutions.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51279&sectionno=46&orderno=46&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_46_content:
  string
  line `Every university and medical institutions`
  line `covered under this Act shall maintain a website at all times and display in its website all such information`
  line `as may be required by the Commission or an Autonomous Board, as the case may be.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (51280)
  sectionNo (47)
  orderNo 47
  title `Completion of courses of studies in medical institutions.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51280&sectionno=47&orderno=47&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_47_content:
  string
  line `(1) Notwithstanding anything`
  line `contained in this Act, any student who was studying for a degree or diploma in any medical institution`
  line `immediately before the commencement of this Act shall continue to so study and complete his course for`
  line `such degree or diploma, and such institution shall continue to provide instructions and hold examination`
  line `for such student in accordance with the syllabus and studies as existed before such commencement, and`
  line `such student shall be deemed to have completed his course of study under this Act and shall be awarded`
  line `degree or diploma under this Act.`
  line
  line `(2) Notwithstanding anything contained in this Act, where recognition granted to a medical institution`
  line `has lapsed, whether by efflux of time or by its voluntary surrender or for any other reason whatsoever,`
  line `such medical institution shall continue to maintain and provide the minimum standards as approved by`
  line `the Commission till such time as all the candidates are able to complete their study in that institution.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (51295)
  sectionNo (48)
  orderNo 48
  title `Chairperson, Members, officers of Commission and of Autonomous Boards to be public servants.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51295&sectionno=48&orderno=48&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_48_content:
  string
  line `The Chairperson, Members, officers and other employees of the Commission and the`
  line `President and Members of Autonomous Boards shall be deemed, when acting or purporting to act in`
  line `pursuance of any of the provisions of this Act, to be public servants within the meaning of section 21 of`
  line `the Indian Penal Code (45 of 1860).`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (51282)
  sectionNo (49)
  orderNo 49
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51282&sectionno=49&orderno=49&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_49_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Government, the Commission or any Autonomous Board or a State Medical Council or any`
  line `Committee thereof, or any officer or other employee of the Government or of the Commission acting`
  line `under this Act for anything which is in good faith done or intended to be done under this Act or the rules`
  line `or regulations made thereunder.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (51283)
  sectionNo (50)
  orderNo 50
  title `Cognizance of offences.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51283&sectionno=50&orderno=50&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_50_content:
  string
  line `No Court shall take cognizance of an offence punishable under this`
  line `Act except upon a complaint in writing made in this behalf by an officer authorised by the Commission or`
  line `the Ethics and Registration Board or a State Medical Council for Indian System of Medicine, as the case`
  line `may be.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (51284)
  sectionNo (51)
  orderNo 51
  title `Power of Central Government to supersede Commission.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51284&sectionno=51&orderno=51&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_51_content:
  string
  line `(1) If, at any time, the Central`
  line `Government is of opinion that--`
  line
  line `(a) the Commission is unable to discharge the functions and duties imposed on it by or under the`
  line `provisions of this Act; or`
  line
  line `(b) the Commission has persistently made default in complying with any direction issued by the`
  line `Central Government under this Act or in the discharge of the functions and duties imposed on it by or`
  line `under the provisions of this Act,`
  line
  line `the Central Government may, by notification, supersede the Commission for such period, not exceeding`
  line `six months, as may be specified in the notification:`
  line
  line `Provided that before issuing a notification under this sub-section, the Central Government shall give a`
  line `reasonable opportunity to the Commission to show cause as to why it should not be superseded and shall`
  line `consider the explanations and objections, if any, of the Commission.`
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the Commission,--`
  line
  line `(a) all the Members shall, as from the date of supersession, vacate their offices as such;`
  line
  line `(b) all the powers, functions and duties which may, by or under the provisions of this Act, be`
  line `exercised or discharged by or on behalf of the Commission, shall until the Commission is`
  line `re-constituted under sub-section (3), be exercised and discharged by such person or persons as the`
  line `Central Government may direct;`
  line
  line `(c) all property owned or controlled by the Commission shall, until the Commission is`
  line `re-constituted under sub-section (3), vest in the Central Government.`
  line
  line `(3) On the expiration of the period of supersession specified by the notification issued under`
  line `sub-section (1), the Central Government may,--`
  line
  line `(a) extend the period of supersession for such further term not exceeding six months, as it may`
  line `consider necessary; or`
  line
  line `(b) re-constitute the Commission by fresh appointment and in such case the Members who`
  line `vacated their offices under clause (a) of sub-section (2) shall not be deemed disqualified for`
  line `appointment:`
  line
  line `Provided that the Central Government may, at any time before the expiration of the period of`
  line `supersession, whether as originally specified under sub-section (1) or as extended under this`
  line `sub-section, take action under clause (b) of this sub-section.`
  line
  line `(4) The Central Government shall cause a notification issued under sub-section (1) and a full report of`
  line `any action taken under this section and the circumstances leading to such action to be laid before both`
  line `Houses of Parliament at the earliest opportunity.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (51296)
  sectionNo (52)
  orderNo 52
  title `Joint sittings of Commission, National Commission for Homoeopathy and National Medical Commission.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51296&sectionno=52&orderno=52&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_52_content:
  string
  line `(1) There shall be a joint sitting of the Commission, the National Commission for`
  line `Homoeopathy, and the National Medical Commission, at least once a year, at such time and place as they`
  line `mutually appoint, to enhance the interface between Indian System of Medicine, Homoeopathy and`
  line `modern system of medicine.`
  line
  line `(2) The Agenda for the joint sitting may be placed with mutual agreement by the Chairpersons of the`
  line `Commissions concerned.`
  line
  line `(3) The joint sitting may, by an affirmative vote of all members present and voting, decide on`
  line `approving specific educational and medical modules or programme that could be introduced in the`
  line `under-graduate and post-graduate courses across medical systems, and promote medical pluralism.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (51286)
  sectionNo (53)
  orderNo 53
  title `State Government to promote public health.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51286&sectionno=53&orderno=53&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_53_content:
  string
  line `Every State Government may, for the purposes`
  line `of addressing or promoting public health, take necessary measures to enhance the capacity of the`
  line `healthcare professionals.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (51287)
  sectionNo (54)
  orderNo 54
  title `Power to make rules.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51287&sectionno=54&orderno=54&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_54_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the foregoing power, such rules may provide for all or any`
  line `of the following matters, namely:--`
  line
  line `(a) the manner of appointing ten Members of the Commission on rotational basis from amongst`
  line `the nominees of the States and Union territories in the Advisory Council under clause (b) of`
  line `sub-section (4) of section 4;`
  line
  line `(b) the manner of appointing members under clause (c) of sub-section (4) of section 4;`
  line
  line `(c) the manner of nominating one expert by the Central Government under clause (d) of`
  line `sub-section (1) of section 5;`
  line
  line `(d) the salary and allowances payable to, and other terms and conditions of service of, the`
  line `Chairperson and Members under sub-section (4) of section 6;`
  line
  line `(e) the form and the manner of making declaration under sub-section (6) of section 6;`
  line
  line `(f) the qualifications and experience to be possessed by Secretary under sub-section (2) of`
  line `section 8;`
  line
  line `(g) the salaries and allowances payable to, and other terms and conditions of the Secretary,`
  line `officers and other employees of the Commission under sub-section (6) of section 8;`
  line
  line `(h) the other powers to be exercised and other functions to be performed by the Commission`
  line `under clause (j) of sub-section (1) of section 10;`
  line
  line `(i) the salary and allowances payable to, and other terms and conditions of service of, the`
  line `President and Members of an Autonomous Board under sub-section (2) of section 21;`
  line
  line `(j) the other factors under clause (d) of section 30.`
  line
  line `(k) the manner of submitting a list of practitioners under the first proviso to sub-section (1) of`
  line `section 34;`
  line
  line `(l) the form for preparing annual statement of accounts under sub-section (1) of section 41;`
  line
  line `(m) the time within which, and the form and the manner in which, the reports and statements shall`
  line `be furnished by the Commission and the particulars with regard to any matter as may be required by`
  line `the Central Government under sub-section (1) of section 42;`
  line
  line `(n) the form and the time for preparing annual report under sub-section (2) of section 42;`
  line
  line `(o) the compensation for the premature termination of employment under the second proviso to`
  line `sub-section (3) of section 58;`
  line
  line `(p) any other matter in respect of which provision is to be made by rules.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (51288)
  sectionNo (55)
  orderNo 55
  title `Power to make regulations.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51288&sectionno=55&orderno=55&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_55_content:
  string
  line `(1) The Commission may, by notification, make regulations`
  line `consistent with this Act and the rules made thereunder to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the functions to be discharged by the Secretary of the Commission under sub-section (4) of`
  line `section 8;`
  line
  line `(b) the procedure in accordance with which experts and professionals may be engaged and the`
  line `number of such experts and professionals under sub-section (7) of section 8;`
  line
  line `(c) the procedure to be followed at the meetings of Commission, including the quorum at its`
  line `meetings under sub-section (3) of section 9;`
  line
  line `(d) the quality and standards to be maintained in education of Indian System of Medicine under`
  line `clause (a) of sub-section (1) of section 10;`
  line
  line `(e) the manner of regulating medical institutions, medical researches and medical professionals`
  line `under clause (b) of sub-section (1) of section 10;`
  line
  line `(f) the manner of functioning of the Commission, the Autonomous Boards and the State Medical`
  line `Councils under clause (d) of sub-section (1) of section 10;`
  line
  line `(g) the procedure to be followed at the meetings of the Medical Advisory Council, including the`
  line `quorum at its meetings under sub-section (3) of section 13;`
  line
  line `(h) the other languages in which, the designated authority through which, and the manner in`
  line `which the National Eligibility-cum-Entrance Test shall be conducted under sub-section (2) of section`
  line 14;
  line
  line `(i) the manner of conducting common counselling by the designated authority for admission to`
  line `medical institutions under sub-section (3) of section 14;`
  line
  line `(j) the manner of admission of students to undergraduate courses under sub-section (4) of section`
  line 14;
  line
  line `(k) the other languages in which, the designated authority through which, and the manner in`
  line `which, the National Exit Test shall be conducted under sub-section (2) of section 15;`
  line
  line `(l) the manner in which a person with foreign medical qualification shall qualify National Exist`
  line `Test under sub-section (4) of section 15;`
  line
  line `(m) the other languages in which, the designated authority through which, and the manner in`
  line `which admission to postgraduate courses shall be conducted under sub-section (2) of section 16;`
  line
  line `(n) the manner of conducting common counselling by the designated authority for admission to`
  line `the postgraduate seats in all medical institutions under sub-section (3) of section 16;`
  line
  line `(o) the manner of conducting the National Teachers’ Eligibility Test for Indian System of`
  line `Medicine and the designated authority through whom such test shall be conducted under sub-section`
  line `(2) of section 17;`
  line
  line `(p) the number of, and the manner in which, experts, professionals, officers and other employees`
  line `shall be made available by the Commission to the Autonomous Boards under section 23;`
  line
  line `(q) the manner in which decisions of the Autonomous Boards shall be made under sub-section (2)`
  line `of section 24;`
  line
  line `(r) the competency based dynamic curriculum at all levels under clause (b) of sub-section (1) of`
  line `section 26;`
  line
  line `(s) the manner of imparting undergraduate, postgraduate and super-speciality courses in`
  line `Ayurveda, Unani, Siddha and Sowa-Rigpa under clause (c) of sub-section (1) of section 26;`
  line
  line `(t) the minimum requirements and standards for conducting courses and examinations in medical`
  line `institutions under clause (d) of sub-section (1) of section 26;`
  line
  line `(u) the standards and norms for infrastructure, faculty and quality of education and research in`
  line `medical institutions of Indian System of Medicine under clause (e) of sub-section (1) of section 26;`
  line
  line `(v) the manner of regulating professional conduct and promoting medical ethics under clause (b)`
  line `of sub-section (1) of section 27;`
  line
  line `(w) the procedure for assessment and rating of the medical institutions under clause (a) of`
  line `sub-section (1) of section 28;`
  line
  line `(x) the manner of carrying out inspections of medical institutions for assessing and rating under`
  line `clause (c) of sub-section (1) of section 28;`
  line
  line `(y) the manner of conducting, and the manner of empanelling independent rating agencies to`
  line `conduct, assess and rate all medical institutions under clause (d) of sub-section (1) of section 28;`
  line
  line `(z) the manner of making available on website or in public domain the assessment and ratings of`
  line `medical institutions under clause (e) of sub-section (1) of section 28;`
  line
  line `(za) the measures to be taken against a medical institution for failure to maintain the minimum`
  line `essential standards under clause (f) of sub-section (1) of section 28;`
  line
  line `(zb) the form of scheme, the particulars thereof, the fee to be accompanied and the manner of`
  line `submitting scheme for establishing new medical college under sub-section (2) of section 29;`
  line
  line `(zc) the manner of preferring an appeal to the Commission for approval of the scheme under`
  line `sub-section (5) of section 29;`
  line
  line `(zd) the areas in respect of which criteria may be relaxed under the proviso to section 30;`
  line
  line `(ze) the manner of taking disciplinary action by a State Medical Council for professional or`
  line `ethical misconduct of registered medical practitioner and the procedure for receiving complaints and`
  line `grievances by the Board of Ethics and Registration for Indian System of Medicine, under`
  line `sub-section (2) of section 31;`
  line
  line `(zf) the act of commission or omission which amounts to professional or ethical misconduct under`
  line `clause (b) of the Explanation to section 31;`
  line
  line `(zg) other particulars to be contained in a National Register under sub-section (1) of section 32;`
  line
  line `(zh) the form, including the electronic form and the manner of maintaining the National Register`
  line `under sub-section (2) of section 32;`
  line
  line `(zi) the manner in which any name or qualification may be added to, or removed from, the`
  line `National Register and the grounds for removal thereof, under sub-section (3) of section 32;`
  line
  line `(zj) the manner of entering the title, diploma or qualification in the State Register or the National`
  line `Register under sub-section (3) of section 33;`
  line
  line `(zk) the manner in which, and the period for which temporary registration may be permitted to a`
  line `foreign citizen under the second proviso to sub-section (1) of section 34;`
  line
  line `(zl) the manner of listing and maintaining medical qualifications granted by a University or`
  line `medical institution in India under sub-section (1) of section 35;`
  line
  line `(zm) the manner of examining the application for grant of recognition under sub-section (3) of`
  line `section 35;`
  line
  line `(zn) the manner of preferring an appeal to the Commission for grant of recognition under`
  line `sub-section (5) of section 35;`
  line
  line `(zo) the manner of including a medical qualification in the list maintained by the Board under`
  line `sub-section (6) of section 35;`
  line
  line `(zp) the manner in which the Board of Ayurveda or the Board of Unani, Siddha and Sowa-Rigpa`
  line `shall list and maintain the medical qualifications which have been granted recognition before the date`
  line `of commencement of this Act, under sub-section (8) of section 35;`
  line
  line `(zq) the manner in which the Commission shall list and maintain the medical qualifications which`
  line `have been granted recognition before the date of commencement of this Act, under sub-section (4) of`
  line `section 36.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (51289)
  sectionNo (56)
  orderNo 56
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51289&sectionno=56&orderno=56&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_56_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (51290)
  sectionNo (57)
  orderNo 57
  title `Power to remove difficulties.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51290&sectionno=57&orderno=57&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_57_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to it be necessary, for the removing the`
  line `difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of a period of two years from`
  line `the commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `house of Parliament.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (51291)
  sectionNo (58)
  orderNo 58
  title `Repeal and saving.`
  content obj_root_law_sections_58_content
  footnotes `1. Ins. by Act 38 of 2021, s. 2 (w.e.f. 18-8-2021).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51291&sectionno=58&orderno=58&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_58_content:
  string
  line `(1) With effect from such date as the Central Government may, by`
  line `notification, appoint in this behalf, the Indian Medicine Central Council Act, 1970 (48 of 1970) shall`
  line `stand repealed and the Central Council of Indian Medicine constituted under section 3 of the said Act`
  line `shall stand dissolved.`
  line
  line `(2) Notwithstanding the repeal of the Act referred to in sub-section (1), it shall not affect,--`
  line
  line `(a) the previous operation of the Act so repealed or anything duly done or suffered thereunder;`
  line
  line `(b) any right, privilege, obligation or liability acquired, accrued or incurred under the Act so`
  line repealed;
  line
  line `(c) any penalty incurred in respect of any contravention under the Act so repealed; or`
  line
  line `(d) any proceeding or remedy in respect of any such right, privilege, obligation, liability, penalty`
  line `as aforesaid, and any such proceeding or remedy may be instituted, continued or enforced, and any`
  line `such penalty may be imposed as if that Act had not been repealed.`
  line
  line `(3) On the dissolution of the Central Council of Indian Medicine, the person appointed as the`
  line `Chairman of that Council and every other person appointed as the Member and any officer and other`
  line `employees of the Council and holding office as such immediately before such dissolution shall vacate`
  line `their respective offices and such Chairman and other Members shall be entitled to claim compensation not`
  line `exceeding three months' pay and allowances for the premature termination of term of their office or of`
  line `any contract of service:`
  line
  line `Provided that any officer or other employee who has been, immediately before the dissolution of the`
  line `Central Council of Indian Medicine appointed on deputation basis to the Central Council of Indian`
  line `Medicine, shall, on such dissolution, stand reverted to their parent cadre, Ministry or Department, as the`
  line `case may be:`
  line
  line `Provided further that any officer, expert, professional or other employee who has been, immediately`
  line `before the dissolution of the Central Council of Indian Medicine employed on regular basis or on`
  line `contractual basis by the Council, shall cease to be such officer, expert, professional or other employees of`
  line `the Central Council and shall be entitled to such compensation for the premature termination of his`
  line `employment, which shall not be less than three months pay and allowances, as may be prescribed.`
  line
  line `(4) Notwithstanding the repeal of the aforesaid enactment, any order made, any licence to practice`
  line `issued, any registration made, any permission to start new medical institution or to start higher course of`
  line `studies or to increase in the admission capacity granted, any recognition of medical qualifications granted,`
  line `under the Indian Medicine Central Council Act, 1970 (48 of 970) which are in force as on the date of`
  line `commencement of this Act shall continue to be in force till the date of their expiry for all purposes, as if`
  line `they had been issued or granted under the provisions of this Act or the rules or regulations made`
  line thereunder.
  line
  line `^1[(5) Notwithstanding the expiration of the period for reconstitution of the Central Council under section 3A of the Indian Medicine Central Council Act, 1970 (48 of 1970), as inserted by the Indian Medicine Central Council (Amendment) Act, 2020 (25 of 2020), all acts done by the Board of Governors constituted under sub-section (4) of that section and all the powers and functions of the Central Council exercised and performed by it under the repealed Act, as amended by the Indian Medicine Central Council (Amendment) Ordinance, 2021 (Ord. 5 of 2021), immediately before the commencement of this Act, shall be deemed to have been done or taken under the provisions of this Act and shall continue in force accordingly unless and until superseded by anything done or by any action taken under this Act.]`
obj_root_law_sections_59:
  sectionId (51292)
  sectionNo (59)
  orderNo 59
  title `Transitory provisions.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00003_202014_1602498622060&sectionId=51292&sectionno=59&orderno=59&orgactid=AC_CEN_51_0_00003_202014_1602498622060
obj_root_law_sections_59_content:
  string
  line `(1) The Commission shall be the successor in interest to the Central`
  line `Council of Indian Medicine including its subsidiaries or owned trusts and all the assets and liabilities of`
  line `the Central Council of Indian Medicine shall be deemed to have been transferred to the Commission.`
  line
  line `(2) Notwithstanding the repeal of the Indian Medicine Central Council Act, 1970 (48 of 1970), the`
  line `Medical standards, requirements and other provisions of the Indian Medicine Central Council Act, 1970`
  line `and the rules and regulations made thereunder shall continue to be in force and operate till new standards`
  line `or requirements are specified under this Act or the rules and regulations made thereunder:`
  line
  line `Provided that anything done or any action taken as regards the medical standards and requirements`
  line `under the enactment under repeal and the rules and regulations made thereunder shall be deemed to have`
  line `been done or taken under the corresponding provision of this Act and shall continue in force accordingly`
  line `unless and until superseded by anything or by any action taken under this Act.`
  line
  line `(3) The Central Government may take such appropriate measure as may be necessary for smooth`
  line `transition of the dissolved Central Council of Indian Medicine to the corresponding to new Commission`
  line `under this Act.`
obj_root_law_sections_59_footnotes:
  string
  line
