  slug the-public-employment-requirement-as-to-residence-act-1957
  handle (1429)
  collectionHandle 123456789/1362
  title `The Public Employment (Requirement as to Residence) Act, 1957`
  actNumber (44)
  enactmentDate 1957-12-07
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1429`
  sources obj_root_law_sources
  sections obj_root_law_sections
  actYear (1957)
  ministry `Ministry of Home Affairs`
  department `Department of Home`
  longTitle `An Act to make in pursuance of clause (3) of article 16 of the Constitution special provisions for requirement as to residence in regard to certain classes of public employment in certain areas and to repeal existing laws prescribing any such requirement.`
  enforcementDate 21-3-1957
  notification `21st March, 1957, vide notification No. G.S.R. 2323, dated 21st March, 1959, see Gazette of India, Extraordinary, Part II, sec. 3(i).`
