  (str title) (str `The Public Employment (Requirement as to Residence) Act, 1957`)
  (str actNumber) (str 44)
  (str enactmentDate) (str 1957-12-07)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1429`)
