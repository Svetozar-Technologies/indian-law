obj_root_law_sections_1:
  sectionId (29896)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00060_193030_1523350319482&sectionId=29896&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00060_193030_1523350319482
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Hindu Gains of Learning`
  line `Act, 1930.`
  line
  line `(2) It extends to the whole of India ^1[except the State of Jammu and Kashmir*.]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 48 of 1959, s. 3 and Sch. 1, for certain words (w.e.f 1-2-1960).`
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory`
  line `of Jammu and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (29897)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00060_193030_1523350319482&sectionId=29897&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00060_193030_1523350319482
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or`
  line context,—
  line
  line `(a) "acquirer" means a member of a Hindu undivided family, who acquires gains of`
  line learning;
  line
  line `(b) "gains of learning" means all acquisitions of property made substantially by`
  line `means of learning, whether such acquisitions be made before or after the`
  line `commencement of this Act and whether such acquisitions be the ordinary or the`
  line `extraordinary result of such learning; and`
  line
  line `(c) "learning" means education, whether elementary, technical, scientific, special or`
  line `general, and training of every kind which is usually intended to enable a person to`
  line `pursue any trade, industry, profession of avocation in life.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (29898)
  sectionNo (3)
  orderNo 3
  title `Gains of learning not to be held, not to be separate property of acquirer merely for certain reasons.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00060_193030_1523350319482&sectionId=29898&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00060_193030_1523350319482
obj_root_law_sections_3_content:
  string
  line `Notwithstanding any custom, rule or interpretation of the Hindu Law,`
  line `no gains of learning shall be held not to be the exclusive and separate property of the`
  line `acquirer merely by reason of—`
  line
  line `(a) his learning having been; in whole or in part, imparted to him by any member,`
  line `living or deceased, of his family, or with the aid of the joint funds of his family, or with`
  line `the aid of the funds of any member thereof, or`
  line
  line `(b) himself or his family having, while he was acquiring his learning, been maintained`
  line `or supported, wholly or in part, by the joint funds of his family, or by the funds of any`
  line `member thereof.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (29899)
  sectionNo (4)
  orderNo 4
  title Savings.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00060_193030_1523350319482&sectionId=29899&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00060_193030_1523350319482
obj_root_law_sections_4_content:
  string
  line `This Act shall not be deemed in any way to affect—`
  line
  line `(a) the terms or incidents of any transfer of property made or effected before the`
  line `commencement of this Act,`
  line
  line `(b) the validity, invalidity, effect or consequences of anything already suffered or done before`
  line `the commencement of this Act,`
  line
  line `(c) any right or liability created under a partition, or an agreement for a partition,`
  line `of joint family property made before the commencement of this Act, or`
  line
  line `(d) any remedy or proceeding in respect of such right or liability; or to render invalid or`
  line `in any way affect anything done before the commencement of this Act in any proceeding pending in a Court at such commencement; and any such remedy and any such proceeding as`
  line `is herein referred to may be enforced, instituted or continued, as the case may be, as if this`
  line `Act had not been passed.`
obj_root_law_sections_4_footnotes:
  string
  line
