  (str slug) (str the-warehousing-corporations-act-1962)
  (str handle) (str 1371)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Warehousing Corporations Act, 1962`)
  (str actNumber) (str 58)
  (str enactmentDate) (str 1962-12-19)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1371`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भाण्‍डागारण निगम अधिनियम,1962`)
  (str actYear) (str 1962)
  (str ministry) (str `Ministry of Consumer Affairs, Food and Public Distribution`)
  (str department) (str `Department of Food and Public Distribution`)
  (str longTitle) (str `An Act to provide for the incorporation and regulation of corporations for the purpose of warehousing of agricultural produce and certain other commodities and for matters connected therewith.`)
  (str enforcementDate) (str 18-03-1963)
  (str notification) (str `18th March, 1963, vide notification No. G.S.R. 463, dated 16th March, 1963, see Gazette of India, Extraordinary, Pt. II, sec. 3 (i). This Act shall, in its application to the States specified in the Schedule to Act 20 of 1965, have effect as if in clause (e) of section 2 the words and figures "being a commodity with respect to which Parliament has power to make laws by virtue of entry 33 in List III in the Seventh Schedule to the Constitution" had been omitted: vide Act 20 of 1965, s. 2 (w.e.f. 27-11-1965).`)
  (str fetchedAt) (str `2026-05-09T19:16:51.217Z`)
