obj_root_law:
  object
  (str slug) (str the-foreign-contribution-regulation-act-2010)
  (str handle) (str 2098)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Foreign Contribution (Regulation) Act, 2010`)
  (str actNumber) (str 42)
  (str enactmentDate) (str 2010-09-26)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2098`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `विदेशी अभिदाय (विनियमन) अधिनियम, 2010`)
  (str actYear) (str 2010)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of Internal Security`)
  (str longTitle) (str `An Act to consolidate the law to regulate the acceptance and utilisation of foreign contribution or foreign hospitality by certain individuals or associations or companies and to prohibit acceptance and utilisation of foreign contribution or foreign hospitality for any activities detrimental to the national interest and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-05-2011)
  (str notification) (str `1st May, 2011, vide notification No. S.O. 909(E), dated 29th April, 2011, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
