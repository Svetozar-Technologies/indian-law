obj_root_law:
  slug the-foreign-contribution-regulation-act-2010
  handle (2098)
  collectionHandle 123456789/1362
  title `The Foreign Contribution (Regulation) Act, 2010`
  actNumber (42)
  enactmentDate 2010-09-26
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2098`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `विदेशी अभिदाय (विनियमन) अधिनियम, 2010`
  actYear (2010)
  ministry `Ministry of Home Affairs`
  department `Department of Internal Security`
  longTitle `An Act to consolidate the law to regulate the acceptance and utilisation of foreign contribution or foreign hospitality by certain individuals or associations or companies and to prohibit acceptance and utilisation of foreign contribution or foreign hospitality for any activities detrimental to the national interest and for matters connected therewith or incidental thereto.`
  enforcementDate 01-05-2011
  notification `1st May, 2011, vide notification No. S.O. 909(E), dated 29th April, 2011, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T22:10:56.613Z`
  translations obj_root_law_translations
