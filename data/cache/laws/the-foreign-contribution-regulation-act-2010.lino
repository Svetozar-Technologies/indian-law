  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `अध्या य 5`
  line `विरीिण, तलाशी और अविग्रहण`
  line `23. लेखाओं या अविलेखों का विरीिण।`
  line `24. लेखाओं या अविलेखों का अविग्रहण।`
  line `25. अविवियम के उल्लं घि में प्र ाप्त िस्तु या करेन्सी या प्र वतिूवत का अविग्रहण।`
  line `26. अवि गृहीत िस्तु या करेंसी या प्र वतिूवत का व् य यि।`
  line `27. अविग्रहण का 1974 के अविवियम सं ० 2 के अिुसार ककया िािा।`
  line `अध्या य 6 न्`
  line `या यविणबयि`
  line `28. अविवियम के उल्लं घि में अविप्राप्त िस्तु या करेंसी या प्र वतिूवत का अविहरण।`
  line `29. अविहरण का न् या यविणबयि।`
  line `30. अविहरण की प्र कक्रया।`
  line `अध्या य 7`
  line `अपील और पुिरीिण`
  line `31. अपील।`
  line `32. केन्री य सरकार द्व ारा आदेशों का पुिरीिण।`
  line `अध्या य 8`
  line `अपराि और शावस्त यां`
  line `33. वमथ्या कर्थि, घोषणा करिा या वमथ्या लेखे पररदत्त करिा।`
  line `34. िारा 10 के उल्लं घि में अविप्राप्त िस्तु या करेन्सी या प्र वतिूवत के वलए शावस्त।`
  line `35. अविवियम के ककसी उपर्बंि के उल्लं घि के वलए दंड।`
  line `36. िहां िस्तु या करेन्सी या प्र वतिूवत अविहरण के वलए उपलब्ि ि हो िहां अवतररत िुमाबिा अविरोवपत करिे की शवत।`
  line `37. विि अपरािों के वलए अलग से दंड का उपर्बंि िहीं ककया गया है उिके वलए शावस्त।`
  line `38. विदेशी अविदाय स् िी कार करिे का प्र वतषेि।`
  line `39. कंपवियों द्व ारा अपराि।`
  line `40. अविवियम के अिीि अपरािों के अवियोिि का ििबि।`
  line `41. कवतपय अपरािों का शमि।`
  line `अध्या य 9 प्र`
  line कीणब
  line `42. िािकारी या दस्ता िेि मांगिे की शवत।`
  line `43. अविवियम के अिीि मामलों का अन्िे षण।`
  line `44. विवहत प्र ाविकारी द्व ारा केन्री य सरकार को वििरवणयों का कदया िािा।`
  line `45. सद्भािपूिबक की गई कारबिाई के वलए संरिण।`
  line `46. विदेश देिे की केन्री य सरकार की शवत।`
  line `47. शवत यों का प्रत् या योिि।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
