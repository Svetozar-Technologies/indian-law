obj_root_law_sections_1:
  sectionId (48084)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48084&sectionno=1&orderno=1&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Coal Mines Labour Welfare`
  line `Fund (Repeal) Act, 1986.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st October, 1986, vide notification No. S.O. 681(E), dated 19th September, 1986, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (48085)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48085&sectionno=2&orderno=2&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "the Act" means the Coal Mines Labour Welfare Fund Act, 1947 (32 of 1947);`
  line
  line `(b) "appointed day" means the date on which this Act comes into force;`
  line
  line `(c) "Housing Board" means the Coal Mines Labour Housing Board constituted under section 6 of`
  line `the Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (48086)
  sectionNo (3)
  orderNo 3
  title `Repeal of Act 32 of 1947 and dissolution of Housing Board.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48086&sectionno=3&orderno=3&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_3_content:
  string
  line `On the appointed day, the Coal`
  line `Mines Labour Welfare Fund Act, 1947 shall stand repealed, and the Coal Mines Labour Housing Board`
  line `shall stand dissolved.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (48087)
  sectionNo (4)
  orderNo 4
  title `Consequential provisions.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48087&sectionno=4&orderno=4&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_4_content:
  string
  line `On the dissolution of the Housing Board,--`
  line
  line `(a) all rights and privileges of the Housing Board shall become the rights and privileges,`
  line `respectively, of the Central Government;`
  line
  line `(b) all properties, movable and immovable, including cash balances, reserve funds, investments`
  line `and moneys lying to the credit of the Housing Board and all rights and interests in, or arising out of,`
  line `such properties as were immediately before the appointed day, in the ownership, possession, power or`
  line `control of the Housing Board, and all books of account, registers and records and all other documents`
  line `of whatever nature relating thereto, shall vest in the Central Government;`
  line
  line `(c) all the borrowings, liabilities and obligations of the Housing Board of whatever kind and`
  line `subsisting immediately before the appointed day, shall be deemed on and from such day to be the`
  line `borrowings, liabilities and obligations, as the case may be, of the Central Government;`
  line
  line `(d) all contracts entered into, and all matters and things engaged to be done by, with or for, the`
  line `Housing Board and subsisting immediately before the appointed day shall be deemed, on and from`
  line `such day to have been entered into or engaged to be done by, with or for, the Central Government;`
  line
  line `(e) all licences and permits granted to the Housing Board and in force immediately before the`
  line `appointed day shall be deemed on and from such day to have been granted to the Central Government`
  line `and shall have effect accordingly.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (48088)
  sectionNo (5)
  orderNo 5
  title `Power of Central Government to direct vesting of rights in a Government company.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48088&sectionno=5&orderno=5&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_5_content:
  string
  line `Notwithstanding anything contained in section 4, the Central Government may, if it is`
  line `satisfied that a Government company is willing to comply, or has complied, with such terms and`
  line `conditions as that Government may think fit to impose, direct, by an order in writing, that the right, title`
  line `and interest of the Housing Board in relation to any property shall, instead of continuing to vest in it, vest`
  line `in the Government company (hereinafter referred to as the Government company) either on the date of`
  line `publication of the direction or on such earlier or later date (not being a date earlier than the appointed day)`
  line `as may be specified in the direction, and on such vesting, the liability or obligation, as the case may be, of`
  line `the Housing Board, in relation to such property shall, instead of continuing to be the liability or obligation`
  line `of the Central Government, become the liability or obligation, as the case may be, of the Government`
  line company.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (48089)
  sectionNo (6)
  orderNo 6
  title `Continuation of suits, etc., against Central Government.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48089&sectionno=6&orderno=6&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_6_content:
  string
  line `(1) if, on the appointed day, any suit`
  line `appeal or other proceeding of whatever nature in relation to the Housing Board is pending by or against`
  line `such Board, the same shall not abate, be discontinued or be in any way prejudicially affected by reason of`
  line `the dissolution of the Housing Board; but the suit, appeal or other proceeding may be continued,`
  line `prosecuted and enforced by or against the Central Government or the Government company, as the case`
  line `may be.`
  line
  line `(2) Where, before the appointed day, any cause of action for any suit or proceeding or any right to`
  line `appeal arose in favour of, or against, the Housing Board, and the institution of any suit or proceeding on`
  line `such cause of action or the filing of such appeal was not barred before the appointed day, such suit or`
  line `proceeding may be instituted or appeal may be filed by or against the Central Government or the`
  line `Government company, as the case may be.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (48090)
  sectionNo (7)
  orderNo 7
  title `Moneys, etc., of the Fund to be credited to the Consolidated Fund of India.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48090&sectionno=7&orderno=7&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_7_content:
  string
  line `On the appointed`
  line `day, all moneys and cash balances lying in the credit of the housing account and the general welfare`
  line `account of the Coal Mines Labour Housing and General Welfare Fund constituted under section 4 of the`
  line `Act, shall become part of, and be credited to, the Consolidated Fund of India.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (48091)
  sectionNo (8)
  orderNo 8
  title `Collection and payment of arrears of duty.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00009_198627_1517807326828&sectionId=48091&sectionno=8&orderno=8&orgactid=AC_CEN_15_16_00009_198627_1517807326828
obj_root_law_sections_8_content:
  string
  line `Notwithstanding the repeal of the Act, the proceeds`
  line `of duty levied before the appointed day under section 3 of the Act,--`
  line
  line `(i) if collected by the collecting agencies but not paid into the Reserve Bank of India; and`
  line
  line `(ii) if not collected by the collecting agencies,`
  line
  line `shall be paid or, as the case may be, collected and paid, into the Reserve Bank of India for being credited`
  line `to the Consolidated Fund of India.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `कोयला खान श्रम कल्‍याण निधि (निरसन) अधिनियम,1986`
