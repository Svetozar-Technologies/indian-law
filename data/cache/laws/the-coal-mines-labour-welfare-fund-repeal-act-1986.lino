  object
  (str title) (str `कोयला खान श्रम कल्‍याण निधि (निरसन) अधिनियम,1986`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1859/5/H1986-27.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:16:27.160Z`)
  (str pageCount) (int 2)
