obj_root_law:
  object
  (str slug) (str the-banking-companies-acquisition-and-transfer-of-undertakings-act-1980)
  (str handle) (str 1792)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Banking Companies (Acquisition and Transfer of Undertakings) Act, 1980`)
  (str actNumber) (str 40)
  (str enactmentDate) (str 1980-07-11)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1792`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बैंककारी कम्‍पनी (उपक्रमों का अर्जन और अन्‍तरण) अधिनियम,1980`)
  (str actYear) (str 1980)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Financial Services`)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the undertakings of certain banking companies, having regard to their size, resources, coverage and organisation, in order further to control the heights of the economy, to meet progressively, and serve better, the needs of the development of the economy and to promote the welfare of the people, in conformity with the policy of the State towards securing the principles laid down in clauses (b) and (c) of article 39 of the Constitution and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 15-04-1980)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T10:19:11.756Z`)
  (str translations) obj_root_law_translations
