  (str title) (str `बैंककारी कम्‍पनी (उपक्रमों का अर्जन और अन्‍तरण) अधिनियम,1980`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1792/2/hhH198040.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:21:01.085Z`)
