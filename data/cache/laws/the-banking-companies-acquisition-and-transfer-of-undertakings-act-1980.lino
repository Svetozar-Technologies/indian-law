obj_root_law:
  slug the-banking-companies-acquisition-and-transfer-of-undertakings-act-1980
  handle (1792)
  collectionHandle 123456789/1362
  title `The Banking Companies (Acquisition and Transfer of Undertakings) Act, 1980`
  actNumber (40)
  enactmentDate 1980-07-11
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1792`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `बैंककारी कम्‍पनी (उपक्रमों का अर्जन और अन्‍तरण) अधिनियम,1980`
  actYear (1980)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to provide for the acquisition and transfer of the undertakings of certain banking companies, having regard to their size, resources, coverage and organisation, in order further to control the heights of the economy, to meet progressively, and serve better, the needs of the development of the economy and to promote the welfare of the people, in conformity with the policy of the State towards securing the principles laid down in clauses (b) and (c) of article 39 of the Constitution and for matters connected therewith or incidental thereto.`
  enforcementDate 15-04-1980
  notification undefined
  fetchedAt `2026-05-09T10:19:11.756Z`
  translations obj_root_law_translations
