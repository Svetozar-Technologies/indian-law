obj_root_law_sections_1:
  sectionId (43410)
  sectionNo (1)
  orderNo 1
  title `Title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00062_189115_1523336259308&sectionId=43410&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00062_189115_1523336259308
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Moorshedabad Act, 1891; and`
  line
  line `(2) It shall come into force at once.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (43411)
  sectionNo (2)
  orderNo 2
  title `Confirmation of indenture of March, 1891.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00062_189115_1523336259308&sectionId=43411&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00062_189115_1523336259308
obj_root_law_sections_2_content:
  string
  line `The said indenture is hereby`
  line confirmed.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (43412)
  sectionNo (3)
  orderNo 3
  title `Additions to schedule to indenture.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00062_189115_1523336259308&sectionId=43412&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00062_189115_1523336259308
obj_root_law_sections_3_content:
  string
  line `(1) The Governor General in Council, by`
  line `notification in the Gazette of India, may in his discretion, on the written request of the Nawab`
  line `Bahadoor of Moorshedabad for the time being, add, in such form as the Governor General in Council`
  line `may think fit, to the schedules of immoveable property which are annexed to the said indenture any`
  line `additional immoveable property which may be acquired from time to time for the maintenance of the`
  line `position and dignity of the Nawab Bahadoor of Moorshedabad for the time being.`
  line
  line `(2) No such notification as is referred to in sub-section (1) shall be made without such previous`
  line `publication as would be necessary under section 6 of the General Clauses Act, 1887, in the case of a`
  line `rule to be made under an enactment to which that section applies.`
  line
  line `(3) The publication in the Gazette of India of such a notification, as having been made by the`
  line `Governor General in Council, shall, subject to any further order of the Governor General in Council,`
  line `be conclusive proof with respect to the subject-matter of the notification.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (43413)
  sectionNo (4)
  orderNo 4
  title `Limitation for claims to scheduled immoveable property.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00062_189115_1523336259308&sectionId=43413&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00062_189115_1523336259308
obj_root_law_sections_4_content:
  string
  line `No right to any`
  line `immoveable property mentioned in any of the schedules to the said indenture, or in any addition`
  line `which under the last foregoing section may from time to time be made to those schedules or any of`
  line `them, shall, if the right has not accrued before the passing of this Act, be acquired by any person by`
  line `adverse possession or assertion of title unless such adverse possession or assertion of title is found to`
  line `have existed for sixty years.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (43414)
  sectionNo (5)
  orderNo 5
  title `Perpetual descent of property.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00062_189115_1523336259308&sectionId=43414&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00062_189115_1523336259308
obj_root_law_sections_5_content:
  string
  line `All property, moveable and immoveable, mentioned in the`
  line `said indenture, or in any of the schedules thereto or in any addition which under section 3 may from`
  line `time to time be made to those schedules or any of them, shall descend and, subject to the provisions of`
  line `the said indenture, be enjoyed for ever by the Nawab Bahadoor of Moorshedabad for the time being.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (43415)
  sectionNo (6)
  orderNo 6
  title `Relief from stamp and registration laws.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00062_189115_1523336259308&sectionId=43415&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00062_189115_1523336259308
obj_root_law_sections_6_content:
  string
  line `The said indenture shall for all the purposes`
  line `of all enactments for the time being in force be admissible in evidence and have in all other respects`
  line `the same effect as if it had been duly stamped and registered in such manner as those enactments, or`
  line `any of them, or any rule or order under any of them, may require.`
obj_root_law_sections_6_footnotes:
  string
  line
