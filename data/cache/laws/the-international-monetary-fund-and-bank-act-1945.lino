obj_root_law_sections_1:
  sectionId (32050)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32050&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_1_content:
  string
  line `(1) This ^1[Act] may be called the International`
  line `Monetary Fund and Bank ^1[Act], 1945.`
  line
  line `(2) It extends to ^2[the whole of India ^3* * *].`
  line
  line `(3) It shall come into force at once.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 25 of 1959, s. 2, for "Ordinance".`
  line
  line `2. Subs. by the A.O. 1950, for "all the Provinces of India".`
  line
  line `3. The words "except Part B States" omitted by Act 3 of 1951, s. 3 and the Sch.`
obj_root_law_sections_2:
  sectionId (32051)
  sectionNo (2)
  orderNo 2
  title `Payments to International Fund and Bank.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32051&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_2_content:
  string
  line `(1) ^1[There shall be paid, after due appropriation`
  line `made by Parliament by law in this behalf, out of the Consolidated Fund of India] all such sums as may`
  line `from time to time be required for the purpose of paying--`
  line
  line `(a) the subscriptions payable by the Central Government, to the International Fund under`
  line `paragraph (a) of section 3 ^2* * * of Article III of the Fund Agreement, and ^3[to the International`
  line `Bank under paragraphs (a) and (c)] of section 3 of Article II of the Bank Agreement;`
  line
  line `(b) any sums payable by the Central Government to the International Fund under`
  line `^4[section 11 of Article V] of the Fund Agreement, and to the International Bank under`
  line `section 9 of Article II of the Bank Agreement;`
  line
  line `(c) any charges payable by the Central Government to the International Fund under section 8 of`
  line `Article V ^5[, or under section 2, section 3 or section 5 of ^6[Article XX]],] of the Fund Agreement;`
  line
  line `(d) any sums required for implementing the guarantee of the Central Government referred to in`
  line `section 3 of Article XIII of the Fund Agreement;`
  line
  line `^7[(dd) any assessments required to be paid by the Central Government to the International Fund`
  line `under section 4 or section 5 of ^8[Article XX] of the Fund Agreement;]`
  line
  line `(e) any compensation required to be paid by the Central Government to the International Fund or`
  line `to any member thereof under ^9[Schedule I, Schedule J or Schedule K] to the Fund Agreement.`
  line
  line `(2) The Central Government may, if it thinks fit so to do, create and issue to the International`
  line `Fund or International Bank, in such form as it thinks fit, any such non-interest bearing and nonnegotiable notes or other obligations as are provided for by ^10[section 4] of Article III of the Fund`
  line `Agreement and section 12 of Article V of the Bank Agreement.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 41 of 1969, s. 2, for certain words (w.e.f. 26-12-1981).`
  line
  line `2. Omitted by Act 67 of 1982, s. 2 (w.e.f. 15-1-1983).`
  line
  line `3. Subs. by Act 25 of 1959, s. 4, for "to the International Bank under paragraph (a)".`
  line
  line `4. Subs. by Act 67 of 1982, s. 2, for "paragraph (b) of section of Article IV" (w.e.f. 15-1-1983).`
  line
  line `5. Ins. by Act 41 of 1969, s. 2 (w.e.f. 26-12-1981).`
  line
  line `6. Subs. by Act 67 of 1982, s. 2, for "Article XXVI" (w.e.f. 15-1-1983).`
  line
  line `7. Ins by Act 41 of 1969, s. 2 (w.e.f. 26-12-1981).`
  line
  line `8. Subs. by Act 67 of 1982, s. 2, for "Article XXVI" (w.e.f. 15-1-1983).`
  line
  line `9. Subs. by s. 2, ibid., for "Schedule D or Schedule E" (w.e.f. 15-1-1983).`
  line
  line `10. Subs. by s. 2, ibid., for "section 5" (w.e.f. 15-1-1983).`
obj_root_law_sections_3:
  sectionId (32052)
  sectionNo (3)
  orderNo 3
  title `Reserve Bank to be depository for International Fund and Bank.`
  content obj_root_law_sections_3_content
  footnotes `1. The word "British" omitted by Act 48 of 1952, s. 3 and Sch. II.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32052&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_3_content:
  string
  line `The Reserve Bank of`
  line `India (hereinafter referred to as the Reserve Bank) shall be the depository of the ^1* * * Indian currency`
  line `holdings of the International Fund and International Bank.`
obj_root_law_sections_3_a:
  sectionId (32053)
  sectionNo 3A
  orderNo 4
  title `Reserve Bank to use, receive, acquire, etc., special drawing rights on behalf of Central Government.`
  content obj_root_law_sections_3_a_content
  footnotes `1. Ins. by Act 41 of 1969, s. 3 (w.e.f. 26-12-1981).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32053&sectionno=3A&orderno=4&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Reserve Bank to use, receive, acquire, etc., special drawing rights on behalf of`
  line `Central Government.--The Reserve Bank may, on behalf of the Central Government, use, receive,`
  line `acquire, hold, transfer or operate the special drawing rights of that Government in the International Fund`
  line `and perform all acts supplemental or incidental thereto.]`
obj_root_law_sections_4:
  sectionId (32054)
  sectionNo (4)
  orderNo 5
  title `Power to call for information.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32054&sectionno=4&orderno=5&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_4_content:
  string
  line `(1) Where under ^1[paragraph (b) of section 3 of Article IV or]`
  line `section 5 of Article VIII of the Fund Agreement, the International Fund requires the Central Government`
  line `to furnish it with any information, the Central Government, or if generally or specially authorised by the`
  line `Central Government in this behalf, the Reserve Bank, may by order in writing require any peson to`
  line `furnish to such officer or other person as may be specified in the order such detailed information as the`
  line `Central Government or the Reserve Bank, as the case may be, may determine to be essential for the`
  line `purpose of complying with the request of the International Fund; and any person so required shall be`
  line `bound to furnish such information.`
  line
  line `(2) Every officer or person to whom any information is required to be furnished under this section`
  line `shall be deemed to be a public servant within the meaning of section 21 of the Indian Penal Code`
  line `(45 of 1860).`
  line
  line `(3) No information obtained under this section shall be furnished to the International Fund in such`
  line `detail as to disclose the affairs of any person ^2***.`
  line
  line `(4) A determination of the Central Government or the Reserve Bank under sub-section (1) as to the`
  line `extent of detail in which information is to be furnished shall be final, and in any prosecution under section`
  line `176 or section 177 of the Indian Penal Code (45 of 1860) in respect of any information required to be`
  line `furnished under this section, it shall not be a defence to assert that the information was required to be`
  line `furnished in greater detail than was essential for the purpose of complying with the request of the`
  line `International Fund.`
  line
  line `(5) No prosecution for an offence in respect of any information required to be furnished under this`
  line `section shall be instituted except with the previous sanction of the Central Government.`
obj_root_law_sections_4_footnotes:
  string
  line `1. Ins. by Act 67 of 1982, s. 3 (w.e.f. 15-1-1983).`
  line
  line `2. Certain words omitted by s. 3, ibid. (w.e.f. 15-1-1983).`
obj_root_law_sections_5:
  sectionId (32055)
  sectionNo (5)
  orderNo 6
  title `Certain provisions of Agreements to have force of law.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by Act 3 of 1951, s. 3 and the Sch., for "Part A States and Part C States".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32055&sectionno=5&orderno=6&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_5_content:
  string
  line `Notwithstanding anything to the`
  line `contrary contained in any other law, the provisions of the Fund and Bank Agreements set out in the`
  line `Schedule shall have the force of law in ^1[India]:`
  line
  line `Provided that nothing in section 9 of Article IX of the Fund Agreement or in section 9 of Article VII`
  line `of the Bank Agreement shall be construed as--`
  line
  line `(a) entitling the International Fund or International Bank to import into ^1[India] goods`
  line `free of any duty of customs without any restriction on their subsequent sale therein, or`
  line
  line `(b) conferring on the International Fund or International Bank any exemption from duties or`
  line `taxes which form part of the price of goods sold or which are in fact no more than charges for`
  line `services rendered.`
obj_root_law_sections_6:
  sectionId (32056)
  sectionNo (6)
  orderNo 7
  title Repealed.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32056&sectionno=6&orderno=7&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_6_content:
  string
  line `[Amendment of section 17, Act 2 of 1934.] Rep. by the Repealing and Amending Act, 1952`
  line `(48 of 1952), s. 2 and Sch.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (32057)
  sectionNo (7)
  orderNo 8
  title `Power to make rules.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00031_194547_1523354437533&sectionId=32057&sectionno=7&orderno=8&orgactid=AC_CEN_2_11_00031_194547_1523354437533
obj_root_law_sections_7_content:
  string
  line `^1[(1)] The Central Government may, by notification in the Official`
  line `Gazette, make rules for giving effect to the provisions set out in the Schedule, and generally for carrying`
  line `out the purposes of this ^2[Act].`
  line
  line `^3[(2) Every rule made under this section shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament while it is in session for a total period of thirty days which may be`
  line `comprised in one session or ^4[in two or more successive sessions], and if before the expiry of ^5[the`
  line `session immediately following the session or the successive sessions aforesaid], both Houses agree in`
  line `making any modification in the rule, or both Houses agree that the rule should not be made, the rule`
  line `shall thereafter have effect only in such modified form or be of no effect, as the case may be, so`
  line `however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that rule.]`
obj_root_law_sections_7_footnotes:
  string
  line `1. Renumbered as sub-section (1) by Act 25 of 1959, s. 5.`
  line
  line `2. Subs. by s. 2, ibid., for "Ordinance".`
  line
  line `3. Ins. by s. 5, ibid.`
  line
  line `4. Subs. by Act 67 of 1982, s. 4, for "in two successive sessions" (w.e.f. 15-1-1983).`
  line
  line `5. Subs. by s. 4, ibid., for certain words (w.e.f. 15-1-1983).`
