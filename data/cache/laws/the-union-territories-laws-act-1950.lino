obj_root_law_sources_hi_1950:
  kind pdf
  url `https://www.indiacode.nic.in/bitstream/123456789/1874/2/h195030.pdf`
  title `संघ राज्यक्षेत्र (विधि) अधिनियम, 1950`
obj_root_law_sections:
  obj_root_law_sections_1
  obj_root_law_sections_2
  obj_root_law_sections_3
  obj_root_law_sections_4
obj_root_law_sections_1:
  sectionId (27004)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part C States".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00057_195030_1517807327422&sectionId=27004&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00057_195030_1517807327422
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the ^1[Union Territories] (Laws)`
  line `Act, 1950.`
  line
  line `(2) It shall come into force on the 16th day of April, 1950.`
obj_root_law_sections_2:
  sectionId (27005)
  sectionNo (2)
  orderNo 2
  title `Power to extend enactments to certain Union territories.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00057_195030_1517807327422&sectionId=27005&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00057_195030_1517807327422
obj_root_law_sections_2_content:
  string
  line `The Central Government may, by`
  line `notification in the Official Gazette, extend to ^1`
  line `[the Union territory of Delhi, Himachal Pradesh, Manipur`
  line `or Tripura or to any part of such territory], with such restrictions and modifications as it thinks fit, any`
  line `enactment which is in force in a ^2`
  line `[State] at the date of the notification, ^3`
  line `* * *.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. ibid., for certain words.`
  line
  line `2. Subs., ibid., for Part A State.`
  line
  line `3. Certain words, brackets and letters, omitted by Act 48 of 1952, s. 3 and the Second Schedule.`
obj_root_law_sections_3:
  sectionId (27006)
  sectionNo (3)
  orderNo 3
  title `Extension of laws to Tripura, Vindhya Pradesh and Manipur.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00057_195030_1517807327422&sectionId=27006&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00057_195030_1517807327422
obj_root_law_sections_3_content:
  string
  line `(1) The Acts and Ordinances`
  line `specified in the Schedule to the Merged States (Laws) Act, 1949 (59 of 1949), are hereby extended to,`
  line `and shall be in force in, the States of Tripura and Vindhya Pradesh, as they are generally in force in the`
  line `territories to which they extend immediately before the commencement of this Act.`
  line
  line `(2)`
  line ^1
  line `[Subject to the provisions contained in sub-section (2A), the Acts and ordinances referred to in`
  line `sub-section (1)], are hereby extended to, and shall be in force in, the State of Manipur as they are`
  line `generally in force in the territories to which they extend immediately before the commencement of`
  line `this Act:`
  line
  line `Provided that the Indian Penal Code (45 of 1860) in its application to the State of Manipur shall have`
  line `effect as if—`
  line
  line `(a) in section 361, for the word "eighteen" the word "fifteen" had been substituted, and`
  line
  line `(b) in section 375, for the word "sixteen" in clause Fifthly the word "fourteen" had been`
  line `substituted, and for the word "fifteen" in the Exception the word "thirteen" had been substituted.`
  line
  line ^2
  line `[(2A) The Acts specified in Part A of the Schedule to this Act shall not extend to the State of`
  line `Manipur, and the Acts specified in Part B thereof shall extend to, and be in force in that State only as`
  line `from the date of commencement of the Union Territories (Laws) Amendment Act, 1956 (68 of 1956), and`
  line `shall with effect from that date, be amended to the manner and to the extent specified in the said Part.]`
  line
  line `(3) For the purpose of facilities the application in the said States of any such Act or Ordinance as`
  line `aforeaid any Court or other authority may construe the Act or Ordinance with such alterations not`
  line `affecting the substance as may be necessary or proper to adapt it to the matter before the Court or other`
  line authority.
  line
  line ^2
  line `[Explanation.—For the purposes of this section and section 4, any reference to the State of Manipur`
  line `or Tripura in relation to any period after the 31st October, 1956, shall be construed as a reference to the`
  line `Union territory of Manipur or Tripura as the case may be].`
obj_root_law_sections_3_footnotes:
  string
