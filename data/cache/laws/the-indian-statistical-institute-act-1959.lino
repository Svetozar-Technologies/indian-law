obj_root_law_sections_1:
  sectionId (36637)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36637&sectionno=1&orderno=1&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Indian Statistical Institute`
  line `Act, 1959.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st April, 1960, vide notification No. S.O. 584(E), dated 2nd March, 1960, see Gazette of India, Extraordinary, Part II,`
  line `sec 3(ii).`
obj_root_law_sections_2:
  sectionId (36638)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36638&sectionno=2&orderno=2&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires.--`
  line
  line `(a) "Institute" means the Indian Statistical Institute registered under the Societies Registration`
  line `Act, 1860 (21 of 1860);`
  line
  line `(b) "memorandum" means the memorandum of association of the Institute filed with the`
  line `Registrar of Joint-Stock Companies under the Societies Registration Act, 1860 (21 of 1860);`
  line
  line `(c) "rules and regulations" includes any rule or regulation (by whatever name called) which the`
  line `Institute is competent to make in the exercise of the powers conferred on it under the Societies`
  line `Registration Act, 1860 (21 of 1860), but shall not include any bye-laws or standing orders made`
  line `under the rules and regulations for the conduct of its day-to-day administration.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (36639)
  sectionNo (3)
  orderNo 3
  title `Declaration of the Indian Statistical Institute as an institution of national importance.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36639&sectionno=3&orderno=3&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_3_content:
  string
  line `Whereas the objects of the institution known as the Indian Statistical Institute are such as`
  line `to make it an institution of national importance, it is hereby declared that the Indian Statistical Institute is`
  line `an institution of national importance.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36640)
  sectionNo (4)
  orderNo 4
  title `Grant of degrees and diplomas by Institute.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 38 of 1995, s. 2, for "statistics" (w.e.f. 18-9-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36640&sectionno=4&orderno=4&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_4_content:
  string
  line `Notwithstanding anything contained in the`
  line `University Grants Commission Act, 1956 (3 of 1956), or in any other law for the time being force, the`
  line `Institute may hold such examinations and grant such degrees and diplomas in ^1[statistics, mathematics,`
  line `quantitative economics, computer science and such other subjects related to statistics] as may be`
  line `determined by the Institute from time to time.`
obj_root_law_sections_5:
  sectionId (36641)
  sectionNo (5)
  orderNo 5
  title `Grants, loans, etc., by Central Government to the Institute.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36641&sectionno=5&orderno=5&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_5_content:
  string
  line `For the purpose of enabling the`
  line `Institute to discharge efficiently its functions, including research, education, training, project activities`
  line `and statistical work relating to planning for national development, the Central Government may, after due`
  line `appropriation made by Parliament by law in this behalf, pay to the Institute in each financial year such`
  line `sums of money as that Government considers necessary by way of grant, loan or otherwise.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36642)
  sectionNo (6)
  orderNo 6
  title `Audit of accounts of the Institute.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36642&sectionno=6&orderno=6&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_6_content:
  string
  line `(1) The accounts of the Institute shall be audited by auditors`
  line `duly qualified to act as auditors of companies under the Companies Act, 1956 (1 of 1956), and the`
  line `institute shall appoint such auditors as the Central Government may, after consultation with the`
  line `Comptroller and Auditor-General of India and the Institute, select.`
  line
  line `(2) The Central Government may issue such directions to the auditors in the performance of their`
  line `duties as it thinks fit.`
  line
  line `(3) Every such auditor in the performance of his duties shall have at all reasonable times access to the`
  line `registers, books of account, records and other documents of the Institute.`
  line
  line `(4) The auditors shall submit their report to the Institute and shall also forward a copy thereof to the`
  line `Central Government for its information.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (36643)
  sectionNo (7)
  orderNo 7
  title `Prior approval of Central Government necessary for certain action by Institute.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36643&sectionno=7&orderno=7&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_7_content:
  string
  line `Notwithstanding anything contained in the Societies Registration Act, 1860 (21 of 1860), or`
  line `in the memorandum or rules and regulations, the Institute shall not, except with the previous approval of`
  line `the Central Government,--`
  line
  line `(a) alter, extend or abridge any of the purposes for which it has been established or for which it is`
  line `being used immediately before the commencement of this Act, or amalgamate itself either wholly or`
  line `partially with any other institution or society; or`
  line
  line `(b) alter or amend in any manner the memorandum or rules and regulations; or`
  line
  line `(c) sell or otherwise dispose of any property acquired by the Institute with money specifically`
  line `provided for such acquisition by the Central Government:`
  line
  line `Provided that no such approval shall be necessary in the case of any such movable property or`
  line `class of movable property as may be specified by the Central Government in this behalf by general or`
  line `special order; or`
  line
  line `(d) be dissolved.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (36649)
  sectionNo (8)
  orderNo 8
  title `Constitution of Committees by Central Government for preparing programme of work by the Institute, etc.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36649&sectionno=8&orderno=8&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_8_content:
  string
  line `(1) The Central Government may constitute as many Committees as and when it`
  line `considers necessary consisting of such number of persons as it thinks fit to appoint thereto and assign to`
  line `each such Committee all or any of the following duties, namely:--`
  line
  line `(a) the preparation and submission to the Central Government as far as possible before the`
  line `commencement of each financial year, of statements showing programmes of work agreed to be`
  line `undertaken by the Institute during that year for which the Central Government may provide funds, as`
  line `well as general financial estimates in respect of such work; and`
  line
  line `(b) the settlement on broad lines of the programme of such work.`
  line
  line `(2) Where the Institute does not agree to undertake any work suggested by any Committee referred to`
  line `in sub-section (1), it shall give to the Central Government its reasons for not so agreeing.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (36645)
  sectionNo (9)
  orderNo 9
  title `Review of work done, Inspection of assets, etc.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36645&sectionno=9&orderno=9&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government may constitute a`
  line `Committee consisting of such number of persons as it thinks fit to appoint thereto for the purpose of--`
  line
  line `(a) reviewing the work done by the Institute and the progress made by it;`
  line
  line `(b) inspecting its buildings, equipment and other assets;`
  line
  line `(c) evaluating the work done by the Institute; and`
  line
  line `(d) advising Government generally on any matter which in the opinion of the Central Government`
  line `is of importance in connection with the work of the Institute;`
  line
  line `and the Committee shall submit its reports thereon in such manner as the Central Government may direct.`
  line
  line `(2) Notice shall be given in every case to the Institute of the intention to cause a review, inspection or`
  line `evaluation to be made, and the Institute shall be entitled to appoint a representative who shall have the`
  line `right to be present and be heard at such review, inspection or evaluation.`
  line
  line `(3) The Central Government may address the Chairman of the Institute with reference to the result of`
  line `such review, inspection or evaluation as disclosed in any report of the Committee referred to in`
  line `sub-section (1), and the Chairman shall communicate to the Central Government the action, if any, taken`
  line thereon.
  line
  line `(4) When the Central Government has, in pursuance of sub-section (3), addressed the Chairman of the`
  line `Institute in connection with any matter, and the Chairman does not within a reasonable time take action to`
  line `the satisfaction of the Central Government in respect thereof, the Central Government may, after`
  line `considering any explanations furnished or representations made on behalf of the Institute, issue such`
  line `directions as it considers necessary in respect of any of the matters dealt with in the report.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (36646)
  sectionNo (10)
  orderNo 10
  title `Institute to afford facilities to Committees.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36646&sectionno=10&orderno=10&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_10_content:
  string
  line `The Institute shall be bound to afford all necessary`
  line `facilities to any Committee constituted under section 8 or section 9 for the purpose of enabling it to carry`
  line `out its duties.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (36647)
  sectionNo (11)
  orderNo 11
  title `Power to issue directions to Institute.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36647&sectionno=11&orderno=11&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_11_content:
  string
  line `(1) The Central Government may, if it is satisfied that it`
  line `is necessary so to do in the public interest, issue, for reasons to be recorded and communicated to the`
  line `Institute, such directions as it thinks fit to the Institute, and such directions may include directions`
  line `requiring the Institute--`
  line
  line `(a) to amend the memorandum or to make or amend any rule or regulation within such period as`
  line `may be specified in the directions;`
  line
  line `(b) to give priorities to the work undertaken or to be undertaken by the Institute in such manner as`
  line `the Central Government may think fit to specify in this behalf.`
  line
  line `(2) Any directions issued under this section shall have effect, notwithstanding anything contained in`
  line `any law for the time being in force or in the memorandum or rules and regulations of the Institute.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (36648)
  sectionNo (12)
  orderNo 12
  title `Power of Central Government to assume functions of control.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_40_66_00001_195957_1517807322454&sectionId=36648&sectionno=12&orderno=12&orgactid=AC_CEN_40_66_00001_195957_1517807322454
obj_root_law_sections_12_content:
  string
  line `(1) If, in the opinion of the`
  line `Central Government,--`
  line
  line `(i) the Institute without just or reasonable cause has made default in giving effect to any direction`
  line `issued under sub-section (4) of section 9 or section 11; or`
  line
  line `(ii) the Council of the Institute has exceeded or abused its powers in relation to the Institute or`
  line `any part thereof;`
  line
  line `the Central Government may, by written order, direct the Institute within a period to be specified in the`
  line `order to show cause to the satisfaction of the Central Government against the making of any appointment`
  line `referred to in sub-section (2).`
  line
  line `(2) If, within the period fixed by any order issued under sub-section (1), cause is not shown to the`
  line `satisfaction of the Central Government, the Central Government may, by order published in the`
  line `Official Gazette and stating the reasons therefore, appoint one or more persons to take charge of the`
  line `Institute or any part thereof for such period not exceeding two years as may be specified in the order.`
  line
  line `(3) Notwithstanding anything contained in any law for the time being in force or in the memorandum`
  line `or rules and regulations of the Institute, on the issue of an order under sub-section (2), during the period`
  line `specified in that order,--`
  line
  line `(a) where the order provides for any person or persons being in charge of the Institute--`
  line
  line `(i) all persons holding office as Members of the Council, including the Chairman, shall be`
  line `deemed to have vacated their offices as such;`
  line
  line `(ii) the person or persons appointed under sub-section (2) to be in charge of the Institute shall`
  line `exercise all the powers and perform all the duties of the Chairman or Council of the Institute,`
  line `whether at a meeting or otherwise, in respect of the Institute;`
  line
  line `(b) where the order provides for any person or persons being in charge of any part of the Institute,`
  line `the person or persons so appointed shall alone be entitled to exercise all the powers and perform all`
  line `the duties of the Chairman or Council in relation to that part.`
obj_root_law_sections_12_footnotes:
  string
  line
