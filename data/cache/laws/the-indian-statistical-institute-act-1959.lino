  (str title) (str `The Indian Statistical Institute Act, 1959`)
  (str actNumber) (str 57)
  (str enactmentDate) (str 1959-12-24)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1425`)
  (str sources) obj_root_law_sources
