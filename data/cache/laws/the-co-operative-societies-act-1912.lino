obj_root_law_sections_1:
  sectionId (70733)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes `1. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part B States".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70733&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Co-operative Societies Act, 1912; and`
  line
  line `(2) it extends to the whole of India except ^2[the territories which, immediately before the 1st November, 1956, were comprised in Part B States.]`
obj_root_law_sections_2:
  sectionId (70734)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70734&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context,—`
  line
  line `(a) “by-laws” means the registered by-laws for the time being in force, and includes a registered`
  line `amendment of the by-laws:`
  line
  line `(b) “committee” means the governing body of a registered society to whom the management of`
  line `its affairs is entrusted:`
  line
  line `(c) “member” includes a person joining in the application for the registration of a society and`
  line `aperson admitted to membership after registration in accordance with the by laws and any rules:`
  line
  line `(d) “officer” includes a chairman, secretary, treasurer, member of committee, or other person`
  line `empowered under the rules or the by-laws to give directions in regard to the business of the society:`
  line
  line `(e) “registered society” means a society registered or deemed to be registered under this Act:`
  line
  line `(f) “Registrar” means a person appointed to perform the duties of a Registrar of Co-operative`
  line `Societies under this Act: and`
  line
  line `(g) “rules” means rules made under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (70735)
  sectionNo (3)
  orderNo 3
  title `The Registrar.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70735&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_3_content:
  string
  line `The State Government may appoint a person to be Registrar of Co-operative`
  line `Societies for the State or any portion of it, and may appoint persons to assist such Registrar, and may, by`
  line `general or special order, confer on any such persons all or any of the powers of a Registrar under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (70784)
  sectionNo (4)
  orderNo 4
  title `Societies which may be registered.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70784&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_4_content:
  string
  line `Subject to the provisions hereinafter contained, a society`
  line `which has as its object the promotion of the economic interests of its members in accordance with`
  line `co-operative principles, or a society established with the object of facilitating the operations of such a`
  line `society, may be registered under this Act with or without limited liability:`
  line
  line `Provided that unless the State Government by general or special order otherwise directs—`
  line
  line `(1) the liability of a society of which a member is a registered society shall be limited;`
  line
  line `(2) the liability of a society of which the object is the creation of funds to be lent to its members,`
  line `and of which the majority of the members are agriculturists, and of which no member is a registered`
  line `society, shall be unlimited.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (70737)
  sectionNo (5)
  orderNo 5
  title `Restrictions on interest of member of society with limited liability and a share capital.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70737&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_5_content:
  string
  line Where
  line `the liability of the members of a society is limited by shares, no member other than a registered society`
  line shall—
  line
  line `(a) hold more than such portion of the share capital of the society, subject to a maximum of onefifth, as may be prescribed by the rules; or`
  line
  line `(b) have or claim any interest in the shares of the society exceeding one thousand rupees`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (70738)
  sectionNo (6)
  orderNo 6
  title `Conditions of registration.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70738&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_6_content:
  string
  line `(1) No society, other than a society of which a member is a registered`
  line `society, shall be registered under this Act which does not consist of at least ten persons above the age of`
  line `eighteen years and, where the object of the society is the creation of funds to be lent to its members,`
  line `unless such persons—`
  line
  line `(a) reside in the same town or village or in the same group of villages; or`
  line
  line `(b) save where the Registrar otherwise directs, are members of the same tribe, class, caste, or`
  line occupation.
  line
  line `(2) The word “limited” shall be the last word in the name of every society with limited liability`
  line `registered under this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (70739)
  sectionNo (7)
  orderNo 7
  title `Power of Registrar to decide certain questions.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70739&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_7_content:
  string
  line `When any question arises whether for the`
  line `purposes of this Act a person is an agriculturist or a non-agriculturist, or whether any person is a resident`
  line `in a town or village or group of villages, or whether two or more villages shall be considered to form a`
  line `group, or whether any person belongs to any particular tribe, class, caste or occupation, the question shall`
  line `be decided by the Registrar, whose decision shall be final.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (70740)
  sectionNo (8)
  orderNo 8
  title `Application for registration.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70740&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_8_content:
  string
  line `(1) For purposes of registration an application to register shall be`
  line `made to the Registrar.`
  line
  line `(2) The application shall be signed—`
  line
  line `(a) in the case of a society of which no member is a registered society by at least ten persons`
  line `qualified in accordance with the requirements of section 6, sub-section (1); and`
  line
  line `(b) in the case of a society of which a member is a registered society, by a duly authorised person`
  line `on behalf of every such registered society, and where all the members of the society are not registered`
  line `societies, by ten other members or, when there are less than ten other members, by all of them.`
  line
  line `(3) The application shall be accompanied by a copy of the proposed by-laws of the society, and the`
  line `persons by whom or on whose behalf such application is made shall furnish such information in regard`
  line `to the society as the Registrar may require.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (70741)
  sectionNo (9)
  orderNo 9
  title Registration.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70741&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_9_content:
  string
  line `If the Registrar is satisfied that a society has complied with the provisions of this`
  line `Act and the rules and that its proposed by-laws are not contrary to the Act or to the rules, he may, if he`
  line `thinks fit, register the society and its by-laws.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (70742)
  sectionNo (10)
  orderNo 10
  title `Evidence of registration.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70742&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_10_content:
  string
  line `A certificate of registration signed by the Registrar shall be`
  line `conclusive evidence that the society therein mentioned is duly registered unless it is proved that the`
  line `registration of the society has been cancelled.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (70743)
  sectionNo (11)
  orderNo 11
  title `Amendment of the by-laws of a registered society.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70743&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_11_content:
  string
  line `(1) No amendment of the by-laws of a`
  line `registered society shall be valid until the same has been registered under this Act, for which purpose a`
  line `copy of the amendment shall be forwarded to the Registrar.`
  line
  line `(2) If the Registrar is satisfied that any amendment of the by-laws is not contrary to this Act or to the`
  line `rules, he may, if he thinks fit, register the amendment.`
  line
  line `(3) When the Registrar registers an amendment of the by-laws of a registered society, he shall issue`
  line `to the society a copy of the amendment certified by him, which shall be conclusive evidence that the same`
  line `is duly registered.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (70744)
  sectionNo (12)
  orderNo 12
  title `Member not to exercise rights till due payment made.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70744&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_12_content:
  string
  line `No member of a registered society`
  line `shall exercise the rights of a member unless or until he has made such payment to the society in respect`
  line `of membership or acquired such interest in the society, as may be prescribed by the rules or by-laws`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (70745)
  sectionNo (13)
  orderNo 13
  title `Votes of members.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70745&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_13_content:
  string
  line `(1) Where the liability of the members of a registered society is not limited`
  line `by shares, each member shall, notwithstanding the amount of his interest in the capital, have one vote`
  line `only as a member in the affairs of the society.`
  line
  line `(2) Where the liability of the members of a registered society is limited by shares, each member shall`
  line `have as many votes as may be prescribed by the by-laws.`
  line
  line `(3) A registered society which has invested any part of its funds in the shares of any other registered`
  line `society may appoint as its proxy, for the purpose of voting in the affairs of such other registered society,`
  line `any one of its members.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (70746)
  sectionNo (14)
  orderNo 14
  title `Restrictions on transfer of share or interest.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70746&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_14_content:
  string
  line `(1) The transfer or charge of the share or interest`
  line `of a member in the capital of a registered society shall be subject to such conditions as to maximum`
  line `holding as may be prescribed by this Act or by the rules.`
  line
  line `(2) In case of a society registered with unlimited liability a member shall not transfer any share held`
  line `by him or his interest in the capital of the society or any part thereof unless—`
  line
  line `(a) he has held such share or interest for not less than one year; and`
  line
  line `(b) the transfer or charge is made to the society or to a member of the society`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (70747)
  sectionNo (15)
  orderNo 15
  title `Address of societies.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70747&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_15_content:
  string
  line `Every registered society shall have an address, registered in accordance`
  line `with the rules, to which all notices and communications may be sent, and shall send to the Registrar`
  line `notice of every change thereof.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (70748)
  sectionNo (16)
  orderNo 16
  title `Copy of Act, rules and by-laws to be open to inspection.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70748&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_16_content:
  string
  line `Every registered society shall keep a`
  line `copy of this Act and of the rules governing such society, and of its by-laws, open to inspection free of`
  line `charge at all reasonable times at the registered address of the society.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (70749)
  sectionNo (17)
  orderNo 17
  title Audit.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70749&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_17_content:
  string
  line `(1) The Registrar shall audit or cause to be audited by some person authorised by him by`
  line `general or special order in writing in this behalf the accounts of every registered society once at least in`
  line `every year.`
  line
  line `(2) The audit under sub-section (1) shall include an examination of overdue debts, if any, and a`
  line `valuation of the assets and liabilities of the society.`
  line
  line `(3) The Registrar, the Collector or any person authorised by general or special order in writing in this`
  line `behalf by the Registrar shall at all times have access to all the books, accounts, papers and securities of a`
  line `society, and every officer of the society shall furnish such information in regard to the transactions and`
  line `working of the society as the person making such inspection may require.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (70750)
  sectionNo (18)
  orderNo 18
  title `Societies to be bodies corporate.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70750&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_18_content:
  string
  line `The registration of a society shall render it a body corporate`
  line `by the name under which it is registered, with perpetual succession and a common seal, and with power`
  line `to hold property, to enter into contracts, to institute and defend suits and other legal proceedings and to`
  line `do all things necessary for the purposes of its constitution.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (70751)
  sectionNo (19)
  orderNo 19
  title `Prior claim of society.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70751&sectionno=19&orderno=19&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_19_content:
  string
  line `Subject to any prior claim of the Government in respect of land-revenue`
  line `or any money recoverable as land-revenue or of a landlord in respect of rent or any money recoverable as`
  line `rent, a registered society shall be entitled in priority to other creditors to enforce any outstanding demand`
  line `due to the society from a member or past member—`
  line
  line `(a) in respect of the supply of seed or manure or of the loan of money for the purchase of seed or`
  line `manure upon the crops or other agricultural produce of such member or person at any time within`
  line `eighteen months from the date of such supply or loan;`
  line
  line `(b) in respect of the supply of cattle, fodder for cattle, agricultural or industrial implements or`
  line `machinery, or raw materials for manufacture, or of the loan of money for the purchase of any of the`
  line `foregoing things—upon any such things so supplied, or purchased in whole or in part from any such`
  line `loan, or on any articles manufactured from raw materials so supplied or purchased.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (70752)
  sectionNo (20)
  orderNo 20
  title `Charge and set-off in respect of shares or interest of member.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70752&sectionno=20&orderno=20&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_20_content:
  string
  line `A registered society shall have`
  line `a charge upon the share or interest in the capital and on the deposits of a member or past member and`
  line `upon any dividend, bonus or profits payable to a member or past member in respect of any debt due from`
  line `such member or past member to the society, and may set-off any sum credited or payable to a member or`
  line `past member in or towards payment of any such debt.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (70753)
  sectionNo (21)
  orderNo 21
  title `Shares or interest not liable to attachment.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70753&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_21_content:
  string
  line `Subject to the provisions of section 20, the share`
  line `or interest of a member in the capital of a registered society shall not be liable to attachment or sale under`
  line `any decree or order of a Court of Justice in respect of any debt or liability incurred by such member, and`
  line `neither the Official Assignee under the Presidency-towns Insolvency Act, 1909 (3 of 1909) nor a`
  line `Receiver under the Provincial Insolvency Act, 1907 (3 of 1907)1`
  line `, shall be entitled to or have any claim on`
  line `such share or interest`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (70754)
  sectionNo (22)
  orderNo 22
  title `Transfer of interest on death of member.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70754&sectionno=22&orderno=22&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_22_content:
  string
  line `(1) On the death of a member a registered society`
  line `may transfer the share or interest of the deceased member to the person nominated in accordance with the`
  line `rules made in this behalf, or, if there is no person so nominated, to such person as may appear to the`
  line `committee to be the heir or legal representative of the deceased member, or pay to such nominee, heir or`
  line `legal representative, as the case may he, a sum representing the value of such member's share or interest,`
  line `as ascertained in accordance with the rules or by-laws:`
  line
  line `Provided that—`
  line
  line `(i) in the case of a society with unlimited liability, such nominee, heir or legal representative, as`
  line `the case may be, may require payment by the society of the value of the share or interest of the`
  line `deceased member ascertained as aforesaid;`
  line
  line `(ii) in the case of a society with limited liability, the society shall transfer the share or interest of`
  line `the deceased member to such nominee, heir or legal representative, as the case may be, being qualified`
  line `in accordance with the rules and by-laws for membership of the society, or on his application within`
  line `one month of the death of the deceased member to any person specified in the application who is so`
  line qualified.
  line
  line `(2) A registered society may pay all other moneys due to the deceased member from the society to`
  line `such nominee, heir or legal representative, as the case may be.`
  line
  line `(3) All transfers and payments made by a registered society in accordance with the provisions of this`
  line `section shall be valid and effectual against any demand made upon the society by any other person.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (70755)
  sectionNo (23)
  orderNo 23
  title `Liability of past member.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70755&sectionno=23&orderno=23&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_23_content:
  string
  line `The liability of a past member for the debts of a registered society`
  line `asthey existed at the time when he ceased to be a member shall continue for a period of two years from`
  line `the date of his ceasing to be a member`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (70756)
  sectionNo (24)
  orderNo 24
  title `Liability of the estates of deceased members.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70756&sectionno=24&orderno=24&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_24_content:
  string
  line `The estate of a deceased member shall be liable`
  line `for a period of one year from the time of his decease for the debts of a registered society as they existed`
  line `at the time of his decease.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (70757)
  sectionNo (25)
  orderNo 25
  title `Register of members.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70757&sectionno=25&orderno=25&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_25_content:
  string
  line `Any register or list of members or shares kept by any registered society`
  line `shall be prima facie evidence of any of the following particulars entered therein:-`
  line
  line `(a) the date at which the name of any person was entered in such register or list as a member;`
  line
  line `(b) the date at which any such person ceased to be a member.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (70759)
  sectionNo (26)
  orderNo 26
  title `Proof of entries in societies’ books.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70759&sectionno=26&orderno=26&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_26_content:
  string
  line `A copy of any entry in a book of a registered society`
  line `regularly kept in the course of business, shall, if certified in such manner as may be prescribed by the`
  line `rules, be received, in any suit or legal proceeding, as prima facie evidence of the existence of such entry,`
  line `and shall be admitted as evidence of the matters, transactions and accounts therein recorded in every case`
  line `where, and to the same extent as, the original entry itself is admissible.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (70785)
  sectionNo (27)
  orderNo 27
  title `Exemption from compulsory registration of instruments relating to shares and debentures of registered society.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70785&sectionno=27&orderno=27&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_27_content:
  string
  line `Nothing in section 17, sub-section (1), clauses (b) and (c) of the Indian`
  line `Registration Act, 1908 (16 of 1908), shall apply to—`
  line
  line `(1) any instrument relating to shares in a registered society, notwithstanding that the assets of such`
  line `society consist in whole or in part of immoveable property; or`
  line
  line `(2) any debenture issued by any such society and not creating, declaring, assigning, limiting or`
  line `extinguishing any right, title or interest to or in immoveable property except in so far as it entitles the`
  line `holder to the security afforded by a registered instrument whereby the society has mortgaged,`
  line `conveyed or otherwise transferred the whole or part of its immoveable property or any interest`
  line `thereinto trustees upon trust for the benefit of the holders of such debentures; or`
  line
  line `(3) any endorsement upon or transfer of any debenture issued by any such society.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (70761)
  sectionNo (28)
  orderNo 28
  title `Power to exempt from income-tax, stamp-duty and registration fees.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70761&sectionno=28&orderno=28&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_28_content:
  string
  line `^1[(1)] The Central`
  line `Government, by notification^2`
  line `in the Official Gazette, may, in the case of any registered society or class`
  line `of registered society, remit ^3*** the income-tax payable in respect of the profits of the society, or of the`
  line `dividends or other payments received by the members of the society on account of profits;`
  line
  line ^4
  line `* * * * *`
  line
  line `^5[(2) The ^6[`
  line `Government], by notification in the Official Gazette, may, in the case of any registered`
  line `society or class of registered society, remit-`
  line
  line `(a) the stamp-duty with which, under any law for the time being in force, instruments executed by`
  line `or on behalf of a registered society or by an officer or member and relating to the business of such`
  line `society, or any class of such instruments, are respectively chargeable, and`
  line
  line `(b) any fee payable under the law of registration for the time being in force.]`
  line
  line `^7[In this sub-section "Government" in relation to stamp-duty in respect of bills of exchange, cheques,`
  line `promissory notes, bills of lading, letters of credit, policies of insurance, ^8[`
  line `transfer of shares, debentures],`
  line `proxies and receipts, and in relation to any stamp-duty falling within ^9[entry 96] in List I in the Seventh`
  line `Schedule to ^10[the Constitution], means the Central Government, and save as aforesaid means the State`
  line Government.]^11
obj_root_law_sections_28_footnotes:
  string
  line `1. S. 28 re-numbered a sub-section (1) of that section by Act 38 of 1920, s. 2 and the first Schedule, Pt. I. The whole of this`
  line `Act,with the exception of`
  line
  line `(a) Sub-section (1) of section 28, and`
  line
  line `(b) Sub-section (2) of section 28, so far as it relates to the stamp-duties`
  line `specified in the second paragraph thereof, has`
  line `been repealed in Bengal by the Bengal Co-operative Societies Act, 1940 (Ben. 21 of 1940), s. 3 and the first Schedule.`
  line
  line `2. For notifications under this section, see Gazette of India, 1914, Pt. I, p. 994.`
  line
  line `3. The brackets and letter (a) omitted by Act 38 of 1920, s. 2 and the first Schedule, Pt. I`
  line
  line `4. Clauses (b) and (c) omitted by s. 2 and the first Schedule, Pt. I, ibid`
  line
  line `5.Added by Act 38 of 1920, s. 2 and the first Schedule Pt. I.`
  line
  line `6. Subs. by the A. O 1937, for "L.G.".`
  line
  line `7. Added, ibid.`
  line
  line `8. Ins. by the A.O. 1950.`
  line
  line `9. Subs., ibid., for "Item 59".`
  line
  line `10. Subs., ibid., for "the Government of India Act, 1935".`
  line
  line `11. For s. 28A ins. in the U.P., see the Co-operative Societies (U.P. Amendment) Act, 1944 (U.P. 1 of 1944) as continued in`
  line `force by the U.P. Expiring Laws Continuance Act, 1948 (U.P. 13 of 1948).`
obj_root_law_sections_29:
  sectionId (70762)
  sectionNo (29)
  orderNo 29
  title `Restrictions on loans.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70762&sectionno=29&orderno=29&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_29_content:
  string
  line `(1) A registered society shall not make a loan to any person other than`
  line `a member:`
  line
  line `Provided that, with the general or special sanction of the Registrar, a registered society may`
  line `make loans to another registered society.`
  line
  line `(2) Save with the sanction of the Registrar, a society with unlimited liability shall not lend money on`
  line `the security of moveable property.`
  line
  line `(3) The State Government may, by general or special order, prohibit or restrict the lending of money`
  line `on mortgage of immoveable property by any registered society or class of registered societies.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (70763)
  sectionNo (30)
  orderNo 30
  title `Restrictions on borrowing.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70763&sectionno=30&orderno=30&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_30_content:
  string
  line `A registered society shall receive deposits and loans from persons`
  line `who are not members only to such extent and under such conditions as may be prescribed by the rules`
  line `or by-laws`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (70764)
  sectionNo (31)
  orderNo 31
  title `Restrictions on other transactions with non-members.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70764&sectionno=31&orderno=31&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_31_content:
  string
  line `Save as provided in sections 29 and`
  line `30, the transactions of a registered society with persons other than members shall be subject to such`
  line `prohibitions and restrictions, if any, as the State Government may, by rules, prescribe`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (70765)
  sectionNo (32)
  orderNo 32
  title `Investment of funds.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70765&sectionno=32&orderno=32&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_32_content:
  string
  line `(1) A registered society may invest or deposit its funds-`
  line
  line `(a) in the Government Savings Bank, or`
  line
  line `(b) in any of the securities specified in section 20 of the Indian Trusts Act, 1882 (2 of 1882), or`
  line
  line `(c) in the shares or on the security of any other`
  line `registered society, or`
  line
  line `(d) with any bank or person carrying on the business of banking approved for this purpose by the`
  line `Registrar, or`
  line
  line `(e) in any other mode permitted by the rules.`
  line
  line `(2) Any investments or deposits made before the commencement of this Act which would have been`
  line `valid if this Act had been in force are hereby ratified and confirmed.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (70766)
  sectionNo (33)
  orderNo 33
  title `Funds not to be divided by way of profit.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70766&sectionno=33&orderno=33&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_33_content:
  string
  line `No part of the funds of a registered society shall be`
  line `divided by way of bonus or dividend or otherwise among its members:`
  line
  line `Provided that after at least one-fourth of the net profits in any year have been carried to a reserve`
  line `fund, payments from the remainder of such profits and from any profits of past years available for`
  line `distribution may be made among the members to such extent and under such conditions as may be`
  line `prescribed by the rules or by-laws:`
  line
  line `Provided also that in the case of a society with unlimited liability no distribution of profits shall be`
  line `made without the general or special order of the State`
  line `Government in this behalf`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (70767)
  sectionNo (34)
  orderNo 34
  title `Contribution to charitable purpose.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70767&sectionno=34&orderno=34&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_34_content:
  string
  line `Any registered society may, with the sanction of the`
  line `Registrar, after one-fourth of the net profits in any year has been carried to a reserve fund, contribute an`
  line `amount not exceeding ten per cent. of the remaining net profits to any charitable purpose, as defined in`
  line `section 2 of the Charitable Endowments Act, 1890 (1 of 1890).`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (70768)
  sectionNo (35)
  orderNo 35
  title `Inquiry by Registrar.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70768&sectionno=35&orderno=35&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_35_content:
  string
  line `(1) The Registrar may of his own motion, and shall on the request of the`
  line `Collector, or on the application of a majority of the committee, or of not less than one-third of the`
  line `members, hold an inquiry or direct some person authorised by him by order in writing in this behalf to`
  line `hold an inquiry into the constitution, working and financial`
  line `condition of a registered society.`
  line
  line `(2) All officers and members of the society shall furnish such information in regard to the affairs of`
  line `the society as the Registrar or the person authorised by the`
  line `Registrar may require.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (70769)
  sectionNo (36)
  orderNo 36
  title `Inspection of books of indebted society.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70769&sectionno=36&orderno=36&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_36_content:
  string
  line `(1) The Registrar shall, on the application of a creditor`
  line `of a registered society, inspect or direct some person authorised by him by order in writing in this`
  line `behalf to inspect the books of the society:`
  line
  line `Provided that—`
  line
  line `(a) the applicant satisfies the Registrar that the debt is a sum then due, and that he has demanded`
  line `payment thereof and has not received satisfaction within a reasonable time; and`
  line
  line `(b) the applicant deposits with the Registrar such sum as security for the costs of the proposed`
  line `inspection as the Registrar may require.`
  line
  line `(2) The Registrar shall communicate the results of any such inspection to the creditor.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (70770)
  sectionNo (37)
  orderNo 37
  title `Costs of inquiry.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70770&sectionno=37&orderno=37&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_37_content:
  string
  line `Where an inquiry is held under section 35, or an inspection is made under`
  line `section 36, the Registrar may apportion the costs, or such part of the costs as he may think right, between`
  line `the society, the members or creditor demanding an inquiry or inspection, and the officers or former officers`
  line `of the society`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (70771)
  sectionNo (38)
  orderNo 38
  title `Recovery of costs.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70771&sectionno=38&orderno=38&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_38_content:
  string
  line `Any sum awarded by way of costs under section 37 may be recovered, on`
  line `application to a Magistrate having jurisdiction in the place where the person from whom the money is`
  line `claimable actually and voluntarily resides or carries on business, by the distress and sale of any moveable`
  line `property within the limits of the jurisdiction of such Magistrate belonging to such person.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (70772)
  sectionNo (39)
  orderNo 39
  title Dissolution.
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70772&sectionno=39&orderno=39&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_39_content:
  string
  line `(1) If the Registrar, after an inquiry has been held under section 35 or after an`
  line `inspection has been made under section 36 or on receipt of an application made by three-fourths of the`
  line `members of a registered society, is of opinion that the society ought to be dissolved, he may cancel the`
  line `registration of the society.`
  line
  line `(2) Any member of a society may, within two months from the date of an order made under`
  line `sub-section (1), appeal from such order.`
  line
  line `(3) Where no appeal is presented within two months from the making of an order cancelling the`
  line `registration of a society, the order shall take effect on the expiry of that period.`
  line
  line `(4) Where an appeal is presented within two months, the order shall not take effect until it is formed by`
  line `the appellate authority.`
  line
  line `(5) The authority to which appeals under this section shall lie shall be the State Government:`
  line
  line `Provided that the State Government may, by notification in the Official Gazette, direct that appeals`
  line `shall lie to such Revenue authority as may be specified in the notification.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (70773)
  sectionNo (40)
  orderNo 40
  title `Cancellation of registration of society.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70773&sectionno=40&orderno=40&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_40_content:
  string
  line `Where it is a condition of the registration of a society that`
  line `it should consist of at least ten members, the Registrar may, by order in writing, cancel the registration of the`
  line `society if at any time it is proved to his satisfaction that the number of the members has been reduced to less`
  line `than ten`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (70774)
  sectionNo (41)
  orderNo 41
  title `Effect of cancellation of registration.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70774&sectionno=41&orderno=41&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_41_content:
  string
  line `Where the registration of a society is cancelled, the society`
  line `shall cease to exist as a corporate body—`
  line
  line `(a) in the case of cancellation in accordance with the provisions of section 39, from the date the order`
  line `of cancellation takes effect;`
  line
  line `(b) in the case of cancellation in accordance with the provisions of section 40, from the date of the`
  line order.
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (70775)
  sectionNo (42)
  orderNo 42
  title Winding-up.
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70775&sectionno=42&orderno=42&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_42_content:
  string
  line `(1) Where the registration of a society is cancelled under section 39 or section 40, the`
  line `Registrar may appoint a competent person to be liquidator of the society.`
  line
  line `^1(2) A liquidator appointed under sub-section (1) shall have power`
  line
  line `(a) to institute and defend suits and other legal proceedings on behalf of the society by his name of`
  line office;
  line
  line `(b) to determine the contribution to be made by the members and past members of the society`
  line `respectively to the assets of the society;`
  line
  line `(c) to investigate all claims against the society and, subject to the provisions of this Act, to decide`
  line `questions of priority arising between claimants;`
  line
  line `(d) to determine by what persons and in what proportions the costs of the liquidation are to be`
  line `borne; and`
  line
  line `(e) to give such directions in regard to the collection and distribution of the assets of the society, as`
  line `may appear to him to be necessary for winding-up the affairs of the society.`
  line
  line `(3) Subject to any rules, a liquidator appointed under this section shall, in so far as such powers are`
  line `necessary for carrying out the purposes of this section, have power to summon and enforce the attendance of`
  line `witnesses and to compel the production of documents by the same means and (so far as may be) in the same`
  line `manner as is provided in the case of a Civil Court under the Code of Civil Procedure, 1908 (5 of 1908).`
  line
  line `(4) Where an appeal from any order made by a liquidator under this section is provided for by the rules, it`
  line `shall lie to the Court of the District Judge.^2`
  line
  line `^3(5) Orders made under this section shall, on application,`
  line `be enforced as follows:-`
  line
  line `(a) when made by a liquidator, by any Civil Court having local jurisdiction in the same manner as a`
  line `decree of such Court;`
  line
  line `(b) when made by the Court of the District Judge on appeal, in the same manner as a decree of such`
  line `Court made in any suit pending therein.`
  line
  line `(6) Save in so far as is hereinbefore expressly provided no Civil Court shall have any jurisdiction in respect`
  line `of any matter connected with the dissolution of a registered society under this Act.^4`
obj_root_law_sections_42_footnotes:
  string
  line `1. This sub-section has been amended in its application to the C.P. and Berar by the C.P. and Berar Co-operative Societies`
  line `Amendment and Liquidator's Orders Validation Act, 1945 (C.P. & B. 10 of 1945) as continued in force by the C.P. &`
  line `Berar Expiring Laws Continuance and Amending Act, 1947 (C.P. & B. 48 of 1947).`
  line
  line `2. For sub-section (4A) which applies to the U.P., see the Co-operative Societies (Amendment) Act, 1919 (U.P. 3 of`
  line `1919).`
  line
  line `3. This sub-section has been modified in its application to the`
  line `U.P., see ibid.`
  line
  line `4. For s. 42A ins. in the C.P., see the Co-operative Societies (C.P. Amendment) Act, 1930 (C. P. 7 of 1930). For sections 42-B`
  line `and 42-C ins. in the C.P. and Berar, see the following Acts as continued in force by the C.P. and Berar Act 48 of 1947:-`
  line
  line `1. The C.P. and Berar Co-operative Societies (Amendment) Act, 1940 (C.P. & B. 5 of 1940);`
  line
  line `2. The C.P. and Berar Co-operative Societies (Amendment) Act, 1941 (C.P. & B. 6 of 1941); and`
  line
  line `3. The C.P. and Berar Co-operative Societies Amendment and Liquidators' Orders Validation Act, 1945 (C.P. & B. 10`
  line `of 1945).`
obj_root_law_sections_43:
  sectionId (70776)
  sectionNo (43)
  orderNo 43
  title Rules.
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70776&sectionno=43&orderno=43&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_43_content:
  string
  line `(1) The State Government may, for the whole or any part of the State and for any`
  line `registered society or class of such societies, make rules^1`
  line `to carry out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line
  line `(a) subject to the provisions of section 5, prescribe the maximum number of shares or portion of the`
  line `capital of a society which may be held by a member;`
  line
  line `(b) prescribe the forms to be used and the conditions to be complied with in the making of applications`
  line `for the registration of a society and the procedure in the matter of such applications;`
  line
  line `(c) prescribe the matters in respect of which a society may or shall make by-laws and for the procedure`
  line `to be followed in making, altering and abrogating by-laws, and the conditions to be satisfied prior to such`
  line `making, alteration or abrogation;`
  line
  line `(d) prescribe the conditions to be complied with by persons applying for admission or admitted as`
  line `members, and provide for the election and admission of members, and the payment to be made and the`
  line `interests to be acquired before the exercise of the right of membership;`
  line
  line `(e) regulate the manner in which funds may be raised by means of shares or debentures or otherwise;`
  line
  line `(f) provide for general meetings of the members and for the procedure at such meetings and the powers`
  line `to be exercised by such meetings;`
  line
  line `(g) provide for the appointment, suspension and removal of the members of the committee and other`
  line `officers, and for the procedure at meetings of the committee, and for the powers to be exercised and the`
  line `duties to be performed by the committee and other officers;`
  line
  line `(h) prescribe the accounts and books to be kept by a society and provide for the audit of such accounts`
  line `and the charges, if any, to be made for such audit, and for the periodical publication of a balance-sheet`
  line `showing the assets and liabilities of a society;`
  line
  line `(i) prescribe the returns to be submitted by a society to the Registrar and provide for the persons by`
  line `whom and the form in which such returns shall be submitted;`
  line
  line `(j) provide for the person by whom and the form in which copies of entries in books of societies`
  line `may be certified;`
  line
  line `(k) provide for the formation and maintenance of a register of members and, where the liability of the`
  line `members is limited by shares, of a register of shares;`
  line
  line `(l) provide that any dispute touching the business of a society between members or past members`
  line `of the society or persons claiming through a member or past member or between a member or past member`
  line `or persons so claiming and the committee or any officer shall be referred to the Registrar for decision or,`
  line `if he so directs, to arbitration, and prescribe the mode of appointing an arbitrator or arbitrators and the`
  line `procedure to be followed in proceedings before the Registrar or such arbitrator or arbitrators, and the`
  line `enforcement of the decisions of the Registrar or the awards of arbitrators;`
  line
  line `(m) provide for the withdrawal and expulsion of members and for the payments, if any to he made to`
  line `members who withdraw or are expelled and for the liabilities of past members;`
  line
  line `(n) provide for the mode in which the value of a deceased members interest shall be ascertained, and`
  line `for the nomination of a person to whom such interest may be paid or transferred;`
  line
  line `(o) prescribe the payments to be made and the conditions to be complied with by members`
  line `applying for loans, the period for which loans may be made, and the amount which may be lent, to an`
  line `individual member;`
  line
  line `(p) provide for the formation and maintenance of reserve funds, and the objects to which such`
  line `funds may be applied, and for the investment of any funds under the control of the`
  line society;
  line
  line `(q) prescribe the extent to which a society may limit the number of its members;`
  line
  line `(r) prescribe the conditions under which profits may be distributed to the members of a society with`
  line `unlimited liability and the maximum rate of dividend which may be paid by societies;`
  line
  line `(s) subject to the provisions of section 39, determine in what cases an appeal shall lie from the orders`
  line `of the Registrar, and prescribe the procedure to be followed in presenting and disposing of such appeals;`
  line and
  line
  line `(t) prescribe the procedure to be followed by a liquidator appointed under section 42, and the cases in`
  line `which an appeal shall lie from the order of such liquidator.`
  line
  line `(3) The State Government may delegate, subject to such conditions, if any, as it thinks fit, all or any of`
  line `its powers to make rules under this section to any authority specified in the order of delegation.`
  line
  line `(4) The power to make rules conferred by this section is subject to the condition of the rules being`
  line `made after previous publication.`
  line
  line `(5) All rules made under this section shall be published in the Official Gazette and on such publication`
  line `shall have effect as if enacted in this Act.`
  line
  line `^2[(6) Every rule made by the State Government under this Act shall be laid, as soon as may be after it is`
  line `made, before the State Legislature.]`
obj_root_law_sections_43_footnotes:
  string
  line `1. For rules, see different local Rules and Orders.`
  line
  line `2. Ins. by Act 4 of 1986, s. 2 and the schedule (w.e.f. 15-5-1986).`
obj_root_law_sections_44:
  sectionId (70777)
  sectionNo (44)
  orderNo 44
  title `Recovery of sums due to Government.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70777&sectionno=44&orderno=44&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_44_content:
  string
  line `(1) All sums due from a registered society or from an`
  line `officer or member or past member of a registered society as such to the Government, including any costs`
  line `awarded to the Government under section 37, may be recovered in the same manner as arrears of`
  line land-revenue.
  line
  line `(2) Sums due from a registered society to Government and recoverable under sub-section (1) may be`
  line `recovered, firstly, from the property of the society; secondly, in the case of a society of which the liability of`
  line `the members is limited, from the members subject to the limit of their liability; and, thirdly; in the case of`
  line `other societies, from the members.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (70778)
  sectionNo (45)
  orderNo 45
  title `Power to exempt societies from conditions as to registration.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70778&sectionno=45&orderno=45&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_45_content:
  string
  line `Notwithstanding anything`
  line `contained in this Act, the State Government may, by special order in each case and subject to such conditions,`
  line `if any, as it may impose, exempt any society from any of the requirements of this Act as to registration`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (70779)
  sectionNo (46)
  orderNo 46
  title `Power to exempt registered societies from provisions of the Act.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70779&sectionno=46&orderno=46&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_46_content:
  string
  line `The State Government may,`
  line `by general or special order, exempt any registered society from any of the provisions of this Act or may direct`
  line `that such provisions shall apply to such society with such modifications as may be specified in the order.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (70780)
  sectionNo (47)
  orderNo 47
  title `Prohibition of the use of the word “co-operative”.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70780&sectionno=47&orderno=47&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_47_content:
  string
  line `(1) No person other than a registered society`
  line `shall trade or carry on business under any name or title of which the word “co-operative” is part without the`
  line `sanction of the State Government:`
  line
  line `Provided that nothing in this section shall apply to the use by any person or his successor in interest of`
  line `any name or title under which he traded or carried on business at the date on which this Act comes into`
  line operation.
  line
  line `(2) Whoever contravenes the provisions of this section shall be punishable with fine which may extend`
  line `to fifty rupees, and in the case of a continuing offence with further fine of five rupees for each day on which`
  line `the offence is continued after conviction therefor.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (70781)
  sectionNo (48)
  orderNo 48
  title `Indian Companies Act, 1882, not to apply.`
  content obj_root_law_sections_48_content
  footnotes `1. See now the Companies Act, 1956 (1 of 1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70781&sectionno=48&orderno=48&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_48_content:
  string
  line `The provisions of the Indian Companies Act, 1882^1`
  line `(6 of 1882), shall not apply to registered societies.`
obj_root_law_sections_49:
  sectionId (70782)
  sectionNo (49)
  orderNo 49
  title `Saving of existing societies.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70782&sectionno=49&orderno=49&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_49_content:
  string
  line `Every society now existing which has been registered under the`
  line `Co-operative Credit Societies Act, 1904 (10 of 1904), shall be deemed to be registered under this Act, and`
  line `its by-laws shall, so far as the same are not inconsistent with the express provisions of this Act, continue`
  line `in force until altered or rescinded.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (70783)
  sectionNo (50)
  orderNo 50
  title [Repealed.].
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00116_191202_1667287261557&sectionId=70783&sectionno=50&orderno=50&orgactid=AC_CEN_5_5_00116_191202_1667287261557
obj_root_law_sections_50_content:
  string
  line `Rep. by the Second Repealing and Amending Act, 1914 (17 of 1914), s. 3 and the`
  line `second Schedule`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `सहकारी सोसाइटी अधिनियम, 1912`
