obj_root_law_sections_1:
  object
  (str sectionId) (str 34497)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title, extent and commencement.`)
  (str content) (str `(1) This Act may be called the White Phosphorus Matches
Prohibition Act, 1913.

(2) It extends to the whole of India except ^1[the territories which, immediately before the 1st November,
1956, were comprised in Part B States]; and

(3) It shall come into force on the first day of July, 1913, with the exception of section 6, which shall
come into force on the first day of July, 1914.`)
  (str footnotes) (str `1. Subs. by the A.O. (No. 2) 1956, for "Part B States".`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00064_191305_1523341916175&sectionId=34497&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00064_191305_1523341916175)
obj_root_law_sections_2:
  object
  (str sectionId) (str 34498)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definition.)
  (str content) (str `In this Act, "white phosphorus" means the substance commonly known as white or
yellow phosphorus.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00064_191305_1523341916175&sectionId=34498&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00064_191305_1523341916175)
obj_root_law_sections_3:
  object
  (str sectionId) (str 34499)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str [Repealed.].)
  (str content) (str `[Prohibition of importation by addition to section 18, Act 8 of 1878.] Rep. by the Repealing Act, 1938
(1 of 1938), s. 2 and the Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00064_191305_1523341916175&sectionId=34499&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00064_191305_1523341916175)
obj_root_law_sections_4:
  object
  (str sectionId) (str 34500)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Prohibition of use of white phosphorus in manufacture of matches.`)
  (str content) (str `(1) No person shall use white
phosphorus in the manufacture of matches.

(2) Any person who uses, or permits the use by any person under his control of, white phosphorus in the
manufacture of matches, shall be punishable with fine which may extend to two hundred rupees.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00064_191305_1523341916175&sectionId=34500&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00064_191305_1523341916175)
obj_root_law_sections_5:
  object
  (str sectionId) (str 34501)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Power of Inspector of Factories to take samples of material used in manufacture.`)
  (str content) (str `(1) Every
person who manufactures matches shall allow an Inspector of Factories appointed under the Indian Factories
Act, 1911^1
(12 of 1911), at any time to take for analysis sufficient samples of any material in use or mixed for
use, in such manufacture:

Provided that any such person may, at the time the sample is taken, and on providing the necessary
appliances, require the Inspector to divide the sample so taken into two parts, and to mark, seal and deliver to
him one part.

(2) Any person who refuses to permit any such Inspector of Factories as aforesaid to take a sample, in
accordance with the provisions of sub-section (1), shall be punishable with fine which may extend to two
hundred rupees.`)
  (str footnotes) (str `1. See now the Factories Act, 1948 (63 of 1945).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00064_191305_1523341916175&sectionId=34501&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00064_191305_1523341916175)
obj_root_law_sections_6:
  object
  (str sectionId) (str 34502)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Prohibition of sale.`)
  (str content) (str `(1) No person shall sell, or offer or expose for sale, or have in his possession for
the purposes of sale, any matches made with white phosphorus.

(2) Any person who contravenes the provisions of sub-section (1) may, on complaint to a Presidency
Magistrate, Sub-divisional Magistrate or Magistrate of the first class, be ordered to forfeit any such matches
in his possession, and any matches so forfeited shall be destroyed or otherwise dealt with as the Magistrate
may direct.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00064_191305_1523341916175&sectionId=34502&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00064_191305_1523341916175)
