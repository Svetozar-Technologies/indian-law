obj_root_law_sections_1:
  sectionId (4612)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00008_195842_1517807318726&sectionId=4612&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00008_195842_1517807318726
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the International Finance Corporation`
  line `(Status, Immunities and Privileges) Act, 1958.`
  line
  line `(2) It extends^1`
  line `to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The Act has now been extended by Act 26 of 1968 to the Union territory Pondicherry, comprising the former French`
  line `Establishments in India, (w.e.f 1-8-1968).`
obj_root_law_sections_2:
  sectionId (4613)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00008_195842_1517807318726&sectionId=4613&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00008_195842_1517807318726
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Agreement" means the Agreement for the establishment and operation of the`
  line `international body known as the International Finance Corporation;`
  line
  line `(b) "Corporation" means the International Finance Corporation established under the`
  line Agreement.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (4614)
  sectionNo (3)
  orderNo 3
  title `Conferment of status and certain immunities and privileges on the Corporation and conferment of certain immunities and privileges on its officers and employees.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00008_195842_1517807318726&sectionId=4614&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00008_195842_1517807318726
obj_root_law_sections_3_content:
  string
  line `(1)`
  line `Notwithstanding anything to the contrary contained in any other law, the provisions of the Agreement`
  line `set out in the Schedule shall have the force of law in India:`
  line
  line `Provided that nothing in Section 9 of Article VI of the Agreement shall be construed as--`
  line
  line `(a) entitling the Corporation to import into India goods free of any duty of customs without`
  line `any restriction on their subsequent sale therein; or`
  line
  line `(b) conferring on the Corporation any exemption from duties or taxes which form part of the`
  line `price of goods sold; or`
  line
  line `(c) conferring on the Corporation any exemption from duties or taxes which are in fact no`
  line `more than charges for services rendered.`
  line
  line `(2) The Central Government may, from time to time, by notification in the Official Gazette,`
  line `amend the Schedule in conformity with any amendments, duly made and adopted, of the provisions of`
  line `the Agreement set out therein:`
  line
  line `Provided that any notification issued under this sub-section shall be laid for not less than thirty`
  line `days before each House of Parliament as soon as may be after it is issued and shall be subject to such`
  line `modifications as Parliament may make during the session in which it is so laid or the session`
  line `immediately following.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (4615)
  sectionNo (4)
  orderNo 4
  title `Power to make rules.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 20 of 1983, s. 2 and the Schedule, for sub-section (2) (w.e.f. 15-3-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00008_195842_1517807318726&sectionId=4615&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00008_195842_1517807318726
obj_root_law_sections_4_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, make rules for carrying out the purposes of this Act.`
  line
  line `^1[(2) Every rule made under this Act shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect as the case may be; so, however, that any`
  line `such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
