obj_root_law_sections_1:
  sectionId (37192)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes `1. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Part B States".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37192&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00026_195018_1517807327302
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Special Criminal Courts (Jurisdiction)`
  line `Act, 1950.`
  line
  line `(2) It extends to the whole of India except ^1`
  line `[the territories which, immediately before the 1st`
  line `November, 1956, were comprised in Part B States].`
obj_root_law_sections_2:
  sectionId (37193)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37193&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00026_195018_1517807327302
obj_root_law_sections_2_content:
  string
  line `In this Act, "special Criminal Court" means any special Court of criminal jurisdiction`
  line `constituted by or under any law included in the Schedule.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (37194)
  sectionNo (3)
  orderNo 3
  title `Jurisdiction of special Criminal Courts to try offences with respect to matters in the Union List.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37194&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00026_195018_1517807327302
obj_root_law_sections_3_content:
  string
  line `Notwithstanding anything contained in law for the time being in force, it shall be lawful for any special`
  line `Criminal Court to try offences against laws with respect to any of the matters enumerated in List I in the`
  line `Seventh Schedule to the Constitution, if such court is otherwise competent to try such offence under the law`
  line `constituting it.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (37195)
  sectionNo (4)
  orderNo 4
  title `Power to add to Schedule.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37195&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00026_195018_1517807327302
obj_root_law_sections_4_content:
  string
  line `The Central Government may, by notification in the Official Gazette, add`
  line `to the Schedule any other State law providing for the trial of offences by special Criminal Courts, and any such`
  line `addition shall take effect as if such law had been included in the Schedule by this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (37196)
  sectionNo (5)
  orderNo 5
  title `Repeal of Ordinance.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37196&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00026_195018_1517807327302
obj_root_law_sections_5_content:
  string
  line `(1) The Special Criminal Courts (Jurisdiction) Ordinance, 1950 (7 of 1950), is`
  line `hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken in the exercise of any power conferred`
  line `by or under the said Ordinance shall be deemed to have been done or taken in the exercise of the powers`
  line `conferred by or under this Act as if this Act were in force on the day on which such thing was done or action`
  line `was taken.`
obj_root_law_sections_5_footnotes:
  string
  line
