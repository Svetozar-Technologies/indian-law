obj_root_law_sections_1:
  object
  (str sectionId) (str 37192)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and extent.`)
  (str content) (str `(1) This Act may be called the Special Criminal Courts (Jurisdiction)
Act, 1950.

(2) It extends to the whole of India except ^1
[the territories which, immediately before the 1st
November, 1956, were comprised in Part B States].`)
  (str footnotes) (str `1. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Part B States".`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37192&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00026_195018_1517807327302)
obj_root_law_sections_2:
  object
  (str sectionId) (str 37193)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definition.)
  (str content) (str `In this Act, "special Criminal Court" means any special Court of criminal jurisdiction
constituted by or under any law included in the Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37193&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00026_195018_1517807327302)
obj_root_law_sections_3:
  object
  (str sectionId) (str 37194)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Jurisdiction of special Criminal Courts to try offences with respect to matters in the Union List.`)
  (str content) (str `Notwithstanding anything contained in law for the time being in force, it shall be lawful for any special
Criminal Court to try offences against laws with respect to any of the matters enumerated in List I in the
Seventh Schedule to the Constitution, if such court is otherwise competent to try such offence under the law
constituting it.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37194&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00026_195018_1517807327302)
obj_root_law_sections_4:
  object
  (str sectionId) (str 37195)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Power to add to Schedule.`)
  (str content) (str `The Central Government may, by notification in the Official Gazette, add
to the Schedule any other State law providing for the trial of offences by special Criminal Courts, and any such
addition shall take effect as if such law had been included in the Schedule by this Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37195&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00026_195018_1517807327302)
obj_root_law_sections_5:
  object
  (str sectionId) (str 37196)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Repeal of Ordinance.`)
  (str content) (str `(1) The Special Criminal Courts (Jurisdiction) Ordinance, 1950 (7 of 1950), is
hereby repealed.

(2) Notwithstanding such repeal, anything done or any action taken in the exercise of any power conferred
by or under the said Ordinance shall be deemed to have been done or taken in the exercise of the powers
conferred by or under this Act as if this Act were in force on the day on which such thing was done or action
was taken.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00026_195018_1517807327302&sectionId=37196&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00026_195018_1517807327302)
