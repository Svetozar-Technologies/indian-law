obj_root_law:
  object
  (str slug) (str the-kalakshetra-foundation-act-1993)
  (str handle) (str 1969)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Kalakshetra Foundation Act, 1993`)
  (str actNumber) (str 06)
  (str enactmentDate) (str 1994-01-04)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1969`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `कलाक्षेत्र प्रतिष्‍ठान अधिनियम, 1993`)
  (str actYear) (str 1994)
  (str ministry) (str `Ministry of Culture`)
  (str department) (undefined)
  (str longTitle) (str `An Act to declare Kalakshetra of Madras to be an institution of national importance to provide for the establishment and incorporation of a Foundation for its administration, to make provisions for further development of Kalakshetra in accordance with the aims and objects for which Kalakshetra was founded and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 29-09-1993)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T12:05:53.880Z`)
  (str translations) obj_root_law_translations
