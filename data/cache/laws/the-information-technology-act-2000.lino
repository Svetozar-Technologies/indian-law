obj_root_law:
  slug the-information-technology-act-2000
  handle (1999)
  collectionHandle 123456789/1362
  title `The Information Technology Act, 2000`
  actNumber (21)
  enactmentDate 2000-06-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1999`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `सूचना प्रौद्योगिकी अधिनियम, 2000`
  actYear (2000)
  ministry `Ministry of Electronics and Information Technology`
  department undefined
  longTitle `An Act to provide legal recognition for transactions carried out by means of electronic data interchange and other means of electronic communication, commonly referred to as "electronic commerce", which involve the use of alternatives to paper-based methods of communication and storage of information, to facilitate electronic filing of documents with the Government agencies and further to amend the Indian Penal Code, the Indian Evidence Act, 1872, the Banker's Books Evidence Act, 1891 and the Reserve Bank of India Act, 1934 and for matters connected therewith or incidental thereto.`
  enforcementDate 17-10-2000
  notification `17th October, 2000, vide notification No. G.S.R. 788 (E), dated 17th October, 2000, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T19:11:08.434Z`
  translations obj_root_law_translations
