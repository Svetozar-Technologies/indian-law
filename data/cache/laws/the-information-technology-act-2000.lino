obj_root_law_sections_52_d:
  sectionId (13071)
  sectionNo 52D
  orderNo 62
  title `Decision by majority.`
  content obj_root_law_sections_52_d_content
  footnotes `1 Subs. by Act 7 of 2017, s. 169, for "Cyber Appellate Tribunal" (w.e.f. 26-5-2017)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_45_76_00001_200021_1517807324077&sectionId=13071&sectionno=52D&orderno=62&orgactid=AC_CEN_45_76_00001_200021_1517807324077
obj_root_law_sections_52_d_content:
  string
  line `If the Members of a Bench consisting of two Members differ in opinion`
  line `on any point, they shall state the point or points on which they differ, and make a reference to the`
  line `Chairperson of the ^1[Appellate Tribunal] who shall hear the point or points himself and such point or`
  line `points shall be decided according to the opinion of the majority of the Members who have heard the case,`
  line `including those who first heard it.`
