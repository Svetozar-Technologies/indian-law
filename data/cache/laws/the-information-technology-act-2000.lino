obj_root_law:
  object
  (str slug) (str the-information-technology-act-2000)
  (str handle) (str 1999)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Information Technology Act, 2000`)
  (str actNumber) (str 21)
  (str enactmentDate) (str 2000-06-09)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1999`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `सूचना प्रौद्योगिकी अधिनियम, 2000`)
  (str actYear) (str 2000)
  (str ministry) (str `Ministry of Electronics and Information Technology`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide legal recognition for transactions carried out by means of electronic data interchange and other means of electronic communication, commonly referred to as "electronic commerce", which involve the use of alternatives to paper-based methods of communication and storage of information, to facilitate electronic filing of documents with the Government agencies and further to amend the Indian Penal Code, the Indian Evidence Act, 1872, the Banker's Books Evidence Act, 1891 and the Reserve Bank of India Act, 1934 and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 17-10-2000)
  (str notification) (str `17th October, 2000, vide notification No. G.S.R. 788 (E), dated 17th October, 2000, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T19:11:08.434Z`)
  (str translations) obj_root_law_translations
