  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_45_76_00001_200021_1517807324077&sectionId=13074&sectionno=55&orderno=65&orgactid=AC_CEN_45_76_00001_200021_1517807324077
obj_root_law_sections_55_content:
  string
  line No
  line `order of the Central Government appointing any person as the ^2`
  line `[Chairperson or the Member] of a`
  line ^1
  line `[Appellate Tribunal] shall be called in question in any manner and no act or proceeding before a ^3`
  line `[Appellate Tribunal] shall be called in question in any manner on the ground merely of any defect in the`
  line `constitution of a ^3`
  line `[Appellate Tribunal].`
obj_root_law_sections_55_footnotes:
