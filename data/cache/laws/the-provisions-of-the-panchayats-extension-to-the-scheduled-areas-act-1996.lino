obj_root_law_translations_hi:
  object
  (str title) (str `पंचायत उपबंध (अनुसूचित क्षेत्रों पर विस्‍तार) अधिनियम, 1996`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1973/3/H1996-40.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:51:10.931Z`)
  (str pageCount) (int 2)
