obj_root_law_sections_1:
  sectionId (14103)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14103&sectionno=1&orderno=1&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called The^1[Oilfields] (Regulation`
  line `and Development) Act, 1948.`
  line
  line `^2[(2) It extends to the whole of India^3***].`
  line
  line `(3) it shall come into force on such date^4`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint in this behalf.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 32 and the Third Schedule, ibid., for "Mines and Minerals" (w.e.f. 1-6-1958).`
  line
  line `2. Subs. by the A.O. 1950, for sub-section 2.`
  line
  line `3. The words "except the State of Jammu and Kashmir" omitted by Act 67 of 1957, s. 32 and the Third Schedule,(w.e.f. 1-6-`
  line `1958).`
  line
  line `4. 25th October, 1949 see Notification No. M-II-155 (24)-I, dated 18th October 1949, Gazette of India, Extraordinary, 1949.`
obj_root_law_sections_2:
  sectionId (14104)
  sectionNo (2)
  orderNo 2
  title [Omitted.].
  content `[Declaration as to expediency of control by Central Government.] mitted by the Mines and Minerals (Regulation and Development) Act, 1957 (67 of 1957), s. 32 and the Third Schedule (w.e.f. 1-6-1958).]`
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14104&sectionno=2&orderno=2&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (14105)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14105&sectionno=3&orderno=3&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_3_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context,---`
  line
  line `(a) the expressions "lessor" and "lessee" respectively include a licensor and licensee;`
  line
  line `^1* * * * *`
  line
  line `^2[(c) "mineral oils" means any naturally occurring hydrocarbon, whether in the form of natural`
  line `gas or in a liquid, viscous or solid form, or a mixture thereof, and includes crude oil, natural gas,`
  line `petroleum, condensate, coal bed methane, oil shale, shale gas, shale oil, tight gas, tight oil, gas`
  line `hydrate in their usual industrial connotation and other gases occurring in association with mineral`
  line `oils, but does not include coal, lignite and helium occurring in association with petroleum or coal or`
  line shale;]
  line
  line `(d) "mining lease" means a lease granted for the purpose of searching for, winning, working,`
  line `getting, making merchantable, carrying away or disposing of ^3[mineral oils] or for purposes`
  line `connected therewith, and includes an exploring or a prospecting license`
  line `^4[granted before the`
  line `commencement of the Oilfields (Regulation and Development) Amendment Act, 2025];`
  line
  line `(e) "oilfield" means any area where any operation for the purpose of obtaining ^5[mineral oils],`
  line `refined oil, partially refined oil and any of the products of petroleum in a liquid or solid state, is to be`
  line `or is being carried on.`
  line
  line `^6[(f) "petroleum lease" means a lease granted on or after the commencement of the Oilfields`
  line `(Regulation and Development) Amendment Act, 2025, for the purpose of prospecting, exploration,`
  line `development, production, making merchantable, carrying away or disposing of mineral oils or for`
  line `purposes connected therewith, and includes a mining lease granted before the commencement of the`
  line `said Act.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Cl. (b) omitted by Act 6 of 2025, s. 2 (w.e.f. 15-4-2025).`
  line
  line `2. Subs. by s. 2, ibid., for clause (c) (w.e.f. 15-4-2025).`
  line
  line `3. Subs. by Act 67 of 1957, s. 32 and the Third Schedule, for minerals (w.e.f. 1-6-1958).`
  line
  line `4. Ins. by Act 6 of 2025, s. 2, (w.e.f. 15-4-2025).`
  line
  line `5. Subs. by s. 2, ibid., for "natural gas and petroleum, crude oil" (15-4-2025).`
  line
  line `6. Ins. by s. 2, ibid., (w.e.f. 15-4-2025).`
obj_root_law_sections_4:
  sectionId (14106)
  sectionNo (4)
  orderNo 4
  title `No petroleum lease to be valid unless it is in accordance with this Act.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 6 of 2025, s. 3, for "mining lease" (w.e.f. 15-4-2025)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14106&sectionno=4&orderno=4&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_4_content:
  string
  line `4. No ^1[petroleum lease] to be valid unless it is in accordance with this Act.--- (1) No ^1[petroleum lease] shall be granted after the commencement of this act otherwise than in accordance with the rules`
  line `made under this Act.`
  line
  line `(2) Any ^1[petroleum lease] granted contrary to the provisions of sub-section (1) shall be void and of`
  line `no effect.`
obj_root_law_sections_4_a:
  sectionId (95864)
  sectionNo 4A
  orderNo 5
  title `prospecting, etc., of mineral oils.`
  content obj_root_law_sections_4_a_content
  footnotes `1. Ins. by Act 6 of 2025, s. 4 (w.e.f. 15-4-2025).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=95864&sectionno=4A&orderno=5&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_4_a_content:
  string
  line `^1[4A. Prospecting, etc., of mineral oils.--- No person shall undertake any operation in any part of`
  line `India or in its territorial waters, continental shelf and exclusive economic zone for the purposes of`
  line `prospecting, exploration, development or production, making merchantable, carrying away or disposing`
  line `of mineral oils, except under a valid lease granted under this Act and the rules made thereunder:`
  line
  line `Provided that nothing in this section shall affect any operation undertaken in any area in accordance`
  line `with the terms and conditions of a license or lease granted before the commencement of the Oilfields`
  line `(Regulation and Development) Amendment Act, 2025.]`
obj_root_law_sections_5:
  sectionId (14107)
  sectionNo (5)
  orderNo 6
  title `Power to make rules as respects petroleum leases.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14107&sectionno=5&orderno=6&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_5_content:
  string
  line `5. Power to make rules as respects ^1[petroleum leases].---(1) The Central Government may, by`
  line `notification in the Official Gazette, make rules for regulating the ^2[grant or extension or renewal of`
  line `petroleum leases or for prohibiting the grant or extension or renewal] of such leases in respect of`
  line `any ^3[mineral oil] or in any area.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely: ---`
  line
  line `(a) the manner in which, the ^3[mineral oil] or areas in respect of which and the persons by`
  line `whom, applications for ^4[petroleum leases] may be made and the fees to be paid on any such`
  line application;
  line
  line `(b) the authority by which, the terms on which, and the conditions subject to which, ^5[petroleum`
  line `leases may be granted or extended or renewed];`
  line
  line `^6[(c) the maximum or minimum area of the petroleum leases;`
  line
  line `(ca) the period for which any petroleum lease may be granted or extended or renewed;`
  line
  line `(cb) the terms on which petroleum leases may be merged or combined;]`
  line
  line `(d) the fixing of the maximum and minimum rent payable by a lessee, whether the ^7[oilfield] is`
  line `worked or not.`
  line
  line `^8[(e) the mechanism to enable resolution of disputes arising out of, or in relation to the petroleum`
  line `leases or any authorisation granted by the Central Government for working of an oilfield through`
  line `alternative dispute resolution methods under any law for the time being in force, in a place within`
  line `India or outside India;`
  line
  line `(f) any other matter which is required to be, or may be made by rules or in respect of which`
  line `provision is to be made under this section.]`
  line
  line `^8[(3) The terms and conditions of a petroleum lease shall remain stable during the period of the lease`
  line `for expeditious and efficient development of oilfields or production of mineral oils and shall not be`
  line `altered to the disadvantage of the lessee during the period of the lease.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 6 of 2025, s. 5, for "mining leases" (w.e.f. 15-4-2025).`
  line
  line `2. Subs. by s. 5, ibid., for certain words (w.e.f. 15-4-2025).`
  line
  line `3. Subs. by Act 67 of 1957, s. 32 and the Third Schedule, for "minerals" (w.e.f.1-6-1958).`
  line
  line `4. Subs. by Act 6 of 2025, s. 5, for "mining leases" (w.e.f. 15-4-2025).`
  line `5. Subs. by s. 5,ibid., for "mining leases may be granted" (w.e.f. 15-4-2025).`
  line
  line `6. Subs. by s. 5,ibid., for clause (c) (w.e.f. 15-4-2025).`
  line
  line `7. Subs. by s. 5,ibid., for "mine" (w.e.f. 15-4-2025).`
  line
  line `8. Ins. by s. 5, ibid. (w.e.f. 15-4-2025).`
obj_root_law_sections_6:
  sectionId (14108)
  sectionNo (6)
  orderNo 7
  title `Power to make rules as respects mineral oils development.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14108&sectionno=6&orderno=7&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_6_content:
  string
  line `6. Power to make rules as respects ^1[mineral oils] development.--- (1) The Central Government`
  line `may, by notification in the Official Gazette, make rules for the ^2[exploration, development, production`
  line `and conservation] of ^3[mineral oils].`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely: ---`
  line
  line `^4* * * * *`
  line
  line `(c) the development of any ^5[mineral oil resources] in any area by prescribing or regulating the`
  line `use of any engines, machinery or other equipment;`
  line
  line `(d) the regulation of drilling, re-drilling, deepening, shutting down, plugging and abandoning`
  line `of ^6[mineral oil wells and decommissioning and site restoration activities] in an oilfield and for the`
  line `limitation or prohibition of such operations and for the taking of remedial measures to prevent waste`
  line `of or damage to ^7[mineral oils];`
  line
  line `(e) the regulation of the methods of producing ^7[mineral oils] in any oilfield, and the limitation or`
  line `prohibition of such methods;`
  line
  line `(f) the compulsory notification of all new borings and shaft sinkings, and the preservation of`
  line `boring records and specimens of cores of all new bore-holes;`
  line
  line `(g) the taking of samples from ^8[oilfields] and new bore-holes;`
  line
  line `^9[(ga) the collection, aggregation, dissemination, use or sharing of the data and samples related`
  line `to mineral oils with the Central Government or any other party nominated by the Central`
  line `Government, for the purposes of economic development, academic research and public welfare;]`
  line
  line `(h) the regulation of the arrangements for the storage of ^3[mineral oils] and the stocks thereof that`
  line `may be kept by any person;`
  line
  line `^10[(i) the collection of royalties, and the levy and collection of fees or taxes, in respect of mineral`
  line `oils ^11[produced];]`
  line
  line `(j) the submission by the ^12[lessees of oilfields of special or periodical returns and reports, and the`
  line `formats] in which and the authorities to whom such returns and reports shall be submitted.`
  line
  line `^13[(k) the sharing of production and processing facilities and other infrastructure, both on land and`
  line `offshore, by two or more lessees for more efficient development of oilfields or production of mineral`
  line oils;
  line
  line `(l) the safety at oilfields including safety mechanisms, standards and protocols for conduct of`
  line `mineral oil operations, protection of persons and infrastructure such as terminals, installations, other`
  line `structures and devices, and mineral oils;`
  line
  line `(m) the sound management of mineral oils in accordance with good international petroleum`
  line `industry practices including obligations of lessees towards protection of environment during`
  line `operations and while abandoning, decommissioning and undertaking site restoration activities;`
  line
  line `(n) the unitisation of leases across States, Union territories and offshore leases, where there is`
  line `reservoir continuity or connectivity, or for efficient exploration, development or production of`
  line `mineral oils;`
  line
  line `(o) promote and facilitate adoption of measures for reducing carbon and greenhouse gas`
  line `emissions and decarbonising operations including but not limited to use of oilfields for other`
  line `purposes, such as, production of hydrogen, carbon capture utilisation and storage or coal gasification;`
  line
  line `(p) reporting of carbon and greenhouse gas emissions related to, arising out of, or resulting from,`
  line `mineral oil operations;`
  line
  line `(q) promote and facilitate development of comprehensive energy projects at oilfields, including`
  line `planning, development, installation, sharing and use of infrastructure for carrying out mineral oil`
  line `operations and solar, wind or other form of renewable energy projects;`
  line
  line `(r) any other matter which is required to be, or may be made by rules, or in respect of which`
  line `provision is to be made under this section.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 6 of 2025, s. 6, for "mineral" (w.e.f.15-4-2025).`
  line
  line `2. Subs. by s. 6, ibid., for "conservation and development" (w.e.f.15-4-2025).`
  line
  line `3. Subs. by Act 67 of 1957, s. 32 and the Third Schedule, for "minerals" (w.e.f.1-6-1958).`
  line
  line `4. Clauses (a) and (b) omitted by s. 32 and the Third Schedule,ibid., (w.e.f.1-6-1958).`
  line
  line `5. Subs. by s. 32 and the Third Schedule, ibid., for "mineral resources" (w.e.f.1-6-1958).`
  line
  line `6. Subs. by Act 6 of 2025, s. 6, for "oil wells" (15-4-2025).`
  line
  line `7. Subs. by s. 6, ibid., for "oil" (15-4-2025).`
  line
  line `8. Subs. by s. 6, ibid., for "mines" (15-4-2025).`
  line
  line `9. Ins. by s. 6, ibid. (15-4-2025).`
  line
  line `10. Subs. by Act 39 of 1969, s. 2, for clause (i) (w.e.f. 1-1-1968).`
  line
  line `11. Subs. by Act 6 of 2025, s. 6, for "mined, quarried, excavated or collected" (w.e.f. 15-4-2025).`
  line
  line `12. Subs. by s. 6, ibid., for certain words (w.e.f. 15-4-2025).`
  line
  line `13. Ins. by s. 6, ibid. (w.e.f. 15-4-2025).`
obj_root_law_sections_6_a:
  sectionId (14109)
  sectionNo 6A
  orderNo 8
  title `Royalties in respect of mineral oils.`
  content obj_root_law_sections_6_a_content
  footnotes obj_root_law_sections_6_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14109&sectionno=6A&orderno=8&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_6_a_content:
  string
  line `^1[6A. Royalties in respect of mineral oils.--- (1) The holders of a mining lease granted before the`
  line `commencement of the Oilfields (Regulation and Development) Amendment Act, 1969 (39 of 1969) shall,`
  line `notwithstanding anything contained in the instrument of lease or in any law in force at such`
  line `commencement, pay royalty in respect of any mineral oil ^2[produced] or collected by him from the leased`
  line `area after such commencement, at the rate for the time being specified in the Schedule in respect of that`
  line `mineral oil.`
  line
  line `(2) The holder of a mining lease ^3[or petroleum lease] granted on or after the commencement of the`
  line `Oilfields (Regulation and Development) Amendment Act, 1969 (39 of 1969) shall pay royalty in respect`
  line `of any mineral oil ^2[produced] or collected by him from the leased area at the rate for the time being`
  line `specified in the Schedule in respect of that mineral oil.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1) or sub-section (2), no royalty shall be`
  line `payable in respect of any ^4[mineral oils] which is unavoidably lost or is returned to the reservoir or is used`
  line `for drilling or other operations relating to the production of ^5[mineral oils].`
  line
  line `^6[(4) The Central Government may, by notification in the Official Gazette, amend the Schedule so as`
  line `to enhance or reduce the rate at which royalty shall be payable in respect of any mineral oil with effect`
  line `from such date as may be specified in the notification and different rates may be notified in respect of`
  line `same mineral oil ^2[produced] or collected from the areas covered by different classes`
  line `of ^7[petroleum leases]:`
  line
  line `Provided that the Central Government shall not fix the rates of royalty in respect of any mineral oil so`
  line `as to exceed twenty per cent. of the sale price of the mineral oil at the oilfields or the oil well-head, as the`
  line `case may be.`
  line
  line `(5) If the Central Government, with a view to encourage exploration in off-shore areas, is satisfied`
  line `that it is necessary in the public interest so to do, it may, by notification in the Official Gazette, exempt`
  line `generally, either absolutely or subject to such conditions as may be specified in the notification,`
  line `mineral oil produced from such areas from the whole or any part of the royalty leviable thereon.]`
obj_root_law_sections_6_a_footnotes:
  string
  line `1. Ins. by Act 39 of 1969, s. 3 (w.e.f. 1-1-1968).`
  line
  line `2. Subs. by Act 6 of 2025, s. 7, for "mined, quarried, excavated" (w.e.f. 15-4-2025).`
  line
  line `3. Ins. by s. 7,ibid. (w.e.f. 15-4-2025).`
  line
  line `4. Subs. by s. 7,ibid., for "crude oil, casing-head condensate or natural gas" (w.e.f. 15-4-2025).`
  line
  line `5. Subs. by s. 7, ibid., for "petroleum or natural gas, or both" (w.e.f. 15-4-2025).`
  line
  line `6. Subs. by Act 29 of 1998, s. 2, for sub-section (4) (w.e.f. 3-9-1998).`
  line
  line `7. Subs. by Act 6 of 2025, s. 7, for "mining leases" (w.e.f. 15-4-2025).`
obj_root_law_sections_7:
  sectionId (14110)
  sectionNo (7)
  orderNo 9
  title `Power to make rules for modification of existing leases.`
  content obj_root_law_sections_7_content
  footnotes `1.Subs. by the A. O. 1950, for "the Central Legislature".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14110&sectionno=7&orderno=9&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_7_content:
  string
  line `(1) The Central Government may, by`
  line `notification in the Official Gazette, make rules for the purpose of modifying or altering the terms and`
  line `conditions of any mining lease granted prior to the commencement of this Act so as to bring such lease`
  line `into conformity with the rules made under sections 5 and 6:`
  line
  line `Provided that any rules so made which provide for the matters mentioned in clause (c) of subsection(2)`
  line `shall not come into force until they have been approved, either with or without modifications,`
  line `by ^1[the House of the People].`
  line
  line `(2) The rules made under sub-section (1) shall provide--`
  line
  line `(a) for giving previous notice of the modification or alteration proposed to be made thereunder to`
  line `the lessee, and where the lessor is not the Central Government, also to the lessor, and for affording`
  line `them an opportunity of showing cause against the proposal;`
  line
  line `(b) for the payment of compensation by the party who would be benefited by the proposed`
  line `modification or alteration to the party whose right under the existing lease would thereby be`
  line `adversely affected; and`
  line
  line `(c) for the principles on which, the manner in which and the authority by which the said`
  line `compensation shall be determined.`
obj_root_law_sections_8:
  sectionId (14111)
  sectionNo (8)
  orderNo 10
  title Delegation.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14111&sectionno=8&orderno=10&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_8_content:
  string
  line `The Central Government may, by notification in the Official Gazette, direct that any`
  line `power exercisable under this Act shall be exercised,subject to such conditions, if any, as may be specified`
  line `therein by such officer or authority as may be specified in the direction.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (14112)
  sectionNo (9)
  orderNo 11
  title Penalties.
  content obj_root_law_sections_9_content
  footnotes `1. Subs. by Act 6 of 2025, s. 8, for section 9 (w.e.f. 15-4-2025).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14112&sectionno=9&orderno=11&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_9_content:
  string
  line `^1[9. Penalties.--- (1) Whoever contravenes the provisions of section 4A or sub-section (1) or sub-section`
  line `(2) of section 6A shall be liable to a penalty of twenty-five lakh rupees.`
  line
  line `(2) Any rule made under any of the provisions of this Act may provide that any contravention thereof shall`
  line `be liable to a penalty of twenty-five lakh rupees.`
  line
  line `(3) Whoever, after having been punished with penalty as referred to in sub-section (1) or sub-section(2),`
  line `continues to contravene any of the provisions of this Act or rules made thereunder, shall be liable to pay a`
  line `further penalty which may extend to ten lakh rupees per day for the entire duration during which the`
  line `contravention continues commencing from the date of imposition of the first penalty.]`
obj_root_law_sections_9_a:
  sectionId (95866)
  sectionNo 9A
  orderNo 12
  title Adjudication.
  content obj_root_law_sections_9_a_content
  footnotes `1. Subs. by Act 6 of 2025, s. 8, for section 9 (w.e.f. 15-4-2025).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=95866&sectionno=9A&orderno=12&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_9_a_content:
  string
  line `^1[9A. Adjudication.--- (1) The Central Government shall, by notification in the Official Gazette, make rules`
  line `for providing eligibility criteria for designating an adjudicating authority and for the manner of conducting`
  line `inquiry and imposing penalty under the provisions of this Act:`
  line
  line `Provided that no officer below the rank of Joint Secretary to the Government of India shall be designated`
  line `as an adjudicating authority.`
  line
  line `(2) The adjudicating authority may summon and enforce the attendance of any person acquainted with the`
  line `facts and circumstances of the case to give evidence or to produce any document, which in his opinion may be`
  line `useful for or relevant to the subject matter of the inquiry and if, on such inquiry, he is satisfied that the person`
  line `concerned has contravened the provisions of this Act or the rules made thereunder, he may determine such`
  line `penalty in accordance with the provisions of this Act.`
  line
  line `(3) No penalty shall be imposed on any person under this section or any rules made thereunder without`
  line `affording an opportunity of being heard.]`
obj_root_law_sections_9_b:
  sectionId (95868)
  sectionNo 9B
  orderNo 13
  title Appeal.
  content obj_root_law_sections_9_b_content
  footnotes `1. Subs. by Act 6 of 2025, s. 8, for section 9 (w.e.f. 15-4-2025).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=95868&sectionno=9B&orderno=13&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_9_b_content:
  string
  line `^1[9B. Appeal.--- (1) Every appeal against the order of the adjudicating authority under this section shall lie`
  line `with the Appellate Tribunal referred to in section 30 of the Petroleum and Natural Gas Regulatory Board Act,`
  line `2006, (19 of 2006) and the provisions contained in sections 33, 34, 35 and 36 of that Act, shall, mutatis`
  line `mutandis apply, in relation to every such appeal.`
  line
  line `(2) The provisions contained in section 37 of the Petroleum and Natural Gas Regulatory Board Act, 2006,`
  line `(19 of 2006) shall mutatis mutandis apply, in relation to every appeal against the order of the Appellate`
  line `Tribunal referred to in sub-section (1).]`
obj_root_law_sections_10:
  sectionId (14113)
  sectionNo (10)
  orderNo 14
  title `Laying of rules and notifications.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14113&sectionno=10&orderno=14&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_10_content:
  string
  line `^1[10. Laying of rules and notifications.--Every rule made under this Act and every notification`
  line `issued ^2[under sub-section (4) or sub-section (5) or section 6A] ^3[or section 8] shall be laid, as soon as may be after it is`
  line `made or issued, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or notification or both Houses agree that the rule or notification`
  line `should not be made or issued, the rule or notification shall thereafter have effect only in such modified`
  line `form or be of no effect, as the case may be; so, however, that any such modification or annulment shall be`
  line `without prejudice to the validity of anything previously done under that rule or notification.]`
obj_root_law_sections_10_footnotes:
  string
  line `1. Subs. by Act 20 of 1984, s. 3, for the original section10.`
  line
  line `2. Subs. by Act 29 of 1998, s. 3, for "under sub-section (4) of section 6A" (w.e.f. 3-9-1998).`
  line
  line `3. Ins. by Act 6 of 2025, s. 9 (w.e.f. 15-4-2025).`
obj_root_law_sections_11:
  sectionId (14114)
  sectionNo (11)
  orderNo 15
  title `Power of inspection.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 6 of 2025, s. 10, for "mine" (w.e.f. 15-4-2025).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14114&sectionno=11&orderno=15&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_11_content:
  string
  line `(1) For the purpose of ascertaining the position of the working, actual or`
  line `prospective, of any ^1[oilfield] or abandoned ^1[oilfield] or for any other purpose mentioned in this Act or`
  line `the rules made thereunder, any officer authorised by the Central Government in this behalf shall have the`
  line `right to---`
  line
  line `(a) enter and inspect any ^1[oilfield];`
  line
  line `(b) order the production of any document, book, register or record in the possession or power of`
  line `any person having the control of, or connected with, any ^1[oilfield];`
  line
  line `(c) examine any person having the control of, or connected with, any^1[oilfield].`
  line
  line `(2) Any officer authorised by the Central Government under sub-section (1) shall be deemed to be a`
  line `public servant within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_12:
  sectionId (14115)
  sectionNo (12)
  orderNo 16
  title `Relaxation of rules in special cases.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14115&sectionno=12&orderno=16&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_12_content:
  string
  line `The Central Government may, if satisfied that it is in the`
  line `public interest so to do, authorise in any case the granting of any ^1[petroleum lease], or the working of`
  line `any ^2[oilfield] on terms and conditions different from those laid down in the rules made under sections 5`
  line `and 6.`
obj_root_law_sections_12_footnotes:
  string
  line `1. Subs. by Act 6 of 2025, s. 11, for "mining lease" (w.e.f. 15-4-2025).`
  line
  line `2. Subs. by s. 11, ibid., for "mine" (w.e.f. 15-4-2025).`
obj_root_law_sections_13:
  sectionId (14116)
  sectionNo (13)
  orderNo 17
  title `Act to be binding on the Government.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. bythe A.O. 1950,fors.13 (w.e.f. 26-1-1950).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14116&sectionno=13&orderno=17&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_13_content:
  string
  line `^1[13. Act to be binding on the Government.--The provisions of this Act shall be binding on the`
  line Government.]
obj_root_law_sections_13_a:
  sectionId (95869)
  sectionNo 13A
  orderNo 18
  title `Validity of leases and licenses.`
  content obj_root_law_sections_13_a_content
  footnotes `1. Ins. by Act 6 of 2025, s. 12 (w.e.f. 15-4-2025).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=95869&sectionno=13A&orderno=18&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_13_a_content:
  string
  line `^1[13A. Validity of leases and licenses.--- All mining leases and licenses granted before`
  line `commencement of the Oilfields (Regulation and Development) Amendment Act, 2025, shall continue to`
  line `be valid for their respective tenure subject to the terms and conditions governing the grant of such leases`
  line `and licenses.]`
obj_root_law_sections_14:
  sectionId (14117)
  sectionNo (14)
  orderNo 19
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00003_194853_1517807321812&sectionId=14117&sectionno=14&orderno=19&orgactid=AC_CEN_32_50_00003_194853_1517807321812
obj_root_law_sections_14_content:
  string
  line `No suit, prosecution or other legal proceeding`
  line `whatever shall lie against any person for anything which is in good faith done or intended to be done`
  line `under this Act.`
obj_root_law_sections_14_footnotes:
  string
  line
