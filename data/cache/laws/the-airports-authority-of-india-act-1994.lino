obj_root_law_sections_1:
  sectionId (16525)
  sectionNo (1)
  orderNo 1
  title `Short title, commencement and application.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16525&sectionno=1&orderno=1&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_1_content:
  string
  line `^1[1. Short title, commencement and application.--(1) This Act may be called the Airports Authority`
  line `of India Act, 1994.`
  line
  line `(2) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
  line
  line `(3) It applies to--`
  line
  line `(a) all airports whereat air transport services are operated or are intended to be operated, other`
  line `than airports and airfields belonging to, or subject to the control of, any armed force of the Union;`
  line
  line `^3[(aa) all private airports insofar as it relates to providing air traffic service, to issue directions`
  line `under section 37 to them and for the purposes of Chapter VA;]`
  line
  line `(b) all civil enclaves;`
  line
  line `(c) all aeronautical communication stations; and`
  line
  line `(d) all training stations, establishments and workshops relating to air transport services.]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Ins. by Act of 43 of 2003, s. 2 (w.e.f. 1-7-2004).`
  line
  line `2.1st April, 1995, vide notification No. S.O. 285(E), dated 30th March, 1995, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
  line
  line `3. Ins. by Act 43 of 2003, s. 3 (w.e.f. 1-7-2004).`
obj_root_law_sections_2:
  sectionId (16526)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 4 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16526&sectionno=2&orderno=2&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "aeronautical communication station" means a station in the aeronautical communication`
  line `service which includes aeronautical practising service, aeronautical fixed service, aeronautical mobile`
  line `service and aeronautical radio communication service;`
  line
  line `(b) "airport" means a landing and taking off area for aircrafts, usually with runways and aircraft`
  line `maintenance and passenger facilities and includes aerodrome as defined in clause (2) of section 2 of`
  line `the Aircraft Act, 1934 (22 of 1934);`
  line
  line `(c) "airstrip" means an area used or intended to be used for the landing and take-off of aircrafts`
  line `with short take-off and landing characteristics and includes all buildings and structures thereon or`
  line `appertaining thereto;`
  line
  line `(d) "air traffic service" includes flight information service, alerting service, air traffic advisory`
  line `service, air traffic control service, area control service, approach control service and airport control`
  line service;
  line
  line `(e) "air transport service" means any service, for any kind of remuneration, whatsoever, for the`
  line `transport by air of persons, mail or any other thing, animate or inanimate, whether such service relates`
  line `to a single flight or series of flights;`
  line
  line `(f) "appointed day" means such date as the Central Government may, by notification in the`
  line `Official Gazette, appoint for the purposes of section 3;`
  line
  line `(g) "Authority" means the Airports Authority of India constituted under section 3;`
  line
  line `(h) "Chairperson" means the Chairperson of the Authority appointed under clause (a) of`
  line `sub-section (3) of section 3;`
  line
  line `(i) "civil enclave" means the area, if any, allotted at an airport belonging to any armed force of`
  line `the Union, for use by persons availing of any air transport services from such airport or for the`
  line `handling of baggage or cargo by such service, and includes land comprising of any building and`
  line `structure on such area;`
  line
  line `(j) "heliport" means an area, either at ground level or elevated on a structure, used or intended to`
  line `be used for the landing and take-off helicopters and includes any area for parking helicopters and all`
  line `buildings and structures thereon or appertaining thereto;`
  line
  line `(k) "International Airports Authority" means the International Airports Authority of India`
  line `constituted under section 3 of the International Airports Authority Act, 1971 (43 of 1971);`
  line
  line `(l) "member" means a member of the Authority and includes the Chairperson, but does not`
  line `include, for the purposes of sections 4, 5, 6 and 7, an ex officio member referred to in clause (b) of`
  line `sub-section (3) of section 3;`
  line
  line `(m) "National Airports Authority" means the National Airports Authority constituted under`
  line `section 3 of the National Airports Authority Act, 1985 (64 of 1985);`
  line
  line `(n) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^1[(nn) "private airport" means an airport owned, developed or managed by--`
  line
  line `(i) any person or agency other than the Authority or any State Government, or`
  line
  line `(ii) any person or agency jointly with the Authority or any State Government or both`
  line `where the share of such person or agency, as the case may be, in the assets of the private`
  line `airport is more than fifty per cent.]`
  line
  line `(o) "regulations" means regulations made under this Act.`
obj_root_law_sections_3:
  sectionId (16527)
  sectionNo (3)
  orderNo 3
  title `Constitution and incorporation of the Authority.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16527&sectionno=3&orderno=3&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_3_content:
  string
  line `(1) With effect from the appointed day, the`
  line `Central Government shall, by notification in the Official Gazette, constitute an Authority to be called the`
  line `Airports Authority of India.`
  line
  line `(2) The Authority shall be a body corporate by the name aforesaid having perpetual succession and a`
  line `common seal, with power, subject to the provisions of this Act, to acquire, hold and dispose of property`
  line `both movable and immovable, and to contract and shall by the said name sue and be sued.`
  line
  line `(3) The Authority shall consist of--`
  line
  line `(a) a Chairperson to be appointed by the Central Government;`
  line
  line `(b) the Director General of Civil Aviation, or an officer not below the rank of the Deputy Director`
  line `General of Civil Aviation, to be appointed by the Central Government, ex officio;`
  line
  line `(c) not less than eight and not more than fourteen members to be appointed by the Central`
  line Government.
  line
  line `(4) The Chairperson shall be a whole-time member and other members referred to in clause (c) of`
  line `sub-section (3) may be appointed as whole-time or part-time members as the Central Government may`
  line `think fit.`
  line
  line `(5) The Chairperson and the members referred to in clause (c) of sub-section (3) shall be chosen from`
  line `among persons who have special knowledge and experience in air transport of any other transport`
  line `services, industry, commercial or financial matters or administration and from among persons who are`
  line `capable of representing organisations of workers and consumers.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (16528)
  sectionNo (4)
  orderNo 4
  title `Disqualification for office of member.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16528&sectionno=4&orderno=4&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_4_content:
  string
  line `A person shall be disqualified for being appointed as a`
  line `member if he--`
  line
  line `(a) has been convicted and sentenced to imprisonment for an offence, which, in the opinion of the`
  line `Central Government, involves moral turpitude; or`
  line
  line `(b) is an undischarged insolvent; or`
  line
  line `(c) is of unsound mind and stands so declared by a competent court; or`
  line
  line `(d) has been removed or dismissed from the service of the Government or a body corporate`
  line `owned or controlled by the Government; or`
  line
  line `(e) has in the opinion of the Central Government such financial or other interest in the Authority`
  line `as is likely to affect prejudicially the discharge by him of his functions as a member.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (16529)
  sectionNo (5)
  orderNo 5
  title `Term of office and conditions of service of members.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16529&sectionno=5&orderno=5&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_5_content:
  string
  line `(1) Subject to the provisions of`
  line `section 6,--`
  line
  line `(i) every whole-time member (other than the ex officio member) shall hold office for a period of`
  line `five years from the date on which he assumes office or till he attains the age of sixty years, whichever`
  line `is earlier, and`
  line
  line `(ii) every part-time member (other than the ex officio member) shall hold office for a period of`
  line `three years from the date on which he assumes office:`
  line
  line `Provided that the Central Government may--`
  line
  line `(a) terminate the appointment of any whole-time member, who is not a servant of the`
  line `Government, after giving him notice for a period of not less than three months or, in lieu thereof, on`
  line `payment of an amount equal to his salary and allowances, if any, for a period of three months;`
  line
  line `(b) terminate the appointment of any part-time member who is not a servant of the Government`
  line `after giving him notice for such period as may be prescribed; and`
  line
  line `(c) terminate at any time the appointment of any member who is a servant of the Government.`
  line
  line `(2) The other conditions of service of the members shall be such as may be prescribed.`
  line
  line `(3) Any member may resign his office by giving notice in writing for such period as may be`
  line `prescribed, to the Central Government and, on such resignation being notified in the Official Gazette by`
  line `the Government, such member shall be deemed to have vacated his office.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (16530)
  sectionNo (6)
  orderNo 6
  title `Vacation of office of member.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16530&sectionno=6&orderno=6&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_6_content:
  string
  line `The Central Government shall remove a member if he--`
  line
  line `(a) becomes subject to any of the disqualifications mentioned in section 4:`
  line
  line `Provided that no member shall be removed on the ground that he has become subject to the`
  line `disqualification mentioned in clause (e) of that section, unless he has been given a reasonable`
  line `opportunity of being heard in the matter; or`
  line
  line `(b) refuses to act or becomes incapable of acting; or`
  line
  line `(c) is, without obtaining leave of absence from the Authority, absent from three consecutive`
  line `meetings of the Authority; or`
  line
  line `(d) in the opinion of the Central Government, has so abused his position as to render his`
  line `continuance in office detrimental to the public interest:`
  line
  line `Provided that no member shall be removed under this clause unless he has been given a`
  line `reasonable opportunity of being heard in the matter.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (16531)
  sectionNo (7)
  orderNo 7
  title `Eligibility of member for re-appointment.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16531&sectionno=7&orderno=7&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_7_content:
  string
  line `Any person ceasing to be a member shall, unless`
  line `disqualified under section 4, be eligible for re-appointment.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (16532)
  sectionNo (8)
  orderNo 8
  title Meetings.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16532&sectionno=8&orderno=8&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_8_content:
  string
  line `(1) The Authority shall meet at such times and places, and shall observe such rules of`
  line `procedure in regard to the transaction of the business at its meetings (including the quorum at such`
  line `meetings) as may be provided by regulations.`
  line
  line `(2) The Chairperson, or, if for any reason he is unable to attend any meeting of the Authority, any`
  line `other member chosen by the members present at the meeting shall preside at the meeting.`
  line
  line `(3) All questions which come up before any meeting of the Authority shall be decided by a majority`
  line `of the votes of the members present and voting, and, in the event of an equality of votes, the Chairperson,`
  line `or in his absence, the person presiding, shall have and exercise a second or casting vote.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (16533)
  sectionNo (9)
  orderNo 9
  title `Vacancies, etc., not to invalidate proceedings of the Authority.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16533&sectionno=9&orderno=9&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_9_content:
  string
  line `No act or proceeding of the`
  line `Authority shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Authority; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Authority; or`
  line
  line `(c) any irregularity in the procedure of the Authority not affecting the merits of the case`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (16534)
  sectionNo (10)
  orderNo 10
  title `Appointment of officers and other employees of the Authority.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16534&sectionno=10&orderno=10&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_10_content:
  string
  line `(1) For the purpose of`
  line `enabling it efficiently to discharge its functions under this Act, the Authority shall, subject to the`
  line `provisions of section 18 and to such rules as may be made in this behalf, appoint (whether on deputation`
  line `or otherwise) such number of officers and other employees as it may consider necessary:`
  line
  line `Provided that the appointment of such category of officers, as may be specified after consultation`
  line `with the Chairperson in such rules, shall be subject to the approval of the Central Government.`
  line
  line `(2) Subject to the provisions of section 18, every officer or other employee appointed by the`
  line `Authority shall be subject to such conditions of service and shall be entitled to such remuneration as may`
  line `be determined by regulations.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (16535)
  sectionNo (11)
  orderNo 11
  title `Authority to act on business principles.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16535&sectionno=11&orderno=11&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_11_content:
  string
  line `In the discharge of its functions under this Act, the`
  line `Authority shall act, so far as may be, on business principles.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (16536)
  sectionNo (12)
  orderNo 12
  title `Functions of the Authority.`
  content obj_root_law_sections_12_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 5 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16536&sectionno=12&orderno=12&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_12_content:
  string
  line `(1) Subject to the rules, if any, made by the Central Government in`
  line `this behalf, it shall be the function of the Authority to manage the airports, the civil enclaves and the`
  line `aeronautical communication stations efficiently.`
  line
  line `(2) It shall be the duty of the Authority to provide air traffic service and air transport service at any`
  line `airport and civil enclaves.`
  line
  line `(3) Without prejudice to the generality of the provisions contained in sub-sections (1) and (2), the`
  line `Authority may--`
  line
  line `(a) plan, develop, construct and maintain runways, taxiways, aprons and terminals and ancillary`
  line `buildings at the airports and civil enclaves;`
  line
  line `^1[(aa) establish airports, or assist in the establishment of private airports, by rendering such`
  line `technical, financial or other assistance which the Central Government may consider necessary for`
  line `such purpose;]`
  line
  line `(b) plan, procure, instal and maintain navigational aids, communication equipment, beacons and`
  line `ground aids at the airports and at such locations as may be considered necessary for safe navigation`
  line `and operation of aircrafts;`
  line
  line `(c) provide air safety services and search and rescue, facilities in co-ordination with other`
  line agencies;
  line
  line `(d) establish schools or institutions or centres for the training of its officers and employees in`
  line `regard to any matter connected with the purposes of this Act;`
  line
  line `(e) construct residential buildings for its employees;`
  line
  line `(f) establish and maintain hotels, restaurants and restrooms at or near the airports;`
  line
  line `(g) establish warehouses and cargo complexes at the airports for the storage or processing of`
  line goods;
  line
  line `(h) arrange for postal, money exchange, insurance and telephone facilities for the use of`
  line `passengers and other persons at the airports and civil enclaves;`
  line
  line `(i) make appropriate arrangements for watch and ward at the airports and civil enclaves;`
  line
  line `(j) regulate and control the plying of vehicles, and the entry and exit of passengers and visitors, in`
  line `the airports and civil enclaves with due regard to the security and protocol functions of the`
  line `Government of India;`
  line
  line `(k) develop and provide consultancy, construction or management services, and undertake`
  line `operations in India and abroad in relation to airports, air-navigation services, ground aids and safety`
  line `services or any facilities thereat;`
  line
  line `(l) establish and manage heliports and airstrips;`
  line
  line `(m) provide such transport facility as are, in the opinion of the Authority, necessary to the`
  line `passengers travelling by air;`
  line
  line `(n) form one or more companies under the Companies Act, 1956 (1 of 1956) or under any other`
  line `law relating to companies to further the efficient discharge of the functions imposed on it by this Act;`
  line
  line `(o) take all such steps as may be necessary or convenient for, or may be incidental to, the exercise`
  line `of any power or the discharge of any function conferred or imposed on it by this Act;`
  line
  line `(p) perform any other function considered necessary or desirable by the Central Government for`
  line `ensuring the safe and efficient operation of aircraft to, from and across the air space of India;`
  line
  line `(q) establish training institutes and workshops;`
  line
  line `(r) any other activity at the airports and the civil enclaves in the best commercial interests of the`
  line `Authority including cargo handling, setting up of joint ventures for the discharge of any function`
  line `assigned to the Authority.`
  line
  line `(4) In the discharge of its functions under this section, the Authority shall have due regard to the`
  line `development of air transport service and to the efficiency, economy and safety of such service.`
  line
  line `(5) Nothing contained in this section shall be construed as--`
  line
  line `(a) authorising the disregard by the Authority of any law for the time being in force; or`
  line
  line `(b) authorising any person to institute any proceeding in respect of duty or liability to which the`
  line `Authority or its officers or other employees would not otherwise be subject.`
obj_root_law_sections_12_a:
  sectionId (16537)
  sectionNo 12A
  orderNo 13
  title `Lease by the Authority.`
  content obj_root_law_sections_12_a_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 6 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16537&sectionno=12A&orderno=13&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_12_a_content:
  string
  line `^1[12A. Lease by the Authority.--(1) Notwithstanding anything contained in this Act, the Authority`
  line `may, in the public interest or in the interest of better management of airports, make a lease of the premises`
  line `of an airport (including buildings and structures thereon and appertaining thereto) to carry out some of its`
  line `functions under section 12 as the Authority may deem fit:`
  line
  line `Provided that such lease shall not affect the functions of the Authority under section 12 which relates`
  line `to air traffic service or watch and ward at airports and civil enclaves.`
  line
  line `(2) No lease under sub-section (1) shall be made without the previous approval of the Central`
  line Government.
  line
  line `(3) Any money, payable by the lessee in terms of the lease made under sub-section (1), shall form`
  line `part of the fund of the Authority and shall be credited thereto as if such money is the receipt of the`
  line `Authority for all purposes of section 24.`
  line
  line `(4) The lessee, who has been assigned any function of the Authority under sub-section (1) shall have`
  line `all the powers of the Authority necessary for the performance of such function in terms of the lease.]`
obj_root_law_sections_13:
  sectionId (16538)
  sectionNo (13)
  orderNo 14
  title `Undertakings of the International Airports Authority and the National Airports Authority to vest in the Authority.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16538&sectionno=13&orderno=14&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_13_content:
  string
  line `(1) On and from the appointed day, there shall be transferred to, and vest in,`
  line `the Authority constituted under section 3, the undertakings of the International Airports Authority and the`
  line `National Airports Authority.`
  line
  line `(2) The undertaking of the International Airports Authority or the National Airports Authority which`
  line `is transferred to, and which vests in, the Authority under sub-section (1) shall be deemed to include all`
  line `assets, rights, powers, authorities and privileges and all property movable and immovable, real or`
  line `personal, corporeal or incorporeal, present or contingent, of whatever nature and wheresoever situate,`
  line `including lands, buildings, machinery, equipments, works, workshops, cash balances, capital, reserves,`
  line `reserve funds, investments, tenancies, leases and book debts and all other rights and interests arising out`
  line `of such property as were immediately before the appointed day in the ownership, possession or power of`
  line `the International Airports Authority, or as the case may be, the National Airports Authority, in relation to`
  line `its undertaking, whether within or outside India, all books of account and documents relating thereto and`
  line `shall also be deemed to include all borrowings, liabilities and obligations of whatever kind then subsisting`
  line `of the International Airports Authority, or as the case may be, the National Airports Authority in relation`
  line `to its undertaking.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (16539)
  sectionNo (14)
  orderNo 15
  title `General effect of vesting of undertaking in the Authority.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16539&sectionno=14&orderno=15&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_14_content:
  string
  line `(1) All contracts, agreements and`
  line `working arrangements subsisting immediately before the appointed day and affecting the International`
  line `Airports Authority, or as the case may be, the National Airports Authority shall, in so far as they relate to`
  line `the International Airports Authority, or as the case may be, the National Airports Authority, cease to have`
  line `effect or be enforceable against the International Airports Authority, or as the case may be, the National`
  line `Airports Authority and shall be of as full force and effect against or in favour of the Authority in which`
  line `the undertakings have vested by virtue of this Act and enforceable as fully and effectually as if, instead of`
  line `the International Airports Authority, or as the case may be, the National Airports Authority, the Authority`
  line `had been named therein or had been a party thereto.`
  line
  line `(2) Any proceeding, suit or cause of action pending or existing immediately before the appointed day`
  line `by or against the International Airports Authority or the National Airports Authority in relation to its`
  line `undertakings may, as from that day, be continued and enforced by or against the Authority in which it has`
  line `vested by virtue of this Act, as it might have been enforced by or against the International Airports`
  line `Authority or the National Airports Authority if this Act had not been passed, and shall cease to be`
  line `enforceable by or against the International Airports Authority, or as the case may be, the National`
  line `Airports Authority.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (16540)
  sectionNo (15)
  orderNo 16
  title `Licences, etc., to be deemed to have been granted to the Authority.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16540&sectionno=15&orderno=16&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_15_content:
  string
  line `With effect from the`
  line `appointed day, all licences, permits, quotas and exemptions, granted to the International Airports`
  line `Authority or the National Airports Authority in connection with the affairs and business of the`
  line `International Airports Authority, or as the case may be, the National Airports Authority, under any law`
  line `for the time being in force, shall be deemed to have been granted to the Authority in which the`
  line `undertakings of the International Airports Authority and the National Airports Authority have vested by`
  line `virtue of this Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (16541)
  sectionNo (16)
  orderNo 17
  title `Tax exemption or benefit to continue to have effect.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16541&sectionno=16&orderno=17&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_16_content:
  string
  line `(1) Where any exemption from, or any`
  line `assessment with respect to, any tax has been granted or made or any benefit by way of set off or carry`
  line `forward, as the case may be, of any unabsorbed depreciation or investment allowance or other allowance or loss has been extended or is available to the International Airports Authority or the National Airports`
  line `Authority, under the Income-tax Act, 1961 (43 of 1961), such exemption, assessment or benefit shall`
  line `continue to have effect in relation to the Authority in which the undertakings of the International Airports`
  line `Authority and the National Airports Authority have vested by virtue of this Act.`
  line
  line `(2) Where any payment made by the International Airports Authority or the National Airports`
  line `Authority is exempt from deduction of the tax at source under any provision of the Income-tax Act, 1961`
  line `(43 of 1961), the exemption from tax will continue to be available as if the provisions of the said Act`
  line `made applicable to the International Airports Authority or the National Airports Authority were operative`
  line `in relation to the Authority in which the undertakings of the International Airports Authority and the`
  line `National Airports Authority have vested by virtue of this Act.`
  line
  line `(3) The transfer and vesting of the undertakings or any part thereof in terms of section 13 shall not be`
  line `construed as a transfer within the meaning of the Income-tax Act, 1961 (43 of 1961) for the purposes of`
  line `capital gains.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (16542)
  sectionNo (17)
  orderNo 18
  title `Guarantee to be operative.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16542&sectionno=17&orderno=18&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_17_content:
  string
  line `Any guarantee given for or in favour of the International Airports`
  line `Authority or the National Airports Authority with respect to any loan or lease finance shall continue to be`
  line `operative in relation to the Authority in which the undertakings of the International Airports Authority`
  line `and the National Airports Authority have vested by virtue of this Act.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (16543)
  sectionNo (18)
  orderNo 19
  title `Provisions in respect of officers and other employees of the International Airports Authority and the National Airports Authority.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16543&sectionno=18&orderno=19&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_18_content:
  string
  line `(1) (a) Every officer or other employee of the International`
  line `Airports Authority serving in its employment immediately before the appointed day shall, in so far as`
  line `such officer or other employee is employed in connection with the undertaking which has vested in the`
  line `Authority by virtue of this Act, becomes, as from the appointed day, an officer or, as the case may be,`
  line `other employee of the International Airports Division of the Authority.`
  line
  line `(b) Every officer or other employee of the National Airports Authority serving in its employment`
  line `immediately before the appointed day shall, in so far as such officer or other employee is employed in`
  line `connection with the undertaking which has vested in the Authority by virtue of this Act, becomes, as from`
  line `the appointed day, an officer or, as the case may be, other employee of the National Airports Division of`
  line `the Authority.`
  line
  line `(2) Every officer or other employee of the International Airports Authority or the National Airports`
  line `Authority who becomes an officer or, as the case may be, other employee of the Authority, as referred to`
  line `in sub-section (1), shall hold his office or service therein by the same tenure, at the same remuneration,`
  line `upon the same terms and conditions, with the same obligations and with the same rights and privileges as`
  line `to leave, passage, insurance, superannuation scheme, provident fund, other funds, retirement, pension,`
  line `gratuity and other benefits as he would have held under the International Airports Authority or, as the`
  line `case may be, the National Airports Authority if its undertaking had not vested in the Authority and shall`
  line `continue to do so as an officer or other employee, as the case may be, of the Authority or until the expiry`
  line `of a period of one year from the appointed day if such officer or other employee opts not to be the officer`
  line `or other employee of the Authority within such period:`
  line
  line `Provided that if the Authority thinks it expedient to extend the period so fixed, it may extend the same`
  line `up to a maximum period of one year.`
  line
  line `(3) Where an officer or other employee of the International Airports Authority or the National`
  line `Airports Authority opts under sub-section (2) not to be in the employment or service of the Authority in`
  line `which the undertakings of the International Airports Authority and the National Airports Authority have`
  line `vested, such officer or other employee shall be deemed to have resigned from the respective cadre.`
  line
  line `(4) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947) or in any`
  line `other law for the time being in force, the transfer of the services of any officer or other employee of the`
  line `International Airports Authority or the National Airports Authority to the Authority shall not entitle such`
  line `officer or other employee to any compensation under this Act or under any other law for the time being in`
  line `force and no such claim shall be entertained by any court, tribunal or other authority.`
  line
  line `(5) The officers and other employees who have retired before the appointed day from the service of`
  line `the International Airports Authority or the National Airports Authority and are entitled to any benefits, rights or privileges shall be entitled to receive the same benefits, rights or privileges from the Authority in`
  line `which the undertakings of the International Airports Authority and the National Airports Authority have`
  line vested.
  line
  line `(6) The trusts of the Provident Fund and Group Insurance and Superannuation Scheme of the`
  line `International Airports Authority or the National Airports Authority and any other bodies created for the`
  line `welfare of officers or employees would continue to discharge their functions in the Authority as was`
  line `being done hitherto in the International Airports Authority or the National Airports Authority and tax`
  line `exemption granted to Provident Fund or Group Insurance and Superannuation Scheme would continue to`
  line `be applied to the Authority.`
  line
  line `(7) After the expiry of the period of one year, or the extended period, as referred to in`
  line `sub-section (2), all the officers and other employees transferred and appointed to the Authority, other than`
  line `those opting not to be the officers or employees of the Authority within such period, shall be governed by`
  line `the rules and regulations made by the Authority in respect of the service conditions of the officers and`
  line `other employees of the said Authority.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (16544)
  sectionNo (19)
  orderNo 20
  title `Compulsory acquisition of land for the Authority.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16544&sectionno=19&orderno=20&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_19_content:
  string
  line `Any land required by the Authority for the`
  line `discharge of its functions under this Act shall be deemed to be needed for a public purpose and such land`
  line `may be acquired for the Authority under the provisions of the Land Acquisition Act, 1894 (1 of 1894) or`
  line `of any other corresponding law for the time being in force.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (16545)
  sectionNo (20)
  orderNo 21
  title `Contracts by the Authority.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16545&sectionno=20&orderno=21&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_20_content:
  string
  line `Subject to the provisions of section 21, the Authority shall be`
  line `competent to enter into and perform any contract necessary for the discharge of its functions under this`
  line Act.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (16546)
  sectionNo (21)
  orderNo 22
  title `Mode of executing contracts on behalf of the Authority.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16546&sectionno=21&orderno=22&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_21_content:
  string
  line `(1) Every contract shall, on behalf of`
  line `the Authority, be made by the Chairperson or such other member or such officer of the Authority as may`
  line `be generally or specially empowered in this behalf by the Authority and such contracts or class of`
  line `contracts as may be specified in the regulations shall be sealed with the common seal of the Authority:`
  line
  line `Provided that no contract exceeding such value or amount as the Central Government may, from time`
  line `to time, by order, fix in this behalf shall be made unless it has been previously approved by the Authority:`
  line
  line `Provided further that no contract for the acquisition or sale of immovable property or for the lease of`
  line `any such property for a term exceeding thirty years and no other contract exceeding such value or amount`
  line `as the Central Government may, from time to time, by order, fix in this behalf shall be made unless it has`
  line `been previously approved by the Central Government.`
  line
  line `(2) Subject to the provisions of sub-section (1), the form and manner in which any contract shall be`
  line `made under this Act shall be such as may be specified by regulations.`
  line
  line `(3) No contract which is not in accordance with the provisions of this Act and the regulations shall be`
  line `binding on the Authority.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (16547)
  sectionNo (22)
  orderNo 23
  title `Power of the Authority to charge, fees, rent, etc.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16547&sectionno=22&orderno=23&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_22_content:
  string
  line `The Authority may,--`
  line
  line `(i) with the previous approval of the Central Government, charge fees or rent--`
  line
  line `(a) for the landing, housing or parking of aircraft or for any other service or facility offered in`
  line `connection with aircraft operations at any airport, heliport or airstrip.`
  line
  line `Explanation.--In this sub-clause "aircraft" does not include an aircraft belonging to any`
  line `armed force of the Union and "aircraft operations" does not include operations of any aircraft`
  line `belonging to the said force;`
  line
  line `(b) for providing air traffic services, ground safety services, aeronautical communications and`
  line `navigational aids and meteorological services at any airport and at any aeronautical`
  line `communication station;`
  line
  line `(c) for the amenities given to the passengers and visitors at any airport, civil enclave, heliport`
  line `or airstrip;`
  line
  line `(d) for the use and employment by persons of facilities and other services provided by the`
  line `Authority at any airport, civil enclave, heliport or airstrip;`
  line
  line `(ii) with due regard to the instructions that the Central Government may give to the Authority,`
  line `from time to time, charge fees or rent from persons who are given by the Authority any facility for`
  line `carrying on any trade or business at any airport, heliport or airstrip.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_22_a:
  sectionId (16548)
  sectionNo 22A
  orderNo 24
  title `Power of Authority to levy development fees at airports.`
  content obj_root_law_sections_22_a_content
  footnotes obj_root_law_sections_22_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16548&sectionno=22A&orderno=24&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_22_a_content:
  string
  line `^1[22A. Power of Authority to levy development fees at airports.--^2[The Authority may,--`
  line
  line `(i) after the previous approval of the Central Government in this behalf, levy on, and collect`
  line `from, the embarking passengers at an airport other than major airports referred to in clause (h) of`
  line `section 2 of the Airports Economic Regulatory Authority of India Act, 2008 (27 of 2008) the`
  line `development fees at the rate as may be prescribed;`
  line
  line `(ii) levy, on, and collect from, the embarking passengers at major airport referred to in clause (h)`
  line `of section 2 of the Airports Economic Regulatory Authority of India Act, 2008 (27 of 2008) the`
  line `development fees at the rate as may be determined under clause (b) of sub-section (1) of`
  line `section 13 of the Airports Economic Regulatory Authority of India Act, 2008,`
  line
  line `and such fees shall be credited to the Authority and shall be regulated and utilised in the prescribed`
  line `manner, for the purposes of--]`
  line
  line `(a) funding or financing the costs of upgradation, expansion or development of the airport at`
  line `which the fee is collected; or`
  line
  line `(b) establishment or development of a new airport in lieu of the airport referred to in`
  line `clause (a); or`
  line
  line `(c) investment in the equity in respect of shares to be subscribed by the Authority in companies`
  line `engaged in establishing, owning, developing, operating or maintaining a private airport in lieu of the`
  line `airport referred to in clause (a) or advancement of loans to such companies or other persons engaged`
  line `in such activities.]`
obj_root_law_sections_22_a_footnotes:
  string
  line `1. Ins. by Act of 43 of 2003, s.7 (w.e.f. 1-7-2004).`
  line
  line `2. Subs. by Act of 27 of 2008, s. 54 and the Schedule, for certain words (w.e.f. 30-11-2008).`
obj_root_law_sections_23:
  sectionId (16549)
  sectionNo (23)
  orderNo 25
  title `Additional capital and grant to the Authority by the Central Government.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16549&sectionno=23&orderno=25&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_23_content:
  string
  line `The Central`
  line `Government may, after due appropriation made by Parliament, by law in this behalf,--`
  line
  line `(a) provide any capital that may be required by the Authority for the discharge of its functions`
  line `under this Act or for any purpose connected therewith on such terms and conditions as that`
  line `Government may determine;`
  line
  line `(b) pay to the Authority, on such terms and conditions as the Central Government may determine,`
  line `by way of loans or grants such sums of money as that Government may consider necessary for the`
  line `efficient discharge by the Authority of its functions under this Act.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (16550)
  sectionNo (24)
  orderNo 26
  title `Fund of the Authority and its investment.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16550&sectionno=24&orderno=26&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_24_content:
  string
  line `(1) The Authority shall have its own fund and all`
  line `receipts of the Authority shall be credited thereto and all payments of the Authority shall be made`
  line therefrom.
  line
  line `(2) The Authority shall have power, subject to the provisions of this Act, to spend such sums as it`
  line `thinks fit to cover all administrative expenses of the Authority and on objects or for purposes authorised`
  line `by this Act and such sums shall be treated as expenditure out of the fund of the Authority.`
  line
  line `(3) All moneys standing at the credit of the Authority which cannot immediately be applied as`
  line `provided in sub-section (2), shall be--`
  line
  line `(a) deposited in the State Bank of India or any such Scheduled bank or banks or other public`
  line `financial institutions subject to such conditions as may, from time to time, be specified by the Central`
  line `Government; and`
  line
  line `(b) invested in the securities of the Central Government or in such manner as may be prescribed.`
  line
  line `Explanation-- In this sub-section, "Scheduled bank" has the same meaning as in clause (e) of`
  line `section of the Reserve Bank of India Act, 1934 (2 of 1934).`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (16551)
  sectionNo (25)
  orderNo 27
  title `Allocation of surplus funds.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16551&sectionno=25&orderno=27&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_25_content:
  string
  line `(1) The Authority may, from time to time, set apart such amounts`
  line `as it thinks fit as a reserve fund or funds for the purpose of expanding existing facilities or services or`
  line `creating new facilities or services at any airport, civil enclave, heliport or airstrip or for the purpose of`
  line `providing against any temporary decrease of revenue or increase of expenditure from transient causes or`
  line `for purposes of replacement or for meeting expenditure arising from loss or damage from fire, cyclone,`
  line `air-crash or other accident or for meeting any liability arising out of any act or commission in the`
  line `discharge of its functions under this Act:`
  line
  line `Provided that without prejudice to the right of the Authority to establish specific reserves for one or`
  line `more specific purposes, the Authority shall also have the power to establish a general reserve:`
  line
  line `Provided further that the sums set apart annually in respect of each or any of the specific and general`
  line `reserves and the aggregate at any time of such sums shall not exceed such limits as may, from time to`
  line `time, be fixed in that behalf by the Central Government.`
  line
  line `(2) After making provision for such reserve fund or funds and for bad and doubtful debts,`
  line `depreciation in assets and all other matters which are usually provided for by companies registered and`
  line `incorporated under the Companies Act, 1956 (1 of 1956) the Authority shall pay the balance of its annual`
  line `net profits to the Central Government.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (16552)
  sectionNo (26)
  orderNo 28
  title `Submission of programme of activities and financial estimates.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16552&sectionno=26&orderno=28&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_26_content:
  string
  line `(1) The Authority shall,`
  line `before the commencement of each financial year, prepare a statement of the programme of its activities`
  line `during the forthcoming financial year as well as financial estimate in respect thereof.`
  line
  line `(2) The statement prepared under sub-section (1) shall, not less than three months before the`
  line `commencement of each financial year, be submitted for approval to the Central Government.`
  line
  line `(3) The statement and the financial estimates of the Authority may, with the approval of the Central`
  line `Government, be revised by the Authority.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (16553)
  sectionNo (27)
  orderNo 29
  title `Borrowing powers of the Authority.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16553&sectionno=27&orderno=29&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_27_content:
  string
  line `(1) The Authority may, with the consent of the Central`
  line `Government or in accordance with the terms of any general or special authority given to it by the Central`
  line `Government, borrow money from any source by the issue of bonds, debentures or such other instruments`
  line `as it may deem fit for discharging all or any of its functions under this Act.`
  line
  line `(2) The Central Government may guarantee in such manner as it thinks fit, the repayment of the`
  line `principal and the payment of interest thereon with respect to the loans borrowed by the Authority under`
  line `sub-section (1).`
  line
  line `(3) Subject to such limits as the Central Government may, from time to time, lay down, the Authority`
  line `may borrow temporarily by way of overdraft or otherwise such amounts as it may require for discharging`
  line `its functions under this Act.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (16554)
  sectionNo (28)
  orderNo 30
  title `Accounts and audit.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16554&sectionno=28&orderno=30&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_content:
  string
  line `(1) The Authority shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts including the profit and loss account and the`
  line `balance-sheet in such form as may be prescribed by the Central Government in consultation with the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Authority shall be audited annually by the Comptroller and Auditor-General`
  line `of India and any expenditure incurred by him in connection with such audit shall be payable by the`
  line `Authority to the Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Authority shall have the same rights and privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General has in connection with the audit of`
  line `Government accounts and, in particular, shall have the right to demand the production of books, accounts,`
  line `connected vouchers, documents and papers and inspect any of the offices of the Authority.`
  line
  line `(4) The accounts of the Authority as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before both`
  line `Houses of Parliament.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_28_a:
  sectionId (16555)
  sectionNo 28A
  orderNo 31
  title Definitions.
  content obj_root_law_sections_28_a_content
  footnotes obj_root_law_sections_28_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16555&sectionno=28A&orderno=31&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_a_content:
  string
  line `^1[28A. Definitions.--In this Chapter, unless the context otherwise requires,--`
  line
  line `(a) airport premises means any premises--`
  line
  line `(i) belonging to airport;`
  line
  line `(ii) taken on lease for the purposes of airport;`
  line
  line `(iii) acquired for the Authority under the provisions of the Land Acquisition Act,`
  line `1894 (1 of 1894) or any other corresponding law for the time being in force.`
  line
  line `Explanation.--For the removal of doubts, it is hereby declared that for the purposes of this clause,`
  line `airport includes private airport;`
  line
  line `(b) eviction officer means an officer of the Authority appointed as such by it under section 28B;`
  line
  line `(c) premises means any land or building or part of a building, and includes--`
  line
  line `(i) the garden, grounds and outhouses, if any, appertaining to such building or part of a`
  line `building; and`
  line
  line `(ii) any fittings affixed to such building or part of a building for more beneficial enjoyment`
  line thereof;
  line
  line `(d) rent, in relation to any airport premises, means the consideration payable periodically for`
  line `the authorised occupation of the premises, and includes--`
  line
  line `(i) any charge for electricity, water or any other service in connection with the occupation of`
  line `the premises; and`
  line
  line `(ii) any tax, by whatever name called, payable in respect of the premises;`
  line
  line ^2*****
  line
  line `(f) unauthorised occupation, in relation to any airport premises, means the occupation by any`
  line `person of the airport premises without authority for such occupation and includes the continuance in`
  line `occupation by any person of the airport premises after the authority (whether by way of grant or any`
  line `other mode of transfer) under which he was allowed to occupy the premises has expired or has been`
  line `determined for any reason whatsoever.]`
obj_root_law_sections_28_a_footnotes:
  string
  line `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  line
  line `2. Clause (e) omitted by Act 33 of 2021, s. 19 (w.e.f. 4-4-2021).`
obj_root_law_sections_28_b:
  sectionId (16556)
  sectionNo 28B
  orderNo 32
  title `Appointment of eviction officers.`
  content obj_root_law_sections_28_b_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16556&sectionno=28B&orderno=32&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_b_content:
  string
  line `^1[28B. Appointment of eviction officers.--The Authority may, by general or special order in writing,`
  line `appoint such number of its officers, as it thinks fit, to be eviction officers for the purposes of this Chapter,`
  line `and define the local limits within which, or the categories of airport premises in respect of which, the`
  line `eviction officers shall exercise the powers conferred and perform the duties imposed, on eviction officers`
  line `by or under this Chapter.]`
obj_root_law_sections_28_c:
  sectionId (16557)
  sectionNo 28C
  orderNo 33
  title `Issue of notice to show cause against order of eviction.`
  content obj_root_law_sections_28_c_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16557&sectionno=28C&orderno=33&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_c_content:
  string
  line `^1[28C. Issue of notice to show cause against order of eviction.--(1) If the eviction officer is of the`
  line `opinion that any persons are in unauthorised occupation of any airport premises and that they should be`
  line `evicted, the eviction officer shall, in the manner hereinafter provided, issue a notice in writing calling`
  line `upon all persons concerned to show cause why an order of eviction should not be made.`
  line
  line `(2) The notice shall--`
  line
  line `(a) specify the grounds on which the order of eviction is proposed to be made; and`
  line
  line `(b) require all persons concerned, that is to say, all persons who are or may be, in occupation of,`
  line `or claim interest in, the airport premises--`
  line
  line `(i) to show cause, if any, against the proposed order on or before such date as is specified in`
  line `the notice, being a date not earlier than seven days from the date of issue thereof, and`
  line
  line `(ii) to appear before the eviction officer on the date specified in the notice along with the`
  line `evidence which they intend to produce in support of the cause shown and also for personal`
  line `hearing, if such hearing is desired.`
  line
  line `(3) The eviction officer shall cause the notice to be served by having it affixed on the outer door or`
  line `some other conspicuous part of the airport premises and in such other manner as may be prescribed,`
  line `whereupon the notice shall be deemed to have been duly given to the persons concerned.`
  line
  line `(4) Where the eviction officer knows or has reasons to believe that any person is in occupation of the`
  line `airport premises, then, without prejudice to the provisions of sub-section (3), he shall cause a copy of the`
  line `notice to be served on every such person by post or by delivering or tendering it to that person or in such`
  line `other manner as may be prescribed.]`
obj_root_law_sections_28_d:
  sectionId (16558)
  sectionNo 28D
  orderNo 34
  title `Eviction of unauthorised occupants.`
  content obj_root_law_sections_28_d_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16558&sectionno=28D&orderno=34&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_d_content:
  string
  line `^1[28D. Eviction of unauthorised occupants.--(1) If, after considering the cause, if any, shown by any`
  line `person in pursuance of a notice under section 28C and any evidence produced by him in support of the`
  line `same and after personal hearing, if any, given under sub-clause (ii) of clause (b) of`
  line `sub-section (2) of section 28C, the eviction officer is satisfied that the airport premises are in unauthorised`
  line `occupation, the eviction officer may make an order of eviction, for reasons to be recorded therein,`
  line `directing that the airport premises shall be vacated, on such date as may be specified in the order, by the`
  line `persons who may be in occupation thereof, and cause a copy of the order to be affixed on the outer door`
  line `or some other conspicuous part of the airport premises.`
  line
  line `(2) If any person refuses or fails to comply with the order of eviction on or before the date specified`
  line `in the order or within fifteen days of the date of publication under sub-section (1), whichever is earlier,`
  line `the eviction officer or any other officer duly authorised by the eviction officer in this behalf may, after the`
  line `date so specified or after the expiry of the period aforesaid, whichever is earlier, evict that person from,`
  line `and take possession of, the airport premises and may, for that purpose, use such force as may be`
  line necessary.]
obj_root_law_sections_28_e:
  sectionId (16559)
  sectionNo 28E
  orderNo 35
  title `Disposal of property left on airport premises by unauthorised occupants.`
  content obj_root_law_sections_28_e_content
  footnotes obj_root_law_sections_28_e_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16559&sectionno=28E&orderno=35&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_e_content:
  string
  line `^1[28E. Disposal of property left on airport premises by unauthorised occupants.--(1) Where any`
  line `persons have been evicted from any airport premises under section 28D, the eviction officer may, after`
  line `giving ten days notice to the persons from whom possession of the airport premises has been taken and`
  line `after publishing the notice in at least one newspaper having circulation in the locality, remove or cause to`
  line `be removed or dispose of by public auction any property remaining on such premises.`
  line
  line `(2) Where any property is sold under sub-section (1), the sale proceeds thereof shall, after deducting`
  line `the expenses of the sale and the amount, if any, due to the Central Government or the corporate authority`
  line `on account of arrears of rent or damages or costs, be paid to such person or persons as may appear to the`
  line `eviction officer to be entitled to the same:`
  line
  line `Provided that where the eviction officer is unable to decide as to the person or persons to whom the`
  line `balance of the amount is payable or as to the apportionment of the same, he may refer such dispute to the`
  line `^2[Central Government] and the decision of the ^2[Central Government] thereon shall be final.]`
obj_root_law_sections_28_e_footnotes:
  string
  line `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  line
  line `2. Subs. by Act 33 of 2021, s. 19, for “Tribunal” (w.e.f. 4-4-2021).br`
obj_root_law_sections_28_f:
  sectionId (16560)
  sectionNo 28F
  orderNo 36
  title `Power to remove unauthorised constructions, etc.`
  content obj_root_law_sections_28_f_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16560&sectionno=28F&orderno=36&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_f_content:
  string
  line `^1[28F. Power to remove unauthorised constructions, etc.--(1) No person shall--`
  line
  line `(a) erect or place or raise any building or any movable or immovable structure or fixture;`
  line
  line `(b) display or spread any goods;`
  line
  line `(c) bring or keep any cattle or other animal,`
  line
  line `on or against or in front of any airport premises except in accordance with the authority (whether by way`
  line `of grant or any other mode of transfer) under which he was allowed to occupy such airport premises.`
  line
  line `(2) Where any building or other immovable structure or fixture has been erected, placed or raised in`
  line `any airport premises in contravention of the provisions of sub-section (1), the eviction officer may serve`
  line `on the person erecting such building or other structure or fixture, a notice requiring him either to remove or show cause why he shall not remove such building or other structure or fixture to or from the airport`
  line `premises within such period, not being less than seven days but not exceeding thirty days as may be`
  line `specified in the notice, and on the omission or refusal of such person to show cause, or to remove such`
  line `building or other structure or fixture from the airport premises, or where the cause shown is not, in the`
  line `opinion of the eviction officer, sufficient, the eviction officer may, by order, remove or cause to be`
  line `removed the building or other structure or fixture from the airport premises and the cost of such removal`
  line `shall be recoverable from such person as an arrear of land revenue.`
  line
  line `(3) Where any movable structure or fixture has been erected, placed or raised, or any goods have been`
  line `displayed or spread or any cattle or other animal has been brought or kept on any airport premises in`
  line `contravention of the provisions of sub-section (1) by any person, the eviction officer may, by order,`
  line `remove or cause to be removed without notice, such structure, fixture, goods, cattle or other animal, as the`
  line `case may be, from the airport premises and the cost of such removal shall be recoverable from such`
  line `person as an arrear of land revenue.]`
obj_root_law_sections_28_g:
  sectionId (16561)
  sectionNo 28G
  orderNo 37
  title `Power to require payment of rent or damages in respect of airport premises.`
  content obj_root_law_sections_28_g_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16561&sectionno=28G&orderno=37&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_g_content:
  string
  line `^1[28G. Power to require payment of rent or damages in respect of airport premises.--(1) Where`
  line `any person is in arrears of rent payable in respect of airport premises, the eviction officer may, by order,`
  line `require that person to pay the same within such time and in such instalments as may be specified in the`
  line order.
  line
  line `(2) Where any person is, or has at any time been, in unauthorised occupation of any airport premises,`
  line `the eviction officer may, having regard to such principles of assessment of damages as may be prescribed,`
  line `assess the damages on account of the use and occupation of such premises and may, by order, require that`
  line `person to pay the damages within such time and in such instalments as may be specified in the order.`
  line
  line `(3) While making an order under sub-section (1) or sub-section (2), the eviction officer may direct`
  line `that the arrears of rent or, as the case may be, damages shall be payable together with simple interest at`
  line `such rate as may be prescribed.`
  line
  line `(4) No order under sub-section (1) or sub-section (2) shall be made against any person until after the`
  line `issue of a notice in writing to the person calling upon him to show cause within such period not being less`
  line `than seven days but not exceeding thirty days as may be specified in the notice as to why such order`
  line `should not be made, and until his objections, if any, and any evidence he may produce in support of the`
  line `same have been considered by the eviction officer.]`
obj_root_law_sections_28_h:
  sectionId (16562)
  sectionNo 28H
  orderNo 38
  title `Powers of eviction officers.`
  content obj_root_law_sections_28_h_content
  footnotes `1. Ins. by Act of 43 of 2003, s. 8 (w.e.f. 1-7-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16562&sectionno=28H&orderno=38&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_h_content:
  string
  line `^1[28H. Powers of eviction officers.--An eviction officer shall, for the purpose of holding any inquiry`
  line `into this Chapter, have the same powers, as are vested in a civil court under the Code of Civil`
  line `Procedure, 1908 (5 of 1908), while trying a suit in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) any other matter which may be prescribed.]`
obj_root_law_sections_28_i:
  sectionId (16589)
  sectionNo 28-I
  orderNo 39
  title `Establishment of Tribunal.`
  content obj_root_law_sections_28_i_content
  footnotes obj_root_law_sections_28_i_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00003_199455_1517807323698&sectionId=16589&sectionno=28-I&orderno=39&orgactid=AC_CEN_36_56_00003_199455_1517807323698
obj_root_law_sections_28_i_content:
  string
  line `Omitted by The Tribunals Reforms Act, 2021 (33 of 2021), s. 19`
  line `(w.e.f. 4-4-2021)`
obj_root_law_sections_28_i_footnotes:
