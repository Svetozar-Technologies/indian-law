obj_root_law:
  object
  (str slug) (str the-airports-authority-of-india-act-1994)
  (str handle) (str 1979)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Airports Authority of India Act, 1994`)
  (str actNumber) (str 55)
  (str enactmentDate) (str 1994-09-12)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1979`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भारतीय विमानपत्तनप्राधिकरण अधिनियम, 1994`)
  (str actYear) (str 1994)
  (str ministry) (str `Ministry of Civil Aviation`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the constitution of the Airports Authority of India and for the transfer and vesting of the undertakings of the International Airports Authority of India and the National Airports Authority to and in the Airports Authority of India so constituted for the better administration and cohesive management of airports and civil enclaves whereat air transport services are operated or are intended to be operated and of all aeronautical communication stations for the purposes of establishing or assisting in the establishment of airports and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-04-1995)
  (str notification) (str `1st April, 1995, vide notification No. S.O. 285(E), dated 30th March, 1995, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T18:11:23.571Z`)
  (str translations) obj_root_law_translations
