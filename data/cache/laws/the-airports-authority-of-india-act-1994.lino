  line
obj_root_law_sections_28_j:
  sectionId (16590)
  sectionNo 28J
  orderNo 40
  title `Resignation and removal.`
  content `Omitted by ibid., s. 19 (w.e.f. 4-4-2021).`
  footnotes obj_root_law_sections_28_j_footnotes
