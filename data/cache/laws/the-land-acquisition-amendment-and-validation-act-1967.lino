obj_root_law_sections_4:
  sectionId (72614)
  sectionNo (4)
  orderNo 4
  title `Validation of certain acquisitions.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_43_00007_196713_1673602452661&sectionId=72614&sectionno=4&orderno=4&orgactid=AC_CEN_18_43_00007_196713_1673602452661
obj_root_law_sections_4_content:
  string
  line `(1) Notwithstanding any judgment, decree or order of any`
  line `court to the contrary, —`
  line
  line `(a) no acquisition of land made or purporting to have been made under the principal Act before the`
  line `commencement of the Land Acquisition (Amendment and Validation) Ordinance, 1967 (1 of 1967),`
  line `and no action taken or thing done (including any order made, agreement entered into, or notification`
  line `published) in connection with such acquisition shall be deemed to be invalid or ever to have become`
  line `invalid merely on the ground—`
  line
  line `(i) that one or more Collectors have performed the functions of Collector under the principal`
  line `Act in respect of the land covered by the same notification under sub-section (1) of section 4 of the`
  line `principal Act;`
  line
  line `(ii) that one or more reports have been made under sub-section (2) of section 5A of the principal`
  line `Act, whether in respect of the entire land, or different parcels thereof, covered by the same`
  line `notification under sub-section (1) of section 4 of the principal Act;`
  line
  line `(iii) that one or more declarations have been made under section 6 of the principal Act in respect`
  line `of different parcels of the land covered by the same notification under sub-section (1) of section 4`
  line `of the principal Act;`
  line
  line `(b) any acquisition in pursuance of any notification published under sub-section (1) of section 4 of`
  line `the principal Act before the commencement of the Land Acquisition (Amendment and Validation)`
  line `Ordinance, 1967 (1 of 1967), may be made after such commencement and no such acquisition and no`
  line `action taken or thing done (including any order made, agreement entered into, or notification`
  line `published), whether before or after such commencement, in connection with such acquisition shall be`
  line `deemed to be invalid merely on the ground referred to in clause (a) or any of them.`
  line
  line `(2) Notwithstanding anything contained in clause (b) of sub-section (1), no declaration under section`
  line `6 of the principal Act in respect of any land which has been notified before the commencement of the Land`
  line `Acquisition (Amendment and Validation) Ordinance, 1967 (1 of 1967), under sub-section (1) of section 4`
  line `of the principal Act, shall be made after the expiry of two years from the commencement of the said`
  line Ordinance.
  line
  line `(3) Where acquisition of any particular land covered by a notification under sub-section (1) of section`
  line `4 of the principal Act, published before the commencement of the Land Acquisition (Amendment and`
  line `Validation) Ordinance, 1967 (1 of 1967), is or has been made in pursuance of any declaration under section`
  line `6 of the principal Act, whether made before or after such commencement, and such declaration is or has`
  line `been made after the expiry of three years from the date of publication of such notification, there shall be`
  line `paid simple interest, calculated at the rate of six per centum per annum on the market value of such land,`
  line `as determined under section 23 of the principal Act, from the date of expiry of the said period of three years`
  line `to the date of tender of payment of compensation awarded by the Collector for the acquisition of such land:`
  line
  line `Provided that no such interest shall be payable for any period during which the proceedings for the`
  line `acquisition of any land were help up on account of stay or injunction by order of a court:`
  line
  line `Provided further that nothing in this sub-section shall apply to the acquisition of any land where the`
  line `amount of compensation has been paid to the persons interested before the commencement of this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (72615)
  sectionNo (5)
  orderNo 5
  title `Repeal and saving.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_43_00007_196713_1673602452661&sectionId=72615&sectionno=5&orderno=5&orgactid=AC_CEN_18_43_00007_196713_1673602452661
obj_root_law_sections_5_content:
  string
  line `(1) The Land Acquisition (Amendment and Validation) Ordinance, 1967`
  line `(1 of 1967), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the principal Act as amended`
  line `by the said Ordinance shall be deemed to have been done or taken under the principal Act as amended by`
  line `this Act as if this Act had come into force on the 20th day of January, 1967.`
obj_root_law_sections_5_footnotes:
  string
  line
