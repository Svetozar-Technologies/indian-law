obj_root_law_translations_hi:
  title `सरकारी स्‍थान (अप्राधिकृत अधिभोगियों की बेदखली)अधिनियम,1971`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1609/2/h1971-40.pdf`
