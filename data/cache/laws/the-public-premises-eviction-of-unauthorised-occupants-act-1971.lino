obj_root_law_sections_1:
  sectionId (16042)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16042&sectionno=1&orderno=1&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Public Premises`
  line `(Eviction of Unauthorised Occupants) Act, 1971.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall be deemed to have come into force on the 16th day of September, 1958 except sections 11,`
  line `19 and 20 which shall come into force at once.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (16043)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16043&sectionno=2&orderno=2&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line ^1
  line `* * * * *`
  line
  line `(b) "estate officer" means an officer appointed as such by the Central Government under`
  line `section 3;`
  line
  line `(c) "premises" means any land or any building or part of a building and includes,--`
  line
  line `(i) the garden, grounds and outhouses, if any, appertaining to such building or part of a`
  line `building, and`
  line
  line `(ii) any fittings affixed to such building or part of a building for the more beneficial`
  line `enjoyment thereof;`
  line
  line `(d) "prescribed" means prescribed by rules made under this Act;`
  line
  line ^2
  line `[(e) "public premises" means--`
  line
  line `(1) any premises belonging to, or taken on lease or requisitioned by, or on behalf of the`
  line `Central Government, and includes any such premises which have been placed by that`
  line `Government, whether before or after the commencement of the Public Premises (Eviction of`
  line `Unauthorised Occupants) Amendment Act, 1980 (61 of 1980) under the control of the Secretariat`
  line `of either Houseof Parliament for providing residential accommodation to any member of the staff`
  line `of that Secretariat;`
  line
  line `(2) any premises belonging to, or taken on lease by, or on behalf of,--`
  line
  line `(i) any company as defined in section 3of the ^3`
  line `[the Companies Act, 2013 (18 of 2013)], in`
  line `which not less than fifty-one per cent. of the paid-up share capital is held by the Central`
  line `Government or any company which is a subsidiary (within the meaning of that Act) of the`
  line `first-mentioned company;`
  line
  line `(ii) any corporation (not being a company as defined in section 3 of the ^3`
  line `[the Companies`
  line `Act, 2013 (18 of 2013)], or a local authority) established by or under a Central Act and`
  line `owned or controlled by the Central Government;`
  line
  line ^4
  line `[(iii) any company as defined in clause (20) of section 2 of the Companies Act, 2013`
  line `(18 of 2013) in which not less than fifty-one per cent. of the paid up capital is held partly by`
  line `the Central Government and partly by one or more State Governments and includes a`
  line
  line `company which is a subsidiary (within the meaning of that Act) of the first-mentioned`
  line `company and which carries on the business of public transport including metro railway.`
  line
  line `Explanation.--For the purposes of this item, "metro railway" shall have the same`
  line `meaning as assigned to it in clause (i) of sub-section (1) of section 2 of the Metro`
  line `Railway (Operation and Maintenance) Act, 2002 (60 of 2002);`
  line
  line `(iiia) any University established or incorporated by any Central Act,];`
  line
  line `(iv) any Institute incorporated by the Institutes of Technology Act, 1961 (59 of`
  line `1961);`
  line
  line ^5
  line `[(v) any Board of Trustees or any successor company constituted under or referred to`
  line `in the Major Port Trusts Act, 1963 (38 of 1963);]`
  line
  line `(vi) the Bhakra Management Board constituted under section 79 of the Punjab`
  line `Reorganisation Act, 1966 (31 of 1966), and that Board as and when re-named as the`
  line `Bhakra-Beas Management Board under sub-section(6) of section 80 of that Act,`
  line ^6
  line ***.
  line
  line ^7
  line `[(vii) any State Government or the Government of any Union territory situated in the`
  line `National Capital Territory of Delhi or in any other Union territory,`
  line
  line `(viii) any Cantonment Board constituted under the Cantonments Act, 1924 (2 of`
  line `1924); and]`
  line
  line `(3) in relation to the^8`
  line `[National Capital Territory of Delhi],--`
  line
  line `(i) any premises belonging to the^9`
  line `[Council as defined in clause (9) of section 2 of the`
  line `New Delhi Municipal Council Act, 1994 (44 of 1994) or Corporation or Corporations`
  line `notified under sub-section (1) of section 3 of the Delhi Municipal Corporation Act, 1957 (66`
  line `of 1957),] of Delhi, or any Municipal Committee or notified area committee, ^6`
  line ***
  line
  line `(ii) any premises belonging to the Delhi Development Authority, whether such premises`
  line `are in the possession of, or leased out by, the said Authority;]^10`
  line [and],
  line
  line ^11
  line `[(iii) any premises belonging to, or taken on lease or requisitioned by, or onbehalf of any`
  line `any State Government or the Government of any Union Territory,]`
  line
  line ^12
  line `[(iv) any premises belonging to, or taken on lease by, or on behalf of any Government`
  line `company as defined in clause (45) of section 2 of the Companies Act, 2013 (18 of 2013).`
  line
  line `Explanation.--For the purposes of this clause, the expression "State Government"`
  line `occurring in clause (45) of the said section shall mean the Government of the National`
  line `Capital Territory of Delhi;]`
  line
  line `^13[(4) any premises of the enemy property as defined in clause (c) of section 2 of the`
  line `Enemy Property Act, 1968 (34 of 1968).]`
  line
  line `(f) "rent", in relation to any public premises, means the consideration payable periodically for the`
  line `authorised occupation of the premises, and includes--`
  line
  line `(i) any charge for electricity, water or any other services in connection with the occupation of`
  line `the premises,`
  line
  line `(ii) any tax (by whatever name called) payable in respect of the premises,`
  line
  line `where such charge or tax is payable by the Central Government or the ^14`
  line `[statutory authority];`
  line
  line `^15[(fa) residential accommodation occupation" in relation to any public premises means occupation by any`
  line `person on grant of licence to him to occupy such premises on the basis of an order of allotment for a fixed`
  line `tenure or for a period he holds office, in accordance with the rules and instructions issued in this regard, made`
  line `under the authority of the Central Government, a State Government, a Union territory Administration or a`
  line `statutory authority, as the case may be;]`
  line
  line `^16[^17[(fb)] "statutory authority", in relation to the public premises referred to in clause (e) of this`
  line `section, means,--`
  line
  line `(i) in respect of the public premises placed under the control of the Secretariat of either House`
  line `of Parliament, the Secretariat of the concerned House of Parliament,`
  line
  line `(ii) in respect of the public premises referred to in item (i) of sub-clause (2)`
  line `^18[and in item (iv)`
  line `of sub-clause (3)] of that clause, the company or the subsidiary company, as the case may be,`
  line `referred to therein,`
  line
  line `(iii) in respect of the public premises referred to in item (ii) of sub-clause (2) of that clause,`
  line `the corporation referred to therein,`
  line
  line `(iv) in respect of the public premises referred to, respectively, in items (iii), (iv), (v) and (vi)`
  line `of sub-clause (2)of that clause, the University, Institute or Board, as the case may be, referred to`
  line `therein, and`
  line
  line `(v) in respect of the public premises referred to in sub-clause (3) of that clause, the ^17[Council,`
  line `Corporation or Corporations], Committee or Authority, as the case may be, referred to in that`
  line sub-clause;]
  line
  line `^19[^20[(fc)] "temporary occupation" in relation to any public premises, means occupation by any person`
  line `person on the basis of an order of allotment made under the authority of the Central Government, a`
  line `State Government, the Government of a Union territory or a statutory authority for a total period`
  line `(including the extended period, if any) which is less than thirty days;]`
  line
  line `(g) "unauthorised occupation", in relation to any public premises, means the occupation by any`
  line `person of the public premises without authority for such occupation, and includes the continuance in`
  line `occupation by any person of the public premises after the authority (whether by way of grant or any`
  line `other mode of transfer) under which he was allowed to occupy the premises has expired or has been`
  line `determined for any reason whatsoever.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Clause (a) omitted by Act 61 of 1980, s. 2 (w.e.f. 20-12-1980).`
  line
  line `2. Subs. by s. 2, ibid., for clause (e) (w.e.f. 20-12-1980).`
  line
  line `3. Subs. by Act 2 of 2015, s. 2, for "the Companies Act, 1956 (1 of 1956)" (w.e.f. 22-6-2015).`
  line
  line `4. Subs. by s. 2, ibid., for item (iii) (w.e.f. 22-6-2015).`
  line
  line `5. Subs. by Act 2 of 2015, s. 2, for item (v) (w.e.f. 22-6-2015).`
  line
  line `6. The word "and" omitted by Act 7 of 1994, s. 2 (w.e.f. 1-6-1994).`
  line
  line `7. Ins. by s. 2, ibid. (w.e.f. 1-6-1994).`
  line
  line `8. Subs. by s. 2, ibid., for "Union territory of Delhi" (w.e.f. 1-6-1994).`
  line
  line `9. Subs. by Act 2 of 2015, s. 2, for "Municipal Corporation" (w.e.f. 22-6-2015).`
  line
  line `10. The word "and" added by Act 7 of 1994, s. 2 (w.e.f. 1-6-1994).`
  line
  line `11. Ins. by s. 2, ibid. (w.e.f. 1-6-1994).`
  line
  line `12. Ins. by Act 2 of 2015, s. 2 (w.e.f. 22-6-2015).`
  line
  line `13. Ins. by Act 3 of 2017, s. 20 (w.e.f. 7-1-2016).`
  line
  line `14. Subs. by Act 61 of 1980, s. 2, for "corporate authority" (w.e.f. 20-12-1980).`
  line
  line `15. Ins. by Act 36 of 2019, s. 2 (w.e.f. 15-9-2019).`
  line
  line `16. Ins. by Act 2 of 2015, s. 2 (w.e.f. 22-6-2015).`
  line
  line `17. Clause (fa) renumbered as clause (fb) by Act 36 of 2019, s. 2 (w.e.f. 15-9-2019).`
  line
  line `18 Subs. by s. 2, ibid., for "Corporation" (w.e.f. 22-6-2015).`
  line
  line `19. Ins. by Act 7 of 1994, s. 2 (w.e.f. 1-6-1994).`
  line
  line `20. Clause (fb) renumbered as clause (fc) by Act 36 of 2019, s. 2 (w.e.f. 15-9-2019).`
obj_root_law_sections_3:
  sectionId (16044)
  sectionNo (3)
  orderNo 3
  title `Appointment of estate officers.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16044&sectionno=3&orderno=3&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_3_content:
  string
  line `The Central Government may, by notification in the Official`
  line Gazette,-
  line
  line `(a) appoint such persons, being gazetted officers of Government ^1[or of the Government of any Union`
  line `Territory] or officers of equivalent rank of the ^2[statutory authority], as it thinks fit, to be estate officers for`
  line `the purposes of this Act; ^3***`
  line
  line `^4[Provided that no officer of the Secretariat of the Rajya Sabha shall be so appointed except after`
  line `consultation with the Chairman of the Rajya Sabha and no officer of the Secretariat of the Lok Sabha shall`
  line `be so appointed except after consultation with the Speaker of the Lok Sabha:`
  line
  line `Provided further that an officer of a statutory authority shall only be appointed as an estate officer in`
  line `respect of the public premises controlled by that authority; ^5***]`
  line
  line `^6[Provided also that the Custodian, Deputy Custodian and Assistant Custodian of the enemy property`
  line `appointed under section 3 of the Enemy Property Act, 1968 (34 of 1968), shall be deemed to have been`
  line `appointed as the Estate Officer in respect of those enemy property, being the public premises, referred to in`
  line `sub-clause (4) of clause (e) of section 2 of this Act for which they had been appointed as the Custodian,`
  line `Deputy Custodian and Assistant Custodian under section 3 of the Enemy Property Act, 1968.]`
  line
  line `(b) define the local limits within which, or the categories of public premises in respect of which, the`
  line `estate officers shall exercise the powers conferred, and perform the duties imposed, on estate officers by or`
  line `under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Ins. by Act 7 of 1994, s. 3 (1-6-1994).`
  line
  line `2. Subs. by Act 61 of 1980, s. 2, for “corporate authority” (w.e.f. 20-12-1980).`
  line
  line `3. The word “and” omitted by s. 3,ibid. (w.e.f. 20-12-1980).`
  line
  line `4. Provisos added by s. 3, ibid. (w.e.f. 20-12-1980).`
  line
  line `5. The word “and” omitted by Act 3 of 2017, s. 20 (w.e.f. 7-1-2016).`
  line
  line `6. Ins. by s. 20,ibid. (w.e.f. 7-1-2016).`
obj_root_law_sections_3_a:
  sectionId (16045)
  sectionNo 3A
  orderNo 4
  title `Eviction from temporary occupation.`
  content obj_root_law_sections_3_a_content
  footnotes `1. Ins. by Act 7 of 1994, s. 4 (w.e.f. 1-6-1994).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16045&sectionno=3A&orderno=4&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_3_a_content:
  string
  line ^1
  line `[3A. Eviction from temporary occupation.--Notwithstanding anything contained in section 4 or`
  line `section 5, if the estate officer, after making such inquiry as he deems expedient in the circumstances of`
  line `the case, is satisfied that any persons who were allowed temporary occupation of any public premises are`
  line `in unauthorised occupation of the said premises, he may, for reasons to be recorded in writing, make an order for the eviction of such persons forthwith and, thereupon, if such persons refuse or fail to comply`
  line `with the said order of eviction, he may evict them from the premises and take possession thereof and may,`
  line `for that purpose, use such force as may be necessary.]`
obj_root_law_sections_3_b:
  sectionId (49589)
  sectionNo 3B
  orderNo 5
  title `Eviction from residential accommodation`
  content obj_root_law_sections_3_b_content
  footnotes `1. Ins. by Act 36 of 2019, s. 3 (w.e.f. 15-9-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=49589&sectionno=3B&orderno=5&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_3_b_content:
  string
  line `^1[3B. Eviction from residential accommodation.-- (1) Notwithstanding anything contained in`
  line `section 4 or section 5, if the estate officer has information that any person, who was granted residential`
  line `accommodation occupation, is in unauthorised occupation of the said residential accommodation, he`
  line shall--
  line
  line `(a) forthwith issue notice in writing calling upon such person to show cause within a period of`
  line `three working days why an order of eviction should not be made;`
  line
  line `(b) cause the notice to be served by having it affixed on the outer door or some other conspicuous`
  line `part of the said residential accommodation, and in such other manner as may be prescribed,`
  line `whereupon the notice shall be deemed to have been served upon such person.`
  line
  line `(2) The estate officer shall, after considering the cause, if any, shown by the person on whom the`
  line `notice is served under sub-section (1) and after making such inquiry as it deems expedient in the`
  line `circumstances of the case, for reasons to be recorded in writing, make an order of eviction of such person.`
  line
  line `(3) If the person in unauthorised occupation refuses or fails to comply with the order of eviction`
  line `referred to in sub-section (2), the estate officer may evict such person from the residential accommodation`
  line `and take possession thereof and may, for that purpose, use such force as may be necessary.]`
obj_root_law_sections_4:
  sectionId (16046)
  sectionNo (4)
  orderNo 6
  title `Issue of notice to show cause against order of eviction.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16046&sectionno=4&orderno=6&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_4_content:
  string
  line ^1
  line `[(1) If the estate officer has`
  line `information that any person is in unauthorised occupation of any public premises and that he should be`
  line `evicted, the estate officer shall issue in the manner hereinafter provided a notice in writing within seven`
  line `working days from the date of receipt of the information regarding the unauthorised occupation calling`
  line `upon the person concerned to show cause why an order of eviction should not be made.`
  line
  line `(1A) If the estate officer knows or has reasons to believe that any person is in unauthorised occupation`
  line `of the public premises, then, without prejudice to the provisions of sub-section (1), he shall forthwith`
  line `issue a notice in writing calling upon the person concerned to show cause why an order of eviction should`
  line `not be made.`
  line
  line `(1B) Any delay in issuing a notice referred to in sub-sections (1) and (1A) shall not vitiate the`
  line `proceedings under this Act.]`
  line
  line `(2) The notice shall--`
  line
  line `(a) specify the grounds on which the order of eviction is proposed to be made; and`
  line
  line ^2
  line `[(b) require all persons concerned, that is to say, all persons who are, or may be, in occupation`
  line `of, or claim interest in, the public premises,--`
  line
  line `(i) to show cause, if any, against the proposed order on or before such date as is specified in`
  line `the notice, being a date not ^3`
  line `[later than] seven days from the date of issue thereof, and`
  line
  line `(ii) to appear before the estate officer on the date specified in the notice along with the`
  line `evidence which they intend to produce in support of the cause shown, and also for personal`
  line `hearing, if such hearing is desired.]`
  line
  line `(3) The estate officer shall cause the notice to be served by having it affixed on the outer door or`
  line `some other conspicuous part of the public premises, and in such other manner as may be prescribed,`
  line `whereupon the notice shall be deemed to have been duly given to all persons concerned.`
  line
  line ^4
  line `* * * * *`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 2 of 2015, s. 3, for sub-section (1) (w.e.f. 22-6-215).`
  line
  line `2. Subs. by Act 61 of 1980, s. 4, for clause (b) (w.e.f. 20-12-1980).`
  line
  line `3. Subs. by Act 2 of 2015, s. 3, for "earlier than" (w.e.f. 22-6-2015).`
  line
  line `4. Sub-section (4) omitted by Act 7 of 1994, s. 5 (w.e.f. 1-6-1994).`
obj_root_law_sections_5:
  sectionId (16047)
  sectionNo (5)
  orderNo 7
  title `Eviction of unauthorised occupants.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16047&sectionno=5&orderno=7&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_5_content:
  string
  line ^1
  line `[(1) If, after considering the cause, if any, shown by any`
  line `person in pursuance of a notice under section 4 and any evidence produced by him in support of the same`
  line `and after personal hearing, if any, given under sub-clause (ii) of clause (b) of sub-section (2) of section 4,`
  line `the estate officer is satisfied that the public premises are in unauthorised occupation, the estate officer`
  line `shall make an order of eviction, for reasons to be recorded therein, directing that the public premises shall`
  line `be vacated, on such date as may be specified in the order but not later than fifteen days from the date of`
  line `the order, by all persons who may be in occupation thereof or any part thereof, and cause a copy of the`
  line `order to be affixed on the outer door or some other conspicuous part of the public premises:`
  line
  line `Provided that every order under this sub-section shall be made by the estate officer as expeditiously`
  line `as possible and all endeavour shall be made by him to issue the order within fifteen days of the date`
  line `specified in the notice under sub-section (1) or sub-section (1A), as the case may be, of section 4.]`
  line
  line `(2) If any person refuses or fails to comply with the order of eviction ^2`
  line `[on or before the date specified`
  line `in the said order or within fifteen days of the date of its publication under sub-section(1), whichever is`
  line `later,] the estate officer or any other officer duly authorised by the estate officer in this behalf ^3`
  line `[may after`
  line `the date so specified or after the expiry of the period aforesaid, whichever is later, evict that person]`
  line
  line `from, and take possession of, the public premises and may, for that purpose, use such force as may be`
  line necessary.
  line
  line ^4
  line `[Provided that if the estate officer is satisfied, for reasons to be recorded in writing, that there exists`
  line `any compelling reason which prevents the person from vacating the premises within fifteen days, the`
  line `estate officer may grant another fifteen days from the date of expiry of the order under sub-section (1) to`
  line `the person to vacate the premises.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 2 of 2015, s. 4, for sub-section (1) (w.e.f. 22-6-2015).`
  line
  line `2. Subs. by Act 61 of 1980, s. 5, for certain words (w.e.f. 20-12-1980).`
  line
  line `3. Subs. by s. 5, ibid., for "may evict that person" (w.e.f. 20-12-1980).`
  line
  line `4. Ins. by Act 2 of 2015, s. 4 (w.e.f. 22-6-2015).`
obj_root_law_sections_5_a:
  sectionId (16048)
  sectionNo 5A
  orderNo 8
  title `Power to remove unauthorised constructions, etc.`
  content obj_root_law_sections_5_a_content
  footnotes obj_root_law_sections_5_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16048&sectionno=5A&orderno=8&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_5_a_content:
  string
  line ^1
  line `[5A. power to remove unauthorised constructions, etc.--(1) No person shall--`
  line
  line `(a) erect or place or raise any building or^2`
  line `[any movable or immovable structure or fixture]`
  line
  line `(b) display or spread any goods,`
  line
  line `(c) bring or keep any cattle or other animal,`
  line
  line `on, or against, or in front of, any public premises except in accordance with the authority (whether by`
  line `way of grant or any other mode of transfer) under which he was allowed to occupy such premises.`
  line
  line ^3
  line `[(2) Where any building or other immovable structure or fixture has been erected, placed or raised on`
  line `on any public premises in contravention of the provisions of sub-section (1), the estate officer may serve`
  line `upon the person erecting such building or other structure or fixture, a notice requiring him either to`
  line `remove, or to show cause why he shall not remove such building or other structure or fixture from the`
  line `public premises within such period, not being less than seven days, as he may specify in the notice; and`
  line `on the omission or refusal of such person either to show cause, or to remove such building or other`
  line `structure or fixture from the public premises, or where the cause shown is not, in the opinion of the estate`
  line `officer, sufficient, the estate officer may, by order, remove or cause to be removed the building or other`
  line `structure or fixture from the public premises and recover the cost of such removal from the person`
  line `aforesaid as an arrear of land revenue.`
  line
  line `(3) Where any movable structure or fixture has been erected, placed or raised, or any goods have been`
  line `displayed or spread, or any cattle or other animal has been brought or kept, on any public premises, in`
  line `contravention of the provisions of sub-section (1) by any person, the estate officer may, by order, remove`
  line `or cause to be removed without notice, such structure, fixture, goods, cattle or other animal, as the case`
  line `may be, from the public premises and recover the cost of such removal from such person as an arrear of`
  line `land revenue.]`
obj_root_law_sections_5_a_footnotes:
  string
  line `1. Ins. by Act 61 of 1980, s. 6 (w.e.f. 20-12-1980).`
  line
  line `2. Subs. by Act 35 of 1984, s. 2, for "other structure or fixture" (w.e.f. 13-11-1984).`
  line
  line `3. Subs. by s. 2, ibid., for sub-section (2) (w.e.f. 13-11-1984).`
obj_root_law_sections_5_b:
  sectionId (16049)
  sectionNo 5B
  orderNo 9
  title `Order of demolition of unauthorised construction.`
  content obj_root_law_sections_5_b_content
  footnotes obj_root_law_sections_5_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16049&sectionno=5B&orderno=9&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_5_b_content:
  string
  line `^1[5B. Order of demolition of unauthorised construction.--(1) Where the erection of any building or`
  line `execution of any work has been commenced, or is being carried on, or has been completed, on any public`
  line `premises by any person in occupation of such public premises under an authority (whether by way of`
  line `grant or any other mode of transfer), and such erection of building or execution of work is in`
  line `contravention of, or not authorised by,such authority, then, the estate officer may, in addition to any other`
  line `action that may be taken under this Act or in accordance with the terms of the authority aforesaid, make`
  line `an order, for reasons to be recorded therein, directing that such erection or work shall be demolished by`
  line `the person at whose instance the erection or work has been commenced, or is being carried on, or has`
  line `been completed, within such period, as may be specified in the order ^2`
  line ***.
  line
  line `Provided that no order under this sub-section shall be made unless the person concerned has been`
  line `given, by means of a notice ^3`
  line `[of not less than seven days] served in the prescribed manner, a reasonable`
  line `opportunity of showing cause why such order should not be made.`
  line
  line `(2) Where the erection or work has not been completed, the estate officer may, by the same order or`
  line `by a separate order, whether made at the time of the issue of the notice under the proviso to`
  line `sub-section (1) or at any other time, direct the person at whose instance the erection or work has been commenced, or is being carried on, to stop the erection or work until the expiry of the period within`
  line `which an appeal against the order of demolition, if made, may be preferred under section 9.`
  line
  line `(3) The estate officer shall cause every order made under sub-section (1), or, as the case may be,`
  line `under sub-section (2), to be affixed on the outer door, or some other conspicuous part, of the public`
  line premises.
  line
  line `(4) Where no appeal has been preferred against the order of demolition made by the estate officer`
  line `under sub-section (1) or where an order of demolition made by the estate officer under that sub-section`
  line `has been confirmed on appeal, whether with or without variation, the person against whom the order has`
  line `been made shall comply with the order within the period specified therein, or, as the case may be, within`
  line `the period, if any, fixed by the appellate officer on appeal, and, on the failure of the person to comply with`
  line `the order within such period, the estate officer or any other officer duly authorised by the estate officer in`
  line `this behalf, may cause the erection or work to which the order relates to be demolished.`
  line
  line `(5) Where an erection or work has been demolished, the estate officer may, by order, require the`
  line `person concerned to pay the expenses of such demolition within such time, and in such number of`
  line `instalments, as may be specified in the order.]`
obj_root_law_sections_5_b_footnotes:
  string
  line `1. Ins. by Act 61 of 1980, s. 6 (w.e.f. 20-12-1980).`
  line
  line `2.Certain words, brackets and figure omitted by s. 3, ibid. (w.e.f. 13-11-1984).`
  line
  line `3. Ins. by s. 3, ibid. (w.e.f. 13-11-1984).`
obj_root_law_sections_5_c:
  sectionId (16050)
  sectionNo 5C
  orderNo 10
  title `Power to seal unauthorised constructions.`
  content obj_root_law_sections_5_c_content
  footnotes `1. Ins. by Act 35 of 1984, s. 4 (w.e.f. 13-11-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16050&sectionno=5C&orderno=10&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_5_c_content:
  string
  line `^1[5C. Power to seal unauthorised constructions.--(1) It shall be lawful for the estate officer, at any`
  line `time, before or after making an order of demolition under section 5B, to make an order directing the`
  line `sealing of such erection or work or of the public premises in which such erection or work has been`
  line `commenced or is being carried on or has been completed in such manner as may be prescribed, for the`
  line `purpose of carrying out the provisions of this Act, or for preventing any dispute as to the nature and extent`
  line `of such erection or work.`
  line
  line `(2) Where any erection or work or any premises in which any erection or work is being carried on`
  line `has, or have been sealed, the estate officer may, for the purpose of demolishing such erection or work in`
  line `accordance with the provisions of this Act, order such seal to be removed.`
  line
  line `(3) No person shall remove such seal except--`
  line
  line `(a) under an order made by the estate officer under sub-section (2); or`
  line
  line `(b) under an order of the appellate officer made in an appeal under this Act.]`
obj_root_law_sections_6:
  sectionId (16051)
  sectionNo (6)
  orderNo 11
  title `Disposal of property left on public premises by unauthorised occupants.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16051&sectionno=6&orderno=11&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_6_content:
  string
  line `(1) Where any`
  line `persons have been evicted from any public premises under section 5 ^1`
  line `[or where any building or other`
  line `work has been demolished under section 5B], the estate officer may, after giving fourteen days notice to`
  line `the persons from whom possession of the public premises has been taken and after publishing the notice`
  line `in at least one newspaper having circulation in the locality, remove or cause to be removed or dispose of`
  line `by public auction any property remaining on such premises.`
  line
  line ^1
  line `[(1A) Where any goods, materials, cattle or other animal have been removed from any public`
  line `premises under section 5A, the estate officer may, after giving fourteen days' notice to the persons owning`
  line `such goods, materials, cattle or other animal and after publishing the notice in at least one newspaper`
  line `having circulation in the locality, dispose of, by public auction, such goods, materials, cattle or other`
  line animal.
  line
  line `(1B) Notwithstanding anything contained in sub-section (1) and (1A), the giving or publication of any`
  line `notice referred to therein shall not be necessary in respect of any property which is subject to speedy and`
  line `natural decay, and the estate officer may, after recording such evidence as he may think fit, cause such`
  line `property to be sold or otherwise disposed of in such manner as he may think fit.]`
  line
  line `(2) Where any property is sold under sub-section (1), the sale proceeds thereof shall, after deducting`
  line `the expenses of the sale and the amount, if any, due to the Central Government or the ^2`
  line `[statutory authority] on account of arrears of rent or damages or costs, be paid to such person or persons as may`
  line `appear to the estate officer to be entitled to the same:`
  line
  line `Provided that where the estate officer is unable to decide as to the person or persons to whom the`
  line `balance of the amount is payable or as to the apportionment of the same, he may refer such dispute to the`
  line `civil court of competent jurisdiction and the decision of the court thereon shall be final.`
  line
  line ^1
  line `[(2A) The expression "costs", referred to in sub-section (2), shall include the cost of removal`
  line `recoverable under section 5A and the cost of demolition recoverable under section 5B.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Ins. by Act 61 of 1980, s. 7 (w.e.f. 20-12-1980).`
  line
  line `2. Subs. by s. 2, bid., for "corporate authority" (w.e.f. 20-12-1980).`
obj_root_law_sections_7:
  sectionId (16052)
  sectionNo (7)
  orderNo 12
  title `Power to require payment of rent or damages in respect of public premises.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16052&sectionno=7&orderno=12&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_7_content:
  string
  line `(1) Where any`
  line `person is in arrears of rent payable in respect of any public premises, the estate officer may, by order,`
  line `require that person to pay the same within such time and in such instalments as may be specified in the`
  line order.
  line
  line `(2) Where any person is, or has at any time been, in unauthorised occupation of any public premises,`
  line `the estate officer may, having regard to such principles of assessment of damages as may be prescribed,`
  line `assess the damages on account of the use and occupation of such premises and may, by order, require that`
  line `person to pay the damages within such time and in such instalments as may be specified in the order.`
  line
  line ^1
  line `[(2A) While making an order under sub-section (1) or sub-section (2), the estate officer may direct`
  line `that the arrears of rent or, as the case may be, damages shall be payable together with ^2`
  line [compound
  line `interest] at such rate as may be prescribed, not being a rate exceeding the current rate of interest within`
  line `the meaning of the Interest Act, 1978 (14 of 1978).]`
  line
  line `(3) No order under sub-section (1) or sub-section (2) shall be made against any person until after the`
  line `issue of a notice in writing to the person calling upon him to show cause ^3`
  line `[within seven days from the`
  line `date of issue thereof], why such order should not be made, and until his objections, if any, and any`
  line `evidence he may produce in support of the same, have been considered by the estate officer.`
  line
  line `^4[(3A) If the person in unauthorised occupation of residential accommodation challenges the eviction`
  line `order passed by the estate officer under sub-section (2) of section 3B in any court, he shall pay damages`
  line `for every month for the residential accommodation held by him.]`
  line
  line `^5[(4) Every order under this section shall be made by the estate officer as expeditiously as possible`
  line `and all endeavour shall be made by him to issue the order within fifteen days of the date specified in the`
  line notice.]
obj_root_law_sections_7_footnotes:
  string
  line `1. Ins. by s. 8, ibid. (w.e.f. 20-12-1980).`
  line
  line `2. Subs. by Act 2 of 2015, s. 5, for "simple interest" (w.e.f. 22-6-2015).`
  line
  line `3. Subs. by s. 5, ibid., for certain words (w.e.f. 22-6-2015).`
  line
  line `4. Ins. by Act 36 of 2019, s. 4 (w.e.f. 15-9-2019).`
  line
  line `5. Ins. by Act 2 of 2015, s. 5 (w.e.f. 22-6-2015).`
obj_root_law_sections_8:
  sectionId (16053)
  sectionNo (8)
  orderNo 13
  title `Powers of estate officers.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16053&sectionno=8&orderno=13&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_8_content:
  string
  line `An estate officer shall, for the purpose of holding any inquiry under`
  line `this Act, have the same powers as are vested in a civil court under the Code of Civil Procedure, 1908`
  line `(5 of 1908) when trying a suit in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) any other matter which may be prescribed.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (16054)
  sectionNo (9)
  orderNo 14
  title Appeals.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16054&sectionno=9&orderno=14&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_9_content:
  string
  line `(1) An appeal shall lie from every order of the estate officer made in respect of any`
  line `public premises under ^1[section 5 or section 5B] ^2`
  line `[or section 5C] or section 7 to an appellate officer who`
  line `shall be the district judge of the district in which the public premises are situate or such other judicial`
  line `officer in that district of not less than ten years standing as the district judge may designate in this behalf.`
  line
  line `(2) An appeal under sub-section (1) shall be preferred,--`
  line
  line `(a) in the case of an appeal from an order under section 5, ^3`
  line `[within twelve days] from the date of`
  line `publication of the order under sub-section (1) of that section; ^4***`
  line
  line `(b) in the case of an appeal from an order ^5[under section 5B or section 7, within twelve days]`
  line `from the date on which the order is communicated to the appellant; ^6[and]`
  line
  line `^2[(c) in the case of an appeal from an order under section 5C, within twelve days from the date of`
  line `such order:]`
  line
  line `^7[Provided that the appellate officer may entertain the appeal in exceptional cases after the expiry`
  line `of thesaid period,if he is satisfied for reasons to be recorded in writing that there was compelling`
  line `reasons which prevented the person from filing the appeal in time.]`
  line
  line `(3) Where an appeal is preferred from an order of the estate officer, the appellate officer may stay`
  line `the enforcement of that order for such period and on such conditions as he deems fit:`
  line
  line `^8[Provided that where the construction or erection of any building or other structure or fixture or`
  line `execution of any other work was not completed on the day on which an order was made under section 5B`
  line `for the demolition or removal of such building or other structure or fixture, the appellate officer shall not`
  line `make any order for the stay of enforcement of such order, unless such security, as may be sufficient in the`
  line `opinion of the appellate officer, has been given by the appellant for not proceeding with such`
  line `construction, erection or work pending the disposal of the appeal.]`
  line
  line `^9[(4) Every appeal under this section shall be disposed of by the appellate officer as expeditiously as`
  line `possible and every endeavour shall be made to dispose of the appeal finally within one month from the`
  line `date of filing the appeal, after providing the parties an opportunity of being heard.]`
  line
  line `(5) The costs of any appeal under this section shall be in the discretion of the appellate officer.`
  line
  line `(6) For the purposes of this section, a presidency-town shall be deemed to be a district and the chief`
  line `judge or the principal judge of the city civil court therein shall be deemed to be the district judge of the`
  line district.
obj_root_law_sections_9_footnotes:
  string
  line `1. Subs. by Act 61 of 1980, s. 9, for "section 5" (w.e.f. 20-12-1980).`
  line
  line `2. Ins. by Act 35 of 1984, s. 5 (w.e.f. 13-11-1984).`
  line
  line `3. Subs. by Act 61 of 1980, s. 9, for "within fifteen days" (w.e.f. 20-12-1980).`
  line
  line `4. The word "and" omitted by Act 35 of 1984, s. 5 (w.e.f. 13-11-1984).`
  line
  line `5. Subs. by Act 61 of 1980, s. 9, for "under section 7, within fifteen days" (w.e.f. 20-12-1980).`
  line
  line `6 Ins. by Act 35 of 1984, s. 5 (w.e.f. 13-11-1984).`
  line
  line `7. Ins. by Act 2 of 2015, s. 6 (w.e.f. 22-6-2015).`
  line
  line `8 The proviso added by Act 61 of 1980, s. 9 (w.e.f. 20-12-1980).`
  line
  line `9. Subs. by Act 2 of 2015, s. 6, for sub-section (4) (w.e.f. 22-6-2015).`
obj_root_law_sections_10:
  sectionId (16055)
  sectionNo (10)
  orderNo 15
  title `Finality of orders.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16055&sectionno=10&orderno=15&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_10_content:
  string
  line `Save as otherwise expressly provided in this Act, every order made by an`
  line `estate officer or appellate officer under this Act shall be final and shall not be called in question in any`
  line `original suit, application or execution proceeding and no injunction shall be granted by any court or other`
  line `authority in respect of any action taken or to be taken in pursuance of any power conferred by or under`
  line `this Act.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (16056)
  sectionNo (11)
  orderNo 16
  title `Offences and penalty.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16056&sectionno=11&orderno=16&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_11_content:
  string
  line ^1
  line `[(1) If any person unlawfully occupies any public premises, he shall be`
  line `punishable with simple imprisonment for a term which may extend to six months, or with fine which may`
  line `extend to five thousand rupees, or with both:`
  line
  line `Provided that a person who, having been lawfully in occupation of any public premises by virtue of`
  line `any authority (whether by way of grant, allotment or by any other mode whatsoever) continues to be in`
  line `occupation of such premises after such authority has ceased to be valid, shall not be guilty of such`
  line offence.]
  line
  line ^2
  line `[(2)] If any person who has been evicted from any public premises under this Act again occupies the`
  line `premises without authority for such occupation, he shall be punishable with imprisonment for a term`
  line `which may extend to one year, or with fine which may extend to ^3`
  line `[five thousand rupees], or with both.`
  line
  line ^2
  line `[(3)] Any magistrate convicting a person under ^4`
  line `[sub-section (2)] may make an order for evicting that`
  line `that person summarily and he shall be liable to such eviction without prejudice to any other action that`
  line `may be taken against him under this Act.`
obj_root_law_sections_11_footnotes:
  string
  line `1. Ins. by Act 35 of 1984, s. 6 (w.e.f. 13-11-1984).`
  line
  line `2. Sub-sections (1) and (2) renumbered as sub-sections (2) and (3) thereof by s.6, ibid. (w.e.f. 13-11-1984).`
  line
  line `3. Subs. by s. 6, ibid., for "one thousand rupees" (w.e.f. 13-11-1984).`
  line
  line `4. Subs. by s. 6, ibid., for "sub-section (1)" (w.e.f. 13-11-1984).`
obj_root_law_sections_11_a:
  sectionId (16057)
  sectionNo 11A
  orderNo 17
  title `Offences under section 11 to be cognizable.`
  content obj_root_law_sections_11_a_content
  footnotes `1. Ins. by Act 35 of 1984, s. 7 (w.e.f. 13-11-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16057&sectionno=11A&orderno=17&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_11_a_content:
  string
  line `^1[11A. Offences under section 11 to be cognizable.-- The Code of Criminal Procedure, 1973`
  line `(2 of 1974), shall apply to an offence under section 11 as if it were a cognizable offence--`
  line
  line `(i) for the purposes of investigation of such offence, and`
  line
  line `(ii) for the purposes of matters, other than--`
  line
  line `(1) matters referred to in section 42 of that Code, and`
  line
  line `(2) arrest of a person except on the complaint of, or upon information received`
  line from,--
  line
  line `(a) a Group A officer as may be appointed by the Central Government, in the case of an`
  line `offence in relation to the public premises specified in sub-clause (1) of clause (e) of section 2;`
  line
  line `(b) an officer equivalent to the rank of a Group A officer of the Central Government or`
  line `where it is not possible to specify an officer of such equivalent rank, such executive officer as`
  line `may be appointed by the statutory authority in the case of an offence in relation to the public`
  line `premises specified in sub-clause (2) of clause (e) of section 2;`
  line
  line `(c) such Deputy Commissioner, in the case of an offence in relation to the public`
  line `premises belonging to the Municipal Corporation of Delhi, as may be appointed by the`
  line `Administrator of the Union territory of Delhi;`
  line
  line `(d) the Secretary, New Delhi Municipal Committee, in the case of an offence in relation`
  line `to the public premises belonging to the New Delhi Municipal Committee;`
  line
  line `(e) the Secretary of a notified area committee, in the case of an offence in relation to the`
  line `public premises belonging to that committee;`
  line
  line `(f) such Director, in the case of an offence in relation to the public premises belonging to`
  line `the Delhi Development Authority, as may be appointed by the Administrator of the Union`
  line `territory of Delhi.]`
obj_root_law_sections_12:
  sectionId (16058)
  sectionNo (12)
  orderNo 18
  title `Power to obtain information.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16058&sectionno=12&orderno=18&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_12_content:
  string
  line `If the estate officer has reason to believe that any persons are in`
  line `unauthorised occupation of any public premises, the estate officer or any other officer authorised by him`
  line `in this behalf may require those persons or any other person to furnish information relating to the names`
  line `and other particulars of the persons in occupation of the public premises and every person so required`
  line `shall be bound to furnish the information in his possession.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (16059)
  sectionNo (13)
  orderNo 19
  title `Liability of heirs and legal representatives.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16059&sectionno=13&orderno=19&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_13_content:
  string
  line `(1) Where any person against whom any`
  line `proceeding for the determination of arrears of rent or for the assessment of damages ^1`
  line `[or for the`
  line `determination of the amount payable by way of interest on such arrears of rent or damages] is to be or has`
  line `been taken dies before the proceeding is taken or during the pendency thereof, the proceeding may be`
  line `taken or, as the case may be, continued against the heirs or legal representatives of that person.`
  line
  line ^1
  line `[(1A) Where any person from whom any cost of removal of any building or other structure or fixture,`
  line `or, as the case may be,any goods, cattle or other animal is to be recovered under sub-section (2) ^2`
  line `[or subsection`
  line `(3)] of section 5A, or any expenses of demolition are to be recovered under sub-section (5) of`
  line `section 5B, dies before any proceeding is taken for the recovery of such cost or during the pendency`
  line `thereof, the proceeding may be taken or, as the case may be, continued against the heirs or legal`
  line `representatives of that person.]`
  line
  line `(2) Any amount due to the Central Government or the ^3`
  line `[statutory authority] from any person whether`
  line `by way of arrears of ^4`
  line `[rent or damages or costs of removal referred to in section 5A or expenses of demolition referred to in section 5B or interest referred to in sub- section (2A) of section 7 or any other`
  line `cost] shall, after the death of the person, be payable by his heirs or legal representatives but their liability`
  line `shall be limited to the extent of the assets of the deceased in their hands.`
obj_root_law_sections_13_footnotes:
  string
  line `1. Ins. by Act 61 of 1980, s. 10 (w.e.f. 20-12-1980).`
  line
  line `2. Ins. by Act 35 of 1984, s. 8 (w.e.f. 13-11-1984).`
  line
  line `3. Subs. by Act 61 of 1980, s. 2, for "corporate authority" (w.e.f. 20-12-1980).`
  line
  line `4. Subs. by s. 10, "ibid"., for "rent or damages or costs" (w.e.f. 20-12-1980).`
obj_root_law_sections_14:
  sectionId (16060)
  sectionNo (14)
  orderNo 20
  title `Recovery of rent, etc., as an arrear of land revenue.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16060&sectionno=14&orderno=20&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_14_content:
  string
  line `If any person refuses or fails to pay ^1`
  line [the
  line `expenses of demolition payable under sub-section (5) of section 5B or] the arrears of rent payable under`
  line `sub-section (1) of section 7 or the damages payable under sub-section (2) ^1`
  line `[or the interest determined`
  line `under sub-section (2A)] of that section or the costs awarded to the Central Government or the`
  line ^2
  line `[statutory authority] under sub-section (5) of section 9 or any ^3`
  line `[portion of such rent, damages, expenses,`
  line `interest] or costs, within the time, if any, specified therefor in the order relating thereto, the estate officer`
  line `may issue a certificate for the amount due to the Collector who shall proceed to recover the same as an`
  line `arrear of land revenue.`
obj_root_law_sections_14_footnotes:
  string
  line `1. Ins. by Act 61 of 1980, s. 11 (w.e.f. 20-12-1980).`
  line
  line `2. Subs. by s. 2, ibid., for "corporate authority" (w.e.f. 20-12-1980).`
  line
  line `3. Subs. by s. 11, ibid., for "portion of such rent, damages" (w.e.f. 20-12-1980).`
obj_root_law_sections_15:
  sectionId (16061)
  sectionNo (15)
  orderNo 21
  title `Bar of jurisdiction.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16061&sectionno=15&orderno=21&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_15_content:
  string
  line ^1
  line `[15. Bar of jurisdiction.--No court shall have jurisdiction to entertain any suit or proceeding in`
  line `respect of--`
  line
  line `(a) the eviction of any person who is in unauthorised occupation of any public premises, or`
  line
  line `(b) the removal of any building, structure or fixture or goods, cattle or other animal from any`
  line `public premises under section 5A, or`
  line
  line `(c) the demolition of any building or other structure made, or ordered to be made, under section`
  line `5B, or`
  line
  line ^60
  line `[(cc) the sealing of any erection or work or of any public premises under section 5C, or]`
  line
  line `(d) the arrears of rent payable under sub-section (1) of section 7 or damages payable under`
  line `sub-section (2), or interest payable under sub-section (2A), of that section, or`
  line
  line `(e) the recovery of--`
  line
  line `(i) costs of removal of any building, structure or fixture or goods, cattle or other animal under`
  line `section 5A, or`
  line
  line `(ii) expenses of demolition under section 5B, or`
  line
  line `(iii) costs awarded to the Central Government or statutory authority under sub-section (5) of`
  line `section 9, or`
  line
  line `(iv) any portion of such rent, damages, costs of removal, expenses of demolition or costs`
  line `awarded to the Central Government or the statutory authority.]`
obj_root_law_sections_15_footnotes:
  string
  line `1. Subs. by s. 12, ibid., for section 15 (w.e.f. 20-12-1980).`
  line
  line `2. Ins. by Act 35 of 1984, s. 9 (w.e.f. 13-11-1984).`
obj_root_law_sections_16:
  sectionId (16062)
  sectionNo (16)
  orderNo 22
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_16_content
  footnotes `1. Subs. by Act 61 of 1980, s. 2, for "corporate authority" (w.e.f. 20-121980).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16062&sectionno=16&orderno=22&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_16_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government or the ^1`
  line `[statutory authority] or the appellate officer or the estate officer`
  line `in respect of anything which is in good faith done or intended to be done in pursuance of this Act or of`
  line `any rules or orders made thereunder.`
obj_root_law_sections_17:
  sectionId (16063)
  sectionNo (17)
  orderNo 23
  title `Delegation of powers.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16063&sectionno=17&orderno=23&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_17_content:
  string
  line `The Central Government may, by notification in the Official Gazette,`
  line `direct that any power exercisable by it under this Act shall, subject to such conditions if any, as may be`
  line `specified in the notification be exercisable also by a State Government or an officer of the State`
  line `Government or an officer of the State Government.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (16064)
  sectionNo (18)
  orderNo 24
  title `Power to make rules.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16064&sectionno=18&orderno=24&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_18_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the form of any notice required or authorised to be given under this Act and the manner in`
  line `which it may be served;`
  line
  line `(b) the holding of inquiries under this Act;`
  line
  line `(c) the distribution and allocation of work to estate officers and the transfer of any proceeding`
  line `pending before an estate officer to another estate officer;`
  line
  line `(d) the procedure to be followed in taking possession of public premises;`
  line
  line `(e) the manner in which damages for unauthorised occupation may be assessed and the principles`
  line `which may be taken into account in assessing such damages;`
  line
  line ^1
  line `[(ee) the manner in which the sealing of any erection or work or of any public premises shall be`
  line `made under sub-section (1) of section 5C;]`
  line
  line ^2
  line `[(ea) the rate at which interest shall be payable on arrears of rent specified in any order made`
  line `under sub-section (1) of section 7, or damages assessed under sub-section (2) of that section;]`
  line
  line `(f) the manner in which appeals may be preferred and the procedure to be followed in appeals;`
  line
  line `(g) any other matter which has to be or may be prescribed.`
  line
  line `(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament while it is in session for a total period of thirty days which may be comprised in one`
  line `session or ^3`
  line `[in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid,] both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_18_footnotes:
  string
  line `1. Ins. by Act 35 of 1984, s. 10 (w.e.f. 13-11-1984).`
  line
  line `2. Ins. by Act 61 of 1980, s. 13 (w.e.f. 20-12-1980).`
  line
  line `3. Subs. by s. 13, ibid., for certain words (w.e.f. 20-12-1980).`
obj_root_law_sections_19:
  sectionId (16065)
  sectionNo (19)
  orderNo 25
  title Repeal.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16065&sectionno=19&orderno=25&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_19_content:
  string
  line `The Public Premises (Eviction of Unauthorised Occupants) Act, 1958 (32 of 1958), is`
  line `hereby repealed.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (16066)
  sectionNo (20)
  orderNo 26
  title Validation.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00004_197140_1517807320037&sectionId=16066&sectionno=20&orderno=26&orgactid=AC_CEN_17_19_00004_197140_1517807320037
obj_root_law_sections_20_content:
  string
  line `Notwithstanding any judgment, decree or order of any court, anything done or any`
  line `action taken (including rules or orders made, notices issued, evictions ordered or effected, damages`
  line `assessed, rents or damages or costs recovered and proceedings initiated) or purported to have been done`
  line `or taken under the public Premises (Eviction of Unauthorised Occupants) Act, 1958 (32 of 1958)`
  line `(hereafter in this section referred to as the 1958-Act) shall be deemed to be as valid and effective as if`
  line `such thing or action was done or taken under the corresponding provisions of this Act which, under`
  line `sub-section (3) of section 1 shall be deemed to have come into force on the 16th day of September, 1958,`
  line `and accordingly--`
  line
  line `(a) no suit or other legal proceeding shall be maintained or continued in any court for the refund`
  line `of any rent or damages or costs recovered under the 1958-Act where such refund has been claimed`
  line `merely on the ground that the said Act has been declared to be unconstitutional and void; and`
  line
  line `(b) no court shall enforce a decree or order directing the refund of any rent or damages or costs`
  line `recovered under the 1958-Act merely on the ground that the said Act has been declared to be`
  line `unconstitutional and void.`
obj_root_law_sections_20_footnotes:
  string
  line
