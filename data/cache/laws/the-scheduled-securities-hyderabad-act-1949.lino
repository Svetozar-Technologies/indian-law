obj_root_law_sections_1:
  object
  (str sectionId) (str 67726)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Scheduled Securities (Hyderabad) Act,1949.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67726&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00061_194907_1657709588894)
obj_root_law_sections_2:
  object
  (str sectionId) (str 67727)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act, --

(i) "Bank" means the Reserve Bank of India;

(ii) "scheduled security" means any Government security, specified in the Schedule to this Act, but
does not include any duplicate security issued under the provisions of section 4;

(iii) "transfer", in relation to a scheduled security, includes the transfer of any interest in the scheduled
security.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67727&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00061_194907_1657709588894)
obj_root_law_sections_3:
  object
  (str sectionId) (str 67728)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Title to scheduled security not affected by previous transfers.`)
  (str content) (str `The Bank shall not, without the
approval in writing of the Central Government, recognize for any purpose any transfer of a scheduled security
otherwise than to the Government of Hyderabad made or purported to have been made before the 31st day of
December, 1948, and notwithstanding any transfer so made or purported to have been so made and
notwithstanding anything contained in any law for the time being in force, the scheduled security shall be
deemed to be, and always to have been, vested in the Government of Hyderabad.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67728&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00061_194907_1657709588894)
obj_root_law_sections_4:
  object
  (str sectionId) (str 67729)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Issue of duplicate securities.`)
  (str content) (str `(1) Notwithstanding anything contained in any law for the time being
in force, the Bank shall issue to the Government of Hyderabad duplicate securities payable to that Government
in lieu of the scheduled securities as if such securities had been lost, and such duplicate securities shall have
the same effect as if they had been issued under section 11 of the Public Debt (Central Government) Act, 1944
(XVIII of 1944).

(2) On the issue of duplicate securities under sub-section (1), all rights of remedies vested in or enforceable
by any person in respect of the scheduled securities, in lieu of which such duplicate securities have been issued,
shall be deemed to be extinguished.

(3) The Bank shall impound all scheduled securities which are or have been presented to it and cancel the
same.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67729&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00061_194907_1657709588894)
obj_root_law_sections_5:
  object
  (str sectionId) (str 67730)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Bar of jurisdiction.`)
  (str content) (str `No suit or other legal proceeding for the enforcement of any rights or remedies
in respect of any scheduled security shall be instituted in any Court save with the previous consent of the
Central Government.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67730&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00061_194907_1657709588894)
obj_root_law_sections_6:
  object
  (str sectionId) (str 67731)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Protection of action taken in good faith.`)
  (str content) (str `No suit, prosecution or other legal proceeding shall lie
against the Central Government, the Bank or any person for anything done or intended to be done in good faith
in pursuance of the provisions of this Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67731&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00061_194907_1657709588894)
obj_root_law_sections_7:
  object
  (str sectionId) (str 67732)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Repeal of Ordinance XXXVII of 1948.`)
  (str content) (str `(1) The Scheduled Securities (Hyderabad) Ordinances,
1948 (XXXVII of 1948), is hereby repealed.

(2) Notwithstanding such repeal, anything done or any action taken in exercise of any power conferred
by or under the said Ordinance shall be deemed to have been done or taken in exercise of the powers conferred
by or under this Act, as if this Act had commenced on the 31st day of December,1948.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67732&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00061_194907_1657709588894)
