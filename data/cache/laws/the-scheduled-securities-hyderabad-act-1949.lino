obj_root_law_sections_1:
  sectionId (67726)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Scheduled Securities (Hyderabad) Act,1949.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67726&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00061_194907_1657709588894
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (67727)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67727&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00061_194907_1657709588894
obj_root_law_sections_2_content:
  string
  line `In this Act, --`
  line
  line `(i) "Bank" means the Reserve Bank of India;`
  line
  line `(ii) "scheduled security" means any Government security, specified in the Schedule to this Act, but`
  line `does not include any duplicate security issued under the provisions of section 4;`
  line
  line `(iii) "transfer", in relation to a scheduled security, includes the transfer of any interest in the scheduled`
  line security.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (67728)
  sectionNo (3)
  orderNo 3
  title `Title to scheduled security not affected by previous transfers.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67728&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00061_194907_1657709588894
obj_root_law_sections_3_content:
  string
  line `The Bank shall not, without the`
  line `approval in writing of the Central Government, recognize for any purpose any transfer of a scheduled security`
  line `otherwise than to the Government of Hyderabad made or purported to have been made before the 31st day of`
  line `December, 1948, and notwithstanding any transfer so made or purported to have been so made and`
  line `notwithstanding anything contained in any law for the time being in force, the scheduled security shall be`
  line `deemed to be, and always to have been, vested in the Government of Hyderabad.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (67729)
  sectionNo (4)
  orderNo 4
  title `Issue of duplicate securities.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67729&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00061_194907_1657709588894
obj_root_law_sections_4_content:
  string
  line `(1) Notwithstanding anything contained in any law for the time being`
  line `in force, the Bank shall issue to the Government of Hyderabad duplicate securities payable to that Government`
  line `in lieu of the scheduled securities as if such securities had been lost, and such duplicate securities shall have`
  line `the same effect as if they had been issued under section 11 of the Public Debt (Central Government) Act, 1944`
  line `(XVIII of 1944).`
  line
  line `(2) On the issue of duplicate securities under sub-section (1), all rights of remedies vested in or enforceable`
  line `by any person in respect of the scheduled securities, in lieu of which such duplicate securities have been issued,`
  line `shall be deemed to be extinguished.`
  line
  line `(3) The Bank shall impound all scheduled securities which are or have been presented to it and cancel the`
  line same.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (67730)
  sectionNo (5)
  orderNo 5
  title `Bar of jurisdiction.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67730&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00061_194907_1657709588894
obj_root_law_sections_5_content:
  string
  line `No suit or other legal proceeding for the enforcement of any rights or remedies`
  line `in respect of any scheduled security shall be instituted in any Court save with the previous consent of the`
  line `Central Government.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (67731)
  sectionNo (6)
  orderNo 6
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67731&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00061_194907_1657709588894
obj_root_law_sections_6_content:
  string
  line `No suit, prosecution or other legal proceeding shall lie`
  line `against the Central Government, the Bank or any person for anything done or intended to be done in good faith`
  line `in pursuance of the provisions of this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (67732)
  sectionNo (7)
  orderNo 7
  title `Repeal of Ordinance XXXVII of 1948.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00061_194907_1657709588894&sectionId=67732&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00061_194907_1657709588894
obj_root_law_sections_7_content:
  string
  line `(1) The Scheduled Securities (Hyderabad) Ordinances,`
  line `1948 (XXXVII of 1948), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken in exercise of any power conferred`
  line `by or under the said Ordinance shall be deemed to have been done or taken in exercise of the powers conferred`
  line `by or under this Act, as if this Act had commenced on the 31st day of December,1948.`
obj_root_law_sections_7_footnotes:
  string
  line
