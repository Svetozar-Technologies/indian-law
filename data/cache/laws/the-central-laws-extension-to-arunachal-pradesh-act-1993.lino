obj_root_law_sections_1:
  object
  (str sectionId) (str 29793)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Central Laws (Extension to
Arunachal Pradesh) Act, 1993.

(2) It shall come into force on such date^1
as the Central Government may, by notification in the
Official Gazette, appoint.`)
  (str footnotes) (str `1. 1st July, 1994, vide notification No. S.O. 491(E), dated1st July, 1994, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00016_199344_1517807323526&sectionId=29793&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00016_199344_1517807323526)
obj_root_law_sections_2:
  object
  (str sectionId) (str 29794)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Extension of certain laws.`)
  (str content) (str `The Acts mentioned in the Schedule and all rules, orders, regulations
and schemes made thereunder are hereby extended to, and shall be in force in, the State of Arunachal
Pradesh.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00016_199344_1517807323526&sectionId=29794&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00016_199344_1517807323526)
obj_root_law_sections_3:
  object
  (str sectionId) (str 29795)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Construction of references to laws not in force in Arunachal Pradesh.`)
  (str content) (str `Any reference in any
Act, mentioned in the Schedule, to a law which is not in force in the State of Arunachal Pradesh shall, in
relation to that State, be construed as a reference to the corresponding law, if any, in force in that state.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00016_199344_1517807323526&sectionId=29795&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00016_199344_1517807323526)
obj_root_law_sections_4:
  object
  (str sectionId) (str 29796)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Construction of references to authorities where new authorities have been constituted.`)
  (str content) (str `Any
reference by whatever form of words in any law for the time being in force in the State of Arunachal
Pradesh to any authority competent at the date of the passing of that law to exercise any powers or
discharge any functions in that State shall, where a corresponding new authority has been constituted by
or under any law now extended to that State, have effect as if it were a reference to the new authority.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00016_199344_1517807323526&sectionId=29796&sectionno=4&orderno=4&orgactid=AC_CEN_5_24_00016_199344_1517807323526)
obj_root_law_sections_5:
  object
  (str sectionId) (str 29797)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Power to remove difficulties.`)
  (str content) (str `(1) If any difficulty arises in giving effect to the provisions of any
Act now extended to the State of Arunachal Pradesh, the Central Government may, by order notified in
the Official Gazette, make such provisions or give such directions as appear to it necessary for the
removal of the difficulty.

(2) In particular, and without prejudice to the generality of the foregoing power, any such notified
order may,--

(a) specify the corresponding authorities within the meaning of section 4;

(b) provide for the transfer of any matter pending immediately before the commencement of
this Act before any court, tribunal or other authority, to any corresponding court, tribunal or other
authority for disposal:

Provided that no such order shall be made after the expiry of two years from the date of
commencement of this Act.

(3) Every order made under this section shall be laid before each House of Parliament.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00016_199344_1517807323526&sectionId=29797&sectionno=5&orderno=5&orgactid=AC_CEN_5_24_00016_199344_1517807323526)
