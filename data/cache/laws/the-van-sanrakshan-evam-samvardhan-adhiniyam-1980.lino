obj_root_law_translations_hi:
  object
  (str title) (str `वन (संरक्षण) अधिनियम, 1980`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1760/3/H1980-69.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:28:53.912Z`)
  (str pageCount) (int 2)
  (str sections) obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
