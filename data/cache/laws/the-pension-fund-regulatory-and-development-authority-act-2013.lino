obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `पेंशन नननि निननयामक और निकास प्र ानिकरण`
  line `अनिननयम, 2013`
  line _________
  line `िाराओं का क्र म`
  line _________
  line िाराएं
  line `अध्या य 1 प्र`
  line `ा र नि क`
  line `1. संनिप् त नाम, निस्ता र और प्र ारि।`
  line `2. पररिाषाएं।`
  line `अध्या य 2`
  line `पेंशन नननि निननयामक और निकास प्र ानिकरण`
  line `3. प्र ानिकरण की स् था पना और नन गमन।`
  line `4. प्र ानिकरण की संरचना।`
  line `5. प्र ानिकरण के अध्य ि और सदस्यों की पदािनि और सेिा की शतें।`
  line `6. सदस्यों का पद से हटाया जाना।`
  line `7. सदस्यों के िािी ननयोजन पर ननर्बंिन।`
  line `8. अध्य ि की प्र शासननक शनत यां।`
  line `9. प्र ानिकरण के अनििेशन।`
  line `10. ररनत यों, आदद से प्र ानिकरण की काययिानहयों का अनिनिमान्य न होना।`
  line `11. प्र ानिकरण के अनिकारी और कमयचारी।`
  line `अध्या य 3`
  line `निस्ता र और लागू होना`
  line `12. निस्ता र और लागू होना।`
  line `अध्या य 4`
  line `अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण की आनस्त यों,`
  line `दानयत्िों, आदद का अंतरण`
  line `13. अंतरर म पेंशन नननि निननयामक और निकास प्र ानिकरण की आनस्त यों, दानयत्िों, आदद का अंतरण।`
  line `अध्या य 5 प्र`
  line `ानिकरण के कतयव्य, शनत यां और कृत्य`
  line `14. प्र ानिकरण के कतयव्य, शनत यां और कृत्य।`
  line `15. ननदेश जारी करने की शनत।`
  line `16. अन्िे षण की शनत।`
  line `17. तलाशी और अनि ग्र हण।`
  line `18. प्र ानिकरण की अनुपालन सुनननच त करने की शनत।`
  line `19. प्र शासक द्व ारा प्रर्बं ि।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `अध्या य 6`
  line `राष्‍टरी य पेंशन प्र णाली`
  line `20. राष्‍टरी य पेंशन प्र णाली।`
  line `21. केन्री य अनिलेखापालन अनिकरण।`
  line `22. उपनस्थ नत अनस्त त् ि।`
  line `23. पेंशन नननि।`
  line `24. निदेशी कं पननयों या व् य नष्‍टट यों या व् य नत यों के संगम पर कनतपय ननर्बंिन।`
  line `25. िारत से र्ब ाहर अनिदाताओं की नननियों के निननिान का प्र नतषेि।`
  line `26. केन्री य अनिलेखपालन अनिकरण आदद की पात्रता मानक।`
  line `अध्या य 7`
  line `मध्य िर्तययों का रनजस्री करण`
  line `27. केन्री य अनिलेखपालन अनिक रण, पेंशन नननि, उपनस्थ नत अनस्त त् ि आदद का रनजस्री करण।`
  line `अध्या य 8`
  line `शानस्त यां और न् या यननणययन`
  line `28. मध्य िती या दकसी अन्य व् य नत द्व ारा अनिननयम के उपर्बंिों सनहत, ननयमों, निननयमों और ननदेशों का अनुपालन करने`
  line `में असफलता के नलए शानस्त।`
  line `29. शानस्त के रू प में िसूल की गई रानशयों का अनिदाता नशिा और संरिण नननि में जमा दकया जाना।`
  line `30. न् या यननणययन की शनत।`
  line `31. मध्य िती की आनस्त यों की कुकी और प्रर्बं ि का अनिक्रमण।`
  line `32. अपराि।`
  line `33. उन्मु नत प्र दान करने की शनत।`
  line `34. िन, आय, लािों और अनिलािों पर कर से छूट।`
  line `35. न् या यालय द्व ारा अपरािों का संज्ञान।`
  line `36. प्र नतिूनत अपील अनिकरण को अपील।`
  line `37. नसनिल न् या यालय की अनिकाररता का न होना।`
  line `38. उच्च तम न् या यालय को अपील।`
  line `अध्या य 9`
  line `नित्त, लेखा और संपरीिा`
  line `39. केन्री य सरकार द्व ारा अनुदान।`
  line `40. पेंशन निनन यामक और निकास नननि का गठन।`
  line `41. अनिदाता नशिा और संरिण नननि का गठन।`
  line `42. लेखा और संपरीिा।`
  line `अध्या य 1 0 प्र`
  line कीणय
  line `43. केन्री य सरकार की ननदेश देने की शनत।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line iii
  line िाराएं
  line `44. प्र ानिकरण को अनतनष्‍टठ त करने की केन्री य सरकार की शनत।`
  line `45. पेंशन सलाहकार सनमनत की स् था पना।`
  line `46. केन्री य सरकार को नििरनणयों, आदद का ददया जाना।`
  line `47. प्र ानिकरण के सदस्यों, अनिकाररयों और कमयचाररयों का लोक सेिक होना।`
  line `48. सद्भािपूियक की गई कारयिाई के नलए संरिण।`
  line `49. शनत यों का प्रत् या योजन।`
  line `50. कंपननयों द्व ारा अपराि।`
  line `51. नन यम र्ब नाने की शनत।`
  line `52. निननयम र्ब नाने की शनत।`
  line `53. ननयमों और निननयमों का संसद् के समि रखा जाना।`
  line `54. करठनाइयों को दूर करने की शनत।`
  line `55. अन्य निनियों के लागू होने का िर्जयत न होना।`
  line `56. व् या िृनत्त।`
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
  orderNo 4
  title `Page 4`
  content obj_root_law_translations_hi_sections_4_content
  footnotes obj_root_law_translations_hi_sections_4_footnotes
  sourcePage 4
obj_root_law_translations_hi_sections_4_content:
  string
  line `पेंशन नननि निननयामक और निकास प्र`
  line `ानिकरण अनिननयम, 2013`
  line `( 2013 का अनिननयम संखयां क 23 )`
  line `[18 नसत र्ब र, 2013 ]`
  line `पेंशन नननियों की स् की मों के अनिदाताओं के नहतों का संरिण करने के नलए`
  line `पेंशन नननियों को स् था नपत, निकनसत और निननयनमत करके िाियय`
  line `आय प्र नतिूनत का संिियन करने हेतु एक प्र ानिकरण की स्`
  line `था पना के नलए तथा उससे संर्बंनित या उसके`
  line `आनुषंनगक निषयों का उपर्बंि`
  line `करने के नलए`
  line अनिननयम
  line `िारत गणराज्य के चौंसठिें िषय में संसद् द्व ारा ननन नलनखत रू प में यह अनिननयनमत हो: ––`
  line `अध्या य 1 प्र`
  line `ा र नि क`
  line `1. सं निप्त नाम, निस्ता र और प्र ारि – – (1) इस अनिननयम का संनिप्त नाम पेंशन नननि निननयामक और निकास प्र ानिकरण`
  line `अनिननयम, 2013 है।`
  line `(2) इसका निस्ता र संपूणय िारत पर है।`
  line `(3) यह उस तारीख को प्र िृत्त होगा, जो केन्री य सरकार, राजपत्र में अनिसूचना द्व ारा, ननयत करे:`
  line `परंतु इस अनिननयम के निन् न - निन् न उपर्बंिों के नलए निन् न - निन् न तारीखें ननयत की जा सकेंगी और दकसी ऐसे उपर्बंि में ऐसे`
  line `अनिननयम के प्र ारंि के प्र नत दकसी ननदेश का यह अथय लगाया जाएगा दक िह उस उपर्बंि के प्र िृत्त होने के प्र नत ननदेश है।`
  line `2. पररिाषाएं –– (1) इस अनिननयम में, जर्ब तक दक संदिय से अन्य था अपेनित न हो, ––`
  line `( क ) “ प्र ा निकरण ” से िारा 3 की उपिारा (1) के अिीन स् था नपत पेंशन नननि निननयामक और निकास प्र निकरण`
  line `अनिप्रेत है;`
  line `( ख ) “ केन्री य अनिलेखपालन अनिकरण ” से अनिलेखपालन, लेखा, प्र शासन और स् की मों के अनिदाताओं के नलए ग्र`
  line `ाहक सेिा के कृत् यों के पालन के नलए िारा 27 के अिीन रनज स् री कृत कोई अनिकरण अनिप्रेत है;`
  line `( ग ) “ अध्य ि ” से प्र ानिकरण का अध्य ि अनिप्रेत है;`
  line `( घ ) “ दस्ता िेज ” के अंतगयत अिरों, अंकों या नचह्नों के माध्य म द्व ारा या एक से अनिक उन माध्य मों द्व ारा दकसी`
  line `पदाथय पर मुदरत या इलैरा ननक रू प में नलनखत, अनिव्य त या िर्णयत कोई निषय - िस्तु सनम नलत है, जो उस निषय - िस्तु के`
  line `अनिलेखन के प्र योजन के नलए अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण, या राष्‍टरी य पेंशन प्र णाली से संर्बद्ध प्र`
  line `ानिकरण या दकसी मध्य िती या दकसी अन्य अनस्त त् ि द्व ारा प्र योग दकए जाने के नलए आशनयत है या प्र युत की जा सकेगी;`
  line `( ङ ) “ व् य नष्‍टट पेंशन लेखा ” से, राष्‍टरी य पेंशन स् की म के अिीन ननर्बन्ि नों और शतों को उपिर्णयत करते हु ए दकसी`
  line `संनिदा के द्व ारा ननष्‍टपा ददत दकसी अनिदाता का कोई लेखा अनिप्रेत है;`
  line `( च ) “ अंतररम पेंशन नननि निननयामक और निका स प्र ानिकरण ” से संकल्प संखया एफ ० सं ० 5/7/2003 - ईसीर्बी एंड`
  line `पी आर, तारीख 10 अतू र्ब र, 2003 और एफ ० सं ० 1 ( 6 ) / 2007 - पी आर, तारीख 14 नि र्ब र, 2008 के माध्य म से केन्री य`
  line `सरकार द्व ारा गरठत अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण अनिप्रेत है;`
  line `( छ ) “ मध्य िती ” में पेंश न नननि, केन्री य अनिलेखपालन अनिकरण, राष्‍टरी य पेंशन प्र णाली न् या स, पेंशन नननि`
  line `सलाहकार, सेिाननिृनत्त सलाहकार, उपनस्थ नत अनस्त त् ि और ऐसा अन्य व् य नत या अनस्त त् ि सनम नलत हैं जो संग्रहण, प्रर्बन्`
  line `ि न, अनिलेखपालन और संचयों के नितरण से संर्बंनित हैं;`
  line `( ज ) “ सदस्य ” से प्र ानिकरण का कोई सदस्य अनिप्रेत है और नजसमें उसका अध्य ि सनम नलत है;`
  line `( झ ) “ राष्‍टरी य पेंशन प्र णाली ” से िारा 20 में ननर्दयष्‍टट अनिदायी पेंशन प्र णाली अनिप्रेत है नजसके द्व ारा उपनस्थ नत`
  line `अनस्त त् ि की प्र णाली, केन्री य अनि लेखपालन अनिकरण और निननयमों द्व ारा यथानिननर्दयष्‍टट संदायों के नलए पेंशन नननियों`
obj_root_law_translations_hi_sections_4_footnotes:
  string
  line
obj_root_law_translations_hi_sections_5:
  kind page
  sectionId pdf-page-5
  sectionNo (5)
  orderNo 5
  title `Page 5`
  content obj_root_law_translations_hi_sections_5_content
  footnotes obj_root_law_translations_hi_sections_5_footnotes
  sourcePage 5
obj_root_law_translations_hi_sections_5_content:
  string
  line `2 द्व`
  line `ारा संचयों का उपयोग करते हु ए अनिदाता से अनिदाय संगृहीत दकए जाते हैं और दकसी व् य नष्‍टट पेंशन लेखा में संनचत दकए`
  line `जाते हैं;`
  line `( ञ ) “ राष्‍टरी य पेंशन प्र णाली न् या स ” से िह न् या सी र्ब ोडय अनिप्रेत है जो अनिदाताओं के फायदे के नलए उनकी`
  line `आनस्त यां िाररत करता है;`
  line `( ट ) “ अनिसूचना ” से राजपत्र में प्र कानशत अनिसूचना अनिप्रेत है;`
  line `( ठ ) “ पेंशन नननि ” से कोई मध्य िती अनिप्रेत है नजसे, ऐसी रीनत में, जो निननयमों द्व ारा निननर्दयष्‍टट की जाए,`
  line `अनिदाय प्र ा प् त करने, उनका सं चयन करने और अनिदाता को संदाय करने के नलए प्र ानिकरण द्व ारा िारा 27 की उपिारा (3)`
  line `के अिीन रनजस्री करण का प्र माणपत्र प्र दान दकया गया है;`
  line `( ड ) “ पेंशन निननयामक और निकास नननि ” से िारा 40 की उपिारा (1) के अिीन गरठत नननि अनिप्रेत है;`
  line `( ढ ) “ उपनस्थ नत अनस्त त् ि ” से कोई मध्य िती अनिप्रेत है जो िारा िारा 27 की उपिारा (3) के अिीन उपनस्थ नत`
  line `अनस्त त् ि के रू प में प्र ानिकरण के पास रनजस्री कृत है और जो नननियों और अनुदेशों को प्र ाप्त करने और उनका पारेषण करने`
  line `तथा नननियों में से उनका संदाय करने के प्र योजनों के नलए केन्री य अनिलेखपालन अनिकरण के साथ इलैरा ननक संयोजकता`
  line `रखने में समथय है;`
  line `( ण ) “ निनहत ” से इस अनिननयम के अिीन र्ब नाए गए ननयमों द्व ारा निनहत अनिप्रेत है;`
  line `( त ) “ निननयनमत आनस्त यों ” से केन्री य अनिलेखापालन अनिकरण के स् िा नमत्िा िीन, पट्टािृत और उसके द्व ारा`
  line `निकनसत आनस्त यां और सप नत्तयां, मूतय और अमूतय दोनों तथा उसके अन्य अनिकार अनिप्रेत हैं;`
  line `( थ ) “ निननयम ” से इस अनिननयम के अिीन प्र ानिकरण द्व ारा र्ब नाए गए निननयम अनिप्रेत हैं;`
  line `( द ) “ स् की म ” से इस अनिननयम के अिीन प्र ानिकरण द्व ारा अनुमोददत पेंश न नननि की कोई स् की म अनिप्रेत है;`
  line `( ि ) “ प्र नतिूनत अपील अनिकरण ” से िारतीय प्र नतिूनत और निननम य र्ब ोडय अनिननयम, 1992 (1992 का 15) की`
  line `िारा 15 ट की उपिारा (1) के अिीन स् था नपत कोई प्र नतिूनत अपील अ निकरण अनिप्रेत है;`
  line `( न ) “ अनिदाता ” के अंतगयत ऐसा व् य नत िी है जो दकसी पेंशन नननि की दकसी स् की म में अनिदाय करता है;`
  line `( प ) “ अनिदाता नशिा और संरिण नननि ” से िारा 41 की उपिारा (1) के अिीन गरठत नननि अनिप्रेत है;`
  line `( फ ) “ न् या सी र्बैं क ” से र्बैं ककारी निननयमन अनिननयम, 1949 (1949 का 10) में यथापररिानष त र्बैं ककारी कंपनी`
  line `अनिप्रेत है।`
  line `(2) उन शब्दों और पदों के, जो इस अनिननयम में प्र युत हैं, और पररिानषत नहीं हैं दकन्तु जो ––`
  line `(i) र्ब ीमा अनिननयम, 19 3 8 (19 3 8 का 4);`
  line `(ii) कप नी अनिननयम, 1956 (1956 का 1);`
  line `(iii) प्र नतिूनत संनिदा ( निनन म यन ) अनिननयम, 1956 (1956 का 4 2 ); और`
  line `(iv) िारतीय प्र नतिूनत और निनन म य र्ब ोडय अनिननयम, 1992 (1992 का 15),`
  line `में पररिानषत हैं, िही अथय होंगे जो उनके अनिनन यमों में हैं।`
  line `अध्या य 2`
  line `पेंशन नननि निननयामक और निकास प्र ानिकरण`
  line `3. प्र ानिकरण की स् था पना और ननगमन –– (1) उस तारीख से, जो केन्री य सरकार अनिसूचना द्व ारा ननयत करे, इस`
  line `अनिननयम के प्र योजनों के नलए पेंशन नननि निननयामक और निकास प्र ानिकरण नामक एक प्र ानिकर ण की स् था पना की`
  line जाएगी।
  line `(2) प्र ानिकरण उपयुयत नाम से एक ननगनमत ननकाय होगा, नजसका शाि त् उत्तरानिकार और सामान्य मुरा होगी, नजसे इस`
  line `अनिननयम के उपर्बन्िों के अिीन रहते हु ए जंगम और स् था िर, दोनों ही प्र का र की सप नत्त का अजयन, िारण और व् य यन करने तथा`
  line `संनिदा करने की श नत होगी तथा उ त नाम से िह िाद लाएगा या उस पर िाद लाया जाएगा।`
  line `(3) प्र ानिकरण का मुखया लय राष्‍टरी य राजिानी िेत्र योजना र्ब ोडय अनिननयम, 1985 (1985 का 2 ) की िारा 2 के खण्ड ( च ) में`
  line `ननर्दयष्‍टट राष्‍टरी य राजिानी िेत्र में हो गा।`
  line `( 4 ) प्र ानिकरण िारत में अन्य स् था नों पर कायायलय स् था नपत कर सकेगा।`
obj_root_law_translations_hi_sections_5_footnotes:
  string
  line
obj_root_law_translations_hi_sections_6:
  kind page
  sectionId pdf-page-6
  sectionNo (6)
  orderNo 6
  title `Page 6`
  content obj_root_law_translations_hi_sections_6_content
  footnotes obj_root_law_translations_hi_sections_6_footnotes
  sourcePage 6
obj_root_law_translations_hi_sections_6_content:
  string
  line 3
  line `4. प्र ानिकरण की संरचना –– प्र ानिकरण ननन नलनखत सदस्यों, अथायत्: ––`
  line `( क ) एक अध्य ि;`
  line `( ख ) तीन पूणयकानलक सदस्यों; और`
  line `( ग ) तीन अंश कानलक सदस्यों,`
  line `से नमलकर र्ब नेगा, नजन्हें केन्री य सरकार द्व ारा, योग्य ता, सत्य ननष्‍टठा और प्र नतष्‍टठा िाले तथा अथयशास् त्र या नित्त या निनि का अनुिि`
  line `रखने िाले व् य नत यों में से ननयुत दकया जाएगा, नज नमें प्रत् ये क निद्या शाखा में से कम से कम एक व् य नत होगा।`
  line `5. प्र ानिकरण के अध्य ि और सदस्यों की पदािनि और सेिा की शतें –– (1) अध्य ि और प्रत् ये क पूणयकानलक सदस्य, उस तारीख`
  line `से, नजसको िह अपना पद ग्र हण करता है, पांच िषय की अिनि के नलए पद िारण करें गे और पुनर्नययुनत के नलए पात्र होंगे:`
  line `परंतु कोई व् य नत, उसके पैंसठ िषय की आयु प्र ाप्त करने के प चा त् अध्य ि के रू प में पद िारण नहीं करेगा:`
  line `परंतु यह और दक कोई व् य नत, उसके र्ब ासठ िषय की आयु प्र ाप्त करने के पचा त् पूणयकानलक सदस्य के रू प में पद िारण`
  line `नहीं करेगा।`
  line `(2) कोई अंशकानलक सदस्य उस तारीख से, नजसको िह अपना पद ग्र हण करता है, पांच िषय से अननिक की अिनि के नलए`
  line `उस रू प में पद िारण करेगा।`
  line `(3) अंशकानलक सदस्यों से निन् न सदस्यों को संदेय िेतन और ित्ते तथा सेिा के अन्य ननर्बंिन और शतें िे होंगी, जो निनहत`
  line `की जाएं।`
  line `( 4 ) अंशकानलक सदस्य ऐसे ित्ते प्र ा प् त करेंगे, जो निनहत दकए जा एं।`
  line `( 5 ) दकसी सदस्य के िेतन, ित्ते तथा सेिा की शतों में उसकी ननयुनत के प चा त् उसके नलए अलािकारी पररितयन नहीं`
  line `दकया जाएगा।`
  line `( 6 ) उपिारा (1) या उपिारा (2) में दकसी र्ब ात के होते हु ए िी कोई सदस्य ––`
  line `( क ) केन्री य सरकार को तीस ददन से अन्यू न की नलनखत सूचना देकर अपना पद त् या ग सकेगा; या`
  line `( ख ) िारा 6 के उपर्बंिों के अनुसार उसके पद से हटाया जा सकेगा।`
  line `6. सदस्यों का पद से हटाया जाना –– (1) केन्री य सरकार, अध्य ि या दकसी अन्य सदस्य को, ––`
  line `( क ) जो ददिानलया न् या यननणीत दकया जाता है या दकसी समय दकया गया है; या`
  line `( ख ) सदस्य के रू प में कायय करने में शारीररक या माननसक रू प से असमथय हो गया है; या`
  line `( ग ) जो दकसी ऐसे अपराि के नलए नसद्धदोष ठहराया गया है नजसमें केन्री य सरकार की राय में नैनतक अिमता`
  line `अन्त ियनलत है; या`
  line `( घ ) नजसने ऐसा नित्तीय या अन्य नहत अर्जयत दकया है नजससे सदस्य के रू प में उसके कृत् यों पर प्र नतकूल प्र िाि`
  line `पड़ने की संिािना है; या`
  line `( ङ ) नजसने केन्री य सरकार की राय में अपने पद का ऐसा दुरुपयो ग दकया है नजसके कारण उसका पद पर र्ब ने रहना`
  line `लोक नहत में हाननकारक है,`
  line `पद से हटा सकेगी।`
  line `(2) दकसी ऐसे अध्य ि या अन्य सदस्य को उपिारा (1) के खण्ड ( घ ) या खण्ड ( ङ ) के अिीन तर्ब तक नहीं हटाया जाएगा जर्ब`
  line `तक उसे उस निषय में सुनिाई का उनचत अिसर नहीं दे ददया जाता है।`
  line `7. सदस्यों के िािी ननयोजन पर ननर्बंिन –– (1) अध्य ि और पूणयकानलक सदस्य उनके उस रू प में पद पर न रहने की तारीख`
  line `से दो िषय की अिनि तक ––`
  line `( क ) या तो केन्री य सरकार के अिीन या दकसी राज्य सरकार के अिीन कोई ननयोजन; या`
  line `( ख ) पेंशन सेट र में दकसी निननयनमत अनस्त त् ि में कोई ननयु नत,`
  line `केन्री य सरकार के पूिय अनुमोदन के नसिाय स् िी कार नहीं करेंगे।`
  line `(2) अंतररम पेंश न नननि निननयामक और निकास प्र ानिकरण के अध्य ि और पूणयकानलक सदस्य, जो इस अनिननयम के प्र ारंि`
  line `के पूिय इस प्र कार पद िारण कर रहे थे, ऐसे प्र ारंि को और उसके प चा त्, उस तारीख से, नजसको िे इस प्र कार पद पर नहीं रहते हैं, दो`
obj_root_law_translations_hi_sections_6_footnotes:
  string
  line
obj_root_law_translations_hi_sections_7:
  kind page
  sectionId pdf-page-7
  sectionNo (7)
  orderNo 7
  title `Page 7`
  content obj_root_law_translations_hi_sections_7_content
  footnotes obj_root_law_translations_hi_sections_7_footnotes
  sourcePage 7
obj_root_law_translations_hi_sections_7_content:
  string
  line 4
  line `िषय की अिनि के नलए पेंश न सेट र में दकसी निननयनमत अनस्त त् ि में, केन्री य सरकार की पूिय अनुमनत के नसिाय कोई ननयुनत स् िी कार`
  line `नहीं करेंगे।`
  line `8. अध्य ि की प्र शासनन क श नत यां –– अध्य ि को, प्र ानिक रण के सिी प्र शासननक निषयों की र्ब ार्बत सािारण अिीिण और`
  line `ननदेशन की श नत यां होंगी।`
  line `9. प्र ानिकरण के अनििेशन –– (1) प्र ानिकरण का अनििेशन ऐसे समय और स् था नों पर होगा और िह अपने अनििेशनों में`
  line `कारर्बार के संव्य िहार के र्ब ारे में ( नजनके अन्त गयत ऐसे अनििेशनों में ग णपू र् तय है ) प्र दक्रया के ऐसे ननयमों का पालन करेगा जो नि ननयमों द्व`
  line `ारा उपर्बंनित दकए जाएं।`
  line `(2) अध्य ि या, यदद िह दकसी कारण से, प्र ानिकरण के अनििेशन में उपनस्थ त होने में असमथय है तो उस अनििेशन में`
  line `उपनस्थ त सदस्यों द्व ारा अपने में से ननिायनचत कोई अन्य सदस्य उस अनििेशन की अध्य िता करेगा।`
  line `(3) प्र ानिकरण के दकसी अनििेश न में, उसके समि आने िाले सिी प्र नों का निननच य, उपनस्थ त और मत देने िाले सदस्यों`
  line `के र्बहु मत द्व ारा दकया जाएगा और मत र्ब रार्बर होने की दशा में अध्य ि या उसकी अनुपनस्थ नत में अध्य िता करने िाले व् य नत का`
  line `नद्वतीय या ननणाययक मत होगा।`
  line `( 4 ) यदद कोई सदस्य, जो दकसी कप नी का ननदेशक है, और उसके ऐसे ननदेशक के रू प में, प्र ानिकरण के दकसी अनििेशन में`
  line `निचार के नलए आने िाले दकसी निषय में कोई प्रत् य ि या अप्रत्य ि िनीय नहत है तो िह सुसंगत पररनस्थ नतयों के उसकी जानकारी में`
  line `आने के प चा त्, यथासंिि शीघ्र ऐसे अनििेशन में अपने नहत की प्र कृनत को प्र कट करेगा और ऐसा प्र कट न प्र ानिकरण की काययिानहयों में`
  line `लेखर्बद्ध दकया जाएगा तथा िह सदस्य, उस निषय की र्ब ार्बत प्र ानिकरण के दकसी निचार - नि मशय या निननच य में िा ग नहीं लेगा।`
  line `10. ररनत यों, आदद से प्र ानिकरण की काययिानहयों का अनिनिमान्य न होना –– प्र ानिकरण का कोई कायय या काययिाही केिल`
  line `इस कारण अनिनिमान्य नहीं होगी दक ––`
  line `( क ) प्र ानिकरण में कोई ररनत है, या उसके गठन में कोई त्रु रट है; या`
  line `( ख ) प्र ानिकरण के सदस्य के रू प में कायय करने िाले दकसी व् य नत की ननयुनत में कोई त्रु रट है; या`
  line `( ग ) प्र ानिकरण की प्र दक्रया में कोई ऐसी अननयनमतता है, जो मामले के गुणागुण पर प्र िाि नहीं डालती है।`
  line `11. प्र ानिकरण के अनिकारी और कमयचारी –– (1) प्र ानिकरण, उतने अनिकाररयों और कमयचाररयों को ननयुत कर सकेगा, जो`
  line `िह इस अनिननयम के अिीन अपने कृत्यों के दितापूणय ननियहन के नलए आिय क समझे।`
  line `(2) उपिारा (1) के अिीन ननयुत दकए गए प्र ानिकरण के अनिकारी और अन्य कमयचाररयों की सेिा के ननर्बन्ि और अन्य`
  line `शतें िे होंगी, जो निननयमों द्व ारा अि िाररत की जाएं।`
  line `अध्या य 3`
  line `निस्ता र और लागू होना`
  line `1 2. निस्ता र और लागू होना –– (1) यह अनिननयम, ––`
  line `( क ) राष्‍टरी य पेंशन प्र णाली;`
  line `( ख ) दकसी अन्य पेंशन स् की म, जो दकसी अन्य अनिननयनमनत द्व ारा निननयनमत नहीं की जाती है,`
  line `को लागू होगा।`
  line `(2) खण्ड ( ख ) में ननर्दयष्‍टट प्रत् ये क पेंशन स् की म, ऐसे समय के िीतर जो निननयमों द्व ारा निननर्दयष्‍टट दकया जाए, प्र ानिकरण द्व ारा र्ब`
  line `नाए गए निननयमों के अनुरूप होगी।`
  line `(3) उपिारा (1) में दकसी र्ब ात के होते हु ए िी, इस अनिननयम के उपर्बंि ननन नलनखत को लागू नहीं होंगे ––`
  line `( क ) ननन नलनखत के अिीन स् की में या नननियां ––`
  line `(i) कोयला खान िनिष्‍टय नननि और प्र कीणय उपर्बंि अनिननयम, 1948 (19 4 8 का 4 6 );`
  line `(ii) कमयचारी िनिष्‍टय नननि और प्र कीणय उपर्बंि अनिननयम, 19 5 2 (19 5 2 का 19 );`
  line `(iii) नानिक िनिष्‍टय नननि अनिननयम, 19 66 (19 66 का 4 );`
  line `(iv) असम चाय र्ब ागान िनिष्‍टय नननि और पें शन नननि स् की म अनिननयम, 195 5 (195 5 का असम`
  line `अनिननय म 1 0 ); और`
  line `(v) जमू - कमी र कमयचारी िनिष्‍टय नननि अनिननयम, 1961 (196 1 का जमू और कमी र अनिननयम`
  line `1 5 );`
obj_root_law_translations_hi_sections_7_footnotes:
  string
  line
obj_root_law_translations_hi_sections_8:
  kind page
  sectionId pdf-page-8
  sectionNo (8)
  orderNo 8
  title `Page 8`
  content obj_root_law_translations_hi_sections_8_content
  footnotes obj_root_law_translations_hi_sections_8_footnotes
  sourcePage 8
obj_root_law_translations_hi_sections_8_content:
  string
  line 5
  line `( ख ) र्ब ीमा अनिननयम, 19 3 8 (19 3 8 का 4) की िारा 2 की उपिारा (2) और उपिारा ( 11 ) में ननर्दयष्‍टट संनिदा;`
  line `( ग ) कोई अन्य पेंशन स् की म नजसे केन्री य सरकार अनिसूचना द्व ारा इस अनिननयम के लागू होने से छूट दे;`
  line `( घ ) अनखल िारतीय सेिा अनिननयम, 195 1 (195 1 का 61) की िारा 2 क के अिीन गरठत संघ या अनखल`
  line `िारतीय सेिाओं के दक्रयाकलापों के संर्बंि में लोक सेिाओं में 1 जनिरी, 2 00 4 से पूिय ननयुत व् य नत;`
  line `( ङ ) दकसी राज्य या ऐसे संघ राज्य िेत्र के, जो केन्री य सरकार द्व ारा अनिसूचना द्व ारा निननर्दयष्‍टट दकए जाएं,`
  line `दक्रयाकलापों के संर्बंि में लोक सेिाओं में ननयुत व् य नत।`
  line `( 4 ) उपिारा (3) में दकसी र्ब ात के होते हु ए िी, कोई राज्य सरकार या दकसी संघ राज्य िेत्र का प्र शासक, अनिसूचना द्व ारा`
  line `राष्‍टरी य पेंशन प्र णाली का अपने कमयचाररयों पर निस्ता र कर सकेगी।`
  line `( 5 ) केंरीय सरकार, उपिारा (3) के खंड ( ग ) में दकसी र्ब ात के होते हु ए िी, दकसी अन्य पेंशन स् की म को [ नजसके अंतगयत`
  line `उपिारा (3) के खं ड ( ग ) के अिीन छूट प्र ाप्त और अनिसूनचत कोई अन्य पेंशन स् की म िी है ] अनिसूचना द्व ारा, इस अनिननयम के लागू`
  line `होने का निस्ता र कर सकेगी।`
  line `( 6 ) उपिारा (3) में ननर्दयष्‍टट दकसी स् की म या नननियों के अिीन शानसत कोई व् य नत अपने निकल्प पर राष्‍टरी य पेंशन प्र णाली`
  line `में सनम नलत हो सकेगा।`
  line `अध्या य 4`
  line `अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण की आनस्त यों,`
  line `दानयत्िों, आदद का अंतरण`
  line `1 3. अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण की आनस्त यों, दानयत्िों, आदद का अंतरण –– अंतररम पेंश न नननि`
  line `निननयामक और निकास प्र ानिकरण की स् था पना की तारीख से ही, ––`
  line `( क ) अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण की सिी आनस्त यां और दानयत्ि, प्र ानिकर ण में`
  line `अंतररत और नननहत हो जाएंगे। स्`
  line `प ष्‍ट टी करण – – अंतररम पेंशन नननि निननयामक और निकास प्र निकरण की आनस्त यों में सिी अनिकार और`
  line `शनत यां, सिी संपनत्तयां, चाहे स् था िर हों या जंगम, नजसमें, निशेषकर नकदी र्ब काया, ननिेप और सिी अन्य नहत तथा ऐसी`
  line `संपनत्तयों में या उससे उद्िूत अनिकार, जो अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण के कब्जे में हों, तथा`
  line `उससे संर्बंनित सिी लेखा र्ब नहयां और अन्य दस्ता िे ज सनम नलत समझे जाएंगे; तथा दानयत्िों में, सिी ऋण, दानयत्ि और`
  line `अन्य र्ब ाध्य ताएं, चाहे नजस प्र कार की हों, सनम नलत समझी जाएगी;`
  line `( ख ) खंड ( क ) के उपर्बंिों पर प्र नतकूल प्र िाि डाले नर्बना उस तारीख से ठीक पूिय, उत निननयामक प्र ानिकरण के प्र`
  line `योजन के नलए या उसके संर्बंि में, उपगत सिी ऋण, र्ब ाध्य ताएं और दानयत्ि, की गई सिी संनिदाएं और अंतररम पेंशन`
  line `नननि निननयामक और निकास प्र ानिकरण द्व ारा, उसके साथ या उसके नलए दकए जाने के नलए िचनर्बद्ध सिी निषय और र्ब`
  line `ातें, प्र ानिकरण द्व ारा, उसके साथ या उसके नलए उपगत, की गई या की जाने के नलए िचनर्बद्ध समझी जाएंगी;`
  line `( ग ) उस तारीख से ठीक पूिय, अंतररम पेंश न नननि निननयामक और निकास प्र ानिकरण को देय सिी िनरानशयां प्र`
  line `ानिकरण को देय समझी जाएंगी; और`
  line `( घ ) उस तारीख से ठीक पूिय अंतररम पेंशन नननि निननयामक और निकास प्र ानिकरण द्व ारा या उसके निरुद्ध`
  line `संनस्थ त की गई या जो संनस्थ त की जा सकती थी, सिी िाद और अन्य निनिक काययिानहयां प्र ानिकरण द्व ारा या उसके निरुद्ध`
  line `जारी रह सकेंगी या संनस्थ त की जा सकेंगी।`
  line `अध्या य 5 प्र`
  line `ानिकरण के कतयव्य, शनत यां और कृत्य`
  line `1 4. प्र ानिकरण के कतयव्य, शनत यां और कृत् य –– (1) इस अ निननयम और तत्स मय प्र िृत्त दकसी अन्य निनि के उपर्बन्िों के`
  line `अिीन रहते हु ए, प्र ानिकरण का यह कतय व् य होगा दक िह राष्‍टरी य पेंश न प्र णाली औ र पेंश न स् की मों को, नजनको यह अनिननयम लागू`
  line `होता है, ननयनमत, संिर्ियत करे और उनकी क्र नमक िृनद्ध को सुनननच त करे तथा ऐसी प्र णाली या स् की मों के अनिदाताओं के नहतों का`
  line `संरिण करे।`
  line `(2) उपिारा (1) में अन्त र् ियष्‍टट उपर्बन्िों की व् या पकता पर प्र नतकूल प्र िाि डाले नर्बना, प्र ानिकरण की शनत यों और कृत् यों में`
  line `ननन नलनखत सनम नलत होंगे ––`
  line `( क ) राष्‍टरी य पेंशन प्र णाली और पेंशन स् की मों का, नजनको यह अनिननयम लागू होता है, निननयम न;`
obj_root_law_translations_hi_sections_8_footnotes:
  string
  line
obj_root_law_translations_hi_sections_9:
  kind page
  sectionId pdf-page-9
  sectionNo (9)
  orderNo 9
  title `Page 9`
  content obj_root_law_translations_hi_sections_9_content
  footnotes obj_root_law_translations_hi_sections_9_footnotes
  sourcePage 9
obj_root_law_translations_hi_sections_9_content:
  string
  line 6
  line `( ख ) स् की मों, उनके ननर्बन्ि नों और शतों का अनुमोदन करना तथा पेंशन नननियों के समग्र प्रर्बन् ि न के मानक`
  line `अनिकनथत करना, नजनके अन्त गयत ऐसी स् की मों के अिीन निननिान के मागयदशयक नसद्धान्त िी हैं;`
  line `( ग ) मध्य िर्तय यों का रनजस्री करण और निननयमन;`
  line `( घ ) आिेदन पर दकसी मध्य िती को एक रनजस्री करण प्र माणपत्र जारी करना और ऐसे रनजस्री करण का निीकरण,`
  line `उपांतरण, प्रत् या हरण, ननल र्ब न या रद्दकरण;`
  line `( ङ ) अनिदाताओं के नहतों का, ––`
  line `(i) ऐसी पेंशन नननियों की, नजनको यह अनिननयम ला गू होता है, निनिन् न स् की मों के अनिदाताओं के`
  line `अनिदाय की सुरिा सुनननच त करके;`
  line `(ii) यह सुनननच त करके दक राष्‍टरी य पेंशन प्र णाली के अिीन मध्य िती और अन्य प्र दक्रया संर्बंिी लागत`
  line `नमतव्य यी और युनत युत है,`
  line `सरंिण करना;`
  line `( च ) निननयमों द्व ारा अििा ररत दकए जाने िाले अनिदाताओं की नशकायतों को दूर करने के नलए तंत्र स् था नपत`
  line करना;
  line `( छ ) पेंशन प्र णाली से संर्बंनित िृनत्तक संगठनों को प्र ोन्न त करना;`
  line `( ज ) मध्य िर्तययों के र्ब ीच तथा मध्य िर्तययों और अनिदाताओं के र्ब ीच नििादों का न् या यननणययन;`
  line `( झ ) आंकडेे़ संग्रहण क रना और मध्य िर्तययों से ऐसे आंकडेे़ संग्रहण करने की अपेिा करना तथा अध्य यन, अनुसंिान`
  line `और पररयोजनाओं का नजमा लेना और उन्हें चलाना;`
  line `( ञ ) पेंशन, सेिाननिृनत्त, र्ब चतों और सं र्बं नित नििाद्यकों तथा मध्य िर्तय यों के प्र नशिण से संर्बंनित नििाद्यकों पर`
  line `अनिदाताओं और सािारण जनता को नशनित करने के नलए कदम उठाना;`
  line `( ट ) पेंशन नननियों के पालन से संर्बंनि त सूचना के प्र सारण का मानकीकरण तथा न् यू नतम मानकों का पालन;`
  line `( ठ ) निननयनमत आनस्त यों का निननयमन;`
  line `( ड ) इस अनिननयम के प्र योजनों को कायायनन्ि त करने के नलए फीस या अन्य प्र िार उद्गृहीत करना;`
  line `( ढ ) उस रू प और रीनत को, नजसमें मध्य िर्तययों द्व ारा लेखा र्ब नहयां र्ब नाए रखी जाएंगी और लेखाओं का नििरण`
  line `ददया जाएगा, निननयमों द्व ारा निनन र् दयष्‍टट करना;`
  line `( ण ) पेंश न नननियों से संर्बंनित मध्य िर्तययों और अन्य अ नस्त त् िों या संगठनों से सूचना मं गा ना, उ नका ननरीिण`
  line `करना, उनके संर्बंि में जांच या अन्िे षण, नजसके अन्त गयत लेखापरीिा िी है, का संचालन करना;`
  line `( त ) ऐसी अन्य शनत यों और कृत्यों का प्र योग करना, जो निनहत दकए जाएं।`
  line `(3) तत्स मय प्र िृत्त दकसी अन्य निनि में दकसी र्ब ात के होते हु ए िी, उप िारा (2) के खण्ड ( ण ) के अिीन शनत यों का प्र योग`
  line `करते समय, प्र ानिकरण को िही श नत यां होंगी जो ननन नलनखत निषयों के संर्बंि में दकसी िाद का निचारण करते समय नसनिल प्र`
  line `दक्रया संनहता, 1908 (1908 का 5) के अिीन दकसी नसनिल न् या यालय में नननहत हैं, अथाय त्: ––`
  line `(i) ऐसे स् था न पर और ऐसे समय पर जो प्र ानिकरण द्व ारा निननर्दयष्‍टट दकया जाए, लेखा र्ब नहयों और अन्य दस्ता िेजों`
  line `का प्र कटीकरण और उन्हें प्रस् तु त करना;`
  line `(ii) व् य नत यों को समन करना और उन्हें हानजर कराना तथा शपथ पर उनकी परीिा करना;`
  line `(iii) दकसी स् था न पर िारा 2 6 में ननर्दय ष्‍ट ट दकसी व् य नत या मध्य िती की दकसी पुस्त क, रनजस्ट र और अन्य`
  line `दस्ता िेजों का ननरीिण करना;`
  line `(iv) सानियों या दस्ता िेजों की परीिा के नलए कमीशन ननकालना;`
  line `(v) कोई अन्य निषय जो निनहत दकया जाए।`
  line `( 4 ) उपिारा (1), उपिारा (2) और उपिारा (3) तथा िारा 1 6 में अन्त र् ियष्‍टट उपर्बन्िों पर प्र नतकूल प्र िाि डाले नर्बना, प्र`
  line `ानिकरण, आदेश द्व ारा अनिदाताओं के नहतों में लेखर्बद्ध दकए जाने िाले कारणों से, अन्िे षण या जांच के लन र्ब त रहने के दौरान`
  line `ननन नलनखत कोई उपाय कर सकेगी, अथायत्: ––`
  line `(i) व् य नत यों को दकसी स् की म में िाग लेने से अिरुद्ध करना;`
obj_root_law_translations_hi_sections_9_footnotes:
  string
  line
obj_root_law_translations_hi_sections_10:
  kind page
  sectionId pdf-page-10
  sectionNo (10)
  orderNo 10
  title `Page 10`
  content obj_root_law_translations_hi_sections_10_content
  footnotes obj_root_law_translations_hi_sections_10_footnotes
  sourcePage 10
obj_root_law_translations_hi_sections_10_content:
  string
  line 7
  line `(ii) दकसी मध्य िती के दकसी पदिारी को उस रू प में कायय करने से अिरुद्ध करना;`
  line `(iii) दकसी दक्रयाकलाप की र्ब ार्बत, जो अन्िे षणािीन है, स् की म के अिीन आगमों को पररर्बद्ध करना और प्र`
  line `नतिाररत करना;`
  line `(iv) अनुमोदन के नलए दकए गए आिेदन पर, अनि काररता रखने िाले प्र थम िगय न् या नयक मनजस्रे ट द्व ारा आदेश`
  line `पाररत दकए जाने के प चा त्, इस अनिननयम या उसके अिीन र्ब नाए गए ननयमों या निननयमों के दकसी उपर्बंि का दकसी िी`
  line `रीनत में अनतक्रमण करने िाले दकसी मध्य िती या अन्य व् य नत के एक या अनिक र्बैं क खा ते या खातों को एक मास से अननिक`
  line `की अिनि के नलए कुकय करना:`
  line `परन् तु केिल र्बैं क खाते या खातों या उनमें दकए गए दकसी संव्य िहार को ही, जो इस अनिननयम के दकसी उपर्बंि या`
  line `उसके अिीन र्ब नाए गए नन यमों या निननयमों के अनतक्रमण में िास्त ि में अन्त ियनलत आगमों से संर्बंनित है, कुकय करने के नलए`
  line `अनुज्ञात दकया जाएगा;`
  line `(v) दकसी िी रीनत में स् की म से सहयोनजत दकसी मध्य िती या दकसी व् य नत को, दकसी दक्रयाकलाप के िागरूप`
  line `दकसी आनस्त का, जो अन्िे षणािीन है, व् य यन या अन्य संक्रामण न करने का ननदेश देना:`
  line `परन् तु प्र ानिकरण, इस िारा के अिी न ऐसे आदेश पाररत करने के या तो पूिय या उसके प चा त्, ऐसे मध्य िर्तययों या संर्बंनित व्`
  line `य नत यों को सुनिाई का अिसर देगा।`
  line `1 5. ननदेश जारी करने की शनत –– िारा 1 4 में अन्य था उपर्बनन्ि त के नसिाय, यदद कोई जांच करने या करा ने के प चा त् प्र`
  line `ानिकरण का यह समािान हो जाता है दक ––`
  line `(i) अनिदाताओं या राष्‍टरी य पेंशन प्र णाली या दकसी पेंशन स् की म के, नजसको यह अनिननयम लागू होता है, व्`
  line `य िनस्थ त निकास के नहतों के नलए; या`
  line `(ii) िारा 2 7 में ननर्दयष्‍टट दकसी मध्य िती या अन्य व् य नत यों या अनस्त त् िों के दक्रयाकलापों का ऐसी रीनत में`
  line `संचानलत दकए जाने से, जो अनिदाताओं के नहतों के नलए हानन कर है, ननिारण करने के नलए; या`
  line `(ii i ) दकसी ऐसे मध्य िती या व् य नत या अनस्त त् ि के उनचत प्रर्बन् ि को सुनननच त करने के नलए,`
  line `यह आिय क है तो िह िारा 2 7 में ननर्दयष्‍टट या पेंशन नननि से सहयो नजत ऐसे मध्य िर्तययों या दकसी ऐसे व् य नत या व् य नत यों के िगय`
  line `को ऐसे ननदेश दे सकेगा जो िह उपयुत समझे:`
  line `परन् तु प्र ानिकरण, ऐसा आदेश पाररत करने के या तो पूिय या उसके पचा त् ऐसे मध्य िर्तययों, अनस्त त् िों या संर्बंनित व् य नत यों`
  line `को सुनिाई का अिस र देगा।`
  line `1 6. अन्िे षण की शनत –– (1) जहां प्र ानिकरण के पास यह नििा स करने का युनत युत आिार है दक ––`
  line `( क ) पेंशन नननि के दक्रयाकला प अनिदाता के नहतों के नलए हाननक र दकसी रीनत में संचानलत दकए जा रहे हैं; या`
  line `( ख ) पेंशन नननि स् की मों से सहयोनजत दकसी मध्य िती या दकसी व् य नत ने इस अनिननयम या उसके अिीन र्ब नाए`
  line `गए ननयमों या निननयमों के दकन्हीं उपर्बन्िों या प्र ानिकरण द्व ारा जारी दकए गए ननदेशों का अनतक्रमण दकया है,`
  line `तो िह दकसी िी समय, नलनखत आदेश द्व ारा दकसी व् य नत को ( नजसे इस िारा में अन्िे षक प्र ानिकारी कहा ग या है ), पेंशन नननि से`
  line `सहयोनजत ऐसे मध्य िती या व् य नत यों के दक्रयाकलापों का अन्िे षण करने और प्र ानिकर ण को उस पर ररपोटय देने के नलए आदेश में`
  line `निननर्दयष्‍टट ननदेश दे सकेगा।`
  line `( 2 ) कप नी अनिननयम, 1956 (1956 का 1) की िारा 23 5 से िारा 2 4 1 में अन्त र् ियष्‍टट उ पर्बन्िों पर प्र नतकूल प्र िाि डाले`
  line `नर्बना, कप नी की दशा में कप नी के प्रत् ये क प्रर्बन् ि क, प्रर्बन् ि ननदेश क, अनिकारी और अन्य कमयचारी का और िारा 2 7 में ननर्दयष्‍टट प्रत् ये क`
  line `मध्य िती या व् य नत या अनस्त त् ि या पेंशन नननि से सहयोनजत प्रत् ये क व् य नत का, यथानस्थ नत, कप नी के या कप नी से संर्बंनित या ऐसे`
  line `मध्य िती या व् य नत से संर्बंनित, जो उसकी अनिरिा या शनत के अिीन हैं, सिी पुस्त कों, रनजस्ट रों, अन्य दस्ता िेजों और अनिलेख`
  line `को, संरनित रखने और अन्िे षक प्र ानिकारी या इस नननमत्त उसके द्व ारा प्र ा निकृत दकसी व् य नत को प्रस् तु त करने का कतयव्य होगा।`
  line `(3) अन्िे षक प्र ानिकारी, पेंशन नननि से दकसी िी रीनत में सहयोनजत दकसी मध्य िती या दकसी व् य नत या अनस्त त् ि से ऐसी`
  line `जानकारी देने या उसके समि या इस नननमत्त उसके द्व ारा प्र ानिकृत दकसी व् य नत के समि, ऐसी पुस्त कों या अन्य दस्ता िेजों या`
  line `अनिलेख को प्रस् तु त करने की अपेिा कर सकेगा, जो िह आिय क समझे, यदद ऐसी जानकारी देना या ऐसी पुस्त कों या रनजस्ट र या`
  line `अन्य दस्ता िेजों या अनिलेख का प्रस् तु त करना उसके अन्िे षण के प्र योजनों के नलए सुसंगत या आिय क है।`
  line `( 4 ) अन्िे षक प्र ानिकारी, उपिारा ( 2 ) या उपिारा (3) के अिीन प्रस् तु त की गई दकसी पुस्त क, रनजस्ट र या अन्य दस्ता िेज या`
  line `अनिलेख को छह मास के नलए अपनी अनिरिा में रख सकेगा और तत्प चा त् पेंशन नननि से सहयोनजत ऐसे मध्य िती या दकसी व् य नत`
  line `या अनस्त त् ि को, नजसके द्व ारा या नजसकी ओर से पुस् त कें, रनजस्ट र, अन्य दस्ता िेज और अनिलेख प्रस् तु त दकए गए थे, लौटा देगा:`
obj_root_law_translations_hi_sections_10_footnotes:
  string
  line
obj_root_law_translations_hi_sections_11:
  kind page
