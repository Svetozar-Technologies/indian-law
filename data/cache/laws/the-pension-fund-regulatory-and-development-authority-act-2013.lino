obj_root_law_sections_1:
  sectionId (20528)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20528&sectionno=1&orderno=1&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Pension Fund`
  line `Regulatory and Development Authority Act, 2013.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date ^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act and any reference`
  line `in any such provision to the commencement of this Act shall be construed as a reference to the coming`
  line `into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1 1st February, 2014, vide Notification No. S.O. 302 (E), dated 1st February, 2014, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (20529)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20529&sectionno=2&orderno=2&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Authority" means the Pension Fund Regulatory and Development Authority established`
  line `under sub-section (1) of section 3;`
  line
  line `(b) "central recordkeeping agency" means an agency registered under section 27 to perform the`
  line `functions of recordkeeping, accounting, administration and customer service for subscribers to`
  line schemes;
  line
  line `(c) "Chairperson" means the Chairperson of the Authority;`
  line
  line `(d) "document" shall include any matter written, expressed or described upon any substance by`
  line `means of letters, figures or marks, or by more than one of those means, in printed or in electronic`
  line `version, which is intended to be used, or which may be used, by the Interim Pension Fund Regulatory`
  line `and Development Authority, or Authority or an intermediary or any other entity connected with the`
  line `National Pension System, for the purpose of recording that matter;`
  line
  line `(e) "individual pension account" means an account of a subscriber, executed by a contract setting`
  line `out the terms and conditions under the National Pension System;`
  line
  line `(f) "Interim Pension Fund Regulatory and Development Authority" means the Interim Pension`
  line `Fund Regulatory and Development Authority set up by the Central Government through Resolutions`
  line `No. F. No. 5/7/2003-ECB&PR, dated the 10th October, 2003 and F. No. 1(6)/2007-PR, dated the 14th`
  line `November, 2008;`
  line
  line `(g) "intermediary" includes pension fund, central recordkeeping agency, National Pension System`
  line `Trust, pension fund adviser, retirement adviser, point of presence and such other person or entity`
  line `connected with collection, management, recordkeeping and distribution of accumulations;`
  line
  line `(h) "member" means a member of the Authority and includes its Chairperson;`
  line
  line `(i) "National Pension System" means the contributory pension system referred to in section 20`
  line `whereby contributions from a subscriber are collected and accumulated in an individual pension`
  line `account using a system of points of presence, a central recordkeeping agency and pension funds as`
  line `may be specified by regulations;`
  line
  line `(j) "National Pension System Trust" means the Board of Trustees who hold the assets of`
  line `subscribers for their benefit;`
  line
  line `(k) "notification" means a notification published in the Official Gazette;`
  line
  line `(l) "pension fund" means an intermediary which has been granted a certificate of registration`
  line `under sub-section (3) of section 27 by the Authority as a pension fund for receiving contributions,`
  line `accumulating them and making payments to the subscriber in the manner as may be specified by`
  line regulations;
  line
  line `(m) "Pension Regulatory and Development Fund" means the fund constituted under`
  line `sub-section (1) of section 40;`
  line
  line `(n) "point of presence" means an intermediary registered with the Authority under sub-section (3)`
  line `of section 27 as a point of presence and capable of electronic connectivity with the central`
  line `recordkeeping agency for the purposes of receiving and transmitting funds and instructions and pay`
  line `out of funds;`
  line
  line `(o) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(p) "regulated assets" means the assets and properties, both tangible and intangible, owned, leased`
  line `or developed by and other rights belonging to, the central recordkeeping agency;`
  line
  line `(q) "regulations" means the regulations made by the Authority under this Act;`
  line
  line `(r) "scheme" means a scheme of pension fund approved by the Authority under this Act;`
  line
  line `(s) "Securities Appellate Tribunal" means a Securities Appellate Tribunal established under`
  line `sub-section (1) of section 15K of the Securities and Exchange Board of India Act, 1992 (15 of 1992);`
  line
  line `(t) "subscriber" includes a person who subscribes to a scheme of a pension fund;`
  line
  line `(u) "Subscriber Education and Protection Fund" means the fund constituted under sub-section (1)`
  line `of section 41;`
  line
  line `(v) "Trustee Bank" means a banking company as defined in the Banking Regulation Act, 1949`
  line `(10 of 1949).`
  line
  line `(2) Words and expressions used and not defined in this Act, but defined in—`
  line
  line `(i) the Insurance Act, 1938 (4 of 1938);`
  line
  line `(ii) the Companies Act, 1956 (1 of 1956);`
  line
  line `(iii) the Securities Contracts (Regulation) Act, 1956 (42 of 1956); and`
  line
  line `(iv) the Securities and Exchange Board of India Act, 1992 (15 of 1992),`
  line
  line `shall have the meanings respectively assigned to them under those Acts.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (20530)
  sectionNo (3)
  orderNo 3
  title `Establishment and incorporation of Authority.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20530&sectionno=3&orderno=3&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_3_content:
  string
  line `(1)With effect from such date as the Central`
  line `Government may, by notification, appoint, there shall be established, for the purposes of this Act, an`
  line `Authority to be called the Pension Fund Regulatory and Development Authority.`
  line
  line `(2) The Authority shall be a body corporate by the name aforesaid, having perpetual succession and a`
  line `common seal with power, subject to the provisions of this Act, to acquire, hold and dispose of property,`
  line `both movable and immovable, and to contract and shall, by the said name, sue or be sued.`
  line
  line `(3) The head office of the Authority shall be in the National Capital Region referred to in clause (f) of`
  line `section 2 of the National Capital Region Planning Board Act, 1985 (2 of 1985).`
  line
  line `(4)The Authority may establish offices at other places in India.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (20531)
  sectionNo (4)
  orderNo 4
  title `Composition of Authority.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20531&sectionno=4&orderno=4&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_4_content:
  string
  line `The Authority shall consist of the following Members, namely:—`
  line
  line `(a) a Chairperson;`
  line
  line `(b) three whole-time members; and`
  line
  line `(c) three part-time members,`
  line
  line `to be appointed by the Central Government from amongst persons of ability, integrity and standing and`
  line `having knowledge and experience in economics or finance or law with at least one person from each`
  line discipline.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (20532)
  sectionNo (5)
  orderNo 5
  title `Term of office and conditions of service of Chairperson and members of Authority.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20532&sectionno=5&orderno=5&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_5_content:
  string
  line `(1) The`
  line `Chairperson and every whole-time member shall hold office for a term of five years from the date on`
  line `which he enters upon his office and shall be eligible for reappointment:`
  line
  line `Provided that no person shall hold office as a Chairperson after he has attained the age of sixty-five`
  line `years:`
  line
  line `Provided further that no person shall hold office as a whole-time member after he has attained the age`
  line `of sixty-two years.`
  line
  line `(2) A part-time member shall hold office as such for a term not exceeding five years from the date on`
  line `which he enters upon his office.`
  line
  line `(3)The salary and allowances payable to, and other terms and conditions of service of, the members`
  line `other than part-time members shall be such as may be prescribed.`
  line
  line `(4)The part-time members shall receive such allowances as may be prescribed.`
  line
  line `(5)The salary, allowances and other conditions of service of a member shall not be varied to his`
  line `disadvantage after his appointment.`
  line
  line `(6) Notwithstanding anything contained in sub-section (1) or sub-section (2), a member may—`
  line
  line `(a) relinquish his office, by giving in writing to the Central Government, a notice of not less than`
  line `thirty days; or`
  line
  line `(b) be removed from his office in accordance with the provisions of section 6.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (20533)
  sectionNo (6)
  orderNo 6
  title `Removal of members from office.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20533&sectionno=6&orderno=6&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_6_content:
  string
  line `(1) The Central Government may remove from office the`
  line `Chairperson or any other member who--`
  line
  line `(a) is, or at any time has been, adjudged as insolvent; or`
  line
  line `(b) has become physically or mentally incapable of acting as a member; or`
  line
  line `(c) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions as`
  line `a member; or`
  line
  line `(e) has, in the opinion of the Central Government, so abused his position as to render his`
  line `continuance in office detrimental to the public interest.`
  line
  line `(2) No such Chairperson or other member shall be removed under clause (d) or clause (e) of`
  line `sub-section (1) unless he has been given a reasonable opportunity of being heard in the matter.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (20534)
  sectionNo (7)
  orderNo 7
  title `Restriction on future employment of members.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20534&sectionno=7&orderno=7&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_7_content:
  string
  line `(1) The Chairperson and the whole-time`
  line `members shall not, for a period of two years from the date on which they cease to hold office as such,`
  line `except with the previous approval of the Central Government, accept--`
  line
  line `(a) any employment either under the Central Government or under any State Government; or`
  line
  line `(b) any appointment in any regulated entity in the pension sector.`
  line
  line `(2) The Chairperson and the whole-time members of the Interim Pension Fund Regulatory and`
  line `Development Authority holding the office as such before the commencement of this Act, shall not, on and`
  line `after such commencement, accept any appointment in any regulated entity in the pension sector for a`
  line `period of two years from the date on which they cease to hold office as such, except with the previous`
  line `approval of the Central Government.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (20535)
  sectionNo (8)
  orderNo 8
  title `Administrative powers of Chairperson.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20535&sectionno=8&orderno=8&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_8_content:
  string
  line `The Chairperson shall have the powers of general`
  line `superintendence and direction in respect of all administrative matters of the Authority.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (20536)
  sectionNo (9)
  orderNo 9
  title `Meetings of Authority.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20536&sectionno=9&orderno=9&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_9_content:
  string
  line `(1) The Authority shall meet at such times and places and shall observe`
  line `such rules of procedure in regard to the transaction of business at its meetings (including quorum at such`
  line `meetings) as may be provided by regulations.`
  line
  line `(2) The Chairperson or, if for any reason, he is unable to attend a meeting of the Authority, any other`
  line `member chosen by the members present from amongst themselves at the meeting, shall preside at the`
  line meeting.
  line
  line `(3) All questions which come up before any meeting of the Authority shall be decided by a majority`
  line `of votes by the members present and voting, and in the event of an equality of votes, the Chairperson or in`
  line `his absence, the person presiding shall have a second or casting vote.`
  line
  line `(4) If any member, who is a director of a company and who as such director, has any direct or indirect`
  line `pecuniary interest in any matter coming up for consideration at a meeting of the Authority, he shall, as`
  line `soon as possible after relevant circumstances have come to his knowledge, disclose the nature of his`
  line `interest at such meeting and such disclosure shall be recorded in the proceedings of the Authority, and the`
  line `member shall not take part in any deliberation or decision of the Authority with respect to that matter.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (20537)
  sectionNo (10)
  orderNo 10
  title `Vacancies, etc., not to invalidate proceedings of Authority.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20537&sectionno=10&orderno=10&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_10_content:
  string
  line `No act or proceeding of the`
  line `Authority shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Authority; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Authority; or`
  line
  line `(c) any irregularity in the procedure of the Authority not affecting the merits of the case.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (20538)
  sectionNo (11)
  orderNo 11
  title `Officers and employees of Authority.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20538&sectionno=11&orderno=11&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_11_content:
  string
  line `(1)The Authority may appoint such officers and other`
  line `employees as it considers necessary for the efficient discharge of its functions under this Act.`
  line
  line `(2) The terms and other conditions of service of officers and other employees of the Authority`
  line `appointed under sub-section (1) shall be such as may be determined by regulations.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (20539)
  sectionNo (12)
  orderNo 12
  title `Extent and application.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20539&sectionno=12&orderno=12&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_12_content:
  string
  line `(1) This Act shall apply to--`
  line
  line `(a) the National Pension System;`
  line
  line `(b) any other pension scheme not regulated by any other enactment.`
  line
  line `(2) Every pension scheme referred to in clause (b) shall conform to the regulations made by the`
  line `Authority within such time as may be specified in the regulations.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1), the provisions of this Act shall not apply`
  line to--
  line
  line `(a) the schemes or funds under--`
  line
  line `(i) the Coal Mines Provident Fund and Miscellaneous Provisions Act, 1948 (46 of 1948);`
  line
  line `(ii) the Employees' Provident Funds and Miscellaneous Provisions Act, 1952 (19 of 1952);`
  line
  line `(iii) the Seamen's Provident Fund Act, 1966 (4 of 1966);`
  line
  line `(iv) the Assam Tea Plantations Provident Fund and Pension Fund Scheme Act, 1955 (Assam`
  line `Act X of 1955); and`
  line
  line `(v) the Jammu and Kashmir Employees' Provident Funds Act, 1961 (Jammu and Kashmir`
  line `Act XV of 1961);`
  line
  line `(b) contracts referred to in sub-section (11) of section 2 of the Insurance Act, 1938 (4 of 1938);`
  line
  line `(c) any other pension scheme, which the Central Government may, by notification, exempt from`
  line `the application of this Act;`
  line
  line `(d) persons appointed before the 1st day of January, 2004 to public services in connection with`
  line `the affairs of the Union, or to All-India Services constituted under section 2A of the All-India`
  line `Services Act, 1951 (61 of 1951);`
  line
  line `(e) persons appointed to public services in connection with the affairs of any State, or such Union`
  line `territories as may be specified by notification by the Central Government.`
  line
  line `(4) Notwithstanding anything contained in sub-section (3), any State Government or administrator of`
  line `a Union territory may, by notification, extend the National Pension System to its employees.`
  line
  line `(5) Notwithstanding anything contained in clause (c) of sub-section (3), the Central Government may,`
  line `by notification, extend the application of this Act to any other pension scheme including any other`
  line `pension scheme exempted and notified under clause (c) of sub-section (3).`
  line
  line `(6) Any person governed under any of the schemes or funds referred to in sub-section (3) may, at his`
  line `option, also join the National Pension System.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (20540)
  sectionNo (13)
  orderNo 13
  title `Transfer of assets, liabilities, etc., of Interim Pension Fund Regulatory and Development Authority.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20540&sectionno=13&orderno=13&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_13_content:
  string
  line `On and from the date of establishment of the Pension Fund Regulatory and Development`
  line Authority,--
  line
  line `(a) all the assets and liabilities of the Interim Pension Fund Regulatory and Development`
  line `Authority shall stand transferred to, and vested in, the Authority.`
  line
  line `Explanation.--The assets of the Interim Pension Fund Regulatory and Development Authority`
  line `shall be deemed to include all rights and powers, all properties, whether movable or immovable,`
  line `including, in particular, cash balances, deposits and all other interests and rights in, or arising out of,`
  line `such properties as may be in the possession of the Interim Pension Fund Regulatory and Development`
  line `Authority and all books of account and other documents relating to the same; and liabilities shall be`
  line `deemed to include all debts, liabilities and obligations of whatever kind;`
  line
  line `(b) without prejudice to the provisions of clause (a), all debts, obligations and liabilities incurred,`
  line `all contracts entered into and all matters and things engaged to be done by, with or for the Interim`
  line `Pension Fund Regulatory and Development Authority immediately before that day, for or in`
  line `connection with the purpose of the said Regulatory Authority, shall be deemed to have been incurred,`
  line `entered into or engaged to be done by, with or for, the Authority;`
  line
  line `(c) all sums of money due to the Interim Pension Fund Regulatory and Development Authority`
  line `immediately before that day shall be deemed to be due to the Authority; and`
  line
  line `(d) all suits and other legal proceedings instituted or which could have been instituted by or`
  line `against the Interim Pension Fund Regulatory and Development Authority immediately before that day`
  line `may be continued or may be instituted by or against the Authority.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (20541)
  sectionNo (14)
  orderNo 14
  title `Duties, powers and functions of Authority.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20541&sectionno=14&orderno=14&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_14_content:
  string
  line `(1) Subject to the provisions of this Act and any`
  line `other law for the time being in force, the Authority shall have the duty, to regulate, promote and ensure`
  line `orderly growth of the National Pension System and pension schemes to which this Act applies and to`
  line `protect the interests of subscribers of such System and schemes.`
  line
  line `(2) Without prejudice to the generality of the provisions contained in sub-section (1), the powers and`
  line `functions of the Authority shall include--`
  line
  line `(a) regulating the National Pension System and the pension schemes to which this Act applies;`
  line
  line `(b) approving the schemes, the terms and conditions thereof and laying down norms for the`
  line `management of the corpus of the pension funds, including investment guidelines under such schemes;`
  line
  line `(c) registering and regulating intermediaries;`
  line
  line `(d) issuing to an intermediary, on application, a certificate of registration and renewing,`
  line `modifying, withdrawing, suspending or cancelling such registration;`
  line
  line `(e) protecting the interests of subscribers by--`
  line
  line `(i) ensuring safety of the contribution of subscribers to various schemes of pension funds to`
  line `which this Act applies;`
  line
  line `(ii) ensuring that the intermediation and other operational costs under the National Pension`
  line `System are economical and reasonable;`
  line
  line `(f) establishing mechanism for redressal of grievances of subscribers to be determined by`
  line regulations;
  line
  line `(g) promoting professional or organisations connected with the pension system;`
  line
  line `(h) adjudication of disputes between intermediaries and between intermediaries and subscribers;`
  line
  line `(i) collecting data and requiring the intermediaries to collect such data and undertaking and`
  line `commissioning studies, research and projects;`
  line
  line `(j) undertaking steps for educating subscribers and the general public on issues relating to`
  line `pension, retirement savings and related issues and training of intermediaries;`
  line
  line `(k) standardising dissemination of information about performance of pension funds and`
  line `performance benchmarks;`
  line
  line `(l) regulating the regulated assets;`
  line
  line `(m) levying fees or other charges for carrying out the purposes of this Act;`
  line
  line `(n) specifying by regulations the form and manner in which books of account shall be maintained`
  line `and statement of accounts shall be rendered by intermediaries;`
  line
  line `(o) calling for information from, undertaking inspection of, conducting inquiries and`
  line `investigations including audit of, intermediaries and other entities or organisations connected with`
  line `pension funds;`
  line
  line `(p) exercising such other powers and functions as may be prescribed.`
  line
  line `(3) Notwithstanding anything contained in any other law for the time being in force, while exercising`
  line `the powers under clause (o) of sub-section (2), the Authority shall have the same powers as are vested in a`
  line `civil court under the Code of Civil Procedure, 1908 (5 of 1908) while trying a suit, in respect of the`
  line `following matters, namely:--`
  line
  line `(i) the discovery and production of books of account and other documents, at such place and`
  line `at such time as may be specified by the Authority;`
  line
  line `(ii) summoning and enforcing the attendance of persons and examining them on oath;`
  line
  line `(iii) inspection of any book, register and other document of any person or intermediary`
  line `referred to in section 26, at any place;`
  line
  line `(iv) issuing commissions for the examination of witnesses or documents;`
  line
  line `(v) any other matter which may be prescribed.`
  line
  line `(4) Without prejudice to the provisions contained in sub-sections (1), (2) and (3) and section 16, the`
  line `Authority may, by order, for reasons to be recorded in writing, in the interest of subscribers, take any of`
  line `the following measures, pending investigation or inquiry, namely:--`
  line
  line `(i) restrain persons from participating in any scheme;`
  line
  line `(ii) restrain any office bearer of an intermediary from acting as such;`
  line
  line `(iii) impound and retain the proceeds under the scheme in respect of any activity which is`
  line `under investigation;`
  line
  line `(iv) attach, after passing an order, on an application made for approval, by the Judicial`
  line `Magistrate of first class having jurisdiction, for a period not exceeding one month, one or more`
  line `bank account or accounts of any intermediary or any person associated with the scheme in any`
  line `manner involved in violation of any of the provisions of this Act or the rules or the regulations`
  line `made thereunder:`
  line
  line `Provided that only the bank account or accounts or any transaction entered therein, relating to`
  line `the proceeds actually involved in the violation of any of the provisions of this Act or the rules or`
  line `the regulations made thereunder shall be allowed to be attached;`
  line
  line `(v) direct any intermediary or any person associated with the scheme in any manner not to`
  line `dispose of or alienate an asset forming part of any activity which is under investigation:`
  line
  line `Provided that the Authority shall, either before or after, passing such orders, under this`
  line `section, give to such intermediaries or persons concerned an opportunity of being heard.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (20542)
  sectionNo (15)
  orderNo 15
  title `Power to issue directions.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20542&sectionno=15&orderno=15&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_15_content:
  string
  line `Save as otherwise provided in section 14, if after making, or causing`
  line `to be made, an inquiry, the Authority is satisfied that it is necessary--`
  line
  line `(i) in the interests of subscribers or orderly development of National Pension System or a`
  line `pension scheme to which this Act applies; or`
  line
  line `(ii) to prevent the affairs of any intermediary or other persons or entities referred to in`
  line `section 27 being conducted in a manner detrimental to the interests of subscribers; or`
  line
  line `(iii) to secure the proper management of any such intermediary or person or entity,`
  line
  line `it may issue such directions to such intermediaries or entities or to any person or class of persons referred`
  line `to in section 27, or associated with the pension fund, as it may deem fit:`
  line
  line `Provided that the Authority shall, either before or after passing such orders, give an opportunity of`
  line `being heard to such intermediaries, entities or persons concerned.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (20543)
  sectionNo (16)
  orderNo 16
  title `Power of investigation.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20543&sectionno=16&orderno=16&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_16_content:
  string
  line `(1) Where the Authority has a reasonable ground to believe that--`
  line
  line `(a) the activities of the pension fund are being conducted in a manner detrimental to the interest`
  line `of the subscriber; or`
  line
  line `(b) any intermediary or any person associated with the schemes of the pension fund has violated`
  line `any of the provisions of this Act or the rules or the regulations made or directions issued by the`
  line `Authority thereunder,`
  line
  line `it may, at any time, by order in writing, direct any person (hereafter in this section referred to as the`
  line `Investigating Authority) specified in the order to investigate the affairs of such intermediary or persons`
  line `associated with the pension fund and to report thereon to the Authority.`
  line
  line `(2) Without prejudice to the provisions contained in sections 235 to 241 of the Companies Act,`
  line `1956 (1 of 1956), it shall be the duty of every manager, managing director, officer and other employee of`
  line `the company, in case of a company and every intermediary or persons or entity referred to in section 27 or`
  line `every person associated with the pension fund to preserve and to produce to the Investigating Authority or`
  line `any person authorised by him in this behalf, all the books, registers, other documents and record of, or`
  line `relating to, the company or, as the case may be, of or relating to, the intermediary or such person, which`
  line `are in their custody or power.`
  line
  line `(3) The Investigating Authority may require any intermediary or any person or entity associated with`
  line `the pension fund in any manner to furnish such information to, or produce such books, or other`
  line `documents, or record before him or any person authorised by him in this behalf as he may consider`
  line `necessary if the furnishing of such information or the production of such books, or register, or other`
  line `documents, or record is relevant or necessary for the purposes of its investigation.`
  line
  line `(4) The Investigating Authority may keep in its custody any books, registers, other documents and`
  line `record produced under sub-section (2) or sub-section (3) for six months and thereafter shall return the`
  line `same to any intermediary or any person associated or entity with the pension fund by whom or on whose`
  line `behalf the books, registers, other documents and record are produced:`
  line
  line `Provided that the Investigating Authority may call for any book, register, other documents and record`
  line `if they are required again:`
  line
  line `Provided further that if the person on whose behalf the books, registers, other documents and record`
  line `are produced requires certified copies of the books, registers, other documents or record produced before`
  line `the Investigating Authority, it shall give certified copies of such books, registers, other documents or, as`
  line `the case may be, record to such person or on whose behalf the books, registers, other documents and`
  line `record were produced.`
  line
  line `(5) Any person, directed to make an investigation under sub-section (1), may examine on oath any`
  line `intermediary or any person associated with the pension fund in any manner, in relation to the affairs of his`
  line `business and may administer an oath accordingly and for that purpose may require any of those persons to`
  line `appear before him personally.`
  line
  line `(6) Notes of any examination under sub-section (5) shall be taken down in writing and shall be read`
  line `over to, or by, and signed by, the person examined, and may thereafter be used in evidence against him.`
  line
  line `(7) If any person fails without reasonable cause or refuses--`
  line
  line `(a) to produce to an Investigating Authority or any person authorised by him in this behalf any`
  line `book, register, other document or record which it is his duty under sub-section (2) or sub-section (3)`
  line `to furnish; or`
  line
  line `(b) to furnish any information which it is his duty under sub-section (3) to furnish; or`
  line
  line `(c) to appear before the Investigating Authority personally when required to do so under`
  line `sub-section (5) or to answer any question which is put to him by the Investigating Authority in`
  line `pursuance of that sub-section; or`
  line
  line `(d) to sign the notes of any examination referred to in sub-section (6),`
  line `he shall be punishable with imprisonment for a term which may extend to one year, or with fine, which`
  line `may extend to twenty-five crore rupees, or with both, and also with a further fine which may extend to ten`
  line `lakh rupees for every day after the first day during which the failure or refusal continues.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (20544)
  sectionNo (17)
  orderNo 17
  title `Search and seizure.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20544&sectionno=17&orderno=17&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_17_content:
  string
  line `(1) Where the Authority, in consequence of information in its possession,`
  line `has reason to believe that--`
  line
  line `(a) any person who has been required under sub-section (3) of section 16 to produce, or cause to`
  line `be produced, any books, accounts or other documents in his custody or power has omitted or failed to`
  line `produce, or cause to be produced, such books, accounts or other documents; or`
  line
  line `(b) any person to whom a requisition to produce any books, accounts or other documents as`
  line `aforesaid has been or might be issued will not, or would not, produce or cause to be produced, any`
  line `books, accounts or other documents which will be useful for, or relevant to, an investigation under`
  line `sub-section (1) of section 16; or`
  line
  line `(c) a contravention of any provision of this Act has been committed or is likely to be committed`
  line `by an intermediary; or`
  line
  line `(d) any claim which is due to be settled by the intermediary, has been or is likely to be rejected or`
  line `settled at a figure higher than a reasonable amount; or`
  line
  line `(e) any claim which is due to be settled by an intermediary, has been or is likely to be rejected or`
  line `settled at a figure lower than a reasonable amount; or`
  line
  line `(f) any illegal fees and charges have been transacted or are likely to be transacted by an`
  line `intermediary; or`
  line
  line `(g) any books, accounts, papers, receipts, vouchers, survey reports or other documents, belonging`
  line `to an intermediary are likely to be tampered with, falsified or manufactured,`
  line
  line `it may authorise any officer of the Authority, not below the rank equivalent to that of a Gazetted Officer`
  line `of the Government (hereafter referred to as the authorised officer), to--`
  line
  line `(i) enter and search any building or place where he has reason to suspect that such books,`
  line `accounts or other documents, or any books or papers relating to any claim, rebate or commission or`
  line `any receipts, vouchers, reports or other documents are kept;`
  line
  line `(ii) break open the lock of any box, locker, safe, almirah or other receptacle for exercising the`
  line `powers conferred by clause (i) where the keys thereof are not available;`
  line
  line `(iii) seize all or any such books, accounts or other documents, found as a result of such search;`
  line
  line `(iv) place marks of identification on such books, accounts or other documents or make or cause`
  line `to be made extracts or copies there from.`
  line
  line `(2) The authorised officer may requisition the services of any police officer or of any officer of the`
  line `Central Government, or of both, to assist him for all or any of the purposes specified in sub-section (1)`
  line `and it shall be the duty of every such police officer or officer to comply with such requisition.`
  line
  line `(3) The authorised officer may, where it is not practicable to seize any such book, account or other`
  line `document, specified in sub-section (1), serve an order on the person who is in immediate possession or`
  line `control thereof that he shall not remove, part with or otherwise deal with it except with the previous`
  line `permission of such officer and such officer may take such steps as may be necessary for ensuring`
  line `compliance with this sub-section.`
  line
  line `(4) The authorised officer may, during the course of the search or seizure, examine on oath any`
  line `person who is found to be in possession or control of any books, accounts or other documents, and any`
  line `statement made by such person during such examination may thereafter be used in evidence in any`
  line `proceeding under this Act.`
  line
  line `(5) The books, accounts, papers, receipts, vouchers, reports, or other documents seized under`
  line `sub-section (1) shall not be retained by the authorised officer for a period exceeding one hundred and`
  line `eighty days from the date of the seizure unless the reasons for retaining the same are recorded by him in`
  line `writing and the approval of the Authority for such retention is obtained:`
  line
  line `Provided that the Authority shall not authorise the retention of the books, accounts, papers, receipts,`
  line `vouchers, reports, or other documents for a period exceeding thirty days after all the proceedings under`
  line `this Act, for which the books, accounts, papers, receipts, vouchers, reports, or other documents are`
  line `relevant, are completed.`
  line
  line `(6) The person from whose custody the books, accounts, papers, receipts, vouchers, reports, or other`
  line `documents are seized under sub-section (1) may make copies thereof, or take extracts there from, in the`
  line `presence of the authorised officer or any other person empowered by him in this behalf at such place and`
  line `time as the authorised officer may appoint in this behalf.`
  line
  line `(7) If a person legally entitled to the books, accounts, papers, receipts, vouchers, reports or other`
  line `documents seized under sub-section (1) objects for any reason to the approval given by the Authority`
  line `under sub-section (5), he may make an application to the Central Government stating therein the reason`
  line `for such objection and requesting for the return of the books, accounts, papers, receipts, vouchers, report`
  line `or other documents.`
  line
  line `(8) On receipt of the application under sub-section (7), the Central Government may, after giving the`
  line `applicant an opportunity of being heard, pass such order as it thinks fit.`
  line
  line `(9) The provisions of the Code of Criminal Procedure, 1973 (2 of 1974) relating to searches and`
  line `seizures shall apply, so far as may be, to every search and seizure made under sub-section (1).`
  line
  line `(10) The Central Government may, by notification, make rules in relation to any search or seizure`
  line `under this section and in particular, and without prejudice to the generality of the foregoing power, such`
  line `rules may provide for the procedure to be followed by the authorised officer,--`
  line
  line `(i) for obtaining ingress into such building or place to be searched where free ingress thereto`
  line `is not available;`
  line
  line `(ii) for ensuring safe custody of any books, accounts, papers, receipts, vouchers, reports, or`
  line `other documents seized under this section.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (20545)
  sectionNo (18)
  orderNo 18
  title `Power of Authority to ensure compliance.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20545&sectionno=18&orderno=18&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_18_content:
  string
  line `If the Authority finds, after causing an inquiry to be`
  line `made, that any person has violated, or is likely to violate, any provisions of this Act, or any rule or`
  line `regulation made thereunder, the Authority may pass an order requiring such person to cease and desist`
  line `from committing or causing such violation.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (20546)
  sectionNo (19)
  orderNo 19
  title `Management by Administrator.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20546&sectionno=19&orderno=19&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_19_content:
  string
  line `(1) If at any time the Authority has reason to believe that the`
  line `central recordkeeping agency or pension fund is acting in a manner likely to be prejudicial to the interest`
  line `of subscribers, it may, after giving the central recordkeeping agency or pension fund, as the case may be,`
  line `an opportunity of being heard, make a report thereon to the Central Government.`
  line
  line `(2) If the Central Government, after considering the report made under sub-section (1) is of the`
  line `opinion, that it is necessary or proper to do so, it may appoint an Administrator to manage the affairs of`
  line `the central recordkeeping agency or pension fund, as the case may be, under the direction and control of`
  line `the Authority, in such manner as may be specified by notification.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (20547)
  sectionNo (20)
  orderNo 20
  title `National Pension System.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20547&sectionno=20&orderno=20&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_20_content:
  string
  line `(1) The contributory pension system notified by the Government of`
  line `India in the Ministry of Finance vide notification number F. No. 5/7/2003-ECB&PR, dated the`
  line `22nd December, 2003, shall be deemed to be the National Pension System with effect from the 1stday of`
  line `January, 2004, and such National Pension System may be amended from time to time by regulations.--`
  line
  line `(2) Notwithstanding anything contained in the said notification, the National Pension System shall, on`
  line `the commencement of this Act, have the following basic features, namely:--`
  line
  line `(a) every subscriber shall have an individual pension account under the National Pension System;`
  line
  line `(b) withdrawals, not exceeding twenty-five per cent. of the contribution made by the subscriber,`
  line `may be permitted from the individual pension account subject to the conditions, such as purpose,`
  line `frequency and limits, as may be specified by the regulations;`
  line
  line `(c) the functions of recordkeeping, accounting and switching of options by the subscriber shall be`
  line `effected by the central recordkeeping agency;`
  line
  line `(d) there shall be a choice of multiple pension funds and multiple schemes:`
  line
  line `Provided that--`
  line
  line `(a) the subscriber shall have an option of investing up to hundred per cent. of his funds in`
  line `Government Securities; and`
  line
  line `(b) the subscriber, seeking minimum assured returns, shall have an option to invest his funds`
  line `in such schemes providing minimum assured returns as may be notified by the Authority;`
  line
  line `(e) there shall be portability of individual pension accounts in case of change of employment;`
  line
  line `(f) collection and transmission of contributions and instructions shall be through points of`
  line `presence to the central recordkeeping agency;`
  line
  line `(g) there shall not be any implicit or explicit assurance of benefits except market based guarantee`
  line `mechanism to be purchased by the subscriber;`
  line
  line `(h) a subscriber shall not exit from the National Pension System except as may be specified by`
  line `the regulations; and`
  line
  line `(i) at exit, the subscriber shall purchase an annuity from a life insurance company in accordance`
  line `with the regulations.`
  line
  line `(3) In addition to the individual pension account mentioned in clause (a) of sub-section (2), a`
  line `subscriber may also, at his option, have an additional account under the National Pension System having`
  line `the features mentioned in clauses (c) to (g) of sub-section (2) and also having the additional feature that`
  line `the subscriber shall be free to withdraw part or all of his money at any time from the additional account.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (20548)
  sectionNo (21)
  orderNo 21
  title `Central Recordkeeping Agency.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20548&sectionno=21&orderno=21&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_21_content:
  string
  line `(1) The Authority shall, by granting a certificate of`
  line `registration under sub-section (3) of section 27, appoint a central recordkeeping agency:`
  line
  line `Provided that the Authority may, in public interest, appoint more than one central recordkeeping`
  line agency.
  line
  line `(2) The central recordkeeping agency shall be responsible for receiving instructions from subscribers`
  line `through the points of presence, transmitting such instructions to pension funds, effecting switching`
  line `instructions received from subscribers and discharging such other duties and functions, as may be`
  line `assigned to it under the certificate of registration or as may be determined by regulations.`
  line
  line `(3) All the assets and properties owned, leased or developed by the central recordkeeping agency,`
  line `shall constitute regulated assets and upon expiry of certificate of registration or earlier revocation thereof,`
  line `the Authority shall be entitled to appropriate and take over the regulated assets, either by itself or through`
  line `an administrator or a person nominated by it in this behalf:`
  line
  line `Provided that the central recordkeeping agency shall be entitled to be compensated the fair value, to`
  line `be ascertained by the Authority, of such regulated assets as may be determined by regulations:`
  line
  line `Provided further that where the earlier revocation of the certificate of registration is based on`
  line `violation of the conditions in the certificate of registration or the provisions of this Act or regulations,`
  line `unless otherwise determined by the Authority, the central recordkeeping agency shall not be entitled to`
  line `claim any compensation in respect of such regulated assets.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (20549)
  sectionNo (22)
  orderNo 22
  title `Point of presence.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20549&sectionno=22&orderno=22&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_22_content:
  string
  line `(1) The Authority may, by granting a certificate of registration under`
  line `sub-section (3) of section 27, permit one or more persons to act as a point of presence for the purpose of`
  line `receiving contributions and instructions, transmitting them to the Trustee Bank or the central`
  line `recordkeeping agency, as the case may be, and paying out benefits to subscribers in accordance with the`
  line `regulations made by the Authority from time to time in this regard.`
  line
  line `(2) A point of presence shall functions in accordance with the terms of its certificate of registration`
  line `and the regulations made under this Act.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (20550)
  sectionNo (23)
  orderNo 23
  title `Pension funds.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20550&sectionno=23&orderno=23&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_23_content:
  string
  line `(1) The Authority may, by granting a certificate of registration under`
  line `sub-section (3) of section 27, permit one or more persons to act as a pension fund for the purpose of`
  line `receiving contributions, accumulating them and making payments to the subscriber in such manner as`
  line `may be specified by regulations.`
  line
  line `(2) The number of pension funds shall be determined by regulations and the Authority may, in public`
  line `interest, vary the number of pension funds:`
  line
  line `Provided that at least one of the pension funds shall be a Government company.`
  line
  line `Explanation.--For the purposes of this sub-section, the expression "Government company" shall`
  line `have the meaning assigned to it in section 617 of the Companies Act, 1956 (1 of 1956).`
  line
  line `(3) The pension fund shall function in accordance with the terms of its certificate of registration and`
  line `the regulations made under this Act.`
  line
  line `(4) The pension fund shall manage the schemes in accordance with the regulations.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (20551)
  sectionNo (24)
  orderNo 24
  title `Certain restrictions on foreign companies or individual or association of persons.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20551&sectionno=24&orderno=24&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_24_content:
  string
  line The
  line `aggregate holding of equity shares by a foreign company either by itself or through its subsidiary`
  line `companies or its nominees or by an individual or by an association of persons whether registered or not`
  line `under any law of a country outside India taken in aggregate in the pension fund shall not exceed`
  line `twenty-six per cent. of the paid-up capital of such fund or such percentage as may be approved for an`
  line `Indian insurance company under the provisions the Insurance Act, 1938 (4 of 1938) whichever is higher.`
  line
  line `Explanation.--For the purposes of this section, the expression "foreign company" shall have the`
  line `meaning assigned to it in clause (23A) of section 2 of the Income-tax Act, 1961 (43 of 1961).`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (20552)
  sectionNo (25)
  orderNo 25
  title `Prohibition of investment of funds of subscribers outside India.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20552&sectionno=25&orderno=25&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_25_content:
  string
  line `No pension fund shall,`
  line `directly or indirectly invest outside India, the funds of subscribers.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (20553)
  sectionNo (26)
  orderNo 26
  title `Eligibility norms of the central recordkeeping agency, etc.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20553&sectionno=26&orderno=26&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_26_content:
  string
  line `The central recordkeeping`
  line `agency, points of presence and pension funds, shall satisfy the eligibility norms as may be specified by`
  line `the regulations, including minimum capital requirement, past track-record including the ability to provide`
  line `guaranteed returns, costs and fees, geographical reach, customer base, information technology capability,`
  line `human resources and such other matters.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (20554)
  sectionNo (27)
  orderNo 27
  title `Registration of central recordkeeping agency, pension fund, point of presence, etc.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20554&sectionno=27&orderno=27&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_27_content:
  string
  line `(1) No`
  line `intermediary, including a pension fund or a point of presence to the extent regulated under this Act, shall`
  line `commence any activity relating to a pension fund except under and in accordance with the conditions of a`
  line `certificate of registration granted by the Authority in accordance with the provisions of this Act and the`
  line `regulations:`
  line
  line `Provided that any intermediary, including any point of presence, who had been associated with a`
  line `pension scheme and appointed to act as such by the Interim Pension Fund Regulatory and Development`
  line `Authority immediately before the establishment of the Authority under this Act for which no registration`
  line `certificate was necessary prior to such establishment, and may continue to do so for a period of six`
  line `months from such establishment or, if he has made an application for such registration within the said`
  line `period of six months till the disposal of such application.`
  line
  line `(2) Every application for grant of a certificate of registration under this Act shall be in such form and`
  line `manner and shall be accompanied by such fees as may be determined by regulations.`
  line
  line `(3) The Authority may, after considering the application and subject to such terms and conditions as it`
  line `may specify, grant a certificate of registration as a central recordkeeping agency, point of presence,`
  line `pension fund or such other intermediary, as the case may be.`
  line
  line `(4) The Authority may, by order, suspend or cancel a certificate of registration granted under`
  line `sub-section (3) in such manner as may be determined by regulations:`
  line
  line `Provided that no order under this sub-section shall be made unless the person concerned has been`
  line `given a reasonable opportunity of being heard.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (20555)
  sectionNo (28)
  orderNo 28
  title `Penalty for failure by an intermediary or any other person to comply with provisions of this Act, rules, regulations and directions.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20555&sectionno=28&orderno=28&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_28_content:
  string
  line `(1) Any person, who is required under this Act or any rules or`
  line `regulations made thereunder,--`
  line
  line `(a) to obtain a certificate of registration from the Authority for carrying on any activity under this`
  line `Act, carries on such activities without obtaining such certificate of registration, he shall be liable to a`
  line `penalty of one lakh rupees for each day during which the failure continues or one crore rupees,`
  line `whichever is less;`
  line
  line `(b) to comply with the terms and conditions of a certificate of registration fails to do so, he shall`
  line `be liable to a penalty of one lakh rupees for each day during which the failure continues or one crore`
  line `rupees, whichever is less;`
  line
  line `(c) to furnish any information, document, books, returns or report to the Authority, fails to furnish`
  line `the same within the time specified by the Authority, he shall be liable to a penalty which may extend`
  line `to one crore rupees or five times the amount of profits made or losses avoided, whichever is higher;`
  line
  line `(d) to maintain books of account or records, fails to maintain the same, he shall be liable to a`
  line `penalty of one lakh rupees for each day during which the failure continues or five times the amount of`
  line `profits made or losses avoided, whichever is higher.`
  line
  line `(2) If any person, who is required under this Act or any rules or regulations made thereunder, to enter`
  line `into an agreement with his client, fails to enter into such agreement, he shall be liable to a penalty of one`
  line `lakh rupees for each day during which the failure continues or five times the amount of profits made or`
  line `losses avoided, whichever is higher.`
  line
  line `(3) If any intermediary registered with the Authority, after having been called upon by the Authority,`
  line `in writing, to redress the grievances of subscribers, fails to redress such grievances within the time`
  line `stipulated by the Authority, he shall be liable to a penalty of not more than one crore rupees or five times`
  line `the amount of profits made or losses avoided, whichever is higher.`
  line
  line `(4) If any person, who is registered under this Act as an intermediary, fails to segregate moneys of the`
  line `client or clients or uses the moneys of a client or clients for self or for any other client, he shall be liable`
  line `to a penalty not exceeding one crore rupees or five times the amount of profits made or losses avoided,`
  line `whichever is higher.`
  line
  line `(5) Whoever fails to comply with any provision of this Act, the rules or the regulations made or the`
  line `directions issued by the Authority under the provisions of this Act for which no separate penalty has been provided, he shall be liable to a penalty which may extend to one crore rupees or five times the amount of`
  line `profits made or losses avoided, whichever is higher.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (20556)
  sectionNo (29)
  orderNo 29
  title `Crediting sums realised by way of penalties to Subscriber Education and Protection Fund.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20556&sectionno=29&orderno=29&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_29_content:
  string
  line `All sums realised by way of penalties under this Act shall be credited to the Subscriber`
  line `Education and Protection Fund established under sub-section (1) of section 41.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (20557)
  sectionNo (30)
  orderNo 30
  title `Power to adjudicate.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20557&sectionno=30&orderno=30&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_30_content:
  string
  line `(1) For the purposes of adjudging under section 28, the Authority shall`
  line `appoint any of its officers not below the rank specified by regulations to be an adjudicating officer for`
  line `holding an inquiry as may be determined by regulations, after giving the person concerned a reasonable`
  line `opportunity of being heard for the purpose of imposing any penalty.`
  line
  line `(2) While holding an inquiry, the adjudicating officer shall have the power to summon and enforce`
  line `the attendance of any person acquainted with the facts and circumstances of the case to give evidence or`
  line `to produce any document which, in the opinion of the adjudicating officer, may be useful for or relevant`
  line `to the subject matter of the inquiry and if, on such inquiry, he is satisfied that the person has failed to`
  line `comply with the provisions of section 28, he may recommend such penalty as he thinks fit in accordance`
  line `with the provisions of that section, to the member in charge of investigation and surveillance.`
  line
  line `(3) The penalty shall be imposed by a member other than the member in charge of investigation and`
  line `surveillance:`
  line
  line `Provided that while adjudging the quantum of penalty under section 28, the member shall have due`
  line `regard to the following factors, namely:—`
  line
  line `(a) amount of disproportionate gain or unfair advantage, wherever quantifiable, made as a result`
  line `of the default;`
  line
  line `(b) amount of loss caused to a subscriber or group of subscribers; and`
  line
  line `(c) the repetitive nature of the default.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (20558)
  sectionNo (31)
  orderNo 31
  title `Attachment of assets and supersession of management of intermediary.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20558&sectionno=31&orderno=31&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_31_content:
  string
  line `(1) Any person`
  line `aggrieved may apply to the Authority for an interim measure of protection in respect of any of the`
  line `following matters, namely:–`
  line
  line `(a) the retention, preservation, interim custody or sale of any asset or property which is regulated`
  line `by the provisions of this Act;`
  line
  line `(b) securing any pension fund, moneys and other assets and properties owned by or under the`
  line `control of the pension fund;`
  line
  line `(c) interim injunction or appointment of an administrator; and`
  line
  line `(d) such other interim measures as may appear to the Authority to be just and necessary,`
  line
  line `and the Authority shall have power to make such orders including an order for attachment of assets of the`
  line `pension fund as it deems fit in this regard.`
  line
  line `(2) Where, on a complaint received by the Authority or suo motu, the Authority, after conducting an`
  line `inquiry, comes to a conclusion that the governing board or board of directors, by whatever name called, or`
  line `the persons in control of any intermediary to the extent regulated under this Act are indulging in any`
  line `activity which is in contravention of the provisions of this Act or regulations, it may supersede the`
  line `governing board or board of directors or management of the intermediary in accordance with the`
  line `provisions of the regulations.`
  line
  line `(3) In case the governing board or board of directors or management of an intermediary is superseded`
  line `under sub-section (2), the Authority may appoint an Administrator to manage the affairs of the`
  line `intermediary in accordance with the provisions contained in the regulations.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (20559)
  sectionNo (32)
  orderNo 32
  title Offences.
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20559&sectionno=32&orderno=32&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_32_content:
  string
  line `(1) Without prejudice to any award of penalty by the member under this Act, if any`
  line `person contravenes or attempts to contravene or abets the contravention of the provisions of this Act or of any rules or regulations made thereunder, he shall be punishable with imprisonment for a term which may`
  line `extend to ten years, or with fine, which may extend to twenty-five crore rupees or with both.`
  line
  line `(2) If any person fails to pay the penalty imposed by the member or fails to comply with any of the`
  line `directions or orders issued by the member, he shall be punishable with imprisonment for a term which`
  line `shall not be less than one month but which may extend to ten years, or with fine, which may extend to`
  line `twenty-five crore rupees, or with both.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (20560)
  sectionNo (33)
  orderNo 33
  title `Power to grant immunity.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20560&sectionno=33&orderno=33&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_33_content:
  string
  line `(1) The Central Government may, on the recommendation by the`
  line `Authority, if satisfied, that any person, who is alleged to have violated any of the provisions of this Act or`
  line `the rules or the regulations made thereunder, has made a full and true disclosure in respect of alleged`
  line `violation, grant to such person, subject to such conditions as it may think fit to impose, immunity from`
  line `prosecution for any offence under this Act, or the rules or the regulations made thereunder and also from`
  line `the imposition of any penalty under this Act with respect to the alleged violation:`
  line
  line `Provided that no such immunity shall be granted by the Central Government in cases where the`
  line `proceedings for the prosecution for any such offence have been instituted before the date of receipt of`
  line `application for grant of such immunity:`
  line
  line `Provided further that the recommendation of the Authority under this sub-section shall not be binding`
  line `upon the Central Government.`
  line
  line `(2) An immunity granted to a person under sub-section (1) may, at any time, be withdrawn by the`
  line `Central Government, if it is satisfied that such person had, in the course of the proceedings, not complied`
  line `with the condition on which the immunity was granted or had given false evidence, and thereupon such`
  line `person may be tried for the offence with respect to which the immunity was granted or for any other`
  line `offence of which he appears to have been guilty in connection with the contravention and shall also`
  line `become liable to the imposition of any penalty under this Act to which such person would have been`
  line `liable, had no such immunity been granted.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (20561)
  sectionNo (34)
  orderNo 34
  title `Exemption from tax on wealth, income, profits and gains.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20561&sectionno=34&orderno=34&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_34_content:
  string
  line `Notwithstanding anything`
  line `contained in–`
  line
  line `(i) the Wealth-tax Act, 1957 (27 of 1957);`
  line
  line `(ii) the Income-tax Act, 1961 (43 of 1961) ; or`
  line
  line `(iii) any other enactment for the time being in force relating to tax on wealth, income, profits or`
  line gains,
  line
  line `the Authority shall not be liable to pay wealth-tax, income-tax or any other tax in respect of its wealth,`
  line `income, profits or gains derived.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (20562)
  sectionNo (35)
  orderNo 35
  title `Cognizance of offences by court.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20562&sectionno=35&orderno=35&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_35_content:
  string
  line `(1) No court shall take cognizance of any offence punishable`
  line `under this Act or any rules or regulations made thereunder, save on a complaint made by the Authority.`
  line
  line `(2) No court inferior to that of a Court of Session shall try any offence punishable under this Act.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (20563)
  sectionNo (36)
  orderNo 36
  title `Appeal to Securities Appellate Tribunal.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20563&sectionno=36&orderno=36&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_36_content:
  string
  line `(1) Any person aggrieved by an order made by the`
  line `Authority or by an adjudicating officer under this Act may prefer an appeal before the Securities`
  line `Appellate Tribunal which shall have jurisdiction over the matter.`
  line
  line `(2) Every appeal under sub-section (1) shall be filed within a period of forty-five days from the date`
  line `of receipt of the order appealed against and it shall be in such form and manner and shall be accompanied`
  line `by such fee as may be prescribed:`
  line
  line `Provided that the Securities Appellate Tribunal may entertain an appeal after the expiry of the said`
  line `period, if it is satisfied that there was sufficient cause for not preferring the appeal within that period.`
  line
  line `(3) On receipt of an appeal under sub-section (1), the Securities Appellate Tribunal may, after giving`
  line `the parties to the appeal, an opportunity of being heard, pass such orders thereon as it thinks fit,`
  line `confirming, modifying or setting aside the order appealed against.`
  line
  line `(4) The Securities Appellate Tribunal shall send a copy of every order made by it to the Authority, the`
  line `parties to the appeal and to the adjudicating officers concerned.`
  line
  line `(5) The appeal filed before the Securities Appellate Tribunal under sub-section (1) shall be dealt with`
  line `by it as expeditiously as possible and endeavour shall be made by it to dispose of the appeal finally within`
  line `six months from the date on which the appeal is presented to it.`
  line
  line `(6) Without prejudice to the provisions of sections 15T and 15U of the Securities and Exchange`
  line `Board of India Act, 1992 (15 of 1992), the Securities Appellate Tribunal shall deal with an appeal under`
  line `this section in accordance with such procedure as may be prescribed.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (20564)
  sectionNo (37)
  orderNo 37
  title `Civil Court not to have jurisdiction.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20564&sectionno=37&orderno=37&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_37_content:
  string
  line `No civil court shall have jurisdiction to entertain any suit`
  line `or proceeding in respect of any matter which an adjudicating officer appointed under this Act or a`
  line `Securities Appellate Tribunal is empowered by or under this Act to determine and no injunction shall be`
  line `granted by any court or other authority in respect of any action taken or to be taken in pursuance of any`
  line `power conferred by or under this Act.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (20565)
  sectionNo (38)
  orderNo 38
  title `Appeal to Supreme Court.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20565&sectionno=38&orderno=38&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_38_content:
  string
  line `Any person aggrieved by any decision or order of the Securities`
  line `Appellate Tribunal under this Act may file an appeal to the Supreme Court within sixty days from the`
  line `date of communication of the decision or order of the Securities Appellate Tribunal to him on any`
  line `question of law arising out of such order:`
  line
  line `Provided that the Supreme Court may, if it is satisfied that the appellant was prevented by sufficient`
  line `cause from filing the appeal within the said period, allow it to be filed within a further period not`
  line `exceeding sixty days.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (20566)
  sectionNo (39)
  orderNo 39
  title `Grants by Central Government.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20566&sectionno=39&orderno=39&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_39_content:
  string
  line `The Central Government may, after due appropriation made`
  line `by Parliament by law in this behalf, make to the Authority grants of such sums of money as that`
  line `Government may think fit for being utilised for the purposes of this Act.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (20567)
  sectionNo (40)
  orderNo 40
  title `Constitution of Pension Regulatory and Development Fund.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20567&sectionno=40&orderno=40&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_40_content:
  string
  line `(1) There shall be constituted a`
  line `fund to be called the Pension Regulatory and Development Fund and there shall be credited thereto—`
  line
  line `(a) all Government grants, fees and charges received by the Authority;`
  line
  line `(b) all sums received by the Authority from such other source as may be decided upon by the`
  line `Central Government.`
  line
  line `(2) The Fund shall be applied for meeting—`
  line
  line `(a) the salaries, allowances and other remuneration of the Chairperson and other members and`
  line `officers and other employees of the Authority;`
  line
  line `(b) other expenses of the Authority in connection with the discharge of its functions and for the`
  line `purposes of this Act.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (20568)
  sectionNo (41)
  orderNo 41
  title `Constitution of Subscriber Education and Protection Fund.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20568&sectionno=41&orderno=41&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_41_content:
  string
  line `(1) The Authority shall establish`
  line `a fund to be called the Subscriber Education and Protection Fund.`
  line
  line `(2) There shall be credited to the Subscriber Education and Protection Fund the following amounts,`
  line `namely:—`
  line
  line `(a) grants and donations given to the Subscriber Education and Protection Fund by the Central`
  line `Government, State Governments, companies or any other institutions for the purposes of the`
  line `Subscriber Education and Protection Fund;`
  line
  line `(b) the interest or other income received out of the investments made from the Subscriber`
  line `Education and Protection Fund;`
  line
  line `(c) the sums realised by way of penalties by the Authority under section 28.`
  line
  line `(3) The Subscriber Education and Protection Fund shall be administered and utilised by the Authority`
  line `for protection of the interests of subscribers in accordance with regulations made for the purpose.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (20569)
  sectionNo (42)
  orderNo 42
  title `Accounts and audit.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20569&sectionno=42&orderno=42&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_42_content:
  string
  line `(1) The Authority shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts in such form as may be prescribed by the Central`
  line `Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Authority shall be audited by the Comptroller and Auditor-General of India at`
  line `such intervals as may be specified by him and any expenditure incurred in connection with such audit`
  line `shall be payable by the Authority to the Comptroller and Auditor-General.`
  line
  line `(3) The Comptroller and Auditor-General of India and any other person appointed by him in`
  line `connection with the audit of the accounts of the Authority shall have the same rights, privileges and`
  line `authority in connection with such audit as the Comptroller and Auditor-General generally has in`
  line `connection with the audit of the Government accounts and, in particular, shall have the right to demand`
  line `the production of books, accounts, connected vouchers and other documents and papers and to inspect`
  line `any of the offices of the Authority.`
  line
  line `(4) The accounts of the Authority as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf, together with the audit-report thereon, shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (20570)
  sectionNo (43)
  orderNo 43
  title `Power of Central Government to issue directions.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20570&sectionno=43&orderno=43&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_43_content:
  string
  line `(1) Without prejudice to the foregoing`
  line `provisions of this Act, the Authority shall, in exercise of its powers or the performance of its functions`
  line `under this Act, be bound by such directions on questions of policy, other than those relating to technical`
  line `and administrative matters, as the Central Government may give, in writing to it, from time to time:`
  line
  line `Provided that the Authority shall, as far as practicable, be given an opportunity to express its views`
  line `before any direction is given under this sub-section.`
  line
  line `(2) The decision of the Central Government, whether a question is one of policy or not, shall be final.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (20571)
  sectionNo (44)
  orderNo 44
  title `Power of Central Government to supersede Authority.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20571&sectionno=44&orderno=44&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_44_content:
  string
  line `(1) If at any time the Central`
  line `Government is of the opinion that`
  line
  line `(a) on account of circumstances beyond the control of the Authority, it is unable to discharge the`
  line `functions or perform the duties imposed on it by or under the provisions of this Act; or`
  line
  line `(b) the Authority has persistently defaulted in complying with any direction issued by the Central`
  line `Government that the Central Government is entitled to issue under this Act or in the discharge of the`
  line `functions or performance of the duties imposed on it by or under the provisions of this Act and as a`
  line `result of such default the financial position of the Authority or the administration of the Authority has`
  line `deteriorated; or`
  line
  line `(c) circumstances exist which render it necessary in the public interest so to do,`
  line
  line `the Central Government may, by notification and for reasons to be specified therein, supersede the`
  line `Authority for such period, not exceeding six months, as may be specified in the notification:`
  line
  line `Provided that before issuing any such notification, the Central Government shall give a reasonable`
  line `opportunity to the Authority to make representations against the proposed supersession and shall consider`
  line `the representations, if any, of the Authority.`
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the Authority,`
  line
  line `(a) the Chairperson and other members shall, as from the date of supersession, vacate their`
  line `offices as such;`
  line
  line `(b) all the powers, functions and duties which may, by or under the provisions of this Act, be`
  line `exercised or discharged by or on behalf of the Authority shall, until the Authority is reconstituted`
  line `under sub-section (3), be exercised and discharged by the Central Government; and`
  line
  line `(c) all properties owned or controlled by the Authority shall, until the Authority is reconstituted`
  line `under sub-section (3), vest in the Central Government.`
  line
  line `(3) On or before the expiration of the period of supersession specified in the notification issued under`
  line `sub-section (1), the Central Government shall reconstitute the Authority.`
  line
  line `(4) The Central Government shall, as soon as may be, cause a copy of the notification issued under`
  line `sub-section (1) and a full report of any action taken by it, to be laid before each House of Parliament.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (20572)
  sectionNo (45)
  orderNo 45
  title `Establishment of Pension Advisory Committee.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20572&sectionno=45&orderno=45&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_45_content:
  string
  line `(1) The Authority may, by notification,`
  line `establish with effect from such date as it may specify in the notification, a Committee to be known as the`
  line `Pension Advisory Committee.`
  line
  line `(2) The Pension Advisory Committee shall consist of not more than twenty-five members, excluding`
  line `ex officio members, to represent the interests of employees' associations, subscribers, commerce and`
  line `industry, intermediaries, and organisations engaged in pension research.`
  line
  line `(3) The Chairperson and the members of the Authority shall be the ex officio Chairperson and ex`
  line `officio members of the Pension Advisory Committee.`
  line
  line `(4) The objects of the Pension Advisory Committee shall be to advise the Authority on matters`
  line `relating to the making of the regulations under section 52.`
  line
  line `(5) Without prejudice to the provisions of sub-section (4), the Pension Advisory Committee may`
  line `advise the Authority on such matters as may be referred to it by the Authority and also on such matters as`
  line `the Committee may deem fit.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (20573)
  sectionNo (46)
  orderNo 46
  title `Furnishing of returns, etc., to Central Government.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20573&sectionno=46&orderno=46&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_46_content:
  string
  line `(1) The Authority shall furnish to the`
  line `Central Government at such time and in such form and manner as may be prescribed, or as the Central`
  line `Government may direct to furnish such returns, statements and other particulars in regard to any proposed`
  line `or existing programme for the promotion and development of the pension industry as the Central`
  line `Government may, from time to time, require.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Authority shall, within nine months`
  line `after the close of each financial year, submit to the Central Government a report giving a true and full`
  line `account of its activities including the activities for promotion and development of schemes of pension`
  line `funds regulated under this Act during the previous financial year.`
  line
  line `(3) Copies of the reports received under sub-section (2) shall be laid, as soon as may be, after they are`
  line `received, before each House of Parliament.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (20574)
  sectionNo (47)
  orderNo 47
  title `Members, officers and employees of Authority to be public servants.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20574&sectionno=47&orderno=47&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_47_content:
  string
  line `The Chairperson and`
  line `other members and officers and other employees of the Authority shall be deemed, when acting or`
  line `purporting to act in pursuance of any of the provisions of this Act, to be public servants within the`
  line `meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (20575)
  sectionNo (48)
  orderNo 48
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20575&sectionno=48&orderno=48&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_48_content:
  string
  line `No suit, prosecution or other legal proceedings shall`
  line `lie against the Central Government or the Authority or any officer of Central Government or any member,`
  line `officer or other employees of the Authority for anything which is in good faith done or intended to be`
  line `done under this Act or the rules or regulations made thereunder.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (20576)
  sectionNo (49)
  orderNo 49
  title `Delegation of powers.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20576&sectionno=49&orderno=49&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_49_content:
  string
  line `(1) The Authority may, by general or special order in writing, delegate`
  line `to any member, officer of the Authority or any other person subject to such conditions, if any, as may be`
  line `specified in the order, such of its powers and functions under this Act (except the powers under section`
  line `52) as it may deem necessary.`
  line
  line `(2) The Authority may, by a general or special order in writing, also form committees of the members`
  line `and delegate to them the powers and functions of the Authority as may be specified by the regulations.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (20577)
  sectionNo (50)
  orderNo 50
  title `Offences by companies.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20577&sectionno=50&orderno=50&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_50_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed was in charge of, and was responsible`
  line `to, the company for the conduct of the business of the company, as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act if he proves that the offence was committed without his knowledge or`
  line `that he has exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to, any neglect on the part of any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of the offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.—For the purposes of this section,—`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of`
  line `individuals; and`
  line
  line `(b) "director, in relation to a firm", means a partner in the firm.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_50_a:
  sectionId (50606)
  sectionNo 50A
  orderNo 51
  title `Powers of Authority not to apply to International Financial Services Centre.`
  content obj_root_law_sections_50_a_content
  footnotes `1. Ins. by Act 50 of 2019, s. 33 and the second Schedule (w.e.f. 1-10-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=50606&sectionno=50A&orderno=51&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_50_a_content:
  string
  line `^1[50A. Powers of Authority not to apply to International Financial Services Centre.--`
  line `Notwithstanding anything contained in any other law for the time being in force, the powers exercisable`
  line `by the Authority under this Act,--`
  line
  line `(a) shall not extend to an International Financial Services Centre set up under sub-section (1) of`
  line `section 18 of the Special Economic Zones Act, 2005 (28 of 2005);`
  line
  line `(b) shall be exercisable by the International Financial Services Centres Authority established`
  line `under sub-section (1) of section 4 of the International Financial Services Centres Authority Act, 2019,`
  line
  line `in so far as regulation of financial products, financial services and financial institutions that are permitted`
  line `in the International Financial Services Centres are concerned.]`
obj_root_law_sections_51:
  sectionId (20578)
  sectionNo (51)
  orderNo 52
  title `Power to make rules.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20578&sectionno=51&orderno=52&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_51_content:
  string
  line `(1) The Central Government may, by notification, make rules for`
  line `carrying out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:`
  line
  line `(a) the salary and allowances payable to and the other conditions of service of the Chairperson`
  line `and whole-time members under sub-section (3) of section 5;`
  line
  line `(b) the allowances payable to part-time members under sub-section (4) of section 5;`
  line
  line `(c) the additional functions which may be performed by the Authority under clause (p) of`
  line `sub-section (2) of section 14;`
  line
  line `(d) any other matter in respect of which the Authority may exercise the powers of a civil court`
  line `under clause (v) of sub-section (3) of section 14;`
  line
  line `(e) the procedure to be followed by the authorised officer under sub-section (10) of section 17;`
  line
  line `(f) the form and manner in which an appeal may be filed before the Securities Appellate`
  line `Tribunal and the fee which shall accompany such appeal, under sub-section (2) of section 36;`
  line
  line `(g) the procedure to be followed by the Securities Appellate Tribunal in dealing with an appeal,`
  line `under sub-section (6) of section 36;`
  line
  line `(h) the form in which annual statement of accounts shall be maintained by the Authority under`
  line `sub-section (1) of section 42;`
  line
  line `(i) the time within which and the form and manner in which returns and reports are to be made`
  line `by the Authority to the Central Government under sub-section (1) of section 46;`
  line
  line `(j) any other matter which is to be, or may be, prescribed, or in respect of which provision is to`
  line `be made, by rules.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (20579)
  sectionNo (52)
  orderNo 53
  title `Power to make regulations.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20579&sectionno=52&orderno=53&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_52_content:
  string
  line `(1) The Authority may, by notification, make regulations`
  line `consistent with this Act and the rules made there under for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:`
  line
  line `(a) the time and places of meetings of the Authority and the procedure to be followed at such`
  line `meetings (including the quorum at such meetings) under sub-section (1) of section 9;`
  line
  line `(b) the terms and other conditions of service of the officers and other employees of the Authority`
  line `under sub-section (2) of section 11;`
  line
  line `(c) the regulations to be made by the Authority in respect of pension schemes referred to in clause`
  line `(b) of sub-section (1) of section 12 and the time within which such schemes should conform to the`
  line `regulations, made under sub-section (2) of that section;`
  line
  line `(d) the establishing of mechanisms for redressing grievances of subscribers under clause (f) of`
  line `sub-section (2) of section 14;`
  line
  line `(e) the form and manner in which books of account shall be maintained and statement of accounts`
  line `shall be rendered by intermediaries under clause (n) of sub-section (2) of section 14;`
  line
  line `(f) amendment to the National Pension System referred to in sub-section (1) of section 20;`
  line
  line `(g) the conditions of its purpose, frequency and limits for withdrawals from individual pension`
  line `account referred to in clause (b) of sub-section (2) of section 20;`
  line
  line `(h) the conditions subject to which the subscriber shall exit from the National Pension System`
  line `referred to in clause (h) of sub-section (2) of section 20;`
  line
  line `(i) the conditions subject to which the subscriber shall purchase an annuity referred to in clause (i)`
  line `of sub-section (2) of section 20;`
  line
  line `(j) the duties and functions of central recordkeeping agency under sub-section (2) of section 21;`
  line
  line `(k) the determination of compensation of fair value of the regulated assets payable to central`
  line `recordkeeping agency under proviso to sub-section (3) of section 21;`
  line
  line `(l) the manner of receiving contributions and instructions and transmitting them to the Trustee`
  line `Bank or central recordkeeping agency, as the case may be, and paying out the benefits to the`
  line `subscribers, under sub-section (1), and the regulations governing functioning of points of presence`
  line `under sub-section (2) of section 22;`
  line
  line `(m) the manner in which a pension fund may receive contributions, accumulate them and make`
  line `payments to the subscriber under sub-section (1), the number of pension funds under sub-section (2),`
  line `the functioning of the pension fund under sub-section(3), and the manner of managing the schemes by`
  line `the pension fund under sub-section (4) of section 23;`
  line
  line `(n) the form and manner in which an application for grant of certificate of registration shall be`
  line `made and the fee which shall accompany such application under sub-section (2) of section 27;`
  line
  line `(o) the conditions subject to which a certificate of registration may be granted to an intermediary`
  line `under sub-section (3) of section 27;`
  line
  line `(p) the procedure and manner of suspension or cancellation of certificate of registration of`
  line `intermediaries under sub-section (4) of section 27;`
  line
  line `(q) the procedure for holding inquiry by an adjudicating officer under sub-section (1) of`
  line `section 30;`
  line
  line `(r) the supersession of the governing board or board of directors of the intermediary under`
  line `sub-section (2) of section 31;`
  line
  line `(s) the management of affairs of the intermediary by an Administrator under sub-section (3) of`
  line `section 31;`
  line
  line `(t) the manner of administering and utilising the Subscriber Education and Protection Fund under`
  line `sub-section (3) of section 41;`
  line
  line `(u) the delegation of powers and functions of the Authority to committees under sub-section (2)`
  line `of section 49;`
  line
  line `(v) establishment, duties and functioning of the National Pension System Trust;`
  line
  line `(w) any other matter which is required to be or may be specified by regulations or in respect of`
  line `which provision is to be or may be made by regulations.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (20580)
  sectionNo (53)
  orderNo 54
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20580&sectionno=53&orderno=54&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_53_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (20581)
  sectionNo (54)
  orderNo 55
  title `Power to remove difficulties.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20581&sectionno=54&orderno=55&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_54_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear it to be necessary for removing the`
  line `difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of five years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (20582)
  sectionNo (55)
  orderNo 56
  title `Application of other laws not barred.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20582&sectionno=55&orderno=56&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_55_content:
  string
  line `The provisions of this Act shall be in addition to and`
  line `not in derogation of the provisions of any other law for the time being in force.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (20583)
  sectionNo (56)
  orderNo 57
  title Savings.
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00007_201323_1517807327819&sectionId=20583&sectionno=56&orderno=57&orgactid=AC_CEN_2_45_00007_201323_1517807327819
obj_root_law_sections_56_content:
  string
  line `Anything done or any action taken by the Interim Pension Fund Regulatory and`
  line `Development Authority and Central Government under the Resolutions of the Government of India in the`
  line `Ministry of Finance number F. No. 5/7/2003-ECB & PR, dated the 10th October, 2003 and`
  line `F.No.1(6)2007-PR, dated the 14th November, 2008 and notification number F. No. 5/7/2003-ECB & PR,`
  line `dated the 22nd December, 2003, shall be deemed to have been done or taken under the corresponding`
  line `provisions of this Act.`
obj_root_law_sections_56_footnotes:
  string
  line
