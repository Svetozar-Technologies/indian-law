obj_root_law:
  slug the-pension-fund-regulatory-and-development-authority-act-2013
  handle (2117)
  collectionHandle 123456789/1362
  title `The Pension Fund Regulatory and Development Authority Act, 2013`
  actNumber (23)
  enactmentDate 2013-09-18
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2117`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `पेंशन निधि विनियामक और विकासप्राधिकरण अधिनियम, 2013`
  actYear (2013)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to provide for the establishment of an Authority to promote old age income security by establishing, developing and regulating pension funds, to protect the interests of subscribers to schemes of pension funds and for matters connected therewith or incidental thereto.`
  enforcementDate 01-02-2014
  notification `1st February, 2014, vide Notification No. S.O. 302 (E), dated 1st February, 2014, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T19:43:42.428Z`
  translations obj_root_law_translations
