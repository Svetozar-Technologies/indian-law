  object
  (str slug) (str the-inter-services-organisations-command-control-and-discipline-act-2023)
  (str handle) (str 19976)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Inter-Services Organisations (Command, Control and Discipline) Act, 2023`)
  (str actNumber) (str 28)
  (str enactmentDate) (str 2023-08-15)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/19976`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `अंतर-सेना संगठन (कमान, नियंत्रण और अनुशासन) अधिनियम, 2023`)
  (str actYear) (str 2023)
  (str ministry) (str `Ministry of Defence`)
  (str department) (str `Department of Military Affairs`)
  (str longTitle) (str `An Act to empower the Commander-in-Chief or the Officer-in-Command of Inter-services Organisations in respect of service personnel who are subject to the Air Force Act, 1950, the Army Act, 1950 and the Navy Act, 1957, who are serving under or attached to his command, for the maintenance of discipline and proper discharge of their duties, and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 10-05-2023)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T09:30:44.525Z`)
  (str translations) obj_root_law_translations
