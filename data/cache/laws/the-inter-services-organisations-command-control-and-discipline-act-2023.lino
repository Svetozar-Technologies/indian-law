obj_root_law:
  slug the-inter-services-organisations-command-control-and-discipline-act-2023
  handle (19976)
  collectionHandle 123456789/1362
  title `The Inter-Services Organisations (Command, Control and Discipline) Act, 2023`
  actNumber (28)
  enactmentDate 2023-08-15
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/19976`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `अंतर-सेना संगठन (कमान, नियंत्रण और अनुशासन) अधिनियम, 2023`
  actYear (2023)
  ministry `Ministry of Defence`
  department `Department of Military Affairs`
  longTitle `An Act to empower the Commander-in-Chief or the Officer-in-Command of Inter-services Organisations in respect of service personnel who are subject to the Air Force Act, 1950, the Army Act, 1950 and the Navy Act, 1957, who are serving under or attached to his command, for the maintenance of discipline and proper discharge of their duties, and for matters connected therewith or incidental thereto.`
  enforcementDate 10-05-2023
  notification undefined
  fetchedAt `2026-05-09T09:30:44.525Z`
  translations obj_root_law_translations
