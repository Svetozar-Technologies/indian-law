obj_root_law_sections_1:
  object
  (str sectionId) (str 33191)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title, extent and commencement.`)
  (str content) (str `(1) This Act may be called the Economic Offences
(Inapplicability of Limitation) Act, 1974.

(2) It extends to the territories to which the Code of Criminal Procedure, 1973 (2 of 1974) applies.

(3) It shall come into force on the 1st day of April, 1974.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00012_197412_1517807319698&sectionId=33191&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00012_197412_1517807319698)
obj_root_law_sections_2:
  object
  (str sectionId) (str 33192)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Chapter XXXVI of the Code of Criminal Procedure, 1973 not to apply to certain offences.`)
  (str content) (str `Nothing in Chapter XXXVI of the Code of Criminal Procedure, 1973 (2 of 1974) shall apply to--

(i) any offence punishable under any of the enactments ^1
[or provisions, if any, thereof] specified
in the Schedule; or

(ii) any other offence, which under the provisions of that Code, may be tried along with such
offence,

and every offence referred to in clause (i) or clause (ii) may be taken cognizance of by the Court having
jurisdiction as if the provisions of that Chapter were not enacted.`)
  (str footnotes) (str `1. Ins. by Act 65 of 1984, s. 10 (w.e.f. 8-10-1984).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00012_197412_1517807319698&sectionId=33192&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00012_197412_1517807319698)
