obj_root_law_sections_1:
  sectionId (19128)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the United Nations (Privileges and Immunities) Act, 1947.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00015_194746_1517807324722&sectionId=19128&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00015_194746_1517807324722
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (19129)
  sectionNo (2)
  orderNo 2
  title `Conferment on United Nations and its representatives and officers and certain privileges and immunities.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00015_194746_1517807324722&sectionId=19129&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00015_194746_1517807324722
obj_root_law_sections_2_content:
  string
  line `(1) Notwithstanding anything to the country contained in any other law, the provisions set`
  line `out in the Schedule to this Act of the Convention on the Privileges and Immunities, adopted by the`
  line `General Assembly of the United Nations on the 13th day of February, 1946, shall have the force of Law`
  line `in India.`
  line
  line `(2) The Central Government may, from time to time, by notification in the Official Gazette, amend`
  line `the Schedule in conformity with any amendments, duly made and adopted, of the provisions of the said`
  line `Convention set out therein.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (19130)
  sectionNo (3)
  orderNo 3
  title `Power to confer certain privileges and immunities on other international organisations and their representatives and officers.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00015_194746_1517807324722&sectionId=19130&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00015_194746_1517807324722
obj_root_law_sections_3_content:
  string
  line `Where in pursuance of any international agreement, convention or`
  line `other instrument it is necessary to accord to any international organisation and its representatives and`
  line `officers privileges and immunities in India similar to those contained in the provisions set out in the`
  line `Schedule, the Central Government may, by notification in the Official Gazette, declare that the provisions`
  line `set out in the schedule shall, subject to such modification, if any it may consider necessary or expedient`
  line `for giving effect to the said agreement, convention or other instrument, apply mutatis mutandis to the`
  line `international organisation specified in the notification and its representatives and officers, and thereupon`
  line `the said provisions shall apply accordingly and, notwithstanding anything to the contrary contained in any`
  line `other law, shall in such application have the force of law in India.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (19131)
  sectionNo (4)
  orderNo 4
  title `Power to make rules.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00015_194746_1517807324722&sectionId=19131&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00015_194746_1517807324722
obj_root_law_sections_4_content:
  string
  line `^1[(1)] The Central Government may ^2[by notification in the Official`
  line `Gazette] make rules for carrying out the purposes of this Act.`
  line
  line `^2[(2) Every rule made under this Act shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule.]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Section 4 renumbered as sub-section (1) thereof by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
  line
  line `2. Ins. by s. 2, ibid. (w.e.f. 15-5-1986).`
