obj_root_law_sections_1:
  sectionId (35708)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35708&sectionno=1&orderno=1&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Bird and Company Limited`
  line `(Acquisition and Transfer of Undertakings and Other Properties ) Act, 1980.`
  line
  line `(2) It shall be deemed to have come into force on the 25th day of October, 1980.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (35709)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35709&sectionno=2&orderno=2&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means the 25th day of October, 1980;`
  line
  line `(b) "Commissioner" means the commissioner of Payments appointed under section 13;`
  line
  line `(c) "Company" means the Bird and Company Limited, being a company as defined in the`
  line `Companies Act, 1956 (1 of 1956), and having its registered office at Chartered Bank Buildings,`
  line `Calcutta-700001, in the State of West Bengal;`
  line
  line `(d) "notification" means a notification published in the Official Gazette;`
  line
  line `(e) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(f) "share" means a share, whether equity or preference, held by the Company in the capital of a`
  line `specified company and includes any such share pledged by the Company with any bank or any other`
  line creditor;
  line
  line `(g) "specified company" means a company specified in Schedule I;`
  line
  line `(h) "specified date", means such date as the Central Government may, for the purposes of any`
  line `provision of this Act, by notification, specify, and different dates may be specified for different`
  line `provisions of this Act;`
  line
  line `(i) words and expressions used herein and not defined but defined in the Companies Act, 1956`
  line `(1 of 1956), shall have the meanings, respectively, assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (35710)
  sectionNo (3)
  orderNo 3
  title `Transfer to, and vesting in, the Central Government of the undertakings of the Company.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35710&sectionno=3&orderno=3&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_3_content:
  string
  line On
  line `the appointed day, the undertakings of the Company and the right, title and interest of the Company in`
  line `relation to its undertakings shall, by virtue of this Act, stand transferred to, and vest in, the Central`
  line Government.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (35711)
  sectionNo (4)
  orderNo 4
  title `Transfer and vesting of shares held by the Company in the specified companies.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35711&sectionno=4&orderno=4&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_4_content:
  string
  line `(1) On the`
  line `appointed day, all the shares held by the Company in the specified companies shall, by virtue of this Act,`
  line `stand transferred to, and vest in, the Central Government.`
  line
  line `(2) The Central Government shall be deemed, on and from the appointed day, to have been registered`
  line `in the Register of Members of the concerned specified company as the holder of each share which stands`
  line `transferred to, and vested in, it by virtue of the provisions of sub-section (1).`
  line
  line `(3) For the removal of doubts, it is hereby declared that the provisions of sub-sections (1) and (2)`
  line `shall not be deemed to affect,--`
  line
  line `(a) any right of a specified company subsisting, immediately before the appointed day, against the`
  line `Company to recover from it any sum of money on the ground that the Company has not paid or`
  line `credited to the specified company the whole or any part of the value of the shares held by it, or on any`
  line `other ground whatsoever; or`
  line
  line `(b) any right of a specified company subsisting, immediately before the appointed day, against the`
  line `Company to receive any payments due from the Company`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (35712)
  sectionNo (5)
  orderNo 5
  title `General effect of vesting.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35712&sectionno=5&orderno=5&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_5_content:
  string
  line `(1) The undertaking of the Company shall be deemed to include all`
  line `assets, rights, leaseholds, powers, authorities and privileges, and all property, movable and immovable,`
  line `including lands, buildings, workshops, stores, instruments, machinery and equipment, cash balances, cash`
  line `on hand, reserve funds, investments, book debts, and all other rights and interests in, or arising out of,`
  line `such property as were immediately before the appointed day in the ownership, possession, power or`
  line `control of the Company, whether within or outside India, and all books of account, registers and other`
  line `documents of whatever nature relating thereto.`
  line
  line `(2) All properties as aforesaid which have vested in the Central Government, whether under section 3`
  line `or section 4, shall, by force of such vesting, be freed and discharged from any trust, obligation, mortgage,`
  line `charge, lien and all other incumbrances affecting them, and any attachment, injunction, decree or order of`
  line `any court or other authority restricting the use of such properties in any manner or appointing any receiver`
  line `in respect of the whole or any part of such properties shall be deemed to have been withdrawn.`
  line
  line `(3) Every mortgagee of any property which has vested under this Act, in the Central Government and`
  line `every person holding any charge, lien or other interest in, or in relation to, any such property, shall give,`
  line `within such time and in such manner as may be prescribed, an intimation to the Commissioner of such`
  line `mortgage, charge, lien or other interest.`
  line
  line `(4) For the removal of doubts, it is hereby declared that the mortgagee of any property referred to in`
  line `sub-section (3) or any other person holding any charge, lien or other interest in, or in relation to, any such`
  line `property shall be entitled to claim, in accordance with his rights and interests, payment of the mortgage`
  line `money or other dues, in whole or in part, out of the amounts specified in section 8, but no such mortgage,`
  line `charge, lien or other interest shall be enforceable against any property which has vested in the Central`
  line Government.
  line
  line `(5) Any licence or other instrument granted to the Company in relation to any undertaking which has`
  line `vested in the Central Government under section 3, at any time before the appointed day and in force`
  line `immediately before that day, shall continue to be in force on and after such day in accordance with its`
  line `tenor in relation to, and for the purposes of, such undertaking and on and from the date of vesting of such`
  line `undertaking under section 7, in a Government company, that Government company shall be deemed to be`
  line `substituted in such licence or other instrument as if such licence or other instrument had been granted to`
  line `such Government company and such Government company shall hold it for the remainder of the period`
  line `for which that company would have held it under the terms thereof.`
  line
  line `(6) If, on the appointed day, any suit, appeal or other proceeding of whatever nature in relation to any`
  line `property which has vested in the Central Government, whether under section 3 or under section 4,`
  line `instituted or preferred by or against the Company is pending, the same shall not abate, be discontinued or`
  line `be, in any way prejudicially affected by reason of the transfer of the undertakings of the Company or of`
  line `anything contained in this Act, but the suit, appeal or other proceeding may be continued, prosecuted or`
  line `enforced by or against the Central Government, or where the undertakings of the Company are directed`
  line `under section 7, to vest in a Government company, by or against such company.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (35713)
  sectionNo (6)
  orderNo 6
  title `Central Government or the Government company not to liable for certain prior liabilities.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35713&sectionno=6&orderno=6&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_6_content:
  string
  line `(1)`
  line `Every liability of the Company in respect of any period prior to the appointed day, shall be the liability of`
  line `the Company and shall be enforceable against it and not against the Central Government, or, where the`
  line `undertakings of the Company are directed, under section 7, to vest in a Government company, against`
  line `such company.`
  line
  line `(2) For the removal of doubts, it is hereby declared that--`
  line
  line `(a) save as otherwise expressly provided in this Act, no liability of Company in relation to its`
  line `undertakings, or in relation to any share held by it in a specified company, in respect of any period`
  line `prior to the appointed day, shall be enforceable against the Central Government, or, where the`
  line `undertakings of the Company are directed under section 7, to vest in a Government company, against`
  line `such company;`
  line
  line `(b) no award, decree or order of any court, tribunal or other authority in relation to the`
  line `undertakings of the Company or in relation to any share held by the Company in a specified company`
  line `passed after the appointed day, in respect of any matter, claim or dispute which arose before that day,`
  line `shall be enforceable against the Central Government, or where the undertakings of the Company are`
  line `directed, under section 7 to vest in a Government company, against such company;`
  line
  line `(c) no liability incurred by the Company before the appointed day, for the contravention of any`
  line `provision of law for the time being in force, shall be enforceable against the Central Government, or,`
  line `where the undertakings of the Company are directed under section 7, to vest in a Government`
  line `company, against such company.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (35776)
  sectionNo (7)
  orderNo 7
  title `Power of Central Government to direct vesting of the undertakings of the Company in a Government c ompany.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35776&sectionno=7&orderno=7&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_7_content:
  string
  line `(1) Notwithstanding anything contained in section 3, the Central Government`
  line `may, if it is satisfied that a Government company is willing to comply with such terms and conditions as`
  line `that Government may think fit to impose, direct, by notification, that the undertakings of the Company`
  line `and the right, title and interest of the Company in relation to its undertakings which have vested in the`
  line
  line `Central Government under section 3, shall, instead of continuing to vest in the Central Government, vest`
  line `in the Government company either on the date of publication of the notification or on such earlier or later`
  line `date (not being a date earlier than the appointed day) as may be specified in the notification.`
  line
  line `(2) Where the right, title and interest of the Company in relation to its undertakings, vest under`
  line `sub-section (1), in a Government company that Government company shall, on and from the date of such`
  line `vesting, be deemed to have become the owner in relation to such undertakings, and all the rights and`
  line `liabilities of the Central Government in relation to such undertakings shall, on and from the date of such`
  line `vesting, be deemed to have become the rights and liabilities, respectively, of that Government company`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (35715)
  sectionNo (8)
  orderNo 8
  title `Payment of amounts to the Company and specified companies.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35715&sectionno=8&orderno=8&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_8_content:
  string
  line `For the transfer to, and`
  line `vesting in, the Central Government, under section 3, of the undertakings of the Company and the right,`
  line `title and interest of the Company in relation to its undertakings there shall be paid by the Central`
  line `Government to the Company in cash and in the manner specified in Chapter VI, an aggregate amount of`
  line `rupees two hundred and eighty-three lakhs.`
  line
  line `(2) For the transfer to, and vesting in, the Central Government, under section 4, of the shares held by`
  line `the Company in the specified companies, there shall be paid by the Central Government to the Company`
  line `in cash and in the manner specified in Chapter VI, an aggregate amount of rupees twenty-seven lakhs.`
  line
  line `(3) The amount specified in sub-section (1) and the amount specified in sub-section (2) shall carry`
  line `simple interest of four per cent. per annum for the period commencing on the appointed day and ending`
  line `on the date on which payment of such amount is made by the Central Government to the Commissioner.`
  line
  line `(4) For the removal of doubts, it is hereby declared that the liabilities of the Company, in relation to`
  line `its undertakings, shall be met , in accordance with the rights and interests of the creditors of the Company,`
  line `from the amounts due to the Company under sub-section (1) and sub-section (2)`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (35716)
  sectionNo (9)
  orderNo 9
  title `Management, etc., of the undertakings of the Company.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35716&sectionno=9&orderno=9&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_9_content:
  string
  line `(1) The general superintendence,`
  line `direction, control and management of the affairs and business of the undertakings of the Company, the`
  line `right, title and interest in relation to which have vested in the Central Government under section 3,`
  line shall,--
  line
  line `(a) where a direction has been made by the Central Government under sub-section (1) of`
  line `section 7, vest, on and from the date specified in such direction, in the Government company`
  line `specified therein;`
  line
  line `(b) where no such direction has been made by the Central Government, vest, on and from the`
  line `appointed day, in one or more Custodians appointed by the Central Government under`
  line `sub-section (2),`
  line
  line `and thereupon the Government company so specified or the Custodian or Custodians so appointed, as the`
  line `case may be, shall be entitled to exercise to the exclusion of all other persons, all such powers and do all`
  line `such things as the Company is authorised to exercise and do in relation to its undertakings.`
  line
  line `(2) The Central Government may appoint an individual or a Government company as the Custodian`
  line `of the undertakings of the Company in relation to which no direction has been made by it under`
  line `sub-section (1) of section 7.`
  line
  line `(3) The Custodian shall receive from the funds of the undertakings of the Company such`
  line `remuneration as the Central Government may fix and shall hold office during the pleasure of the Central`
  line Government.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (35718)
  sectionNo (10)
  orderNo 10
  title `Duty of persons in charge of management of undertakings of the Company to deliver all assets, etc .`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35718&sectionno=10&orderno=10&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_10_content:
  string
  line `(1) On the vesting of the management of the undertakings of the Company in a Government`
  line `company or on the appointment of a Custodian, all persons in charge of the management of the`
  line `undertakings of the Company immediately before such vesting or appointment, shall be bound to deliver`
  line
  line `to such Government company or Custodian, as the case may be, all assets, books of account, registers and`
  line `other documents in their custody relating to the undertakings of the Company.`
  line
  line `(2) The Central Government may issue such directions as it may deem desirable in the circumstances`
  line `of the case to the Government company or the Custodian as to the powers and duties of such Government`
  line `company or Custodian and such Government company or Custodian may also, if it is considered`
  line `necessary so to do, apply to the Central Government at any time for instructions as to the manner in which`
  line `the management of the undertakings of the Company shall be conducted or in relation to any other matter`
  line `arising in the course of such management.`
  line
  line `(3) The Custodian shall maintain an account of the undertakings of the Company in such form and`
  line `manner and under such conditions as may be prescribed and the provisions of the Companies Act, 1956`
  line `(1 of 1956), shall apply to the audit of the account so maintained as they apply to the audit of the accounts`
  line `of a company.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (35775)
  sectionNo (11)
  orderNo 11
  title `Continuance of employees .`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35775&sectionno=11&orderno=11&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_11_content:
  string
  line `(1) Every employee of the Company, employed in connection with`
  line `any undertaking owned by it, shall, on and from the appointed day, become an employee of the Central`
  line `Government, and where such undertaking is vested in a Government company under this Act, become, on`
  line `and from the date of such vesting in such Government company, an employee thereof and shall hold`
  line `office or service under the Central Government or the Government company, as the case may be, with the`
  line `same rights and privileges as to pension, gratuity and other matters as would have been admissible to him`
  line `if there had been no such vesting and shall continue to do so unless and until his employment under the`
  line `Central Government or the Government company, as the case may be, is duly terminated or until his`
  line `remuneration and other conditions of service are duly altered by the Central Government or the`
  line `Government company, as the case may be.`
  line
  line `(2) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947), or in any`
  line `other law for the time being in force, the transfer of the services of any officer or other person employed`
  line `in any undertaking owned by the Company to the Central Government or the Government company shall`
  line `not entitle such officer or other employee to any compensation under this Act or any other law for the`
  line `time being in force and no such claim shall be entertained by any court, tribunal or other authority.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (35719)
  sectionNo (12)
  orderNo 12
  title `Provident fund and other funds.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35719&sectionno=12&orderno=12&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_12_content:
  string
  line `(1) Where the Company has established a provident fund,`
  line `superannuation fund, welfare fund or other fund for the benefit of the person employed in any of the`
  line `undertakings of the Company, the monies relatable to the employee, whose services have become`
  line `transferred by or under this Act, to the Central Government or the Government company, shall, out of the`
  line `monies standing, on the appointed day, to the credit of such provident, superannuation, welfare or other`
  line `fund, stand transferred to , and vest in, the Central Government or the Government company, as the case`
  line `may be.`
  line
  line `(2) The monies which stand transferred under sub-section (1) to the Central Government or the`
  line `Government company, as the case may be, shall be dealt with by that Government or the Government`
  line `company in such manner as may be prescribed.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (35720)
  sectionNo (13)
  orderNo 13
  title `Appointment of Commissioner of Payments.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35720&sectionno=13&orderno=13&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_13_content:
  string
  line `(1) The Central Government shall, for the`
  line `purpose of disbursing the amounts payable to the Company under section 8, by notification, appoint a`
  line `Commissioner of Payments.`
  line
  line `(2) The Central Government may appoint such other persons as it may think fit to assist the`
  line `Commissioner and thereupon the Commissioner may authorise one or more of such persons also to`
  line `exercise all or any of the powers exercisable by him under this Act and different persons may be`
  line `authorised to exercise different powers.`
  line
  line `(3) Any person authorised by the Commissioner to exercise any of the powers exercisable by the`
  line `Commissioner may exercise those powers in the same manner and with the same effect as if they have`
  line `been conferred on that person directly by this Act and not by way of authorisation.`
  line
  line `(4) The salaries and allowances of the Commissioner and other persons appointed under this section`
  line `shall be defrayed out of the Consolidated Fund of India.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (35721)
  sectionNo (14)
  orderNo 14
  title `Payment by Central Government to the Commissioner.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35721&sectionno=14&orderno=14&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_14_content:
  string
  line `(1) The Central Government`
  line `shall, within thirty days from the specified date, pay, in cash, to the Commissioner, for payment to the`
  line `Company the amounts specified in section 8.`
  line
  line `(2) A deposit account shall be opened by the Central Government in favour of the Commissioner, in`
  line `the Public Account of India, and every amount paid under this Act to the Commissioner shall be`
  line `deposited by him to the credit of the said deposit account and the said deposit account shall be operated`
  line `by the Commissioner.`
  line
  line `(3) Records shall be maintained by the Commissioner in respect of the undertakings of the Company`
  line `and the shares held by it in the specified companies, in relation to which payment has been made to him`
  line `under this Act.`
  line
  line `(4) The interest accruing on the amount standing to the credit of the deposit account referred to in`
  line `sub-section (2) shall enure to the benefit of the Company.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (35722)
  sectionNo (15)
  orderNo 15
  title `Certain powers of Central Government or Government company.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35722&sectionno=15&orderno=15&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_15_content:
  string
  line `(1) The Central`
  line `Government or the Government company, as the case may be, shall be entitled to receive, up to the`
  line `specified date, to the exclusion of all other persons, any money due to the Company, or the Government`
  line `company, and realised after the appointed day, notwithstanding that the realisation pertains to a period`
  line `prior to the appointed day.`
  line
  line `(2) The Central Government or the Government company, as the case may be, may make a claim to`
  line `the Commissioner with regard to every payment made by it after the appointed day for discharging any`
  line `liability of the Company in relation to any period prior to the appointed day; and every such claim shall`
  line `have priority in accordance with the priorities attaching, under this Act, to the matter in relation to which`
  line `such liability has been discharged by the Central Government or the Government company.`
  line
  line `(3) Save as otherwise provided in this Act, the liabilities of the Company in respect of any transaction`
  line `prior to the appointed day, which have not been discharged on or before the specified date, shall be the`
  line `liabilities of the company`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (35723)
  sectionNo (16)
  orderNo 16
  title `Claims to be made to the Commissioner.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35723&sectionno=16&orderno=16&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_16_content:
  string
  line `Every person having a claim against the Company`
  line `shall prefer such claim before the Commissioner within thirty days from the specified date:`
  line
  line `Provided that if the Commissioner is satisfied that the claimant was prevented by sufficient cause`
  line `from preferring the claim within the said period of thirty days, he may entertain the claim within a further`
  line `period of thirty days and not thereafter`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (35724)
  sectionNo (17)
  orderNo 17
  title `Priority of claims.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35724&sectionno=17&orderno=17&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_17_content:
  string
  line `The claims arising out of the matters specified in the Schedule II shall have`
  line `priorities in accordance with the following principles namely:--`
  line
  line `(a) Category I shall have precedence over all other categories and Category II shall have`
  line `precedence over Category III, and so on;`
  line
  line `(b) the claims specified in each of the categories, shall rank equally and be paid in full, but, if the`
  line `amount is insufficient to meet such claims in full, they shall abate in equal proportions and be paid`
  line accordingly;
  line
  line `(c) the question of discharging any liability with regard to a matter specified in a lower category`
  line `shall arise only if a surplus is left after meeting all the liabilities specified in the immediately higher`
  line category
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (35725)
  sectionNo (18)
  orderNo 18
  title `Examination of claims.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35725&sectionno=18&orderno=18&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_18_content:
  string
  line `(1) On receipt of the claims made under section 16, the Commissioner`
  line `shall arrange the claims in the order of priorities specified in the Schedule II and examine the same in`
  line `accordance with such order of priorities.`
  line
  line `(2) If, on an examination of the claims, the Commissioner is of opinion that the amount paid to him`
  line `under this Act is not sufficient to meet the liabilities specified in any lower category, he shall not be`
  line `required to examine the claims in respect of such lower category.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (35726)
  sectionNo (19)
  orderNo 19
  title `Admission or rejection of claims.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35726&sectionno=19&orderno=19&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_19_content:
  string
  line `(1) After examining the claims with reference to the`
  line `priorities set out in the Schedule II, the Commissioner shall fix a certain date on or before which every`
  line `claimant shall file the proof of his claim or be excluded from the benefit of the disbursements made by the`
  line Commissioner.
  line
  line `(2) Not less than fourteen days notice of the date so fixed shall be given by advertisement in one`
  line `issue of any daily newspaper in the English language and in one issue of such daily newspaper in the`
  line `regional language as the Commissioner may consider suitable, and every such notice shall call upon the`
  line `claimant to file the proof of his claim with the Commissioner within the time specified in the`
  line advertisement.
  line
  line `(3) Every claimant who fails to file the proof of his claim within the time specified by the`
  line `Commissioner shall be excluded from the disbursements made by the Commissioner.`
  line
  line `(4) The commissioner shall, after such investigation as may, in his opinion, be necessary and after`
  line `giving the Company an opportunity of refuting the claim and after giving the claimant a reasonable`
  line `opportunity of being heard, by order in writing, admit or reject the claim in whole or in part.`
  line
  line `(5) The Commissioner shall have the power to regulate his own procedure in all matters arising out of`
  line `the discharge of his functions, including the place or places at which he may hold his sittings and shall,`
  line `for the purpose of making an investigation under this Act, have the same powers as are vested in a civil`
  line `court under the Code of Civil Procedure, 1908 (5 of 1908), while trying a suit, in respect of the following`
  line `matters, namely:--`
  line
  line `(a) the summoning and enforcing the attendance of any witness and examining him on oath;`
  line
  line `(b) the discovery and production of any document or other material object producible as`
  line evidence;
  line
  line `(c) the reception of evidence on affidavits;`
  line
  line `(d) the issuing of any commission for the examination of witnesses.`
  line
  line `(6) Any investigation before the Commissioner shall be deemed to be a judicial proceeding within the`
  line `meaning of sections 193 and 228 of the Indian Penal Code ( 45 of 1860 ) and the Commissioner shall be`
  line `deemed to be a civil court for the purposes of section 195 and Chapter XXVI of the Code of Criminal`
  line `Procedure, 1973 ( 2 of 1974 ).`
  line
  line `(7) A claimant, who is dissatisfied with the decision of the Commissioner, may prefer an appeal`
  line `against the decision to the principal civil court of original jurisdiction within the local limits of whose`
  line `jurisdiction the registered office of the Company is situated:`
  line
  line `Provided that where a person who is a Judge of a High Court is appointed to be the Commissioner,`
  line `such appeal shall lie to the High Court at Calcutta, and such appeal shall be heard and disposed of by not`
  line `less than two Judges of that High Court.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (35727)
  sectionNo (20)
  orderNo 20
  title `Disbursement of money by Commissioner to claimants.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35727&sectionno=20&orderno=20&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_20_content:
  string
  line `After admitting a claim under`
  line `this Act, the amount due in respect of such claim shall be paid by the Commissioner to the person or`
  line `persons to whom such amount is due, and, on such payment, the liability of the Company in respect of`
  line `such claim shall stand discharged.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (35728)
  sectionNo (21)
  orderNo 21
  title `Disbursement of amounts to the Company and possession of certain machinery, equipment, etc.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35728&sectionno=21&orderno=21&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_21_content:
  string
  line `(1) If, out of the monies paid to him in relation to the undertakings of the Company, there is a`
  line `balance left after meeting the liabilities as specified in the Schedule II, the Commissioner shall disburse`
  line `such balance to the company.`
  line
  line `(2) Where any machinery, equipment or other property, has vested, under this Act, in the Central`
  line `Government or the Government company, as the case may be, but such machinery, equipment or other`
  line `property does not belong to the Company, it shall be lawful for the Central Government or the`
  line `Government company, as the case may be, to continue to possess such machinery, equipment and other`
  line `property on the same terms and conditions under which they were possessed by the Company`
  line `immediately before the appointed day`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (35729)
  sectionNo (22)
  orderNo 22
  title `Undisbursed or unclaimed amount to be deposited to the general revenue account.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35729&sectionno=22&orderno=22&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_22_content:
  string
  line Any
  line `money paid to the Commissioner which remains undisbursed or unclaimed on the date immediately`
  line `preceding the date on which the office of the Commissioner is finally wound up, shall be transferred by`
  line `the Commissioner, before his office is finally wound up, to the general revenue account of the Central`
  line `Government; but a claim to any money so transferred may be preferred to the Central Government by the`
  line `person entitled to such payment and shall be dealt with as if such transfer had not been made, and the`
  line `order, if any, for payment of the claim, being treated as an order for the refund of revenue.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (35730)
  sectionNo (23)
  orderNo 23
  title `Act to have overriding effect.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35730&sectionno=23&orderno=23&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_23_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force or in any instrument`
  line `having effect by virtue of any law, other than this Act, or in any decree or order of any court, tribunal or`
  line `other authority.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (35777)
  sectionNo (24)
  orderNo 24
  title `Contracts to cease to have effect unless ratified by the Central Government or Government company .`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35777&sectionno=24&orderno=24&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_24_content:
  string
  line `Every contract entered into by the Company in relation to the undertakings owned by it,`
  line `which has vested in the Central Government under section 3, for any service, sale or supply, and in force`
  line `immediately before the appointed day, shall, on and from the expiry of a period of one hundred and eighty`
  line `days from the appointed day, cease to have effect unless such contract is, before the expiry of that period,`
  line `ratified, in writing, by the Central Government or Government company, in which such undertakings`
  line `have been vested under this Act, and in ratifying such contract, the Central Government or Government`
  line `company may make such alteration or modification therein as it may think fit:`
  line
  line `Provided that the Central Government or Government company shall not omit to ratify a contract and`
  line `shall not make any alteration or modification in a contract--`
  line
  line `(a) unless it is satisfied that such contract is unduly onerous or has been entered into in bad faith`
  line `or is detrimental to the interests of the Central Government or such Government company; and`
  line
  line `(b) except after giving to the parties to the contract a reasonable opportunity of being heard and`
  line `except after recording, in writing, its reasons for refusal to ratify the contract or for making any`
  line `alteration or modification therein.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (35732)
  sectionNo (25)
  orderNo 25
  title Penalties.
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35732&sectionno=25&orderno=25&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_25_content:
  string
  line `Any person who--`
  line
  line `(a) having in his possession, custody or control any property forming part of any undertaking of`
  line `the Company, or any share held by the Company in any specified company, wrongfully withholds`
  line `such property or share from the Central Government or Government company; or`
  line
  line `(b) wrongfully obtains possession of, or retains any property forming part of any undertaking of`
  line `the Company or willfully withholds or fails to furnish to the Central Government or Government`
  line `company or any person specified by that Government or Government company, any document`
  line `relating to such undertakings or share which may be in his possession, custody or control or fails to`
  line `deliver to the Central Government or Government company or any person specified by that`
  line `Government or Government Company, any assets, books of account, registers or other documents in`
  line `his possession, custody or control, relating to the undertakings of the Company or any share held by`
  line `the Company in any specified company; or`
  line
  line `(c) wrongfully recovers or destroys any property forming part of any undertaking of the Company`
  line `or prefers any claim under this Act which he knows or has reasonable cause to believe to be false or`
  line `grossly inaccurate,`
  line
  line `shall be punishable with imprisonment for a term which may extend to two years, or with fine which may`
  line `extend to ten thousand rupees, or with both.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (35733)
  sectionNo (26)
  orderNo 26
  title `Offences by companies.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35733&sectionno=26&orderno=26&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_26_content:
  string
  line `(1) Where an offence punishable under this Act has been committed`
  line `by a company, every person who at the time the offence was committed was in charge of, and was`
  line `responsible to, the company for the conduct of the business of the company, as well as the company, shall`
  line `be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1) where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall be deemed to be guilty of`
  line `that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.-- For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line
  line `(b) "director", in relation to a firm, means a partner in the firm`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (35734)
  sectionNo (27)
  orderNo 27
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35734&sectionno=27&orderno=27&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_27_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government or the Custodian of the Undertakings of the Company, or the`
  line `Government Company or any officer or other person authorised by that Government or Government`
  line `company for anything which is in good faith done or intended to be done under this Act`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (35735)
  sectionNo (28)
  orderNo 28
  title `Delegation of powers.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35735&sectionno=28&orderno=28&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_28_content:
  string
  line `(1)The Central Government may, by notification, direct that all or any of`
  line `the powers exercisable by it under this Act, other than the powers conferred by this section and section 29`
  line `and section 30, may also be exercised by such person or persons as may be specified in the notification.`
  line
  line `(2) Whenever any delegation of power is made under sub-section (1), the person to whom such power`
  line `has been delegated shall act under the direction, control and supervision of the Central Government.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (35736)
  sectionNo (29)
  orderNo 29
  title `Power to make rules.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35736&sectionno=29&orderno=29&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_29_content:
  string
  line `(1) The Central Government may, by notification, make rules for`
  line `carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the time within which, and the manner in which, an intimation shall be given to the`
  line `commissioner under sub-section (3) of section 5;`
  line
  line `(b) the form and the manner in which, and the conditions under which, accounts shall be`
  line `maintained by the Custodian as required by sub-section (3) of section 10;`
  line
  line `(c) the manner in which monies in any provident fund or other fund referred to in section 12 shall`
  line `be dealt with;`
  line
  line `(d) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made by the Central Government under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (35737)
  sectionNo (30)
  orderNo 30
  title `Power to remove difficulties.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35737&sectionno=30&orderno=30&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_30_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order, not inconsistent with the provisions of this Act, remove the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of two years from the appointed`
  line day.
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (35738)
  sectionNo (31)
  orderNo 31
  title `Repeal and saving.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00007_198067_1517807324670&sectionId=35738&sectionno=31&orderno=31&orgactid=AC_CEN_14_15_00007_198067_1517807324670
obj_root_law_sections_31_content:
  string
  line `(1) The Bird and Company Limited (Acquisition and Transfer of`
  line `Undertakings and Other Properties) Ordinance, 1980 (18 of 1980), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the Ordinance so repealed`
  line `shall be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_31_footnotes:
  string
  line
