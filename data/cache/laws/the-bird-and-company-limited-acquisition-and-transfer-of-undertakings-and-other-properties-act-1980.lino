obj_root_law:
  object
  (str slug) (str the-bird-and-company-limited-acquisition-and-transfer-of-undertakings-and-other-properties-act-1980)
  (str handle) (str 19235)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Bird and Company Limited (Acquisition and Transfer of Undertakings and Other Properties) Act, 1980`)
  (str actNumber) (str 67)
  (str enactmentDate) (str 1980-12-27)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/19235`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बर्ड एण्‍ड कम्‍पनी लिमिटेड (उपक्रमों और अन्‍य सम्‍पत्तियों का अर्जन और अन्‍तरण) अधिनियम,1980`)
  (str actYear) (str 1980)
  (str ministry) (str `Ministry of Steel`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the undertakings of the Bird and Company Limited for the purpose of ensuring the continuity of production of goods which are vital to the needs of the country and for the acquisition of shares held by the Bird and Company Limited in the specified companies for the purpose of securing to those undertakings the facilities and advantages derived by reason of such shareholding with respect to the operation and functioning of those undertakings and also to enable the Central Government to exercise such control over the affairs of the specified companies as is necessary to ensure that the affairs of those companies are not mismanaged and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 1980-10-25)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T15:50:59.238Z`)
  (str translations) obj_root_law_translations
