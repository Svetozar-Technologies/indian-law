  (str sectionId) (str 49712)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Repealing and Amending Act, 2015.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_201517_1571392199791&sectionId=49712&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00072_201517_1571392199791)
obj_root_law_sections_2:
  object
  (str sectionId) (str 49713)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Repeal of enactments.`)
  (str content) (str `The enactments specified in the First Schedule are hereby
repealed to the extent mentioned in the fourth column thereof.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_201517_1571392199791&sectionId=49713&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00072_201517_1571392199791)
obj_root_law_sections_3:
  object
  (str sectionId) (str 49714)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Amendment of certain enactments.`)
  (str content) (str `The enactments specified in the Second Schedule are
hereby amended to the extent and the manner mentioned in the fourth column thereof.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_201517_1571392199791&sectionId=49714&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00072_201517_1571392199791)
obj_root_law_sections_4:
  object
  (str sectionId) (str 49715)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str Savings.)
  (str content) (str `The repeal by this Act of any enactment shall not affect any Act in which such
enactment has been applied, incorporated or referred to;

and this Act shall not affect the validity, invalidity, effect or consequences of anything already
done or suffered, or any right, title, obligation or liability already acquired, accrued or incurred, or any
remedy or proceeding in respect thereof, or any release or discharge of or from any debt, penalty,
obligation, liability, claim or demand, or any indemnity already granted, or the proof of any past act or
thing;

nor shall this Act affect any principle or rule of law, or established jurisdiction, form or course of
pleading, practice or procedure, or existing usage, custom, privilege, restriction, exemption, office or
appointment, notwithstanding that the same respectively may have been in any manner affirmed,
recognised or derived by, in or from any enactment hereby repealed;

nor shall the repeal by this Act of any enactment provide or restore any jurisdiction, office,
custom, liability, right, title, privilege, restriction, exemption, usage, practice, procedure or other
matter or thing not now existing or in force.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_201517_1571392199791&sectionId=49715&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00072_201517_1571392199791)
