  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Repealing and Amending Act, 2015.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_201517_1571392199791&sectionId=49712&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00072_201517_1571392199791
