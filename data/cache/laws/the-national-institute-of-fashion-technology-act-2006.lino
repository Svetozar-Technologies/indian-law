  (str slug) (str the-national-institute-of-fashion-technology-act-2006)
  (str handle) (str 2031)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Institute of Fashion Technology Act, 2006`)
  (str actNumber) (str 28)
  (str enactmentDate) (str 2006-07-13)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2031`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `राष्‍ट्रीय फैशन प्रौद्योगिकी संस्‍थानअधिनियम, 2006`)
  (str actYear) (str 2006)
  (str ministry) (str `Ministry of Textiles`)
  (str longTitle) (str `An Act to establish and incorporate the National Institute of Fashion Technology for the promotion and development of education and research in fashion technology and for matters connected therewithand incidental thereto.`)
  (str enforcementDate) (str 01-04-2007)
  (str notification) (str `1st April, 2007, vide notification No. S.O. 2159(E), dated 27th December, 2006, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
