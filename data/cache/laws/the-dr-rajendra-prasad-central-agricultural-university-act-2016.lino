obj_root_law_sections_1:
  sectionId (30275)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30275&sectionno=1&orderno=1&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Dr. Rajendra Prasad Central`
  line `Agricultural University Act, 2016.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 7th October, 2016, vide notification S.O. 3184 (E), dated 7th October, 2016, see Gazette of India, Extraordinary Part II,`
  line `s. 3 (ii).`
obj_root_law_sections_2:
  sectionId (30276)
  sectionNo (2)
  orderNo 2
  title `Declaration of Dr. Rajendra Prasad Central Agricultural University as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30276&sectionno=2&orderno=2&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the institution known as the Dr. Rajendra Prasad`
  line `Central Agricultural University are such as to make the institution one of the national importance, it is`
  line `hereby declared that the institution known as the Dr. Rajendra Prasad Central Agricultural University`
  line `is an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (43752)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=43752&sectionno=3&orderno=3&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_3_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the context otherwise`
  line `requires, ---`
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "agriculture" means the basic and applied sciences of the soil and water management, crop`
  line `production including production of all garden crops, control of plants, pests and diseases, horticulture`
  line `including floriculture, animal husbandry including veterinary and dairy science, fisheries, forestry`
  line `including farm forestry, home-science, agricultural engineering and technology, marketing and`
  line `processing of agricultural and animal husbandry products, land use and management;`
  line
  line `(d) "Board" means the Board of Management of the University;`
  line
  line `(e) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(f) "Chancellor" means the Chancellor of the University;`
  line
  line `(g) "college" means a constituent college of the University whether located at the headquarters,`
  line `campus or elsewhere;`
  line
  line `(h) "Department" means a Department of Studies of the University;`
  line
  line `(i) "employee" means any person appointed by the University and includes teachers and other`
  line `staff of the University;`
  line
  line `(j) "extension education" means the educational activities concerned with the training of`
  line `orchardists, farmers and other groups serving agriculture, horticulture, fisheries and improved`
  line `practices related thereto and the various phases of scientific technology related to agriculture and`
  line `agricultural production including post-harvest technology and marketing;`
  line
  line `(k) "Faculty" means Faculty of the University;`
  line
  line `(l) "Ordinances" means the Ordinances of the University;`
  line
  line `(m) "Regulations" means the Regulations made by any prescribed authority of the University;`
  line
  line `(n) "Research Advisory Committee" means the Research Advisory Committee of the University;`
  line
  line `(o) "Statutes" means the Statutes of the University;`
  line
  line `(p) "student" means a person enrolled in the University for undergoing a course of study for`
  line `obtaining a degree, diploma or other academic distinction duly instituted;`
  line
  line `(q) "teachers" means Professors, Associate Professors, Assistant Professors, Teaching Faculty`
  line `Members and their equivalent appointed for imparting instruction or conducting research or extension`
  line `education programmes or combination of these in the University, college or any institute maintained`
  line `by the University and designated as teachers by the Ordinances;`
  line
  line `(r) "University" means the Dr. Rajendra Prasad Central Agricultural University established under`
  line `this Act;`
  line
  line `(s) "Vice-Chancellor" means the Vice-Chancellor of the University; and`
  line
  line `(t) "Visitor" means the Visitor of the University.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (30277)
  sectionNo (4)
  orderNo 4
  title `Establishment and incorporation of Dr. Rajendra Prasad Central Agricultural University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30277&sectionno=4&orderno=4&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_4_content:
  string
  line `(1) The University established and incorporated under the Bihar Agricultural`
  line `University Act, 1987 (Bihar Act 8 of 1988), in so far as it relates to the Rajendra Agricultural`
  line `University shall be established as a body corporate under this Act by the name of the "Dr. Rajendra`
  line `Prasad Central Agricultural University".`
  line
  line `(2) The headquarters of the University shall be at Pusa in the State of Bihar and it may also`
  line `establish campuses at such other places within its jurisdiction as it may deem fit;`
  line
  line `Provided that the University shall integrate the existing campus and other associated facilities of`
  line `the Rajendra Agricultural University, Pusa and the effective date of take-over shall be as specified in`
  line `the notification published in the Official Gazette.`
  line
  line `(3) The first Chancellor, the first Vice-Chancellor and the first members of the Board, the`
  line `academic Council and all persons who may hereafter become such officers or members, so long as`
  line `they continue to hold such office or membership are hereby constituted a body corporate by the name`
  line `of the Dr. Rajendra Prasad Central Agricultural University.`
  line
  line `(4) The University shall have perpetual succession and a common seal and shall sue and be sued`
  line `by the said name.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (30278)
  sectionNo (5)
  orderNo 5
  title `Objects of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30278&sectionno=5&orderno=5&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_5_content:
  string
  line `The objects of the University shall be---`
  line
  line `(a) to impart education in different branches of agriculture and allied sciences as it may deem`
  line fit;
  line
  line `(b) to further the advancement of learning and conducting of research in agricultural and`
  line `allied sciences;`
  line
  line `(c) to undertake programmes of extension education in the country with particular attention to`
  line `the State of Bihar;`
  line
  line `(d) to promote partnership and linkages with national and international educational`
  line `institutions; and`
  line
  line `(e) to undertake such other activities as it may, from time to time, determine.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (30279)
  sectionNo (6)
  orderNo 6
  title `Powers of the University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30279&sectionno=6&orderno=6&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_6_content:
  string
  line `The University shall have the following powers, namely: —`
  line
  line `(i) to make provisions for instructions in agriculture and allied sciences;`
  line
  line `(ii) to make provisions for conduct of research in agriculture and allied branches of learning;`
  line
  line `(iii) to make provisions for dissemination of the findings of research and technical`
  line `information through extension programmes;`
  line
  line `(iv) to grant, subject to such conditions as it may determine, diplomas or certificates to, and`
  line `confer degrees or other academic distinctions on the basis of examination, evaluation or any other`
  line `method of testing, on persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinction for good and sufficient cause;`
  line
  line `(v) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(vi) to provide lectures and instructions for field workers, village leaders and other persons`
  line `not enrolled as regular students of the University and to grant certificates to them as may be`
  line `prescribed by the Statutes;`
  line
  line `(vii) to co-operate or collaborate or associate with any other University or authority or`
  line `institution of higher learning in such manner and for such purpose as the University may`
  line determine;
  line
  line `(viii) to establish and maintain colleges relating to agriculture, horticulture, fisheries, forestry,`
  line `veterinary and animal science, dairying, home-science and allied sciences, as necessary;`
  line
  line `(ix) to establish and maintain such campuses, Krishi Vigyan Kendras, special centres,`
  line `specialised laboratories, libraries, museums or other units for research and institution as are, in its`
  line `opinion, necessary for the furtherance of its objects;`
  line
  line `(x) to create teaching, research and extension education posts and to make appointments`
  line thereto;
  line
  line `(xi) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(xii) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xiii) to determine standards of admission to the University which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xiv) to provide and maintain residential accommodation for students and employees;`
  line
  line `(xv) to supervise the residences of the students of the University and to make arrangements`
  line `for promoting their health and general welfare;`
  line
  line `(xvi) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xvii) to regulate and enforce discipline among the students and the employees and to take`
  line `such disciplinary measures in this regard as it may deem necessary;`
  line
  line `(xviii) to fix, demand and receive such fees and other charges as may be prescribed by the`
  line Statutes;
  line
  line `(xix) to borrow, with the approval of the Central Government on the security of its property,`
  line `money for the purpose of the University;`
  line
  line `(xx) to receive benefactions, donations and gifts and to acquire, hold, manage and dispose of`
  line `any property, movable or immovable including trust and endowment properties, for its purposes;`
  line and
  line
  line `(xxi) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (30280)
  sectionNo (7)
  orderNo 7
  title Jurisdiction.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30280&sectionno=7&orderno=7&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_7_content:
  string
  line `(1) The jurisdiction and responsibility of the University with respect to`
  line `teaching, research and programmes of extension education at the University level, in the field of`
  line `agriculture and allied subjects shall extend to the whole country with special reference to the State of`
  line Bihar.
  line
  line `(2) All colleges, directorates, research stations, experiment stations and Krishi Vigyan Kendras of`
  line `the existing Rajendra Agricultural University and other institutions coming under the jurisdiction and`
  line `authority of the University shall be constituent unit and no other units shall be recognised as affiliated`
  line units.
  line
  line `(3) The University may assume responsibility for the training of field extension workers and`
  line `others and may develop such training centres as may be required in various regions under its`
  line jurisdiction.
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (30281)
  sectionNo (8)
  orderNo 8
  title `University open to all classes, castes and creed.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30281&sectionno=8&orderno=8&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_8_content:
  string
  line `The University shall be open to persons of`
  line `every sex, caste, creed, race or class, and it shall not be lawful for the University to adopt or impose`
  line `on any person, any test whatsoever of religious belief or profession in order to entitle him to be`
  line `appointed as a teacher of the University or to hold any other office therein or be admitted as a student`
  line `in the University or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making`
  line `special provisions for the employment or admission of women, persons with disability or of persons`
  line `belonging to the weaker sections of the society and, in particular, of the Scheduled Castes, the`
  line `Scheduled Tribes and Other Backward Classes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (30282)
  sectionNo (9)
  orderNo 9
  title `The Visitor.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30282&sectionno=9&orderno=9&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_9_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) Subject to the provisions of sub-sections (3) and (4), the Visitor shall have the right to cause`
  line `an inspection to be made, by such person or persons as he may direct, of the University, its buildings,`
  line `laboratories, libraries, museums, workshops and equipments, and of any institution or college and also`
  line `of the examination, instruction and other work conducted or done by the University, and to cause an`
  line `inquiry to be made in like manner in respect of any matter connected with the administration and`
  line `finances of the University.`
  line
  line `(3) The Visitor shall, in every case, give notice to the University of his intention to cause, an`
  line `inspection or inquiry to be made and the University shall, on receipt of such notice, have the right to`
  line `make, within thirty days from the date of receipt of the notice or such other period as the Visitor may`
  line `determine, such representations to him as it may consider necessary.`
  line
  line `(4) After considering the representations, if any, made by the University, the Visitor may cause to`
  line `be made such inspection or inquiry as is referred to in sub-section (2).`
  line
  line `(5) Where an inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative who shall have the right to appear in person and to be heard on`
  line `such inspection or inquiry.`
  line
  line `(6) The Visitor may address the Vice-Chancellor with reference to the results of such inspection`
  line `or inquiry together with such views and advice with regard to the action to be taken thereon as the`
  line `Visitor may be pleased to offer and on receipt of the address made by the Visitor, the Vice-Chancellor`
  line `shall communicate forthwith to the Board, the results of the inspection or inquiry and the views of the`
  line `Visitor and the advice tendered by him upon the action to be taken thereon.`
  line
  line `(7) The Board shall communicate through the Vice-Chancellor to the Visitor such action, if any,`
  line `as it proposes to take or has been taken by it upon the results of such inspection or inquiry.`
  line
  line `(8) Where the Board does not, within reasonable time, take action to the satisfaction of the`
  line `Visitor, the Visitor may, after considering any explanation furnished or representation made by the`
  line `Board, issue such directions as he may think fit and the Board shall be bound to comply with such`
  line directions.
  line
  line `(9) Without prejudice to the foregoing provisions of this section, the Visitor may, by an order in`
  line `writing, annul any proceeding of the University which is not in conformity with this Act, the Statutes`
  line `or the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the University to show cause why`
  line `such an order should not be made and, if any cause is shown within a reasonable time, he shall`
  line `consider the same.`
  line
  line `(10) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (30283)
  sectionNo (10)
  orderNo 10
  title `Officers of the University.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30283&sectionno=10&orderno=10&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_10_content:
  string
  line `The following shall be the officers of the University,`
  line `namely: —`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Deans;`
  line
  line `(4) the Directors;`
  line
  line `(5) the Registrar;`
  line
  line `(6) the Comptroller;`
  line
  line `(7) the University Librarian; and`
  line
  line `(8) such other officers as may be prescribed by the Statutes.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (30284)
  sectionNo (11)
  orderNo 11
  title `The Chancellor.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30284&sectionno=11&orderno=11&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_11_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as`
  line `may be prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the Head of the University.`
  line
  line `(3) The Chancellor shall, if present, preside at the convocations of the University held for`
  line `conferring degrees.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (30285)
  sectionNo (12)
  orderNo 12
  title `The Vice-Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30285&sectionno=12&orderno=12&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_12_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University`
  line `and shall exercise general supervision and control over the affairs of the University and give effect to`
  line `the decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of the opinion that immediate action is necessary on any`
  line `matter, exercise any power conferred on any authority of the University by or under this Act and shall`
  line `report to such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been`
  line `taken, it may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action`
  line `taken by the Vice-Chancellor under this sub-section shall have the right to appeal against such action`
  line `to the Board within three months from the date on which decision on such action is communicated to`
  line `him and thereupon the Board may confirm, modify or reverse the action taken by the ViceChancellor.`
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the`
  line `University is beyond the powers of the authority conferred by the provisions of this Act, the Statutes`
  line `of the Ordinances or that any decision taken is not in the interest of the University, may ask the`
  line `authority concerned to review its decision within sixty days of such decision and if the authority`
  line `refuses to review the decision either in whole or in part or no decision is taken by it within the said`
  line `period of sixty days, the matter shall be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may`
  line `be prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (30286)
  sectionNo (13)
  orderNo 13
  title `Deans and Director.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30286&sectionno=13&orderno=13&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_13_content:
  string
  line `Every Dean and every Director shall be appointed in such manner`
  line `and shall exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (30287)
  sectionNo (14)
  orderNo 14
  title `The Registrar.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30287&sectionno=14&orderno=14&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_14_content:
  string
  line `(1) The Registrar shall be appointed in such manner as may be prescribed`
  line `by the Statutes.`
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such powers and perform such duties as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (30288)
  sectionNo (15)
  orderNo 15
  title `The Comptroller.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30288&sectionno=15&orderno=15&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_15_content:
  string
  line `The Comptroller shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (30289)
  sectionNo (16)
  orderNo 16
  title `Other officers.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30289&sectionno=16&orderno=16&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_16_content:
  string
  line `The manner of appointment and powers and duties of the other officers of`
  line `the University shall be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (30290)
  sectionNo (17)
  orderNo 17
  title `Authorities of the University.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30290&sectionno=17&orderno=17&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_17_content:
  string
  line `The following shall be the authorities of the University,`
  line `namely: —`
  line
  line `(1) the Board;`
  line
  line `(2) the Academic Council;`
  line
  line `(3) the Research Council;`
  line
  line `(4) the Extension Education Council;`
  line
  line `(5) the Finance Committee;`
  line
  line `(6) the Faculties and Board of Studies; and`
  line
  line `(7) such other authorities as may be prescribed by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (30291)
  sectionNo (18)
  orderNo 18
  title `Board of Management.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30291&sectionno=18&orderno=18&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_18_content:
  string
  line `(1) The Board shall be the principal executive body of the`
  line University.
  line
  line `(2) The constitution of the Board, the term of office of its members and its powers and functions`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (30292)
  sectionNo (19)
  orderNo 19
  title `The Academic Council.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30292&sectionno=19&orderno=19&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_19_content:
  string
  line `(1) The Academic Council shall be the principal academic body of`
  line `the University and shall, subject to the provisions of this Act and the Statutes and Ordinances, have`
  line `the control and general regulation of, and be responsible for the maintenance of standards of learning,`
  line `education, instruction, evaluation and examination within the University and shall exercise such other`
  line `powers and perform such other functions as may be conferred or imposed upon it by the Statutes.`
  line
  line `(2) The constitution of the Academic Council and the term of office of its members shall be`
  line `prescribed by the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (30293)
  sectionNo (20)
  orderNo 20
  title `The Research Council.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30293&sectionno=20&orderno=20&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_20_content:
  string
  line `The constitution, powers and functions of the Research Council`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
