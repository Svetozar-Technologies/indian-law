obj_root_law:
  object
  (str slug) (str the-dr-rajendra-prasad-central-agricultural-university-act-2016)
  (str handle) (str 2150)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Dr. Rajendra Prasad Central Agricultural University Act, 2016.`)
  (str actNumber) (str 32)
  (str enactmentDate) (str 2016-05-28)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2150`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `डा० राजेन्द्र प्रसाद केंद्रीय कृषि विश्वरविद्यालय अधिनियम, 2016`)
  (str actYear) (str 2016)
  (str ministry) (str `Ministry of Agriculture and Farmers Welfare`)
  (str department) (str `Department of Agricultural Research and Education`)
  (str longTitle) (str `An Act to provide for the establishment and incorporation of a University by conversion of the existing Rajendra Agricultural University, Pusa, Bihar to Dr. Rajendra Prasad Central Agricultural University for the development of agriculture and for the furtherance of the advancement of learning and pursuit of research in agriculture and allied sciences and to declare it to be an institution of national importance.`)
  (str enforcementDate) (str 07-10-2016)
