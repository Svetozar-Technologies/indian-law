  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30297&sectionno=24&orderno=24&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_24_content:
  string
