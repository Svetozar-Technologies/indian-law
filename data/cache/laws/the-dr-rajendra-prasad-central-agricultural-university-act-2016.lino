  (str title) (str `डा० राजेन्द्र प्रसाद केंद्रीय कृषि विश्वरविद्यालय अधिनियम, 2016`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2150/3/H2016-32.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:47:39.524Z`)
