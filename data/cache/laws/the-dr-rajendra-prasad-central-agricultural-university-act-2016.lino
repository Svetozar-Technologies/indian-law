  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_47_00006_201632_1517807328191&sectionId=30298&sectionno=25&orderno=25&orgactid=AC_CEN_23_47_00006_201632_1517807328191
obj_root_law_sections_25_content:
  string
  line `The constitution, powers and functions of other authorities of the`
  line `University referred to in clause (7) of section 17 shall be such as may be prescribed by the Statutes.`
obj_root_law_sections_25_footnotes:
