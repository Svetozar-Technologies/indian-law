obj_root_law_sources_hi_1951:
  kind pdf
  url `https://www.indiacode.nic.in/bitstream/123456789/1363/2/hH1951-61.pdf`
  title `अखिल भारतीय सेवा अधिनियम, 1951`
obj_root_law_sections:
  obj_root_law_sections_1
  obj_root_law_sections_2
  obj_root_law_sections_2_a
  obj_root_law_sections_3
  obj_root_law_sections_4
obj_root_law_sections_1:
  sectionId (38384)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the All-India Services Act, 1951.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00002_195161_1517807321358&sectionId=38384&sectionno=1&orderno=1&orgactid=AC_CEN_26_36_00002_195161_1517807321358
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (38385)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes `1. Ins. by Act 27 of 1963, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00002_195161_1517807321358&sectionId=38385&sectionno=2&orderno=2&orgactid=AC_CEN_26_36_00002_195161_1517807321358
obj_root_law_sections_2_content:
  string
  line `In this Act, the expression "an All-India Service" means the service known as the`
  line `Indian Administrative Service or the service known as the Indian Police Service, ^1[or any other`
  line `service specified in section 2A].`
obj_root_law_sections_2_a:
  sectionId (38386)
  sectionNo 2A
  orderNo 3
  title `Other All-India Services.`
  content obj_root_law_sections_2_a_content
  footnotes `1. Ins. by s. 3, ibid.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00002_195161_1517807321358&sectionId=38386&sectionno=2A&orderno=3&orgactid=AC_CEN_26_36_00002_195161_1517807321358
obj_root_law_sections_2_a_content:
  string
  line `^1[2A. Other All-India Services.--With effect from such date as the Central Government may,`
  line `by notification in the Official Gazette, appoint in this behalf, there shall be constituted the following`
  line `All-India Services and different dates may be appointed for different services, namely:--`
  line
  line `1. The Indian Service of Engineers (Irrigation, Power, Buildings and Roads);`
  line
  line `2. The Indian Forest Service;`
  line
  line `3. The Indian Medical and Health Service.]`
obj_root_law_sections_3:
  sectionId (38388)
  sectionNo (3)
  orderNo 4
  title `Regulation of recruitment and conditions of service.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00002_195161_1517807321358&sectionId=38388&sectionno=3&orderno=4&orgactid=AC_CEN_26_36_00002_195161_1517807321358
obj_root_law_sections_3_content:
  string
  line `(1) The Central Government may,`
  line `after consultation with the Governments of the States concerned, ^1*** ^2[and by notification in the Official Gazette]] make rules for the regulation of recruitment,`
  line `and the conditions of service of persons appointed to an All-India Service.`
  line
  line `^3[(1A) The power to make rules conferred by this section shall include the power to give`
  line `retrospective effect from a date not earlier than the date of commencement of this Act, to the rules or`
  line `any of them but no retrospective effect shall be given to any rule so as to prejudicially affect the`
  line `interests of any person to whom such rule may be applicable.]`
  line
  line `^4[(2) Every rule made by the Central Government under this section and every regulation made`
  line `under or in pursuance of any such rule, shall be laid, as soon as may be after such rule or regulation is`
  line `made, before each House of Parliament while it is in session for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree`
  line `in making any modification in such rule or regulation or both Houses agree that such rule or`
  line `regulation should not be made, the rule or regulation shall thereafter have effect only in such modified`
  line `form or be of no effect, as the case may be; so, however, that any such modification or annulment`
  line `shall be without prejudice to the validity of anything previously done under that rule or regulation.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. The words "including the State of Jammu and Kashmir" omitted by the Jammu and Kashmir Reorganisation`
  line `(Adaptation of Central Laws) Order, 2020, vide notification No. S.O. 1123(E) dated (18-3-2020) and vide Union Territory`
  line `of Ladakh Reorganisation (Adaptation of Central Laws) Order, 2020, notification No. S.O. 3774(E), dated`
  line `(23-10-2020). Earlier ins. by Act 25 of 1958, s. 2.`
  line
  line `2. Ins. by Act 19 of 1975, s. 3.`
  line
  line `3. Ins. by Act 23 of 1975, s. 2.`
  line
  line `4. Subs. by Act 19 of 1975, s. 3, for sub-section (2).`
obj_root_law_sections_4:
  sectionId (38387)
  sectionNo (4)
  orderNo 5
  title `Continuance of existing rules.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00002_195161_1517807321358&sectionId=38387&sectionno=4&orderno=5&orgactid=AC_CEN_26_36_00002_195161_1517807321358
obj_root_law_sections_4_content:
  string
  line `All rules in force immediately before the commencement of`
  line `this Act and applicable to an All-India Service shall continue to be in force and shall be deemed to be`
  line `rules made under this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
