obj_root_law_sections_1:
  sectionId (579)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=579&sectionno=1&orderno=1&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Company Secretaries Act, 1980.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1 as the Central Government may, by notification in the Official Gazette, appoint`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st January, 1981, vide notification No. S.O. 989(E), dated 27th December, 1980, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii)`
obj_root_law_sections_2:
  sectionId (580)
  sectionNo (2)
  orderNo 2
  title `Definitions and interpretation.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=580&sectionno=2&orderno=2&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,`
  line
  line `(a) Associate means an Associate Member of the Institute;`
  line
  line `^1[(aa) "Authority" means the Appellate Authority referred to in section 22A;`
  line
  line `(aaa) "Board" means the Quality Review Board constituted under section 29A;];`
  line
  line `^2[(ab) Board of Discipline means the Board of Discipline constituted under sub-section (1) of section 21A;]`
  line
  line `(b) "Companies Act" means ^3[the Companies Act, 2013 (18 of 2013) or any other previous company law as defined in clause (67) of section 2 of the said Act];`
  line
  line `(c) "Company Secretary" means a person who is a member of the Institute;`
  line
  line `(d) "Council" means the Council of the Institute constituted under section 9;`
  line
  line `^2[(da) Director (Discipline) means the Director (Discipline) referred to in section 21 and includes Joint Director (Discipline);`
  line
  line `(db) Disciplinary Committee means the Disciplinary Committee constituted under sub-section (1) of section 21B;`
  line
  line `(dc) Disciplinary Directorate means the Disciplinary Directorate established under sub-section (1) of section 21;]`
  line
  line `(e) "dissolved company" means the Institute of Company Secretaries of India registered under the Companies Act;`
  line
  line `(f) "Fellow" means a Fellow Member of the Institute;`
  line
  line `^4[(fa) "firm" shall have the meaning assigned to it in section 4 of the Indian Partnership Act, 1932 (9 of 1932), and includes,`
  line
  line `(i) the limited liability partnership as defined in clause (n) of sub-section (1) of section 2 of the Limited Liability Partnership Act, 2008 (6 of 2009); or`
  line
  line `(ii) the sole proprietorship,`
  line `registered with the Institute;]`
  line
  line `(g) "Institute" means the Institute of Company Secretaries of India constituted under this Act;`
  line
  line `^5[(ga) notification means a notification published in the Official Gazette and the term notify shall be construed accordingly;]`
  line
  line `^6[(gb) partner shall have the meaning assigned to it in section 4 of the Indian Partnership Act, 1932 (9 of 1932) or in clause (q) of sub-section (1) of section 2 of the Limited Liability Partnership Act, 2008 (6 of 2009), as the case may be;`
  line
  line `(gc) "partnership" means.`
  line
  line `(A) a partnership as defined in section 4 of the Indian Partnership Act, 1932 (9 of 1932); or`
  line
  line `(B) a limited liability partnership which has no company as its partner;]`
  line
  line `(h) "prescribed" means prescribed by regulations made under this Act;`
  line
  line `(i) "President" means the President of the Council;`
  line
  line `^7[(j) Register means the Register of members of the Institute maintained under section 19 or the Register of firms of the Institute maintained under section 20B, as the case may be;]`
  line
  line `^6 [(jj) "sole proprietorship" means an individual who engages himself in the practice of the profession of the company secretaries or offers to perform services referred to in clauses (b) to (f) of sub-section (2);]`
  line
  line `^8[(ja) "specified" means specified by rules made by the Central Government under this Act;`
  line
  line `^9[(jaa) Standing Committee means the Standing Committee constituted under sub-section (1) of section 17;]`
  line
  line `(jb) Tribunal means a Tribunal established under sub-section (1) of section 10B;];`
  line
  line `(k) Vice-President means the Vice-President of the Council;`
  line
  line `(l) year means the period commencing on the 1st day of April of any year and ending on the 31st day of March of the succeeding year;`
  line
  line `(m) words and expressions used herein and not defined but defined in the Companies Act shall have the meanings respectively assigned to them in that Act`
  line
  line `(2) Save as otherwise provided in this Act, a member of the Institute shall be deemed to be in practice when, individually or in partnership with one or more members of the Institute in practice or in partnership with members of such other recognised professions as may be prescribed, he, in consideration of remuneration received or to be received,`
  line
  line `(a) engages himself in the practice of the profession of Company Secretaries to, or in relation to, any company; or`
  line
  line `(b) offers to perform or performs services in relation to the promotion, forming, incorporation, amalgamation, reconstruction, reorganisation or winding up of companies; or`
  line
  line `(c) offers to perform or performs such services as may be performed by`
  line
  line `(i) an authorised representative of a company with respect to filing, registering, presenting, attesting or verifying any documents (including forms, applications and returns) by or on behalf of the company,`
  line
  line `(ii) a share transfer agent,`
  line
  line `(iii) an issue house,`
  line
  line `(iv) a share and stockbroker,`
  line
  line `(v) a secretarial auditor or consultant,`
  line
  line `(vi) an adviser to a company on management, including any legal or procedural matter falling under ^10[***], the Industries (Development and Regulation) Act, 1951 (65 of 1951), the Companies Act, the Securities Contracts (Regulation) Act, 1956 (42 of 1956), any of the rules or bye-laws made by a recognised stock exchange, ^11[the Securities and Exchange Board of India Act, 1992 (15 of 1992), the Foreign Exchange Management Act, 1999 (42 of 1999), the Competition Act, 2002 (12 of 2003)], or under any other law for the time being in force,`
  line
  line `(vii) issuing certificates on behalf of, or for the purposes of, a company; or`
  line
  line `(d) holds himself out to the public as a Company Secretary in practice; or`
  line
  line `(e) renders professional services or assistance with respect to matters of principle or detail relating to the practice of the profession of Company Secretaries; or`
  line
  line `(f) renders such other services as, in the opinion of the Council, are or may be rendered by a Company Secretary in practice;`
  line
  line `and the words to be in practice, with their grammatical variations and cognate expressions, shall be construed accordingly.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Ins. by Act 8 of 2006, s. 2 (w.e.f. 8-8-2006).`
  line
  line `2. Ins. by Act 12 of 2022, s. 74 (w.e.f.10-5-2022).`
  line
  line `3. Subs. by s. 74, ibid., for "Companies Act, 1956". (w.e.f.10-5-2022).`
  line
  line `4. Ins. by Act 4 of 2012, s. 2 (w.e.f. 8-1-2012).`
  line
  line `5. Subs. by Act 12 of 2022, s. 74, for clause (ga) (w.e.f.10-5-2022).`
  line
  line `6. Ins. by Act 4 of 2012, s. 2 (w.e.f. 8-1-2012).`
  line
  line `7. Subs. by Act 12 of 2022, s. 74, for clause (j) (w.e.f.10-5-2022).`
  line
  line `8. Ins. by Act 8 of 2006, s. 2 (w.e.f. 8-8-2006).`
  line
  line `9. Ins. by Act 12 of 2022, s. 74 (w.e.f. 10-5-2022).`
  line
  line `10. The words "the Capital Issues (Control) Act, 1947 (29 of 1947)" omitted by s. 74, ibid., (w.e.f.10-5-2022).`
  line
  line `11. Subs. by s. 74, ibid., for "the Monopolies and Restrictive Trade Practices Act, 1969 (54 of 1969), the Foreign Exchange Regulation Act, 1973 (46 of 1973)"(w.e.f.10-5-2022).`
obj_root_law_sections_3:
  sectionId (581)
  sectionNo (3)
  orderNo 3
  title `Incorporation of the Institute.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=581&sectionno=3&orderno=3&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_3_content:
  string
  line `(1) All persons whose names are entered in the Register of the dissolved company immediately before the commencement of this Act and all persons who may hereafter`
  line `have their names entered in the Register to be maintained under this Act, so long as they continue to have their names borne on the Register to be maintained under this Act, are hereby constituted a body corporate by the name of the Institute of Company Secretaries of India and all such persons shall be known as members of the Institute.`
  line
  line `(2) The Institute shall have perpetual succession and a common seal and shall have power to acquire, hold and dispose of property, movable or immovable and shall by its name sue or be sued.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (582)
  sectionNo (4)
  orderNo 4
  title `Entry of names in the Register of members.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=582&sectionno=4&orderno=4&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_4_content:
  string
  line `(1) Any of the following persons shall be entitled to have his name entered in the ^1[Register of members], namely:`
  line
  line `(a) any person who immediately before the commencement of this Act was an Associate or a Fellow (including an Honorary Fellow) of the dissolved company;`
  line
  line `(b) any person who is a holder of the Diploma in Company Secretaryship awarded by the`
  line `Government of India;`
  line
  line `(c) any person who has passed the examinations conducted by the dissolved company and has completed training either as specified by the dissolved company or as prescribed by the Council, except any such person who is not a permanent resident of India;`
  line
  line `(d) any person who has passed such examination and completed such training, as may be`
  line `prescribed for membership of the Institute;`
  line
  line `(e) any person who has passed such other examination and completed such other training ^2[outside India] as is recognised by the Central Government or the Council as being equivalent to the examination and training prescribed under this Act for membership of the Institute:`
  line
  line `Provided that in the case of any person belonging to any of the classes mentioned in this sub-section who is not permanently residing in India, the Central Government or the Council may impose such further conditions as it may deem to be necessary or expedient in the public interest.`
  line
  line `(2) Every person belonging to the class mentioned in clause (a) or clause (b) of sub-section (1) shall have his name entered in the Register without the payment of any entrance fee.`
  line
  line `^3[(3) Every person belonging to any of the classes mentioned in clauses (c), (d) and (e) of sub-section (1) shall have his name entered in the Register on application being made and granted in the prescribed manner and on payment of such fees, as may be determined, by notification, by the Council, [^4***]:`
  line
  line `^5* * * * *].`
  line
  line `(4) The. Central Government may take such steps as may be necessary for the purpose of having the names of all persons belonging to the classes mentioned in clauses (a) and (b) of sub-section (1) entered in the Register at the commencement of this Act.`
  line
  line `(5) Notwithstanding anything contained in this section, the Council may confer on any person Honorary Fellow Membership, if the Council is of the opinion that such person has made a significant contribution to the profession of Company Secretaries and thereupon the Council shall enter the name of such person in the Register but such person shall not have any voting rights in any election or meetings of the Institute and shall not also be required to pay any fee to the Institute.`
obj_root_law_sections_4_footnotes:
  string
  line `1 Subs. by Act 12 of 2022, s. 75, for “Register” (w.e.f 10-5-2022).`
  line
  line `2 Subs. by ibid., s. 75, for “without India” (w.e.f.10-5-2022).`
  line
  line `3. Subs. by Act 8 of 2006, s. 4, for sub-section (3) (w.e.f. 8-8-2006).`
  line
  line `4 The words “which shall not exceed rupees three thousand” omitted by Act 12 of 2022, s. 75 (w.e.f.10-5-2022).`
  line
  line `5 The proviso omitted by s. 75, ibid., (w.e.f. 10-5-2022).`
obj_root_law_sections_5:
  sectionId (583)
  sectionNo (5)
  orderNo 5
  title `Associates and Fellows.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=583&sectionno=5&orderno=5&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_5_content:
  string
  line `(1) The members of the Institute shall be divided into two classes designated respectively as Associates and Fellows.`
  line
  line `(2) Any person other than a person to whom the provisions of sub-section (4) apply, shall, on his name being entered in the ^1[Register of members], be deemed to have become an Associate and as long as his name remains so entered, shall be entitled to use the letters A.C.S. after his name to indicate that he is an Associate.`
  line
  line `^2[(3) A person, being an Associate who has been in continuous practice in India as a Company Secretary for at least five years and a person who has been an Associate for a continuous period of not less than five years and who possesses such qualifications or practical experience as the Council may prescribe with a view to ensuring that he has experience equivalent to the experience normally acquired as a result of continuous practice for a period of five years as a Company Secretary shall, on payment of`
  line `such fees, as may be determined, by notification, by the Council, ^3[***], and on application made and granted in the prescribed manner, be entered in the ^1[Register of members] as a Fellow:`
  line
  line `^4* * * *`
  line
  line `Explanation I.-- For the purposes of this sub-section, a person shall be deemed to have practised in India for any period for which he has held a certificate of practice under section 6, notwithstanding that he did not actually practise during that period.`
  line
  line `Explanation II.-- In computing the continuous period during which a person has been an Associate of the Institute, there shall be included any continuous period during which the person has been an Associate of the dissolved company immediately before he became an Associate of the Institute.]`
  line
  line `(4) Any person who was a Fellow of the dissolved company and who is entitled to have his name entered in the ^1[Register of members] under clause (a) of sub-section (1) of section 4, shall be entered in the ^1[Register of members] as a Fellow.`
  line
  line `(5) Any person whose name is entered in the ^1[Register of members] as a Fellow shall, so long as his name remains so entered, be entitled to use the letters F.C.S. after his name to indicate that he is a Fellow.`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 12 of 2022, s. 76 for "Register" (w.e.f.10-5-2022).`
  line
  line `2. Subs. by Act 8 of 2006, s. 4, for sub-section (3) (w.e.f. 8-8-2006)`
  line
  line `3. The words "which shall not exceed rupees five thousand," omitted by Act 12 of 2022, s. 76 (w.e.f.10-5-2022).`
  line
  line `4. The proviso omitted by s. 76, ibid., (w.e.f 10-5-2022).`
obj_root_law_sections_6:
  sectionId (584)
  sectionNo (6)
  orderNo 6
  title `Certificate of practice.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=584&sectionno=6&orderno=6&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_6_content:
  string
  line `(1) No member of the Institute shall be entitled to practise, whether in`
  line `India or elsewhere, unless he has obtained from the Council a certificate of practice.`
  line
  line `^1[(2) A member who desires to be entitled to practise shall make an application in such form and pay such annual fee, for his certificate as may be determined, by notification, by the Council, ^2[***], and such fee shall be payable on or before the 1st day of April in each year:`
  line
  line `^3* * * *`
  line
  line `^4[(3) The certificate of practice obtained under sub-section (1) may be cancelled by the Council under such circumstances as may be prescribed.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 5, for sub-section (2) (w.e.f. 8-8-2006).`
  line
  line `2.The words “which shall not exceed rupees three thousand,” omitted by Act 12 of 2022, s. 77 (w.e.f.10-5-2022).`
  line
  line `3. The proviso omitted by s. 77, ibid., (w.e.f 10-5-2022).`
  line
  line `4. Ins. by Act 8 of 2006, s. 5, (w.e.f. 8-8-2006).`
obj_root_law_sections_7:
  sectionId (585)
  sectionNo (7)
  orderNo 7
  title `Members to be known as Company Secretaries.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=585&sectionno=7&orderno=7&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_7_content:
  string
  line `Every member of the Institute in practice shall, and any other member may, use the designation of a Company Secretary and no member using such designation shall use any other description, whether in addition thereto or in substitution therefor:`
  line
  line `Provided that nothing in this section shall be deemed to prohibit any such member from adding any other description or letters to his name, if entitled thereto, to indicate membership of such other institute whether in India or elsewhere as may be recognised in this behalf by the Council, or any other qualification that he may possess, or to prohibit a firm, all the partners of which are members of the Institute and in practice, from being known by its firm name as Company Secretaries.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (586)
  sectionNo (8)
  orderNo 8
  title Disabilities.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=586&sectionno=8&orderno=8&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_8_content:
  string
  line `Notwithstanding anything contained in section 4, a person shall not be entitled to`
  line `have his name entered in, or borne on, the ^1[Register of members]; if he--`
  line
  line `(a) has not attained the age of twenty-one years at the time of his application for the entry of his name in the ^1[Register of members]; or`
  line
  line `(b) is of unsound mind and stands so adjudged by a competent court; or`
  line
  line `(c) is an undercharged insolvent ^2[or undischarged bankrupt]; or`
  line
  line `^2[(ca) is declared bankrupt under the Insolvency and Bankruptcy Code, 2016 (31 of 2016);]`
  line
  line `(d) being a discharged insolvent, has not obtained from the court a certificate stating that his insolvency was caused by misfortune without any misconduct on his part; or`
  line
  line `(e) has been convicted by a competent court, whether within or ^3[outside India], of an offence involving moral turpitude and punishable with imprisonment or of an offence, not of a technical nature, committed by him in his professional capacity unless in respect of the offence committed he has either been granted a pardon or, on an application made by him in this behalf, the Central Government has, by an order in writing, removed the disability; or`
  line
  line `(f) has been removed from membership of the Institute on being found on inquiry to have been guilty of professional or other misconduct:`
  line
  line `Provided that a person who has been removed from membership for a specified period shall not be entitled to have his name entered in the ^1[Register of members] until the expiry of such period.`
obj_root_law_sections_8_footnotes:
  string
  line `1. Subs. by Act 12 of 2022, s. 78, for “Register” (w.e.f.10-5-2022).`
  line
  line `2. Ins. by s. 78, ibid. (w.e.f. 10-5-2022).`
  line
  line `3. Subs by s. 78, ibid., for “without India” (w.e.f. 10-5-2022).`
obj_root_law_sections_9:
  sectionId (587)
  sectionNo (9)
  orderNo 9
  title `Constitution of the Council of the Institute.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=587&sectionno=9&orderno=9&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_9_content:
  string
  line `(1) There shall be a Council of the Institute for the management of the affairs of the Institute and for discharging the functions assigned to it by or under this Act.`
  line
  line `^1[(2) The Council shall be composed of the following persons, namely:--`
  line
  line `(a) not more than fifteen persons elected by the members of the Institute, from amongst the`
  line `Fellows of the Institute chosen in such manner and from such regional constituencies as may be specified:`
  line
  line `Provided that a Fellow of the Institute, who has been found guilty of any professional or other`
  line `misconduct and whose name is removed from the ^2[Register of members] or has been awarded penalty of fine, shall not be eligible to contest the election,--`
  line
  line `(i) in case of misconduct falling under the First Schedule of this Act, for a period of ^3[four years];`
  line
  line `(ii) in case of misconduct falling under the Second Schedule of this Act, for a period of ^4[eight years],`
  line
  line `from the completion of the period of removal of name from the ^2[Register of members] or payment of fine, as the case may be;`
  line
  line `(b) not more than five persons nominated in the specified manner by the Central Government.]`
  line
  line `^5[(3) No person holding a post under the Central Government or a State Government shall be eligible for election to the Council under clause (a) of sub-section (2)].`
  line
  line `(4) No ^6[member of the Institute or any partner of a firm] who has been auditor of the Institute shall be eligible for election to the Council under clause (a) of sub-section (2) for a period of ^3[four years] after he ceases to be an auditor.]`
obj_root_law_sections_9_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 6, for sub-section (2) (w.e.f. 5-9-2006).`
  line
  line `2. Subs. by Act 12 of 2022, s.79. for Register (w.e.f. 10-50-2022).`
  line
  line `3. Subs. by s. 79, ibid., for "three years" (w.e.f 10-5-2022).`
  line
  line `4. Subs. by s. 79, ibid., for "six years" (w.e.f. 10-5-2022).`
  line
  line `5. Ins. by Act 8 of 2006, s. 6 (w.e.f. 5-9-2006)`
  line
  line `6. Subs. by Act 12 of 2022, s. 79, for "person" (w.e.f. 10-5-2022).`
obj_root_law_sections_10:
  sectionId (588)
  sectionNo (10)
  orderNo 10
  title `Re-election or re-nomination to Council.`
  content obj_root_law_sections_10_content
  footnotes `12. Subs. by s. 7, ibid., for section 10 (w.e.f. 8-8-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=588&sectionno=10&orderno=10&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_10_content:
  string
  line `^1[10. Re-election or re-nomination to Council-- A member of the Council, elected or nominated under sub-section (2) of section 9, shall be eligible for re-election or, as the case may be, re-nomination:`
  line
  line `Provided that no member shall hold the office for more than two consecutive terms:`
  line
  line `Provided further that a member of the Council, who is or has been elected as Presid ent under sub-section (1) of section 12, shall not be eligible for election or nomination as a member of the Council.]`
obj_root_law_sections_10_a:
  sectionId (589)
  sectionNo 10A
  orderNo 11
  title `Settlement of disputes regarding election.`
  content `^1[10A. Settlement of disputes regarding election.-- In case of any dispute regarding any election under clause (a) of sub-section (2) of section 9, the aggrieved person may make an application within thirty days from the date of declaration of the result of election to the Secretary of the Institute, who shall forward the same to the Central Government.]`
  footnotes `1. Ins. by Act 8 of 2006, s. 8. (w.e.f. 17-11-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=589&sectionno=10A&orderno=11&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_10_b:
  sectionId (590)
  sectionNo 10B
  orderNo 12
  title `Establishment of Tribunal.`
  content obj_root_law_sections_10_b_content
  footnotes `1. Ins. by Act 8 of 2006, s. 8. (w.e.f. 17-11-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=590&sectionno=10B&orderno=12&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_10_b_content:
  string
  line `^1[10B. Establishment of Tribunal.-- (1) On receipt of any application under section 10A, the Central Government shall, by notification, establish a Tribunal consisting of a Presiding Officer and two other`
  line `Members to decide such dispute and the decision of such Tribunal shall be final.`
  line
  line `(2) A person shall not be qualified for appointment,--`
  line
  line `(a) as a Presiding Officer of the Tribunal unless he has been a member of the Indian Legal`
  line `Service and has held a post in Grade I of the service for at least three years;`
  line
  line `(b) as a Member unless he has been a member of the Council for at least one full term and who is not a sitting member of the Council or who has not been a candidate in the election under dispute; or`
  line
  line `(c) as a Member unless he holds the post of a Joint Secretary to the Government of India or any other post under the Central Government carrying a scale of pay which is not less than that of a Joint Secretary to the Government of India.`
  line
  line `(3) The terms and conditions of service of the Presiding Officer and Members of the Tribunal, their place of meetings and allowances shall be such as may be specified.`
  line
  line `(4) The expenses of the Tribunal shall be borne by the Council.]`
obj_root_law_sections_11:
  sectionId (591)
  sectionNo (11)
  orderNo 13
  title `Nomination in default of election.`
  content `If the members of the Institute fail to elect any member under clause (a) of sub-section (2) of section 9 from any of the regional constituencies that may be notified under that clause, the Central Government may nominate any duly qualified person from such constituency to fill up the vacancy, and any person so nominated shall be deemed to be a duly elected member of the Council.`
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=591&sectionno=11&orderno=13&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (592)
  sectionNo (12)
  orderNo 14
  title `President and Vice-President.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=592&sectionno=12&orderno=14&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_12_content:
  string
  line `(1) The Council at its first meeting shall elect two of its members to be respectively the President and the Vice-President thereof, and so often as the office of the President or the Vice-President falls vacant, the Council shall choose a person to be the President or the`
  line `Vice-President, as the case may be:`
  line
  line `^1* * * *`
  line
  line `(2) The President shall be the ^2[Head] of the Council.`
  line
  line `^3[(2A) The President shall preside at the meetings of the Council.`
  line
  line `(2B) The President and the Vice-President shall exercise such powers and perform such duties and functions as may be prescribed.`
  line
  line `(2C) It shall be the duty of the President to ensure that the decisions taken by the Council are implemented.]`
  line
  line `(3) The President or the Vice-President shall hold office for a period of one year from the date on which he is chosen but so as not to extend beyond his term of office as a member of the Council, and subject to his being a member of the Council at the relevant time, he shall be eligible for re-election ^3[under sub-section (1).]`
  line
  line `^4[(4) On the expiration of the duration of the Council, or of the term of office of the President and the Vice-President thereof, the President and the Vice-President shall continue to hold office until such time as a new President and the Vice-President is elected and takes over charge of their duties.]`
  line
  line `(5) In the event of the occurrence of any vacancy in the office of the President, the Vice-President shall act as President until the date on which a new President elected in accordance with the provisions of this section to fill such vacancy enters upon his office and when the President is unable to discharge his functions owing to absence, illness or any other cause, the Vice-President shall discharge his functions until the date on which the President resumes his duties	.`
obj_root_law_sections_12_footnotes:
  string
  line `1. The proviso omitted by Act 12 of 2022, s. 80 (w.e.f. 10-5-2022).`
  line
  line `2. Subs. by s. 9, ibid., for Chief Executive Authority (w.e.f. 8-8-2006).`
  line
  line `3. Ins. by Act 12 of 2022, s. 80 (w.e.f. 10-5-2022).`
  line
  line `4. Subs. by Act 8 of 2006, s. 9, for sub-section (4) (w.e.f. 8-8-2006).`
obj_root_law_sections_13:
  sectionId (593)
  sectionNo (13)
  orderNo 15
  title `Resignation of membership and casual vacancies.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=593&sectionno=13&orderno=15&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_13_content:
  string
  line `(1) Any member of the Council may at any time resign his membership by writing under his hand addressed to the President, and the seat of such member shall become vacant when such resignation is notified in the Official Gazette.`
  line
  line `(2) A member of the Council shall be deemed to have vacated his seat if he is declared by the Council to have been absent without sufficient excuse from three consecutive meetings of the Council ^1[ or he has been found guilty of any professional or other misconduct and awarded penalty of fine], or of any of the Committees which has been constituted by the Council and of which he is a member or if his name is, for any cause, removed from the ^2[Register of members] under the provisions of section 20.`
  line
  line `(3) A casual vacancy in the office of a member of the Council shall be filled by fresh election from the constituency concerned or by nomination by the Central Government, as the case may be, and the person elected or nominated to fill the vacancy shall hold office until the dissolution of the Council:`
  line
  line `Provided that no election shall be held to fill a casual vacancy occurring within ^3[one year] prior to the date of the expiration of the term of the Council, but such a vacancy may be filled by nomination by the Central Government after consultation with the President of the Council.`
  line
  line `(4) No act done by the Council shall be called in question on the ground merely of the existence of any vacancy in, or defect in the constitution of, the Council.`
obj_root_law_sections_13_footnotes:
  string
  line `1. Ins. by Act 8 of 2006, s. 10 (w.e.f. 17-11-2006).`
  line
  line `2.Subs. by Act 12 of 2022, s. 81, for "Register" (w.e.f. 10-5-2022).`
  line
  line `3. Subs. by Act 8 of 2006, s. 10, for six months (w.e.f. 17-11-2006)`
obj_root_law_sections_14:
  sectionId (594)
  sectionNo (14)
  orderNo 16
  title `Duration and dissolution of the Council.`
  content obj_root_law_sections_14_content
  footnotes `1. Subs. by s. 11, ibid., for "three years" (w.e.f. 19-1-2007).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=594&sectionno=14&orderno=16&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_14_content:
  string
  line `(1) The duration of any Council constituted under`
  line `this Act shall be ^1[four years] from the date of its first meeting.`
  line
  line `(2) Notwithstanding the expiration of the duration of a Council (hereafter in this sub-section referred to as the former Council), the former Council shall continue to exercise its functions under this Act until a new Council is constituted in accordance with the provisions of this Act and on such constitution the former Council shall stand dissolved.`
obj_root_law_sections_15:
  sectionId (595)
  sectionNo (15)
  orderNo 17
  title `Functions of Council.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=595&sectionno=15&orderno=17&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_15_content:
  string
  line `^1[15. Functions of Council.-- (1) The Institute shall function under the overall control, guidance and supervision of the Council and the duty of carrying out the provisions of this Act shall be vested in the Council.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing powers, the duties of the Council shall include`
  line
  line `(a) to approve academic courses and their contents;`
  line
  line `(b) the prescribing of fees for the examination of candidates for enrolment;`
  line
  line `(c) the prescribing of qualifications for entry in the ^2[Register of members];`
  line
  line `(d) the recognition of foreign qualifications and training for purposes of enrolment;`
  line
  line `(e) the prescribing of guidelines for granting or refusal of certificates of practice under this Act;`
  line
  line `^3[(ea) the granting or refusal, of registration of a firm;]`
  line
  line `(f) the levy of fees from members, examinees and other persons;`
  line
  line `(g) the regulation and maintenance of the status and standard of professional qualifications of members of the Institute;`
  line
  line `(h) the carrying out, by granting financial assistance to persons other than members of the Council or in any other manner, of research in such matters of interest to Company Secretaries as may be prescribed;`
  line
  line `(i) to enable functioning of the Director (Discipline), the Board of Discipline, the Disciplinary Committee and the Appellate Authority constituted under the provisions of this Act;`
  line
  line `(j) to enable functioning of the Quality Review Board;`
  line
  line `^3[(ja) to issue guidelines for the purpose of carrying out the objects of this Act;`
  line
  line `(jb) to conduct investor education and awareness programmes;`
  line
  line `(jc) to enter into any memorandum or arrangement with the prior approval of the Central Government, with any agency of any foreign country, for the purpose of performing its functions under this Act;]`
  line
  line `(k) consideration of the recommendations of the Quality Review Board made under clause`
  line `(a) of section 29B and details of action taken thereon in its annual report; and`
  line
  line `(l) to ensure the functioning of the Institute in accordance with the provisions of this Act and in performance of other statutory duties as may be entrusted to the Institute from time to time.`
obj_root_law_sections_15_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 12, for section 15 (w.e.f. 17-11-2006)`
  line
  line `2. Subs. by Act 12 of 2022, s. 82, for "Register" (w.e.f. 10-5-2022).`
  line
  line `3. Ins. by ,s. 82, ibid.,(w.e.f 10-5-2022).`
obj_root_law_sections_15_a:
  sectionId (596)
  sectionNo 15A
  orderNo 18
  title `Functions of Institute.`
  content obj_root_law_sections_15_a_content
  footnotes obj_root_law_sections_15_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=596&sectionno=15A&orderno=18&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_15_a_content:
  string
  line `^1[15A. Functions of Institute.-- The functions of the Institute shall include--`
  line
  line `(a) the examination of candidates for enrolment;`
  line
  line `(b) the regulation of training of students;`
  line
  line `(c) the maintenance and publication of a Register of persons qualified to practice as Company Secretaries;`
  line
  line `^2[(ca) the maintenance and publication of a Register of firms;]`
  line
  line `(d) collection of fees from members, examinees and other persons;`
  line
  line `(e) subject to the orders of the appropriate authorities under this Act, the removal of names from the ^3[Register of members and firms and the restoration of names to the Register of members and firms] which have been removed;`
  line
  line `(f) the maintenance of a library and publication of books and periodicals relating to management of companies and allied subjects;`
  line
  line `(g) the conduct of elections to the Council of the Institute; and`
  line
  line `(h) the granting or refusal of certificates of practice as per guidelines issued by the Council.]`
obj_root_law_sections_15_a_footnotes:
  string
  line `1. Ins. by Act 8 of 2006, s. 13 (w.e.f. 17-11-2006) [in respect of new section 15B (w.e.f. 8-8-2006).]`
  line
  line `2. Ins. by Act 12 of 2022, s. 83 (w.e.f 10-5-2022).`
  line
  line `3. Subs. by s. 83, ibid., for "Register and the restoration to the Register of names" (w.e.f 10-5-2022).`
obj_root_law_sections_15_b:
  sectionId (597)
  sectionNo 15B
  orderNo 19
  title `Imparting education by Universities and other bodies.`
  content obj_root_law_sections_15_b_content
  footnotes `1. Ins. by Act 8 of 2006, s. 13 (w.e.f. 17-11-2006) [in respect of new section 15B (w.e.f. 8-8-2006)].`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=597&sectionno=15B&orderno=19&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_15_b_content:
  string
  line `^1[15B. Imparting education by Universities and other bodies.-- (1) Subject to the provisions of this Act, any University established by law or any body affiliated to the Institute, may impart education on the subjects covered by the academic courses of the Institute.`
  line
  line `(2) The Universities or bodies referred to in sub-section (1) shall, while awarding degree, diploma or certificate or bestowing any designation, ensure that the award or designation do not resemble or is not identical to one awarded by the Institute.`
  line
  line `(3) Nothing contained in this section shall enable a University or a body to adopt a name or`
  line `nomenclature which is in any way similar to that of the Institute.]`
obj_root_law_sections_16:
  sectionId (598)
  sectionNo (16)
  orderNo 20
  title `Officers and employees, salary, allowances, etc.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=598&sectionno=16&orderno=20&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_16_content:
  string
  line `^1[16. Officers and employees, salary, allowances, etc.-- (1) For the efficient performance of its duties, the Council shall--`
  line
  line `(a) appoint a Secretary of the Council to perform such duties as may be prescribed;`
  line
  line `(b) appoint a Director (Discipline) to perform such functions as assigned to him under this Act and the rules and regulations framed thereunder;`
  line
  line `(c) designate an officer of the Council or the Institute to carry out the administrative functions of the Institute as its chief executive.`
  line
  line `(2) The Council may also--`
  line
  line `(a) appoint such other officers and employees to the Council and the Institute as it considers necessary;`
  line
  line `(b) require and take from the Secretary or from any other officer or employee of the Council and the Institute such security for the due performance of his duties, as the Council considers necessary;`
  line
  line `^2[(c) prescribe the manner of appointment, powers, duties and functions of the Secretary and other officers and employees, their salaries, fees, allowances and other terms and conditions of service;]`
  line
  line `(d) with the previous sanction of the Central Government, fix the allowances of the President, Vice-President and other members of the Council and members of its Committees;`
  line
  line `(3) The Secretary of the Council shall be entitled to participate in the meetings of the Council but shall not be entitled to vote thereat..`
obj_root_law_sections_16_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 14 for section 16 (w.e.f. 17-11-2006).`
  line
  line `2. Subs by Act 12 of 2022, s. 84 clause (ii), for clause (c) (w.e.f 10-5-2022).`
obj_root_law_sections_17:
  sectionId (599)
  sectionNo (17)
  orderNo 21
  title `Committees of the Council.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=599&sectionno=17&orderno=21&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_17_content:
  string
  line `(1) The Council shall constitute from amongst its members the following Standing Committees, namely:--`
  line
  line `(a) an Executive Committee;`
  line
  line `^1[(b) a Finance Committee; and]`
  line
  line `(c) an Examination Committee.`
  line
  line `(2) The Council may also constitute a Training and Educational Facilities Committee, Professional Research and Publications Committee and such other Committees from amongst its members as it deems necessary for the purpose of carrying out the provisions of this Act.`
  line
  line `^2[(3) Each of the Standing Committees shall consist of the President and the Vice-President, ex officio, and minimum of three and maximum of five members to be elected by the Council from amongst its members.]`
  line
  line `^3 * * * * *`
  line
  line `(6) Notwithstanding anything contained in this section, any Committee formed under`
  line `sub-section (2), may, with the sanction of the Council co-opt such other members of the Institute not exceeding ^4[one-third of the total membership of the Committee] as the Committee thinks fit, and any member so co-opted shall be entitled to exercise all the rights of a member of the Committee.`
  line
  line `(7) Every Committee constituted under this section shall elect its own Chairman:`
  line `Provided that--`
  line
  line `(i) where the President is a member of such Committee, he shall be the Chairman of such`
  line `Committee, and in his absence, the Vice-President, if he is a member of such Committee, shall be its Chairman; and`
  line
  line `(ii) where the President is not a member of such Committee but the Vice-President is a member, he shall be its Chairman.`
  line
  line `(8) The Standing Committees and other Committees formed under this section shall exercise such functions and be subject to such conditions in the exercise thereof as may be prescribed.`
obj_root_law_sections_17_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 15, for clause (b) (w.e.f. 17-11-2006).`
  line
  line `2. Subs by s. 15, ibid., for sub-section (3) (w.e.f. 17-11-2006)`
  line
  line `3. Sub-sections (4) and (5) omitted by s. 15, ibid. (w.e.f. 17-11-2006).`
  line
  line `4. Subs. by s. 15, ibid., for "two-thirds of the total membership of the Committee" (w.e.f. 17-11-2006).`
obj_root_law_sections_18:
  sectionId (600)
  sectionNo (18)
  orderNo 22
  title `Finances of the Council.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=600&sectionno=18&orderno=22&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_18_content:
  string
  line `(1) There shall be established a fund under the management and control of the Council into which shall be paid all moneys (including donations and grants) received by the Council and out of which shall be met all expenses including any donations made and liabilities properly incurred by the Council.`
  line
  line `(2) The Council may invest any money for the time being standing to the credit of the fund in any Government security or in any other security approved by the Central Government.`
  line
  line `^1[(3) The Council shall keep proper accounts of the fund distinguishing capital from revenue in the manner prescribed.`
  line
  line `(4) The Council shall prepare in the manner prescribed and approve, prior to the start of the financial year, an annual financial statement (the budget) indicating all its anticipated revenues as well as all proposed expenditures for the forthcoming year.`
  line
  line `^2[(5) The annual accounts of the Council shall be prepared in such manner as may be prescribed and subject to audit by a firm of chartered accountants to be appointed annually by the Council from the panel of auditors maintained by the Comptroller and Auditor-General of India:`
  line
  line `Provided that a firm shall not be eligible for appointment as an auditor under this sub-section, if any of its partner is or has been a member of the Council during the last four years:`
  line
  line `Provided further that, in the event it is brought to the notice of the Council that the accounts of the Council do not represent a true and fair view of its finances, then, the Council may itself cause a special audit to be conducted:`
  line
  line `Provided also that, if such information, that the accounts of the Council do not represent a true and fair view of its finances, is sent to the Council by the Central Government, then, the Council may, wherever appropriate cause a special audit or take such other action as it considers necessary and shall furnish an action taken report thereon to the Central Government.`
  line .]
  line
  line `^2[(5A) As soon as may be practicable at the end of each year, the Council shall circulate the audited accounts to its members at least fifteen days in advance and consider and approve these accounts in a special meeting convened for the purpose.`
  line
  line `(5B) The Council shall cause to be published in the Gazette of India not later than the 30th day of September of the year next following, a copy of the audited accounts and the Report of the Council for that year duly approved by the Council and copies of the said accounts and Report shall be forwarded to the Central Government and to all the members of the Institute.]`
  line
  line `(6) Subject to such directions as the Central Government may, by order in writing, make in this behalf, the Council may borrow`
  line
  line `(a) any money required for meeting its liabilities on capital account on the security of the fund or on the security of any other assets for the time being belonging to it; or`
  line
  line `(b) for the purpose of meeting current liabilities pending the receipt of income by way of`
  line `temporary loan or over-draft.`
obj_root_law_sections_18_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 16, for sub-sections (3), (4) and (5) (w.e.f. 17-11-2006).`
  line
  line `2. Subs by Act 12 of 2022, s. 85, for sub-section (5) (w.e.f. 10-5-2022).`
  line
  line `3. Ins. by Act 8 of 2006, s. 16 (w.e.f. 17-11-2006).`
obj_root_law_sections_19:
  sectionId (601)
  sectionNo (19)
  orderNo 23
  title `Register of members.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=601&sectionno=19&orderno=23&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_19_content:
  string
  line `^1[(1) The Council shall maintain a Register of members of the Institute in such manner as may be prescribed.]`
  line
  line `(2) The ^2[Register of members] shall include the following particulars about every member of the Institute,`
  line `namely:`
  line
  line `(a) his full name, date of birth, domicile, residential and professional addresses;`
  line
  line `(b) the date on which his name is entered in the Register;`
  line
  line `(c) his qualifications;`
  line
  line `^3[(ca) whether any actionable information or complaint is pending or any penalty has been imposed against him under Chapter V, including details thereof, if any;]`
  line
  line `(d) whether he holds a certificate of practice; and`
  line
  line `(e) any other particulars which may be prescribed.`
  line
  line `(3) The Council shall cause to be published in such manner as may be prescribed a list of members of the Institute as on the 1st day of April of each year, and shall, if requested to do so by any such member, send him a copy of such list ^4[on payment of such amount as may be prescribed].`
  line
  line `^5[(4) Every member of the Institute shall, on his name being entered in the Register, pay such annual membership fee as may be determined, by notification, by the Council, ^6[***]:`
  line
  line `^7* * * *`
obj_root_law_sections_19_footnotes:
  string
  line `1. Subs by Act 12 of 2022, s. 86, for sub-section (1) (w.e.f. 10-5-2022)`
  line
  line `2. Subs by ,s. 86, ibid for "Register" (w.e.f. 10-5-2022).`
  line
  line `3. Ins by s. 86, ibid., (w.e.f. 10-5-2022).`
  line
  line `4. Ins. by Act 8 of 2006, s. 17 (w.e.f. 17-11-2006).`
  line
  line `5. Subs. by s. 17, ibid., for sub-section (4) (w.e.f. 17-11-2006).`
  line
  line `6. The words ,which shall not exceed rupees five thousand omitted by Act 12 of 2022, s.86 (w.e.f. 10-5-2022)`
  line
  line `7. The proviso omitted by s. 86, ibid (w.e.f. 10-5-2022).`
obj_root_law_sections_20:
  sectionId (602)
  sectionNo (20)
  orderNo 24
  title `Removal from the Register of members.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=602&sectionno=20&orderno=24&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_20_content:
  string
  line `(1) The Council may remove from the ^1[Register of members] the name of any member of the Institute--`
  line
  line `(a) who is dead; or`
  line
  line `(b) from whom a request has been received to that effect; or`
  line
  line `(c) who has not paid any prescribed fee required to be paid by him; or`
  line
  line `(d) who is found to have been subject at the time when his name was entered in the ^1[Register of members], or who at any time thereafter has become subject, to any of the disabilities mentioned in section 8, or who for any other reason has ceased to be entitled to have his name borne on the ^1[Register of members].`
  line
  line `(2) The Council shall remove from the ^1[Register of members] the name of any member in respect of whom an order has been passed under this Act removing him from membership of the Institute.`
  line
  line `^2[(3) If the name of any member has been removed from the ^1[Register of members] under clause (c) of sub-section (1), on receipt of an application, his name may be entered again in the ^1[Register of members] on payment of the arrears of annual fee and entrance fee along with such additional fee, as may be determined, by notification, by the Council, ^3[***]:`
  line
  line `^4 * * * *`
obj_root_law_sections_20_footnotes:
  string
  line `1. Subs. by Act 12 of 2022, s. 87, for "Register" (w.e.f. 10-5-2022).`
  line
  line `2. Ins. by Act 8 of 2006, s. 18 (w.e.f. 8-8-2006).`
  line
  line `3.The words ",which shall not exceed rupees two thousand" omitted by Act 12 of 2022, s. 87 (w.e.f 10-5-2022).`
  line
  line `4. The proviso omitted by s. 87, ibid., (w.e.f. 10-5-2022).`
obj_root_law_sections_21:
  sectionId (603)
  sectionNo (21)
  orderNo 25
  title `Disciplinary Directorate.`
  content obj_root_law_sections_21_content
  footnotes `1. Subs. by s. 19, ibid., for section 21 (w.e.f. 17-11-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=603&sectionno=21&orderno=25&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_21_content:
  string
  line `^1[21. Disciplinary Directorate.-- (1) The Council shall, by notification, establish a Disciplinary Directorate headed by an officer of the Institute designated as Director (Discipline) and such other employees for making investigations in respect of any information or complaint received by it.`
  line
  line `(2) On receipt of any information or complaint along with the prescribed fee, the Director (Discipline) shall arrive at a prima facie opinion on the occurrence of the alleged misconduct.`
  line
  line `(3) Where the Director (Discipline) is of the opinion that a member is guilty of any professional or other misconduct mentioned in the First Schedule, he shall place the matter before the Board of Discipline and where the Director (Discipline) is of the opinion that a member is guilty of any professional or other misconduct mentioned in the Second Schedule or in both the Schedules, he shall place the matter before the Disciplinary Committee.`
  line
  line `(4) In order to make investigations under the provisions of this Act, the Disciplinary Directorate shall follow such procedure as may be specified.`
  line
  line `(5) Where a complainant withdraws the complaint, the Director (Discipline) shall place such withdrawal before the Board of Discipline or as the case may be, the Disciplinary Committee, and the said Board or Committee may, if it is of the view that the circumstances so warrant, permit the withdrawal at any stage.]`
obj_root_law_sections_21_a:
  sectionId (604)
  sectionNo 21A
  orderNo 26
  title `Board of Discipline.`
  content obj_root_law_sections_21_a_content
  footnotes `1. Ins. by Act 8 of 2006, s. 20 (w.e.f. 17-11-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=604&sectionno=21A&orderno=26&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_21_a_content:
  string
  line `^1[21A. Board of Discipline. -- (1) The Council shall constitute a Board of Discipline consisting of--`
  line
  line `(a) a person with experience in law and having knowledge of the disciplinary matters and the profession, to be its presiding officer;`
  line
  line `(b) two members one of whom shall be a member of the Council elected by the Council and the other member shall be the person designated under clause (c) of sub-section (1) of section 16;`
  line
  line `(c) the Director (Discipline) shall function as the Secretary of the Board.`
  line
  line `(2) The Board of Discipline shall follow summary disposal procedure in dealing with all the cases before it.`
  line
  line `(3) Where the Board of Discipline is of the opinion that a member is guilty of a professional or other misconduct mentioned in the First Schedule, it shall afford to the member an opportunity of being heard before making any order against him and may thereafter take any one or more of the following actions, namely:--`
  line
  line `(a) reprimand the member;`
  line
  line `(b) remove the name of the member from the Register up to a period of three months;`
  line
  line `(c) impose such fine as it may think fit which may extend to rupees one lakh.`
  line
  line `(4) The Director (Discipline) shall submit before the Board of Discipline all information and`
  line `complaints where he is of the opinion that there is no prima facie case and the Board of Discipline may, if it agrees with the opinion of the Director (Discipline), close the matter or in case of disagreement, may advise the Director (Discipline) to further investigate the matter`
obj_root_law_sections_21_b:
  sectionId (605)
  sectionNo 21B
  orderNo 27
  title `Disciplinary Committee.`
  content obj_root_law_sections_21_b_content
  footnotes `1. Ins. by Act 8 of 2006, s. 20 (w.e.f. 17-11-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=605&sectionno=21B&orderno=27&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_21_b_content:
  string
  line `^1[21B. Disciplinary Committee. -- (1) The Council shall constitute a Disciplinary Committee consisting of the President or the Vice-President of the Council as the Presiding Officer and two members to be elected from amongst the members of the Council and two members to be nominated by the Central Government from amongst the persons of eminence having experience in the field of law, economics, business, finance or accountancy:`
  line
  line `Provided that the Council may constitute more Disciplinary Committees as and when it considers necessary.`
  line
  line `(2) The Disciplinary Committee, while considering the cases placed before it, shall follow such procedure as may be specified.`
  line
  line `(3) Where the Disciplinary Committee is of the opinion that a member is guilty of a professional or other misconduct mentioned in the Second Schedule or both the First Schedule and the Second Schedule, it shall afford to the member an opportunity of being heard before making any order against him and may thereafter take any one or more of the following actions, namely:--`
  line
  line `(a) reprimand the member;`
  line
  line `(b) remove the name of the member from the Register permanently or for such period, as it thinks fit;`
  line
  line `(c) impose such fine as it may think fit, which may extend to rupees five lakhs.`
  line
  line `(4) The allowances payable to the members nominated by the Central Government shall be such as may be specified.]`
obj_root_law_sections_21_c:
  sectionId (606)
  sectionNo 21C
  orderNo 28
  title `Authority, Disciplinary Committee, Board of Discipline and Director (Discipline) to have powers of civil court.`
  content obj_root_law_sections_21_c_content
  footnotes obj_root_law_sections_21_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=606&sectionno=21C&orderno=28&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_21_c_content:
  string
  line `^1[21C. Authority, Disciplinary Committee, Board of Discipline and Director (Discipline) to have`
  line `powers of civil court. -- For the purposes of an inquiry under the provisions of this Act, the Authority, the`
  line `Disciplinary Committee, Board of Discipline and the Director (Discipline) shall have the same powers as are vested in a civil court under the Code of Civil Procedure, 1908 (5 of 1908), in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) the discovery and production of any document; and`
  line
  line `(c) receiving evidence on affidavit.`
  line
  line `^2 * * * *`
obj_root_law_sections_21_c_footnotes:
  string
  line `1. Ins. by Act 8 of 2006, s. 20 (w.e.f. 17-11-2006).`
  line
  line `2. The Explanation omitted by Act 12 of 2022, s. 92 (w.e.f. 10-5-2022).`
obj_root_law_sections_21_d:
  sectionId (607)
  sectionNo 21D
  orderNo 29
  title `Transitional provisions.`
  content `^1[21D. Transitional provisions.-- All complaints pending before the Council or any inquiry initiated by the Disciplinary Committee or any reference or appeal made to a High Court prior to the commencement of the Company Secretaries (Amendment) Act, 2006 (8 of 2006) shall continue to be governed by the provisions of this Act, as if this Act had not been amended by the Company Secretaries (Amendment) Act, 2006.]`
  footnotes `1. Ins. by Act 8 of 2006, s. 20 (w.e.f. 17-11-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=607&sectionno=21D&orderno=29&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_22:
  sectionId (608)
  sectionNo (22)
  orderNo 30
  title `Professional or other misconduct defined.`
  content `^1[22. Professional or other misconduct defined.-- For the purposes of this Act, the expression "professional or other misconduct" shall be deemed to include any act or omission provided in any of the Schedules, but nothing in this section shall be construed to limit or abridge in any way the power conferred or duty cast on the Director (Discipline) under sub-section (1) of section 21 to inquire into the conduct of any member of the Institute under any other circumstances.]`
  footnotes `1. Subs. by Act 8 of 2006, s. 21, for section 22 (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=608&sectionno=22&orderno=30&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_22_a:
  sectionId (609)
  sectionNo 22A
  orderNo 31
  title `Constitution of Appellate Authority.`
  content obj_root_law_sections_22_a_content
  footnotes `1. Ins. by s. 22, ibid. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=609&sectionno=22A&orderno=31&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_22_a_content:
  string
  line `^1[[22A. Constitution of Appellate Authority.-- The Appellate Authority constituted under sub-section (1) of section 22A of the Chartered Accountants Act, 1949 (38 of 1949), shall be deemed to be the Appellate Authority for the purposes of this Act subject to the modification that for clause (b) of said sub-section (1), the following clause had been substituted, namely:--`
  line
  line `"(b) the Central Government shall, by notification appoint two part-time members from amongst the persons who have been members of the Council of the Institute of Company Secretaries of India for at least one full term and who is not a sitting member of the Council;].`
obj_root_law_sections_22_b:
  sectionId (610)
  sectionNo 22B
  orderNo 32
  title `Term of office of members of Authority.`
  content `^1[22B. Term of office of members of Authority.-- A person appointed as a member shall hold office for a term of three years from the date on which he enters upon his office or until he attains the age of sixty-two years, whichever is earlier.]`
  footnotes `1. Ins. by s. 22, ibid. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=610&sectionno=22B&orderno=32&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_22_c:
  sectionId (611)
  sectionNo 22C
  orderNo 33
  title `Procedure, etc., of Authority.`
  content obj_root_law_sections_22_c_content
  footnotes `1. Ins. by s. 22, ibid. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=611&sectionno=22C&orderno=33&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_22_c_content:
  string
  line `^1[22C. Procedure, etc., of Authority.-- The provisions of section 22C, section 22D and section 22F of the Chartered Accountants Act, 1949 (38 of 1949) shall apply to the Authority in relation to allowances and terms and conditions of service of its Chairperson and members, and in the discharge of its functions`
  line `under this Act as they apply to it in the discharge of its functions under the Chartered Accountants Act, 1949.]`
obj_root_law_sections_22_d:
  sectionId (612)
  sectionNo 22D
  orderNo 34
  title `Officers and other staff of Authority.`
  content obj_root_law_sections_22_d_content
  footnotes `1. Ins. by s. 22, ibid. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=612&sectionno=22D&orderno=34&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_22_d_content:
  string
  line `^1[22D. Officers and other staff of Authority.-- (1) The Council shall make available to the Authority such officers and other staff members as may be necessary for the efficient performance of the functions of the Authority.`
  line
  line `(2) The salaries and allowances and conditions of service of the officers and other staff members of the Authority shall be such as may be prescribed.]`
obj_root_law_sections_22_e:
  sectionId (613)
  sectionNo 22E
  orderNo 35
  title `Appeal to Authority.`
  content obj_root_law_sections_22_e_content
  footnotes `1. Ins. by s. 22, ibid. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=613&sectionno=22E&orderno=35&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_22_e_content:
  string
  line `^1[22E. Appeal to Authority.-- (1) Any member of the Institute aggrieved by any order of the Board`
  line `of Discipline or the Disciplinary Committee imposing on him any of the penalties referred to in`
  line `sub-section (3) of section 21A and sub-section (3) of section 21B, may within ninety days from the date on which the order is communicated to him, prefer an appeal to the Authority:`
  line
  line `Provided that the Director (Discipline) may also appeal against the decision of the Board of`
  line `Discipline or the Disciplinary Committee to the Authority if so authorised by the Council, within ninety days:`
  line
  line `Provided further that the Authority may entertain any such appeal after the expiry of the said period of ninety days, if it is satisfied that there was sufficient cause for not filing the appeal in time.`
  line
  line `(2) The Authority may, after calling for the records of any case, revise any order made by the Board of Discipline or the Disciplinary Committee under sub-section (3) of section 21A and sub-section (3) of section 21B and may--`
  line
  line `(a) confirm, modify or set aside the order;`
  line
  line `(b) impose any penalty or set aside, reduce, or enhance the penalty imposed by the order;`
  line
  line `(c) remit the case to the Board of Discipline or Disciplinary Committee for such further enquiry as the Authority considers proper in the circumstances of the case; or`
  line
  line `(d) pass such other order as the Authority thinks fit: Provided that the Authority shall give an opportunity of being heard to the parties concerned before passing any order.]`
obj_root_law_sections_23:
  sectionId (614)
  sectionNo (23)
  orderNo 36
  title `Constitution and functions of Regional Councils.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=614&sectionno=23&orderno=36&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_23_content:
  string
  line `(1) For the purpose of advising and assisting it on matters concerning its functions, the Council may constitute such Regional Councils as and when it deems fit for one or more of the regional constituencies that may be notified by the Central Government under clause (a) of sub-section (2) of section 9.`
  line
  line `(2) The Regional Councils shall be constituted in such manner and exercise such functions as may be prescribed.`
  line
  line `(3) Notwithstanding anything contained in this section, each Regional Council of the dissolved company shall, on the commencement of this Act, become the Regional Council of the Institute for the area for which it was functioning as a Regional Council immediately before such commencement and shall function as such--`
  line
  line `(i) for a period of two years from such commencement, or`
  line
  line `(ii) till a Regional Council is constituted for such area in accordance with the provisions of this`
  line section,
  line
  line `whichever is earlier.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (615)
  sectionNo (24)
  orderNo 37
  title `Penalty for falsely claiming to be a member, etc.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=615&sectionno=24&orderno=37&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_24_content:
  string
  line `Subject to the provisions of section 7, any person who,`
  line
  line `(a) not being a member of the Institute,--`
  line
  line `(i) represents that he is a member of the Institute; or`
  line
  line `(ii) uses the designation Company Secretary; or`
  line
  line `(iii) uses the letters A.C.S. or F.C.S. after his name; or`
  line
  line `(b) being a member of the Institute, but not having a certificate of practice, represents that he is in practice or practises as a Company Secretary,`
  line
  line `shall be punishable on first conviction with fine which may extend to ^1[one lakh rupees], and on any subsequent conviction with imprisonment which may extend to six months, or with fine which may extend to ^2[five lakh rupees], or with both.`
obj_root_law_sections_24_footnotes:
  string
  line `1. Subs by Act 12 of 2022, s. 96, for “one thousand rupees” (w.e.f. 10-5-2022).`
  line
  line `2. Subs by, s. 96, ibid., for “five thousand rupees” (w.e.f. 10-5-2022).`
obj_root_law_sections_25:
  sectionId (616)
  sectionNo (25)
  orderNo 38
  title `Penalty for using name of the Council, or awarding degree of Company Secretary.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=616&sectionno=25&orderno=38&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_25_content:
  string
  line `(1) Save as otherwise provided in this Act, no person shall--`
  line
  line `(a) use a name or a common seal which is identical with the name or the common seal of the`
  line `Institute or so nearly resembles it as to deceive or as is likely to deceive the public;`
  line
  line `(b) award any degree, diploma or certificate or bestow any designation which indicates or`
  line `purports to indicate the position or attainment of any qualification or competence in Company`
  line `Secretaryship similar to that of a member of the Institute; or`
  line
  line `(c) seek to regulate in any manner whatsoever the profession of Company Secretaries.`
  line
  line `(2) Any person contravening the provisions of sub-section (1) shall, without prejudice to any other proceedings which may be taken against him, ^1[be punishable with imprisonment which may extend to six months or with fine which shall not be less than one lakh rupees but which may extend to five lakh rupees or with both on first conviction], and on any subsequent conviction with imprisonment which may extend to ^2[one year, or with fine which shall not be less than two lakh rupees but which may extend to ten lakh rupees], or with both.`
  line
  line `^3	[*`
  line
  line *
  line
  line *
  line
  line *
  line
  line *]
obj_root_law_sections_25_footnotes:
  string
  line `1 .Subs by, s. 97, ibid., for be punishable on first conviction with fine which may extend to one thousand rupees. (w.e.f. 10-5-2022).`
  line
  line `2.. Subs by, s. 97, ibid., for six months, or with fine which may extend to five thousand rupees. (w.e.f. 10-5-2022).`
  line
  line `3. Sub-section (3) omitted by Act 8 of 2006, s. 23 (w.e.f. 8-8-2006).`
obj_root_law_sections_26:
  sectionId (617)
  sectionNo (26)
  orderNo 39
  title `Companies not to engage in Company Secretaryship.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=617&sectionno=26&orderno=39&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_26_content:
  string
  line `(1) No company, whether incorporated in India or elsewhere, shall practise as Company Secretaries.`
  line
  line `^1[Explanation.-- For the removal of doubts, it is hereby declared that the company shall include any limited liability partnership which has company as its partner for the purposes of this section.]`
  line
  line `^2[(2) If any company contravenes the provisions of sub-section (1), then every director, manager,`
  line `Secretary and any other officer who is knowingly a party to such contravention shall be punished on first`
  line `conviction with fine which shall not be less than two lakh rupees but which may extend to ten lakh`
  line `rupees, and on any subsequent conviction with fine which shall not be less than four lakh rupees but`
  line `which may extend to twenty lakh rupees.].`
obj_root_law_sections_26_footnotes:
  string
  line `1. Explanation ins. by Act 4 of 2012, s. 3 (w.e.f. 8-1-2012)`
  line
  line `2. Subs by Act 12 of 2022, s. 98, for sub-section (2) (w.e.f. 10-5-2022).`
obj_root_law_sections_27:
  sectionId (618)
  sectionNo (27)
  orderNo 40
  title `Unqualified persons not to sign documents.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=618&sectionno=27&orderno=40&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_27_content:
  string
  line `(1) No person other than a member of the Institute shall sign any document on behalf of a Company Secretary in practice or a firm of such Company Secretaries in his or its professional capacity.`
  line
  line `^1[(2) Any person who contravenes the provisions of sub-section (1) shall, without prejudice to any other proceedings which may be taken against him, be punishable on first conviction with a fine not less than ^2[one lakh rupees] but which may extend to ^3[five lakh rupees], and in the event of a second or subsequent conviction with imprisonment for a term which may extend to one year or with a fine not less than ^4[two lakh rupees] but which may extend to ^5[ten lakh rupees] or with both.]`
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 24, for sub-section (2) (w.e.f. 8-8-2006).`
  line
  line `2. Subs by Act 12 of 2022, s. 99, for “five thousand rupees” (w.e.f. 10-5-2022).`
  line
  line `3. Subs by , s. 99, ibid., for “one lakh rupees” (w.e.f. 10-5-2022).`
  line
  line `4. Subs by , s. 99, ibid., for “ten thousand rupees” (w.e.f. 10-5-2022).`
  line
  line `5. Subs by , s. 99, ibid., for “two lakh rupees” (w.e.f. 10-5-2022).`
obj_root_law_sections_28:
  sectionId (619)
  sectionNo (28)
  orderNo 41
  title `Offences by companies.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=619&sectionno=28&orderno=41&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_28_content:
  string
  line `(1) If the person committing an offence under this Act is a company, the company as well as every person in charge of, and responsible to, the company for the conduct of its`
  line `business at the time of the commission of the offence shall be deemed to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any punishment if he proves that the offence was committed without his knowledge or that he had exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been committed by a company and it is proved that the offence has been committed with the consent or connivance of, or that the commission of the offence is attributable to any neglect on the part of, any director, manager, secretary or other officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty of that offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) company means any body corporate and includes a firm or other association of individuals; and`
  line
  line `(b) director, in relation to a firm, means a partner in the firm.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (620)
  sectionNo (29)
  orderNo 42
  title `Sanction to prosecute.`
  content `No person shall be prosecuted under this Act except on a complaint made by or under the order of the Council or of the Central Government.`
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=620&sectionno=29&orderno=42&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_29_a:
  sectionId (621)
  sectionNo 29A
  orderNo 43
  title `Establishment of Quality Review Board.`
  content obj_root_law_sections_29_a_content
  footnotes `1. Ins. by Act 8 of 2006, s. 25. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=621&sectionno=29A&orderno=43&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_29_a_content:
  string
  line `^1[29A. Establishment of Quality Review Board. -- (1) The Central Government shall, by notification, constitute a Quality Review Board consisting of a Chairperson and four other members`
  line
  line `(2) The Chairperson and members of the Board shall be appointed from amongst the persons of eminence having experience in the field of law, economics, business, finance or accountancy.`
  line
  line `(3) Two members of the Board shall be nominated by the Council and other two members shall be nominated by the Central Government.]`
obj_root_law_sections_29_b:
  sectionId (622)
  sectionNo 29B
  orderNo 44
  title `Functions of Board.`
  content obj_root_law_sections_29_b_content
  footnotes obj_root_law_sections_29_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=622&sectionno=29B&orderno=44&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_29_b_content:
  string
  line `^1[29B. Functions of Board.-- The Board shall perform the following functions, namely:--`
  line
  line `(a) to make recommendations to the Council with regard to the quality of services provided by the members of the Institute;`
  line
  line `(b) to review the quality of services provided by the members of the Institute including secretarial services; and`
  line
  line `(c) to guide the members of the Institute to improve the quality of services and adherence to the various statutory and other regulatory requirements.]`
  line
  line `^2[(d) to forward cases of non-compliance with various statutory and regulatory requirements by the members of the Institute or firms, noticed by it during the course of its review, to the Disciplinary Directorate for its examination.]`
obj_root_law_sections_29_b_footnotes:
  string
  line `1. Ins. by Act 8 of 2006, s. 25. (w.e.f. 17-11-2006)`
  line
  line `2. Ins. by Act 12 of 2022, s. 100, (w.e.f. 10-5-2022).`
obj_root_law_sections_29_c:
  sectionId (624)
  sectionNo 29C
  orderNo 45
  title `Procedure of Board`
  content obj_root_law_sections_29_c_content
  footnotes `1. Ins. by Act 8 of 2006, s. 25. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=624&sectionno=29C&orderno=45&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_29_c_content:
  string
  line `^1[29C. Procedure of Board. -- The Board shall meet at such time and place and follow in its meetings`
  line `such procedure as may be specified.]`
obj_root_law_sections_29_d:
  sectionId (625)
  sectionNo 29D
  orderNo 46
  title `Terms and conditions of service of Chairperson and members of Board and its expenditure`
  content obj_root_law_sections_29_d_content
  footnotes `1. Ins. by s. 25, ibid. (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=625&sectionno=29D&orderno=46&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_29_d_content:
  string
  line `^1[29D. Terms and conditions of service of Chairperson and members of Board and its`
  line `expenditure.-- (1) The terms and conditions of service of the Chairperson and the members of the Board,`
  line `and their allowances shall be such as may be specified.`
  line
  line `(2) The expenditure of the Board shall be borne by the Council.]`
obj_root_law_sections_30:
  sectionId (626)
  sectionNo (30)
  orderNo 47
  title `Amendment of Act 8 of 2006`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=626&sectionno=30&orderno=47&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_30_content:
  string
  line `[Amendment of Act 8 of 2006].—Omitted by the Company Secretaries Act, 2006 (8 of 2006)`
  line `s. 2 and the First Schedule (w.e.f. 17-11-2006).`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (627)
  sectionNo (31)
  orderNo 48
  title `Dissolution of the Institute of Company Secretaries of India registered under the Companies Act.—`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=627&sectionno=31&orderno=48&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_31_content:
  string
  line `On the commencement of this Act--`
  line
  line `(a) the company known as the Institute of Company Secretaries of India registered under the`
  line `Companies Act shall stand dissolved and thereafter no person shall make, assert or take any claims or demands or proceedings against the dissolved company or against any officer thereof in his capacity as such officer except in so far as may be necessary, for enforcing the provisions of this Act;`
  line
  line `(b) the right of every member to, or in respect of, the dissolved company shall be extinguished, and thereafter no member of that company shall make, assert or take any claims or demands or proceedings in respect of that company except as provided in this Act`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (628)
  sectionNo (32)
  orderNo 49
  title `Transfer of assets and liabilities of the dissolved company to the Institute.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=628&sectionno=32&orderno=49&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_32_content:
  string
  line `(1) On the commencement of this Act, there shall be transferred to and vested in the Institute all the assets and liabilities of the dissolved company.`
  line
  line `(2) The assets of the dissolved company shall be deemed to include all rights and powers, and all property, whether movable or immovable, of that company, including in particular, cash balances, reserve funds, investments, deposits and all other interests and rights in or arising out of such property as may be in the possession of the dissolved company and all books of accounts, papers or documents of the dissolved company; and the liabilities shall be deemed to include all debts, liabilities and obligations of whatever kind then existing of that company.`
  line
  line `(3) All contracts, debts, bonds, agreements and other instruments of whatever nature to which the dissolved company is a party, subsisting or having effect immediately before the commencement of this Act, shall be of as full force and effect against or in favour of the Institute, as the case may be, and may be enforced as fully and effectively as if instead of the dissolved company, the Institute had been a party thereto.`
  line
  line `(4) If, on the commencement of this Act, any suit, appeal or other legal proceeding of whatever nature by or against the dissolved company is pending, the same shall not abate, be discontinued or be in any way prejudicially affected by reason of the transfer to the Institute of the assets and liabilities of the dissolved company or of anything contained in this Act, but the suit, appeal or other proceeding may be continued, prosecuted and enforced by or against the Institute, in the same manner and to the same extent as it would or may be continued, prosecuted and enforced by or against the dissolved company if this Act had not been passed.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (629)
  sectionNo (33)
  orderNo 50
  title `Provisions respecting employees of the dissolved company`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=629&sectionno=33&orderno=50&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_33_content:
  string
  line `(1) Every person employed in the dissolved company and continuing in its employment immediately before the commencement of this Act shall, as from such commencement, become an employee of the Institute, shall hold his office or service therein by the same tenure and upon the same terms and conditions and with the same rights and privileges as to pension and gratuity as he would have held the same under the dissolved company if this`
  line `Act had not been passed, and shall continue to do so unless and until his employment in the Institute is terminated or until his remuneration, terms and conditions of employment are duly altered by the Institute.`
  line
  line `(2) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947) or in any other law for the time being in force, the transfer of the services of any employee of the dissolved company to the Institute shall not entitle any such employee to any compensation under that Act or other law, and no such claim shall be entertained by any court, tribunal or other authority.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (630)
  sectionNo (34)
  orderNo 51
  title `Coordination Committee`
  content `^1[The Coordination Committee constituted under section 9A of the Chartered Accountants Act, 1949 (38 of 1949), shall be deemed to be the Coordination Committee for the purposes of this Act.]`
  footnotes `1. Subs by Act 12 of 2022, s. 101, for section 34 (w.e.f. 10-5-2022).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=630&sectionno=34&orderno=51&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_35:
  sectionId (631)
  sectionNo (35)
  orderNo 52
  title `Directions of the Central Government`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=631&sectionno=35&orderno=52&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_35_content:
  string
  line `(1) The Central Government may, from time to time, issue such directions to the Council as in the opinion of the Central Government are conducive to the fulfilment of the objects of this Act and in the discharge of its functions, the Council shall be bound to carry out any such directions.`
  line
  line `(2) Directions issued under sub-section (1) may include directions to the Council to make any regulations or to amend or revoke any regulations already made.`
  line
  line `(3) If, in the opinion of the Central Government, the Council has persistently committed default in giving effect to the directions issued under this section, the Central Government may, after giving an opportunity to the Council to state its case, by order, dissolve the Council, whereafter a new Council shall be constituted in accordance with the provisions of this Act with effect from such date as may be specified by the Central Government.`
  line
  line `(4) Where the Central Government passes an order under sub-section (3) dissolving the Council, it may, pending the constitution of a new Council in accordance with the provisions of this Act, authorise any person or body of persons to take over the management of the affairs of the Institute and to exercise such functions as may be specified in this behalf by the Central Government`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (632)
  sectionNo (36)
  orderNo 53
  title `Protection of action taken in good faith`
  content obj_root_law_sections_36_content
  footnotes `1. Subs. by Act 8 of 2006, s. 27, for section 36 (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=632&sectionno=36&orderno=53&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_36_content:
  string
  line `^1[36. Protection of action taken in good faith.-- No suit, prosecution or other legal proceeding shall lie against the Central Government or the Council or the Authority or the Disciplinary Committee or the Tribunal or the Board or the Board of Discipline or the Disciplinary Directorate or any officer of that Government, Council, Authority, Disciplinary Committee, Tribunal, Board, Board of Discipline or the Disciplinary Directorate, for anything which is in good faith done or intended to be done under this Act or`
  line `any rule, regulation, notification, direction or order made thereunder.]`
obj_root_law_sections_36_a:
  sectionId (633)
  sectionNo 36A
  orderNo 54
  title `Members, etc., to be public servants.`
  content obj_root_law_sections_36_a_content
  footnotes `1. Ins. by Act 8 of 2006, s. 28 (w.e.f. 17-11-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=633&sectionno=36A&orderno=54&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_36_a_content:
  string
  line `^1[36A. Members, etc., to be public servants.-- The Chairperson, Presiding Officer, members and`
  line `other officers and employees of the Authority, Disciplinary Committee, Tribunal, Board, Board of Discipline or the Disciplinary Directorate shall be deemed to be public servants within the meaning of section 21 of the Indian Penal Code (45 of 1860).]`
obj_root_law_sections_37:
  sectionId (634)
  sectionNo (37)
  orderNo 55
  title `Maintenance of branch offices.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=634&sectionno=37&orderno=55&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_37_content:
  string
  line `(1) Where a Company Secretary in practice or a firm of such Company Secretaries has more than one office in India, each one of such offices shall be in the separate charge of a member of the Institute:`
  line
  line `Provided that the Council may in suitable cases exempt any Company Secretary in practice or firm of such Company Secretaries from the operation of this sub-section.`
  line
  line `(2) Every Company Secretary in practice or firm of such Company Secretaries maintaining more than one office shall send to the Council a list of offices and the persons in charge thereof and shall keep the Council informed of any changes in relation thereto`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (635)
  sectionNo (38)
  orderNo 56
  title Reciprocity
  content obj_root_law_sections_38_content
  footnotes `1. Subs. by Act 12 of 2022, s. 102, for “Register” (w.e.f. 10-5-2022).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=635&sectionno=38&orderno=56&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_38_content:
  string
  line `(1) Where any country, notified by the Central Government in this behalf in the`
  line `Official Gazette, prevents persons of Indian domicile from becoming members of any institution similar to the Institute established under this Act or from practising the profession of Company Secretaryship or subjects them to unfair discrimination in that country, no subject of any such country shall be entitled to become a member of the Institute or practise the profession of Company Secretaries in India.`
  line
  line `(2) Subject to the provisions of sub-section (1), the Council may prescribe the conditions, if any, subject to which foreign qualifications relating to Company Secretaryship shall be recognised for the purposes of entry in the ^1[Register of members].`
obj_root_law_sections_38_a:
  sectionId (636)
  sectionNo 38A
  orderNo 57
  title `Power of Central Government to make rules`
  content obj_root_law_sections_38_a_content
  footnotes obj_root_law_sections_38_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=636&sectionno=38A&orderno=57&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_38_a_content:
  string
  line `^1[38A. Power of Central Government to make rules.-- (1) The Central Government may, by notification, make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing powers, such rules may provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of election and nomination in respect of members to the Council under`
  line `sub-section (2) of section 9;`
  line
  line `(b) the terms and conditions of service of the Presiding Officer and Members of the Tribunal,`
  line `place of meetings and allowances to be paid to them under sub-section (3) of section 10B;`
  line
  line `^2[(c) the form, manner and fee for filing an information or a complaint under sub-section (1), the manner of deciding a complaint or information as actionable or non-actionable under sub-section (2) and the procedure of investigation under sub-section (7), of section 21;`
  line
  line `(d) the procedure while considering the cases by the Boards of Discipline under sub-section (2) and time limit for payment of fine under sub-section (7), of section 21A;`
  line
  line `(da) the procedure while considering the cases by the Disciplinary Committees under sub-section (2) and time-limit for payment of fine under sub-section (7), of section 21B;]`
  line
  line `(e) the procedure to be followed by the Board in its meetings under section 29C; and`
  line
  line `(f) the terms and conditions of service of the Chairperson and members of the Board under`
  line `sub-section (1) of section 29D.`
obj_root_law_sections_38_a_footnotes:
  string
  line `1. Ins. by Act 8 of 2006, s. 29. (w.e.f. 8-8-2006).`
  line
  line `2. Subs. by Act 12 of 2022, s. 103, for clauses (c) and (d) (w.e.f. 10-5-2022).`
obj_root_law_sections_39:
  sectionId (637)
  sectionNo (39)
  orderNo 58
  title `Power to make regulations.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=637&sectionno=39&orderno=58&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_39_content:
  string
  line `(1) The Council may, by notification in the Gazette of India, make regulations for the purpose of carrying out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such regulations may provide for all or any of the following matters, namely:--`
  line
  line `(a) the professions that may be recognised under sub-section (2) of section 2 and ^1[item (2)] and`
  line
  line `(4) of Part I of the First Schedule;`
  line
  line `(b) the examinations and training for the purposes of clauses (c), (d) and (e) of sub-section (1) of section 4;`
  line
  line `(c) the manner of making an application and granting thereof under sub-section (3) of section 4 or sub-section (3) of section 5;`
  line
  line `(d) the fees payable under sub-section (3) of section 4, sub-section (3) of section 5, sub-section (2) of section 6, ^2[***] sub-section (2) of section 15, sub-section (4) of section 19 and clause (c) of sub-section (1) of section 20;`
  line
  line `(e) the qualifications and practical experience for the purposes of sub-section (3) of section 5;`
  line
  line `(f) the form in which an application may be made under sub-section (2) of section 6;`
  line
  line `^3[(fa) the circumstances under which certificates of practice may be cancelled under sub-section (3) of section 6;`
  line
  line `(fb) the powers, duties and functions of the President and the Vice-President of the Council under sub-section (2B) of section 12;]`
  line
  line `^4 * * * * *`
  line
  line `(h) the transaction of business by the Council for the discharge of its functions under section 15and other provisions of this Act, the place at which and the intervals at which the Council shall hold its meetings for the transaction of such business, the procedure to be followed at such meetings and all other matters connected therewith;`
  line
  line `^3[(ha) guidelines for granting or refusal of certificates of practice under clause (e) of sub-section (2) of section 15;]`
  line
  line `(i) the regulation and maintenance of the status and standards of professional qualifications of members of the Institute, as required by ^4[clause (g)] of sub-section (2) of section 15;`
  line
  line `(j) the carrying out of research in matters of interest to Company Secretaries as required by ^5[clause (h)] of sub-section (2) of section 15;`
  line
  line `(k) the maintenance of libraries and publication of books and periodicals relating to management of companies and allied subjects, as required by ^6[clause (f) of section 15A];`
  line
  line `^3[(ka) the manner of appointment, powers, duties, functions, salaries, fees, allowances and other terms and conditions of service of the Secretary and other officers and employees of the Council under clause (c) of sub-section (2) of section 16;]`
  line
  line `^7 * * *`
  line
  line `(m) the transaction of business by the Standing Committees and other Committees referred to in section 17, the places at which and the intervals at which such Committees shall hold their meetings for the transaction of such business, the procedure to be followed at such meeting and all other matters connected therewith;`
  line
  line `^3[(ma) the maintenance of accounts under sub-section (3), the manner of preparing annual financial statement under sub-section (4) and the manner of preparing the annual accounts of the Council under sub-section (5), of section 18;]`
  line
  line `(n) the manner in which the Register may be maintained under sub-section (1) of section 19;`
  line
  line `(o) the other particulars to be included in the Register, as required by clause (e) of sub-section (2) of section 19;`
  line
  line `^8[(p) the manner of making an application for grant of registration of a firm and the terms and conditions of such registration under section 20A;`
  line
  line `(pa) the manner of maintenance of Register of firms, and other particulars including details of pendency of any actionable information or complaint or imposition of any penalty against the firm under sub-section (1) and sub-section (2) and the manner in which the annual list of firms registered with the Institute shall be published under sub-section (3), of section 20B;`
  line
  line `(pb) the manner of making available status of actionable information and complaints and orders passed under sub-section (9) of section 21;`
  line
  line `(pc) the manner of preparing panel of persons under clauses (a), (b) and (c) of sub-section (1) and the allowances payable to the Presiding Officers and members of the Boards of Discipline under sub-section (8), of section 21A;`
  line
  line `(pd) the manner of preparing panel of persons under clauses (a), (b) and (c) of sub-section (1) and the allowances payable to the Presiding Officers and members of the Disciplinary Committees under sub-section (8) of section 21B;`
  line
  line `(pe) the salaries and allowances and conditions of service of officers and staff of the Authority under sub-section (2) of section 22D;]`
  line
  line `^9 * * * * *`
  line
  line `(r) the manner in which Regional Council may be constituted under sub-section (2) of section 23 and the functions thereof;`
  line
  line `(s) the conditions subject to which foreign qualifications may be recognised under sub-section (2) of section 38;`
  line
  line `(t) any other matter which is required to be, or may be, prescribed under this Act.`
  line
  line `(3) All regulations made by the Council under this Act shall be subject to the condition of previous publication and to the approval of the Central Government.`
  line
  line `^10 * * * * *`
obj_root_law_sections_39_footnotes:
  string
  line `1. Subs. by Act 8 of 2006, s. 30, for items (1), (3) (w.e.f. 8-8-2006).`
  line
  line `2. The words, brackets and letter clause (a) of omitted by , s. 30, ibid (w.e.f. 8-8-2006).`
  line
  line `3. Ins. by Act 12 of 2022, s. 104 (w.e.f. 10-5-2022).`
  line
  line `4. Clause (g) omitted by s. 30, ibid. (w.e.f. 8-8-2006).`
  line
  line `4. Subs. by s. 30, ibid., for clause (i) (w.e.f. 8-8-2006).`
  line
  line `5. Subs. by s. 30, ibid., for clause (j) (w.e.f. 8-8-2006).`
  line
  line `6. Subs. by s. 30, ibid., for clause (k) of sub-section (2) of section 15 (w.e.f. 8-8-2006).`
  line
  line `7. Clause (l) omitted by s. 30, ibid. (w.e.f. 8-8-2006).`
  line
  line `8. Subs. by Act 12 of 2022, s. 104, for clause (p) (w.e.f. 10-5-2022).`
  line
  line `9. Clause (q) omitted by s. 30, ibid. (w.e.f. 8-8-2006).`
  line
  line `10. Sub-section (4) omitted by Act 8 of 2006, s. 30 (w.e.f.8-8-2006).`
obj_root_law_sections_40:
  sectionId (1662)
  sectionNo (40)
  orderNo 59
  title `Rules, regulations and notifications to be laid before Parliament.`
  content obj_root_law_sections_40_content
  footnotes `1. Ins. by s. 31, ibid. (w.e.f. 8-8-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00006_198056_1517807325344&sectionId=1662&sectionno=40&orderno=59&orgactid=AC_CEN_22_29_00006_198056_1517807325344
obj_root_law_sections_40_content:
  string
  line `^1[40. Rules, regulations and notifications to be laid before Parliament.-- Every rule and every regulation made and every notification issued under this Act shall be laid, as soon as may be after it is made or issued, before each House of Parliament, while it is in session, for a total period of thirty days which may be comprised in one session or in two or more successive sessions, and if, before the expiry of the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule, regulation or notification, or both Houses agree that the rule, regulation or notification should not be made, or issued, the rule, regulation or notification shall thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that any such modification or annulment shall be without prejudice to the validity of anything previously done under that rule, regulation or notification.]`
