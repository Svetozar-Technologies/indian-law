obj_root_law_sections_1:
  sectionId (47342)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47342&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Diplomatic Relations (Vienna`
  line `Convention) Act, 1972.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (47343)
  sectionNo (2)
  orderNo 2
  title `Application of Vienna Convention on Diplomatic Relations.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47343&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_2_content:
  string
  line `(1) Notwithstanding anything to`
  line `the contrary contained in any other law, the provisions set out in the Schedule to this Act of the Vienna`
  line `Convention on Diplomatic Relations, adopted by the United Nations Conference on Diplomatic`
  line `Intercourse and Immunities on the 14th day of April, 1961, shall have the force of law in India.`
  line
  line `(2) The Central Government may, from time to time, by notification in the Official Gazette, amend`
  line `the Schedule in conformity with any amendments, duly made and adopted, of the provisions of the said`
  line `Convention set out therein.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47353)
  sectionNo (3)
  orderNo 3
  title `Application of certain privileges and immunities to diplomatic missions and their members pursuant to international agreement.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47353&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_3_content:
  string
  line `Where in pursuance of any agreement, convention or other`
  line `instrument it is necessary to accord to any diplomatic mission and its members, the sending State of`
  line `which is not a party to the Vienna Convention on Diplomatic Relations, 1961, or to any other special`
  line `mission and its members, privileges and immunities in India similar to those contained in the provisions`
  line `set out in the Schedule, the Central Government may, by notification in the Official Gazette, declare that`
  line `the provisions set out in the Schedule shall, subject to such modifications, if any, as it may consider`
  line `necessary or expedient for giving effect to the said agreement, convention or other instrument, apply`
  line `mutatis mutandis to the diplomatic mission and its members, or to the other special mission and its`
  line `members, as the case may be, and thereupon the said provisions shall apply accordingly, and`
  line `notwithstanding anything to the contrary contained in any other law, shall in such application have the`
  line `force of law in India.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47345)
  sectionNo (4)
  orderNo 4
  title `Restrictions on privileges and immunities.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47345&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_4_content:
  string
  line `If it appears to the Central Government that a State`
  line `which is a party to the Vienna Convention on Diplomatic Relations, 1961 is in breach of its obligations`
  line `arising thereunder or, that the privileges and immunities accorded to an Indian Mission or members`
  line `thereof in the territory of any State which is a party to the Vienna Convention on Diplomatic Relations,`
  line `1961, are less than those conferred by this Act on the Diplomatic mission of that State or members`
  line `thereof, the Central Government may, notwithstanding anything contained in this Act, by notification in`
  line `the Official Gazette, withdraw such of the privileges and immunities so conferred from the diplomatic`
  line `mission of that State or from members thereof as may appear to the Central Government to be proper`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47346)
  sectionNo (5)
  orderNo 5
  title Waiver.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47346&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_5_content:
  string
  line `For the purpose of article 32 of the Convention set out in the Schedule, a waiver by the`
  line `head of the mission of any State or any person for the time being performing his functions shall be`
  line `deemed to be a waiver by that State.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47347)
  sectionNo (6)
  orderNo 6
  title `Restrictions on certain exemptions from customs duty, etc.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47347&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_6_content:
  string
  line `Nothing contained in article 36 of`
  line `the Convention set out in the Schedule shall be construed to entitle a diplomatic mission or member`
  line `thereof to import into India goods free of any duty of customs without any restrictions on their subsequent`
  line `sale therein.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47348)
  sectionNo (7)
  orderNo 7
  title `Privileges and immunities of citizens of India.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47348&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_7_content:
  string
  line `For the purpose of article 38 of the Convention`
  line `set out in the Schedule, a citizen of India shall be entitled only to such additional privileges and`
  line `immunities, other than those set out in that article, as are granted to him by the Central Government by`
  line `notification in the Official Gazette.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47349)
  sectionNo (8)
  orderNo 8
  title `Restrictions on entry into diplomatic premises.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47349&sectionno=8&orderno=8&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_8_content:
  string
  line `No public servant or agent of the Central`
  line `Government, a State Government or any public authority shall enter the premises of a diplomatic mission`
  line `for the purpose of serving legal process, except with the consent of the head of the mission. Such consent`
  line `may be obtained through the Ministry of External Affairs of the Government of India.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (47350)
  sectionNo (9)
  orderNo 9
  title Evidence.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47350&sectionno=9&orderno=9&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_9_content:
  string
  line `If in any proceedings any question arises whether or not any person is entitled to any`
  line `privilege or immunity under this Act, a certificate issued by or under the authority of the Secretary to the`
  line `Government of India in the Ministry of External Affairs stating any fact relating to that question shall be`
  line `conclusive evidence of that fact.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47351)
  sectionNo (10)
  orderNo 10
  title `Power to make rules.`
  content obj_root_law_sections_10_content
  footnotes `1. Ins. by Act 4 of 1986, s. 2 (w.e.f. 15-5-1986).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47351&sectionno=10&orderno=10&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_10_content:
  string
  line `The Central Government may ^1[by notification in the Official Gazette],`
  line `make rules for carrying out the purposes of this Act.`
obj_root_law_sections_11:
  sectionId (47352)
  sectionNo (11)
  orderNo 11
  title `Notifications issued and rules made under this Act to be laid before Parliament.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00014_197243_1517807324657&sectionId=47352&sectionno=11&orderno=11&orgactid=AC_CEN_10_10_00014_197243_1517807324657
obj_root_law_sections_11_content:
  string
  line Every
  line `notification issued and every rule made under this Act shall be laid as soon as may be after it is issued or`
  line `made before each House of Parliament, while it is in session, for a total period of thirty days which may`
  line `be comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the notification or, as the case may be, in the rule, or both Houses agree that the`
  line `notification or rule should not be issued or made, the notification or rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that notification or`
  line rule.
obj_root_law_sections_11_footnotes:
  string
  line
