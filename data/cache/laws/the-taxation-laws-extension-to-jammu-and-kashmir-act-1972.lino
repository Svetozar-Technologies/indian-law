obj_root_law_sections_1:
  sectionId (72656)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_197225_1673603101397&sectionId=72656&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00037_197225_1673603101397
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called The Taxation Laws (Extension to`
  line `Jammu and Kashmir) Act, 1972.`
  line
  line `(2) It shall come into force on the 1st day of July, 1972`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (72657)
  sectionNo (2)
  orderNo 2
  title `Extension of certain taxation laws to Jammu and Kashmir and amendments thereto.`
  content obj_root_law_sections_2_content
  footnotes `1. Sub-section (3) rep. by the Repealing and Amending Act, 1978 (38 of 1978), s. 2 and the First Schedule (w.e.f. 26-11-1978).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_197225_1673603101397&sectionId=72657&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00037_197225_1673603101397
obj_root_law_sections_2_content:
  string
  line `The provisions of Chapter VII of the Finance (No. 2) Act, 1971 (32 of 1971), and all rules made and`
  line `notifications issued by the Central Government, and all regulations made by the Central Board of Excise`
  line `and Customs, thereunder shall extend to, and come into force in, the State of Jammu and Kashmir.`
  line `(2) The Tax on Postal Articles Act, 1971 (47 of 1971), and the Inland Air Travel Tax`
  line `Act, 1971 (48 of 1971), and all rules made and notifications issued by the Central Government thereunder`
  line `shall extend to, and come into force in, the State of Jammu and Kashmir.`
  line
  line `^1* * * * *`
obj_root_law_sections_3:
  sectionId (72658)
  sectionNo (3)
  orderNo 3
  title `Constitution of references to Code of Criminal Procedure, 1898.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_197225_1673603101397&sectionId=72658&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00037_197225_1673603101397
obj_root_law_sections_3_content:
  string
  line `The reference to the Code of`
  line `Criminal Procedure, 1898 (5 of 1898), in Chapter VII of the Finance (No. 2) Act, 1971 (32 of 1971), and`
  line `in section 8 of the Inland Air Travel Tax Act, 1971 (48 of 1971), shall, in relation to the State of Jammu`
  line `and Kashmir, be construed as a reference to the corresponding law in force in that State.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (72659)
  sectionNo (4)
  orderNo 4
  title `Power to remove difficulties.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_197225_1673603101397&sectionId=72659&sectionno=4&orderno=4&orgactid=AC_CEN_2_2_00037_197225_1673603101397
obj_root_law_sections_4_content:
  string
  line `If, in or in relation to the State of Jammu and Kashmir,`
  line `any difficulty arises in giving effect to the provisions of Chapter VII of the Finance (No. 2)`
  line `Act, 1971 (32 of 1971), or of the Tax on Postal Articles Act, 1971 (47 of 1971), or of the Inland Air`
  line `Travel Tax Act, 1971 (48 of 1971), now extended to the State of Jammu and Kashmir, the Central`
  line `Government may, as occasion may require, by order notified in the Official Gazette, make such`
  line `provisions or give such directions, not inconsistent with the provisions of that Chapter or Act, as appear to`
  line `it to be necessary for the removal of the difficulty.`
  line
  line `Provided that no such order shall be made under this section after the expiration of two years from the`
  line `commencement of this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
