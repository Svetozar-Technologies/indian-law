obj_root_law:
  slug the-tribhuvan-sahkari-university-act-2025
  handle (21049)
  collectionHandle 123456789/1362
  title `The "Tribhuvan" Sahkari University Act, 2025`
  actNumber (11)
  enactmentDate 2025-04-03
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/21049`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (2025)
  ministry `Ministry of Cooperation`
  department undefined
  longTitle `An Act to establish the Institute of Rural Management Anand, as a University to be known as the “Tribhuvan” Sahkari University and to declare the same as an institution of national importance; to impart technical and management education and training in co-operative sector; to promote co-operative research and development and to attain standards of global excellence therein in order to realise the vision of “Sahkar Se Samriddhi” and to strengthen the co-operative movementin the country through a network of institutions, and also to declare the Institute as one of the Schools of the University and for matters connected therewith or incidental thereto.`
  enforcementDate 05-04-2025
  notification undefined
