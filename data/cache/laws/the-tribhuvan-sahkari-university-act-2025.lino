obj_root_law_sections_1:
  sectionId (95518)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95518&sectionno=1&orderno=1&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the "Tribhuvan" Sahkari`
  line `University Act, 2025.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act and any`
  line `reference in any such provision to the commencement of this Act shall be construed as a reference to`
  line `the coming into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 5th day of April, 2025, vide notification No. S.O. 1619 (E), dated 4th day of April, 2025, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3 (ii).`
obj_root_law_sections_2:
  sectionId (95519)
  sectionNo (2)
  orderNo 2
  title `Declaration of "Tribhuvan Sahkari" University as institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes `* CORRIGENDUM dated 3rd April, 2025.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95519&sectionno=2&orderno=2&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the "Tribhuvan" Sahkari University are such as to make it an institution of`
  line `national importance, it is hereby declared that the "Tribhuvan" Sahkari University is an institution of`
  line `national *importance.`
obj_root_law_sections_3:
  sectionId (95520)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95520&sectionno=3&orderno=3&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_3_content:
  string
  line `(1) In this Act, unless the context otherwise requires,---`
  line
  line `(a) "Academic and Research Council" means the Academic and Research Council of the`
  line University;
  line
  line `(b) "academic staff" means such categories of staff designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "appointed day" means the date of establishment of the University under sub section (1) of`
  line `section 4;`
  line
  line `(d)"Assessment and Improvement Council" means the Assessment and Improvement Council`
  line `of the University;`
  line
  line `(e) "Board for Affiliation and Recognition" means the Board for Affiliation and Recognition`
  line `of the University;`
  line
  line `(f) "Board of Co-operative Studies" means the Board of Co-operative Studies of a School of`
  line `the University;`
  line
  line `(g) "Capacity Building Council" means the Capacity Building Council of the University;`
  line
  line `(h) "Chancellor" means the Chancellor of the University;`
  line
  line `(i) "co-operative principles" means the co-operative principles provided in the First Schedule`
  line `of the Multi-State Co-operative Societies Act, 2002 (39 of 2002);`
  line
  line `(j) "co-operative societies" means all co-operative societies registered under Co-operative`
  line `Societies Acts of the respective States, Union territories with Legislature and without Legislature`
  line `and the Multi-State Co-operative Societies Act, 2002 (39 of 2002);`
  line
  line `(k) "Dean" means the Head of a School or Head of an administrative Department of the`
  line University;
  line
  line `(l) "Director" means the Director of the Institute of Rural Management Anand School;`
  line
  line `(m) "employee" means any person appointed by the University and includes the teachers and`
  line `other staff of the University;`
  line
  line `(n) "Executive Board" means the Executive Board of the Institute of Rural Management`
  line `Anand School;`
  line
  line `(o) "Executive Council" means the Executive Council of the University;`
  line
  line `(p) "Finance Committee" means the Finance Committee of the University;`
  line
  line `(q) "Fund" means the University Fund referred to in section 40;`
  line
  line `(r) "Governing Board" means the Governing Board of the University;`
  line
  line `(s) "hostel" means a unit of residence for the students of the University or School, as the case`
  line `may be;`
  line
  line `(t) "Institute" means an academic institution including a college admitted to or affiliated to`
  line `the privileges of the University and the expression "Institution" shall be construed accordingly;`
  line
  line `(u) "Institute of Rural Management Anand" means the Institute of Rural Management Anand`
  line `established and incorporated under the Societies Registration Act, 1860 and located in Anand,`
  line Gujarat;
  line
  line `(v) "Institute of Rural Management Anand School" means one of the Schools of the`
  line University;
  line
  line `(w) "notification" means a notification published in the Official Gazette and the expression`
  line `"notified" with its cognate meanings and grammatical variations shall be construed accordingly;`
  line
  line `(x) "outlying campus" means the campus of the University as may be established by it at any`
  line `place in or outside India;`
  line
  line `(y) "Registrar" means the Registrar of the University;`
  line
  line `(z) "Research and Development Council" means the Research and Development Council of`
  line `the University;`
  line
  line `(za) "Schedule" means the Schedules appended to this Act;`
  line
  line `(zb) "School" means a School established by the University in each sector where degree,`
  line `diploma and certificate are awarded by the University;`
  line
  line `(zc) "Statutes", "Ordinances" and "Regulations" mean respectively, the Statutes, the`
  line `Ordinances and the Regulations of the University made under this Act;`
  line
  line `(zd) "Teachers of the University" means the Professors, Associate Professors, Assistant`
  line `Professors and such other persons as may be appointed for imparting instructions, training or`
  line `conducting research in the University or in any outlying campus maintained by the University;`
  line
  line `(ze) "Tribhuvan" Sahkari University' means the "Tribhuvan" Sahkari University established`
  line `and incorporated as a University under this Act;`
  line
  line `(zf) "University" means the "Tribhuvan" Sahkari University established and incorporated as a`
  line `University under this Act;`
  line
  line `(zg) "Vice-Chancellor" means the Vice-Chancellor of the University.`
  line
  line `(2) The words and expressions used herein and not defined, but defined in the Multi-State Cooperative Societies Act, 2002 (39 of 2002) shall have the respectively meanings assigned to them`
  line `in that Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (95521)
  sectionNo (4)
  orderNo 4
  title `Establishment and incorporation of "Tribhuvan" Sahkari University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95521&sectionno=4&orderno=4&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_4_content:
  string
  line `(1) With effect`
  line `from such date as the Central Government may, by notification, appoint, the Institute of Rural`
  line `Management Anand shall be established as a University to be known as the "Tribhuvan" Sahkari`
  line `University, which shall be a body corporate, having perpetual succession and a common seal, with`
  line `power, subject to the provisions of this Act, to acquire, hold property, both movable and immovable,`
  line `and to contract and shall, by the said name sue or be sued.`
  line
  line `(2) The headquarters of the University shall be at Anand in the State of Gujarat and the`
  line `University may establish Schools or outlying campuses or affiliate institutes at such other places in`
  line `India as it may deem fit:`
  line
  line `Provided that the University may, with the prior approval of the Central Government, also`
  line `establish or maintain outlying campuses or affiliate institutes outside India.`
  line
  line `(3) The Chancellor, the Vice-Chancellor, the members of the Governing Board, the Executive`
  line `Council, the Academic and Research Council, the Capacity Building Council, the Assessment and`
  line `Improvement Council, the Research and Development Council and other authorities shall constitute`
  line `the University.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (95522)
  sectionNo (5)
  orderNo 5
  title `Effect of establishment of University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95522&sectionno=5&orderno=5&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_5_content:
  string
  line `(1) On and from the date of commencement of this`
  line Act,---
  line
  line `(a) the Institute of Rural Management Anand registered as a society under the Societies`
  line `Registration Act, 1860 (21 of 1860) stands dissolved;`
  line
  line `(b) any reference to the Institute of Rural Management Anand in any contract or other`
  line `instrument shall be deemed as a reference to the University;`
  line
  line `(c) all property or assets, movable and immovable, of or belonging to the Institute of Rural`
  line `Management Anand shall vest in the University;`
  line
  line `(d) all rights and liabilities of the Institute of Rural Management An and shall be transferred`
  line `to, and be the rights and liabilities of the University;`
  line
  line `(e) the identity and autonomy of the Institute of Rural Management An and School and its`
  line `rights and privileges shall be continued:`
  line
  line `Provided that the Institute of Rural Management Anand School so declared under this Act`
  line `shall have an Executive Board which shall be responsible for ensuring identity and autonomy of`
  line `the School as granted under this section:`
  line
  line `Provided further that the Institute of Rural Management Anand School shall have a Director`
  line `who shall be responsible to implement the decisions of the Executive Board besides other regular`
  line `responsibilities of the University.`
  line
  line `(2) The Institute of Rural Management Anand School shall be declared as the "Centre of`
  line `Excellence" for Rural Management.`
  line
  line `Explanation.---For the purposes of this sub-section, the expression "Centre of Excellence" means`
  line `the Institute of Rural Management Anand School to have greater autonomy within the overall`
  line `institutional framework of the University to achieve excellence in its domain and also responsible for`
  line `developing and spreading best practices in imparting education, training and conducting research`
  line `within the University.`
  line
  line `(3) Subject to the provisions of this Act, every person employed in the Institute of Rural`
  line `Management Anand immediately before the commencement of this Act shall hold such employment`
  line `in the University by the same tenure and on the same terms and conditions and with the same rights`
  line `and privileges as to pension and gratuity as he would have held under the Institute of Rural`
  line `Management Anand, if this Act had not been enacted and such terms and conditions, rights and`
  line `privileges shall not be varied to his disadvantage:`
  line
  line `Provided that the University shall be at liberty to place the services of the persons permanently`
  line `employed in the Institute of Rural Management Anand immediately before the commencement of this`
  line `Act to any area, field, department and the like and at any place or location across India as deemed fit`
  line `by the University to further its objects.`
  line
  line `(4) The identity and autonomy of any ongoing academic programme and course of the Institute of`
  line `Rural Management Anand School shall be preserved by the University and any modification, if`
  line `needed, shall be with the concurrence of the Executive Board of such School.`
  line
  line `(5) The Institute of Rural Management Anand School shall have administrative and academic`
  line `autonomy as may be provided by the Statutes.`
  line
  line `(6) The post-retirement benefits including medical benefits, if any, of every academic staff,`
  line `teacher and every other employee in the Institute of Rural Management Anand who has`
  line `superannuated before the commencement of this Act shall be borne by the University in a manner and`
  line `form as deemed fit and not to the disadvantage of the superannuated employees.`
  line
  line `(7) Any ongoing disciplinary proceedings against any permanent employees in the Institute of`
  line `Rural Management Anand at the time of the commencement of this Act shall continue to be governed`
  line `by the Institute of Rural Management Anand Society Rules, 2004.`
  line
  line `(8) Any matter governing the conditions of service relating to the teacher, academic staff and`
  line `every other employee for which no provision has been made in this Act, shall be determined by the`
  line `provisions to be made by the Executive Council.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (95523)
  sectionNo (6)
  orderNo 6
  title `Objects of University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95523&sectionno=6&orderno=6&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_6_content:
  string
  line `The objects of the University shall be---`
  line
  line `(i) to provide qualified and trained manpower to meet the present and future needs of the cooperative sector by establishing its own Schools or through affiliating institutes;`
  line
  line `(ii) to provide training, education and capacity building to the employees and board members`
  line `of co-operative societies at all levels;`
  line
  line `(iii) to act as an apex body to integrate, coordinate, and standardise the academic and research`
  line `activities of affiliated co-operative institutes and training centres;`
  line
  line `(iv) to standardise the course design and content, pedagogy, course delivery in co-operative`
  line `education and training in accordance with the national and international best practices and the`
  line `guiding principles specified in the First Schedule to this Act;`
  line
  line `(v) to develop centres of excellence in co-operative education, training, research and`
  line consultancy;
  line
  line `(vi) to evolve as an institution of national and international repute for advanced studies in the`
  line `field of co-operative education and training, and any other areas connected with co-operative`
  line societies;
  line
  line `(vii) to disseminate and advance knowledge by providing institutional and research facilities`
  line `in the field of co-operative education and training, and to take appropriate measures for promoting`
  line `innovations in teaching-learning process and inter-disciplinary studies and research;`
  line
  line `(viii) to establish Schools and affiliate institutes for imparting the state-of-the-art education`
  line `and training in the field of co-operation for all sectors;`
  line
  line `(ix) to provide distance learning or mass e-learning platform and courses for serving the`
  line `education and training needs of the co-operative societies;`
  line
  line `(x) to undertake and promote research and development in all sectors relating to`
  line co-operatives;
  line
  line `(xi) to promote innovation, entrepreneurship and start-ups in the co-operative sector;`
  line
  line `(xii) to establish and promote partnership and linkages with co-operative societies or unions`
  line `or federations at all levels, industry, Institutions, Governments, International Co-operative`
  line `Alliance and co-operative educational institutions in India and abroad for furtherance of its`
  line objects;
  line
  line `(xiii) to discharge any other objects which the University deems fit to undertake for the`
  line `furtherance of its objects; and`
  line
  line `(xiv) to discharge such other objects, not inconsistent with the provisions of this Act and the`
  line `Statutes made thereunder, which the Central Government may, by notification, specify in this`
  line behalf.
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (95524)
  sectionNo (7)
  orderNo 7
  title `Powers and functions of University.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95524&sectionno=7&orderno=7&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of this Act and the`
  line `Statutes and Ordinances made thereunder, the University shall exercise and perform the following`
  line `powers and functions, namely:---`
  line
  line `(i) to plan, design, develop the required courses of study and conduct appropriate academic`
  line `and training programmes in the field of co-operation;`
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or`
  line `certificates to, and confer degrees or other academic distinctions on, persons, on the basis of`
  line `examinations, evaluation or any other method of testing, and to withdraw any such certificates,`
  line `diplomas, degrees or other academic distinctions for good and sufficient cause;`
  line
  line `(iii) to provide lectures and instructions for persons not enrolled as regular students of the`
  line `University and to grant certificates to them;`
  line
  line `(iv) to establish and maintain such outlying campuses, entrepreneurial incubation centres for`
  line `new co-operative ventures, targeted skill development centres or other units for research,`
  line `instruction, and training as are, in the opinion of the University, necessary for the furtherance of`
  line `its objects;`
  line
  line `(v) to establish and maintain Schools and hostels subject to assessment of demand;`
  line
  line `(vi) to provide nomenclature to the Institute of Rural Management Anand School by Statutes`
  line `made under this Act;`
  line
  line `(vii) to confer honorary degrees or other distinctions;`
  line
  line `(viii) to institute Professorships, Associate Professorships, Assistant Professorships and other`
  line `teaching or academic positions, required by the University and to appoint persons to such`
  line `Professorships, Associate Professorships, Assistant Professorships or other teaching or academic`
  line positions;
  line
  line `(ix) to appoint persons working in any University or academic institution, including those`
  line `located outside the country, as teachers of the University;`
  line
  line `(x) to create administrative, ministerial and other posts and to make appointments thereto`
  line `subject to availability of financial resources;`
  line
  line `(xi) to co-operate or collaborate or associate with any other University or authority or`
  line `institution of higher learning, including those located outside the country, in such manner and for`
  line `such purposes as the University, may determine;`
  line
  line `(xii) to provide facilities through the distance education system;`
  line
  line `(xiii) to institute and award fellowships, scholarships, studentships, medals and prizes for`
  line `raising academic standards and research;`
  line
  line `(xiv) to organise and undertake extramural studies, training and extension services;`
  line
  line `(xv) to make provision for research and advisory services and for that purpose, to enter into`
  line `such arrangements with other institutions, co-operative societies, industrial or other organisations,`
  line `as the University may deem necessary;`
  line
  line `(xvi) to organise and conduct refresher courses, workshops, seminars, conferences, training of`
  line `trainers, and other programmes for teachers, evaluators, other academic staff and students;`
  line
  line `(xvii) to appoint on contract or otherwise visiting Professors, Emeritus Professors, Consultants`
  line `and such other persons who may contribute to the advancement of the objects of the University;`
  line
  line `(xviii) to determine standards of admission to the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xix) to demand and receive payment of fees and other charges;`
  line
  line `(xx) to demand and receive payment for undertaking projects and consultancy services;`
  line
  line `(xxi) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xxii) to supervise, control, regulate and enforce discipline among the students and the`
  line `employees, and to take such disciplinary measures in this regard as may be deemed fit by the`
  line `University to be necessary;`
  line
  line `(xxiii) to make arrangements for promoting the health and general welfare of the employees`
  line `and students;`
  line
  line `(xxiv) to receive benefactions, donations and gifts and to acquire, hold and manage movable`
  line `or immovable, including trust and endowment properties, for the purposes of the University;`
  line
  line `(xxv) to dispose of any immovable property, with the previous approval of the Central`
  line Government;
  line
  line `(xxvi) to borrow, with the previous approval of the Central Government, on the security of the`
  line `property of the University, money for the purposes of the University;`
  line
  line `(xxvii) to conduct innovative experiments and promote new methods and technologies in the`
  line `fields of co-operative management and other related fields;`
  line
  line `(xxviii) to purchase or to take on lease any land or building or works which may be necessary or`
  line `convenient for the purposes of the University, on such terms and conditions as it may deem fit and`
  line `proper and to construct, alter and maintain any such building or work;`
  line
  line `(xxix) to start any new degree, allied course or research programme or diploma or certification or`
  line `training programme and discontinue any courses or research programme or training programme`
  line `without prejudice to the interest of the students;`
  line
  line `(xxx) to invest the funds of the University in or upon such securities and transpose any investment`
  line `from time to time in such manner as it may deem fit in the interest of the University and as provided`
  line `by the Statutes;`
  line
  line `(xxxi) to act as an advisory body to the Government of India and other National Institutions, State`
  line `Governments and National Co-operative Societies on all matters related to co-operative societies;`
  line
  line `(xxxii) to grant affiliation to Institutes or to a particular course or programme being conducted`
  line `by any Institute in or outside India;`
  line
  line `(xxxiii) to develop and certify teachers or practitioners as co-operative trainers and resource`
  line persons;
  line
  line `(xxxiv) to provide for the preparation of instructional and training materials, including films,`
  line `audio-visual materials, other software and the like;`
  line
  line `(xxxv) to recognise persons for imparting instructions in any Institute admitted or affiliated to`
  line `the privileges of the University; and`
  line
  line `(xxxvi) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
  line
  line `(2) The University shall in the exercise of its powers have jurisdiction over the outlying`
  line campuses.
  line
  line `(3) In exercising its powers referred to in sub-section (1), it shall be the endeavour of the`
  line `University to maintain an all-India character and high standards of teaching, training and research,`
  line `and the University may, among other measures which may be necessary for the said purpose, take, in`
  line `particular, the following measures, namely:---`
  line
  line `(i) admissions of students and recruitment of teachers shall be made on all-India basis through`
  line `appropriate procedures approved by the Executive Council;`
  line
  line `(ii) conduct self-financing, demand based, customised courses for the co-operatives;`
  line
  line `(iii) foreign students to be admitted by the University to various courses and programmes, as`
  line `per the policy and schemes of the Government of India and the procedure approved by the`
  line `Executive Council;`
  line
  line `(iv) inter-University mobility of teachers with portable pension scheme benefits, if any, and`
  line `protection of seniority shall be encouraged.`
  line
  line `Explanation.---For the purposes of this clause, the expression "portable pension scheme"`
  line `means a scheme to continue or carry forward the pension scheme already subscribed by the`
  line `incoming teacher;`
  line
  line `(v) semester system, continuous evaluation and choice-based credit system may be introduced`
  line `and the University may enter into agreement with other Universities and academic institutions for`
  line `credit transfer and joint degree programmes.`
  line
  line `Explanation.---For the purposes of this clause, the expression "choice-based credit`
  line `system" means a criterion based grading system to assess student's achievement based on the`
  line `learning goals for each programme, with continuous and comprehensive evaluation instead of`
  line `high stake examinations;`
  line
  line `(vi) innovative courses and programmes of studies shall be introduced with a provision`
  line `for periodic review and restructuring;`
  line
  line `(vii) active participation of students shall be ensured in all academic activities of the`
  line `University, including evaluation of teachers;`
  line
  line `(viii) accreditation may be obtained from the National Assessment and Accreditation`
  line `Council or any other accrediting agency of repute as may be determined by the University;`
  line and
  line
  line `(ix) e-governance shall be introduced in every possible sphere of activity with an effective`
  line `management information system.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (95525)
  sectionNo (8)
  orderNo 8
  title `University to be open to all caste, creed, race or class.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95525&sectionno=8&orderno=8&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_8_content:
  string
  line `The University shall be open to`
  line `persons of any sex and of whatever caste, creed, race or class, and it shall not be lawful for the`
  line `University to adopt or impose on any person, any test whatsoever of religious belief or profession in`
  line `order to entitle such person to be appointed as a teacher of the University or to hold any other office`
  line `therein or to be admitted as a student in the University or to graduate there at or to enjoy or exercise`
  line `any privilege thereof:`
  line
  line `Provided that the University shall follow the policy of the Central Government regarding`
  line `reservations in admissions and employment.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (95526)
  sectionNo (9)
  orderNo 9
  title `Power of Central Government to review and issue directions.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95526&sectionno=9&orderno=9&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_9_content:
  string
  line `(1) The Central`
  line `Government may, from time to time, appoint one or more persons to review or inspect the work and`
  line `progress of the University and outlying campuses including its buildings, libraries, laboratories and`
  line `equipments, and other infrastructure maintained by it and also of the examinations, teaching and other`
  line `work conducted or done by the University, and to submit a report thereon and upon receipt of that`
  line `report, the Central Government may, take such action and issue such directions, as it considers`
  line `necessary, in respect of any of the matters dealt with in the report and the University shall abide by`
  line `such action and be bound to comply with such directions.`
  line
  line `(2) Without prejudice to the foregoing provisions of this section, the Central Government may, by`
  line `an order in writing, annul any proceeding of the University which is not in conformity with the`
  line `provisions of this Act or the Statutes or the Ordinances made thereunder.`
  line
  line `(3) Without prejudice to the provisions of this Act and the Statutes made thereunder, the`
  line `University, in discharge of its general powers and functions under this Act, shall be bound by such`
  line `directions as the Central Government may give in writing to it from time to time.`
  line
  line `(4) The Central Government shall have such other powers, in respect of the affairs of the`
  line `University, as may be provided by the Statutes.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (95527)
  sectionNo (10)
  orderNo 10
  title Chancellor.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95527&sectionno=10&orderno=10&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_10_content:
  string
  line `(1) The Central Government may, by notification, appoint a person of`
  line `eminence as the Chancellor of the University.`
  line
  line `(2) The Chancellor shall hold office for a term of five years or until he attains the age of seventy`
  line `years, whichever is earlier:`
  line
  line `Provided that notwithstanding the expiry of his term of office, the Chancellor shall continue to`
  line `hold office until his successor enters upon his office.`
  line
  line `(3) The terms and other conditions of service of Chancellor shall be such as may be provided by`
  line `the Statutes.`
  line
  line `(4) The Chancellor shall, by virtue of his office, be the Head of the University and shall, if`
  line `present, preside at the Convocations of the University held for conferring degrees and other`
  line `ceremonial functions and also the meetings of the Governing Board.`
  line
  line `(5) The Chancellor shall exercise such other powers and perform such other duties as may be`
  line `assigned to him under this Act and the Statutes made thereunder.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (95528)
  sectionNo (11)
  orderNo 11
  title `Officers of University and Institute of Rural Management Anand School.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95528&sectionno=11&orderno=11&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_11_content:
  string
  line `The following`
  line `shall be the officers of the University and the Institute of Rural Management Anand School,`
  line `namely:---`
  line
  line `(a) the Vice-Chancellor;`
  line
  line `(b) the Director and ex officio Dean of the Institute of Rural Management Anand School;`
  line
  line `(c) the Dean;`
  line
  line `(d) the Registrar;`
  line
  line `(e) the Finance Officer;`
  line
  line `(f) the Controller of Examinations;`
  line
  line `(g) the Librarian; and`
  line
  line `(h) such other officers as may be provided by the Ordinances to be the officers of the`
  line `University and the Institute of Rural Management Anand School.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (95529)
  sectionNo (12)
  orderNo 12
  title Vice-Chancellor.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95529&sectionno=12&orderno=12&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_12_content:
  string
  line `(1) The Vice-Chancellor shall be a person having such eligibility criteria`
  line `and shall be appointed by the Central Government in such manner and subject to such terms and`
  line `conditions of service as may be provided by the Statutes:`
  line
  line `Provided that the first Vice-Chancellor shall be appointed by the Central Government in such`
  line `manner and subject to such terms and conditions as may be determined by it and he shall hold office`
  line `for a term of three years and may be eligible for re-appointment for another term of two years.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University`
  line `and shall exercise general supervision and control over other officers of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of the opinion that immediate action is necessary on any`
  line `matter, exercise any power conferred on any authority, except the Governing Board of the University`
  line `by or under this Act and shall inform such authority at its next meeting the action taken by him on`
  line `such matter.`
  line
  line `(4) Where the Vice-Chancellor is of the opinion that any decision taken by any officer or`
  line `authority, other than Chancellor or the Governing Board of the University is beyond the powers of`
  line `such officer or authority conferred under the provisions of this Act or the Statutes or the Ordinances`
  line `made thereunder or that any decision taken by the officer or authority is not as per the objects of the`
  line `University, he shall have powers to rescind such decisions and issue appropriate directions and all`
  line `such matters shall be placed before the Governing Board for information.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may`
  line `be provided by the Statutes.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (95530)
  sectionNo (13)
  orderNo 13
  title Registrar.
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95530&sectionno=13&orderno=13&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_13_content:
  string
  line `(1) The Registrar shall be appointed by the Central Government in such manner,`
  line `and on such terms and conditions, as may be provided by the Statutes:`
  line
  line `Provided that the first Registrar shall be appointed by the Central Government in such manner and`
  line `on such terms and conditions as may be determined by it and the said officer shall hold office for a`
  line `term of three years, and may be eligible for re-appointment for another term of two years.`
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University, and shall exercise such other powers and perform such other`
  line `duties, as may be provided by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (95531)
  sectionNo (14)
  orderNo 14
  title `Finance Officer.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95531&sectionno=14&orderno=14&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_14_content:
  string
  line `The Finance Officer shall be appointed by the Central Government in such`
  line `manner, and on such terms and conditions and shall exercise such powers and perform such duties, as`
  line `may be provided by the Statutes:`
  line
  line `Provided that the first Finance Officer shall be appointed by the Central Government in such`
  line `manner and on such terms and conditions as may be determined by it and the said officer shall hold`
  line `office for a term of three years, and may be eligible for re-appointment for another term of two years.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (95532)
  sectionNo (15)
  orderNo 15
  title `Director of Institute of Rural Management Anand School.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95532&sectionno=15&orderno=15&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_15_content:
  string
  line `(1) There shall be a Director`
  line `and ex officio Dean of the Institute of Rural Management Anand School who shall be the principal`
  line `academic and administrative officer for that School, and shall exercise supervision and control over`
  line `all employees of that School.`
  line
  line `(2) The Director shall be appointed in such manner, and on such terms and conditions and shall`
  line `exercise such powers and perform such duties, as may be provided by the Ordinances.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (95533)
  sectionNo (16)
  orderNo 16
  title Dean.
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95533&sectionno=16&orderno=16&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_16_content:
  string
  line `(1) Each School of the University shall be headed by a Dean who shall be the`
  line `principal academic and administrative officer for that School, and shall exercise supervision and`
  line `control over all employees of that School.`
  line
  line `(2) The Dean shall be appointed by the Executive Council in such manner, and on such terms and`
  line `conditions, and shall exercise such powers and perform such duties, as may be provided by the`
  line Ordinances.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (95534)
  sectionNo (17)
  orderNo 17
  title `Controller of Examinations.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95534&sectionno=17&orderno=17&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_17_content:
  string
  line `The Controller of Examinations shall be appointed in such`
  line `manner, and on such terms and conditions, and shall exercise such powers and perform such duties, as`
  line `may be provided by the Ordinances.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (95535)
  sectionNo (18)
  orderNo 18
  title Librarian.
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95535&sectionno=18&orderno=18&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_18_content:
  string
  line `The Librarian shall be appointed in such manner, and on such terms and`
  line `conditions, and shall exercise such powers and perform such duties, as may be provided by the`
  line Ordinances.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (95536)
  sectionNo (19)
  orderNo 19
  title `Other officers.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95536&sectionno=19&orderno=19&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_19_content:
  string
  line `(1) In addition to the officers referred to in clauses (a) to (g) of section 11,`
  line `the University shall consist of such other officers as may be provided by the Ordinances.`
  line
  line `(2) The manner of appointment, terms and conditions of service and powers and duties of other`
  line `officers of the University shall be such as may be provided by the Ordinances.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (95537)
  sectionNo (20)
  orderNo 20
  title `Authorities of University and Institute of Rural Management Anand School.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95537&sectionno=20&orderno=20&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_20_content:
  string
  line The
  line `following shall be the authorities of the University and Institute of Rural Management Anand School,`
  line `namely:---`
  line
  line `(a) the Governing Board;`
  line
  line `(b) the Executive Council;`
  line
  line `(c) the Academic and Research Council;`
  line
  line `(d) the Executive Board;`
  line
  line `(e) the Capacity Building Council;`
  line
  line `(f) the Assessment and Improvement Council;`
  line
  line `(g) the Research and Development Council;`
  line
  line `(h) the Board for Affiliation and Recognition;`
  line
  line `(i) the Finance Committee;`
  line
  line `(j) the Board of Co-operative Studies; and`
  line
  line `(k) such other authorities as may be provided by the Ordinances to be the authorities of the`
  line `University and Institute of Rural Management Anand School.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (95538)
  sectionNo (21)
  orderNo 21
  title `Governing Board.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95538&sectionno=21&orderno=21&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_21_content:
  string
  line `(1) The Chancellor shall be the Chairperson of the Governing Board.`
  line
  line `(2) In addition to the Chairperson, the Governing Board shall consist of the following members`
  line `who shall be nominated by the Central Government, namely:---`
  line
  line `(a) Vice-Chancellor---Member, ex officio;`
  line
  line `(b) Secretary, Ministry of Cooperation---Member, ex officio;`
  line
  line `(c) Four Secretaries of Central Ministries or Departments dealing with important sectors of`
  line `co-operative---Members, ex officio;`
  line
  line `(d) Four Principal Secretaries or Secretaries of Co-operation Department of States or Union`
  line `territories, by rotation---Members, ex officio;`
  line
  line `(e) Managing Director, National Co-operative Development Corporation---Member,`
  line `ex officio;`
  line
  line `(f) Chairperson, National Dairy Development Board---Member, ex officio;`
  line
  line `(g) Chief Executive, National Fisheries Development Board---Member, ex officio;`
  line
  line `(h) Chairperson, National Bank for Agriculture and Rural Development---Member, ex officio;`
  line
  line `(i) Four Chairpersons of National Co-operative Societies, by rotation--- Members, ex officio;`
  line
  line `(j) Chairperson, Institute of Rural Management Anand School---Member, ex officio;`
  line
  line `(k) Four Deans of Schools and Departments established by the University, by rotation---`
  line `Members, ex officio;`
  line
  line `(l) Two Directors of Institutes affiliated to the University, by rotation---Members, ex officio;`
  line
  line `(m) Four Professors who are members of the Academic and Research Council, Capacity`
  line `Building Council, Assessment and Improvement Council and Research and Development Council`
  line `respectively, by rotation---Members, ex officio;`
  line
  line `(n) Finance Officer of the University---Member, ex officio;`
  line
  line `(o) President, Alumni Association---Member, ex officio;`
  line
  line `(p) Four eminent persons in the field of co-operatives---Members;`
  line
  line `(q) Representative of the Reserve Bank, not below the rank of`
  line `Executive Director---Member,`
  line `ex officio; and`
  line
  line `(r) the Registrar---Member-Secretary, ex officio.`
  line
  line `(3) The term of office of the nominated members, other than ex officio Members shall be for a`
  line `period of three years from the date of their nomination:`
  line
  line `Provided that term of office of an ex officio Member shall continue so long as he holds the office`
  line `by virtue of which he is a member.`
  line
  line `(4) Subject to the provisions of this Act and the statutes made thereunder, the Governing Board`
  line `shall exercise and perform the following powers and functions, namely:---`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University, and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the`
  line `University and the audit report on such accounts;`
  line
  line `(c) to nominate members of Academic and Research Council, Capacity Building Council,`
  line `Assessment and Improvement Council, Research and Development Council and Board for`
  line `Affiliation and Recognition; and`
  line
  line `(d) to perform such other powers and functions as may be provided by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (95539)
  sectionNo (22)
  orderNo 22
  title `Executive Council.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95539&sectionno=22&orderno=22&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_22_content:
  string
  line `(1) The Vice-Chancellor shall be the ex officio Chairperson of the`
  line `Executive Council, which shall be the principal executive body of the University and shall exercise`
  line `supervision and control over all authorities of the University referred to in clauses (c) to (k) of`
  line `section 20.`
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers`
  line `and functions shall be such as may be provided by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (95540)
  sectionNo (23)
  orderNo 23
  title `Academic and Research Council.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95540&sectionno=23&orderno=23&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_23_content:
  string
  line `(1) The Vice-Chancellor shall be the ex officio`
  line `Chairperson of the Academic and Research Council, which shall be the principal academic and`
  line `research body of the University and shall, subject to the provisions of this Act, the Statutes and the`
  line `Ordinances made thereunder, co-ordinate and exercise general supervision over the academic and`
  line `research policies of the University.`
  line
  line `(2) The constitution of the Academic and Research Council, the term of office of its members and`
  line `its powers and functions shall be such as may be provided by the Ordinances.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (95541)
  sectionNo (24)
  orderNo 24
  title `Executive Board of Institute of Rural Management Anand School.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95541&sectionno=24&orderno=24&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_24_content:
  string
  line `(1) Subject to the`
  line `provisions of this Act and the Statutes made thereunder, there shall be an Executive Board of the`
  line `Institute of Rural Management Anand School which shall, co-ordinate and exercise general`
  line `supervision over such School.`
  line
  line `(2) The constitution of the Executive Board, selection of its Chairperson, the term of office of its`
  line `Chairperson and members and its powers and functions shall be such as may be provided by the`
  line Statutes.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (95542)
  sectionNo (25)
  orderNo 25
  title `Capacity Building Council.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95542&sectionno=25&orderno=25&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_25_content:
  string
  line `(1) The Vice-Chancellor shall be the ex officio Chairperson of`
  line `the Capacity Building Council, which shall be the principal body of the University for capacity`
  line `building programmes and shall, subject to the provisions of this Act, the Statutes and the Ordinances`
  line `made thereunder, co-ordinate and exercise general supervision over the capacity building policies of`
  line `the University.`
  line
  line `(2) The constitution of the Capacity Building Council, the term of office of its members and its`
  line `powers and functions shall be such as may be provided by the Ordinances.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (95543)
  sectionNo (26)
  orderNo 26
  title `Assessment and Improvement Council.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95543&sectionno=26&orderno=26&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_26_content:
  string
  line `(1) The Vice-Chancellor shall be the ex officio`
  line `Chairperson of the Assessment and Improvement Council, which shall be the principal body of the`
  line `University for assessment and improvement of all programmes and shall, subject to the provisions of`
  line `this Act, the Statutes and the Ordinances made thereunder, co-ordinate and exercise general`
  line `supervision over the matters relating to assessment and improvement of such programmes.`
  line
  line `(2) The constitution of the Assessment and Improvement Council, the term of office of its`
  line `members and its powers and functions shall be such as may be provided by the Ordinances.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (95544)
  sectionNo (27)
  orderNo 27
  title `Research and Development Council.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95544&sectionno=27&orderno=27&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_27_content:
  string
  line `(1) The Vice-Chancellor shall be the ex officio`
  line `Chairperson of the Research and Development Council, which shall be the principal body of the`
  line `University for undertaking and promoting research and development activities in all sectors relating to`
  line `co-operatives and shall, subject to the provisions of this Act, the Statutes and the Ordinances made`
  line `thereunder, co-ordinate and exercise general supervision over the matters relating to research and`
  line development.
  line
  line `(2) The constitution of the Research and Development Council, the term of office of its members`
  line `and its powers and functions shall be such as may be provided by the Ordinances.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (95545)
  sectionNo (28)
  orderNo 28
  title `Board for Affiliation and Recognition.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95545&sectionno=28&orderno=28&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_28_content:
  string
  line `(1) The Vice-Chancellor shall be the ex officio`
  line `Chairperson of the Board for Affiliation and Recognition, which shall be responsible for admitting or`
  line `affiliating institutes to the privileges of the University.`
  line
  line `(2) The constitution of the Board for Affiliation and Recognition, the term of office of its`
  line `members and its powers and functions shall be such as may be provided by the Ordinances.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (95546)
  sectionNo (29)
  orderNo 29
  title `Finance Committee.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95546&sectionno=29&orderno=29&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_29_content:
  string
  line `(1) The Vice-Chancellor shall be the ex officio Chairperson of the`
  line `Finance Committee.`
  line
  line `(2) The constitution of the Finance Committee, the term of office of its members and its powers`
  line `and functions shall be such as may be provided by the Ordinances.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (95547)
  sectionNo (30)
  orderNo 30
  title `Board of Co-operative Studies.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95547&sectionno=30&orderno=30&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_30_content:
  string
  line `(1) Every School shall have a Board of Co-operative`
  line Studies.
  line
  line `(2) The constitution of the Board of Co-operative Studies, the term of office of its members and`
  line `its powers and functions shall be such as may be provided by the Ordinances.`
  line
  line `(3) The Board of Co-operative Studies shall have such number of Committees not exceeding five,`
  line `including three Committees, comprising of experts, dealing in streams of degree, diploma and`
  line `certificate, respectively.`
  line
  line `(4) The constitution, powers and functions of the Committees referred to in sub-section (3) shall`
  line `be such as may be provided by the Ordinances.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (95548)
  sectionNo (31)
  orderNo 31
  title `Other authorities of University.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95548&sectionno=31&orderno=31&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_31_content:
  string
  line `The manner of appointment, terms and conditions, powers`
  line `and functions of other authorities referred to in clause (k) of section 20 shall be such as may be`
  line `provided by the Ordinances.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (95549)
  sectionNo (32)
  orderNo 32
  title `Meetings of authorities.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95549&sectionno=32&orderno=32&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_32_content:
  string
  line `(1) The authorities except the Governing Board and Executive`
  line `Council shall meet at such places and times, and shall follow such rules of procedure in regard to the`
  line `transaction of the business at its meetings (including quorum), as maybe provided by the Ordinances.`
  line
  line `(2) If the Chairperson of any authority, for any reason is unable to attend a meeting of such`
  line `authority, any other member chosen by the members present amongst themselves at the meeting, shall`
  line `preside over the meeting.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (95550)
  sectionNo (33)
  orderNo 33
  title Statutes.
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95550&sectionno=33&orderno=33&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_33_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:---`
  line
  line `(a) the constitution of the Governing Board, Executive Council and Executive Board, as may`
  line `be constituted from time to time, and their powers and functions;`
  line
  line `(b) the appointment and continuance in office of the members of the Governing Board,`
  line `Executive Council and Executive Board, the filling up of vacancies of members, and all other`
  line `matters relating to these authorities;`
  line
  line `(c) the nomenclature of the Institute of Rural Management Anand School so declared under`
  line `this Act;`
  line
  line `(d) the terms and conditions relating to clause (iv) of sub-section (3) of section 7, subject to`
  line `any provision relating to transfer of teachers from the University to other Central University or`
  line `Centrally Funded Technical Institutes to be decided in consultation with concerned Central`
  line `Government Departments; and`
  line
  line `(e) all other matters which by this Act are to be, or may be, provided for by the Statutes.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (95551)
  sectionNo (34)
  orderNo 34
  title `Power to make Statutes.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95551&sectionno=34&orderno=34&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_34_content:
  string
  line `(1) The first Statutes as specified in the Second Schedule shall be`
  line `continued till they are superseded by new Statutes.`
  line
  line `(2) The new or additional Statutes shall be made by the Central Government either suo motu or on`
  line `the recommendation of the Executive Council, at any point of time and as deemed fit.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (95552)
  sectionNo (35)
  orderNo 35
  title Ordinances.
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95552&sectionno=35&orderno=35&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_35_content:
  string
  line `Subject to the provisions of this Act and the Statutes made thereunder, the`
  line `Ordinances may provide for all or any of the following matters, namely:---`
  line
  line `(a) the constitution, powers and functions of all authorities except Governing Board,`
  line `Executive Council and Executive Board, as may be constituted from time to time;`
  line
  line `(b) the appointment and continuance in office of the members of the said authorities and other`
  line `bodies, the filling up of vacancies of members, and all other matters relating to those authorities`
  line `and other bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties, emoluments and terms and conditions of service of`
  line `officers of the University and the Institute of Rural Management Anand School except`
  line `Vice-Chancellor, Registrar and Finance Officer;`
  line
  line `(d) the appointment of teachers, academic staff and other employees of the University and the`
  line `Institute of Rural Management Anand School, their emoluments and terms and conditions of their`
  line service;
  line
  line `(e) the appointment of teachers and academic staff working in any other University or`
  line `organisation for a specific period for undertaking a joint project;`
  line
  line `(f) the terms and conditions of service of employees including provisions for pension,`
  line `insurance, provident fund, the manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing the seniority of service of the employees of the University;`
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(j) the conferment of affiliation to institutes;`
  line
  line `(k) the establishment and closure of Schools, Departments and hostels;`
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the conferment and withdrawal of degrees, diplomas, certificates and other academic`
  line distinctions;
  line
  line `(n) the management of Schools established and maintained by the University;`
  line
  line `(o) the delegation of powers vested in the authorities or officers of the University and the`
  line `Institute of Rural Management Anand School;`
  line
  line `(p) the maintenance of discipline among the employees and students;`
  line
  line `(q) the admission of students to the University and their enrolment as such;`
  line
  line `(r) the courses of study and their duration to be laid down for all degrees, diplomas and`
  line `certificates of the University;`
  line
  line `(s) the medium of instructions and examinations;`
  line
  line `(t) the award of degrees, diplomas, certificates and other academic distinctions, the`
  line `qualifications for the same and the means to be taken relating to the granting and obtaining of the`
  line same;
  line
  line `(u) the fees to be charged for courses of study in the University and for admission to`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(v) the conditions for award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(w) the conduct of examinations, including the term of office and manner of appointment and`
  line `the duties of examining bodies, examiners and moderators;`
  line
  line `(x) the conditions of residence of the students of the University;`
  line
  line `(y) the special arrangements, if any, which may be made for the residence and teaching of`
  line `women students and prescribing special courses of studies for them;`
  line
  line `(z) the establishment of Centres of Studies, Board of Studies and other Committees;`
  line
  line `(za) the manner of co-operation and collaboration with other Universities, institutions and`
  line `other organisations including industry;`
  line
  line `(zb) the creation, composition and functions of any other body which is considered necessary`
  line `for improving the academic life of the University;`
  line
  line `(zc) the setting up of a machinery for redressal of grievances of employees and students; and`
  line
  line `(zd) any other matter which, by this Act or the Statutes made thereunder, is to be or may be,`
  line `provided for by the Ordinances.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (95553)
  sectionNo (36)
  orderNo 36
  title `Power to make Ordinances.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95553&sectionno=36&orderno=36&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_36_content:
  string
  line `(1) The first Ordinances shall be made by the Vice-Chancellor`
  line `and the Ordinances so made may be amended or repealed at any time by the Executive Council.`
  line
  line `(2) Save as otherwise provided in sub-section (1), the Executive Council shall make Ordinances`
  line `either suo motu or on the recommendation of the related authority of the University referred to in`
  line `clauses (c) to (k) of section 20, as decided by such Executive Council.`
  line
  line `(3) Every Ordinance so made under sub-sections (1) and (2) shall be submitted, as soon as may be`
  line `after it is made, to the Central Government for information.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (95554)
  sectionNo (37)
  orderNo 37
  title Regulations.
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95554&sectionno=37&orderno=37&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_37_content:
  string
  line `Any authority under section 20 may make Regulation, consistent with the`
  line `provisions of this Act, the Statutes and the Ordinances made thereunder, for the conduct of its own`
  line `business and every Regulation so made shall be submitted, as soon as may be after it is made, to the`
  line `Executive Council for information.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (95555)
  sectionNo (38)
  orderNo 38
  title `Annual report.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95555&sectionno=38&orderno=38&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_38_content:
  string
  line `(1) The annual report of the University shall be prepared under the`
  line `directions of Executive Council, which shall include, among other matters, the steps taken by the`
  line `University towards the fulfilment of its objects and shall be submitted to the Governing Board after`
  line `the approval of Executive Council within six months from the closing of financial year and the`
  line `Governing Board shall consider the report in its annual meeting.`
  line
  line `(2) The Governing Board shall submit the annual report to the Central Government along with its`
  line `comments, if any, on or before the expiry of nine months from the closing of financial year.`
  line
  line `(3) The Central Government shall, as soon as may be after it is received, cause a copy of the`
  line `annual report be laid before each House of Parliament.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (95556)
  sectionNo (39)
  orderNo 39
  title `Annual accounts.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95556&sectionno=39&orderno=39&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_39_content:
  string
  line `(1) The University shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts, including the balance-sheet, in such form and`
  line `accounting standards as may be provided by it in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the University shall be audited by the Comptroller and Auditor-General of`
  line `India and any expenditure incurred by it in connection with such audit shall be payable by the`
  line `University to the Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the University shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with`
  line `the audit of the Government accounts, and, in particular, shall have the right to demand the production`
  line `of books, accounts, connected vouchers and other documents and papers and to inspect the offices of`
  line `the University.`
  line
  line `(4) The accounts of the University as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf together with the audit report thereon shall be`
  line `forwarded annually to the Central Government on or before the expiry of nine months from the`
  line `closing of financial year and that Government shall cause the same to be laid before each House of`
  line Parliament.
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (95557)
  sectionNo (40)
  orderNo 40
  title `Fund of University.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95557&sectionno=40&orderno=40&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_40_content:
  string
  line `(1) There shall be a University Fund which shall include---`
  line
  line `(a) any contribution or grant made by the Central Government;`
  line
  line `(b) grant from Co-operative Education Fund maintained under the Multi-State Co-operative`
  line `Societies Act, 2002 (39 of 2002) or States' or Union Territories' Co-operative Societies Acts;`
  line
  line `(c) grant from corpus Fund for Co-operative Training set up by the Central Government;`
  line
  line `(d) any contribution or grant made by the State Government;`
  line
  line `(e) any contribution made by Government, semi-Government or autonomous bodies;`
  line
  line `(f) any gifts, bequests, donations, endowments or other grants;`
  line
  line `(g) income received by the University from fees and charges;`
  line
  line `(h) income received by the University from undertaking projects and consultancy services;`
  line
  line `(i) money received by the University from the collaborating industries, co-operative societies,`
  line `federations, unions and other organisations in terms of the provisions of the Memorandum of`
  line `Understanding between the University and such collaborating industry, co-operative society,`
  line `federation, union or other organisation; and`
  line
  line `(j) money received from any other source, provided that any funding from foreign sources`
  line `shall require prior approval of the Central Government.`
  line
  line `(2) All funds of the University shall be deposited in such banks or invested in such manner as the`
  line `Executive Council may decide on the recommendation of the Finance Committee.`
  line
  line `(3) The funds of the University shall be applied towards meeting the expenses of the University`
  line `including expenses incurred in the exercise of its powers and discharge of its functions by or under`
  line `this Act.`
  line
  line `(4) The University, at all times, shall strive to be self-sufficient in meeting its expenses and shall,`
  line `while launching new courses or programmes, establishing new schools or other infrastructure,`
  line `creating or filling posts, incurring recurring or non-recurring expenses and creating any other financial`
  line `liability, take into account financial resources that are either available with the University or tied up`
  line `with stakeholders or any other source.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (95558)
  sectionNo (41)
  orderNo 41
  title `Conditions of service of employees, etc.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95558&sectionno=41&orderno=41&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_41_content:
  string
  line `(1) Every employee of the University shall be`
  line `appointed under a written contract, which shall be lodged with the University and a copy of which`
  line `shall be furnished to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Dispute Resolution Body consisting of one member`
  line `appointed by the Executive Council, one member nominated by the employee concerned and an`
  line `independent member from outside the University to be appointed by the Executive Council.`
  line
  line `(3) The decision of the Dispute Resolution Body shall be final and no suit shall lie in any civil`
  line `court in respect of the matters decided by the Dispute Resolution Body.`
  line
  line `(4) Every request made by the employee under sub-section (2) shall be deemed to be a submission`
  line `to arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation`
  line `Act, 1996 (26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Dispute Resolution Body shall be such as may be`
  line `provided by the Ordinances.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (95559)
  sectionNo (42)
  orderNo 42
  title `Right to appeal.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95559&sectionno=42&orderno=42&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_42_content:
  string
  line `(1) Any person including an employee or a student of the University`
  line `Aggrieved by the decision or order of the Academic and Research Council, the Capacity Building`
  line `Council, the Assessment and Improvement Council, the Research and Development Council, the`
  line `Board for Affiliation and Recognition and the Board of Co-operative Studies may file an appeal to the`
  line `Executive Council.`
  line
  line `(2) The form, manner and the procedure for filing and disposing of appeal referred to in subsection (1) shall be such as may be provided by the Ordinances.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (95560)
  sectionNo (43)
  orderNo 43
  title `Provident and pension funds.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95560&sectionno=43&orderno=43&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_43_content:
  string
  line `(1) The University shall constitute for benefit of its`
  line `employees such provident fund or any other similar fund or provide such insurance schemes, as it may`
  line `deem fit, in such manner and subject to such conditions, as may be provided by the Ordinances.`
  line
  line `(2) Where such provident fund or other similar fund has been so constituted, the Central`
  line `Government may declare that the provisions of the Provident Funds Act, 1925 (19 of 1925) shall`
  line `apply to such fund, as if it were a Government provident fund.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (95561)
  sectionNo (44)
  orderNo 44
  title `Returns and information.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95561&sectionno=44&orderno=44&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_44_content:
  string
  line `The University shall furnish to the Central Government such`
  line `returns or other information with respect to its property or activities, within such period, as may be`
  line `determined by the Central Government from time to time.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (95562)
  sectionNo (45)
  orderNo 45
  title `Acts and proceedings not invalidated by vacancies.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95562&sectionno=45&orderno=45&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_45_content:
  string
  line `No act or proceedings of any`
  line `authority or other body of the University shall be invalid merely by reason of the existence of a`
  line `vacancy or vacancies among its members.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (95571)
  sectionNo (46)
  orderNo 46
  title `University and Institute of Rural Management Anand School to be public authority under Right to Information Act.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95571&sectionno=46&orderno=46&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_46_content:
  string
  line `The provisions of the Right to Information Act, 2005 (20 of`
  line `2005) shall apply to the University and the Institute of Rural Management Anand School, as if it were`
  line `a public authority defined in clause (h) of section 2 of that Act.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (95564)
  sectionNo (47)
  orderNo 47
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95564&sectionno=47&orderno=47&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_47_content:
  string
  line `No suit, prosecution or other legal proceedings`
  line `shall lie against any officer or other employee of the University for anything which is in good faith`
  line `done or intended to be done in pursuance of any of the provisions of this Act, the Statutes or the`
  line `Ordinances made thereunder.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (95565)
  sectionNo (48)
  orderNo 48
  title `Act to have overriding effect.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95565&sectionno=48&orderno=48&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_48_content:
  string
  line `Save as otherwise provided, the provisions of this Act shall`
  line `be in addition to and not in derogation of the University Grants Commission Act, 1956 (3 of 1956)`
  line `and any other law for the time being in force.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (95566)
  sectionNo (49)
  orderNo 49
  title `Mode of proof of University record.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95566&sectionno=49&orderno=49&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_49_content:
  string
  line `Notwithstanding anything contained in the Bharatiya`
  line `Sakshya Adhiniyam, 2023 (47 of 2023) or in any other law for the time being in force, a copy of any`
  line `receipt, application, notice, order, proceeding or resolution of any authority or other body of the`
  line `University, or any other document in possession of the University, or any entry in any register duly`
  line `maintained by the University, if certified by the Registrar, shall be received as prima facie evidence of`
  line `such receipt, application, notice, order, proceeding, resolution or document or the existence of entry in`
  line `the register and shall be admitted as evidence of the matters and transactions therein where the`
  line `original thereof would, if produced, have been admissible in evidence.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (95567)
  sectionNo (50)
  orderNo 50
  title `Statutes to be laid before Parliament.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95567&sectionno=50&orderno=50&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_50_content:
  string
  line `(1) Every Statute made under this Act shall be`
  line `published in the Official Gazette.`
  line
  line `(2) Every Statute made under this Act, shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute or both Houses agree that the Statute should not be made, the`
  line `Statute shall thereafter have effect only in such modified form or be of no effect, as the case may be;`
  line `so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that Statute.`
  line
  line `(3) The power to make Statutes shall include the power to give retrospective effect, from a date`
  line `not earlier than the date of commencement of this Act, to the Statutes but no retrospective effect shall`
  line `be given to any Statutes so as to prejudicially affect the interests of any person to whom such Statutes`
  line `may be applicable.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (95568)
  sectionNo (51)
  orderNo 51
  title `Residuary provision.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95568&sectionno=51&orderno=51&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_51_content:
  string
  line `(1) The Central Government shall have the authority to deal with any`
  line `matter pertaining to the University and the Institute of Rural Management Anand School and not`
  line `specifically dealt with in this Act.`
  line
  line `(2) The decision of the Central Government on all such matters shall be final.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (95569)
  sectionNo (52)
  orderNo 52
  title `Power to remove difficulties.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95569&sectionno=52&orderno=52&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_52_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such`
  line `provisions, not inconsistent with the provisions of this Act, as may appear to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from`
  line `the date of commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (95570)
  sectionNo (53)
  orderNo 53
  title `Transitional provisions.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_200_0_00003_A2025-11_1745400500757&sectionId=95570&sectionno=53&orderno=53&orgactid=AC_CEN_200_0_00003_A2025-11_1745400500757
obj_root_law_sections_53_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes`
  line `made thereunder,---`
  line
  line `(a) the Board of Governors and other committees functioning in Institute of Rural`
  line `Management Anand shall continue to function till such time the authorities or committees are`
  line `constituted in the University under the provisions of this Act;`
  line
  line `(b) the existing officers of Institute of Rural Management Anand shall continue to function till`
  line `such time, the officers of the University are appointed under the provisions of this Act; and`
  line
  line `(c) till the First Statutes and Ordinances are made, any matter not specifically dealt within this`
  line `Act shall be governed by rules and regulations of Institute of Rural Management Anand.`
obj_root_law_sections_53_footnotes:
  string
  line
