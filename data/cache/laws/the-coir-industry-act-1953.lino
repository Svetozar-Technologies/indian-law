obj_root_law:
  slug the-coir-industry-act-1953
  handle (2179)
  collectionHandle 123456789/1362
  title `The Coir Industry Act, 1953`
  actNumber (45)
  enactmentDate 1953-12-23
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2179`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `कयर उद्योग अधिनियम, 1953`
  actYear (1953)
  ministry `Ministry of Micro, Small and Medium Enterprises`
  department undefined
  longTitle `An Act to provide for the establishment of a Board for the development of the Coir Industry and for that purpose to levy a customs duty on coir fiber, coir yarn and coir products exported from India and for matters connected therewith.`
  enforcementDate 09-02-1954
  notification `9th February, 1954, vide notification No. S.R.O. 470, dated 9th February, 1954, see Gazette of India, Extraordinary Part I, s. 3(ii).`
