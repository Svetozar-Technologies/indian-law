  obj_root_law_sections_22
  obj_root_law_sections_23
  obj_root_law_sections_24
  obj_root_law_sections_25
  obj_root_law_sections_26
  obj_root_law_sections_27
obj_root_law_sections_1:
  sectionId (9710)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9710&sectionno=1&orderno=1&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Coir Industry`
  line `Act, 1953.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*..`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1 . 9th February, 1954, vide notification No. S.R.O. 470, dated 9th February, 1954, see Gazette of India, Extraordinary Part I,`
  line `s. 3(ii).`
  line
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (9711)
  sectionNo (2)
  orderNo 2
  title `Declaration as to expediency of control by the Union.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9711&sectionno=2&orderno=2&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_2_content:
  string
  line `It is hereby declared that it is expedient`
  line `in the public interest that the Union should take under its control the coir industry,`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (9712)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9712&sectionno=3&orderno=3&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Board" means the Coir Board constituted under section 4;`
  line
  line `(b) "cess" means the customs duty imposed by section 13;`
  line
  line `(c) "coir" or "coir fiber" means the fiber extracted from the husk of the coconut;`
  line
  line `(d) "coir products" means mats and mattings, rugs and carpets, ropes and other articles`
  line `manufactured wholly or partly from coir or coir yarn;`
  line
  line `(e) "coir yarn" means yarn obtained by the spinning of coir;`
  line
  line `(f) "export" with its grammatical variations and cognate expressions means to take out of the`
  line `territories to which this Act extends by land, sea or air to any place outside India other than a country`
  line `or territory notified in this behalf by the Central Government by notification in the Official Gazette;`
  line
  line `(g) "Fund" means the Coir Fund referred to in section 15;`
  line
  line `(h) "husks" means coconut husks, both raw and retied;`
  line
  line `(i) "member" means a member of the Board;`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (9713)
  sectionNo (4)
  orderNo 4
  title `Establishment and constitution of the Coir Board.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9713&sectionno=4&orderno=4&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_4_content:
  string
  line `(1) With effect from such date as the`
  line `Central Government may, by notification in the Official Gazette, specify in this behalf, there shall be`
  line `established for the purposes of this Act a Board to be called the Coir Board.`
  line
  line `(2) The Board shall be a body corporate by the name aforesaid, having perpetual succession and a`
  line `common seal with power to acquire, hold and dispose of property, both movable and immovable, and to`
  line `contract, and shall, by the said name, sue and be sued.`
  line
  line `(3) The Board shall consist of a Chairman and such number of other members not exceeding forty as`
  line `the Central Government may think expedient, to be appointed by that Government by notification in the`
  line `Official Gazette from among persons who are in its opinion capable of representing--`
  line
  line `(a) growers of coconuts and producers of husks and coir yarn;`
  line
  line `(b) persons engaged in the production of husks, coir and yarn and in the manufacture of coir`
  line products;
  line
  line `(c) manufacturers of coir products;`
  line
  line `(d) dealers in coir, coir yarn and coir products, including both exporters and internal traders;`
  line
  line `(e) parliament;`
  line
  line `(f) the Governments of the principal coconut growing States;`
  line
  line `(g) such other persons or class of persons who, in the opinion of the Central Government, ought`
  line `to be represented on the Board.`
  line
  line `(4) The number of persons to be appointed as members from each of the categories specified in`
  line `sub-section (3), the term of office, of the procedure to be followed in the discharge of their functions by,`
  line `and the manner of filling vacancies among, the members of the Board shall be such as may be prescribed.`
  line
  line `(5) Any officer of the Central Government when deputed by that Government in this behalf shall have`
  line `the right to attend meetings of the Board and take part in the proceedings thereof but shall not be entitled`
  line `to vote.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (9714)
  sectionNo (5)
  orderNo 5
  title `Vacancies, etc., not to invalidate acts and proceedings.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9714&sectionno=5&orderno=5&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_5_content:
  string
  line `No act or proceeding taken by the`
  line `Board under this Act shall be questioned on the ground merely of--`
  line
  line `(a) the existence of any vacancy in the Constitution of, the Board; or`
  line
  line `(b) any omission, defect or irregularity not affecting the merits of the case.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (9715)
  sectionNo (6)
  orderNo 6
  title `Salary and allowances of Chairman.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9715&sectionno=6&orderno=6&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_6_content:
  string
  line `The Chairman shall be entitled to such salary and`
  line `allowances and shall be subject to such conditions of service in respect of leave, pension, provident fund`
  line `and other matters as may from time to time be fixed by the Central Government.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (9716)
  sectionNo (7)
  orderNo 7
  title Vice-Chairman.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9716&sectionno=7&orderno=7&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_7_content:
  string
  line `The Board shall elect from among its members a Vice-Chairman, who shall`
  line `exercise such of the powers and discharge such of the duties of the Chairman as may be prescribed or as`
  line `may be delegated to him by the Chairman.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (9717)
  sectionNo (8)
  orderNo 8
  title `Executive and other Committees.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9717&sectionno=8&orderno=8&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_8_content:
  string
  line `(1) There shall be an Executive Committee of the Board for`
  line `the purpose of exercising such of the powers and performing such of the duties of the Board as may be`
  line `prescribed or as the Board may delegate to it.`
  line
  line `(2) The Executive Committee shall consist of--`
  line
  line `(i) the Chairman,`
  line
  line `(ii) the Vice-Chairman, and`
  line
  line `(iii) five other members elected by the members of the Board, from among themselves of whom`
  line `not more than two shall be Government officials and one shall be from among the members`
  line `representing persons engaged in the production of husks, coir and coir yarn and in the manufacture of`
  line `coir products.`
  line
  line `(3) Subject to such control and restrictions as may be prescribed, the Board may constitute other`
  line `standing committees or ad hoc committes for exercising any power or discharging any duty of the Board`
  line `or for enquiring into or reporting and advising on any matter which the Board may refer to them.`
  line
  line `(4) A Standing Committee shall consist exclusively of members of the Board.`
  line
  line `(5) An ad hoc Committee may include persons who are not members of the Board, but their number`
  line `shall be less than one-half of its strength.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (9718)
  sectionNo (9)
  orderNo 9
  title `Secretary and staff.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9718&sectionno=9&orderno=9&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government shall, after consulting the Board appoint a`
  line `Secretary to the Board who shall exercise such powers and perform such duties as may be prescribed or as`
  line `may be delegated to him by the Board or the Chairman.`
  line
  line `(2) Subject to such control and restrictions as may be prescribed, the Board may appoint such officers`
  line `and employees as may be necessary for the efficient performance of its functions and pay them such`
  line `salaries and allowances as it may determine from time to time.`
  line
  line `(3) The Chairman, Secretary and other officers and employees of the Board shall not undertake any`
  line `work unconnected with their duties under this Act except with the permission of the Central Government.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (9719)
  sectionNo (10)
  orderNo 10
  title `Functions of the Board.`
  content obj_root_law_sections_10_content
  footnotes `1. Ins. by Act 25 of 1964, s. 3 (w.e.f. 16-6-1964).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9719&sectionno=10&orderno=10&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_10_content:
  string
  line `(1) It shall be the duty of the Board to promote by such measures as it`
  line `thinks fit the development under the control of the Central Government of the coir industry.`
  line
  line `(2) Without prejudice to the generality of the provisions of sub-section (1), the measures referred to`
  line `therein may relate to`
  line
  line `(a) promoting exports of coir yarn and coir products, and carrying on propaganda for that`
  line purpose;
  line
  line `(b) regulating under the supervision of the Central Government the production of husks, coir yarn`
  line `and coir products by registering coir spindles and looms for manufacturing coir products as also`
  line `manufacturers of coir products, licensing exporters of coir, coir yarn and coir products and taking`
  line `such other appropriate steps as may be prescribed;`
  line
  line `(c) undertaking, assisting or encouraging scientific technological and economic research and`
  line `maintaining and assisting in the maintenance of one or more research institutes;`
  line
  line `(d) collecting statistics from manufacturers of, and dealers in, coir products and from such other`
  line `persons as may be prescribed, on any matter relating to the coir industry; the publication of statistics`
  line `so collected or portions thereof or extracts therefrom;`
  line
  line `(e) fixing grade standards and arranging when necessary for inspection of coir fibre, coir yarn and`
  line `coir products;`
  line
  line `(f) improving the marketing of coconut husk, coir fibre, coir yarn and coir products in India and`
  line `elsewhere and preventing unfair competition;`
  line
  line `^1[(ff) setting up or assisting in the setting up of factories for the production of coir products with`
  line `the aid of power;]`
  line
  line `(g) promoting co-operative organisation among producers of husk, coir fibre and coir yarn and`
  line `manufacturers of coir products;`
  line
  line `(h) ensuring remunerative returns to producers of husks, coir fibre and coir yarn and`
  line `manufacturers of coir products;`
  line
  line `(i) licensing of retting places and warehouses and otherwise regulating the stocking and sale of`
  line `coir fibre, coir yarn and coir products both for the internal market and for exports;`
  line
  line `(j) advising on all matters relating to the development of the coir industry;`
  line
  line `(k) such other matters as may be prescribed.`
  line
  line `(3) The Board shall perform its functions under this section in accordance with and subject to such`
  line `rules as may be made by the Central Government.`
obj_root_law_sections_11:
  sectionId (9720)
  sectionNo (11)
  orderNo 11
  title `Dissolution of the Board.`
  content obj_root_law_sections_11_content
  footnotes `1. The words "or fails to act" omitted by Act 45 of 1953, s. 2 and the Schedule (w.e.f. 17-5-1957).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9720&sectionno=11&orderno=11&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_11_content:
  string
  line `(1) The Central Government may, if the Board does any act`
  line `exceeding the powers conferred upon it or acts in a manner contrary to the rules or prejudicial to the`
  line `interests of the industry or acts ^1* * * contrary to the directions given by the Central Government, call`
  line `upon the Board to show cause why the Board should not be dissolved and if no explanation is offered or`
  line `if the Central Government is dissatisfied with the explanation given it may suspend or dissolve the Board`
  line `from such date and for such period as may be specified in the notification.`
  line
  line `(2) When the Board is dissolved under the provisions of sub-section (1)--`
  line
  line `(a) all members shall, from the date of dissolution, vacate their offices as such members;`
  line
  line `(b) all powers and duties of the Board shall, during the period of dissolution, be exercised and`
  line `performed by such person or persons as the Central Government may appoint in this behalf;`
  line
  line `(c) all funds and other property vested in the Board shall, during the period of dissolution, vest in`
  line `the Central Government; and`
  line
  line `(d) as soon as the period of dissolution expires, the Board shall be reconstituted in accordance`
  line `with the provisions of this Act.`
obj_root_law_sections_12:
  sectionId (9721)
  sectionNo (12)
  orderNo 12
  title `Control of export of coir fibre, coir yarn and coir products.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9721&sectionno=12&orderno=12&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_12_content:
  string
  line `No coir fibre, coir yarn or coir`
  line `products shall be exported otherwise than under a licence issued by or on behalf of the Board in the`
  line `prescribed manner, and the provisions of the Sea Customs Act, 1878 (VIII of 19887), shall have effect as`
  line `if the provisions made by this section had been made by notification issued under Section 19 of that Act:`
  line
  line `Provided that nothing herein contained shall apply to any coir product dispatched out of the territories`
  line `to which this Act extends by post or carried in a passengers luggage for his personal use:`
  line
  line `Provided further that the Central Government may exempt from the operation of this section either`
  line `absolutely or subject to specified conditions, the export of any coir fibre, coir yarn or coir product to any`
  line `foreign settlement bounded by India.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (9722)
  sectionNo (13)
  orderNo 13
  title `Imposition of a duty of customs on export of coir fibre, coir yarn and coir products.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 40 of 1960, s. 9, for the words "at such rate not exceeding one rupee per hundred weight" (w.e.f. 1-10-1960)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9722&sectionno=13&orderno=13&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_13_content:
  string
  line `(1)`
  line `With effect from such date as may be specified by the Central Government by notification in the Official`
  line `Gazette, there shall be levied and collected as a cess for the purposes of this Act a duty of customs on all`
  line `coir fibre, coir yarn and coir products which are exported ^1[at such rate not exceeding two rupees per`
  line `quintal] as the Central Government may, by the same or a like notification from time to time, fix.`
  line
  line `(2) The cess levied under sub-section (1) shall be in addition to any other duty leviable under the`
  line `Indian Tariff Act, 1934 (XXXII of 1934), or any other law for the time being in force and shall be`
  line `collected by such agencies and in such manner as may be prescribed.`
obj_root_law_sections_14:
  sectionId (9723)
  sectionNo (14)
  orderNo 14
  title `Payment of proceeds of cess to the Board.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9723&sectionno=14&orderno=14&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_14_content:
  string
  line `The proceeds of the cess levied under sub-section`
  line `(1) of section 13 shall first be credited to the Consolidated Fund of India and the Central Government may`
  line `thereafter from time to time pay to the Board from and out of such proceeds such sums of money as it`
  line `may think fit after deducting the expenses of collection.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_14_a:
  sectionId (9724)
  sectionNo 14A
  orderNo 15
  title `Grant by the Central Government to the Board.`
  content obj_root_law_sections_14_a_content
  footnotes `1. Ins. by Act 25 of 1964, s. 4 (w.e.f. 16-6-1964).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9724&sectionno=14A&orderno=15&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_14_a_content:
  string
  line `^1[14A. Grant by the Central Government to the Board.--The Central Government may, after due`
  line `appropriation made by Parliament by law in this behalf, pay to the Board by way of grants, such sums of`
  line `money as the Central Government may consider necessary.]`
obj_root_law_sections_15:
  sectionId (9725)
  sectionNo (15)
  orderNo 16
  title `Constitution of Fund.`
  content obj_root_law_sections_15_content
  footnotes `1 Ins. by s. 5, ibid. (w.e.f. 16-6-1964).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9725&sectionno=15&orderno=16&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_15_content:
  string
  line `(1) There shall be formed by the Board a Fund to be called the Coir`
  line `Fund and there shall be credited thereto--`
  line
  line `(a) the proceeds of the cess made over to the Board by the Central Government;`
  line
  line `(b) any other fee that may be levied and collected under this Act or the rules made thereunder;`
  line
  line `^1[(c) any sum of money that may be paid by way of grants under section 14A.]`
  line
  line `(2) The Fund shall be applied towards meeting the expenses of the Board and the cost of the measures`
  line `referred to in section 10.`
obj_root_law_sections_16:
  sectionId (9726)
  sectionNo (16)
  orderNo 17
  title `Borrowing powers of Board.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9726&sectionno=16&orderno=17&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_16_content:
  string
  line `Subject to such rules as may be made in this behalf, the Board`
  line `shall have power to borrow on the security of the Fund or any other asset for any purposes for which the`
  line `Fund may be applied.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (9727)
  sectionNo (17)
  orderNo 18
  title `Accounts and audit.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by Act 25 of 1964, s. 6, for section 17 (w.e.f. 16-6-1964)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9727&sectionno=17&orderno=18&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_17_content:
  string
  line `^1[17. Accounts and audit.--(1) The Board shall maintain proper accounts and other relevant records`
  line `and prepare an annual statement of accounts, including the profit and loss account and the balance-sheet`
  line `in such form as may be prescribed by the Central Government in consultation with the Comptroller and`
  line `Auditor-General of India.`
  line
  line `(2) The accounts of the Board shall be audited by the Comptroller and Auditor-General of India at`
  line `such intervals as may be prescribed by him and any expenditure incurred in connection with such audit`
  line `shall be payable by the Board to the Comptroller and Auditor-General.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Board shall have the same rights and privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General has in connection with audit of`
  line `Government accounts, and in particular, shall have the right to demand the production of books, accounts,`
  line `connected vouchers and other documents and papers and to inspect any of the offices of the Board.`
  line
  line `(4) The accounts of the Board as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.]`
obj_root_law_sections_18:
  sectionId (9728)
  sectionNo (18)
  orderNo 19
  title `General control over acts and proceedings of the Board.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9728&sectionno=18&orderno=19&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_18_content:
  string
  line `(1) All acts and proceedings of the`
  line `Board shall be subject to the control of the Central Government which may cancel, suspend or modify as`
  line `it thinks fit any action taken by the Board.`
  line
  line `(2) The Board shall carry out such directions as may be issued to it by the Central Government for the`
  line `efficient administration of this Act.`
  line
  line `(3) The records of the Board shall be open to inspection at all reasonable times by any officer`
  line `authorised in this behalf by the Central Government.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (9729)
  sectionNo (19)
  orderNo 20
  title `Report and returns.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by 41 of 1994, s. 2, for sub-section (1) (w.e.f. 8-7-1994).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9729&sectionno=19&orderno=20&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_19_content:
  string
  line `^1[(1) The Board shall submit to the Central Government and such other`
  line `authority, as may be prescribed, an annual report on its activities and the working of this Act for the`
  line `preceding year; and a copy of every such report shall, as soon as may be after it is received by the Central`
  line `Government, be laid before each House of Parliament.]`
  line
  line `(2) The Board shall prepare and submit such other returns relating to the coir industry as may be`
  line `required by that Government from time to time.`
obj_root_law_sections_20:
  sectionId (9730)
  sectionNo (20)
  orderNo 21
  title Penalties.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9730&sectionno=20&orderno=21&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_20_content:
  string
  line `(1) If any person contravenes the provisions of section 12, he shall be punishable`
  line `with fine which may extend to five hundred rupees.`
  line
  line `(2) Any person who attempts to contravene or abets the contravention of the provisions of section 12`
  line `shall be deemed to have contravened those provisions.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (9731)
  sectionNo (21)
  orderNo 22
  title `Offences by companies.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9731&sectionno=21&orderno=22&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_21_content:
  string
  line `(1) If the person committing an offence under section 12 is a`
  line `company, every person who at the time the contravention was committed was incharge of, and was`
  line `responsible to, the company for the conduct of the business of the company, as well as the company shall`
  line `be deemed to be guilty of the contravention and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he exercised all`
  line `due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1) where an offence under section 12 has`
  line `been committed by a company and it is proved that the offence has been committed with the consent or connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director" in relation to a firm means a partner in the firm.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (9732)
  sectionNo (22)
  orderNo 23
  title `Previous sanction of Central Government for prosecution.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9732&sectionno=22&orderno=23&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_22_content:
  string
  line `No prosecution for any offence`
  line `punishable under this Act shall be instituted except with the previous approval of the Central`
  line Government.
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (9733)
  sectionNo (23)
  orderNo 24
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9733&sectionno=23&orderno=24&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_23_content:
  string
  line `No suit prosecution or other legal proceeding shall`
  line `lie against any person for anything in good faith done or intended to be done under this Act or the rules`
  line `made thereunder.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (9734)
  sectionNo (24)
  orderNo 25
  title `Power to delegate.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9734&sectionno=24&orderno=25&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_24_content:
  string
  line `The Central Government may, by order notified in the Official Gazette,`
  line `direct that any power exercisable by it under this Act may also be exercised in such cases and subject to`
  line `such conditions, if any, as may be specified in the order by such officer or authority as may be specified`
  line therein.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (9735)
  sectionNo (25)
  orderNo 26
  title `Suspension of operation of Act.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9735&sectionno=25&orderno=26&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_25_content:
  string
  line `(1) If the Central Government is satisfied that circumstances`
  line `have arisen rendering it necessary that certain of the restrictions imposed by this Act should cease to be`
  line `imposed or if it considers it necessary or expedient so to do in the public interest the Central Government`
  line `may, by notification in the Official Gazette, suspend or relax to a specified extent either indefinitely or for`
  line `such period as may be specified in the notification the operation of all or any of the provisions of this Act.`
  line
  line `(2) Where the operation of any provisions of this Act has under sub-section (1) been suspended or`
  line `relaxed indefinitely, such suspension or relaxation may at any time while this Act remains in force be`
  line `removed by the Central Government by notification in the Official Gazette.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (9736)
  sectionNo (26)
  orderNo 27
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9736&sectionno=26&orderno=27&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_26_content:
  string
  line `(1) The Central Government may, subject to`
  line `the condition of previous publication, make rules or carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the constitution of the Board, the number of persons to be appointed as members from each of`
  line `the categories specified in sub-section (3) of section 4, the term of office and the other conditions of`
  line `service of, the procedure to be followed by, and the manner of filling vacancies among, the members`
  line `of the Board;`
  line
  line `(b) the circumstances in which, and the authority by which, members may be removed;`
  line
  line `(c) the holding of a minimum number of meetings every year;`
  line
  line `(d) the pay and allowances and other conditions of service of the secretary;`
  line
  line `(e) the maintenance of records of all business transacted at meetings of the Board and the`
  line `submission of copies of such records to the Central Government;`
  line
  line `(f) the preparation of budget estimate of the receipts and expenditure of the Board and the`
  line `authority by which such estimates should be sanctioned;`
  line
  line `(g) the conditions subject to which, and the mode in which, contracts may be made by or on`
  line `behalf of the Board;`
  line
  line `(h) the powers of the Board and the Executive Committee and the Chairman, in regard to the`
  line `incurring of expenditure; and the re-appropriation of estimated savings in any budget heard to another`
  line `such head;`
  line
  line `(i) the conditions subject to which the Board may borrow;`
  line
  line `(j) the form and the manner in which accounts should be kept by the Board;`
  line
  line `(k) the registration of coir spindles and looms for the manufacture of coir products as also the`
  line `registration of manufacturers of coir products and the conditions for such registration; the grant or`
  line `issue of licences under this Act; the fees to be levied in respect of such registration and licences; and`
  line `the suspension and cancellation of such registration and licences;`
  line
  line `(l) the form of applications for registration and licences under this Act and the fee, if any, to be`
  line `paid in respect of any such applications;`
  line
  line `(m) the collection of any information or statistics in respect of the coir industry;`
  line
  line `(n) any other matter which is to be or may be prescribed.`
  line
  line `^1[(3) Every rule made by the Central Government under this section shall be laid as soon as may be`
  line `after it is made, before each House of Parliament while it is in session for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if ^2[before the expiry`
  line `of the session immediately following the session or the successive sessions aforesaid], both Houses agree`
  line `in making any modification in the rule or both Houses agree that the rule should not be made, the rule`
  line `shall thereafter have effect only in such modified form or be of no effect, as the case may be; so, however,`
  line `that any such modification or annulment shall be without prejudice to the validity of anything previously`
  line `done under that rule.]`
obj_root_law_sections_26_footnotes:
  string
  line `1. Subs. by Act 25 of 1964, s. 7, for sub-section (3) (w.e.f. 16-6-1964).`
  line
  line `2. Subs. by Act 4 of 1986, s. 2 and the Schedule, for the words "before the expiry of the session in which it is so laid or the`
  line `successive sessions aforesaid" (w.e.f. 15-5-1986).`
obj_root_law_sections_27:
  sectionId (9737)
  sectionNo (27)
  orderNo 28
  title `Power of Board to make by-laws.`
  content obj_root_law_sections_27_content
  footnotes `1. Ins. by Act 4 of 1986, s. 2 and the Schedule, (w.e.f. 15-5-1986).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00003_195345_1517807328323&sectionId=9737&sectionno=27&orderno=28&orgactid=AC_CEN_46_77_00003_195345_1517807328323
obj_root_law_sections_27_content:
  string
  line `(1) The Board may make by-laws consistent with this Act`
  line `and the rules made thereunder, to provide for,--`
  line
  line `(a) the dates, times and places of its meetings and of the meetings of the Executive and other`
  line `Committees and the quorum for such meetings, and the procedure thereat;`
  line
  line `(b) the delegation of powers and duties to the Executive or any other Committee, or to its`
  line `Chairman, Vice-Chairman, Secretary or any other of its officers;`
  line
  line `(c) the travelling allowances of members and of members of Committees;`
  line
  line `(d) the appointment, promotion and dismissal of its officers and other employees other than the`
  line `Secretary and the creation and abolition of their posts;`
  line
  line `(e) the conditions of service of its officers and other employees other than the Secretary including`
  line `their pay, leave, leave allowances, pensions, gratuities, compassionate allowances and travelling`
  line `allowances and the establishment and maintenance of a provident fund for them;`
  line
  line `(f) the maintenance of its accounts;`
  line
  line `(g) the persons by whom, and the manner in which payments, deposits and investments may be`
  line `made on its behalf;`
  line
  line `(h) the custody of moneys required for its current expenditure and the investment of moneys not`
  line `so required;`
  line
  line `(i) the preparation of statements showing the sums allotted to departments of the Central and`
  line `State Governments and other institutions.`
  line
  line `(2) No by-law shall take effect until it has been confirmed by the Central Government and published`
  line `in the Official Gazette; and the Central Government in confirming a by-law may make any change therein`
  line `which appears to it to be necessary.`
  line
  line `(3) The Central Government may, by notification in the Official Gazette, cancel any by-law which it`
  line `has confirmed and thereupon the by-law shall cease to have effect.`
  line
  line `^1[(4) Every by-law made under this Act shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the by-law or both Houses agree that the by-law should not be made, the by-law shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that by-law.]`
