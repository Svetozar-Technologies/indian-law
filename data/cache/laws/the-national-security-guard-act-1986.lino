obj_root_law_sections_1:
  sectionId (7659)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7659&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Security Guard Act,`
  line 1986.
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 16th October, 1986, vide notification No. S.O. 737(E), dated 16th October, 1986, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (7660)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7660&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,—`
  line
  line `(a) "active duty", in relation to a person subject to this Act, means any duty as a member of the`
  line `Security Guard during the period in which such person is attached to, or forms part of, a unit of the`
  line `Security Guard—`
  line
  line `(i) which is engaged in operations against terrorists or any person in arms against the Union;`
  line or
  line
  line `(ii) which is operating at a picket or engaged on patrol or any other duty, in relation to`
  line `combating terrorist activity;`
  line
  line `(b) "Assistant Commander" means a person appointed or in pay as an Assistant Commander`
  line `Grade I, Assistant Commander Grade II or Assistant Commander Grade III;`
  line
  line `(c) "civil offence" means an offence which is triable by a Criminal Court or by a special Judge`
  line `appointed under the Criminal Law Amendment Act, 1952 (46 of 1952);`
  line
  line `(d) "civil prison" means any jail or place used for the detention of any criminal prisoner under the`
  line `Prisons Act, 1894 (9 of 1894), or under any other law for the time being in force;`
  line
  line `(e) "combatised tradesman" means a person appointed or in pay as a combatised tradesman;`
  line
  line `(f) "Commander", when used in any provision of this Act with reference to any unit of the`
  line `Security Guard, means the officer whose duty it is to discharge with respect to that unit, the functions`
  line `of a Commander in regard to matters of the description referred to in that provision;`
  line
  line `(g) "Criminal Court" means a Court of ordinary criminal justice in any part of India and includes`
  line `a Court of a special Judge appointed under the Criminal Law Amendment Act, 1952 (46 of 1952);`
  line
  line `(h) "Deputy Inspector-General" means a Deputy Inspector-General of the Security Guard`
  line `appointed under section 5;`
  line
  line `(i) "Director-General" and "Additional Director-General" mean, respectively, the`
  line `Director-General and an Additional Director-General of the Security Guard appointed under`
  line `section 5;`
  line
  line `(j) "Group" means a unit of the Security Guard constituted as a Group by the Central`
  line Government;
  line
  line `(k) "Group Commander" means a Group Commander of the Security Guard appointed under`
  line `section 5;`
  line
  line `(l) "Inspector-General" means an Inspector-General of the Security Guard appointed under`
  line `section 5;`
  line
  line `(m) "Judge Attorney-General", "Additional Judge Attorney-General", "Deputy Judge`
  line `Attorney-General" and "Judge Attorney" mean, respectively, the Judge Attorney-General, an`
  line `Additional Judge Attorney-General, a Deputy Judge Attorney-General and a Judge Attorney of the`
  line `Security Guard appointed in the appropriate rank by the Central Government;`
  line
  line `(n) "member of the Security Guard" means an officer, an Assistant Commander, a Ranger or a`
  line `combatised tradesman;`
  line
  line `(o) "notification" means a notification published in the Official Gazette;`
  line
  line `(p) "offence" means any act or omission punishable under this Act and includes a civil offence;`
  line
  line `(q) "officer" means a person appointed or in pay as an officer of the Security Guard;`
  line
  line `(r) "prescribed" means prescribed by rules;`
  line
  line `(s) "Ranger" means a Ranger Grade I and a Ranger Grade II of the Security Guard;`
  line
  line `(t) "rule" means a rule made under this Act;`
  line
  line `(u) "Security Guard" means the National Security Guard;`
  line
  line `(v) "Security Guard Court" means a Court referred to in section 61;`
  line
  line `(w) "Security Guard custody" means the arrest or confinement of a member of the Security Guard`
  line `according to rules;`
  line
  line `(x) "superior officer", when used in relation to a person subject to this Act, means`
  line
  line `(i) any member of the Security Guard to whose command such person is for the time being`
  line `subject in accordance with the rules;`
  line
  line `(ii) any officer of a higher rank or class,`
  line
  line `and includes, when such person is not an officer, an Assistant Commander or a Ranger of a higher rank or`
  line class;
  line
  line `(y) "terrorist" means any person who, with intent to over-awe the Government as by law`
  line `established or to strike terror in the people or any section of the people or to alienate any section of`
  line `the people or to adversely affect the harmony amongst different sections of the people, does any act`
  line `or thing by using bombs, dynamite or other explosive substances or inflammable substances or`
  line `firearms or other lethal weapons or poisons or noxious gases or other chemicals or any other`
  line `substances (whether biological or otherwise) of a hazardous nature, in such a manner as to cause, or`
  line `as is likely to cause, death of, or injuries to, any person or persons or damage to, or destruction of,`
  line `property or disruption of any supplies or services essential to the life of the community;`
  line
  line `(z) all words and expressions used and not defined in this Act but defined in the Indian Penal`
  line `Code (45 of 1860) shall have the meanings respectively assigned to them in that Code.`
  line
  line `(2) In this Act, references to any law not in force in any State shall be construed as references to`
  line `the corresponding law in force in that State.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (7661)
  sectionNo (3)
  orderNo 3
  title `Persons subject to this Act.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7661&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_3_content:
  string
  line `(1) The following persons appointed (whether on deputation or in`
  line `any other manner) in the Security Guard shall be subject to this Act, wherever they may be, namely:—`
  line
  line `(a) officers and Assistant Commander; and`
  line
  line `(b) Rangers and combatised tradesmen.`
  line
  line `(2) Every person subject to this Act shall remain so subject until repatriated, retired, released,`
  line `discharged, removed or dismissed from the Security Guard in accordance with the provisions of this Act`
  line `and the rules`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (7662)
  sectionNo (4)
  orderNo 4
  title `Constitution of the Security Guard.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7662&sectionno=4&orderno=4&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_4_content:
  string
  line `(1) There shall be an armed force of the Union called the`
  line `National Security Guard for combating terrorist activities with a view to protect States against internal`
  line disturbances.
  line
  line `(2) Subject to the provisions of this Act, the Security Guard shall be constituted in such manner as`
  line `may be prescribed and the conditions of service of the members of the Security Guard shall be such as`
  line `may be prescribed.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (7663)
  sectionNo (5)
  orderNo 5
  title `Control, direction, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7663&sectionno=5&orderno=5&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_5_content:
  string
  line `(1) The general superintendence, direction and control of the Security`
  line `Guard shall vest in, and be exercised by, the Central Government and subject thereto and to the provisions`
  line `of this Act and the rules, the command and supervision of the Security Guard shall vest in an officer to be`
  line `appointed by the Central Government as the Director-General of the Security Guard.`
  line
  line `(2) The Director-General shall, in the discharge of his duties under this Act, be assisted by such`
  line `number of Additional Directors-General, Inspectors-General, Deputy Inspectors-General, Group`
  line `Commanders and other officers as may be appointed by the Central Government.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (7664)
  sectionNo (6)
  orderNo 6
  title `Liability for service outside India.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7664&sectionno=6&orderno=6&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_6_content:
  string
  line `Every member of the Security Guard shall be liable to serve`
  line `in any part of India as well as outside India.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (7665)
  sectionNo (7)
  orderNo 7
  title `Resignation and withdrawal from the post.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7665&sectionno=7&orderno=7&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_7_content:
  string
  line `No member of the Security Guard shall be at`
  line liberty—
  line
  line `(a) to resign his appointment during the term of his engagement; or`
  line
  line `(b) to withdraw himself from all or any of the duties of his appointment,`
  line
  line `except with the previous permission in writing of the prescribed authority.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (7666)
  sectionNo (8)
  orderNo 8
  title `Tenure of service under the Act.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7666&sectionno=8&orderno=8&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_8_content:
  string
  line `Every person subject to this Act shall hold office during the`
  line `pleasure of the President.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (7667)
  sectionNo (9)
  orderNo 9
  title `Termination of service by Central Government.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7667&sectionno=9&orderno=9&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_9_content:
  string
  line `Subject to the provisions of this Act and the`
  line `rules, the Central Government may dismiss or remove from service any person subject to this Act.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (7668)
  sectionNo (10)
  orderNo 10
  title `Dismissal, removal or reduction by the Director-General and by other officers.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7668&sectionno=10&orderno=10&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_10_content:
  string
  line `(1) The`
  line `Director-General, any Additional Director-General or any Inspector-General may dismiss or remove from`
  line `service or reduce to a lower grade or rank or the ranks, any person subject to this Act other than an`
  line officer.
  line
  line `(2) An officer not below the rank of a Deputy Inspector-General or any prescribed officer may`
  line `dismiss or remove from the service any person under his command other than an officer or an Assistant`
  line Commander.
  line
  line `(3) Any such officer as is mentioned in sub-section (2) may reduce to a lower grade or rank or the`
  line `ranks any person under his command except an officer or an Assistant Commander.`
  line
  line `(4) The exercise of any power under this section shall be subject to the provisions of this Act and the`
  line rules.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (7669)
  sectionNo (11)
  orderNo 11
  title `Certificate of termination of service.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7669&sectionno=11&orderno=11&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_11_content:
  string
  line `An Assistant Commander or a Ranger or a combatised`
  line `tradesman who is retired, released, discharged, removed or dismissed from the service shall be furnished`
  line `by the officer to whose command he is subject, with a certificate setting forth—`
  line
  line `(a) the authority terminating his service;`
  line
  line `(b) the cause for such termination; and`
  line
  line `(c) the full period of his service in the Security Guard.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (7670)
  sectionNo (12)
  orderNo 12
  title `Restrictions respecting right to form associations, freedom of speech, etc.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7670&sectionno=12&orderno=12&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_12_content:
  string
  line `(1) No person`
  line `subject to this Act shall, without the previous sanction in writing of the Central Government or of the`
  line `prescribed authority,—`
  line
  line `(a) be a member of, or be associated in any way with, any trade union, labour union, political`
  line `association or with any class of trade unions, labour unions or political associations; or`
  line
  line `(b) be a member of, or be associated in any way with, any society, institution, association or`
  line `organisation that is not recognised as part of the Security Guard or is not of a purely social,`
  line `recreational or religious nature; or`
  line
  line `(c) communicate with the press or publish or cause to be published any book, letter or other`
  line `document except where such communication or publication is in the bona fide discharge of his duties`
  line `or is of a purely literary, artistic or scientific character or is of a prescribed nature.`
  line
  line `Explanation.—If any question arises as to whether any society, institution, association or organisation`
  line `is of a purely social, recreational or religious nature under clause (b) of this sub-section, the decision of`
  line `the Central Government thereon shall be final.`
  line
  line `(2) No person subject to this Act shall participate in, or address, any meeting or take part in any`
  line `demonstration organised by any body of persons for any political purposes or for such other purposes as`
  line `may be prescribed.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (7671)
  sectionNo (13)
  orderNo 13
  title `Remedy of aggrieved persons other than officers.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7671&sectionno=13&orderno=13&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_13_content:
  string
  line `(1) Any person subject to this Act other`
  line `than an officer who deems himself wronged by any superior or other officer may, complain to the officer`
  line `under whose command he is serving.`
  line
  line `(2) When the officer complained against is the officer to whom any complaint should, under`
  line `sub-section (1), be preferred, the aggrieved person may complain to such officers next superior officer.`
  line
  line `(3) Every officer receiving any such complaint shall make as complete an investigation into it as may`
  line `be possible for giving full redress to the complainant; or when necessary, refer the complaint to a superior`
  line authority.
  line
  line `(4) The Director-General may revise any decision made under any of the foregoing sub-sections, but,`
  line `subject thereto, such decision shall be final.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (7672)
  sectionNo (14)
  orderNo 14
  title `Remedy of aggrieved officers.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7672&sectionno=14&orderno=14&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_14_content:
  string
  line `Any officer who deems himself wronged by his Commander or`
  line `any other superior officer and who, on due application made to his Commander or such other superior`
  line `officer, does not receive the redress to which he considers himself entitled, may complain to the`
  line `Director-General or the Central Government through proper channel.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (7673)
  sectionNo (15)
  orderNo 15
  title `Offences in relation to the terrorists and other persons in arms against the Union and punishable with death.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7673&sectionno=15&orderno=15&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_15_content:
  string
  line `Any person subject to this Act who commits any of the following offences, that`
  line `is to say,—`
  line
  line `(a) shamefully abandons place of his duty or misbehaves in such manner as to show cowardice`
  line `during operations;`
  line
  line `(b) treacherously holds correspondence with, or communicates intelligence to, a terrorist or any`
  line `person in arms against the Union; or`
  line
  line `(c) directly or indirectly assists any terrorist with money, arms, ammunition, stores or supplies or`
  line `in any other manner whatsoever; or`
  line
  line `(d) knowingly does any act calculated to imperil the success of the Security Guard or the military,`
  line `naval, air forces or any other armed force of India or any forces co-operating therewith or any part of`
  line `such forces,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer death or such less punishment as is in`
  line `this Act mentioned.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (7674)
  sectionNo (16)
  orderNo 16
  title `Offences punishable more severely on active duty than at other times.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7674&sectionno=16&orderno=16&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_16_content:
  string
  line `Any person subject to`
  line `this Act who commits any of the following offences, that is to say,—`
  line
  line `(a) forces a safeguard, or forces or uses criminal force to a sentry; or`
  line
  line `(b) breaks into any house or other place in search of plunder; or`
  line
  line `(c) being a sentry sleeps upon his post, or is drunk; or`
  line
  line `(d) without orders from his superior officer leaves his guard, picket, patrol or post,`
  line
  line `shall, on conviction by a Security Guard Court,—`
  line
  line `(i) if he commits any such offence when on active duty, be liable to suffer imprisonment for a`
  line `term which may extend to fourteen years or such less punishment as is in this Act mentioned; and`
  line
  line `(ii) if he commits any such offence when not on active duty, be liable to suffer imprisonment for`
  line `a term which may extend to seven years of such less punishment as is in this Act mentioned`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (7675)
  sectionNo (17)
  orderNo 17
  title Mutiny.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7675&sectionno=17&orderno=17&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_17_content:
  string
  line `Any person subject to this Act who commits any of the following offences, that is to`
  line say,—
  line
  line `(a) begins, incites, causes or conspires with any other person to cause any mutiny in the Security`
  line `Guard or in the military, naval, air forces or any other armed force of India or any forces co-operating`
  line `therewith; or`
  line
  line `(b) joins in any such mutiny; or`
  line
  line `(c) being present at any such mutiny, does not use his utmost endeavours to suppress the same; or`
  line
  line `(d) knowing or having reason to believe in the existence of any such mutiny, or of any intention`
  line `to mutiny or of any such conspiracy, does not, without delay, give information thereof to his`
  line `Commander or other superior officer; or`
  line
  line `(e) endeavours to seduce any person in the Security Guard or in the military, naval, air forces or`
  line `any other armed force of India or any forces co-operating therewith from his duty or allegiance to the`
  line Union,
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer death or such less punishment as is in`
  line `this Act mentioned.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (7676)
  sectionNo (18)
  orderNo 18
  title `Desertion and aiding desertion.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7676&sectionno=18&orderno=18&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_18_content:
  string
  line `(1) Any person subject to this Act who deserts or attempts to`
  line `desert the service shall, on conviction by a Security Guard Court,—`
  line
  line `(a) if he commits the offence when on active duty or when under orders for active duty, be liable`
  line `to suffer death or such less punishment as is in this Act mentioned; and`
  line
  line `(b) if he commits the offence under any other circumstances, be liable to suffer imprisonment for`
  line `a term which may extend to seven years or such less punishment as is in this Act mentioned.`
  line
  line `(2) Any person subject to this Act who knowingly harbours any such deserter shall, on conviction by`
  line `a Security Guard Court, be liable to suffer imprisonment for a term which may extend to three years or`
  line `such less punishment as is in this Act mentioned.`
  line
  line `(3) Any person subject to this Act who, being cognizant of any desertion or attempt at desertion of a`
  line `person subject to this Act, does not forthwith give notice to his own or some other superior officer, or take`
  line `any steps in his power to cause such person to be apprehended, shall, on conviction by a Security Guard`
  line `Court, be liable to suffer imprisonment for a term which may extend to two years or such less punishment`
  line `as is in this Act mentioned.`
  line
  line `(4) For the purposes of this Act, a person deserts,—`
  line
  line `(a) if he absents from his unit or the place of duty at any time with the intention of not reporting`
  line `back to such unit or place, or who, at any time and under any circumstances when absent from his`
  line `unit or place of duty, does any act which shows that he has an intention of not reporting to such unit`
  line `or place of duty;`
  line
  line `(b) if he absents himself without leave with intent to avoid any active duty.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (7677)
  sectionNo (19)
  orderNo 19
  title `Absence without leave.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7677&sectionno=19&orderno=19&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_19_content:
  string
  line `Any person subject to this Act who commits any of the following`
  line `offences, that is to say,—`
  line
  line `(a) absents himself without leave; or`
  line
  line `(b) without sufficient cause overstays leave granted to him; or`
  line
  line `(c) being on leave or absence and having received information from the appropriate authority that`
  line `any unit or part thereof to which he belongs, has been ordered on active duty, fails, without sufficient`
  line `cause, to rejoin without delay; or`
  line
  line `(d) without sufficient cause fails to appear at the time fixed at the parade or place appointed for`
  line `exercise or duty; or`
  line
  line `(e) when on parade, or on the line of march, without sufficient cause or without leave from his`
  line `superior officer, quits the parade or line of march; or`
  line
  line `(f) when in camp or elsewhere, is found beyond any limits fixed, or in any place prohibited, by`
  line `any general, local or other order, without a pass or written leave from his superior officer; or`
  line
  line `(g) without leave from his superior officer or without due cause, absents himself from any school`
  line `when duly ordered to attend there,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to three years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (7678)
  sectionNo (20)
  orderNo 20
  title `Striking or threatening superior officer.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7678&sectionno=20&orderno=20&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_20_content:
  string
  line `Any person subject to this Act who commits any of`
  line `the following offences, that is to say,—`
  line
  line `(a) uses criminal force to or assaults his superior officer; or`
  line
  line `(b) uses threatening language to such officer; or`
  line
  line `(c) uses insubordinate language to such officer,`
  line
  line `shall, on conviction by a Security Guard Court,—`
  line
  line `(i) if such officer is at the time in the execution of his office or, if the offence is committed on`
  line `active duty, be liable to suffer imprisonment for a term which may extend to fourteen years or such`
  line `less punishment as is in this Act mentioned; and`
  line
  line `(ii) in other cases, be liable to suffer imprisonment for a term which may extend to ten years or such less`
  line `punishment as is in this Act mentioned:`
  line
  line `Provided that in the case of any offence specified in clause (c), the imprisonment shall not exceed five years.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (7679)
  sectionNo (21)
  orderNo 21
  title `Disobedience to superior officer.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7679&sectionno=21&orderno=21&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_21_content:
  string
  line `(1) Any person subject to this Act who disobeys, in such`
  line `manner as to show a wilful defiance of authority, any lawful command given personally by his superior`
  line `officer in the execution of his office whether the same is given orally, or in writing or by signal or`
  line `othrewise, shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term`
  line `which may extend to fourteen years or such less punishment as is in this Act mentioned.`
  line
  line `(2) Any person subject to this Act who disobeys any lawful command given by his superior officer`
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to seven years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (7680)
  sectionNo (22)
  orderNo 22
  title `Assault and obstruction.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7680&sectionno=22&orderno=22&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_22_content:
  string
  line `Any person subject to this Act who commits any of the following`
  line `offences, that is to say,`
  line
  line `(a) being concerned in any quarrel, affray or disorder, refuses to obey any officer, though of`
  line `inferior rank, who orders him into arrest, or uses criminal force to or assaults any such officer; or`
  line
  line `(b) uses criminal force to, or assaults any person, whether subject to this Act or not, in whose`
  line `custody he is lawfully placed, and whether he is or is not his superior officer; or`
  line
  line `(c) resists an escort whose duty it is to apprehend him or have him in charge; or`
  line
  line `(d) breaks out of barracks, camp or quarters; or`
  line
  line `(e) refuses to obey any general, local or other order,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend, in the case of offences specified in clauses (d) and (e), to two years, and in the case of the`
  line `offences specified in the other clauses, to ten years, or in either case such less punishment as is in this Act`
  line mentioned.
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (7681)
  sectionNo (23)
  orderNo 23
  title `Certain forms of disgraceful conduct.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7681&sectionno=23&orderno=23&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_23_content:
  string
  line `Any person subject to this Act who commits any of the`
  line `following offences, that is to say,—`
  line
  line `(a) is guilty of any disgraceful conduct of a cruel, indecent or unnatural kind; or`
  line
  line `(b) malingers or feigns or produces disease or infirmity in himself or intentionally delays his cure`
  line `or aggravates his disease or infirmity; or`
  line
  line `(c) with intent to render himself or any other person unfit for service, voluntarily causes hurt to`
  line `himself or that person,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to seven years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (7682)
  sectionNo (24)
  orderNo 24
  title `Ill-treating a subordinate.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7682&sectionno=24&orderno=24&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_24_content:
  string
  line `Any officer, Assistant Commander or Ranger Grade I, who uses`
  line `criminal force to, or otherwise ill-treats, any person subject to this Act, being his subordinate in rank or`
  line `position, shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term`
  line `which may extend to seven years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (7683)
  sectionNo (25)
  orderNo 25
  title Drunkenness.
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7683&sectionno=25&orderno=25&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_25_content:
  string
  line `(1) Any person subject to this Act, who is found in a state of drunkenness,`
  line `whether on duty or not, shall, on conviction by a Security Guard Court, be liable to suffer imprisonment`
  line `for a term which may extend to six months or such less punishment as is in this Act mentioned.`
  line
  line `(2) For the purposes of sub-section (1), a person shall be deemed to be in a state of drunkenness if,`
  line `owing to the influence of alcohol or any drug whether alone or in combination with any other substance,`
  line `he is unfit to be entrusted with his duty or with any duty which he may be called upon to perform or`
  line `behaves in a disorderly manner or in a manner likely to bring discredit to the Security Guard.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (7684)
  sectionNo (26)
  orderNo 26
  title `Permitting escape of person in custody.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7684&sectionno=26&orderno=26&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_26_content:
  string
  line `Any person subject to this Act who commits any of`
  line `the following offences, that is to say,—`
  line
  line `(a) when in command of a guard, picket, patrol, detachment or post, releases without proper`
  line `authority, whether wilfully or without reasonable excuse, any person committed to his charge, or`
  line `refuses to receive any prisoner or person so committed; or`
  line
  line `(b) wilfully or without reasonable excuse allows to escape any person who is committed to his`
  line `charge, or whom it is his duty to keep or guard,`
  line
  line `shall, on conviction by a Security Guard Court, be liable, if he has acted wilfully, to suffer imprisonment`
  line `for a term which may extend to ten years or such less punishment as is in this Act mentioned; and if he`
  line `has not acted wilfully, to suffer imprisonment for a term which may extend to two years or such less`
  line `punishment as is in this Act mentioned.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (7685)
  sectionNo (27)
  orderNo 27
  title `Irregularity in connection with arrest or confinement.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7685&sectionno=27&orderno=27&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_27_content:
  string
  line `Any person subject to this Act who`
  line `commits any of the following offences, that is to say,—`
  line
  line `(a) unnecessarily detains a person in arrest or confinement without bringing him to trial, or fails`
  line `to bring his case before the proper authority for investigation; or`
  line
  line `(b) having committed a person to Security Guard custody fails without reasonable cause to`
  line `deliver at the time of such committal, or as soon as practicable, and in any case within forty-eight`
  line `hours thereafter, to the officer or other person into whose custody the person arrested is committed,`
  line `an account in writing signed by himself of the offence with which the person so committed is`
  line charged,
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to one year or such less punishment as is in this Act mentioned.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (7686)
  sectionNo (28)
  orderNo 28
  title `Escape from custody.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7686&sectionno=28&orderno=28&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_28_content:
  string
  line `Any person subject to this Act who, being in lawful custody, escapes or`
  line `attempts to escape, shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a`
  line `term which may extend to three years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (7687)
  sectionNo (29)
  orderNo 29
  title `Offences in respect of property.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7687&sectionno=29&orderno=29&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_29_content:
  string
  line `Any person subject to this Act who commits any of the`
  line `following offences, that is to say,—`
  line
  line `(a) commits theft of any property belonging to the Government, or to any Security Guard mess,`
  line `band or institution, or to any person subject to this Act; or`
  line
  line `(b) dishonestly misappropriates or converts to his own use any such property; or`
  line
  line `(c) commits criminal breach of trust in respect of any such property: or`
  line
  line `(d) dishonestly receives or retains any such property in respect of which any of the offences under`
  line `clauses (a), (b) and (c) has been committed, knowing or having reason to believe the commission of`
  line `such offence; or`
  line
  line `(e) wilfully destroys or injures any property of the Government entrusted to him; or`
  line
  line `(f) does any other thing with intent to defraud, or to cause wrongful gain to one person or`
  line `wrongful loss to another person,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to ten years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (7688)
  sectionNo (30)
  orderNo 30
  title `Extortion and exaction.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7688&sectionno=30&orderno=30&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_30_content:
  string
  line `Any person subject to this Act who commits any of the following`
  line `offences, that is to say,—`
  line
  line `(a) commits extortion; or`
  line
  line `(b) without proper authority exacts from any person money, provisions or service,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to ten years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (7689)
  sectionNo (31)
  orderNo 31
  title `Making away with equipment.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7689&sectionno=31&orderno=31&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_31_content:
  string
  line `Any person subject to this Act who commits any of the`
  line `following offences, that is to say,—`
  line
  line `(a) makes away with, or is concerned in making away with, any arms, ammunition, equipment,`
  line `instruments, tools, clothing or any other thing being the property of the Government issued to him for`
  line `his use or entrusted to him; or`
  line
  line `(b) loses by neglect anything mentioned in clause (a); or`
  line
  line `(c) sells, pawns, destroys or defaces any medal or decoration granted to him,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend, in the case of the offences specified in clause (a), to ten years, and in the case of the offences`
  line `specified in the other clauses, to five years, or in either case such less punishment as is in this Act`
  line mentioned.
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (7690)
  sectionNo (32)
  orderNo 32
  title `Injury to property.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7690&sectionno=32&orderno=32&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_32_content:
  string
  line `Any person subject to this Act who commits any of the following offences,`
  line `that is to say,—`
  line
  line `(a) destroys or injures any property mentioned in clause (a) of section 31, or any property`
  line `belonging to any Security Guard mess, band or institution, or to any person subject to this Act; or`
  line
  line `(b) commits any act which causes damage to, or destruction of, any property of the Government`
  line `by fire or in any other manner whatever; or`
  line
  line `(c) kills, injures, makes away with, ill-treats or losses, any animal entrusted to him,`
  line
  line `shall, on conviction by a Security Guard Court, be liable, if he has acted wilfully, to suffer imprisonment`
  line `for a term which may extend to ten years or such less punishment as is in this Act mentioned; and if he`
  line `has acted without reasonable excuse, to suffer imprisonment for a term which may extend to five years or`
  line `such less punishment as is in this Act mentioned.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (7691)
  sectionNo (33)
  orderNo 33
  title `False accusations.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7691&sectionno=33&orderno=33&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_33_content:
  string
  line `Any person subject to this Act who commits any of the following offences,`
  line `that is to say,—`
  line
  line `(a) makes a false accusation against any person subject to this Act, knowing or having reason to`
  line `believe such accusation to be false; or`
  line
  line `(b) in making a complaint against any person subject to this Act makes any statement affecting`
  line `the character of such person, knowing or having reason to believe such statement to be false, or`
  line `knowingly and wilfully suppresses any material fact,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to three years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (7692)
  sectionNo (34)
  orderNo 34
  title `Falsifying official documents and false declarations.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7692&sectionno=34&orderno=34&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_34_content:
  string
  line `Any person subject to this Act who`
  line `commits any of the following offences, that is to say,—`
  line
  line `(a) in any report, return, list, certificate, book or other document made or signed by him, or of the`
  line `contents of which it is his duty to ascertain the accuracy, knowingly makes, or is privy to the making`
  line `of, any false or fraudulent statement; or`
  line
  line `(b) in any document of the description mentioned in clause (a) knowingly makes, or is privy to`
  line `the making of, any omission, with intent to defraud; or`
  line
  line `(c) knowingly and with intent to injure any person, or knowingly and with intent to defraud,`
  line `suppresses, defaces, alters or makes away with any document which it is his duty to preserve or`
  line `produce; or`
  line
  line `(d) where it is his official duty to make a declaration respecting any matter, knowingly makes a`
  line `false declaration; or`
  line
  line `(e) obtains for himself, or for any other person, any pension, allowance or other advantage or`
  line `privilege by a statement which is false, and which he either knows or believes to be false or does not`
  line `believe to be true, or by making or using a false entry in any book or record, or by making any`
  line `document containing a false statement, or by omitting to make a true entry or document containing a`
  line `true statement,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to ten years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (7693)
  sectionNo (35)
  orderNo 35
  title `False declaration on appointment.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7693&sectionno=35&orderno=35&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_35_content:
  string
  line `Any person having become subject to this Act who is`
  line `discovered to have made at the time of appointment a wilfully false statement or declaration in connection`
  line `with his appointment, shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for`
  line `a term which may extend to three years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (7694)
  sectionNo (36)
  orderNo 36
  title `Offences relating to Security Guard Court.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7694&sectionno=36&orderno=36&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_36_content:
  string
  line `Any person subject to this Act who commits any`
  line `of the following offences, that is to say,—`
  line
  line `(a) being duly summoned or ordered to attend as a witness before a Security Guard Court,`
  line `wilfully or without reasonable excuse, makes default in attending; or`
  line
  line `(b) refuses to take an oath or make an affirmation legally required by a Security Guard Court to`
  line `be taken or made; or`
  line
  line `(c) refuses to produce or deliver any document in his power or control legally required by a`
  line `Security Guard Court to be produced or delivered by him; or`
  line
  line `(d) refuses, when a witness, to answer any question which he is by law bound to answer; or`
  line
  line `(e) is guilty of contempt of the Security Guard Court by using insulting or threatening language,`
  line `or by causing any interruption or disturbance in the proceedings of such court,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to three years or such less punishment as is in this Act mentioned`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (7695)
  sectionNo (37)
  orderNo 37
  title `False evidence.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7695&sectionno=37&orderno=37&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_37_content:
  string
  line `Any person subject to this Act who, having been duly sworn or affirmed before`
  line `any Security Guard Court, or before any officer competent under this Act to administer oath or`
  line `affirmation or before a Court of inquiry constituted under this Act, makes any statement which is false,`
  line `and which he either knows or believes to be false or does not believe to be true, shall, on conviction by a`
  line `Security Guard Court, be liable to suffer imprisonment for a term which may extend to seven years or`
  line `such less punishment as is in this Act mentioned.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (7696)
  sectionNo (38)
  orderNo 38
  title `Unlawful detention of pay.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7696&sectionno=38&orderno=38&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_38_content:
  string
  line `Any officer, Assistant Commander or Ranger Grade I who, having`
  line `received the pay of a person subject to this Act unlawfully detains or refuses to pay the same when due,`
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to five years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (7697)
  sectionNo (39)
  orderNo 39
  title `Unbecoming conduct.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7697&sectionno=39&orderno=39&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_39_content:
  string
  line `Any officer or Assistant Commander who behaves in a manner`
  line `unbecoming of his position and the character expected of him shall, on conviction by a Security Guard`
  line `Court, be liable to be dismissed or to suffer such less punishment as is in this Act mentioned.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (7698)
  sectionNo (40)
  orderNo 40
  title `Violation of good order and discipline.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7698&sectionno=40&orderno=40&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_40_content:
  string
  line `Any person subject to this Act who is guilty of any act`
  line `or omission which, though not specified in this Act, is prejudicial to good order and discipline of the`
  line `Security Guard shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term`
  line `which may extend to seven years or such less punishment as is in this Act mentioned.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (7699)
  sectionNo (41)
  orderNo 41
  title `Miscellaneous offences.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7699&sectionno=41&orderno=41&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_41_content:
  string
  line `Any person subject to this Act who commits any of the following`
  line `offences, that is to say,—`
  line
  line `(a) being in command of any detachment or post or on the march, and receiving a complaint that`
  line `any one under his command has beaten or otherwise maltreated or oppressed any person, or has`
  line `caused disturbance at any public place, or committed any riot or trespass, fails to have due reparation`
  line `made to the injured person or to report the case to the proper authority; or`
  line
  line `(b) by defiling any place of worship, or otherwise intentionally insults the religion, or wounds the`
  line `religious feelings of any person; or`
  line
  line `(c) attempts to commit suicide, and in such attempt does any act towards the commission of such`
  line `offence; or`
  line
  line `(d) being below the rank of an Assistant Commander, when off duty, appears without proper`
  line `authority, in or about camp, or in or about, or when going to, or returning from, any town, carrying a`
  line `rifle, sword or other offensive weapon; or`
  line
  line `(e) directly or indirectly accepts or obtains, or agrees to accept, or attempts to obtain, for himself`
  line `or for any other person, any gratification as a motive or reward for procuring the appointment of any`
  line `person, or leave of absence, promotion or any other advantage or indulgence for any person in the`
  line `service; or`
  line
  line `(f) commits any offence against the property or person of any inhabitant of, or resident in, the`
  line `country in which he is serving,`
  line
  line `shall, on conviction by a Security Guard Court, be liable to suffer imprisonment for a term which may`
  line `extend to seven years or such less punishment as is in this Act mentioned`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (7700)
  sectionNo (42)
  orderNo 42
  title Attempt.
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7700&sectionno=42&orderno=42&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_42_content:
  string
  line `Any person subject to this Act who attempts to commit any of the offences specified`
  line `in sections 15 to 41 (both inclusive) and in such attempt does any act towards the commission of the`
  line `offence shall, on conviction by a Security Guard Court, where no express provision is made by this Act`
  line `for the punishment of such attempt, be liable,—`
  line
  line `(a) if the offence attempted to be committed is punishable with death, to suffer imprisonment for`
  line `a term which may extend to fourteen years or such less punishment as is in this Act mentioned; and`
  line
  line `(b) if the offence attempted to be committed is punishable with imprisonment, to suffer`
  line `imprisonment for a term which may extend to one-half of the longest term provided for that offence`
  line `or such less punishment as is in this Act mentioned.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (7701)
  sectionNo (43)
  orderNo 43
  title `Abetment of offences that have been committed.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7701&sectionno=43&orderno=43&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_43_content:
  string
  line `Any person subject to this Act who abets`
  line `the commission of any of the offences specified in sections 15 to 41 (both inclusive) shall, on conviction`
  line `by a Security Guard Court, if the act abetted is committed in consequence of the abetment and no express`
  line `provision is made by this Act for the punishment of such abetment, be liable to suffer the punishment`
  line `provided for that offence or such less punishment as is in this Act mentioned.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (7702)
  sectionNo (44)
  orderNo 44
  title `Abetment of offences that have not been committed.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7702&sectionno=44&orderno=44&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_44_content:
  string
  line `(1) Any person subject to this Act`
  line `who abets the commission of any of the offences punishable with death under sections 15, 17 and`
  line `sub-section (1) of section 18 shall, on conviction by a Security Guard Court, if that offence be not`
  line `committed in consequence of the abetment, and no express provision is made by this Act for the`
  line `punishment of such abetment, be liable to suffer imprisonment for a term which may extend to fourteen`
  line `years or such less punishment as is in this Act mentioned.`
  line
  line `(2) Any person subject to this Act who abets the commission of any of the offences specified in`
  line `sections 15 to 41 (both inclusive) and punishable with imprisonment shall, on conviction by a Security`
  line `Guard Court, if that offence be not committed in consequence of the abetment, and no express provision`
  line `is made by this Act for the punishment of such abetment, be liable to suffer imprisonment for a term`
  line `which may extend to one-half of the longest term provided for that offence or such less punishment as is`
  line `in this Act mentioned.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (7703)
  sectionNo (45)
  orderNo 45
  title `Civil offences.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7703&sectionno=45&orderno=45&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_45_content:
  string
  line `Subject to the provisions of section 46, any person subject to this Act who at any`
  line `place in, or beyond, India commits any civil offence shall be deemed to be guilty of an offence against`
  line `this Act and, if charged therewith under this section shall be liable to be tried by a Security Guard Court`
  line `and, on conviction, be punishable as follows, that is to say,—`
  line
  line `(a) if the offence is one which would be punishable under any law in force in India with death, he`
  line `shall be liable to suffer any punishment, assigned for the offence, by the aforesaid law and such less`
  line `punishment as is in this Act mentioned; and`
  line
  line `(b) in any other case, he shall be liable to suffer any punishment, assigned for the offence by the`
  line `law in force in India, or imprisonment for a term which may extend to seven years, or such less`
  line `punishment as is in this Act mentioned.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (7704)
  sectionNo (46)
  orderNo 46
  title `Civil offences not triable by a Security Guard Court.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7704&sectionno=46&orderno=46&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_46_content:
  string
  line `A person subject to this Act who`
  line `commits an offence of murder or of culpable homicide not amounting to murder against, or of rape in`
  line `relation to, a person not subject to this Act shall not be deemed to be guilty of an offence under this Act`
  line `and shall not be tried by a Security Guard Court, unless he commits any of the said offences,—`
  line
  line `(a) while on active duty; or`
  line
  line `(b) at any place outside India.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (7705)
  sectionNo (47)
  orderNo 47
  title `Punishments awardable by Security Guard Courts.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7705&sectionno=47&orderno=47&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_47_content:
  string
  line `(1) Punishments may be inflicted in`
  line `respect of offences committed by persons subject to this Act and convicted by Security Guard Courts`
  line `according to the scale following, that is to say,—`
  line
  line `(a) death;`
  line
  line `(b) imprisonment which may be for the term of life or any other lesser term but excluding`
  line `imprisonment for a term not exceeding three months in Security Guard custody;`
  line
  line `(c) dismissal from the service;`
  line
  line `(d) imprisonment for a term not exceeding three months in Security Guard custody;`
  line
  line `(e) reduction to the ranks or to a lower rank or grade in the case of a Ranger Grade I;`
  line
  line `(f) forfeiture of seniority of rank and forfeiture of all or any part of the service for the purpose of`
  line `promotion where promotion depends upon length of service;`
  line
  line `(g) forfeiture of service for the purpose of increment or pension or other prescribed purpose;`
  line
  line `(h) severe reprimand or reprimand except in the case of persons below the rank of Ranger`
  line `Grade I;`
  line
  line `(i) forfeiture in the case of a person sentenced to dismissal from the service of all arrears of pay`
  line `and allowances and other public money due to him at the time of such dismissal;`
  line
  line `(j) deduction from pay and allowances to make good any proved loss or damage occasioned by`
  line `the offence for which he is convicted.`
  line
  line `(2) Each of the punishments specified in sub-section (1) shall be deemed to be inferior in degree to`
  line `every punishment preceding it in the above scale`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (7706)
  sectionNo (48)
  orderNo 48
  title `Alternative punishments awardable by Security Guard Courts.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7706&sectionno=48&orderno=48&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_48_content:
  string
  line `Subject to the provisions of`
  line `this Act, a Security Guard Court may, on convicting a person subject to this Act of any of the offences`
  line `specified in sections 15 to 44 (both inclusive) award either the particular punishment with which the`
  line `offence is stated in the said sections to be punishable or, in lieu, thereof, any of the punishments lower in`
  line `the scale set out in section 47 regard being had to the nature and degree of the offence.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (7707)
  sectionNo (49)
  orderNo 49
  title `Combination of punishments.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7707&sectionno=49&orderno=49&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_49_content:
  string
  line `A sentence of a Security Guard Court may award in addition to,`
  line `or without any one other punishment, the punishment specified in clause (c) of sub-section (1) of`
  line `section 47 and any one or more of the punishments specified in clauses (e) to (j) (both inclusive) of that`
  line sub-section.
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (7708)
  sectionNo (50)
  orderNo 50
  title `Punishments otherwise than by Security Guard Courts.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7708&sectionno=50&orderno=50&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_50_content:
  string
  line `Punishments may also be inflicted`
  line `in respect of offences committed by persons subject to this Act without the intervention of a Security`
  line `Guard Court in the manner stated in sections 51 and 53.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (7709)
  sectionNo (51)
  orderNo 51
  title `Minor punishments.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7709&sectionno=51&orderno=51&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_51_content:
  string
  line `(1) Subject to the provisions of section 52, a Commander of and above`
  line `the rank of a Group Commander may, in the prescribed manner proceed against a person subject to this`
  line `Act other than an officer or an Assistant Commander, who is charged with an offence under this Act and`
  line `award such person, to the extent prescribed, one or more of the following punishments, that is to say,—`
  line
  line `(a) imprisonment in Security Guard custody up to twenty-eight days;`
  line
  line `(b) detention up to twenty-eight days;`
  line
  line `(c) confinement to the lines up to twenty-eight days;`
  line
  line `(d) extra guards or duties;`
  line
  line `(e) deprivation of any acting rank provided such rank has not been held by him for more than two`
  line years;
  line
  line `(f) severe reprimand or reprimand;`
  line
  line `(g) deductions from his pay and allowances of any sum required to make good any loss or`
  line `damage occasioned by the offence for which he is punished.`
  line
  line `(2) If a group is being temporarily commanded by an officer of the rank of a Squadron Commander or`
  line `a Team Commander, such officer shall have full powers of a Commander as specified in sub-section (1).`
  line
  line `(3) Subject to the provisions of section 52, a Squadron Commander or a Team Commander`
  line `commanding a squadron or a team or any detachment shall have the power to proceed against a person`
  line `subject to this Act, other than an officer or an Assistant Commander, who is charged with an offence`
  line `under this Act and award such person to the extent prescribed, one or more of the punishments specified`
  line `in clauses (a) to (d) and (g) of sub-section (1) provided that the maximum limit of punishment awarded`
  line `under each of the clauses (a), (b) and (c) shall not exceed fourteen days.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (7710)
  sectionNo (52)
  orderNo 52
  title `Limit of punishments under section 51.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7710&sectionno=52&orderno=52&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_52_content:
  string
  line `(1) In the case of an award of two or more of the`
  line `punishments specified in clauses (a), (b), (c) and (d) of sub-section (1) of section 51, the punishments`
  line `specified in clause (c) or clause (d) shall take effect only at the end of the punishment specified in clause`
  line `(a) or clause (b).`
  line
  line `(2) When two or more of the punishments specified in the said clauses (a), (b) and (c) are awarded to`
  line `a person conjointly, or when already undergoing one or more of the said punishments, the whole extent of`
  line `the punishments shall not exceed in the aggregate fifty-six days.`
  line
  line `(3) The punishments specified in the said clauses (a), (b) and (c) shall not be awarded to any person`
  line `who is of the rank of Ranger Grade I or was, at the time of committing the offence for which he is`
  line `punished, or such rank.`
  line
  line `(4) The punishments specified in clause (f) of sub-section (1) of section 51 shall not be awarded to`
  line `any person below the rank of Ranger Grade I.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (7711)
  sectionNo (53)
  orderNo 53
  title `Punishment of officers of or below the rank of Squadron Commanders by officers not below the rank of Inspectors-General.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7711&sectionno=53&orderno=53&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_53_content:
  string
  line `An officer not below the rank of an Inspector-General may, in the`
  line `prescribed manner, proceed against an officer of or below the rank of a Squadron Commander, who is`
  line `charged with an offence under this Act, and award one or more of the following punishments, that is to`
  line say,—
  line
  line `(a) forfeiture of seniority, or in the case of any of them whose promotion depends upon length of`
  line `service, forfeiture of service for the purpose of promotion for a period not exceeding one year, but`
  line `subject to the right of the accused previous to the award to elect to be tried by a General Security`
  line `Guard Court;`
  line
  line `(b) severe reprimand or reprimand;`
  line
  line `(c) deduction from pay and allowances of any sum required to make good any proved loss or`
  line `damage occasioned by the offence of which he is convicted.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (7712)
  sectionNo (54)
  orderNo 54
  title `Punishment of persons of the rank of Assistant Commander.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7712&sectionno=54&orderno=54&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_54_content:
  string
  line `(1) An officer not below the`
  line `rank of a Deputy Inspector-General may, in the prescribed manner, proceed against a person of the rank`
  line `of an Assistant Commander who is charged with an offence under this Act and award one or more of the`
  line `following punishments, that is to say,—`
  line
  line `(a) forfeiture of seniority, or in the case of any of them whose promotion depends upon the length`
  line `of service, forfeiture of service for the purpose of promotion for a period not exceeding one year, but`
  line `subject to the right of the accused previous to the award to elect to be tried by a General Security`
  line `Guard Court;`
  line
  line `(b) severe reprimand or reprimand;`
  line
  line `(c) deduction from pay and allowances of any sum required to make good any proved loss or`
  line `damage occasioned by the offence of which he is convicted.`
  line
  line `(2) An officer of the rank of a Group Commander may, in the prescribed manner, proceed against a`
  line `person of the rank of an Assistant Commander who is charged with an offence under this Act and award`
  line `any one or both of the following punishments, that is to say,—`
  line
  line `(a) severe reprimand or reprimand;`
  line
  line `(b) deduction from pay and allowances of any sum required to make good any proved loss or`
  line `damage occasioned by the offence of which he is convicted.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (7713)
  sectionNo (55)
  orderNo 55
  title `Custody of offenders.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7713&sectionno=55&orderno=55&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_55_content:
  string
  line `(1) Any person subject to this Act who is charged with an offence may`
  line `be taken into Security Guard custody, under the order of any superior officer.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), an officer may order into Security Guard`
  line `custody any other officer, though such other officer may be of a higher rank, engaged in a quarrel, affray`
  line `or disorder.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (7714)
  sectionNo (56)
  orderNo 56
  title `Duty of Commander in regard to detention.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7714&sectionno=56&orderno=56&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_56_content:
  string
  line `(1) It shall be the duty of every Commander to`
  line `take care that a person under his command when charged with an offence is not detained in custody for`
  line `more than forty-eight hours after the committal of such person into custody is reported to him, without the`
  line `charge being investigated, unless investigation within that period seems to him to be impracticable having`
  line `regard to the public service.`
  line
  line `(2) The case of every person being detained in custody beyond a period of forty-eight hours, and the`
  line `reasons therefor, shall be reported by the Commander to the next higher authority.`
  line
  line `(3) In reckoning the period of forty-eight hours specified in sub-section (1), Sundays and other public`
  line `holidays shall be excluded.`
  line
  line `(4) Subject to the provisions of this Act, the Central Government may make rules providing for the`
  line `manner in which and the period for which any person subject to this Act may be taken into and detained`
  line `in Security Guard custody, pending the trial by any competent authority for any offence committed by`
  line him
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (7715)
  sectionNo (57)
  orderNo 57
  title `Interval between committal and trial.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7715&sectionno=57&orderno=57&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_57_content:
  string
  line `In every case where any such person as is mentioned in`
  line `section 55 and as is not on active duty, remains in such custody for a longer period than eight days`
  line `without a Security Guard Court for his trial being convened, a special report giving reasons for the delay`
  line `shall be made by his Commander and a similar report shall be forwarded at intervals of every eight days`
  line `until a Security Guard Court is convened or such person is released from custody.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (7716)
  sectionNo (58)
  orderNo 58
  title `Arrest by civil authorities.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7716&sectionno=58&orderno=58&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_58_content:
  string
  line `Whenever any person subject to this Act, who is accused of an`
  line `offence under this Act, is within the jurisdiction of any Magistrate or police officer, such Magistrate or`
  line `police officer shall aid in the apprehension and delivery to Security Guard custody of such persons upon`
  line `receipt of a written application to that effect signed by his Commander or an officer authorised by the`
  line `Commander in that behalf.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (7717)
  sectionNo (59)
  orderNo 59
  title `Capture of deserters.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7717&sectionno=59&orderno=59&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_59_content:
  string
  line `(1) Whenever any person subject to this Act deserts, the Commander of`
  line `the unit to which he belongs, shall give information of the desertion to such civil authorities as, in his`
  line `opinion, may be able to afford assistance towards the capture of the deserter; and such authorities shall`
  line `thereupon take steps for the apprehension of the said deserter in like manner as if he were a person for`
  line `whose apprehension a warrant had been issued by a Magistrate, and shall deliver the deserter, when`
  line `apprehended, into Security Guard custody.`
  line
  line `(2) Any police officer may arrest without warrant any person reasonably believed to be subject to this`
  line `Act, and to be a deserter and shall bring him without delay before the nearest Magistrate, to be dealt with`
  line `according to law`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (7718)
  sectionNo (60)
  orderNo 60
  title `Inquiry into absence without leave.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7718&sectionno=60&orderno=60&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_60_content:
  string
  line `(1) When any person subject to this Act has been absent`
  line `from duty without due authority for a period of thirty days, a Court of inquiry shall, as soon as`
  line `practicable, be appointed by an officer not below the rank of a Group Commander under whose command`
  line `he is for the time being serving and such Court shall, on oath or affirmation administered in the prescribed`
  line `manner, inquire respecting the absence of the person, and the deficiency, if any, in the property of the`
  line `Government entrusted to his care, or in any arms, ammunition, equipment, instruments, clothing or`
  line `necessaries; and if satisfied of the fact of such absence without due authority or other sufficient cause, the`
  line `Court shall declare such absence and the period thereof and the said deficiency, if any, and transmit the`
  line `proceedings of the Court of inquiry to the officer who appointed the court of inquiry, for further action.`
  line
  line `(2) If the person declared absent does not afterwards surrender or is not apprehended, he shall, for the`
  line `purposes of this Act, be deemed to be a deserter.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (7719)
  sectionNo (61)
  orderNo 61
  title `Kinds of security Guard Courts.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7719&sectionno=61&orderno=61&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_61_content:
  string
  line `For the purposes of this Act there shall be three kinds of`
  line `Security Guard Courts, that is to say,—`
  line
  line `(a) General Security Guard Courts;`
  line
  line `(b) Petty Security Guard Courts; and`
  line
  line `(c) Summary Security Guard Courts.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (7720)
  sectionNo (62)
  orderNo 62
  title `Power to convene General Security Guard Court.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7720&sectionno=62&orderno=62&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_62_content:
  string
  line `A General Security Guard Court may be`
  line `convened by the Central Government or the Director-General or by any officer empowered in this behalf`
  line `by warrant of the Director-General.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (7721)
  sectionNo (63)
  orderNo 63
  title `Power to convene a Petty Security Guard Court.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7721&sectionno=63&orderno=63&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_63_content:
  string
  line `A Petty Security Guard Court may be`
  line `convened by an officer having power to convene a General Security Guard Court or by an officer`
  line `empowered in this behalf by warrant of any such officer.`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (7722)
  sectionNo (64)
  orderNo 64
  title `Contents of warrants issued under sections 62 and 63.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7722&sectionno=64&orderno=64&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_64_content:
  string
  line `A warrant, issued under section 62 or`
  line `section 63 may contain such restrictions, reservations or conditions as the officer issuing it may think fit.`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (7723)
  sectionNo (65)
  orderNo 65
  title `Composition of General Security Guard Court.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7723&sectionno=65&orderno=65&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_65_content:
  string
  line `A General Security Guard Court shall consist`
  line `of not less than five officers.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (7724)
  sectionNo (66)
  orderNo 66
  title `Composition of a Petty Security Guard Court.`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7724&sectionno=66&orderno=66&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_66_content:
  string
  line `A Petty Security Guard Court shall consist of`
  line `not less than three officers.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (7725)
  sectionNo (67)
  orderNo 67
  title `Summary Security Guard Court.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7725&sectionno=67&orderno=67&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_67_content:
  string
  line `(1) A Summary Security Guard Court may be held by the`
  line `Commander of any unit of the Security Guard and he alone shall constitute the Court.`
  line
  line `(2) The proceedings shall be attended throughout by two other persons who shall be officers or`
  line `Assistant Commanders or one of either, and who shall not as such, be sworn or affirmed:`
  line
  line `Provided that the persons attending the Court for the trial of an officer shall not be of a rank lower`
  line `than the rank of that officer unless in the opinion of the convening officer recorded in the convening`
  line `order, officers of such rank are not, having due regard to the exigencies of public service, available.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (7726)
  sectionNo (68)
  orderNo 68
  title `Dissolution of a Security Guard Court.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7726&sectionno=68&orderno=68&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_68_content:
  string
  line `(1) If a Security Guard Court after the commencement`
  line `of a trial is reduced below the minimum number of officers required by this Act, it shall be dissolved.`
  line
  line `(2) If, on account of the illness of the concerned Judge Attorney or, as the case may be, Deputy Judge`
  line `Attorney-General or Additional Judge Attorney-General or of the accused before the finding, it is`
  line `impossible to continue the trial, a Security Guard Court shall be dissolved.`
  line
  line `(3) The authority or officer who convened a Security Guard Court may dissolve the same if it appears`
  line `to it or him that the exigencies of the service or necessities of discipline render it impossible or`
  line `inexpedient to continue the said Security Guard Court.`
  line
  line `(4) Where a Security Guard Court is dissolved under this section, the accused may be tried again.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (7727)
  sectionNo (69)
  orderNo 69
  title `Powers of a General Security Guard Court.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7727&sectionno=69&orderno=69&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_69_content:
  string
  line `A General Security Guard Court shall have the`
  line `power to try any person subject to this Act for any offence punishable thereunder and to pass any`
  line `sentence authorised thereby.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (7728)
  sectionNo (70)
  orderNo 70
  title `Powers of a Petty Security Guard Court.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7728&sectionno=70&orderno=70&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_70_content:
  string
  line `A Petty Security Guard Court shall have the power`
  line `to try any person subject to this Act other than an officer or an Assistant Commander for any offence`
  line `made punishable thereunder and to pass any sentence authorised by this Act other than a sentence of`
  line `death, or imprisonment for a term exceeding two years.`
obj_root_law_sections_70_footnotes:
  string
  line
obj_root_law_sections_71:
  sectionId (7729)
  sectionNo (71)
  orderNo 71
  title `Powers of a Summary Security Guard Court.`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7729&sectionno=71&orderno=71&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_71_content:
  string
  line `(1) Subject to the provisions of sub-section (2),`
  line `a Summary Security Guard Court may try any offence punishable under this Act.`
  line
  line `(2) When there is no grave reason for immediate action a reference can, without detriment to`
  line `discipline, be made to the officer empowered to convene a Petty Security Force Court for the trial of the`
  line `alleged offender, an officer holding a Summary Security Guard Court shall not try without such reference`
  line `any offence punishable under any of the sections 15, 17 and 45, or any offence against the officer holding`
  line `the Court.`
  line
  line `(3) A Summary Security Guard Court may try any person subject to this Act and under the command`
  line `of the officer holding the Court, except an officer, or an Assistant Commander.`
  line
  line `(4) A Summary Security Guard Court may pass any sentence which may be passed under this Act,`
  line `except the sentence of death or of imprisonment for a term exceeding the limit specified in`
  line `sub-section (5).`
  line
  line `(5) The limit referred to in sub-section (4) shall be,—`
  line
  line `(a) one year, if the officer holding the Security Guard Court holds the rank not below that of a`
  line `Group Commander;`
  line
  line `(b) three months, in any other case.`
obj_root_law_sections_71_footnotes:
  string
  line
obj_root_law_sections_72:
  sectionId (7730)
  sectionNo (72)
  orderNo 72
  title `Prohibition of second trial.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7730&sectionno=72&orderno=72&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_72_content:
  string
  line `(1) When any person subject to this Act has been acquitted or`
  line `convicted of an offence by a Security Guard Court or by a Criminal Court or has been dealt with under`
  line `section 51 or section 53 or section 54, he shall not be liable to be tried again for the same offence by a`
  line `Security Guard Court or dealt with under the said sections.`
  line
  line `(2) When any person subject to this Act, has been acquitted or convicted of an offence by a Security`
  line `Guard Court or has been dealt with under section 51 or section 53 or section 54, he shall not be liable to`
  line `be tried again by a Criminal Court for the same offence or on the same facts.`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (7731)
  sectionNo (73)
  orderNo 73
  title `Period of limitation for trial.`
  content obj_root_law_sections_73_content
  footnotes obj_root_law_sections_73_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7731&sectionno=73&orderno=73&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_73_content:
  string
  line `(1) Except as provided by sub-section (2), no trial by a Security`
  line `Guard Court of any person subject to this Act for any offence shall be commenced after the expiration of`
  line `a period of three years from the date of such offence.`
  line
  line `(2) The provisions of sub-section (1) shall not apply to a trial for an offence of desertion or for any of`
  line `the offences mentioned in section 17.`
  line
  line `(3) In the computation of the period of time mentioned in sub-section (1), any time spent by such`
  line `person in evading arrest after the commission of the offence, shall be excluded,`
obj_root_law_sections_73_footnotes:
  string
  line
obj_root_law_sections_74:
  sectionId (7732)
  sectionNo (74)
  orderNo 74
  title `Trial, etc., of offender who ceases to be subject to this Act.`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7732&sectionno=74&orderno=74&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_74_content:
  string
  line `(1) Where an offence under this`
  line `Act had been committed by any person while subject to this Act, and he has ceased to be so subject, he`
  line `may be taken into and kept in Security Guard custody and tried and punished for such offence as if he`
  line `continued to be so subject.`
  line
  line `(2) No such person shall be tried for an offence, unless his trial commences within six months after he`
  line `had ceased to be subject to this Act;`
  line
  line `Provided that nothing contained in this sub-section shall apply to the trial of any such person for an`
  line `offence of desertion or for any of the offences mentioned in section 17 or shall affect the jurisdiction of a`
  line `criminal court to try any offence triable by such Court as well as by a Security Guard Court.`
obj_root_law_sections_74_footnotes:
  string
  line
obj_root_law_sections_75:
  sectionId (7733)
  sectionNo (75)
  orderNo 75
  title `Application of Act during term of sentence.`
  content obj_root_law_sections_75_content
  footnotes obj_root_law_sections_75_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7733&sectionno=75&orderno=75&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_75_content:
  string
  line `(1) When a person subject to this Act is`
  line `sentenced by a Security Guard Court to imprisonment, this Act shall apply to him during the term of his`
  line `sentence, though he is dismissed from the Security Guard, or has otherwise ceased to be subject to this`
  line `Act, and he may be kept, removed, imprisoned and punished as if he continued to be subject to this Act.`
  line
  line `(2) When a person subject to this Act is sentenced by a Security Guard Court to death, this Act shall`
  line `apply to him till the sentence is carried out.`
obj_root_law_sections_75_footnotes:
  string
  line
obj_root_law_sections_76:
  sectionId (7734)
  sectionNo (76)
  orderNo 76
  title `Place of trial.`
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7734&sectionno=76&orderno=76&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_76_content:
  string
  line `Any person subject to this Act who commits any offence against it may be tried`
  line `and punished for such offence in any place whatever.`
obj_root_law_sections_76_footnotes:
  string
  line
obj_root_law_sections_77:
  sectionId (7735)
  sectionNo (77)
  orderNo 77
  title `Choice between Criminal Court and Security Guard Court.`
  content obj_root_law_sections_77_content
  footnotes obj_root_law_sections_77_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7735&sectionno=77&orderno=77&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_77_content:
  string
  line `When a Criminal Court and a`
  line `Security Guard Court have each jurisdiction in respect of an offence, it shall be in the discretion of the`
  line `Director-General, or the Inspector-General or the Deputy Inspector-General, within whose command the`
  line `accused person is serving or such other officer as may be prescribed, to decide before which Court the`
  line `proceedings shall be instituted, and, if that officer decides that they shall be instituted before a Security`
  line `Guard Court, to direct that the accused person shall be detained in Security Guard custody.`
obj_root_law_sections_77_footnotes:
  string
  line
obj_root_law_sections_78:
  sectionId (7736)
  sectionNo (78)
  orderNo 78
  title `Power of criminal court to require delivery of offender.`
  content obj_root_law_sections_78_content
  footnotes obj_root_law_sections_78_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7736&sectionno=78&orderno=78&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_78_content:
  string
  line `(1) When a Criminal Court having`
  line `jurisdiction is of the opinion that proceedings shall be instituted before itself in respect of any alleged`
  line `offence, it may, by written notice, require the officer referred to in section 77 at his option, either to`
  line `deliver over the offender to the nearest Magistrate to be proceeded against according to law, or to`
  line `postpone proceedings, pending a reference to the Central Government.`
  line
  line `(2) In every such case, the said officer shall either deliver over the offender in compliance with the`
  line `requisition, or shall forthwith refer the question as to the Court before which the proceedings are to be`
  line `instituted, for the determination of the Central Government whose order upon such reference shall be`
  line final.
obj_root_law_sections_78_footnotes:
  string
  line
obj_root_law_sections_79:
  sectionId (7737)
  sectionNo (79)
  orderNo 79
  title `Presiding officer.`
  content obj_root_law_sections_79_content
  footnotes obj_root_law_sections_79_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7737&sectionno=79&orderno=79&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_79_content:
  string
  line `At every General Security Guard Court or Petty Security Guard Court, the`
  line `senior member shall be the presiding officer.`
obj_root_law_sections_79_footnotes:
  string
  line
obj_root_law_sections_80:
  sectionId (7738)
  sectionNo (80)
  orderNo 80
  title `Judge Attorneys, etc.`
  content obj_root_law_sections_80_content
  footnotes obj_root_law_sections_80_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7738&sectionno=80&orderno=80&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_80_content:
  string
  line `Every General Security Guard Court shall, and every Petty Security`
  line `Guard Court may, be attended by a Judge Attorney or a Deputy Judge Attorney-General or an Additional`
  line `Judge Attorney-General, or, if no such officer is available, an officer approved by the Judge`
  line `Attorney-General or by any officer authorised in this behalf by the Judge Attorney-General.`
obj_root_law_sections_80_footnotes:
  string
  line
obj_root_law_sections_81:
  sectionId (7739)
  sectionNo (81)
  orderNo 81
  title Challenges.
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7739&sectionno=81&orderno=81&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_81_content:
  string
  line `(1) At all trials by a General Security Guard Court or by a Petty Security Guard`
  line `Court, as soon as the Court is assembled, the names of the presiding officer and members shall be read`
  line `over to the accused, who shall thereupon be asked whether he objects to being tried by any officer, sitting`
  line `on the Court.`
  line
  line `(2) If the accused objects to such officer, his objection and also the reply thereto of the officer`
  line `objected to shall be heard and recorded, and the remaining officers of the Court shall, in the absence of`
  line `the challenged officer, decide on the objection.`
  line
  line `(3) If the objection is allowed by one half or more of the votes of the officers entitled to vote, the`
  line `objection shall be allowed, and the member objected to shall retire, and his vacancy may be filled in the`
  line `prescribed manner, by another officer subject to the same right of the accused to object.`
  line
  line `(4) When no challenge is made, or when a challenge has been made and disallowed, or the place of`
  line `every officer successfully challenged has been filled by another officer to whom no objection is made or`
  line `allowed, the Court shall proceed with the trial.`
obj_root_law_sections_81_footnotes:
  string
  line
obj_root_law_sections_82:
  sectionId (7740)
  sectionNo (82)
  orderNo 82
  title `Oaths of members, Judge Attorney and witness.`
  content obj_root_law_sections_82_content
  footnotes obj_root_law_sections_82_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7740&sectionno=82&orderno=82&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_82_content:
  string
  line `(1) An oath or affirmation in the prescribed`
  line `manner shall be administered to every member of every Security Guard Court and to the Judge Attorney,`
  line `or, as the case may be, the Deputy Judge Attorney-General or the Additional Judge Attorney-General or`
  line `the officer approved under section 80, before the commencement of the trial.`
  line
  line `(2) Every person giving evidence before a Security Guard Court shall be examined after being duly`
  line `sworn or affirmed in the prescribed form.`
  line
  line `(3) The provisions of sub-section (2) shall not apply where the witness is a child under twelve years`
  line `of age and the Security Guard Court is of the opinion that though the witness understands the duty of`
  line `speaking the truth, he does not understand the nature of an oath or affirmation.`
obj_root_law_sections_82_footnotes:
  string
  line
obj_root_law_sections_83:
  sectionId (7741)
  sectionNo (83)
  orderNo 83
  title `Voting by members.`
  content obj_root_law_sections_83_content
  footnotes obj_root_law_sections_83_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7741&sectionno=83&orderno=83&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_83_content:
  string
  line `(1) Subject to the provisions of sub-sections (2) and (3), every decision of`
  line `a Security Guard Court shall be passed by an absolute majority of votes; and where there is an equality of`
  line `votes on either the finding or the sentence, the decision shall be in favour of the accused.`
  line
  line `(2) No sentence of death shall be passed by a General Security Guard Court without the concurrence`
  line `of at least two-thirds of the members of the Court.`
  line
  line `(3) In matters, other than a challenge or the finding or sentence, the presiding officer shall have a`
  line `casting vote.`
obj_root_law_sections_83_footnotes:
  string
  line
obj_root_law_sections_84:
  sectionId (7742)
  sectionNo (84)
  orderNo 84
  title `General rule as to evidence.`
  content obj_root_law_sections_84_content
  footnotes obj_root_law_sections_84_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7742&sectionno=84&orderno=84&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_84_content:
  string
  line `The Indian Evidence Act, 1872, (1 of 1872) shall, subject to the`
  line `provisions of this Act, apply to all proceedings before a Security Guard Court.`
obj_root_law_sections_84_footnotes:
  string
  line
obj_root_law_sections_85:
  sectionId (7743)
  sectionNo (85)
  orderNo 85
  title `Judicial notice.`
  content obj_root_law_sections_85_content
  footnotes obj_root_law_sections_85_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7743&sectionno=85&orderno=85&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_85_content:
  string
  line `A Security Guard Court may take judicial notice of any matter within the`
  line `general knowledge of the members as officers of the Security Guard.`
obj_root_law_sections_85_footnotes:
  string
  line
obj_root_law_sections_86:
  sectionId (7744)
  sectionNo (86)
  orderNo 86
  title `Summoning witnesses.`
  content obj_root_law_sections_86_content
  footnotes obj_root_law_sections_86_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7744&sectionno=86&orderno=86&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_86_content:
  string
  line `(1) The convening officer, the presiding officer of a Security Guard`
  line `Court, the Judge Attorney or, as the case may be, the Deputy Judge Attorney-General or the Additional`
  line `Judge Attorney-General or the officer approved under section 80 or the Commander of the accused`
  line `person may, by summons under his hand, require the attendance, at a time and place to be mentioned in`
  line `the summons, of any person either to give evidence or to produce any document or other thing.`
  line
  line `(2) In the case of a witness who is subject to this Act, the summons shall be sent to his Commander`
  line `and such officer shall serve it upon him accordingly.`
  line
  line `(3) In the case of any other witness, the summons shall be sent to the Magistrate within whose`
  line `jurisdiction he may be, or resides, and such Magistrate shall give effect to the summons as if the witness`
  line `was required in the Court of such a Magistrate.`
  line
  line `(4) When a witness is required to produce any particular document or other thing in his possession or`
  line `power, the summons shall describe it with reasonable precision.`
obj_root_law_sections_86_footnotes:
  string
  line
obj_root_law_sections_87:
  sectionId (7745)
  sectionNo (87)
  orderNo 87
  title `Documents exempted from production.`
  content obj_root_law_sections_87_content
  footnotes obj_root_law_sections_87_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7745&sectionno=87&orderno=87&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_87_content:
  string
  line `(1) Nothing in section 86 shall be deemed to effect`
  line `the operation of sections 123 and 124 of the Indian Evidence Act, 1872 (1 of 1872) or to apply to any`
  line `letter, postcard, telegram or other document in the custody of the postal or telegraph authorities.`
  line
  line `(2) If any document in such custody is, in the opinion of any District Magistrate, Chief Judicial`
  line `Magistrate, Court of Session on High Court wanted for the purpose of any Security Guard Court, such`
  line `Magistrate or Court may require the postal or telegraph authorities, as the case may be, to deliver such`
  line `document to such person as such Magistrate or Court may direct.`
  line
  line `(3) If any such document is, in the opinion of any other Magistrate or of any Commissioner of Police`
  line `or District Superintendent of Police, wanted for any such purpose, he may require the postal or telegraph`
  line `authorities, as the case may be, to cause such search to be made for, and to detain such document pending`
  line `the order of any such District Magistrate, Chief Judicial Magistrate, Court of Session or High Court.`
obj_root_law_sections_87_footnotes:
  string
  line
obj_root_law_sections_88:
  sectionId (7746)
  sectionNo (88)
  orderNo 88
  title `Commissions for examination of witnesses.`
  content obj_root_law_sections_88_content
  footnotes obj_root_law_sections_88_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7746&sectionno=88&orderno=88&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_88_content:
  string
  line `(1) Whenever, in the course of a trial by a`
  line `Security Guard Court, it appears to the Court that the examination of a witness is necessary for the ends`
  line `of justice, and that the attendance of such witness cannot be procured without an amount of delay,`
  line `expense or inconvenience which, in the circumstances of the case, would be unreasonable, such Court`
  line `may address the Judge Attorney-General in order that a commission to take the evidence of such witness`
  line `may be issued.`
  line
  line `(2) The Judge Attorney-General may then if he thinks necessary, issue a commission to any Chief`
  line `Judicial Magistrate or Magistrate of the first class, within the local limits of whose jurisdiction such`
  line `witness resides, to take the evidence of such witness.`
  line
  line `(3) The Magistrate or officer to whom the commission is issued, or, if he is the Chief Judicial`
  line `Magistrate, he or such Magistrate of the first class as he appoints in this behalf, shall proceed to the place`
  line `where the witness is, or shall summon the witness before him and shall take down his evidence in the`
  line `same manner, and may for this purpose exercise the same powers, as in the trials of warrant-cases under`
  line `the Code of Criminal Procedure, 1973 (2 of 1974).`
  line
  line `(4) When the witness resides in a tribal area or in any place outside India, the commission may be`
  line `issued in the manner specified in Chapter XXIII-B of the Code of Criminal Procedure, 1973 (2 of 1974).`
obj_root_law_sections_88_footnotes:
  string
  line
obj_root_law_sections_89:
  sectionId (7747)
  sectionNo (89)
  orderNo 89
  title `Examination of witness on commission.`
  content obj_root_law_sections_89_content
  footnotes obj_root_law_sections_89_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7747&sectionno=89&orderno=89&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_89_content:
  string
  line `(1) The prosecutor and accused person in any case in`
  line `which a commission is issued under section 88 may respectively forward any interrogatories in writing`
  line `which the Court may think relevant to the issue, and the Magistrate or officer executing the commission`
  line `shall examine the witness upon such interrogatories.`
  line
  line `(2) The prosecutor and the accused person may appear before such Magistrate or officer by counsel,`
  line `or, except in the case of an accused person in custody, in person, and may examine, cross-examine and`
  line `re-examine, as the case may be, the said witness.`
  line
  line `(3) After a commission issued under section 88 has been duly executed, it shall be returned, together`
  line `with the deposition of the witness examined thereunder, to the Judge, Attorney-General.`
  line
  line `(4) On receipt of a commission, and deposition returned under sub-section (3), the Judge`
  line `Attorney-General shall forward the same to the Court at whose instance the commission was issued or, if`
  line `such Court has been dissolved, to any other Court conveaned for the trial of the accused person; and the`
  line `commission, the return thereto and the deposition shall be open to inspection by the prosecutor and the`
  line `accused person, and may, subject to all just exceptions, be read in evidence in the case by either the`
  line `prosecutor or the accused and shall form part of the proceedings of the Court.`
  line
  line `(5) In every case in which a commission is issued under section 88, the trial may be adjourned for`
  line `specified time reasonably sufficient for the execution and return of the commission.`
obj_root_law_sections_89_footnotes:
  string
  line
obj_root_law_sections_90:
  sectionId (7748)
  sectionNo (90)
  orderNo 90
  title `Conviction of offence not charged.`
  content obj_root_law_sections_90_content
  footnotes obj_root_law_sections_90_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7748&sectionno=90&orderno=90&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_90_content:
  string
  line `A person charged before a Security Guard Court,—`
  line
  line `(a) with desertion may be found guilty of attempting to desert or of being absent without leave;`
  line
  line `(b) with attempting to desert may be found guilty of being absent without leave;`
  line
  line `(c) with using criminal force may be found guilty of assault;`
  line
  line `(d) with using threatening language may be found guilty of using insubordinate language;`
  line
  line `(e) with any one of the offences specified in clauses (a), (b), (c) and (d) of section 29 may be`
  line `found guilty of any other of these offences with which he might have been charged;`
  line
  line `(f) with an offence punishable under section 45 may be found guilty of any other`
  line `offence of which he might have been found guilty, if the provisions of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974), were applicable;`
  line
  line `(g) with any offence under this Act may, on failure of proof of an offence having been committed`
  line `in circumstances involving a more severe punishment, be found guilty of the same offence as having`
  line `been committed in circumstances involving a less severe punishment;`
  line
  line `(h) with any offence under this Act may be found guilty of having attempted or abetted the`
  line `commission of that offence, although the attempt or abetment is not separately charged.`
obj_root_law_sections_90_footnotes:
  string
  line
obj_root_law_sections_91:
  sectionId (7749)
  sectionNo (91)
  orderNo 91
  title `Presumption as to signatures.`
  content obj_root_law_sections_91_content
  footnotes obj_root_law_sections_91_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7749&sectionno=91&orderno=91&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_91_content:
  string
  line `In any proceeding under this Act, any application, certificate,`
  line `warrant, reply or other document purporting to be signed by an officer in the service of the Government`
  line `shall, on production, be presumed to have been duly signed by the person by whom and in the character in`
  line `which it purports to have been signed, until the contrary is shown.`
obj_root_law_sections_91_footnotes:
  string
  line
obj_root_law_sections_92:
  sectionId (7750)
  sectionNo (92)
  orderNo 92
  title `Appointment paper.`
  content obj_root_law_sections_92_content
  footnotes obj_root_law_sections_92_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7750&sectionno=92&orderno=92&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_92_content:
  string
  line `(1) Any appointment paper purporting to be signed by an appointing`
  line `authority shall, in proceedings under this Act, be evidence of the person appointed having given the`
  line `answers to questions which he is therein represented as having given.`
  line
  line `(2) The appointment of such person may be proved by the production of the original or a copy of his`
  line `appointment paper purporting to be certified to be a true copy by the officer having the custody of the`
  line `appointment paper.`
obj_root_law_sections_92_footnotes:
  string
  line
obj_root_law_sections_93:
  sectionId (7751)
  sectionNo (93)
  orderNo 93
  title `Presumption as to certain documents.`
  content obj_root_law_sections_93_content
  footnotes obj_root_law_sections_93_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7751&sectionno=93&orderno=93&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_93_content:
  string
  line `(1) A letter, return or other document respecting the`
  line `service of any person in, or the dismissal or discharge of any person from, any unit of the Security Guard,`
  line `or respecting the circumstances of any person not having served in, or belonged to, any unit of the`
  line `Security Guard, if purporting to be signed by or on behalf of the Central Government or the`
  line `Director-General, or by any other competent authority, shall be evidence of the facts stated in such letter,`
  line `return or other document.`
  line
  line `(2) A National Security Guard List or Gazette purporting to be published by authority shall be`
  line `evidence of the status and rank of the officers and Assistant Commanders therein mentioned, and of any`
  line `appointment held by them and of the group, unit or branch of the Security Guard to which they belong.`
  line
  line `(3) Where a record is made in any unit book in pursuance of this Act or of any rules or otherwise in`
  line `the discharge of official duties, and purports to be signed by the Commander or by the officer whose duty`
  line `it is to make such record, such record shall be evidence of the facts therein stated.`
  line
  line `(4) A copy of any record in any unit book purporting to be certified to be a true copy by the officer`
  line `having custody of such book shall be evidence of such record.`
  line
  line `(5) Where any person subject to this Act is being tried on a charge of desertion or of absence without`
  line `leave, and such person has surrendered himself into the custody of any officer or other person subject to`
  line `this Act, or any unit of the Security Guard, or has been apprehended by such officer or person, a`
  line `certificate purporting to be signed by such officer, or by the Commander of the unit to which such person`
  line `belongs, as the case may be, and stating the fact, date and place of such surrender or apprehension, and`
  line `the manner in which he was dressed, shall be evidence of the matters so stated.`
  line
  line `(6) Where any person subject to this Act is being tried on a charge of desertion or of absence without`
  line `leave and such person has surrendered himself into the custody of, or has been apprehended by, a police`
  line `officer not below the rank of an officer in charge of a police station, a certificate purporting to be signed`
  line `by such police officer and stating the fact, date and place of such surrender or apprehension and the`
  line `manner in which he was dressed shall be evidence of the matters so stated.`
  line
  line `(7) (a) Any document purporting to be a report under the hand of a Government scientific expert to`
  line `whom this sub-section applies, upon any matter or thing duly submitted to him for examination or`
  line `analysis and report in the course of any proceeding under this Act, may be used as evidence in any`
  line `inquiry, trial or other proceeding under this Act.`
  line
  line `(b) The Security Guard Court may, if it thinks fit, summon and examine any such expert as to the`
  line `subject matter of his report.`
  line
  line `(c) Where any such expert is summoned by a Security Guard Court and he is unable to attend`
  line `personally, he may, unless the Court has expressly directed him to appear personally depute any`
  line `responsible person working with him to attend the Court if such officer is conversant with the facts of the`
  line `case and can satisfactorily depose in the Court on his behalf.`
  line
  line `(d) This sub-section applies to the Government scientific experts, for the time being specified in`
  line `sub-section (4) of section 293 of the Code of Criminal Procedure, 1973 (2 of 1974).`
obj_root_law_sections_93_footnotes:
  string
  line
obj_root_law_sections_94:
  sectionId (7752)
  sectionNo (94)
  orderNo 94
  title `Reference by accused to Government officer.`
  content obj_root_law_sections_94_content
  footnotes obj_root_law_sections_94_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7752&sectionno=94&orderno=94&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_94_content:
  string
  line `(1) If at any trial for desertion or absence`
  line `without leave, over-staying leave or not rejoining when warned for service, the accused person states in`
  line `his defence any sufficient or reasonable excuse for his unauthorised absence, and refers in support thereof`
  line `to any officer in the service of the Government, or if it appears that any such officer is likely to prove or`
  line `disprove the said statement in the defence, the Court shall address such officer and adjourn the`
  line `proceedings until his reply is received.`
  line
  line `(2) The written reply of any officer so referred to shall, if signed by him, be received in evidence and`
  line `have the same effect as if made on oath before the Court.`
  line
  line `(3) If the Court is dissolved before the receipt of such reply or if the Court omits to comply with the`
  line `provisions of this section, the convening officer may, at his discretion, annul the proceedings and order a`
  line `fresh trial.`
obj_root_law_sections_94_footnotes:
  string
  line
obj_root_law_sections_95:
  sectionId (7753)
  sectionNo (95)
  orderNo 95
  title `Evidence of previous convictions and general character.`
  content obj_root_law_sections_95_content
  footnotes obj_root_law_sections_95_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7753&sectionno=95&orderno=95&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_95_content:
  string
  line `(1) When any person subject to this`
  line `Act has been convicted by a Security Guard Court of any offence, such Security Guard Court may inquire`
  line `into and receive and record evidence of any previous convictions of such person, either by a Security`
  line `Guard Court or by a Criminal Court, or any previous award of punishment under section 51 or section 53`
  line `or section 54 and may further inquire into and record the general character of such person and such other`
  line `matters as may be prescribed.`
  line
  line `(2) The evidence received under this section may be either oral, or in the shape of entries in, or`
  line `certified extracts from, books of Security Guard Courts or other official records; and it shall not be`
  line `necessary to give notice before trial to the person tried that evidence as to his previous convictions or`
  line `character will be received.`
  line
  line `(3) At a Summary Security Guard Court, the officer holding the trial may, if he thinks fit, record any`
  line `previous convictions against the offender, his general character, and such other matters as may be`
  line `prescribed, as of his own knowledge, instead of requiring them to be proved under the foregoing`
  line `provisions of this section.`
obj_root_law_sections_95_footnotes:
  string
  line
obj_root_law_sections_96:
  sectionId (7754)
  sectionNo (96)
  orderNo 96
  title `Lunacy of accused.`
  content obj_root_law_sections_96_content
  footnotes obj_root_law_sections_96_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7754&sectionno=96&orderno=96&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_96_content:
  string
  line `(1) Whenever, in the course of a trial by a Security Guard Court, it appears`
  line `to the Court that the person charged is by reason of unsoundness of mind incapable of making his`
  line `defence, or that he committed the act alleged but was by reason of unsoundness of mind incapable of`
  line `knowing the nature of the Act or knowing that it was wrong or contrary to Law, the Court shall record a`
  line `finding accordingly.`
  line
  line `(2) The presiding officer of the Court, or, in the case of a Summary Security Guard Court, the officer`
  line `holding the trial, shall forthwith report the case to the confirming officer, or to the authority empowered`
  line `to deal with its finding under section 111, as the case may be.`
  line
  line `(3) The confirming officer to whom the case is reported under sub-section (2) may, if he does not`
  line `confirm the finding, take steps to have the accused person tried by the same or another Security Guard`
  line `Court for the offence with which he was charged.`
  line
  line `(4) The authority to whom the finding of a Summary Security Guard Court is reported under`
  line `sub-section (2), and a confirming officer confirming the finding in any case so reported to him shall order`
  line `the accused person to be kept in custody in the prescribed manner and shall report the case for the orders`
  line `of the Central Government.`
  line
  line `(5) On receipt of a report under sub-section (4), the Central Government may order the accused`
  line `person to be detained in a lunatic asylum or other suitable place of safe custody.`
obj_root_law_sections_96_footnotes:
  string
  line
obj_root_law_sections_97:
  sectionId (7755)
  sectionNo (97)
  orderNo 97
  title `Subsequent fitness of lunatic accused for trial.`
  content obj_root_law_sections_97_content
  footnotes obj_root_law_sections_97_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7755&sectionno=97&orderno=97&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_97_content:
  string
  line `Where any accused person, having been found`
  line `by reason of unsoundness of mind to be incapable of making his defence, is in custody or under detention`
  line `under section 96, any officer prescribed in this behalf, may—`
  line
  line `(a) if such person is in custody under sub-section (4) of section 96, on the report of a medical`
  line `officer that he is capable of making his defence, or`
  line
  line `(b) if such person is detained in a jail under sub-section (5) of section 96, on a certificate of the`
  line `Inspector-General of Prisons, and if such person is detained in a lunatic asylum under the said`
  line `sub-section, on a certificate of any two or more of the visitors of such asylum and if he is detained in`
  line `any other place under that sub-section, on a certificate of the prescribed authority, that he is capable`
  line `of making his defence,`
  line
  line `take steps to have such person tried by the same or another Security Guard Court for the offence with`
  line `which he was originally charged or, if the offence is a civil offence, by a Criminal Court.`
obj_root_law_sections_97_footnotes:
  string
  line
obj_root_law_sections_98:
  sectionId (7756)
  sectionNo (98)
  orderNo 98
  title `Transmission to Central Government of orders under section 97.`
  content obj_root_law_sections_98_content
  footnotes obj_root_law_sections_98_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7756&sectionno=98&orderno=98&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_98_content:
  string
  line `A copy of every order`
  line `made by an officer under section 97 for the trial of the accused shall forthwith be sent to the Central`
  line Government.
obj_root_law_sections_98_footnotes:
  string
  line
obj_root_law_sections_99:
  sectionId (7757)
  sectionNo (99)
  orderNo 99
  title `Release of lunatic accused.`
  content obj_root_law_sections_99_content
  footnotes obj_root_law_sections_99_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7757&sectionno=99&orderno=99&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_99_content:
  string
  line `Where any person is in custody under sub-section (4) of section 96`
  line `or under detention under sub-section (5) of that section,—`
  line
  line `(a) if such person is in custody under the said sub-section (4), on the report of a medical officer,`
  line or
  line
  line `(b) if such person is detained under the said sub-section (5), on a certificate from any of the`
  line `authorities mentioned in clause (b) of section 97 that in the judgment of such officer or authority such`
  line `person may be released without danger of his doing injury to himself or to any other person,`
  line
  line `the Central Government may order that such person be released or detained in custody, or transferred to a`
  line `public lunatic asylum if he has not already been sent to such an asylum.`
obj_root_law_sections_99_footnotes:
  string
  line
obj_root_law_sections_100:
  sectionId (7758)
  sectionNo (100)
  orderNo 100
  title `Delivery of lunatic accused to relatives.`
  content obj_root_law_sections_100_content
  footnotes obj_root_law_sections_100_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7758&sectionno=100&orderno=100&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_100_content:
  string
  line `Where any relative or friend of any person who is in`
  line `custody under sub-section (4) of section 96 of under detention under sub-section (5) of that section`
  line `desires that he should be delivered to his care and custody, the Central Government may, upon`
  line `application by such relative or friend and, on his giving security to the satisfaction of that Government`
  line `that the person delivered shall be properly taken care of, and, prevented from doing injury to himself or to`
  line `any other officer, and be produced for the inspection of such officer, and at such times and places, as the`
  line `Central Government may direct, order such person to be delivered to such relative or friend.`
obj_root_law_sections_100_footnotes:
  string
  line
obj_root_law_sections_101:
  sectionId (7759)
  sectionNo (101)
  orderNo 101
  title `Order for custody and disposal of property pending trial.`
  content obj_root_law_sections_101_content
  footnotes obj_root_law_sections_101_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7759&sectionno=101&orderno=101&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_101_content:
  string
  line `When any property regarding`
  line `which any offence appears to have been committed, or which appears to have been used for the`
  line `commission of any offence, is produced before a Security Guard Court during a trial, the Court may make`
  line `such order as it thinks fit for the proper custody of such property pending the conclusion of the trial, and`
  line `if the property is subject to speedy or natural decay may, after recording such evidence as it thinks`
  line `necessary, order it to be sold or otherwise disposed of.`
obj_root_law_sections_101_footnotes:
  string
  line
obj_root_law_sections_102:
  sectionId (7760)
  sectionNo (102)
  orderNo 102
  title `Order for disposal of property regarding which offence is committed.`
  content obj_root_law_sections_102_content
  footnotes obj_root_law_sections_102_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7760&sectionno=102&orderno=102&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_102_content:
  string
  line `(1) After the`
  line `conclusion of a trial before any Security Guard Court, the Court or the officer confirming the finding or`
  line `sentence of such Security Guard Court, or any authority superior to such officer, or in the case of a`
  line `Summary Security Guard Court whose finding or sentence does not require confirmation, an officer not`
  line `below the rank of a Deputy Inspector-General within whose command the trial was held, may make such`
  line `order as it or he thinks fit for the disposal by destruction, confiscation, delivery to any person claiming to`
  line `be entitled to possession thereof, or otherwise, of any property or document produced before the Court or`
  line `in its custody, or regarding which any offence appears to have been committed or which has been used for`
  line `the commission of any offence.`
  line
  line `(2) Where any order has been made under sub-section (1) in respect of property regarding which an`
  line `offence appears to have been committed, a copy of such order signed and certified by the authority`
  line `making the same may, whether the trial was held within India or not, be sent to a Magistrate within whose`
  line `jurisdiction such property for the time being is situated, and such Magistrate shall thereupon cause the`
  line `order to be carried into effect as if it were an order passed by him under the provisions of the Code of`
  line `Criminal Procedure, 1973 (2 of 1974).`
  line
  line `(3) In this section, the term "property" includes in the case of property regarding which an offence`
  line `appears to have been committed, not only such property as has been originally in the possession or under`
  line `the control of any person, but also any property into or for which the same may have been converted or`
  line `exchanged and anything acquired by such conversion or exchange whether immediately or otherwise.`
obj_root_law_sections_102_footnotes:
  string
  line
obj_root_law_sections_103:
  sectionId (7761)
  sectionNo (103)
  orderNo 103
  title `Powers of Security Guard Court in relation to proceedings under the Act.`
  content obj_root_law_sections_103_content
  footnotes obj_root_law_sections_103_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7761&sectionno=103&orderno=103&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_103_content:
  string
  line `Any trial by a`
  line `Security Guard Court under the provisions of this Act shall be deemed to be a judicial proceeding within`
  line `the meaning of sections 193 and 228 of the Indian Penal Code (45 of 1860) and the Security Guard Court`
  line `shall be deemed to be a Court within the meaning of sections 345 and 346 of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974).`
obj_root_law_sections_103_footnotes:
  string
  line
obj_root_law_sections_104:
  sectionId (7762)
  sectionNo (104)
  orderNo 104
  title `Finding and sentence not valid, unless confirmed.`
  content obj_root_law_sections_104_content
  footnotes obj_root_law_sections_104_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7762&sectionno=104&orderno=104&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_104_content:
  string
  line `No finding or sentence of a General`
  line `Security Guard Court or a Petty Security Guard Court shall be valid except so far as it may be confirmed`
  line `as provided by this Act.`
obj_root_law_sections_104_footnotes:
  string
  line
obj_root_law_sections_105:
  sectionId (7763)
  sectionNo (105)
  orderNo 105
  title `Power to confirm finding and sentence of General Security Guard Court`
  content obj_root_law_sections_105_content
  footnotes obj_root_law_sections_105_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=7763&sectionno=105&orderno=105&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_105_content:
  string
  line `The findings`
  line `and sentences of General Security Guard Courts may be confirmed by the Central Government or by any`
  line `officer empowered in this behalf by warrant of the Central Government.`
obj_root_law_sections_105_footnotes:
  string
  line
obj_root_law_sections_106:
  sectionId (27724)
  sectionNo (106)
  orderNo 106
  title `Power to confirm finding and sentence of Petty Security Guard Court.`
  content obj_root_law_sections_106_content
  footnotes obj_root_law_sections_106_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27724&sectionno=106&orderno=106&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_106_content:
  string
  line `The findings and`
  line `sentences of Petty Security Guard Courts may be confirmed by an authority or officer having power to`
  line `convene a General Security Guard Court or by any officer empowered in this behalf by warrant of such`
  line `authority or officer.`
obj_root_law_sections_106_footnotes:
  string
  line
obj_root_law_sections_107:
  sectionId (27725)
  sectionNo (107)
  orderNo 107
  title `Limitation of powers of confirming authority.`
  content obj_root_law_sections_107_content
  footnotes obj_root_law_sections_107_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27725&sectionno=107&orderno=107&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_107_content:
  string
  line `A warrant issued under section 105 or section`
  line `106 may contain such restrictions, reservations or conditions as the authority issuing it may think fit.`
obj_root_law_sections_107_footnotes:
  string
  line
obj_root_law_sections_108:
  sectionId (27726)
  sectionNo (108)
  orderNo 108
  title `Power of confirming authority to mitigate, remit or commute sentences`
  content obj_root_law_sections_108_content
  footnotes obj_root_law_sections_108_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27726&sectionno=108&orderno=108&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_108_content:
  string
  line `Subject to such`
  line `restrictions, reservations or conditions, as may be contained in any warrant issued under section 105 or`
  line `section 106, a confirming authority may, when confirming the sentence of a Security Guard Court,`
  line `mitigate or remit the punishment thereby awarded, or commute that punishment for any punishment or`
  line `punishments lower in the scale laid down in section 47 or may set aside the proceedings of the trial if`
  line `found to be illegal.`
obj_root_law_sections_108_footnotes:
  string
  line
obj_root_law_sections_109:
  sectionId (27727)
  sectionNo (109)
  orderNo 109
  title `Revision of finding or sentence`
  content obj_root_law_sections_109_content
  footnotes obj_root_law_sections_109_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27727&sectionno=109&orderno=109&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_109_content:
  string
  line `(1) Any finding or sentence of a Security Guard Court which`
  line `requires confirmation may be once revised by the order of the confirming authority and on such revision,`
  line `the Court, if so directed by the confirming authority, may take additional evidence.`
  line
  line `(2) The Court, on revision, shall consist of the same officers as were present when the original`
  line `decision was passed, unless any of those officers are unavoidably absent.`
  line
  line `(3) In case of such unavoidable absence the cause thereof shall be duly certified in the proceedings,`
  line `and the Court shall proceed with the revision, provided that, if a General Security Guard Court, it still`
  line `consists of five officers, or, if a Petty Security Guard Court, of three officers.`
obj_root_law_sections_109_footnotes:
  string
  line
obj_root_law_sections_110:
  sectionId (27728)
  sectionNo (110)
  orderNo 110
  title `Finding and sentence of a Summary Security Guard Court.`
  content obj_root_law_sections_110_content
  footnotes obj_root_law_sections_110_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27728&sectionno=110&orderno=110&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_110_content:
  string
  line `The finding and sentence of a`
  line `Summary Security Guard Court shall not require to be confirmed, but may be carried out forthwith.`
obj_root_law_sections_110_footnotes:
  string
  line
obj_root_law_sections_111:
  sectionId (27729)
  sectionNo (111)
  orderNo 111
  title `Transmission of proceedings of Summary Security Guard Court`
  content obj_root_law_sections_111_content
  footnotes obj_root_law_sections_111_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27729&sectionno=111&orderno=111&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_111_content:
  string
  line `The proceedings of`
  line `every Summary Security Guard Court shall, without delay, be forwarded to the officer not below the rank`
  line `of a Deputy Inspector-General within whose command the trial was held, or to the prescribed officer, and`
  line `such officer, or the Director-General or any officer empowered by him in this behalf may, for reasons`
  line `based on the merits of the case, but not on merely technical grounds, set aside the proceedings, or reduce`
  line `the sentence to any other sentence which the Court might have passed.`
obj_root_law_sections_111_footnotes:
  string
  line
obj_root_law_sections_112:
  sectionId (27730)
  sectionNo (112)
  orderNo 112
  title `Alteration of finding of sentence in certain cases.`
  content obj_root_law_sections_112_content
  footnotes obj_root_law_sections_112_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27730&sectionno=112&orderno=112&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_112_content:
  string
  line `(1) Where a finding of guilty by a Security`
  line `Guard Court, which has been confirmed or which does not require confirmation, is found for any reason`
  line `to be invalid or cannot be supported by the evidence, the authority which would have had power under`
  line `section 124 to commute the punishment awarded by the sentence, if the finding had been valid, may`
  line `substitute a new finding and pass a sentence for the offence specified or involved in such finding:`
  line
  line `Provided that no such substitution shall be made unless such findings could have been validly made`
  line `by the Security Guard Court on the charge and unless it appears that the Security Guard Court must have`
  line `been satisfied of the facts establishing the said offence.`
  line
  line `(2) Where a sentence passed by a Security Guard Court which has been confirmed, or which does not`
  line `require confirmation, not being a sentence passed in pursuance of a new finding substituted under`
  line `sub-section (1), is found for any reason to be invalid, the authority referred to in sub-section (1) may pass`
  line `a valid sentence.`
  line
  line `(3) The punishment awarded by a sentence passed under sub-section (1) or sub-section (2) shall not`
  line `be higher in the scale of punishments than, or in excess of, the punishment awarded by, the sentence for`
  line `which a new sentence is substituted under this section.`
  line
  line `(4) Any finding substituted, or any sentence passed under this section shall, for the purposes of this`
  line `Act and the rules, have effect as if it were a finding or sentence, as the case may be, of a Security Guard`
  line Court.
obj_root_law_sections_112_footnotes:
  string
  line
obj_root_law_sections_113:
  sectionId (27731)
  sectionNo (113)
  orderNo 113
  title `Remedy against order, finding or sentence of Security Guard Court.`
  content obj_root_law_sections_113_content
  footnotes obj_root_law_sections_113_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27731&sectionno=113&orderno=113&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_113_content:
  string
  line `(1) Any person`
  line `subject to this Act who considers himself aggrieved by any order passed by any Security Guard Court`
  line `may present a petition to the officer or authority empowered to confirm any finding or sentence of such`
  line `Security Guard Court, and the confirming authority may take such steps as may be considered necessary`
  line `to satisfy itself as to the correctness, legality or propriety of the order passed or as to the regularity of any`
  line `proceeding to which the order relates.`
  line
  line `(2) Any person subject to this Act who considers himself aggrieved by a finding or sentence of any`
  line `Security Guard Court which has been confirmed, may present a petition to the Central Government, the`
  line `Director-General, or any prescribed officer superior in command to the one who confirmed such finding`
  line `or sentence, and the Central Government, the Director-General, or the prescribed officer, as the case may`
  line `be, may pass such order thereon as it or he thinks fit.`
obj_root_law_sections_113_footnotes:
  string
  line
obj_root_law_sections_114:
  sectionId (27732)
  sectionNo (114)
  orderNo 114
  title `Annulment of proceedings.`
  content obj_root_law_sections_114_content
  footnotes obj_root_law_sections_114_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27732&sectionno=114&orderno=114&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_114_content:
  string
  line `The Central Government, the Director-General or an InspectorGeneral`
  line `may annul the proceedings of any Security Guard Court on the ground that they are illegal or`
  line unjust.
obj_root_law_sections_114_footnotes:
  string
  line
obj_root_law_sections_115:
  sectionId (27733)
  sectionNo (115)
  orderNo 115
  title `Form of sentence of death.`
  content obj_root_law_sections_115_content
  footnotes obj_root_law_sections_115_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27733&sectionno=115&orderno=115&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_115_content:
  string
  line `In awarding a sentence of death, a Security Guard Court shall, in`
  line `its discretion, direct that the offender shall suffer death by being hanged by the neck until he be dead, or`
  line `shall suffer death by being shot to death.`
obj_root_law_sections_115_footnotes:
  string
  line
obj_root_law_sections_116:
  sectionId (27734)
  sectionNo (116)
  orderNo 116
  title `Commencement of sentence of imprisonment`
  content obj_root_law_sections_116_content
  footnotes obj_root_law_sections_116_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27734&sectionno=116&orderno=116&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_116_content:
  string
  line `Whenever any person is sentenced by a`
  line `Security Guard Court under this Act to imprisonment, the term of his sentence shall, whether it has been`
  line `revised or not, be reckoned to commence on the day on which the original proceedings were signed by the`
  line `presiding officer, or in the case of a Summary Security Guard Court, by the Court:`
  line
  line `Provided that the period of detention or confinement, if any undergone by an accused person, during`
  line `the investigation, inquiry or trial of the case in which he is sentenced and before the date on which the`
  line `original proceedings were signed shall be set-off against the term of his sentence and the liability of such`
  line `person to undergo imprisonment shall be restricted to the remainder, if any of the term of his sentence.`
obj_root_law_sections_116_footnotes:
  string
  line
obj_root_law_sections_117:
  sectionId (27735)
  sectionNo (117)
  orderNo 117
  title `Execution of sentence of imprisonment.`
  content obj_root_law_sections_117_content
  footnotes obj_root_law_sections_117_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27735&sectionno=117&orderno=117&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_117_content:
  string
  line `(1) Whenever any sentence of imprisonment is`
  line `passed under this Act by a Security Guard Court or whenever any sentence of death is commuted to`
  line `imprisonment, the confirming officer, or in case of a Summary Security Guard Court the officer holding`
  line `the Court or such other officer as may be prescribed, shall, save as otherwise provided in sub-sections (3)`
  line `and (4), direct that the sentence shall be carried out by confinement in a civil prison.`
  line
  line `(2) When a direction has been made under sub-section (1), the Commander of the person under`
  line `sentence or such other officer as may be prescribed shall forward a warrant in the prescribed form to the`
  line `officer in charge of the prison in which such person is to be confined and shall arrange for his despatch to`
  line `such prison with the warrant.`
  line
  line `(3) In the case of a sentence of imprisonment for a period not exceeding three months and passed`
  line `under this Act by a Security Guard Court, the appropriate officer under sub-section (1) may direct that the`
  line `sentence shall be carried out by confinement in Security Guard custody instead of in a civil prison.`
  line
  line `(4) On active duty, a sentence of imprisonment may be carried out by confinement in such place as`
  line `the Deputy Inspector-General within whose command the person sentenced is serving or any prescribed`
  line `officer, may, from time to time, appoint.`
obj_root_law_sections_117_footnotes:
  string
  line
obj_root_law_sections_118:
  sectionId (27736)
  sectionNo (118)
  orderNo 118
  title `Temporary custody of offender.`
  content obj_root_law_sections_118_content
  footnotes obj_root_law_sections_118_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27736&sectionno=118&orderno=118&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_118_content:
  string
  line `Where a sentence of imprisonment is directed to be`
  line `undergone in a civil prison the offender may be kept in Security Guard custody or in any other fit place,`
  line `till such time as it is possible to send him to a civil prison.`
obj_root_law_sections_118_footnotes:
  string
  line
obj_root_law_sections_119:
  sectionId (27737)
  sectionNo (119)
  orderNo 119
  title `Execution of sentence of imprisonment in special cases`
  content obj_root_law_sections_119_content
  footnotes obj_root_law_sections_119_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27737&sectionno=119&orderno=119&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_119_content:
  string
  line `Whenever, in the opinion of an`
  line `officer not below the rank of a Deputy Inspector-General within whose command the trial is held, any`
  line `sentence or portion of a sentence of imprisonment cannot for special reasons, conveniently be carried out`
  line `in Security Guard custody in accordance with the provisions of section 117, such officer may direct that`
  line `such sentence or portion of sentence shall be carried out by confinement in any civil prison or other fit`
  line place.
obj_root_law_sections_119_footnotes:
  string
  line
obj_root_law_sections_120:
  sectionId (27738)
  sectionNo (120)
  orderNo 120
  title `Conveyance of prisoner from place to place.`
  content obj_root_law_sections_120_content
  footnotes obj_root_law_sections_120_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27738&sectionno=120&orderno=120&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_120_content:
  string
  line `A person under sentence of imprisonment may,`
  line `during his conveyance from place to place, or when on board a ship, aircraft, or otherwise, be subjected to`
  line `such restraint as is necessary for his safe conduct and removal.`
obj_root_law_sections_120_footnotes:
  string
  line
obj_root_law_sections_121:
  sectionId (27739)
  sectionNo (121)
  orderNo 121
  title `Communication of certain orders to prison officers.`
  content obj_root_law_sections_121_content
  footnotes obj_root_law_sections_121_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27739&sectionno=121&orderno=121&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_121_content:
  string
  line `Whenever an order is duly made under`
  line `this Act setting aside or varying any sentence, order or warrant under which any person is confined in a`
  line `civil prison, a warrant in accordance with such order shall be forwarded by the officer making the order or`
  line `his staff officer or such other person as may be prescribed, to the officer in charge of the prison in which`
  line `such person is confined.`
obj_root_law_sections_121_footnotes:
  string
  line
obj_root_law_sections_122:
  sectionId (27740)
  sectionNo (122)
  orderNo 122
  title `Execution of sentence of fine.`
  content obj_root_law_sections_122_content
  footnotes obj_root_law_sections_122_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27740&sectionno=122&orderno=122&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_122_content:
  string
  line `When a sentence of fine is imposed by a Security Guard Court`
  line `under section 45, a copy of such sentence signed and certified by the confirming officer, or where no`
  line `confirmation is required, by the officer holding the trial may be sent to any Magistrate in India, and such`
  line `Magistrate shall thereupon cause the fine to be recovered in accordance with the provisions of the Code of`
  line `Criminal Procedure, 1973 (2 of 1974), as if it were a sentence of fine imposed by such Magistrate.`
obj_root_law_sections_122_footnotes:
  string
  line
obj_root_law_sections_123:
  sectionId (27741)
  sectionNo (123)
  orderNo 123
  title `Informality or error in the order or warrant`
  content obj_root_law_sections_123_content
  footnotes obj_root_law_sections_123_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27741&sectionno=123&orderno=123&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_123_content:
  string
  line `Whenever any person is sentenced to`
  line `imprisonment under this Act, and is undergoing the sentence in any place or manner in which he might be`
  line `confined under a lawful order or warrant in pursuance of this Act, the confinement of such person shall`
  line `not be deemed to be illegal only by reason of informality or error in, or as respects, the order, warrant or`
  line `other document, or the authority by which, or in pursuance whereof such person was brought into, or, is`
  line `confined in any such place, and any such order, warrant or document may be amended accordingly.`
obj_root_law_sections_123_footnotes:
  string
  line
obj_root_law_sections_124:
  sectionId (27742)
  sectionNo (124)
  orderNo 124
  title `Pardon and remission`
  content obj_root_law_sections_124_content
  footnotes obj_root_law_sections_124_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27742&sectionno=124&orderno=124&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_124_content:
  string
  line `When any person subject to this Act has been convicted by a Security`
  line `Guard Court of any offence, the Central Government or the Director-General or, in the case of a sentence,`
  line `which he could have confirmed or which did not require confirmation, an officer not below the rank of a`
  line `Deputy Inspector-General within whose command such person at the time of conviction was serving, or`
  line `the prescribed officer may,—`
  line
  line `(a) either with or without conditions which the person sentenced accepts, pardon the person or`
  line `remit the whole or any part of the punishment awarded; or`
  line
  line `(b) mitigate the punishment awarded; or`
  line
  line `(c) commute such punishment for any less punishment or punishments mentioned in this Act; or`
  line
  line `(d) either with or without conditions which the person sentenced accepts, release the person on`
  line parole.
obj_root_law_sections_124_footnotes:
  string
  line
obj_root_law_sections_125:
  sectionId (27743)
  sectionNo (125)
  orderNo 125
  title `Cancellation of conditional pardon, release on parole or remission.`
  content obj_root_law_sections_125_content
  footnotes obj_root_law_sections_125_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27743&sectionno=125&orderno=125&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_125_content:
  string
  line `(1) If any condition on`
  line `which a person has been pardoned or released on parole or a punishment has been remitted is, in the`
  line `opinion of the authority which granted the pardon, release or remission not fulfilled, such authority may`
  line `cancel the pardon, release or remission, and thereupon the sentence of the Court shall be carried into`
  line `effect as if such pardon, release or remission had not been granted.`
  line
  line `(2) A person whose sentence of imprisonment is carried into effect under the provisions of`
  line `sub-section (1) shall undergo only the unexpired portion of his sentence.`
obj_root_law_sections_125_footnotes:
  string
  line
obj_root_law_sections_126:
  sectionId (27744)
  sectionNo (126)
  orderNo 126
  title `Suspension of sentence of imprisonment`
  content obj_root_law_sections_126_content
  footnotes obj_root_law_sections_126_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27744&sectionno=126&orderno=126&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_126_content:
  string
  line `(1) Where a person subject to this Act is sentenced`
  line `by a Security Guard Court to imprisonment, the Central Government, the Director-General or any officer`
  line `empowered to convene a General Security Guard Court may suspend the sentence whether or not the`
  line `offender has already been committed to prison or to Security Guard custody.`
  line
  line `(2) The authority or officer specified in sub-section (1) may, in the case of an offender so sentenced,`
  line `direct that until the orders of such authority or officer have been obtained the offender shall not be`
  line `committed to prison or to Security Guard custody.`
  line
  line `(3) The powers conferred by sub-sections (1) and (2) may be exercised in the case of any such`
  line `sentence which has been confirmed, reduced or commuted.`
obj_root_law_sections_126_footnotes:
  string
  line
obj_root_law_sections_127:
  sectionId (27745)
  sectionNo (127)
  orderNo 127
  title `Orders pending suspension.`
  content obj_root_law_sections_127_content
  footnotes obj_root_law_sections_127_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27745&sectionno=127&orderno=127&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_127_content:
  string
  line `(1) Where the sentence referred to in section 126 is imposed by`
  line `a Security Guard Court, other than a Summary Security Guard Court, the confirming officer may, when`
  line `confirming the sentence, direct that the offender be not committed to prison or to Security Guard custody`
  line `until the orders of the authority or officer specified in section 126, have been obtained.`
  line
  line `(2) Where a sentence of imprisonment is imposed by a Summary Security Guard Court, the officer`
  line `holding the trial may make the direction referred to in sub-section (1).`
obj_root_law_sections_127_footnotes:
  string
  line
obj_root_law_sections_128:
  sectionId (27746)
  sectionNo (128)
  orderNo 128
  title `Release on suspension.`
  content obj_root_law_sections_128_content
  footnotes obj_root_law_sections_128_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27746&sectionno=128&orderno=128&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_128_content:
  string
  line `Where a sentence is suspended under section 126, the offender shall`
  line `forthwith be released from custody.`
obj_root_law_sections_128_footnotes:
  string
  line
obj_root_law_sections_129:
  sectionId (27747)
  sectionNo (129)
  orderNo 129
  title `Computation of period of suspension.`
  content obj_root_law_sections_129_content
  footnotes obj_root_law_sections_129_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27747&sectionno=129&orderno=129&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_129_content:
  string
  line `Any period during which the sentence is under`
  line `suspension shall be reckoned as part of the term of such sentence.`
obj_root_law_sections_129_footnotes:
  string
  line
obj_root_law_sections_130:
  sectionId (27748)
  sectionNo (130)
  orderNo 130
  title `Order after suspension`
  content obj_root_law_sections_130_content
  footnotes obj_root_law_sections_130_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27748&sectionno=130&orderno=130&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_130_content:
  string
  line `while a sentence is suspended, order—`
  line
  line `(a) that the offender be committed to undergo the unexpired portion of the sentence; or`
  line
  line `(b) that the sentence be remitted.`
obj_root_law_sections_130_footnotes:
  string
  line
obj_root_law_sections_131:
  sectionId (27749)
  sectionNo (131)
  orderNo 131
  title `Reconsideration of case after suspension.`
  content obj_root_law_sections_131_content
  footnotes obj_root_law_sections_131_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27749&sectionno=131&orderno=131&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_131_content:
  string
  line `(1) Where a sentence has been suspended, the case`
  line `may at any time, and shall at intervals of not more than four months, be reconsidered by the authority or`
  line `officer specified in section 126, or by any officer not below the rank of a Deputy Inspector-General duly`
  line `authorised by the authority or officer specified in section 126.`
  line
  line `(2) Where on such reconsideration by the officer so authorised it appears to him that the conduct of`
  line `the offender since his conviction has been such as to justify a remission of the sentence, he shall refer the`
  line `matter to the authority or officer specified in section 126.`
obj_root_law_sections_131_footnotes:
  string
  line
obj_root_law_sections_132:
  sectionId (27750)
  sectionNo (132)
  orderNo 132
  title `Fresh sentence after suspension.`
  content obj_root_law_sections_132_content
  footnotes obj_root_law_sections_132_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27750&sectionno=132&orderno=132&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_132_content:
  string
  line `Where an offender, while a sentence on him is suspended`
  line `under this Act, is sentenced for any other offence, then—`
  line
  line `(a) if the further sentence is also suspended under this Act, the two sentences shall run`
  line concurrently;
  line
  line `(b) if the further sentence is for a period of three months or more and is not suspended under this`
  line `Act, the offender shall also be committed to prison or Security Guard custody for the unexpired`
  line `portion of the previous sentence, but both sentences shall run concurrently; and`
  line
  line `(c) if the further sentence is for a period of less than three months and is not suspended under this`
  line `Act, the offender shall be so committed on that sentence only, and the previous sentence shall, subject`
  line `to any order which may be passed under section 130 or section 131 continue to be suspended.`
obj_root_law_sections_132_footnotes:
  string
  line
obj_root_law_sections_133:
  sectionId (27751)
  sectionNo (133)
  orderNo 133
  title `Scope of power of suspension.`
  content obj_root_law_sections_133_content
  footnotes obj_root_law_sections_133_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27751&sectionno=133&orderno=133&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_133_content:
  string
  line `The powers conferred by sections 126 and 130 shall be in`
  line `addition to, and not in derogation of, the power of mitigation, remission and commutation.`
obj_root_law_sections_133_footnotes:
  string
  line
obj_root_law_sections_134:
  sectionId (27752)
  sectionNo (134)
  orderNo 134
  title `Effect of suspension and remission on dismissal.`
  content obj_root_law_sections_134_content
  footnotes obj_root_law_sections_134_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27752&sectionno=134&orderno=134&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_134_content:
  string
  line `(1) Where in addition to any other sentence`
  line `the punishment of dismissal has been awarded by a Security Guard Court, and such other sentence is`
  line `suspended under section 126, then, such dismissal shall not take effect until so ordered by the authority or`
  line `officer specified in section 126.`
  line
  line `(2) If such other sentence is remitted under section 130, the punishment of dismissal shall also be`
  line remitted.
obj_root_law_sections_134_footnotes:
  string
  line
obj_root_law_sections_135:
  sectionId (27753)
  sectionNo (135)
  orderNo 135
  title `Rank structure`
  content obj_root_law_sections_135_content
  footnotes obj_root_law_sections_135_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27753&sectionno=135&orderno=135&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_135_content:
  string
  line `(1) The officers and other members of the Security Guard shall be classified`
  line `in accordance with their ranks in the following categories, namely:—`
  line
  line `(a) officers—`
  line
  line `(i) Director-General.`
  line
  line `(ii) Additional Director-General.`
  line
  line `(iii) Inspector-General.`
  line
  line `(iv) Deputy Inspector-General.`
  line
  line `(v) Group Commander.`
  line
  line `(vi) Squadron Commander.`
  line
  line `(vii) Team Commander`
  line
  line `(b) Assistant Commanders—`
  line
  line `(viii) Assistant Commander Grade I.`
  line
  line `(ix) Assistant Commander Grade II.`
  line
  line `(x) Assistant Commander Grade III.`
  line
  line `(c) person other than officers and Assistant Commanders—`
  line
  line `(xi) Ranger Grade I.`
  line
  line `(xii) Ranger Grade II.`
  line
  line `(xiii) Combatised tradesmen.`
  line
  line `(2) The matters relating to inter se seniority of persons belonging to the same rank shall be`
  line `determined in accordance with such rules as may be prescribed.`
  line
  line `(3) Notwithstanding anything contained in this Act, the Director-General may, subject to`
  line `confirmation by the Central Government as provided hereinafter, grant to an officer or Assistant`
  line `Commander Grade I a rank, mentioned in clause (a) of sub-section (1) as a local rank, whenever`
  line `considered necessary by him in the interest of better functioning of the Security Guard.`
  line
  line `(4) An officer or Assistant Commander Grade I holding a local rank,—`
  line
  line `(a) shall exercise the command and be vested with powers of an officer holding that rank;`
  line
  line `(b) shall cease to hold that rank, if the grant of such rank is not confirmed within one month by`
  line `the Central Government, or when so ordered by the Director-General or when he ceases to hold the`
  line `appointment for which the rank was granted;`
  line
  line `(c) shall not be entitled to claim any seniority over other officers by virtue of his having held such`
  line `local rank; and`
  line
  line `(d) shall not be entitled to any extra pay for holding such rank.`
obj_root_law_sections_135_footnotes:
  string
  line
obj_root_law_sections_136:
  sectionId (27754)
  sectionNo (136)
  orderNo 136
  title `Deduction from pay and allowances`
  content obj_root_law_sections_136_content
  footnotes obj_root_law_sections_136_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27754&sectionno=136&orderno=136&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_136_content:
  string
  line `(1) Subject to the provisions of sub-section (4), the`
  line `following deductions may be made from the pay and allowances of an officer, that is to say—`
  line
  line `(a) all pay and allowances due to an officer for every day he absents himself without leave, unless`
  line `a satisfactory explanation has been given and accepted by the Inspector-General under whom he is for`
  line `the time being serving, and for every day of imprisonment awarded by a Criminal Court or a Security`
  line `Guard Court;`
  line
  line `(b) any sum required to make good the pay of any person subject to this Act which the officer has`
  line `unlawfully retained or unlawfully refused to pay;`
  line
  line `(c) any sum required to be paid as fine imposed by a Criminal Court;`
  line
  line `(d) any sum required to make up any loss, damage or destruction of public property or property`
  line `belonging to the Security Guard which, after due investigation, appears to the Inspector-General`
  line `under whom the officer is for the time being serving, to have been occasioned by wrongful act or`
  line `negligence on the part of the officer;`
  line
  line `(e) any sum required by an order of the Central Government to be paid for the maintenance of his`
  line `wife or his legitimate or illegitimate child or step-child or towards the cost of any relief given by the`
  line `said Government to the said wife or child.`
  line
  line `(2) Subject to the provisions of sub-section (4), the following deductions may be made from the pay`
  line `and allowances of a person subject to this Act, other than an officer, that is to say,—`
  line
  line `(a) all pay and allowances due to him for every day of absence either on desertion or without`
  line `leave unless a satisfactory explanation has been given and accepted by his Commander and for every`
  line `day of imprisonment awarded by a Criminal Court, a Security Guard Court or an officer exercising`
  line `authority under section 51;`
  line
  line `(b) any sum required to make good the pay of any person subject to this Act which he has`
  line `unlawfully retained or unlawfully refused to pay;`
  line
  line `(c) any sum required to make good such compensation for any expenses, loss, damage or`
  line `destruction caused by him to the Central Government or to any building or property or any private`
  line `fund of the Security Guard as may be awarded by his Commander;`
  line
  line `(d) any sum required to be paid as fine imposed by a Criminal Court;`
  line
  line `(e) any sum required by an order of the Central Government to be paid for the maintenance of his`
  line `wife or his legitimate or illegitimate child or step-child or towards the cost of any relief given by the`
  line `said Government to the said wife or child.`
  line
  line `(3) (i) No person shall be treated as absent or under imprisonment for a day unless the absence or`
  line `imprisonment has lasted, whether wholly in one day or partly in one day and partly in another, for six`
  line `consecutive hours or upwards.`
  line
  line `(ii) Any absence or imprisonment for less than a day may be reckoned as absence or imprisonment`
  line `for a day if such absence or imprisonment prevented the absentee from fulfilling any duty as a member of`
  line `the Security Guard which was thereby thrown upon some other member.`
  line
  line `(4) The total deductions from the pay and allowances of a person made under clauses (b) to (e) of`
  line `sub-section (1) or clauses (b) to (e) of sub-section (2) shall not, except where he is sentenced to dismissal,`
  line `exceed in any one month, one-half of his pay and allowances for that month.`
  line
  line `(5) Any sum authorised by this Act to be deducted from the pay and allowances of any person may,`
  line `without prejudice to any other mode of recovering the same, be deducted from any public money due to`
  line `him other than a pension.`
  line
  line `(6) The following shall be the authorities competent to order deductions from pay and allowances`
  line `under this Act, namely:—`
  line
  line `(a) Commanders not below the rank of Group Commanders, in the case of persons other than`
  line officers;
  line
  line `(b) Inspector-General, in the case of officers.`
  line
  line `(7) Any authority superior to the one ordering any deduction under this Act shall be competent to`
  line `remit the whole or part of the said deduction.`
  line
  line `(8) Any power conferred by the provisions of this section on an officer may be exercised by an officer`
  line `or authority superior in command to the first mentioned officer.`
obj_root_law_sections_136_footnotes:
  string
  line
obj_root_law_sections_137:
  sectionId (27755)
  sectionNo (137)
  orderNo 137
  title `Powers and duties conferable and imposable on members of the Security Guard.`
  content obj_root_law_sections_137_content
  footnotes obj_root_law_sections_137_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27755&sectionno=137&orderno=137&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_137_content:
  string
  line `(1) The`
  line `Central Government may, by general or special order published in the Official Gazette, direct that, subject`
  line `to such conditions and limitations as may be specified in the order, any member of the Security Guard`
  line `may exercise or discharge such of the powers or duties under any Central Act as may be specified in the`
  line `said order, being the powers and duties which, in the opinion of the Central Government, an officer of the`
  line `corresponding or lower rank is by such Central Act empowered to exercise or discharge for the said`
  line purposes.
  line
  line `(2) The Central Government may, by general or special order published in the Official Gazette,`
  line `confer or impose, with the concurrence of the State Government concerned, any of the powers or duties`
  line `which may be exercised or discharged under a State Act by a police officer upon a member of the`
  line `Security Guard who, in the opinion of the Central Government, holds a corresponding or higher rank.`
  line
  line `(3) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session for a total period of thirty days which may be comprised in one`
  line `session or in two or more successive sessions and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the order or both Houses agree that the order should not be made, the order shall thereafter have effect`
  line `only in such modified form or be of no effect, as the case may be; so, however, that any such modification`
  line `or annulment shall be without prejudice to the validity of anything previously done under that order.`
obj_root_law_sections_137_footnotes:
  string
  line
obj_root_law_sections_138:
  sectionId (27756)
  sectionNo (138)
  orderNo 138
  title `Protection for acts of members of the Security Guard.`
  content obj_root_law_sections_138_content
  footnotes obj_root_law_sections_138_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27756&sectionno=138&orderno=138&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_138_content:
  string
  line `(1) In any suit or proceeding against`
  line `any member of the Security Guard for any act done by him in pursuance of a warrant or order of a`
  line `competent authority, it shall be lawful for him to plead that such act was done by him under the authority`
  line `of such warrant or order.`
  line
  line `(2) Any such plea may be proved by the production of the warrant or order directing the act, and if it`
  line `is so proved the member of the Security Guard shall thereupon be discharged from liability in respect of`
  line `the act so done by him, notwithstanding any defect in the jurisdiction of the authority which issued such`
  line `warrant or order.`
  line
  line `(3) Notwithstanding anything contained in any other law for the time being in force, any legal`
  line `proceeding (whether civil or criminal) which may lawfully be brought against any member of the Security`
  line `Guard for anything done or intended to be done under the powers conferred by, or in pursuance of, any`
  line `provision of this Act or the rules, shall be commenced within three months after the act complained of`
  line `was committed and not otherwise, and notice in writing of such proceeding and of the cause thereof shall`
  line `be given to the defendant or his superior officer at least one month before the commencement of such`
  line proceeding.
obj_root_law_sections_138_footnotes:
  string
  line
obj_root_law_sections_139:
  sectionId (27757)
  sectionNo (139)
  orderNo 139
  title `Power to make rules.`
  content obj_root_law_sections_139_content
  footnotes obj_root_law_sections_139_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27757&sectionno=139&orderno=139&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_139_content:
  string
  line `(1) The Central Government may, by notification, make rules for`
  line `carrying out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:—`
  line
  line `(a) the manner in which the Security Guard shall be constituted and the conditions of service of`
  line `its members under sub-section (1) of section 4;`
  line
  line `(b) the nature of the book or letter or other document, the communication or publication whereof`
  line `would not be restricted by sub-section (1) of section 12;`
  line
  line `(c) the purposes other than political purposes for which a person subject to the Act shall not`
  line `participate in, or address, any meeting or demonstration under sub-section (2) of section 12;`
  line
  line `(d) the purposes for which the forfeiture of service as a punishment may be inflicted under`
  line `sub-section (1) of section 47;`
  line
  line `(e) the manner in which officers may be proceeded against under section 53 and sub-sections (1)`
  line `and (2) of section 54;`
  line
  line `(f) the manner in which and the period for which any person subject to this Act may be taken into`
  line `and detained in Security Guard custody pending his trial under sub-section (4) of section 56;`
  line
  line `(g) the manner in which a Court of inquiry enquiring into the absence of person, shall administer`
  line `oath or affirmation under sub-section (1) of section 60;`
  line
  line `(h) the manner in which a vacancy may be filled in on the retirement of a member of General`
  line `Security Guard Court or a Petty Security Guard Court under sub-section (3) of section 81;`
  line
  line `(i) the manner in which oath or affirmation shall be administered to the members of the Security`
  line `Guard Courts and the Judge Attorney, etc., under sub-section (1) of section 82;`
  line
  line `(j) the manner in which a person giving evidence before a Security Guard Court shall be sworn or`
  line `affirmed in under sub-section (2) of section 82;`
  line
  line `(k) the manner in which a Security Guard Court when convicting a person may inquire into under`
  line `sub-section (1) of section 95;`
  line
  line `(l) the manner in which an accused person shall be kept in custody under sub-section (4) of`
  line `section 96;`
  line
  line `(m) the form of the warrant which shall be forwarded to the officer in charge of the prison`
  line `in which a person under sentence of imprisonment is to be conferred under sub-section (2) of`
  line `section 117;`
  line
  line `(n) the person who shall forward the warrant for the confinement of a person in a civil prison`
  line `under section 121;`
  line
  line `(o) the matters relating to inter se seniority of persons belonging to the same rank under`
  line `sub-section (2) of section 135;`
  line
  line `(p) the authorities or officers to be prescribed under section 7, sub-section (2) of section 10,`
  line `sub-section (1) of section 12, section 77, section 97, section 111, sub-section (2) of section 113,`
  line `sub-sections (1), (2) and (4) of section 117 and section 124;`
  line
  line `(q) any other matter which is to be, or may be, prescribed or in respect of which this Act makes`
  line `no provision or makes insufficient provision and provision is, in the opinion of the Central`
  line `Government, necessary for the proper implementation of this Act.`
  line
  line `(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making`
  line `any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however,`
  line `that any such modification or annulment shall be without prejudice to the validity of anything`
  line `previously done under that rule.`
obj_root_law_sections_139_footnotes:
  string
  line
obj_root_law_sections_140:
  sectionId (27758)
  sectionNo (140)
  orderNo 140
  title `Provisions as to existing National Security Guard.`
  content obj_root_law_sections_140_content
  footnotes obj_root_law_sections_140_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00037_198647_1517807326729&sectionId=27758&sectionno=140&orderno=140&orgactid=AC_CEN_2_2_00037_198647_1517807326729
obj_root_law_sections_140_content:
  string
  line `(1) The National Security Guard in`
  line `existence at the commencement of this Act shall be deemed to be the Security Guard constituted under`
  line `this Act.`
  line
  line `(2) The members of the National Security Guard in existence at the commencement of this Act shall`
  line `be deemed to have been appointed as such under this Act.`
  line
  line `(3) Anything done or any action taken before the commencement of this Act in relation to the`
  line `constitution of the National Security Guard referred to in sub-section (1), in relation to any person`
  line `appointed, shall be as valid and as effective in law as if such thing or action was done or taken under this`
  line `Act:`
  line
  line `Provided that nothing in this sub-section shall render any person guilty of any offence in respect of`
  line `anything done or omitted to be done by him before the commencement of this Act.`
obj_root_law_sections_140_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
