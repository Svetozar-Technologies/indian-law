obj_root_law:
  slug the-national-security-guard-act-1986
  handle (1853)
  collectionHandle 123456789/1362
  title `The National Security Guard Act, 1986`
  actNumber (47)
  enactmentDate 1986-09-22
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1853`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्‍ट्रीय सुरक्षक अधिनियम, 1986`
  actYear (1986)
  ministry `Ministry of Home Affairs`
  department `Department of Internal Security`
  longTitle `An Act to provide for the constitution and regulation of an armed force of the Union for combating terrorist activities with a view to protecting States against internal disturbances and for matters connected therewith.`
  enforcementDate 16-10-1986
  notification `16th October, 1986, vide notification No. S.O. 737(E), dated 16th October, 1986, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
