  (str slug) (str the-national-security-guard-act-1986)
  (str handle) (str 1853)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Security Guard Act, 1986`)
  (str actNumber) (str 47)
  (str enactmentDate) (str 1986-09-22)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1853`)
