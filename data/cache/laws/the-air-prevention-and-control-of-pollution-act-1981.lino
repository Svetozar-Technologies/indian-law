obj_root_law:
  slug the-air-prevention-and-control-of-pollution-act-1981
  handle (1389)
  collectionHandle 123456789/1362
  title `The Air (Prevention and Control of Pollution) Act, 1981`
  actNumber (14)
  enactmentDate 1981-03-29
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1389`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `वायु (प्रदूषण निवारण और नियंत्रण) अधिनियम, 1981`
  actYear (1981)
  ministry `Ministry of Environment, Forest and Climate Change`
  department undefined
  longTitle `An Act to provide for the prevention, control and abatement of air pollution, for the establishment, with a view to carrying out the aforesaid purposes, of Boards, for conferring on and assigning to such Boards powers and functions relating thereto and for matters connected therewith.`
  enforcementDate 16-05-1981
  notification `16th May, 1981, vide notification No. G.S.R. 351(E), dated 15th May, 1981, see Gazette of India, Extraordinary, Part II, sec. 3 (i).`
