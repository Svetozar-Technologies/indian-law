obj_root_law_sections_1:
  sectionId (28687)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28687&sectionno=1&orderno=1&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Air (Prevention and`
  line `Control of Pollution) Act, 1981.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1 as the Central Government may, by notification in the Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 16th May, 1981,vide notificationNo. G.S.R. 351(E), dated 15th May, 1981, see Gazette of India, Extraordinary, Part II, sec. 3`
  line `(i).`
obj_root_law_sections_2:
  sectionId (28688)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28688&sectionno=2&orderno=2&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "air pollutant" means any solid, liquid or gaseous substance ^1[(including noise)] present in the`
  line `atmosphere in such concentration as may be or tend to be injurious to human beings or other living`
  line `creatures or plants or property or environment;`
  line
  line `(b) "air pollution" means the presence in the atmosphere of any air pollutant;`
  line
  line `(c) "approved appliance" means any equipment or gadget used for the bringing of any`
  line `combustible material or for generating or consuming any fume, gas of particulate matter and`
  line `approved by the State Board for the purposes of this Act;`
  line
  line `(d) "approved fuel" means any fuel approved by the State Board for the purposes of this Act;`
  line
  line `(e) "automobile" means any vehicle powered either by internal combustion engine or by any`
  line `method of generating power to drive such vehicle by burning fuel;`
  line
  line `(f) "Board" means the Central Board or a State Board;`
  line
  line `(g) "Central Board" means the ^2[Central Pollution Control Board] constituted under section 3 of`
  line `the Water (Prevention and Control of Pollution) Act, 1974 (6 of 1974);`
  line
  line `(h) "chimney" includes any structure with an opening or outlet from or through which any air`
  line `pollutant may be emitted;`
  line
  line `(i) "control equipment" means any apparatus, device, equipment or system to control the quality`
  line `and manner of emission of any air pollutant and includes any device used for securing the efficient`
  line `operation of any industrial plant;`
  line
  line `(j) "emission" means any solid or liquid or gaseous substance coming out of any chimney, duct or`
  line `flue or any other outlet;`
  line
  line `(k) "industrial plant" means any plant used for any industrial or trade purposes and emitting any`
  line `air pollutant into the atmosphere;`
  line
  line `(l) "member" means a member of the Central Board or a State Board, as the case may be, and`
  line `includes the Chairman thereof;`
  line
  line `^3[(m) "occupier", in relation to any factory or premises, means the person who has control over`
  line `the affairs of the factory or the premises, and includes, in relation to any substance, the person in`
  line `possession of the substance;]`
  line
  line `(n) "prescribed" means prescribed by rules made under this Act by the Central Government or, as`
  line `the case may be, the State Government;`
  line
  line `(o) "State Board" means,--`
  line
  line `(i) in relation to a State in which the Water (Prevention and Control of Pollution) Act, 1974`
  line `(6 of 1974), is in force and the State Government has constituted for that State a ^4`
  line `[State Pollution`
  line `Control Board] under section 4 of that Act, the said State Board; and`
  line
  line `(ii) in relation to any other State, the State Board for the Prevention and Control of Air`
  line `Pollution constituted by the State Government under section 5 of this Act.`
obj_root_law_sections_2_footnotes:
  string
  line `1 Ins. by Act 47 of 1987, s. 2 (w.e.f. 1-4-1988).`
  line
  line `2 Subs. by s. 2,ibid., for Central Board for the Prevention and Control of Water Pollution (w.e.f. 1-4-1988).`
  line
  line `3 Subs. by Act 47 of 1987, s. 2, for clause (m) (w.e.f. 1-4-1988).`
  line
  line `4 Subs. by s. 2, ibid., for State Board for the Prevention and Control of Water Pollution (w.e.f. 1-4-1988).`
obj_root_law_sections_3:
  sectionId (28689)
  sectionNo (3)
  orderNo 3
  title `Central Pollution Control Board.`
  content obj_root_law_sections_3_content
  footnotes `1 Subs. by s. 3, ibid., for sections 3 and 4 (w.e.f. 1-4-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28689&sectionno=3&orderno=3&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_3_content:
  string
  line ^1
  line `[3. Central Pollution Control Board.--The Central Pollution Control Board constituted under`
  line `section 3 of the Water (Prevention and Control of Pollution) Act, 1974 (6 of 1974), shall, without`
  line `prejudice to the exercise and performance of its powers and functions under that Act, exercise the powers`
  line `and perform the functions of the Central Pollution Control Board for the prevention and control of air`
  line `pollution under this Act.]`
obj_root_law_sections_4:
  sectionId (28690)
  sectionNo (4)
  orderNo 4
  title `State Pollution Control Boards constituted under section 4 of Act 6 of 1974 to be State Boards under this Act.`
  content obj_root_law_sections_4_content
  footnotes `1 Subs. by s. 3, ibid., for sections 3 and 4 (w.e.f. 1-4-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28690&sectionno=4&orderno=4&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_4_content:
  string
  line `^1[4. State Pollution Control Boards constituted under section 4 of Act 6 of 1974 to be State Boards`
  line `under this Act.--In any State in which the Water (Prevention and Control of Pollution) Act, 1974 (6 of`
  line `1974), is in force and the State Government has constituted for that State a State Pollution Control Board`
  line `under section 4 of that Act, such State Board shall be deemed to be the State Board for the Prevention and`
  line `Control of air Pollution constituted under section 5 of this Act, and accordingly that State Pollution`
  line `Control Board shall, without prejudice to the exercise and performance of its powers and functions under`
  line `that Act, exercise the powers and perform the functions of the State Board for the prevention and control`
  line `of air pollution under this Act.]`
obj_root_law_sections_5:
  sectionId (28691)
  sectionNo (5)
  orderNo 5
  title `Constitution of State Boards.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28691&sectionno=5&orderno=5&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_5_content:
  string
  line `(1) In any State in which the Water (Prevention and Control of`
  line `Pollution) Act, 1974 (6 of 1974), is not in force, or that Act is in force but the State Government has not`
  line `constituted a ^1`
  line `[State Pollution Control Board] under that Act, the State Government shall, with effect`
  line `from such date as it may, by notification in the Official Gazette, appoint, constitute a State Board for the`
  line `Prevention and Control of Air Pollution under such name as may be specified in the notification, to`
  line `exercise the powers conferred on, and perform the functions assigned to, that Board under this Act.`
  line
  line `(2) A State Board constituted under this Act shall consist of the following members, namely:--`
  line
  line `(a) a Chairman, being a person, having special knowledge or practical experience in respect of`
  line `matters relating to environmental protection, to be nominated by the State Government:`
  line
  line `Provided that the Chairman may be either whole-time or part-time as the State Government may`
  line `think fit;`
  line
  line `(b) such number of officials, not exceeding five, as the State Government may think fit, to be`
  line `nominated by the State Government to represent that Government;`
  line
  line `(c) such number of persons, not exceeding five, as the State Government may think fit, to be`
  line `nominated by the State Government from amongst the members of the local authorities functioning`
  line `within the State;`
  line
  line `(d) such number of non-officials, not exceeding three, as the State Government may think fit, to`
  line `be nominated by the State Government to represent the interest of agriculture, fishery or industry or`
  line `trade or labour or any other interest, which, in the opinion of that Government, ought to be`
  line represented;
  line
  line `(e) two persons to represent the companies or corporations owned, controlled or managed by the`
  line `State Government, to be nominated by that Government;`
  line
  line ^2
  line `[(f) a full-time member-secretary having such qualifications knowledge and experience of`
  line `scientific, engineering or management aspects of pollution control as may be prescribed, to be`
  line `appointed by the State Government:]`
  line
  line `Provided that the State Government shall ensure that not less than two of the members are`
  line `persons having special knowledge or practical experience in respect of matters relating to the`
  line `improvement of the quality of air or the prevention, control or abatement of air pollution.`
  line
  line `(3) Every State Board constituted under this Act shall be a body corporate with the name specified by`
  line `the State Government in the notification issued under sub-section (1), having perpetual succession and a`
  line `common seal with power, subject to the provisions of this Act, to acquire and dispose of property and to`
  line `contract, and may by the said name sue or be sued.`
obj_root_law_sections_5_footnotes:
  string
  line `1 Subs. by s. 4, ibid., for State Board for the Prevention and Control of Water Pollution (w.e.f. 1-4-1988).`
  line
  line `2 Subs. by Act 47 of 1987, s. 4, for clause (f) (w.e.f. 1-4-1988).`
obj_root_law_sections_6:
  sectionId (28692)
  sectionNo (6)
  orderNo 6
  title `Central Board to exercise the powers and perform the functions of a State Board in the Union territories.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28692&sectionno=6&orderno=6&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_6_content:
  string
  line `No State Board shall be constituted for a Union territory and in relation to a Union`
  line `territory, the Central Board shall exercise the powers and perform the functions of a State Board under`
  line `this Act for that Union territory:`
  line
  line `Provided that in relation to any Union territory the Central Board may delegate all or any of its`
  line `powers and functions under this section to such person or body of persons as the Central Government`
  line `may specify.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (28693)
  sectionNo (7)
  orderNo 7
  title `Terms and conditions of service of members.`
  content obj_root_law_sections_7_content
  footnotes `1. The words "but not for more than two terms" omitted by Act 47 of 1987, s. 5 (w.e.f. 1-4-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28693&sectionno=7&orderno=7&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_7_content:
  string
  line `(1) Save as otherwise provided by or under this`
  line `Act, a member of a State Board constituted under this Act, other than the member-secretary, shall hold`
  line `office for a term of three years from the date on which his nomination is notified in the Official Gazette:`
  line
  line `Provided that a member shall, notwithstanding the expiration of his term, continue to hold office until`
  line `his successor enters upon his office.`
  line
  line `(2) The terms of office of a member of a State Board constituted under this Act and nominated under`
  line `clause (b) or clause (e) of sub-section (2) of section 5 shall come to an end as soon as he ceases to hold`
  line `the office under the State Government or, as the case may be, the company or corporation owned,`
  line `controlled or managed by the State Government, by virtue of which he was nominated.`
  line
  line `(3) A member of a State Board constituted under this Act, other than the member-secretary, may at`
  line `any time resign his office by writing under his hand addressed,`
  line
  line `(a) in the case of the Chairman, to the State Government; and`
  line
  line `(b) in any other case, to the Chairman of the State Board,`
  line `and the seat of the Chairman or such other member shall thereupon become vacant.`
  line
  line `(4) A member of a State Board constituted under this Act, other than the member-secretary, shall be`
  line `deemed to have vacated his seat, if he is absent without reason, sufficient in the opinion of the State`
  line `Board, from three consecutive meetings of the State Board or where he is nominated under clause (c) of`
  line `sub-section (2) of section 5, he ceases to be a member of the local authority and such vacation of seat shall, in either case, take effect from such date as the State Government may, by notification in the`
  line `Official Gazette, specify.`
  line
  line `(5) A casual vacancy in a State Board constituted under this Act shall be filled by a fresh nomination`
  line `and the person nominated to fill the vacancy shall hold office only for the remainder of the term for which`
  line `the member whose place he takes was nominated.`
  line
  line `(6) A member of a State Board constituted under this Act shall be eligible for re-nomination^1`
  line ***.
  line
  line `(7) The other terms and conditions of service of the Chairman and other members (except the`
  line `member-secretary) of a State Board constituted under this Act shall be such as may be prescribed.`
obj_root_law_sections_8:
  sectionId (28694)
  sectionNo (8)
  orderNo 8
  title Disqualifications.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28694&sectionno=8&orderno=8&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_8_content:
  string
  line `(1) No person shall be a member of a State Board constituted under this Act,`
  line who--
  line
  line `(a) is, or at any time has been, adjudged insolvent, or`
  line
  line `(b) is of unsound mind and has been so declared by a competent court, or`
  line
  line `(c) is, or has been, convicted of an offence which, in the opinion of the State Government,`
  line `involves moral turpitude, or`
  line
  line `(d) is, or at any time has been, convicted of an offence under this Act, or`
  line
  line `(e) has directly or indirectly by himself on by any partner, any share or interest in any Firm or`
  line `company carrying on the business of manufacture, sale, or hire of machinery, industrial plant, control`
  line `equipment or any other apparatus for the improvement of the quality of air or for the prevention,`
  line `control or abatement of air pollution, or`
  line
  line `(f) is a director or a secretary, manager or other salaried officer or employee of any company or`
  line `firm having any contract with the Board, or with the Government constituting the Board or with a`
  line `local authority in the State, or with a company or corporation owned, controlled or managed by the`
  line `Government, for the carrying out of programmes for the improvement of the quality of air or for the`
  line `prevention, control or abatement of air pollution, or`
  line
  line `(g) has so abused, in the opinion of the State Government, his position as a member, as to render`
  line `his continuance on the State Board detrimental to the interest of the general public.`
  line
  line `(2) The State Government shall, by order in writing, remove any member who is, or has become,`
  line `subject to any disqualification mentioned in sub-section (1).`
  line
  line `Provided that no order of removal shall be made by the State Government under this section unless`
  line `the member concerned has been given a reasonable opportunity of showing cause against the same.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1) or sub-section (6) of section 7, a member`
  line `who has been removed under this section shall not be eligible to continue to hold office until his`
  line `successor enters upon his office, or, as the case may be, for re-nomination as a member.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (28695)
  sectionNo (9)
  orderNo 9
  title `Vacation of seats by members.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28695&sectionno=9&orderno=9&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_9_content:
  string
  line `If a member of a State Board constituted under this Act becomes`
  line `subject to any of the disqualifications specified in section 8, his seat shall become vacant.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (28696)
  sectionNo (10)
  orderNo 10
  title `Meetings of Board.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28696&sectionno=10&orderno=10&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_10_content:
  string
  line `(1) For the purposes of this Act, a Board shall meet at least once in every`
  line `three months and shall observe such rules of procedure in regard to the transaction of business at its`
  line `meetings as may be prescribed:`
  line
  line `Provided that if, in the opinion of the Chairman, any business of an urgent nature is to be transacted,`
  line `he may convene a meeting of the Board at such time as he thinks fit for the aforesaid purpose.`
  line
  line `(2) Copies of minutes of the meetings under sub-section (1) shall be forwarded to the Central Board`
  line `and to the State Government concerned.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (28697)
  sectionNo (11)
  orderNo 11
  title `Constitution of committees.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28697&sectionno=11&orderno=11&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_11_content:
  string
  line `(1) A Board may constitute as many committees consisting wholly`
  line `of members or partly of members and partly of other persons and for such purpose or purposes as it may`
  line `think fit.`
  line
  line `(2) A committee constituted under this section shall meet at such time and at such place, and shall`
  line `observe such rules of procedure in regard to the transaction of business at its meetings, as may be`
  line prescribed.
  line
  line `(3) The members of a committee other than the members of the Board shall be paid such fees and`
  line `allowances, for attending its meetings and for attending to any other work of the Board as may be`
  line prescribed.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (28698)
  sectionNo (12)
  orderNo 12
  title `Temporary association of persons with Board for particular purpose.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28698&sectionno=12&orderno=12&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_12_content:
  string
  line `(1) A Board may`
  line `associate with itself in such manner, and for such purposes, as may be prescribed, any person whose`
  line `assistance or advice it may desire to obtain in performing any of its functions under this Act.`
  line
  line `(2) A person associated with the Board under sub-section (1) for any purpose shall have a right to`
  line `take part in the discussions of the Board relevant to that purpose, but shall not have a right to vote at a`
  line `meeting of the Board and shall not be a member of the Board for any other purpose.`
  line
  line `(3) A person associated with a Board under sub-section (1) shall be entitled to receive such fees and`
  line `allowances as may be prescribed.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (28699)
  sectionNo (13)
  orderNo 13
  title `Vacancy in Board not to invalidate acts or proceedings.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28699&sectionno=13&orderno=13&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_13_content:
  string
  line `No act or proceeding of a Board or`
  line `any committee thereof shall be called in question on the ground merely of the existence of any vacancy`
  line `in, or any defect in the constitution of, the Board or such committee, as the case may be.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (28700)
  sectionNo (14)
  orderNo 14
  title `Member-secretary and officers and other employees of State Boards.`
  content obj_root_law_sections_14_content
  footnotes `1 Subs. by Act 47 of 1987, s. 6, for sub-section (2) (w.e.f. 1-4-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28700&sectionno=14&orderno=14&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_14_content:
  string
  line `(1) The terms and`
  line `conditions of service of the member-secretary of a State Board constituted under this Act shall be such as`
  line `may be prescribed.`
  line
  line ^1
  line `[(2) The member-secretary of a State Board, whether constituted under this Act or not, shall exercise`
  line `such powers and perform such duties as may be prescribed, or as may, from time to time, be delegated to`
  line `him by the State Board or its Chairman.]`
  line
  line `(3) subject to such rules as may be made by the State Government in this behalf, a State Board,`
  line `whether constituted under this Act or not, may appoint such officers and other employees as it considers`
  line `necessary for the efficient performance of its functions under this Act.`
  line
  line `(4) The method of appointment, the conditions of service and the scales of pay of the officers (other`
  line `than the member-secretary) and other employees of a State Board appointed under sub-section (3) shall be`
  line `such as may be determined by regulations made by the State Board under this Act.`
  line
  line `(5) Subject to such conditions as may be prescribed, a State Board constituted under this Act may`
  line `from time to time appoint any qualified person to be a consultant to the Board and pay him such salary`
  line `and allowances or fees, as it thinks fit.`
obj_root_law_sections_15:
  sectionId (28701)
  sectionNo (15)
  orderNo 15
  title `Delegation of powers.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28701&sectionno=15&orderno=15&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_15_content:
  string
  line `A State Board may, by general or special order, delegate to the`
  line `Chairman or the member-secretary or any other officer of the Board subject to such conditions and`
  line `limitations, if any,as may be specified in the order, such of its powers and functions under this Act as it`
  line `may deem necessary.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (28702)
  sectionNo (16)
  orderNo 16
  title `Functions of Central Board.`
  content obj_root_law_sections_16_content
  footnotes `1 Ins. by Act 47 of 1987, s. 7 (w.e.f. 1-4-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28702&sectionno=16&orderno=16&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_16_content:
  string
  line `(1) Subject to the provisions of this Act, and without prejudice to`
  line `the performance, of its functions under the Water (Prevention and Control of Pollution) Act, 1974 (6 of`
  line `1974), the main functions of the Central Board shall be to improve the quality of air and to prevent,`
  line `control or abate air pollution in the country.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing functions, the Central Board`
  line may--
  line
  line `(a) advise the Central Government on any matter concerning the improvement of the quality of`
  line `air and the prevention, control or abatement of air pollution;`
  line
  line `(b) plan and cause to be executed a nation-wide programme for the prevention, control or`
  line `abatement of air pollution;`
  line
  line `(c) co-ordinate the activities of the State and resolve disputes among them;`
  line
  line `(d) provide technical assistance and guidance to the State Boards, carry out and sponsor`
  line `investigations and research relating to problems of air pollution and prevention, control or abatement`
  line `of air pollution;`
  line
  line ^1
  line `[(dd) perform such of the functions of any State Board as may be specified in and order made`
  line `under sub-section (2) of section 18;]`
  line
  line `(e) plan and organise the training of persons engaged or to be engaged in programmes for the`
  line `prevention, control or abatement of air pollution on such terms and conditions as the Central Board`
  line `may specify;`
  line
  line `(f) organise through mass media a comprehensive programme regarding the prevention, control or`
  line `abatement of air pollution;`
  line
  line `(g) collect, compile and publish technical and statistical data relating to air pollution and the`
  line `measures devised for its effective prevention, control or abatement and prepare manuals, codes or`
  line `guides relating to prevention, control or abatement of air pollution;`
  line
  line `(h) lay down standards for the quality of air;`
  line
  line `(i) collect and disseminate information in respect of matters relating to air pollution;`
  line
  line `(j) perform such other functions as may be prescribed.`
  line
  line `(3) The Central Board may establish or recognise a laboratory or laboratories to enable the Central`
  line `Board to perform its functions under this section efficiently.`
  line
  line `(4) The Central Board may--`
  line
  line `(a) delegate any of its functions under this Act generally or specially to any of the committees`
  line `appointed by it;`
  line
  line `(b) do such other things and perform such other acts as it may think necessary for the proper`
  line `discharge of its functions and generally for the purpose of carrying into effect the purposes of this`
  line Act.
obj_root_law_sections_17:
  sectionId (28703)
  sectionNo (17)
  orderNo 17
  title `Functions of State Boards.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28703&sectionno=17&orderno=17&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_17_content:
  string
  line `(1) Subject to the provisions of this Act, and without prejudice to`
  line `the performance of its functions, if any, under the Water (Prevention and Control of Pollution) Act, 1974`
  line `(Act 6 of 1974), the functions of a State Board shall be--`
  line
  line `(a) to plan a comprehensive programme for the prevention, control or abatement of air pollution`
  line `and to secure the execution thereof;`
  line
  line `(b) to advise the State Government on any matter concerning the prevention, control or abatement`
  line `of air pollution;`
  line
  line `(c) to collect and disseminate information relating to air pollution;`
  line
  line `(d) to collaborate with the Central Board in organising the training of persons engaged or to be`
  line `engaged in programmes relating to prevention, control or abatement of air pollution and to organise`
  line `mass-education programme relating thereto;`
  line
  line `(e) to inspect, at all reasonable times, any control equipment, industrial plant or manufacturing`
  line `process and to give, by order, such directions to such persons as it may consider necessary to take`
  line `steps for the prevention, control or abatement of air pollution;`
  line
  line `(f) to inspect air pollution control areas at such intervals as it may think necessary, assess the`
  line `quality of air therein and take steps for the prevention, control or abatement of air pollution in such`
  line areas;
  line
  line `(g) to lay down, in consultation with the Central Board and having regard to the standards for the`
  line `quality of air laid down by the Central Board, standards for emission of air pollutants into the`
  line `atmosphere from industrial plants and automobiles or for the discharge of any air pollutant into the`
  line `atmosphere from any other source whatsoever not being a ship or an aircraft:`
  line
  line `Provided that different standards for emission may be laid down under this clause for different`
  line `industrial plants having regard to the quantity and composition of emission of air pollutants into the`
  line `atmosphere from such industrial plants;`
  line
  line `(h) to advise the State Government with respect to the suitability of any premises or location for`
  line `carrying on any industry which is likely to cause air pollution;`
  line
  line `(i) to Perform such other functions as may be prescribed or as may, from time to time, be`
  line `entrusted to it by the Central Board or the State Government;`
  line
  line `(j) to do such other things and to perform such other acts as it may think necessary for the proper`
  line `discharge of its functions and generally for the purpose of carrying into effect the purposes of this`
  line Act.
  line
  line `(2) A State Board may establish or recognise a laboratory or laboratories to enable the State Board to`
  line `perform its functions under this section efficiently.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (28704)
  sectionNo (18)
  orderNo 18
  title `Power to give directions.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28704&sectionno=18&orderno=18&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_18_content:
  string
  line ^1
  line `[(1)]In the performance of its functions under this Act--`
  line
  line `(a) the Central Board shall be bound by such directions in writing as the Central Government may`
  line `give to it; and`
  line
  line `(b) every State Board shall be bound by such directions in writing as the Central Board or the`
  line `State Government may give to it:`
  line
  line `Provided that where a direction given by the State Government is inconsistent with the direction`
  line `given by the Central Board, the matter shall be referred to the Central Government for its decision.`
  line
  line ^2
  line `[(2) Where the Central Government is of the opinion that any State Board has defaulted in`
  line `complying with any directions given by the Central Board under sub-section (1) and as a result of such`
  line `default a grave emergency has arisen and it is necessary or expedient so to do in the public interest, it`
  line `may, by order, direct the Central Board to perform any of the functions of the State Board in relation to`
  line `such area, for such period and for such purposes, as may be specified in the order.`
  line
  line `(3) Where the Central Board performs any of the functions of the State Board in pursuance of a`
  line `direction under sub-section (2), the expenses, if any, incurred by the Central Board with respect to the`
  line `performance of such functions may, if the State Board is empowered to recover such expenses, be`
  line `recovered by the Central Board with interest (at such reasonable rate as the Central Government may, by`
  line `order, fix) from the date when a demand for such expenses is made until it is paid from the person or`
  line `persons concerned as arrears of land revenue or of public demand.`
  line
  line `(4) For the removal of doubts, it is hereby declared that any directions to perform the functions of any`
  line `State Board given under sub-section (2) in respect of any area would not preclude the State Board from`
  line `performing such functions in any other area in the State or any of its other functionsin that area.]`
obj_root_law_sections_18_footnotes:
  string
  line `1 Section 18 renumbered as sub-section (1) thereof by Act 47 of 1987, s. 8 (w.e.f. 1-4-1988).`
  line
  line `2 Ins. by s. 8, ibid. (w.e.f. 1-4-1988).`
obj_root_law_sections_19:
  sectionId (28705)
  sectionNo (19)
  orderNo 19
  title `Power to declare air pollution control areas.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28705&sectionno=19&orderno=19&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_19_content:
  string
  line `(1) The State Government may, after`
  line `consultation with the State Board, by notification in the Official Gazette declare in such manner as may`
  line `be prescribed, any area or areas within the State as air pollution control area or areas for the purposes of`
  line `this Act.`
  line
  line `(2) The State Government may, after consultation with the State Board, by notification in the Official`
  line Gazette,--
  line
  line `(a) alter any air pollution control area whether by way of extension or reduction;`
  line
  line `(b) declare a new air pollution control area in which may be merged one or more existing air`
  line `pollution control areas or any part or parts thereof.`
  line
  line `(3) If the State Government, after consultation with the State Board, is of opinion that the use of any`
  line `fuel, other than an approved fuel, in any air pollution control area or part thereof, may cause or is likely to`
  line `cause air pollution, it may, by notification in the Official Gazette, prohibit the use of such fuel in such`
  line `area or part thereof with effect from such date (being not less than three months from the date of`
  line `publication of the notification) as may be specified in the notification.`
  line
  line `(4) The State Government may, after consultation with the State Board, by notification in the Official`
  line `Gazette, direct that with effect from such date as may be specified therein, no appliance, other than an`
  line `approved appliance, shall be used in the premises situated in an air pollution control area:`
  line
  line `Provided that different dates may be specified for different parts of an air pollution control area or for`
  line `the use of different appliances.`
  line
  line `(5) If the State Government, after consultation with the State Board, is of opinion that the burning of`
  line `any material (not being fuel) in any air pollution control area or part thereof may cause or is likely to`
  line `cause air pollution, it may, by notification in the Official Gazette, prohibit the burning of such material in`
  line `such area or part thereof.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (28706)
  sectionNo (20)
  orderNo 20
  title `Power to give instructions for ensuring standards for emission from automobiles.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28706&sectionno=20&orderno=20&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_20_content:
  string
  line `With a`
  line `view to ensuring that the standards for emission of air pollutants from automobiles laid down by the State`
  line `Board under clause (g) of sub-section (1) of section 17 are complied with, the State Government shall, in`
  line `consultation with the State Board, give such instructions as may be deemed necessary to the concerned`
  line `authority in charge of registration of motor vehicles under the Motor Vehicles Act, 1939 (4 of 1939), and`
  line `such authority shall, notwithstanding anything contained in that Act or the rules made thereunder be`
  line `bound to comply with such instructions.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (28707)
  sectionNo (21)
  orderNo 21
  title `Restrictions on use of certain industrial plants.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00004_198114_1517807322114&sectionId=28707&sectionno=21&orderno=21&orgactid=AC_CEN_16_18_00004_198114_1517807322114
obj_root_law_sections_21_content:
  string
  line ^1
  line `[(1) No person shall establish or operate any`
  line `industrial plant in an air pollution control area unless the previous consent of the State Board has been`
  line `obtained in pursuance of an application made by such person in accordance with the provisions of this`
  line `section:`
  line
  line `Provided that the Central Government may in consultation with the Central Pollution Control Board, by notification in the Official Gazette, exempt certain categories of industrial plants from the application of the provisions of this sub-section..]`
  line
  line `(2) An application for consent of the State Board under sub-section (1) shall be accompanied by such`
  line `fees as may be prescribed and shall be made in the prescribed form and shall contain the particulars of the`
  line `industrial plant and such other particulars as may be prescribed:`
  line
  line `Provided that where any person, immediately before the declaration of any area as an air pollution`
  line `control area, operates in such area any industrial plant, ^2***such person shall make the application under`
  line `this sub-section within such period (being not less than three months from the date of such declaration) as`
  line
  line `may be prescribed and where such person makes such application, he shall be deemed to be operating`
  line `such industrial plant with the consent of the State Board until the consent applied for has been refused.`
  line
  line `(3) The State Board may make such inquiry as it may deem fit in respect of the application for`
  line `consent referred to in sub-section (1) and in making any such inquiry, shall follow such procedure as may`
  line `be prescribed.`
  line
  line `(4) Within a period of four months after the receipt of the application for consent referred to in`
  line `sub-section (1), the State Board shall, by order in writing, ^3`
  line `[and for reasons to be recorded in the order,`
  line `grant the consent applied for subject to such conditions and for such period as may be specified in the`
  line `order, or refuse such consent]:`
  line
  line ^4
  line `[Provided that it shall be open to the State Board to cancel such consent before the expiry of the`
  line `period for which it is granted or refuse further consent after such expiry if the conditions subject to which`
  line `such consent has been granted are not fulfilled:`
  line
  line `Provided further that before cancelling a consent or refusing a further consent under the first`
  line `provision, a reasonable opportunity of being heard shall be given to the person concerned.]`
  line
  line `(5) Every person to whom consent has been granted by the State Board under sub-section (4), shall`
  line `comply with the following conditions, namely:--`
  line
  line `(i) the control equipment of such specifications as the State Board may approve in this behalf`
  line `shall be installed and operated in the premises where the industry is carried on or proposed to be`
  line `carried on;`
  line
  line `(ii) the existing control equipment, if any, shall be altered or replaced in accordance with the`
  line `directions of the State Board;`
  line
  line `(iii) the control equipment referred to in clause (i) or clause (ii) shall be kept at all times in good`
  line `running condition;`
  line
  line `(iv) chimney, wherever necessary, of such specifications as the State Board may approve in this`
  line `behalf shall be erected or re-erected in such premises; and`
  line
  line `(v) such other conditions as the State Board, may specify in this behalf; and`
  line
  line `(vi) the conditions referred to in clauses (i), (ii) and (iv) shall be complied with within such period`
  line `as the State Board may specify in this behalf:`
  line
  line `Provided that in the case of a person operating any industrial plant^5*** in an air pollution control`
  line `area immediately before the date of declaration of such area as an air pollution control area, the period so`
  line `specified shall not be less than six months:`
  line
  line `Provided further that--`
  line
  line `(a) after the installation of any control equipment in accordance with the specifications under`
  line `clause (i), or`
  line
  line `(b) after the alteration or replacement of any control equipment in accordance with the directions`
  line `of the State Board under clause (ii), or`
  line
  line `(c) after the erection or re-erection of any chimney under clause (iv),`
  line
  line `no control equipment or chimney shall be altered or replaced or, as the case may be, erected or re-erected`
  line `except with the previous approval of the State Board.`
  line
  line `(6) If due to any technological improvement or otherwise the State Board is of opinion that all or any`
  line `of the conditions referred to in sub-section (5) require or requires variation (including the change of any`
  line `control equipment, either in whole or in part), the State Board shall, after giving the person to whom consent has been granted an opportunity of being heard, vary all or any of such conditions and thereupon`
  line `such person shall be bound to comply with the conditions as so varied.`
  line
  line `(7) Where a person to whom consent has been granted by the State Board under sub-section (4)`
  line `transfers his interest in the industry to any other person, such consent shall be deemed to have been`
  line `granted to such other person and he shall be bound to comply with all the conditions subject to which it`
  line `was granted as if the consent was granted to him originally.`
obj_root_law_sections_21_footnotes:
  string
  line `1. Subs. by Act 18 of 2023, s. 2 and Schedule for sub-section (1), (w.e.f. 1-4-2024).`
  line
  line `2. The words "for the purpose of any industry specified in the Schedule" omitted by s. 9, ibid. (w.e.f. 1-4-1988).`
  line
  line `3. Subs. by Act 47 of 1987, s. 9, for certain words (w.e.f. 1-4-1988).`
  line
  line `4. Ins. by s. 9, ibid. (w.e.f. 1-4-1988).`
  line
  line `5. The words "for the purpose of any industry specified in the Schedule" omitted by s. 9, ibid. (w.e.f. 1-4-1988).`
obj_root_law_sections_21_a:
  sectionId (92292)
  sectionNo 21A
  orderNo 22
  title `Power to issue guidelines.`
