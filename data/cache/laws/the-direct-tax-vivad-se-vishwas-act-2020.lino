obj_root_law_sections_1:
  sectionId (49832)
  sectionNo (1)
  orderNo 1
  title `Short title`
  content `This Act may be called the Direct Tax Vivad se Vishwas Act, 2020.`
  footnotes obj_root_law_sections_1_footnotes
