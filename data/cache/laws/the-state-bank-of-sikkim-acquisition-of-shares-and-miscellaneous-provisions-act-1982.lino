  object
  (str title) (str `सिक्‍किम स्‍टेट बैंक (शेयरों का अर्जन) औरप्रकीर्ण उपबंध अधिनियम, 1982`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1773/3/H1982-62.pdf`)
