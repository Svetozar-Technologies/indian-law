  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00003_197657_1517807318022&sectionId=43699&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00003_197657_1517807318022
obj_root_law_sections_1_content:
  string
  line `This Act may be called the High Court at Patna (Establishment of a Permanent Bench`
  line `at Ranchi) Act, 1976.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (43700)
  sectionNo (2)
  orderNo 2
  title `Establishment of a permanent bench of High Court at Patna at Ranchi.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00003_197657_1517807318022&sectionId=43700&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00003_197657_1517807318022
obj_root_law_sections_2_content:
  string
  line `There shall be`
  line `established a permanent bench of the High Court at Patna at Ranchi, and such Judges of the High Court at`
  line `Patna, being not less than three in number, as the Chief Justice of that High Court may, from time to time,`
  line `nominate, shall sit at Ranchi in order to exercise the jurisdiction and power for the time being vested in`
  line `that High Court in respect of cases arising in the districts of Hazaribagh, Giridih, Dhanbad, Ranchi,`
  line `Palamau and Singhbhum:`
  line
  line `Provided that the Chief Justice of that High Court may, in his discretion, order that any case or class`
  line `of cases arising in any such district shall be heard at Patna.`
obj_root_law_sections_2_footnotes:
  string
  line
