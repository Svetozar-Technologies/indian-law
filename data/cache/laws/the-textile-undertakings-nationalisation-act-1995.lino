obj_root_law_sections_1:
  sectionId (12394)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12394&sectionno=1&orderno=1&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Textile Undertakings`
  line `(Nationalisation) Act, 1995.`
  line
  line `(2) The provisions of sections 31 and 32 shall come into force at once and the remaining provisions of`
  line `this Act shall be deemed to have come into force on the 1st day of April, 1994.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (12395)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12395&sectionno=2&orderno=2&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means the 1st day of April, 1994;`
  line
  line `(b) "bank" means--`
  line
  line `(i) the State Bank of India constituted under the State Bank of India Act, 1955 (23 of 1955);`
  line
  line `(ii) a subsidiary Bank as defined in the State Bank of India (Subsidiary Banks) Act, 1959`
  line `(38 of 1959);`
  line
  line `(iii) a corresponding new bank constituted under section 3 of the Banking Companies`
  line `(Acquisition and Transfer of Undertakings) Act, 1970(5 of 1970);`
  line
  line `(iv) a corresponding new bank constituted under section 3 of the Banking Companies`
  line `(Acquisition and Transfer of Undertakings) Act, 1980 (40 of 1980);`
  line
  line `(v) any other bank, being a scheduled bank as defined in clause (e) of section 2 of the Reserve`
  line `Bank of India Act, 1934 (2 of 1934);`
  line
  line `(c) "Commissioner" means a Commissioner of Payments appointed under section 17;`
  line
  line `(d) "Custodian"means a Custodian appointed under section 4 of the Textile Undertakings (Taking`
  line `Over of Management) Act, 1983 (40 of 1983) or under section 4 of the Laxmirattan and Atherton`
  line `West Cotton Mills (Taking Over of Management) Act, 1976 (98 of 1976), as the case may be;`
  line
  line `(e) "National Textile Corporation" means the National Textile Corporation Limited formed and`
  line `registered under the Companies Act, 1956 (1 of 1956);`
  line
  line `(f) "notification" means a notification published in the Official Gazette;`
  line
  line `(g) "owner", when used in relation to a textile undertaking, means any person or firm who or`
  line `which is, immediately before the appointed day, the immediate proprietor or lessee or occupier of the`
  line `textile undertaking or any part thereof, and in the case of a textile company which is being wound up`
  line `or the business whereof is being carried on by a liquidator or receiver, includes such liquidator or`
  line `receiver, and also includes any agent or manager of such owner but does not include any person or`
  line `body of persons authorised under the Textile Undertakings (Taking Over of Management) Act, 1983`
  line `(40 of 1983) or under the Laxmirattan and Atherton West Cotton Mills (Taking Over of Management)`
  line `Act, 1976 (98 of 1976) to take over the management of the whole or any part of the textile`
  line undertaking;
  line
  line `(h) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(i) "specified date" means such date as the Central Government may, for the purpose of any`
  line `provision of this Act, by notification, specify; and different dates may be specified for different`
  line `provisions of this Act;`
  line
  line `(j) "subsidiary textile corporation" means the National Textile Corporation (South Maharashtra)`
  line `Limited, the National Textile Corporation (Uttar Pradesh) Limited or any other textile corporation`
  line `formed by the National Textile Corporation as its subsidiary;`
  line
  line `(k) "textile" includes yarn or fabrics made either wholly or partly of cotton, wool, jute, synthetic`
  line `and artificial (man-made) fibres;`
  line
  line `(l) "textile company" means a company (being a company as defined in the Companies Act,`
  line `1956) (1 of 1956) specified in column (3) of the First Schedule as owning the textile undertaking`
  line `specified in the corresponding entry in column (2) of that Schedule;`
  line
  line `(m) "textile undertaking" or 'the textile undertaking" means an undertaking specified in`
  line `column (2) of the First Schedule, the management of which was before the appointed day, taken over`
  line `by the Central Government under the Textile Undertakings (Taking Over of Management) Act, 1983`
  line `(40 of 1983), or as the case may be, under the Laxmirattan and Atherton West Cotton Mills (Taking`
  line `Over of Management) Act, 1976 (98 of 1976).`
  line
  line `(2) Words and expressions used herein and not defined but defined in the Companies Act, 1956`
  line `(1 of 1956), shall have the meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (12396)
  sectionNo (3)
  orderNo 3
  title `Acquisition of rights of owners and vesting of the textile undertakings.`
  content obj_root_law_sections_3_content
  footnotes `1 Ins. by Act 36 of 2014, s. 5 (w.e.f. 24-10-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12396&sectionno=3&orderno=3&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_3_content:
  string
  line `(1) On the appointed`
  line `day, the right, title and interest of the owner in relation to every textile undertaking shall stand transferred`
  line `to, and shall vest absolutely in, the Central Government.`
  line
  line `(2) Every textile undertaking which stands vested in the Central Government by virtue of`
  line `sub-section (1) shall, immediately after it has so vested, stand transferred to, and vested in, the National`
  line `Textile Corporation.`
  line
  line ^1
  line `[(3) Notwithstanding the transfer and vesting of any textile undertaking to the National Textile`
  line `Corporation by virtue of sub-section (2), the lease-hold rights of the textile undertakings shall continue to`
  line `remain vested in the Central Government on payment of lease-hold rents and shall be discharged, for and`
  line `on behalf of that Government, by the National Textile Corporation as and when payment of such`
  line `lease-hold rents or any amount becomes due and payable.`
  line
  line `(4) Subject to sub-section (3), no court shall have jurisdiction to order divestment from the National`
  line `Textile Corporation of the property vested in it by the Central Government.]`
obj_root_law_sections_4:
  sectionId (12397)
  sectionNo (4)
  orderNo 4
  title `General effect of vesting.`
  content obj_root_law_sections_4_content
  footnotes `1 Ins. by Act 36 of 2014, s. 6 (w.e.f. 24-10-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12397&sectionno=4&orderno=4&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_4_content:
  string
  line `(1) The textile undertakings referred to in section 3 shall be deemed to`
  line `include all assets, rights, lease-holds, powers, authorities and privileges and all property, movable and`
  line `immovable, including lands, buildings, workshops, stores, instruments, machinery and equipment, cash`
  line `balances, cash on hand, reserve funds, investments and book debts pertaining to the textile undertakings`
  line `and all other rights and interests in, or arising out of, such property as were immediately before the`
  line `appointed day in the ownership, possession, power or control of the textile company in relation to the said`
  line `undertakings, whether within or outside India, and all books of account, registers and all other documents`
  line `of whatever nature relating thereto and shall also be deemed to include the liabilities and obligations`
  line `specified in sub-section (2) of section 5.`
  line
  line `(2) All property as aforesaid which have vested in the Central Government under sub-section (1) of`
  line `section 3 shall, by force of such vesting, be freed and discharged from any trust, obligation,mortgage,`
  line `charge, lien and all other incumbrances affecting it, and any attachment, injunction or decree or order of`
  line `any court or other authority restricting, the use of such property in any manner shall be deemed to have`
  line `been withdrawn.`
  line
  line `(3) Where any licence or other instrument in relation to a textile undertaking had been granted, at any`
  line `time before the appointed day to the owner by the Central Government or a State Government or any`
  line `other authority, the National Textile Corporation shall, on and from such date, be deemed to be`
  line `substituted in such licence or other instrument in place of the owner referred to therein as if such licence`
  line `or such other instrument had been granted to it and shall hold such licence or the textile undertaking`
  line `specified in such other instrument for the remainder of the period for which the owner would have held`
  line `such licence or the textile undertaking under such other instrument.`
  line
  line `(4) Every mortgagee of any property which has vested under this Act in the Central Government and`
  line `every person holding any charge, lien or other interest in, or in relation to, any such property shall give,`
  line `within such time and in such manneras may be prescribed, an intimation to the Commissioner of such`
  line `mortgage, charge, lien or other interest.`
  line
  line `(5) For the removal of doubts, it is hereby declared that the mortgagee of any property referred to in`
  line `sub-section (2) or any other person holding any charge, lien or other interest in, or in relation to, any such`
  line `property shall be entitled to claim, in accordance with his rights and interest, payment of the mortgage`
  line `money or other dues, in whole or in part, out of the amounts specified in relation to such property in the`
  line `First Schedule, but no such mortgage, charge, lien or other interest shall be enforceable against any`
  line `property which has vested in the Central Government.`
  line
  line `(6) If, on the appointed day, any suit, appeal or other proceeding of whatever nature in relation to any`
  line `property which has vested in the Central Government under section 3, instituted or preferred by or against`
  line `the textile company is pending, the same shall not abate, be discontinued or be, in any way, prejudicially`
  line `affected by reason of the transfer of the textile undertakings or of anything contained in this Act, but the`
  line `suit, appeal or other proceeding may be continued, prosecuted or enforced by or against the National`
  line `Textile Corporation.`
  line
  line `(7) Any person who, on the date on which the Textile Undertakings (Nationalisation) Ordinance,`
  line `1995 (Ord. 6 of 1995) was promulgated, was in possession of, or had under his custody or control, the`
  line `whole or any part of any textile undertaking referred to in section 3, the management of which could not`
  line `be taken over by the Central Government by reason of any decree, order or injunction of any court or`
  line `otherwise, shall deliver forthwith the possession of such undertaking or part and all books of account, registers and all other documents of whatever nature relating to such undertaking or part to the Central`
  line `Government or the National Textile Corporation or such other person as the Central Government or the`
  line `National Textile Corporation, as the case may be, may specify in this behalf.`
  line
  line ^1
  line `[(8) Notwithstanding the fact that the textile operations have been discontinued in any textile`
  line `undertaking being revived, shall for all effects and purposes be deemed that the textile operations are`
  line `being continued and no suit or proceeding shall be instituted or if instituted be maintainable against the`
  line `National Textile Corporation on the ground that it has discontinued such activity in the textile`
  line undertaking.
  line
  line `(9) For the removal of doubts, it is hereby declared that the continued deemed vesting of the leasehold`
  line `land in the Central Government shall not affect, impair or in any manner prejudice the rights of the`
  line `National Textile Corporation to prosecute or defend any proceedings as a subsequent vestee in respect`
  line `of any such lease-hold rights and no such proceedings shall fail only on account of the non-impleadment`
  line `of that Government.]`
obj_root_law_sections_5:
  sectionId (12398)
  sectionNo (5)
  orderNo 5
  title `Owner to be liable for certain prior liabilities.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12398&sectionno=5&orderno=5&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_5_content:
  string
  line `(1) Every liability, other than the liability`
  line `specified in sub-section (2), of the owner of a textile undertaking, in relation to the textile undertakings in`
  line `respect of any period prior to the appointed day, shall be the liability of such owner and shall be`
  line `enforceable against him and not against the Central Government or the National Textile Corporation.`
  line
  line `(2) Any liability arising in respect of--`
  line
  line `(a) loans advanced by the Central Government, or a State Government, or both, to a textile`
  line `undertaking (together with interest due thereon) after the management of such undertaking had been`
  line `taken over by the Central Government under section 3 of the Textile Undertakings (Taking Over of`
  line `Management) Act, 1983, (40 of 1983) or as the case may be, under section 3 of the Laxmirattan and`
  line `Atherton West Cotton Mills (Taking Over of Management) Act, 1976 (98 of 1976);`
  line
  line `(b) amounts advanced to a textile undertaking after the management of such undertaking had`
  line `been taken over by the Central Government under section 3 of the Textile Undertakings (Taking Over`
  line `of Management) Act, 1983 (40 of 1983), or as the case may be, under section 3 of the Laxmirattan`
  line `and Atherton West Cotton Mills (Taking Over of management) Act, 1976 (98 of 1976) by the`
  line `National Textile Corporation or by a State Textile Corporation, or by both, together with interest due`
  line thereon;
  line
  line `(c) wages, salaries and other dues of employees of the textile undertaking, in respect of any`
  line `period after the management of such undertaking had been taken over by the Central Government,`
  line
  line `shall, on and from the appointed day, be the liability of the Central Government and shall be discharged,`
  line `for and on behalf of that Government, by the National Textile Corporation as and when repayment of`
  line `such loans or amounts becomes due or as and when such wages, salaries or other dues become due and`
  line payable.
  line
  line `(3) For the removal of doubts, it is hereby declared that,--`
  line
  line `(a) save as otherwise expressly provided in this section or in any other section of this Act, no`
  line `liability, other than the liability specified in sub-section (2), in relation to a textile undertaking, in`
  line `respect of any period prior to the appointed day, shall be enforceable against the Central Government`
  line `or the National Textile Corporation;`
  line
  line `(b) no award, decree or order of any court, tribunal or other authority in relation to any textile`
  line `undertaking, passed after the appointed day, in respect of any matter, claim or dispute in relation to`
  line `any matter not referred to in sub-section (2),which arosebefore that day shall be enforceable against`
  line `the Central Government or the National Textile Corporation;`
  line
  line `(c) no liability of any textile undertaking or any owner thereof in relation to any textile`
  line `undertaking before the appointed day, for the contravention of any provision of law for the time being`
  line `in force, shall be enforceable against the Central Government or the National Textile Corporation.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (12399)
  sectionNo (6)
  orderNo 6
  title `Transfer of any textile undertaking or part thereof to a subsidiary textile corporation.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12399&sectionno=6&orderno=6&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_6_content:
  string
  line `(1) The National Textile Corporation may, by order in writing, transfer any textile undertaking specified`
  line `at serial numbers 1 to 13 in the First Schedule or part of any such textile undertaking to the National`
  line `Textile Corporation (South Maharashtra) Limited and any textile undertaking specified at serial numbers`
  line `14 and 15 in the First Schedule or part of any such textile undertaking to the National Textile Corporation`
  line `(Uttar Pradesh) Limited, as the case may be, or to any other subsidiary textile corporation and any such`
  line `transfer shall be subject to such terms and conditions as may be specified in the said order.`
  line
  line `(2) The subsidiary textile corporation shall, on and from the date of such transfer, be deemed to be`
  line `substituted in the licence or other instrument referred to in sub-section (3) of section 4 in place of the`
  line `National Textile Corporation as if such licence or other instrument had been granted to the subsidiary`
  line `textile corporation, and shall hold such licence or other instrument for the remainder of the period for`
  line `which the National Textile Corporation would have held such licence or other instrument.`
  line
  line `(3) On the transfer to a subsidiary textile corporation of any textile undertaking or any part thereof,`
  line `the liabilities of the National Textile Corporation, referred to in sub-section (2) of section 5, shall, in so`
  line `far as they relate to the textile undertaking or part thereof so transferred to the subsidiary textile`
  line `corporation, become, on and from the date of such transfer, the liabilities of the subsidiary textile`
  line `corporation and shall be discharged by the subsidiary textile corporation as and when any such liability is`
  line `required to be discharged.`
  line
  line `(4) Save as otherwise expressly provided in this Act, references in this Act to the National Textile`
  line `Corporation shall, in respect of any textile undertaking or any part thereof which is transferred to a`
  line `subsidiary textile corporation, be construed as references to the subsidiary textile corporation.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (12400)
  sectionNo (7)
  orderNo 7
  title `Shares to be issued by the National Textile Corporation for the value of the assets transferred to it by the Central Government.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12400&sectionno=7&orderno=7&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_7_content:
  string
  line `(1) An amount equal to the value of the assets of a textile`
  line `undertaking transferred to, and vested in, the National Textile Corporation under sub-section (2) of`
  line `section 3, shall be deemed to be contribution made by the Central Government to the equity capital of the`
  line `National Textile Corporation; and for the contribution so made, the National Textile Corporation shall`
  line `issue (if necessary after amending its memorandum and articles of association) to the Central Government`
  line `paid-up shares, in its equity capital, having a face value equal to the amount specified against the textile`
  line `undertaking in the corresponding entry in column (4) of the First Schedule.`
  line
  line `(2) Where any liability assumed by the Central Government under this Act is taken over by the`
  line `National Textile Corporation under section 27, the Central Government shall surrender to that`
  line `Corporation the shares issued to it under sub-section (1) having the face value equal to the amount to the`
  line `extent to which the liability has been so taken over by the National Textile Corporation and thereupon the`
  line `share capital of the National Textile Corporation shall, to the extent of the face value of the shares so`
  line `surrendered, stand reduced.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (12401)
  sectionNo (8)
  orderNo 8
  title `Payment of amount to owners of textile undertakings.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12401&sectionno=8&orderno=8&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_8_content:
  string
  line `The owner of every textile undertaking`
  line `shall be given by the Central Government, in cash and in the manner specified in Chapter VI, for the`
  line `transfer to, and vesting in, it, under sub-section (1) of section 3, of such textile undertaking and the right,`
  line `title and interest of the owner in relation to such textile undertaking, an amount equal to the amount`
  line `specified against it in the corresponding entry in column (4) of the First Schedule.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (12402)
  sectionNo (9)
  orderNo 9
  title `Payment of further amount.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12402&sectionno=9&orderno=9&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_9_content:
  string
  line `(1) In consideration of the retrospective operation of the provisions`
  line `of sections 3, 4 and 5, there shall be given, in cash, by the Central Government to the owner of every`
  line `textile undertaking, the management of which was taken over by the Central Government, an amount`
  line `equal to an amount calculated at the rate specified in section 5 of the Textile Undertakings (Taking Over`
  line `of Management) Act, 1983 (40 of 1983), or as the case may be, as specified in section 5 of the`
  line `Laxmirattan and Atherton West Cotton Mills (Taking Over of Management) Act, 1976 (98 of 1976) for`
  line `the period commencing on the appointed day and ending on the date on which the Textile Undertakings`
  line `(Nationalisation) Ordinance, 1995 (Ord. 6 of 1995) was promulgated.`
  line
  line `(2) In addition to the amount referred to in section 8, there shall be given by the Central Government,`
  line `in cash, to the owner of every textile undertaking, simple interest at the rate of four per cent.per annum on`
  line `the amount specified against such owner in the corresponding entry in column (4) of the First Schedule`
  line `for the period commencing on the appointed day and ending on the date on which payment of such`
  line `amount is made by the Central Government to the Commissioner.`
  line
  line `(3) The amount representing interest calculated at the rate specified in sub-section (2) shall be given`
  line `in addition to the amount specified in the First Schedule.`
  line
  line `(4) For the removal of doubts, it is hereby declared that the liabilities of the owners in relation to the`
  line `textile undertakings which have vested in the Central Government under section 3 shall be discharged`
  line `from the amount referred to in the First Schedule and also from the amounts determined under`
  line `sub-sections (1) and (2) in accordance with the rights and interests of the creditors of the owner.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (12403)
  sectionNo (10)
  orderNo 10
  title `Management, etc., of textile undertakings.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12403&sectionno=10&orderno=10&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_10_content:
  string
  line `The National Textile Corporation or any person`
  line `which that Corporation may, by order in writing, specify, shall be entitled to exercise the powers of`
  line `general superintendence, direction, control and management of the affairs and business of a textile`
  line `undertaking, the right, title and interest of an owner in relation to which have vested in that Corporation`
  line `under sub-section (2) of section 3, and do all such things as the owner of the textile undertaking is`
  line `authorised to exercise and do.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (12404)
  sectionNo (11)
  orderNo 11
  title `Special provision for disposal of assets of the textile undertakings in certain circumstances.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12404&sectionno=11&orderno=11&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_11_content:
  string
  line `If the National Textile Corporation considers it necessary or expedient for the better`
  line `management, modernisation, restructuring or revival of a textile undertaking so to do, it may, with the`
  line `previous sanction of the Central Government, transfer, mortgage, sell or otherwise dispose of any land,`
  line `plant, machinery or any other assets of any of the textile undertakings:`
  line
  line `Provided that the proceeds of no such transfer, mortgage, sale or disposal of assets shall be utilised for`
  line `any purpose other than the purpose for which the sanction of the Central Government has been obtained.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (12405)
  sectionNo (12)
  orderNo 12
  title `Duty of persons in charge of management of textile undertakings to deliver all assets, etc.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12405&sectionno=12&orderno=12&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_12_content:
  string
  line `On the vesting of the management of a textile undertaking in the National Textile Corporation, all persons`
  line `in charge of the management of such textile undertaking immediately before such vesting shall be bound`
  line `to deliver to the National Textile Corporation all assets, books of account, registers or other documents in`
  line `their custody relating to the textile undertaking.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (12406)
  sectionNo (13)
  orderNo 13
  title Accounts.
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12406&sectionno=13&orderno=13&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_13_content:
  string
  line `The National Textile Corporation shall maintain the accounts of the textile`
  line `undertakings in accordance with the provisions of the Companies Act, 1956(1 of 1956).`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (12407)
  sectionNo (14)
  orderNo 14
  title `Employment of certain employees to continue.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12407&sectionno=14&orderno=14&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_14_content:
  string
  line `(1) Every person who is a workman within the`
  line `meaning of the Industrial Disputes Act, 1947 (14 of 1947), and has been, immediately before the`
  line `appointed day, in the employment of a textile undertaking shall become, on and from the appointed day,`
  line `an employee of the National Textile Corporation, and shall hold office or service in the National Textile`
  line `Corporation with the same rights and privileges as to pension, gratuity and other matters as would have`
  line `been admissible to him if the rights in relation to such textile undertaking had not been transferred to, and`
  line `vested in, the National Textile Corporation, and shall continue to do so unless and until his employment`
  line `in the National Textile Corporation is duly terminated or until his remuneration, terms and conditions of`
  line `employment are duly altered by the National Textile Corporation.`
  line
  line `(2) Every person who is not a workman within the meaning of the Industrial Disputes Act, 1947`
  line `(14 of 1947), and who has been, immediately before the appointed day, in the employment of a textile`
  line `undertaking shall, in so far as such person is employed in connection with the textile undertaking which`
  line `has vested in the National Textile Corporation, become, as from the appointed day, an employee of the`
  line `National Textile Corporation and shall hold his office or service therein by the same tenure, at the same remuneration and upon the same terms and conditions and with the same rights and privileges as to`
  line `pension and gratuity and other matters as he would have held the same under the textile undertaking if it`
  line `had not vested in the National Textile Corporation and shall continue to do so unless and until his`
  line `employment in the National Textile Corporation is duly terminated or until his remuneration, terms and`
  line `conditions of employment are duly altered by the National Textile Corporation.`
  line
  line `(3) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947), or in any`
  line `other law for the time being in force, the transfer of the services of any officer or other employee of a`
  line `textile undertaking to the National Textile Corporation shall not entitle such officer or other employee to`
  line `any compensation under this Act or any other law for the time being in force and no such claim shall be`
  line `entertained by any court, tribunal or other authority.`
  line
  line `(4) Where, under the terms of any contract of service or otherwise, any person whose services`
  line `become terminated or whose services become transferred to the National Textile Corporation by reason of`
  line `the provisions of this Act is entitled to any arrears of salary or wages or any payment for any leave not`
  line `availed of or other payment, not being payment by way of gratuity or pension, such person may, except to`
  line `the extent such liability has been taken over by the Central Government under section 5, enforce his claim`
  line `against the owner of the textile undertaking but not against the Central Government or the National`
  line `Textile Corporation.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (12408)
  sectionNo (15)
  orderNo 15
  title `Provident and other funds.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12408&sectionno=15&orderno=15&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_15_content:
  string
  line `(1) Where the owner of a textile undertaking has established a`
  line `provident fund, superannuation, welfare or other fund for the benefit of the persons employed in such`
  line `textile undertaking, the monies relatable to the employees, whose services have become transferred by or`
  line `under this Act to the National Textile Corporation shall, out of the monies standing, on the appointed day,`
  line `to the credit of such provident fund, superannuation, welfare or other fund, stand transferred to, and shall`
  line `vest in, the National Textile Corporation.`
  line
  line `(2) The monies which stand transferred, under sub-section (1), to the National Textile Corporation`
  line `shall be dealt with by that Corporation in such manner as maybe prescribed.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (12409)
  sectionNo (16)
  orderNo 16
  title `Transfer of employees to a subsidiary textile corporation.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12409&sectionno=16&orderno=16&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_16_content:
  string
  line `Where any textile undertaking or`
  line `any part thereof is transferred under this Act to a subsidiary textile corporation, every person referred to in`
  line `sub-section (1) and sub-section (2), of section 14 shall, on and from the date of such transfer, become an`
  line `employee of the subsidiary textile corporation, and the provisions of sections 14 and 15 shall apply to`
  line `such employee as they apply to an employee of the National Textile Corporation as if references in the`
  line `said sections to the National Textile Corporation were references to the subsidiary textile corporation.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (12410)
  sectionNo (17)
  orderNo 17
  title `Appointment of Commissioners of Payments.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12410&sectionno=17&orderno=17&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_17_content:
  string
  line `(1) For the purpose of disbursing the amounts`
  line `payable to the owner of each textile undertaking, the Central Government shall, by notification in the`
  line `Official Gazette,--`
  line
  line `(a) appoint such number of persons as it may think fit to be Commissioners of Payments; and`
  line
  line `(b) define the local limits within which the Commissioners of Payments shall exercise the powers`
  line `conferred, and perform the duties imposed, on them by or under this Act.`
  line
  line `(2) The Central Government may appoint such other persons at it may think fit to assist the`
  line `Commissioner and thereupon the Commissioner may authorise one or more of such persons also to`
  line `exercise all or any of the powers exercisable by him under this Act, and different persons may be`
  line `authorised to exercise different powers.`
  line
  line `(3) Any person authorised by the Commissioner to exercise any powers may exercise those powers in`
  line `the same manner and with the same effect as if they have been conferred on that person directly by this`
  line `Act and not by way of authorisation.`
  line
  line `(4) The salaries and allowances of the Commissioner and other persons appointed under this section`
  line `shall be defrayed out of the Consolidated Fund of India.`
  line
  line `(5) References in this Act to the Commissioner shall, where more than one Commissioner has been`
  line `appointed, be construed as references to the Commissioner in relation to the textile undertaking within the`
  line `local limits of the jurisdiction specified under clause (b) of sub-section (1).`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (12411)
  sectionNo (18)
  orderNo 18
  title `Payment by the Central Government to the Commissioner.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12411&sectionno=18&orderno=18&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_18_content:
  string
  line `(1) The Central Government`
  line `shall, within thirty days from the specified date, pay in cash to the Commissioner, for payment to the`
  line `owner of a textile undertaking, an amount equal to the amount specified against the textile undertaking in`
  line `the First Schedule and shall also pay to the Commissioner such sums as may be due to the owner of a`
  line `textile undertaking under sub-sections (1) and (2) of section 9.`
  line
  line `(2) In relation to the textile undertakings, the management of which was taken over by the Central`
  line `Government under the Textile Undertakings (Taking Over of Management) Act, 1983 (40 of 1983), there`
  line `shall be paid by the Central Government in addition to the amount referred to in sub-section (1), to the`
  line `Commissioner, in cash, such amount payable under section 5 of that Act as remains unpaid in relation to`
  line `the period commencing on the date on which such management was taken over by the Central`
  line `Government and ending on the appointed day.`
  line
  line `(3) In relation to the textile undertakings, the management of which was taken over by the Central`
  line `Government under the Laxmirattan and Atherton West Cotton Mills (Taking Over of Management) Act,`
  line `1976 (98 of 1976), there shall be paid by the Central Government [in addition to the amount referred to in`
  line `sub-section (1)], to the Commissioner, in cash, such amount payable under section 5of that Act as remains`
  line `unpaid in relation to the period commencing on the date on which such management was taken over by`
  line `the Central Government and ending on the appointed day.`
  line
  line `(4) A deposit account shall be opened by the Central Government, in favour of the Commissioner, in`
  line `the Public Account of India, and every amount paid under this Act to the Commissioner shall be`
  line `deposited by him to the credit of the said deposit account in the Public Account of India, and thereafter`
  line `the said deposit account shall be operated by the Commissioner.`
  line
  line `(5) Separate records shall be maintained by the Commissioner in respect of each textile undertaking`
  line `in relation to which payments have been made to him under this Act.`
  line
  line `(6) Interest accruing on the amounts standing to the credit of the deposit account referred to in`
  line `sub-section (4) shall inure to the benefit of the owners of the textile undertakings.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (12412)
  sectionNo (19)
  orderNo 19
  title `Certain powers of the National Textile Corporation.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12412&sectionno=19&orderno=19&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_19_content:
  string
  line `(1) The National Textile Corporation`
  line `shall be entitled to receive, up to the specified date, to the exclusion of all other persons, any money due`
  line `to the textile undertaking,realised after the appointed day, notwithstanding that the realisations pertain to a`
  line `period prior to the appointed day.`
  line
  line `(2) The National Textile Corporation may make a claim to the Commissioner with regard to every`
  line `payment made by the Custodian after the appointed day but before the date on which the Textile`
  line `Undertakings (Nationalisation) Ordinance, 1995 (Ord. 6 of 1995) was promulgated for discharging any`
  line `liability of the owner of textile undertaking in relation to any period prior to the appointed day, and every`
  line `such claim shall have priority, in accordance with the priorities attaching, under this Act, to the matter in`
  line `relation to which such liability has been discharged by the Custodian.`
  line
  line `(3) Save as otherwise provided in this Act, the liabilities in relation to a textile undertaking in respect`
  line `of any period prior to the appointed day which have not been discharged by the Custodian shall be the`
  line `liabilities of the owner of that textile undertaking.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (12413)
  sectionNo (20)
  orderNo 20
  title `Claims to be made to the Commissioner.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12413&sectionno=20&orderno=20&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_20_content:
  string
  line `Every person having a claim against the owner of a`
  line `textile undertaking shall prefer such claim before the Commissioner within thirty days from the specified`
  line `date:`
  line
  line `Provided that if the Commissioner is satisfied that the claimant was prevented by sufficient cause`
  line `from preferring the claim within the said period of thirty days, he may entertain the claim within a further`
  line `period of thirty days but not thereafter.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (12414)
  sectionNo (21)
  orderNo 21
  title `Priority of claims.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12414&sectionno=21&orderno=21&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_21_content:
  string
  line `The claims arising out of the matters specified in the Second Schedule shall`
  line `have priorities in accordance with the following principles, namely:--`
  line
  line `(a) category I shall have precedence over all other categories and category II shall have`
  line `precedence over category III and so on;`
  line
  line `(b) the claims specified in each of the categories, except category IV, shall rank equally and be`
  line `paid in full, but if the amount is insufficient to meet such claims in full, they shall abate in equal`
  line `proportions and be paid accordingly;`
  line
  line `(c) the liabilities specified in category IV shall be discharged, subject to the priorities specified in`
  line `this section, in accordance with the terms of the secured loans and the priority, inter se, of such loans;`
  line and
  line
  line `(d) the question of payment of a liability with regard to a matter specified in a lower category`
  line `shall arise only if a surplus is left after meeting all the liabilities specified in the immediately higher`
  line category.
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (12415)
  sectionNo (22)
  orderNo 22
  title `Examination of claims.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12415&sectionno=22&orderno=22&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_22_content:
  string
  line `(1) On receipt of the claims under section 20, the Commissioner shall`
  line `arrange the claims in the order of priority specified in the Second Schedule and examine the same in`
  line `accordance with the said order.`
  line
  line `(2) If, on examination of the claims, the Commissioner is of the opinion that the amount paid to him`
  line `under this Act is not sufficient to meet the liabilities specified in any lower category, he shall not be`
  line `required to examine the liabilities in respect of such lower category.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (12416)
  sectionNo (23)
  orderNo 23
  title `Admission or rejection of claims.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12416&sectionno=23&orderno=23&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_23_content:
  string
  line `(1) After examining the claims with reference to the priority`
  line `set out in the Second Schedule, the Commissioner shall fix a certain date on or before which every`
  line `claimant shall file the proof of his claim or be excluded from the benefit of the disbursement made by the`
  line Commissioner.
  line
  line `(2) Not less than fourteen days' notice of the date so fixed shall be given by advertisement in one`
  line `issue of the daily newspaper in the English language and one issue of the daily newspaper in the regional`
  line `language as the Commissioner may consider suitable, and every such notice shall call upon the claimant`
  line `to file the proof of his claim with the Commissioner within the time specified in the advertisement.`
  line
  line `(3) Every claimant who fails to file the proof of his claim within the time specified by the`
  line `Commissioner shall be excluded from the disbursements made by the Commissioner.`
  line
  line `(4) The Commissioner shall, after such investigation as may, in his opinion, be necessary and after`
  line `giving the owner of the textile undertaking an opportunity of refuting the claim and after giving the`
  line `claimants a reasonable opportunity of being heard, in writing, admit or reject the claim in whole or in`
  line part.
  line
  line `(5) The Commissioner shall have the power to regulate his own procedure in all matters arising out of`
  line `the discharge of his functions including the place or places at which he may hold his sittings and shall, for`
  line `the purpose of making any investigation under this Act, have the same powers as are vested in a civil`
  line `court under the Code of Civil Procedure, 1908 (5 of 1908), while trying a suit, in respect of the following`
  line `matters, namely:--`
  line
  line `(a) the summoning and enforcing the attendance of any witness and examining him on oath;`
  line
  line `(b) the discovery and production of any document or other material object producible as`
  line evidence;
  line
  line `(c) the reception of evidence on affidavits; and`
  line
  line `(d) the issuing of any commission for the examination of witnesses.`
  line
  line `(6) Any investigation before the Commissioner shall be deemed to be a judicial proceeding within the`
  line `meaning of sections 193 and 228 of the Indian Penal Code (45 of 1860) and the Commissioner shall be`
  line `deemed to be a civil court for the purposes of section 195 and Chapter XXVI of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974).`
  line
  line `(7) A claimant who is dissatisfied with the decision of the Commissioner may prefer an appeal`
  line `against the decision to the principal civil court of original jurisdiction within the local limits of whose`
  line `jurisdiction the textile undertaking is situated:`
  line
  line `Provided that where a person who is a Judge of a High Court is appointed to be the Commissioner,`
  line `such appeal shall lie to the High Court for the State in which the textile undertaking is situated, and such`
  line `appeal shall be heard and disposed of by not less than two Judges of that High Court.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (12417)
  sectionNo (24)
  orderNo 24
  title `Disbursement of money by the Commissioner to claimants.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12417&sectionno=24&orderno=24&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_24_content:
  string
  line `After admitting a claim under`
  line `this Act, the amount due in respect of such claim shall be credited by the Commissioner to the relevant`
  line `fund or be paid to the person or persons to whom such sums are due and on such credit or payment the`
  line `liability of the owner in respect of such claim shall stand discharged.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (12418)
  sectionNo (25)
  orderNo 25
  title `Disbursement of amounts to the owners.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12418&sectionno=25&orderno=25&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_25_content:
  string
  line `(1) If, out of the monies paid to him in relation to a`
  line `textile undertaking, there is a balance left after meeting the liabilities as specified in the Second Schedule,`
  line `the Commissioner shall disburse such balance to the owner of such textile undertaking.`
  line
  line `(2) Before making any payment to the owner of any textile undertaking under sub-section (1), the`
  line `Commissioner shall satisfy himself as to the right of such person to receive the whole or any part of such`
  line `amount, and in the event of there being a doubt or dispute as to the right of the person to receive the`
  line `whole or any part of the amount referred to in sections 8 and 9, the Commissioner shall refer the matter to`
  line `the court and make the disbursement in accordance with the decision of that court.`
  line
  line `(3) For the removal of doubts, it is hereby declared that the entries in column (3) of the First Schedule`
  line `shall not be deemed to be conclusive as to the right, title and interest of any person in relation to any`
  line `textile undertaking specified in the corresponding entries in column (2) of the said Schedule and evidence`
  line `shall be admissible to establish the right, title and interest of any person in relation to such textile`
  line undertaking.
  line
  line `(4) Where any machinery, equipment or other property in a textile undertaking has vested in the`
  line `National Textile Corporation, but such machinery, equipment or other property does not belong to the`
  line `owner of such textile undertaking, the amount specified in column (4) of the First Schedule against such`
  line `textile undertaking shall, on a reference made to it by the Commissioner, be apportioned by the court`
  line `between the owner of such textile undertaking and the owner of such machinery, equipment or other`
  line `property having due regard to the value of such machinery, equipment or other property on the appointed`
  line day.
  line
  line `Explanation. -- In this section, "court", in relation to a textile undertaking, means the principal civil`
  line `court of original jurisdiction within the local limits of whose jurisdiction the textile undertaking is`
  line situated.
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (12419)
  sectionNo (26)
  orderNo 26
  title `Undisbursed or unclaimed amounts to be deposited to the general reserve account.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12419&sectionno=26&orderno=26&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_26_content:
  string
  line Any
  line `money paid to the Commissioner which remains undisbursed or unclaimed for a period of three years`
  line `from the last day on which the disbursement was made, shall be transferred by the Commissioner to the`
  line `general revenue account of the Central Government; but a claim to any money so transferred may be`
  line `preferred to the Central Government by the person entitled to such payment and shall be dealt with as if`
  line `such transfer had not been made, the order, if any, for payment of the claim being treated as an order for`
  line `the refund of revenue.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (12420)
  sectionNo (27)
  orderNo 27
  title `Assumption of liability.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12420&sectionno=27&orderno=27&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_27_content:
  string
  line `(1) Where any liability of the owner of a textile undertaking arising`
  line `out of any item specified in category I of the Second Schedule is not discharged fully by the`
  line `Commissioner out of the amount paid to him under this Act, the Commissioner shall intimate in writing`
  line `to the Central Government the extent of the liability which remains undischarged, and that liability shall`
  line `be assumed by the Central Government.`
  line
  line `(2) The Central Government may, by order, direct the National Textile Corporation to take over any`
  line `liability assumed by that Government under sub-section (1), and on receipt of such direction, it shall be`
  line `the duty of the National Textile Corporation to discharge such liability.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (12421)
  sectionNo (28)
  orderNo 28
  title `Management to continue to vest in the custodian until alternative arrangements are made.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12421&sectionno=28&orderno=28&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_28_content:
  string
  line `Notwithstanding the vesting, under this Act, of a textile undertaking in the National Textile`
  line Corporation,--
  line
  line `(a) the Custodian who has been managing the affairs of such undertaking before the date on`
  line `which the Textile Undertakings (Nationalisation) Ordinance, 1995 (Ord. 6 of 1995) was promulgated`
  line `shall, until alternative arrangements have been made by the National Textile Corporation, continue to`
  line `manage the affairs of such undertakings as if the Custodian had been authorised by the National`
  line `Textile Corporation to manage the affairs of such undertaking; and`
  line
  line `(b) the Custodian or any person authorised by him for this purpose shall,until alternative`
  line `arrangements have been made by the National Textile Corporation, continue to be authorised to`
  line `operate, in relation to the textile undertaking, any account of such undertaking in a bank as if such`
  line `Custodian or the person authorised by the Custodian had been authorised by the National Textile`
  line `Corporation to operate such account.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (12422)
  sectionNo (29)
  orderNo 29
  title `Act to override all other enactments.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12422&sectionno=29&orderno=29&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_29_content:
  string
  line `The provisions of this Act shall have effect`
  line `notwithstanding anything inconsistent therewith contained in any other law for the time being in force or`
  line `in any instrument having effect by virtue of any law other than this Act or in any decree or order of any`
  line `court, tribunal or authority.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (12423)
  sectionNo (30)
  orderNo 30
  title `Contracts to cease to have effect unless ratified by the National Textile Corporation.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12423&sectionno=30&orderno=30&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_30_content:
  string
  line `(1)`
  line `Every contract entered into by the owner or occupier of any textile undertaking for any service, sale or`
  line `supply and in force immediately before the appointed day shall, on and from the expiry of one hundred`
  line `and twenty days from the date on which the Textile Undertakings (Nationalisation) Ordinance, 1995`
  line `(Ord. 6 of 1995) was promulgated, cease to have effect unless such contract is before the expiry of that`
  line `period, ratified, in writing, by the National Textile Corporation and in ratifying such contract the National`
  line `Textile Corporation may make such alterations or modifications therein as it may think fit:`
  line
  line `Provided that the National Textile Corporation shall not omit to ratify a contract, and shall not make`
  line `any alteration or modification in a contract, unless it is satisfied that such contract is unduly onerous or`
  line `has been entered into in bad faith or is detrimental to the interests of the textile undertaking.`
  line
  line `(2) The National Textile Corporation shall not omit to ratify a contract or make any alteration or`
  line `modification therein except after giving to the parties to the contract a reasonable opportunity of being`
  line `heard and except after recording in writing its reasons for refusal to ratify the contract or for making any`
  line `alteration or modification therein.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (12424)
  sectionNo (31)
  orderNo 31
  title Penalties.
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12424&sectionno=31&orderno=31&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_31_content:
  string
  line `Any person who,--`
  line
  line `(a) having in his possession, custody or control any property forming part of a textile`
  line `undertaking, wrongfully withholds such property from the Central Government or the National`
  line `Textile Corporation, or any person authorised by that Government or Corporation, as the case may be,`
  line `in this behalf, or`
  line
  line `(b)wrongfully obtains possession of, or retains, any property forming part of the textile`
  line `undertaking or wilfully withholds or fails to furnish to the Central Government, the National Textile`
  line `Corporation or any person specified by that Government, or Corporation, as the case may be, any`
  line `document relating to such textile undertaking which may be in his possession, custody or control or`
  line `fails to deliver to the National Textile Corporation or any person specified by that Corporation any`
  line `assets, books of account, registers or other documents in his custody relating to the textile`
  line `undertaking, or`
  line
  line `(c) wrongfully removes or destroys any property forming part of any textile undertaking or`
  line `prefers any claim under this Act which he knows or has reasonable cause to believe to be false or`
  line `grossly inaccurate,`
  line
  line `shall be punishable with imprisonment for a term which may extend to two years, or with fine which may`
  line `extend to ten thousand rupees, or with both.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (12425)
  sectionNo (32)
  orderNo 32
  title `Offences by companies.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12425&sectionno=32&orderno=32&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_32_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed was in charge of, and was responsible`
  line `to, the company for the conduct of the business of the company as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall be deemed to be guilty of`
  line `that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (12426)
  sectionNo (33)
  orderNo 33
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12426&sectionno=33&orderno=33&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_33_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government or any officer of that Government or the Custodian or the National`
  line `Textile Corporation or any subsidiary textile corporation or any officer or other person authorised by`
  line `either of such Corporations for anything which is in good faith done or intended to be done under this`
  line Act.
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (12427)
  sectionNo (34)
  orderNo 34
  title `Textile companies not to be wound up by the court.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12427&sectionno=34&orderno=34&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_34_content:
  string
  line `No proceeding for the winding up of a`
  line `textile company, the right, title and interest in relation to the textile undertaking owned by which have`
  line `vested in the National Textile Corporation under this Act or for the appointment of a receiver in respect of`
  line `the business of the textile undertaking shall lie or be proceeded with in any court except with consent of`
  line `the Central Government.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (12428)
  sectionNo (35)
  orderNo 35
  title `Delegation of powers.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12428&sectionno=35&orderno=35&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_35_content:
  string
  line `(1) The Central Government may, by notification, direct that all or any`
  line `of the powers exercisable by it under this Act, other than the power under section 36, may also be`
  line `exercised by any person or persons as may be specified in the notification.`
  line
  line `(2) Whenever any delegation of power is made under sub-section (1), the person to whom such power`
  line `has been delegated shall act under the direction, control and supervision of the Central Government.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (12429)
  sectionNo (36)
  orderNo 36
  title `Power to make rules.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12429&sectionno=36&orderno=36&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_36_content:
  string
  line `(1) The Central Government may, by notification,make rules to carry out`
  line `the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the time within which and the manner in which an intimation referred to in sub-section (4) of`
  line `section 4 shall be given;`
  line
  line `(b) the manner in which monies in any provident or other fund referred to in section 15 shall be`
  line `dealt with;`
  line
  line `(c)any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made by the Central Government under this Act shall be laid, as soon as may be after it`
  line `is made before each House of Parliament, while it is in session, for a total period of thirty days which may`
  line `be comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (12430)
  sectionNo (37)
  orderNo 37
  title `Power to remove difficulties.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12430&sectionno=37&orderno=37&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_37_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order not inconsistent with the provisions of this Act, remove`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of two years from the date on`
  line `which the Textile Undertakings (Nationalisation) Ordinance, 1995 (Ord. 6 of 1995) was promulgated.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (12431)
  sectionNo (38)
  orderNo 38
  title `Repeal and saving.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12431&sectionno=38&orderno=38&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_38_content:
  string
  line `(1) The Textile Undertakings (Nationalisation) Ordinance, 1995`
  line `(Ord. 6 of 1995), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (12432)
  sectionNo (39)
  orderNo 39
  title Validation.
  content obj_root_law_sections_39_content
  footnotes `1 Ins. by Act 36 of 2014, s. 7 (w.e.f. 24-10-2014)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00006_199539_1517807323431&sectionId=12432&sectionno=39&orderno=39&orgactid=AC_CEN_20_25_00006_199539_1517807323431
obj_root_law_sections_39_content:
  string
  line ^1
  line `[39. Validation.-- Notwithstanding anything contained in any judgment, decree or order of any`
  line `court, tribunal or other authority,--`
  line
  line `(a) the provisions of this Act, as amended by the Textile Undertakings (Nationalisation) Laws`
  line `(Amendment and Validation) Act, 2014 (36 of 2014), shall have and shall be deemed always to have`
  line `effect for all purposes as if the provisions of this Act, as amended by the said Act, had been in force at`
  line `all material times;`
  line
  line `(b) any lease-hold property divested from the National Textile Corporation to any person under`
  line `the provisions of this Act, as it stood immediately before the commencement of the Textile`
  line `Undertakings (Nationalisation) Laws (Amendment and Validation) Act, 2014 (36 of 2014), shall`
  line `stand transferred to and vest or continue to vest, free from all encumbrances, in the National Textile`
  line `Corporation in the same manner as it was vested in the National Textile Corporation before such`
  line `divesting of that property under the provisions of this Act as if the provisions of this Act, as amended`
  line `by the aforesaid Act, were in force at all material times;`
  line
  line `(c) no suit or other proceedings shall, without prejudice to the generality of the foregoing`
  line `provisions, be maintained or continued in any court or tribunal or authority for the enforcement of any`
  line `decree or order or direction given by such court or tribunal or authority, notwithstanding any`
  line `undertaking filed by the National Textile Corporation in any court or tribunal or authority, directing`
  line `divestment of such lease-hold property from the National Textile Corporation vested in it under`
  line `section 3 of this Act, as it stood before the commencement of the Textile Undertakings`
  line `(Nationalisation) Laws (Amendment and Validation) Act, 2014 (36 of 2014), and such lease-hold`
  line `property shall continue to vest in the National Textile Corporation under section 3 of this Act, as`
  line `amended by the aforesaid Act, as if the said section was in force at all material times;`
  line
  line `(d) any transfer of any property, vested in the National Textile Corporation, by virtue of any order`
  line `of attachment, seizure or sale in execution of a decree of a civil court or orders of any tribunal or`
  line `other authority in respect of lease-hold property vested in the National Textile Corporation which is`
  line `contrary to the provisions of this Act, as amended by the Textile Undertakings (Nationalisation) Laws`
  line `(Amendment and Validation) Act, 2014 (36 of 2014), shall be deemed to be null and void and`
  line `notwithstanding such transfer, continue to vest in the National Textile Corporation under this Act.]`
