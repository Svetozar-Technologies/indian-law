obj_root_law:
  slug the-textile-undertakings-nationalisation-act-1995
  handle (1976)
  collectionHandle 123456789/1362
  title `The Textile Undertakings (Nationalisation) Act, 1995`
  actNumber (39)
  enactmentDate 1995-09-08
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1976`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `कपड़ा उपक्रम (राष्‍ट्रीयकरण)अधिनियम, 1995`
  actYear (1995)
  ministry `Ministry of Textiles`
  longTitle `An Act to provide for the acquisition and transfer of the textile undertakings, and the right, title and interest of the owners in respect of the textile undertakings, specified in the First Schedule with a view to augmenting the production and distribution of different varieties of cloth and yarn so as to subserve the interests of the general public and for matters connected therewith or incidental thereto.`
  enforcementDate 01-04-1994
  notification `Ss. 31 and 32 (08-09-1995)`
  fetchedAt `2026-05-08T23:21:33.981Z`
  translations obj_root_law_translations
