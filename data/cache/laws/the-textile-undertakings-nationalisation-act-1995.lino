obj_root_law:
  object
  (str slug) (str the-textile-undertakings-nationalisation-act-1995)
  (str handle) (str 1976)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Textile Undertakings (Nationalisation) Act, 1995`)
  (str actNumber) (str 39)
  (str enactmentDate) (str 1995-09-08)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1976`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `कपड़ा उपक्रम (राष्‍ट्रीयकरण)अधिनियम, 1995`)
  (str actYear) (str 1995)
  (str ministry) (str `Ministry of Textiles`)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the textile undertakings, and the right, title and interest of the owners in respect of the textile undertakings, specified in the First Schedule with a view to augmenting the production and distribution of different varieties of cloth and yarn so as to subserve the interests of the general public and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-04-1994)
  (str notification) (str `Ss. 31 and 32 (08-09-1995)`)
  (str fetchedAt) (str `2026-05-08T23:21:33.981Z`)
  (str translations) obj_root_law_translations
