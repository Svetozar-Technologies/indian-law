obj_root_law_sections_1:
  object
  (str sectionId) (str 9605)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the High Court at Bombay
(Extension of Jurisdiction to Goa, Daman and Diu) Act, 1981.

(2) It shall come into force on such date^1
as the Central Government may, by notification in the
Official Gazette, appoint.`)
  (str footnotes) (str `1. 30th October, 1982, vide notification No. G.S.R. 592(E), dated 8th October, 1982, see Gazette of India, Extraordinary,
Part II, sec. 3(i).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9605&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_2:
  object
  (str sectionId) (str 9606)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act, unless the context otherwise requires,—

(a) "appointed day" means the date on which this Act comes into force;

(b) "Court of the Judicial Commissioner" means the Court of the Judicial Commissioner for Goa,
Daman and Diu.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9606&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_3:
  object
  (str sectionId) (str 9607)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Extension of jurisdiction of Bombay High Court to Goa, Daman and Diu.`)
  (str content) (str `(1) On and from
the appointed day, the jurisdiction of the High Court at Bombay shall extend to the Union territory of
Goa, Daman and Diu.

(2) On and from the appointed day, the Court of the Judicial Commissioner shall cease to function
and is hereby abolished:

Provided that nothing in this sub-section shall prejudice or affect the continued operation of any
notice served, injunction issued, direction given or proceedings taken before the appointed day by the
Court of the Judicial Commissioner, abolished by this sub-section, under the powers then conferred upon
that Court.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9607&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_4:
  object
  (str sectionId) (str 9608)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Jurisdiction of Bombay High Court.`)
  (str content) (str `On and from the appointed day, the High Court at
Bombay shall have, in respect of the territories included in the Union territory of Goa, Daman and Diu, all
such jurisdiction, powers and authority as, under the law in force immediately before the appointed day,
are exercisable in respect of the said territories by the Court of the Judicial Commissioner.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9608&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_5:
  object
  (str sectionId) (str 9609)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Chapter VI of Part VI of the Constitution to apply to the Bombay High Court exercising jurisdiction over the Union territory of Goa, Daman and Diu.`)
  (str content) (str `The provisions of Chapter VI of Part
VI of the Constitution shall apply to the High Court at Bombay in relation to the exercise of its
jurisdiction to the Union territory of Goa, Daman and Diu, subject to the following exceptions and
modifications, namely:—

(a) the references in the said Chapter to "State" except where it occurs in the expression
"Governor of the State" shall be construed as references to the Union territory of Goa, Daman and
Diu;

(b) in clause (1) of article 233 and in article 234, the references to the Governor of the State, and
in article 237, the reference to the Governor, shall be construed as references to the Administrator of
the Union territory of Goa, Daman and Diu;

(c) the provisions of article 233A shall not apply;

(d) in article 234, the reference to the State Public Service Commission shall be construed as a
reference to the Union Public Service Commission.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9609&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_6:
  object
  (str sectionId) (str 9610)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Special provisions relating to advocates.`)
  (str content) (str `Subject to any rule made or direction given by the
High Court at Bombay in this behalf, any person who, immediately before the appointed day, is an
advocate entitled to practise in the Court of the Judicial Commissioner shall be entitled to practise as an
advocate in the High Court at Bombay.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9610&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_7:
  object
  (str sectionId) (str 9611)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Transfer of pending proceedings from the Court of the Judicial Commissioner to the Bombay High Court.`)
  (str content) (str `(1) All proceedings pending in the Court of the Judicial Commissioner immediately before
the appointed day shall stand transferred to the High Court at Bombay.

(2) Every proceeding transferred under sub-section (1) shall be disposed of by the High Court at
Bombay as if such proceeding were entertained by that High Court.

(3) Any order made before the appointed day by the Court of the Judicial Commissioner shall, for all
purposes, have effect not only as an order of that Court but also as an order of the High Court at Bombay.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9611&sectionno=7&orderno=7&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_8:
  object
  (str sectionId) (str 9612)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str `Right to appear or act in proceedings transferred to the Bombay High Court.`)
  (str content) (str `Any person
who, immediately before the appointed day, is an advocate entitled to practise in the Court of the Judicial
Commissioner and was authorised to appear or to act in any proceedings transferred from that Court
under section 7, shall have the right to appear or to act, as the case may be, in the High Court at Bombay
in relation to those proceedings.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9612&sectionno=8&orderno=8&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_9:
  object
  (str sectionId) (str 9613)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str `Establishment of a permanent bench of Bombay High Court at Panaji.`)
  (str content) (str `On and from the
appointed day, there shall be established a permanent bench of the High Court at Bombay at Panaji and
such Judges of the High Court at Bombay, being not less than two in number, as the Chief Justice of that
High Court may, from time to time, nominate, shall sit at Panaji in order to exercise the jurisdiction and
power for the time being vested in that High Court in respect of cases arising in the Union territory of
Goa, Daman and Diu:

Provided that the Chief Justice of that High Court may, in his discretion order that any case or class of
cases arising in such territory shall be heard at Bombay.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9613&sectionno=9&orderno=9&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_10:
  object
  (str sectionId) (str 9614)
  (str sectionNo) (str 10)
  (str orderNo) (int 10)
  (str title) (str `Allocation of expenditure of the Bombay High Court.`)
  (str content) (str `The expenditure in respect of the High
Court at Bombay, including the expenditure in respect of the salaries and allowances of the Judges,
officers and servants of the High Court shall, as from the appointed day, be allocated between the State of
Maharashtra and the Union in such proportion as the President may, by order, determine.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9614&sectionno=10&orderno=10&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_11:
  object
  (str sectionId) (str 9615)
  (str sectionNo) (str 11)
  (str orderNo) (int 11)
  (str title) (str `Rule of construction.`)
  (str content) (str `References in any law in force in the Union territory of Goa, Daman and
Diu to the Court of the Judicial Commissioner shall, on and from the appointed day, be construed in
relation to that territory as references to the High Court at Bombay.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9615&sectionno=11&orderno=11&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_12:
  object
  (str sectionId) (str 9618)
  (str sectionNo) (str 12)
  (str orderNo) (int 12)
  (str title) (str Repealed.)
  (str content) (str `[Amendment of Goa, Daman and Diu Act 16 of 1965].—Rep. by the Repealing and Amending
Act, 1988 (19 of 1988) s.2 and the First Schedule (w.e.f. 31-3-1988).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9618&sectionno=12&orderno=12&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_13:
  object
  (str sectionId) (str 9619)
  (str sectionNo) (str 13)
  (str orderNo) (int 13)
  (str title) (str `Power to remove difficulties.`)
  (str content) (str `(1) If any difficulty arises in giving effect to the provisions of
this Act, the Central Government may, by order notified in the Official Gazette, make such provision, not
inconsistent with the provisions of this Act, as appears to it to be necessary or expedient for the removal
of the difficulty:

Provided that no such order shall be made after the expiry of a period of two years from the appointed
day.

(2) Every order made under this section shall be laid, as soon as may be after it is made, before each
House of Parliament, while it is in session, for a total period of thirty days which may be comprised in
one session or in two or more successive sessions, and if, before the expiry of the session immediately
following the session or the successive sessions aforesaid, both Houses agree in making any modification
in the order or both Houses agree that the order should not be made, the order shall thereafter have effect
only in such modified form or be of no effect, as the case may be; so, however, that any such modification
or annulment shall be without prejudice to the validity of anything previously done under that order.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9619&sectionno=13&orderno=13&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_sections_14:
  object
  (str sectionId) (str 9620)
  (str sectionNo) (str 14)
  (str orderNo) (int 14)
  (str title) (str `Power to adapt laws.`)
  (str content) (str `For the purpose of facilitating the application of any law in relation to the
Union territory of Goa, Daman and Diu, the Central Government may, before the expiration of two years
from the appointed day, by order, make such adaptations and modifications of the law, whether by way of
repeal or amendment, as may be necessary or expedient to give effect to the provisions of this Act and
thereupon every such law shall have effect subject to the adaptations and modifications so made until
altered, repealed or amended by a competent legislature or other competent authority.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9620&sectionno=14&orderno=14&orgactid=AC_CEN_3_3_00018_198126_1517807326176)
obj_root_law_translations:
  object
  (str hi) obj_root_law_translations_hi
obj_root_law_translations_hi:
  object
  (str title) (str `मुम्‍बई उच्‍च न्‍यायालय (गोवा, दमण और दीव पर अधिकारिता का विस्‍तारण) अधिनियम, 1981`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1783/3/H1981-26.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:52:04.470Z`)
  (str pageCount) (int 2)
  (str sections) obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
  array
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
obj_root_law_translations_hi_sections_1:
  object
  (str kind) (str page)
  (str sectionId) (str pdf-page-1)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Page 1`)
  (str content) (str `मुम्ब ईउच्च न् या यालय ( गोवा,दमणऔरदीवपर
अधिकाररताकाधवस्ता रण ) अधिधियम, 1981
(1981 काअधिधियमसंखयां क 26 )
[9 ददसम्ब र, 1981 ]
मुम्ब ईउच्च न् या यालयकीअधिकाररताकागोवा,दमणऔरदीवसंघ
राज्य क्षेत्र परधवस्ता रकरिेके धलए पणजीमेंउस
उच्च न् या यालयकीएकस्था यीन्या यपीठ स्
था धपतकरिेके धलए औरउससे
संबद्धधवषयोंकेधलयउपबन्ि
करिेकेधलए
अधिधियम
भारतगणराज्य केबत्तीसवेंवषषमेंसंसद्द्वाराधिम्ि धलधितरूपमेंयहअधिधियधमतहो: ––
1. संधक्षप्त िामऔरप्रारम्भ –– (1) इसअधिधियमकासंधक्ष प् त िाममुम्ब ईउच्च न् या यालय ( गोवा,दमणऔरदीवपर
अधिकाररताकाधवस्ता रण ) अधिधियम, 1981 है।
(2) यहउसतारीिकोप्रवृत्तहोगा,जोकेंद्रीयसरकार,राजपत्रमेंअधिसूचिाद्वाराधियतकरे।
2. पररभाषाएं –– इसअधिधियममें,जबतकदकसंदभषसेअन्य थाअधभप्रे तिहो, ––
( क ) “ धियतददि ” सेवहतारीिअधभप्रेतहैधजसकोयहअधिधियमप्रवृत्तहोताहै;
( ि ) “ न् या धयक आयुक्त कान्या यालय ” सेगोवा,दमणऔरदीवके धलए न् या धयकआयुक्त कान्या यालय
अधभप्रेतहै।
3. मुम्ब ईउच्च न् या यालयकीअधिकाररता कागोवा,दमणऔरदीवपरधवस्ता रण –– (1) धियतददिसेहीमुम्ब ईउच्च न्
या यालयकीअधिकाररताकागोवा,दमणऔरदीवसंघराज्य क्षेत्र परधवस्ता रहोगा।
(2) धियतददिसेहीन्या धयकआयुक्त कान्या यालयकायषकरिाबंदकरदेगाऔरइसकेद्वाराउसे समाप्त दकयाजा ताहै:
परन्तु इसउपिाराकीकोईबा तन्या धयकआयुक्त केन्या यालय द्व ारा,धजसेइस उपिाराद्वारासमाप्त करददया गया हैतब
उसन्या यालयकोप्रदत्तशधक्त योंकेअिीिधियतददिकेपूवषतामीलकीगईदकसीसूचिा,जारी दकए गए दकसीव्या देश, ददए गए
दकसीधिदेशया कीगईदकन्हीं कायषवाधहयोंकाप्रवतषिचालूरहिेपर ितोप्रधतकूलप्रभावडालेगीऔर िउसेप्रभाधवतकरेगी।
4. मुम्ब ईउच्च न् या यालयकीअधिकाररता –– धियतददिसेहीमुम्ब ईउच्च न् या यालयकोगोवा,दमणऔरदीवसंघ
राज्य क्षेत्र मेंसधम्म धलतराज्य क्षेत्रों कीबाबतऐसीसभीअधिकाररता,शधक्त यांऔरप्राधिकारहोंगेजोधियतददिकेठीकपूवषप्रवृत्त
धवधिकेअिीिउक्त राज्य क्षेत्रों कीबा ब तन्या धयकआयुक्त केन्या यालयद्वाराप्रयोग दकए जातेथे।
5. संधविािकेअध्या य 6 केभाग 6 कागोवा,दमणऔरदीवसंघराज्य क्षेत्र परअधिकाररताकाप्रयोगकरिेवालेमुम्ब ई
उच्च न् या यालयकोलागूहोिा –– संधविािकेभाग 6 केअध्या य 6 केउपबंिमुम्ब ईउच्च न् या यालयको,गोवा,दमणऔरदीवसंघ
राज्य क्षेत्र परउसकीअधिकाररताकेप्रयोगकेसंबंिमेंधिम्ि धलधितअपवादोंऔरउपान्त रों केअिीिरहतेहुएलागूहोंगे,अथाषत्: ––
( क ) उक्त अध्या यमें, “ राज्य ” केप्रधतधिदेशोंका,जहांवे “ राज्य केराज्य पाल ” पदमेंआतेहैंउसकेधसवाय,यह
अथषलगाया जाएगा दकवेगोवा,दमणऔरदीवसंघराज्य क्षेत्र केप्रधतधिदेशहैं;
( ि ) अिुच्छे द 233 केिंड (1) औरअिुच्छे द 234 मेंरा ज् य केराज्य पालकेप्रधतधिदे शोंकाऔरअिुच्छे द 237 में
राज्य पालकेप्रधतधि दे शकायहकायषलगायाजाएगादक वेगोवा,दमणऔरदीवसंघराज्य क्षेत्र केप्रशासककेप्रधत
धिदेशहै;
( ग ) अिुच्छे द 233 क केउपबंिला गूिहींहोंगे;
( घ ) अिुच्छे द 234 मेंलोकसेवाआयोगकेप्रधतधिदेशकायहअथषलगाया जाएगा दकवहसंघलोकसेवाआयोग
केप्रधत धिदेशहै।
6. अधिवक्ता ओं केसंबंिमेंधवशेषउपबंि –– मुम्ब ईउच्च न् या यालयद्वाराइसधिधमत्तबिाये गए दकसीधियम या दकए गए
दकसी धिदेशकेअिीिरहतेहुएकोईव्य धक्त,जोधियतददिकेठीकपूवषन्या धयकआयुक्त केन्या यालयमेंअधिवक्ता केरूपमें व्
य वसायकरिेकेधलएहकदारहै,मुम्ब ईउच्च न् या यालयमेंअधिवक्ता केरूपमेंव्य वसायकरिेकेधलएहकदारहोगा।`)
