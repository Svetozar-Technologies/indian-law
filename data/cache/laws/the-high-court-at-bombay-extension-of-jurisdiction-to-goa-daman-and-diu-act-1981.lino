obj_root_law_sections_1:
  sectionId (9605)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9605&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the High Court at Bombay`
  line `(Extension of Jurisdiction to Goa, Daman and Diu) Act, 1981.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 30th October, 1982, vide notification No. G.S.R. 592(E), dated 8th October, 1982, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (9606)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9606&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "appointed day" means the date on which this Act comes into force;`
  line
  line `(b) "Court of the Judicial Commissioner" means the Court of the Judicial Commissioner for Goa,`
  line `Daman and Diu.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (9607)
  sectionNo (3)
  orderNo 3
  title `Extension of jurisdiction of Bombay High Court to Goa, Daman and Diu.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9607&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_3_content:
  string
  line `(1) On and from`
  line `the appointed day, the jurisdiction of the High Court at Bombay shall extend to the Union territory of`
  line `Goa, Daman and Diu.`
  line
  line `(2) On and from the appointed day, the Court of the Judicial Commissioner shall cease to function`
  line `and is hereby abolished:`
  line
  line `Provided that nothing in this sub-section shall prejudice or affect the continued operation of any`
  line `notice served, injunction issued, direction given or proceedings taken before the appointed day by the`
  line `Court of the Judicial Commissioner, abolished by this sub-section, under the powers then conferred upon`
  line `that Court.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (9608)
  sectionNo (4)
  orderNo 4
  title `Jurisdiction of Bombay High Court.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9608&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_4_content:
  string
  line `On and from the appointed day, the High Court at`
  line `Bombay shall have, in respect of the territories included in the Union territory of Goa, Daman and Diu, all`
  line `such jurisdiction, powers and authority as, under the law in force immediately before the appointed day,`
  line `are exercisable in respect of the said territories by the Court of the Judicial Commissioner.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (9609)
  sectionNo (5)
  orderNo 5
  title `Chapter VI of Part VI of the Constitution to apply to the Bombay High Court exercising jurisdiction over the Union territory of Goa, Daman and Diu.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9609&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_5_content:
  string
  line `The provisions of Chapter VI of Part`
  line `VI of the Constitution shall apply to the High Court at Bombay in relation to the exercise of its`
  line `jurisdiction to the Union territory of Goa, Daman and Diu, subject to the following exceptions and`
  line `modifications, namely:—`
  line
  line `(a) the references in the said Chapter to "State" except where it occurs in the expression`
  line `"Governor of the State" shall be construed as references to the Union territory of Goa, Daman and`
  line Diu;
  line
  line `(b) in clause (1) of article 233 and in article 234, the references to the Governor of the State, and`
  line `in article 237, the reference to the Governor, shall be construed as references to the Administrator of`
  line `the Union territory of Goa, Daman and Diu;`
  line
  line `(c) the provisions of article 233A shall not apply;`
  line
  line `(d) in article 234, the reference to the State Public Service Commission shall be construed as a`
  line `reference to the Union Public Service Commission.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (9610)
  sectionNo (6)
  orderNo 6
  title `Special provisions relating to advocates.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9610&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_6_content:
  string
  line `Subject to any rule made or direction given by the`
  line `High Court at Bombay in this behalf, any person who, immediately before the appointed day, is an`
  line `advocate entitled to practise in the Court of the Judicial Commissioner shall be entitled to practise as an`
  line `advocate in the High Court at Bombay.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (9611)
  sectionNo (7)
  orderNo 7
  title `Transfer of pending proceedings from the Court of the Judicial Commissioner to the Bombay High Court.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9611&sectionno=7&orderno=7&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_7_content:
  string
  line `(1) All proceedings pending in the Court of the Judicial Commissioner immediately before`
  line `the appointed day shall stand transferred to the High Court at Bombay.`
  line
  line `(2) Every proceeding transferred under sub-section (1) shall be disposed of by the High Court at`
  line `Bombay as if such proceeding were entertained by that High Court.`
  line
  line `(3) Any order made before the appointed day by the Court of the Judicial Commissioner shall, for all`
  line `purposes, have effect not only as an order of that Court but also as an order of the High Court at Bombay.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (9612)
  sectionNo (8)
  orderNo 8
  title `Right to appear or act in proceedings transferred to the Bombay High Court.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9612&sectionno=8&orderno=8&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_8_content:
  string
  line `Any person`
  line `who, immediately before the appointed day, is an advocate entitled to practise in the Court of the Judicial`
  line `Commissioner and was authorised to appear or to act in any proceedings transferred from that Court`
  line `under section 7, shall have the right to appear or to act, as the case may be, in the High Court at Bombay`
  line `in relation to those proceedings.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (9613)
  sectionNo (9)
  orderNo 9
  title `Establishment of a permanent bench of Bombay High Court at Panaji.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9613&sectionno=9&orderno=9&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_9_content:
  string
  line `On and from the`
  line `appointed day, there shall be established a permanent bench of the High Court at Bombay at Panaji and`
  line `such Judges of the High Court at Bombay, being not less than two in number, as the Chief Justice of that`
  line `High Court may, from time to time, nominate, shall sit at Panaji in order to exercise the jurisdiction and`
  line `power for the time being vested in that High Court in respect of cases arising in the Union territory of`
  line `Goa, Daman and Diu:`
  line
  line `Provided that the Chief Justice of that High Court may, in his discretion order that any case or class of`
  line `cases arising in such territory shall be heard at Bombay.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (9614)
  sectionNo (10)
  orderNo 10
  title `Allocation of expenditure of the Bombay High Court.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9614&sectionno=10&orderno=10&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_10_content:
  string
  line `The expenditure in respect of the High`
  line `Court at Bombay, including the expenditure in respect of the salaries and allowances of the Judges,`
  line `officers and servants of the High Court shall, as from the appointed day, be allocated between the State of`
  line `Maharashtra and the Union in such proportion as the President may, by order, determine.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (9615)
  sectionNo (11)
  orderNo 11
  title `Rule of construction.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9615&sectionno=11&orderno=11&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_11_content:
  string
  line `References in any law in force in the Union territory of Goa, Daman and`
  line `Diu to the Court of the Judicial Commissioner shall, on and from the appointed day, be construed in`
  line `relation to that territory as references to the High Court at Bombay.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (9618)
  sectionNo (12)
  orderNo 12
  title Repealed.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9618&sectionno=12&orderno=12&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_12_content:
  string
  line `[Amendment of Goa, Daman and Diu Act 16 of 1965].—Rep. by the Repealing and Amending`
  line `Act, 1988 (19 of 1988) s.2 and the First Schedule (w.e.f. 31-3-1988).`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (9619)
  sectionNo (13)
  orderNo 13
  title `Power to remove difficulties.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9619&sectionno=13&orderno=13&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_13_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order notified in the Official Gazette, make such provision, not`
  line `inconsistent with the provisions of this Act, as appears to it to be necessary or expedient for the removal`
  line `of the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of two years from the appointed`
  line day.
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the order or both Houses agree that the order should not be made, the order shall thereafter have effect`
  line `only in such modified form or be of no effect, as the case may be; so, however, that any such modification`
  line `or annulment shall be without prejudice to the validity of anything previously done under that order.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (9620)
  sectionNo (14)
  orderNo 14
  title `Power to adapt laws.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00018_198126_1517807326176&sectionId=9620&sectionno=14&orderno=14&orgactid=AC_CEN_3_3_00018_198126_1517807326176
obj_root_law_sections_14_content:
  string
  line `For the purpose of facilitating the application of any law in relation to the`
  line `Union territory of Goa, Daman and Diu, the Central Government may, before the expiration of two years`
  line `from the appointed day, by order, make such adaptations and modifications of the law, whether by way of`
  line `repeal or amendment, as may be necessary or expedient to give effect to the provisions of this Act and`
  line `thereupon every such law shall have effect subject to the adaptations and modifications so made until`
  line `altered, repealed or amended by a competent legislature or other competent authority.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `मुम्‍बई उच्‍च न्‍यायालय (गोवा, दमण और दीव पर अधिकारिता का विस्‍तारण) अधिनियम, 1981`
