obj_root_law_sections_1:
  sectionId (8781)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8781&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the English and Foreign Languages`
  line `UniversityAct, 2006.`
  line
  line `(2) It shall come into force on such date^1 as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 3rd August 2007, vide notification No. S.O. 1350(E), dated 1st August, 2007, see Gazette of India, Extraordinary, Part II, sec.`
  line `3(ii)`
obj_root_law_sections_2:
  sectionId (8782)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8782&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the context otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(d) "Chancellor", "Vice-Chancellor" and "Pro-Vice-Chancellor" mean, respectively, the`
  line `Chancellor, Vice-Chancellor and Pro-Vice-Chancellor of the University;`
  line
  line `(e) "College" means a College maintained by the University;`
  line
  line `(f) "Court" means the Court of the University;`
  line
  line `(g) "Department" means a Department of Studies and includes a Centre of Studies;`
  line
  line `(h) "distance education system" means the system of imparting education through any means of`
  line `communication, such as broadcasting, telecasting, correspondence courses, seminars, contact`
  line `programmes or the combination of any two or more such means;`
  line
  line `(i) "employee" means any person appointed by the University and includes teachers and other`
  line `staff of the University;`
  line
  line `(j) "Executive Council" means the Executive Council of the University;`
  line
  line `(k) "Hall" means a unit of residence or of corporate life for the students of the University, or of a`
  line `College or an Institution, maintained by the University;`
  line
  line `(l) "Institution" means an academic institution, not being a College, maintained by the University;`
  line
  line `(m) "Principal" means the head of a College or an Institution and includes where there is no`
  line `Principal, the person for the time being duly appointed to act as Principal, and, in the absence of the`
  line `Principal or the acting Principal, a Vice-Principal duly appointed as such;`
  line
  line `(n) "recognised institution" means an institution of higher learning recognised by the University;`
  line
  line `(o) "recognised teachers" means persons working in any recognised institution and recognised by`
  line `the University for the purpose of imparting instruction or conducting research or both;`
  line
  line `(p) "School" means a School of Studies of the University;`
  line
  line `(q) "Statutes", "Ordinances" and "Regulations" mean, respectively, the Statutes, Ordinances and`
  line `Regulations of the University for the time being in force;`
  line
  line `(r) "teachers of the University" means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instruction or conducting research in the University or in any College`
  line `or Institution maintained by the University and are designated as teachers by the Ordinances;`
  line
  line `(s) "University" means the Central Institute of English, Hyderabad Society founded by the`
  line `Central Government at Hyderabad in 1958 as a Society registered under the Hyderabad Society`
  line `Registration Act, 1350 (Act 1 of 1350 Fasli) which was renamed as Central Institute of English and`
  line `Foreign Languages, Hyderabad Society in 1972 and declared in 1973 as an Institution deemed to be a`
  line `University under section 3 of the University Grants Commission Act, 1956 (3 of 1956);and which is`
  line `incorporated as a university under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (8783)
  sectionNo (3)
  orderNo 3
  title `Establishment of the University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8783&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established, in the State of Andhra Pradesh,`
  line `a University by the name of "The English and Foreign Languages University".`
  line
  line `(2) The headquarters of the University shall be at Hyderabad, campuses at Lucknow and Shillong;`
  line `and it may establish campuses at such other places as it may deem fit.`
  line
  line `(3) The first Chancellor, the first Vice-Chancellor and the first members of the Court, the Executive`
  line `Council and the Academic Council, and all persons who may hereafter become such officers or members,`
  line `so long as they continue to hold such office or membership, shall constitute the University.`
  line
  line `(4) The University shall have perpetual succession and a common seal and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (8784)
  sectionNo (4)
  orderNo 4
  title `Dissolution of the Central Institute of English and Foreign Languages, Hyderabad Society and transfer of all the properties and effect of establishment of the University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8784&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_4_content:
  string
  line `On and from the`
  line `commencement of this Act,--`
  line
  line `(i) the Society known as the Central Institute of English and Foreign Languages, Hyderabad`
  line `Society, shall be dissolved, and all properties, movable or immovable, and all rights, powers and`
  line `privileges of the said Society shall be transferred to and vest in the University and shall be applied to`
  line `the objects and purposes for which the University is established;`
  line
  line `(ii) all debts, liabilities and obligations of the said Society shall be transferred to the University`
  line `and shall thereafter be discharged and satisfied by it;`
  line
  line `(iii) all references in any enactment to the said Society shall be construed as references to the`
  line University;
  line
  line `(iv) any will, deed or other document, whether made or executed before or after the`
  line `commencement of this Act, which contains any bequest, gift or trust in favour of the said Society`
  line `shall be construed as if the University was therein named instead of the Society;`
  line
  line `(v) subject to the provisions of this Act, every person employed immediately before the`
  line `commencement of this Act in the Central Institute of English and Foreign Languages, Hyderabad,`
  line `shall hold such employment in the University by the same tenure and on the same terms and`
  line `conditions and with the same rights and privileges as to pension and gratuity as he would have held`
  line `under the Central Institute of English and Foreign Languages, Hyderabad, if this Act had not been`
  line passed.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (8785)
  sectionNo (5)
  orderNo 5
  title `Objects of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8785&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_5_content:
  string
  line `The objects of the University shall be to disseminate and advance`
  line `knowledge by providing instructional, research and extension facilities in the teaching of English and`
  line `Foreign Languages and Literature in India; to train language teachers in methods and approaches`
  line `appropriate to the Indian context; to provide expertise in language and teacher education to foreign`
  line `professionals; to evolve indigenous ways of testing of languages proficiency; to make provisions for innovative teaching-learning materials in both print and electronic media; to take appropriate measures`
  line `for inter-disciplinary studies and research in Literary and Cultural Studies; and to develop critical`
  line `intercultural understanding of the civilizations.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (8786)
  sectionNo (6)
  orderNo 6
  title `Powers of the University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8786&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_6_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instructions in the relevant branches of learning and to make provision for the`
  line `advancement and dissemination of knowledge for furtherance of its objects;`
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing, on persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(iii) to organise and to undertake extramural studies, training and extension services;`
  line
  line `(iv) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(v) to provide facilities through the distance education system to such persons as it may`
  line determine;
  line
  line `(vi) to institute Principalships, Professorships, Readerships, Lecturerships and other teaching or`
  line `academic positions, required by the University and to appoint persons to such Principalships,`
  line
  line `Professorships, Readerships, Lecturerships or other teaching or academic positions;`
  line
  line `(vii) to recognise an institution of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(viii) to appoint persons working in any other University or educational institution as teachers of`
  line `the University for a specified period;`
  line
  line `(ix) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(x) to co-operate or collaborate or associate with any other University or authority or institution of`
  line `higher learning in such manner and for such purposes as the University may determine;`
  line
  line `(xi) to establish, with the prior approval of the Central Government, such Campuses, Centres and`
  line `specialised laboratories or other units for research and instruction, within or outside India, as are, in`
  line `the opinion of the University necessary for the furtherance of its objects;`
  line
  line `(xii) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xiii) to establish and maintain Colleges, Institutions and Halls;`
  line
  line `(xiv) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions, industrial or other organisations, as the University may deem`
  line necessary;
  line
  line `(xv) to organise and conduct refresher courses, workshops, seminars and other programmes for`
  line `teachers, evaluators and other academic staff;`
  line
  line `(xvi) to recognise, guide, supervise and control Halls not maintained by the University and other`
  line `accommodation for students, and to withdraw any such recognition;`
  line
  line `(xvii) to appoint on contract or otherwise visiting Professors, Emeritus Professors, Consultants,`
  line `Scholars and such other persons who may contribute to the advancement of the objects of the`
  line University;
  line
  line `(xviii) to confer autonomous status on a College or an Institution or a Department, as the case`
  line `may be, in accordance with the Statutes;`
  line
  line `(xix) to determine standards of admission to the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xx) to demand and receive payment of fees and other charges;`
  line
  line `(xxi) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xxii) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xxiii) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxiv) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(xxv) to receive benefactions, donations and gifts and to acquire, hold and manage, and to dispose`
  line `of, with the previous approval of the Central Government, any property, movable or immovable,`
  line `including trust and endowment properties for the purposes of the University;`
  line
  line `(xxvi) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University;`
  line
  line `(xxvii) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (8787)
  sectionNo (7)
  orderNo 7
  title Jurisdiction.
  content `The jurisdiction of the University shall extend to the whole of India.`
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8787&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (8788)
  sectionNo (8)
  orderNo 8
  title `University open to all classes, castes and creeds.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8788&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_8_content:
  string
  line `The University shall be open to persons of`
  line `either sex and of whatever caste, creed, race or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person, any test whatsoever of religious belief or profession in order to entitle him to be`
  line `appointed as a teacher of the University or to hold any other office therein or be admitted as a student in`
  line `the University or to graduate thereat or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for the employment or admission of women, persons with disabilities or of persons belonging`
  line `to the weaker sections of the society and, in particular, of the Scheduled Castes and the Scheduled Tribes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (8789)
  sectionNo (9)
  orderNo 9
  title Visitor.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8789&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_9_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University, including Colleges and Institutions maintained by it, and to submit a report thereon; and`
  line `upon receipt of that report, the Visitor may, after obtaining the views of the Executive Council thereon`
  line `through the Vice-Chancellor, take such action and issue such directions as he considers necessary in`
  line `respect of any of the matters dealt with in the report and the University shall be bound to comply with`
  line `such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection, to be made by such person or persons as he`
  line `may direct, of the University, its buildings, libraries, laboratories and equipment and of any College or`
  line `Institution maintained by the University; and also of the examinations, teaching and other work conducted`
  line `or done by the University and to cause an inquiry to be made in like manner in respect of any matter`
  line `connected with theadministration or finances of the University, Colleges or Institutions.`
  line
  line `(4) The Visitor shall, in every matter referred to in sub-section (3), give notice to the University of his`
  line `intention to cause an inspection or inquiry to be made, and the University shall have the right to make`
  line `such representations to the Visitor, as it may considernecessary.`
  line
  line `(5) After considering the representations, if any, made by the University, the Visitor may cause to be`
  line `made such inspection or inquiry as is referred to in sub-section (3).`
  line
  line `(6) Where any inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative, who shall have the right to be present and be heard at such`
  line `inspection or inquiry.`
  line
  line `(7) The Visitor may address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry together with such views and advice with regard to the action to be taken thereon, as the Visitor`
  line `may be pleased to offer, and on receipt of address made by the Visitor, the Vice-Chancellor shall communicate, to the Executive Council, the views of the Visitor with such advice as the Visitor may offer`
  line `upon the action to be taken thereon.`
  line
  line `(8) The Executive Council shall communicate through the Vice-Chancellor to the Visitor such action,`
  line `if any, as it proposes to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(9) Where the Executive Council does not, within a reasonable time, take action to the satisfaction of`
  line `the Visitor, the Visitor may, after considering any explanation furnished or representation made by the`
  line `Executive Council, issue such directions as he may think fit and the Executive Council shall comply with`
  line `such directions.`
  line
  line `(10) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annual any proceeding of the University which is not in conformity with the Act, the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the Registrar to show cause why such`
  line `an order should not be made, and, if any cause is shown within a reasonable time, he shall consider the`
  line same.
  line
  line `(11) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (8790)
  sectionNo (10)
  orderNo 10
  title `The Chief Rector.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8790&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_10_content:
  string
  line `The Governor of the State of Andhra Pradesh shall be the Chief Rector of`
  line `the University.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (8791)
  sectionNo (11)
  orderNo 11
  title `Officers of the University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8791&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_11_content:
  string
  line `The following shall be the officers of the University,--`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Pro-Vice-Chancellor;`
  line
  line `(4) the Deans of Schools;`
  line
  line `(5) the Registrar;`
  line
  line `(6) the Finance Officer;`
  line
  line `(7) the Controller of Examinations;`
  line
  line `(8) the Librarian; and`
  line
  line `(9) such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (8792)
  sectionNo (12)
  orderNo 12
  title `The Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8792&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_12_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the head of the University and shall, if present,`
  line `preside at the Convocations of the University held for conferring degrees and meetings of the Court.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (8793)
  sectionNo (13)
  orderNo 13
  title `The Vice-Chancellor.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8793&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_13_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner and on such terms and conditions of service as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority at its next meeting the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been taken, it`
  line `may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to represent against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated to him and thereupon the ExecutiveCouncil may confirm, modify or reverse the action taken by the ViceChancellor.`
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the University is`
  line `beyond the powers of the authority conferred by the provisions of this Act, the Statutes or the Ordinances`
  line `or that any decision taken is not in the interest of the University, may ask the authority concerned to`
  line `review its decision within sixty days of such decision and if the authority refuses to review the decision`
  line `either in whole or in part or no decision is taken by it within the said period of sixty days, the matter shall`
  line `be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (8794)
  sectionNo (14)
  orderNo 14
  title `The Pro-Vice-Chancellor.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8794&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_14_content:
  string
  line `The Pro-Vice-Chancellor shall be appointed in such manner and on`
  line `such terms and conditions of service, and shall exercise such powers and perform such duties, as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (8795)
  sectionNo (15)
  orderNo 15
  title `The Deans of Schools.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8795&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_15_content:
  string
  line `Every Dean of School shall be appointed in such manner and shall`
  line `exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (8796)
  sectionNo (16)
  orderNo 16
  title `The Registrar.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8796&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_16_content:
  string
  line `(1) The Registrar shall be appointed in such manner and on such terms and conditions of service as may be prescribed by the Statutes.`
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such powers and perform such duties as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (8797)
  sectionNo (17)
  orderNo 17
  title `The Finance Officer.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8797&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_17_content:
  string
  line `The Finance Officer shall be appointed in such manner and on such terms`
  line `and conditions of service, and shall exercise such powers and perform such duties, as may be prescribed`
  line `by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (8798)
  sectionNo (18)
  orderNo 18
  title `The Controller of Examinations.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8798&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_18_content:
  string
  line `The Controller of Examinations shall be appointed in such`
  line `manner and shall exercise such powers and perform such duties, as may be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (8799)
  sectionNo (19)
  orderNo 19
  title `The Librarian.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8799&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_19_content:
  string
  line `The Librarian shall be appointed in such manner and on such terms and`
  line `conditions of service, and shall exercise such powers and perform such duties, as may be prescribed by`
  line `the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (8800)
  sectionNo (20)
  orderNo 20
  title `Other officers.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8800&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_20_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (8801)
  sectionNo (21)
  orderNo 21
  title `Authorities of the University.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8801&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_21_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(1) the Court;`
  line
  line `(2) the Executive Council;`
  line
  line `(3) the Academic Council;`
  line
  line `(4) the Schools of Studies;`
  line
  line `(5) the Finance Committee; and`
  line
  line `(6) such other authorities as may be declared by the Statutes to be the authorities of the`
  line University.
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (8802)
  sectionNo (22)
  orderNo 22
  title `The Court.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8802&sectionno=22&orderno=22&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_22_content:
  string
  line `(1) The constitution of the Court and the term of office of its members shall be`
  line `prescribed by the Statutes:`
  line
  line `Provided that such number of members as may be prescribed by the Statutes shall be elected from`
  line `among the teachers, employees and students of the University.`
  line
  line `(2) Subject to the provisions of this Act, the Court shall have the following powers and functions,`
  line `namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the University`
  line `and the audit report on such accounts;`
  line
  line `(c) to advise the Visitor in respect of any matter which may be referred to it for advice; and`
  line
  line `(d) to perform such other functions as may be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (8803)
  sectionNo (23)
  orderNo 23
  title `The Executive Council.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8803&sectionno=23&orderno=23&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_23_content:
  string
  line `(1) The Executive Council shall be the principal executive body of the`
  line University.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes:`
  line
  line `Provided that such number of members as may be prescribed by the Statutes shall be from among the`
  line `elected members of the Court.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (8804)
  sectionNo (24)
  orderNo 24
  title `The Academic Council.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8804&sectionno=24&orderno=24&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_24_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and the Ordinances,coordinate and`
  line `exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes:`
  line
  line `Provided that such number of members as may be prescribed by the Statutes shall be from among the`
  line `elected members of the Court who are teachers of the University.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (8805)
  sectionNo (25)
  orderNo 25
  title `The Schools of Studies.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8805&sectionno=25&orderno=25&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_25_content:
  string
  line `The constitution, powers and functions of the Schools of Studies shall`
  line `be prescribed by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (8806)
  sectionNo (26)
  orderNo 26
  title `The Finance Committee.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8806&sectionno=26&orderno=26&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_26_content:
  string
  line `The constitution, powers and functions of the Finance Committee`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (8807)
  sectionNo (27)
  orderNo 27
  title `Other authorities.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8807&sectionno=27&orderno=27&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_27_content:
  string
  line `The constitution, powers and functions of other authorities, as may be`
  line `declared by the Statutes to be the authorities of the University, shall be prescribed by the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (8808)
  sectionNo (28)
  orderNo 28
  title `Powers to make Statutes.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8808&sectionno=28&orderno=28&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_28_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all`
  line `or any of the following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the appointment and continuance in office of the members of the said authorities and bodies,`
  line `the filling up of vacancies of members, and all other matters relating to those authorities and other`
  line `bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers, academic staff and other employees of the University, their`
  line `emoluments and conditions of service;`
  line
  line `(e) the recognition of persons as recognized teachers;`
  line
  line `(f) the appointment of teachers, academic staff working in any other University or organisation`
  line `for a specific period for undertaking a joint project;`
  line
  line `(g) the conditions of service of employees including provision for pension, insurance and`
  line `provident fund, the manner of termination of service and disciplinary action relating to employees of`
  line `the University;`
  line
  line `(h) the principles governing the seniority of service of the employees of the University;`
  line
  line `(i) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(j) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(k) the conferment of autonomous status on a College or an Institution or a Department;`
  line
  line `(l) the establishment and abolition of Schools, Departments, Centres, Halls, Colleges and`
  line Institutions;
  line
  line `(m) the grant and withdrawal of recognition to Institutions;`
  line
  line `(n) the conferment of honorary degrees;`
  line
  line `(o) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(p) the management of Colleges and Institutions established by the University;`
  line
  line `(q) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(r) the maintenance of discipline among the employees and students;`
  line
  line `(s) all other matters which by this Act are to be or may be provided for by the Statutes.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (8809)
  sectionNo (29)
  orderNo 29
  title `Statutes how to be made.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8809&sectionno=29&orderno=29&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_29_content:
  string
  line `(1) The first Statutes are those set out in the Schedule.`
  line
  line `(2) The Executive Council may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Executive Council shall not make, amend or repeal any Statutes affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Executive Council.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require`
  line `the assent of the Visitor who may assent thereto or withhold assent or remit to the Executive Council for`
  line re-consideration.
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may make new or`
  line `additional Statutes or amend or repeal the Statutes referred to in sub-section (1), during the period of three`
  line `years immediately after the commencement of this Act:`
  line
  line `Provided that the Visitor may, on the expiry of the said period of three years, make, within one year`
  line `from the date of such expiry, such detailed Statutes as he may consider necessary and such detailed`
  line `Statutes shall be laid before both Houses of Parliament.`
  line
  line `(6) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may direct the`
  line `University to make provisions in the Statutes in respect of any matter specified by him and if the`
  line `Executive Council is unable to implement such direction within sixty days of its receipt, the Visitor may,`
  line `after considering the reasons, if any, communicated by the Executive Council for its inability to comply`
  line `with such direction, make or amend the Statutes suitably.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (8810)
  sectionNo (30)
  orderNo 30
  title `Power to make Ordinances.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8810&sectionno=30&orderno=30&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_30_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, qualifications for`
  line `the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(f) the conditions for award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(g) the conduct of examinations, including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence and teaching of women`
  line `students and the prescribing of special courses of studies for them;`
  line
  line `(j) the manner of co-operation and collaboration with other Universities, institutions and other`
  line `agencies not involving the carrying on of any activity for profit including learned bodies or`
  line associations;
  line
  line `(k) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(l) the institution of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(m) the setting up of a machinery for redressal of grievances of employees; and`
  line
  line `(n) all other matters which by this Act or the Statutes, are to be or may be, provided for by the`
  line Ordinances.
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Central Government and the Ordinances so made may be amended, repealed or added to at any time by`
  line `the Executive Council in the manner prescribed by the Statutes:`
  line
  line `Provided that till such time as the first Ordinances are not so made by the Vice-Chancellor, in respect`
  line `of the matters that are to be provided for by the Ordinances under this Act and Statutes, the relevant`
  line `provisions of the rules and the bye-laws of the Central Institute of English and Foreign Languages,`
  line `Hyderabad in force immediately before the commencement of this Act shall be applicable in so far as`
  line `they are not inconsistent with the provisions of this Act and the Statutes.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (8811)
  sectionNo (31)
  orderNo 31
  title Regulations.
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8811&sectionno=31&orderno=31&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_31_content:
  string
  line `The authorities of the University may make Regulations, consistent with this Act,`
  line `the Statutes and the Ordinances for the conduct of their own business and that of the Committees, if any,`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances, in the manner`
  line `prescribed by the Statutes.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (8812)
  sectionNo (32)
  orderNo 32
  title `Annual report.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8812&sectionno=32&orderno=32&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_32_content:
  string
  line `(1) The annual report of the University shall be prepared under the directions of`
  line `the Executive Council, which shall include, among other matters, the steps taken by the University`
  line `towards the fulfilment of its objects and shall be submitted to the Court on or after such date as may be`
  line `prescribed by the Statutes and the Court shall consider the report in its annual meeting.`
  line
  line `(2) The Court shall submit the annual report to the Visitor along with its comments, if any.`
  line
  line `(3) A copy of the annual report, as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (8813)
  sectionNo (33)
  orderNo 33
  title `Annual accounts.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8813&sectionno=33&orderno=33&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_33_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be`
  line `prepared under the directions of the Executive Council and shall, once at least every year and atintervals`
  line `of not more than fifteen months, be audited by the Comptroller and Auditor-General of India or by such`
  line `persons as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts together with the audit report thereon shall be submitted to the`
  line `Court and the Visitor along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Court and the observations of the Court, if any, shall, after being considered by the Executive Council, be`
  line `submitted to the Visitor.`
  line
  line `(4) A copy of the annual accounts together with the audit report as submitted to the Visitor, shall also`
  line `be submitted to the Central Government, which shall, as soon as may be, cause the same to be laid before`
  line `both Houses of Parliament.`
  line
  line `(5) The audited annual accounts after having been laid before both Houses of Parliament shall be`
  line `published in the Gazette of India.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (8814)
  sectionNo (34)
  orderNo 34
  title `Returns and information.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8814&sectionno=34&orderno=34&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_34_content:
  string
  line `The University shall furnish to the Central Government such returns`
  line `or other information with respect to its property or activities as the Central Government may, from time to`
  line `time, require.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (8815)
  sectionNo (35)
  orderNo 35
  title `Conditions of service of employees.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8815&sectionno=35&orderno=35&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_35_content:
  string
  line `(1) Every employee of the University shall be appointed`
  line `under a written contract, which shall be lodged with the University and a copy of which shall be furnished`
  line `to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Executive Council, one member nominated by the employee concerned and an umpire appointed by`
  line `the Visitor.`
  line
  line `(3) The decision of the Tribunal shall be final, and no suit shall lie in any civil court in respect of the`
  line `matters decided by the Tribunal:`
  line
  line `Provided that nothing in this sub-section shall preclude the employee from availing of the judicial`
  line `remedies available under articles 32 and 226 of the Constitution.`
  line
  line `(4) Every request made by the employee under sub-section (2), shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation Act, 1996`
  line `(26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be prescribed by the Statutes.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (8816)
  sectionNo (36)
  orderNo 36
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8816&sectionno=36&orderno=36&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_36_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the case`
  line `may be, and who has been debarred from appearing at the examinations of the University for more than`
  line `one year, may, within ten days of the date of receipt of such orders or copy of such resolution by him,`
  line `appeal to the Executive Council and the Executive Council may confirm, modify or reverse the decision`
  line `of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-sections`
  line `(2), (3), (4) and (5) of section 35 shall, as far as may be, apply to a reference made under this sub-section.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (8817)
  sectionNo (37)
  orderNo 37
  title `Right to appeal.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8817&sectionno=37&orderno=37&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_37_content:
  string
  line `Every employee or student of the University or a College or an Institution`
  line `maintained by the University shall, notwithstanding anything contained in this Act, have a right to appeal`
  line `within such time as may be prescribed by the Statutes, to the Executive Council against the decision of`
  line `any officer or authority of the University or of the Principal of any College or an Institution, as the case`
  line `may be, and thereupon the Executive Council may confirm, modify or reverse the decision appealed`
  line against.
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (8818)
  sectionNo (38)
  orderNo 38
  title `Provident and pension funds.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8818&sectionno=38&orderno=38&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_38_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such provident or pension fund or provide such insurance schemes as it may deem fit in such`
  line `manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or pension fund has been so constituted, the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to such fund, as if it`
  line `were a Government provident fund.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (8819)
  sectionNo (39)
  orderNo 39
  title `Disputes as to constitution of University authorities and bodies.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8819&sectionno=39&orderno=39&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_39_content:
  string
  line `If any question arises as to`
  line `whether any person has been duly elected or appointed as, or is entitled to be, a member of any authority`
  line `or other body of the University, the matter shall be referred to the Visitor whose decision thereon shall be`
  line final.
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (8820)
  sectionNo (40)
  orderNo 40
  title `Filling of casual vacancies.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8820&sectionno=40&orderno=40&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_40_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `members) of any authority or other body of the University shall be filled, as soon as may be, by the`
  line `person or body who appoints, elects or co-opts the member whose place has become vacant and person`
  line `appointed, elected or co-opted to a casual vacancy shall be a member of such authority or body for the`
  line `residue of the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (8821)
  sectionNo (41)
  orderNo 41
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8821&sectionno=41&orderno=41&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_41_content:
  string
  line `No act or`
  line `proceedings of any authority or other body of the University shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (8822)
  sectionNo (42)
  orderNo 42
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8822&sectionno=42&orderno=42&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_42_content:
  string
  line `No suit or other legal proceeding shall lie against any`
  line `officer or other employee of the University for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (8823)
  sectionNo (43)
  orderNo 43
  title `Mode of proof of University record.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8823&sectionno=43&orderno=43&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_43_content:
  string
  line `Notwithstanding anything contained in the Indian`
  line `Evidence Act, 1872 (1 of 1872) or in any other law for the time being in force, a copy of any receipt,`
  line `application, notice, order, proceeding or resolution of any authority or other body of the University, or`
  line `any other document in possession of the University, or any entry in any register duly maintained by the`
  line `University, if certified by the Registrar, shall be received as prima facie evidence of such receipt,`
  line `application, notice, order, proceeding, resolution or document or the existence of entry in the register and`
  line `shall be admitted as evidence of the matters and transactions therein where the original thereof would, if`
  line `produced, have been admissible in evidence.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (8824)
  sectionNo (44)
  orderNo 44
  title `Power to remove difficulties.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8824&sectionno=44&orderno=44&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_44_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under sub-section (1) shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the order or both Houses agree that the order should not be made, the order shall thereafter have effect`
  line `only in such modified form or be of no effect, as the case may be; so, however, that any such modification`
  line `or annulment shall be without prejudice to the validity of anything previously done under that order.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (8825)
  sectionNo (45)
  orderNo 45
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8825&sectionno=45&orderno=45&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_45_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successivesessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.`
  line
  line `(3) The power to make Statutes, Ordinances or Regulations shall include the power to give`
  line `retrospective effect, from a date not earlier than the date of commencement of this Act, to the Statutes, Ordinances or Regulations or any of them but no retrospective effect shall be given to any Statute,`
  line `Ordinance or Regulation so as to prejudicially affect the interests of any person to whom such Statute,`
  line `Ordinance or Regulation may be applicable.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (8826)
  sectionNo (46)
  orderNo 46
  title `Transitional provisions.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00009_200707_1517807323610&sectionId=8826&sectionno=46&orderno=46&orgactid=AC_CEN_9_30_00009_200707_1517807323610
obj_root_law_sections_46_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes,--`
  line
  line `(a) the first Chancellor and the first Vice-Chancellor shall be appointed by the Central`
  line `Government in such manner and on such conditions as may be deemed fit and each of the said`
  line `officers shall hold office for such term, not exceeding five years, as may be specified by the Central`
  line Government;
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Central Government`
  line `and each of the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Court and the first Executive Council shall consist of not more than thirty members`
  line `and eleven members, respectively, who shall be nominated by the Central Government and shall hold`
  line `office for a term of three years;`
  line
  line `(d) the first Academic Council shall consist of not more than twenty-one members, who shall be`
  line `nominated by the Central Government and they shall hold office for a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment or nomination, as the case may be, by the Central Government, and the person so appointed`
  line `or nominated shall hold office for so long as the officer or member in whose place he is appointed or`
  line `nominated would have held office, if such vacancy had not occurred.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
