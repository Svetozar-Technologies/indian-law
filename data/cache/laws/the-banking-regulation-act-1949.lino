obj_root_law_translations_hi_sections_78:
  kind page
  sectionId pdf-page-78
  sectionNo (78)
  orderNo 78
  title `Page 78`
  content obj_root_law_translations_hi_sections_78_content
  footnotes obj_root_law_translations_hi_sections_78_footnotes
  sourcePage 78
obj_root_law_translations_hi_sections_78_content:
  string
  line 78
  line `ििच संखया संविप्त िाम संशोिि`
  line `1 2 3 4`
  line `(i) िंि (3) में “ उस िारा के िंि (4) में विविर्दचष्ट विवभध ि प्र कार`
  line `की प्र वतभूवतयों पर ” शब्दों के पश् र्ा त् विम्ि विवित शब्द`
  line `अंत:स्था वपत ककए जाएंगे, अथाचत्: —`
  line `“ या जब उिार या अवग्रम बैंककारी कंपिी अविवियम, 1949`
  line `(1949 का 14) में यथापररभावित बैंककारी कंपिी को कदया जािा`
  line `हो तो अधय प्र कार की ऐसी प्र वतभूवत पर जैसी बैंक पयाचप्त समझे, ”;`
  line `(ii) “ इस िारा के अिीि ” शब्दों के स् था ि पर जहां कहीं भी िे आते`
  line `है, “ इस उपिारा के अिीि ” शब्द रिे जाएंगे;`
  line `( ि ) इस प्र कार पुि:संखया ककत उपिारा (1) के पश् र्ा त् विम्ि विवित`
  line `उपिारा अंत:स्था वपत की जाएगी, अथाचत्: —`
  line `“ (2) जहां ककसी बैंककारी कंपिी का वजसे उपिारा (1) के िंि (3) के`
  line `उपबंिों के अिीि उिार या अवग्रम कदया गया है, पररसमापि`
  line `ककया जाता है, िहां ऐसे उिार या अवग्रम की बाबत ररजिच बैंक`
  line `को देय कोई रावशयां उसे बैंककारी कंपिी की आवस्त यों पर प्र थम`
  line `भार केिि उि दािों के, यकद कोई हों, अिीि रहते हु ए होंगी जो`
  line `ककसी पूिचिती ऐसे उिार या अवग्रम की बाबत ककसी अधय`
  line `बैंककारी कंपिी के हैं, जो उिार या अवग्रम ऐसी बैंककारी कम्प िी`
  line `िे ककसी प्र वतभूवत पर कदया था। ”;`
  line `(3) िारा 42 में उपिारा (6) के स् था ि पर विम्ि विवित उपिारा`
  line `रिी जाएगी, अथाचत्: —`
  line `“(6) एतत्प श् र् ा त् यथा उपबंवित को छोड़कर ररजिच बैंक`
  line `भारत के राजपत्र में अविसूर्िा द्व ारा, —`
  line `( क ) ककसी ऐसे बैंक का वद्वतीय अिुसूर्ी में सवम्म वित ककए जािे`
  line `का विदेश करेगा जो पहिे से उसमें ऐसे सवम्म वित िहीं हैं`
  line `और जो भारत के ककसी प्र ांत में बैंककारी कारबार करता है,`
  line `और —`
  line `(i) वजसके पास पांर् िाि रु पए के अधयू ि से संकवित मूल्य की`
  line `समादत्त पूंजी और आरविवतयां हैं, और`
  line `(ii) जो ररिजच बैंक का यह समािाि करा देता है कक उस बैंक के`
  line `कायचकिापों को उसके वििेपकताचओं के वहतों के विए`
  line `हाविकर रीवत से िहीं र् िाया जा रहा है, और`
  line `(iii) जो कंपिी अविवियम, 1913 (1913 का 7) की िारा 2 के`
  line `ख ा ं ि (2) में यथापररभावित कंपिी है या जो भारत के प्र`
  line `ांतों के बाहर ककसी स् था ि में प्र िृत्त ककसी विवि के द्व ारा या`
  line `अिीि विगवमत विगम या कंपिी है।`
  line `( ि ) ककसी ऐसे अिुसूवर्त बैंक को उसे अिुसूर्ी से विकािे जािे का`
  line `विदेश करेगा, —`
  line `(i) वजसकी समादत्त पूंजी और आरविवतयों का संकवित मूल्य ककसी`
  line `समय पांर् िाि रु पए से कम हो जाता है, या`
  line `(ii) वजसकी बाबत ररजिच बैंक की राय बैंककारी कंपिी अविवियम,`
  line `1949 की िारा 35 के अिीि विरीिर् करिे के पश् र्ा त् यह है कक`
  line `िह अपिे कायचकिापों को अपिे वििेपकताचओं के वहतों के विए`
  line `हाविकर रू प से र् िा रहा है, या`
obj_root_law_translations_hi_sections_78_footnotes:
  string
