obj_root_law_translations_hi_sections_80:
  kind page
  sectionId pdf-page-80
  sectionNo (80)
  orderNo 80
  title `Page 80`
  content obj_root_law_translations_hi_sections_80_content
  footnotes obj_root_law_translations_hi_sections_80_footnotes
  sourcePage 80
obj_root_law_translations_hi_sections_80_content:
  string
  line 80
  line `पूंजी और दावयत्ि सं पवत्त और आवस्त यां रु`
  line `० पै ० रु ० पै ०`
  line `आहूत असमादत्त रावशयों को र् टाइए`
  line `समपहृत्त शेयर जोड़ दीवजए`
  line `________ 3. मांग पर तथा अल्प सूर्िा पर प्र ाप्य ििरावश`
  line `2. आरवित विवि और अधय आरविवतयां 4. विवििाि [ मूल्या कंि की रीवत विविए अथाचत्`
  line `िागत या बाजार ( मूल्य ) ( र् )] —`
  line `3. वििेप और अधय िाते:`
  line `वियतकाविक वििेप, बर्त बैंक वििेप, र् ािू`
  line `िाते, आकवस्म कता िाते, आकद _______`
  line `(i) केंरीय और राज्य सरकारों की प्र वतभूवतयां`
  line `तथा अधय धया सी प्र वतभूवतयां वजिके अंतगचत`
  line `केंरीय और राज्य सरकारों के िजािा वि पत्र`
  line `भी हैं;`
  line `(i) बैंक से`
  line `(ii) अधय से (ii) शेयर ( इसका अविमािी, मामूिी,`
  line `आस्थ वगत और अधय िगों के शेयरों में`
  line `िगीकरर् कीवजए और पूर्चत: समादत्त तथा`
  line `भागत: समादत्त शेयरों को पृथ क् त:`
  line `कदिाइए )`
  line `4. अधय बैंककारी कंपवियों, अवभकताचओं आकद से`
  line `उिार —`
  line `(i) 1 [ भारत में ] देय (iii) विबेंर्र या बंिपत्र`
  line `(ii) 2 [ भारत से बाहर ] देय ________ (iv) अधय विवििाि जो समुवर्त शीिचकों के`
  line `अिीि िगीकृत ककए जाएंगे`
  line `विवशवष्ट यां:`
  line `(i) प्र वतभूत ( प्र वतभूवत का स् ि रू प विविए ) (v) स् ि र् च`
  line `(ii) अ प्र वतभूत 5. अवग्रम िि —`
  line `5. देय वबि ( िूबंत और शंकास्प द ऋर्ों से वभध ि, वजिके विए`
  line `िेिापरीिकों को समािािप्रद रू प में उपबंि कर`
  line `कदया गया है )`
  line `6. प्र ाप्य वबि जो संग्रहर् के विए है जैसा कक`
  line `समािांतर स् तं भ में कदिाया गया है`
  line `(i) 1 [ भारत में ] देय (I ) उिार, िकद उिार, ओिर ड्र ाफ्ट आकद:`
  line `(ii) 2 [ भारत से बाहर ] देय (i) 1 [ भारत में ] देय`
  line `7. अधय दावयत्ि ( ग ) (ii) 2 [ भारत के बाहर ] देय _______`
  line `8. स् िी कृवतयां, पृष्ठां कि और अधय बाध्य ताएं जो`
  line `समािांतर स् तं भ में कदिाई गई हैं।`
  line `(II) वमती काटे प र कदए गए और िरीदे गए`
  line `( केंरीय और राज्य सरकारों के िजािा विपत्रों`
  line `से वभध ि ) विवियम पत्र;`
  line `9. िाभ और हावि (i) भारत में देय`
  line `अंवतम तुििपत्र के अिुसार िाभ वजसमें से`
  line `वि वियोवजत रावशयां कम कीवजए।`
  line `(ii) भारत के बाहर देय _______`
  line `अवग्र म ििों की विवशवष्ट यां:`
  line `िाभ हावि िेिे में से ििच के विए विया गया िाभ`
  line `जोड़ दीवजए।`
  line `(i) िसूिी योग्य समझे जािे िािे ऋर् वजिकी`
  line `बाबत बैंककारी कंपिी पूर्चत: प्र वतभूत है,`
  line `10. समावित दावयत्ि ( र् ) (ii) िसूिी योग्य समझे गए ऋर् वजिके विए`
  line `बैंककारी कं पिी ऋवर्यों की िैयवक्त क प्र वतभूवत`
  line `से वभध ि कोई प्र वतभूवत िारर् िहीं करती,`
  line `(iii) िसूिी योग्य समझे गए ऋर् जो ऋवर्यों की`
  line `िैयवक्त क प्र वतभूवत के अिािा एक या अविक`
  line `पिकारों के िैयवक्त क दावयत्िों द्व ारा प्र वतभूत है,`
  line `1 1950 के अविवियम सं ० 20 की िारा 3 द्व ारा “ ककसी राज्य में ” शब्दों के स् था ि पर प्र वतस्था वपत।`
  line `2 1950 के अविवियम सं ० 20 की िारा 3 द्व ारा “ राज्य से बाहर ” शब्दों के स् था ि पर प्र वतस्था वपत।`
