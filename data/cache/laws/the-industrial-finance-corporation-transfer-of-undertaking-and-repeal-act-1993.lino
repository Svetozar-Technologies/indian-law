obj_root_law_sections_1:
  sectionId (32348)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32348&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Industrial Finance Corporation`
  line `(Transfer of Undertaking and Repeal) Act, 1993.`
  line
  line `(2) It shall be deemed to have come into force on the 1st day of October, 1992.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (32349)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32349&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means such date as the Central Government may, by notification in the`
  line `Official Gazette, appoint under section 3;`
  line
  line `(b) "Company" means the Industrial Finance Corporation of India Limited to be formed and`
  line `registered under the Companies Act, 1956 (1 of 1956);`
  line
  line `(c) "Corporation" means the Industrial Finance Corporation of India established under`
  line `sub-section (1) of section 3 of the Industrial Finance Corporation Act, 1948 (15 of 1948).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (32350)
  sectionNo (3)
  orderNo 3
  title `Undertaking of the Corporation to vest in the company.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32350&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_3_content:
  string
  line `On such date as the Central`
  line `Government may, by notification in the Official Gazette, appoint, there shall be transferred to, and vest in,`
  line `the Company, the undertaking of the Corporation.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (32351)
  sectionNo (4)
  orderNo 4
  title `General effect of vesting of undertaking in the Company.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32351&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_4_content:
  string
  line `(1) Every shareholder of the`
  line `Corporation immediately before the appointed day shall be deemed to be registered on and from the`
  line `appointed day as a shareholder of the Company to the extent of the face value of the shares held by such`
  line shareholder.
  line
  line `(2) The undertaking of the Corporation which is transferred to and which vests in the Company under`
  line `section 3 shall be deemed to include all business, assets, rights, powers, authorities and privileges and all`
  line `properties, movable and immovable, real and personal, corporeal and incorporeal, in possession or`
  line `reservation, present or contingent of whatever nature and wheresoever situate including lands, buildings,`
  line `vehicles, cash balances, deposits, foreign currencies, disclosed and undisclosed reserves, reserve fund,`
  line `special reserve fund, benevolent reserve fund, any other fund, stocks, investments, shares, bonds,`
  line `debentures, security, management of any industrial concern, loans, advances and guarantees given to`
  line `industrial concerns, tenancies, leases and book debts and all other rights and interests arising out of such`
  line `property as were immediately before the appointed day in the ownership, possession or power of the`
  line `Corporation in relation to its undertaking, within or without India, all books of accounts, registers, records`
  line `and documents relating thereto and shall also be deemed to include all borrowings, liabilities and`
  line `obligations of whatever kind within or without India then subsisting of the Corporation in relation to its`
  line undertaking.
  line
  line `(3) All contracts, deeds, bonds, guarantees, powers of attorney, other instruments and working`
  line `arrangements subsisting immediately before the appointed day and affecting the Corporation shall cease`
  line `to have effect or to be enforceable against the Corporation and shall be of as full force and effect against`
  line `or in favour of the Company in which the undertaking of the Corporation has vested by virtue of this Act`
  line `and enforceable as fully and effectually as if instead of the Corporation, the Company had been named`
  line `therein or had been a party thereto.`
  line
  line `(4) Any proceeding or cause of action pending or existing immediately before the appointed day by or`
  line `against the Corporation in relation to its undertaking may, as from the appointed day, be continued and`
  line `enforced by or against the Company in which the undertaking of the Corporation has vested by virtue of this Act as it might have been enforced by or against the Corporation if this Act had not been enacted and`
  line `shall cease to be enforceable by or against the Corporation.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (32352)
  sectionNo (5)
  orderNo 5
  title `Concession, etc., to be deemed to have been granted to the Company.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32352&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_5_content:
  string
  line `With effect from the`
  line `appointed day, all fiscal and other concessions, licences, benefits, privileges and exemptions granted to`
  line `the Corporation in connection with the affairs and business of the Corporation under any law for the time`
  line `being in force shall be deemed to have been granted to the Company.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (32353)
  sectionNo (6)
  orderNo 6
  title `Tax exemption or benefit to continue to have effect.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32353&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_6_content:
  string
  line `(1) Where any exemption from, or any`
  line `assessment with respect to, any tax has been granted or made or any benefit by way of set off or carry`
  line `forward of any unabsorbed depreciation or investment allowance or other allowance or loss has been`
  line `extended or is available to the Corporation under the Income-tax Act, 1961 (43 of 1961), such exemption,`
  line `assessment or benefit shall continue to have effect in relation to the Company.`
  line
  line `(2) Where any payment made by the Corporation is exempt from deduction of tax at source under any`
  line `provision of the Income-tax Act, 1961 (43 of 1961), such exemption will continue to be available as if the`
  line `provisions of the said Act made applicable to the Corporation were operative in relation to the Company.`
  line
  line `(3) The transfer and vesting of the undertaking or any part thereof in terms of section 3 shall not be`
  line `construed as a transfer within the meaning of the Income-tax Act, 1961 (43 of 1961) for the purposes of`
  line `capital gains.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (32354)
  sectionNo (7)
  orderNo 7
  title `Guarantee to be operative.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32354&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_7_content:
  string
  line `Any guarantee given for or in favour of the Corporation with respect`
  line `to any loan, lease finance or other assistance shall continue to be operative in relation to the Company.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (32355)
  sectionNo (8)
  orderNo 8
  title `Provisions in respect of officers and other employees of Corporation.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32355&sectionno=8&orderno=8&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_8_content:
  string
  line `(1) Every officer or`
  line `other employee of the Corporation (except a Director of the Board, Chairman or Managing Director)`
  line `serving in the employment immediately before the appointed day shall, in so far as such officer or other`
  line `employee is employed in connection with the undertaking which has vested in the Company by virtue of`
  line `this Act, become, as from the appointed day, an officer or, as the case may be, other employee of the`
  line `Company and shall hold his office or service therein by the same tenure, at the same remuneration, upon`
  line `the same terms and conditions, with the same obligations and with the same rights and privileges as to`
  line `leave, leave fare concession, welfare scheme, medical benefit scheme, insurance, provident fund, other`
  line `funds, retirement, voluntary retirement, gratuity and other benefits as he would have held under the`
  line `Corporation if its undertaking had not vested in the Company and shall continue to do so as an officer or,`
  line `as the case may be, other employee of the Company or until the expiry of a period of six months from the`
  line `appointed day if such officer or other employee opts not to continue to be the officer or other employee of`
  line `the Company within such period.`
  line
  line `(2) Where an officer or other employee of the Corporation opts under sub-section (1) not to be in`
  line `employment or service of the Company, such officer or other employee shall be deemed to have resigned.`
  line
  line `(3) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947) or in any`
  line `other law for the time being in force, the transfer of the services of any officer or other employee of the`
  line `Corporation to the Company shall not entitle such officer or other employee to any compensation under`
  line `this Act or under any other law for the time being in force and no such claim shall be entertained by any`
  line `court, tribunal or other authority.`
  line
  line `(4) The officers and other employees who have retired before the appointed day from the service of`
  line `the Corporation and are entitled to any benefits, rights or privileges shall be entitled to receive the same`
  line `benefits, rights or privileges from the Company.`
  line
  line `(5) The trusts of the provident fund or the gratuity fund of the Corporation and any other bodies`
  line `created for the welfare of officers or employees would continue to discharge their functions in the`
  line `Company as was being done hitherto in the Corporation and any tax exemption granted to the provident`
  line `fund or the gratuity fund would continue to be applied to the Company.`
  line
  line `(6) Notwithstanding anything contained in this Act or in the Companies Act, 1956 (1 of 1956) or in`
  line `any other law for the time being in force or in the regulations of the Corporation, no Director of the`
  line `Board, Chairman, Managing Director or any other person entitled to manage the whole or substantial part`
  line `of the business and affairs of the Corporation shall be entitled to any compensation against the Corporation or the Company for the loss of office or for the premature termination of any contract of`
  line `management entered into by him with the Corporation.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (32356)
  sectionNo (9)
  orderNo 9
  title `Act 18 of 1891 to apply to the books of the Company.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32356&sectionno=9&orderno=9&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_9_content:
  string
  line `The Company shall be deemed to be a`
  line `bank for the purposes of the Bankers Books Evidence Act, 1891.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (32357)
  sectionNo (10)
  orderNo 10
  title `Shares, bonds and debentures to be deemed to be approved securities.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32357&sectionno=10&orderno=10&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_10_content:
  string
  line Notwithstanding
  line `anything contained in any other law for the time being in force, the shares, bonds and debentures of the`
  line `Company shall be deemed to be approved securities for the purposes of the Indian Trusts Act, 1882`
  line `(2 of 1982), the Insurance Act, 1938 (4 of 1938) ^1***.`
obj_root_law_sections_10_footnotes:
  string
  line `1. The words and figures "and the Banking Regulation Act, 1949 (10 of 1949) omitted by Act 4 of 2013, s. 17 and The Schedule`
  line `(w.e.f. 17-1-2013).`
obj_root_law_sections_11:
  sectionId (32358)
  sectionNo (11)
  orderNo 11
  title `Repeal and saving of Act 15 of 1948.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32358&sectionno=11&orderno=11&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_11_content:
  string
  line `(1) On the appointed day, the Industrial Finance`
  line `Corporation Act, 1948 shall stand repealed.`
  line
  line `(2) Notwithstanding the repeal of the Industrial Finance Corporation Act, 1948 (15 of 1948), the`
  line `Company shall, so far as may be, comply with the provisions of sections 33, 34, 34A, 35 and 43 of the`
  line `Act so repealed for any of the purposes related to the annual accounts of the Corporation.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (32359)
  sectionNo (12)
  orderNo 12
  title `Repeal and saving.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00022_199323_1517807321346&sectionId=32359&sectionno=12&orderno=12&orgactid=AC_CEN_2_11_00022_199323_1517807321346
obj_root_law_sections_12_content:
  string
  line `(1) The Industrial Finance Corporation (Transfer of Undertaking and`
  line `Repeal) Ordinance, 1993 (Ord. 5 of 1993) is hereby repealed.`
  line
  line `(2) Notwithstanding the repeal of the Industrial Finance Corporation (Transfer of Undertaking and`
  line `Repeal) Ordinance, 1993 (Ord. 5 of 1993), anything done or any action taken under the said Ordinance,`
  line `shall be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `औद्योगिक वित्त निगम (उपक्रम का अंतरण और निरसन) अधिनियम, 1993`
