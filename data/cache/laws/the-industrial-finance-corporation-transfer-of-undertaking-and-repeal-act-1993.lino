  (str title) (str `औद्योगिक वित्त निगम (उपक्रम का अंतरण और निरसन) अधिनियम, 1993`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1390/3/H1993-23.pdf`)
  (str sourceKind) (str pdf)
