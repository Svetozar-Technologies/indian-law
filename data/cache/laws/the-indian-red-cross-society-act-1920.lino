obj_root_law_sections_1:
  sectionId (34224)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes `1. Sub-section (2) omitted by Act 22 of 1956, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34224&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Indian Red Cross Society Act, 1920.`
  line
  line `^1* * * * *`
obj_root_law_sections_2:
  sectionId (34225)
  sectionNo (2)
  orderNo 2
  title `Constitution of Indian Red Cross Society.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34225&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_2_content:
  string
  line `There shall be constitued by this Act a`
  line `Society to be known as the Indian Red Cross Society (hereinafter called the Society). The first`
  line `members of the Society shall be nominated by persons who immediately before the`
  line `commencement of this Act were members of the Joint War Committee, Indian Branch, of the`
  line `Order of St. John of Jerusalem in England and the British Red Cross Society (hereinafter called`
  line `the Committee) at a meeting to be summoned and held for that purpose in accordance with`
  line `the usual practice of the Committee within three months from the commencement of this Act. The`
  line `number of members to be so nominated shall not be less than twenty-five or more than fifty.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (34226)
  sectionNo (3)
  orderNo 3
  title `Appointment of Managing Body.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34226&sectionno=3&orderno=3&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_3_content:
  string
  line `The Committee shall also at the same meeting`
  line `appoint from among the members nominated under section 2 of the Managing Body of the`
  line `Society (hereinafter called the Managing Body), the members of which shall hold office as`
  line `such until a new Managing Body is appointed as hereinafter provided. The number of members`
  line `of the Managing Body shall not be less than ten or more than thirty.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (34227)
  sectionNo (4)
  orderNo 4
  title Incorporation.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34227&sectionno=4&orderno=4&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_4_content:
  string
  line `The first members of the Society and all persons who may hereafter`
  line `become members thereof so long as they continue so to be, are hereby constituted a body`
  line `corporate under the name of the Indian Red Cross Society, and the said body shall have`
  line `perpetual succession and a common seal with power to hold and acquire property, moveable`
  line `and immoveable, and shall sue and be sued by the said name.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_4_a:
  sectionId (34228)
  sectionNo 4A
  orderNo 5
  title `President of the Society.`
  content obj_root_law_sections_4_a_content
  footnotes `1. Ins. by Act 14 of 1992, s. 2 (w.e.f. 23-1-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34228&sectionno=4A&orderno=5&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_4_a_content:
  string
  line `^1[4A. President of the Society.--The President of India shall be the President of the Society`
  line `(hereinafter referred to as the President).]`
obj_root_law_sections_4_b:
  sectionId (34229)
  sectionNo 4B
  orderNo 6
  title `Composition of Managing Body.`
  content obj_root_law_sections_4_b_content
  footnotes `1. Ins. by Act 14 of 1992, s. 2 (w.e.f. 23-1-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34229&sectionno=4B&orderno=6&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_4_b_content:
  string
  line `(1) Notwithstanding anything contained in section 3, the`
  line `Managing Body shall consist of the following members, namely:--`
  line
  line `(a) a Chairman to be nominated by the President for such term as he may deem fit;`
  line
  line `(b) six members to be nominated by the President for such term as he may deem fit;`
  line
  line `(c) twelve members to be elected by the State Branch Committees for a term of two years in`
  line `accordance with the rules made by the Managing Body under section 5:`
  line
  line `Provided that not more than one member shall be elected by any State Branch Committee:`
  line
  line `Provided further that no member, elected under this section shall hold office continuously for more`
  line `than two terms.`
  line
  line `(2) The Managing Body existing immediately before the commencement of the Indian Red Cross`
  line `Society (Amendment) Act, 1992 (14 of 1992) shall case to exist and the Chairman and all the members of`
  line `the said Body shall be deemed to have vacated their offices on such commencement and the Managing`
  line `Body shall be reconstituted within a period of six months from such commencement in accordance with`
  line `the provisions of sub-section (1) and until it is so reconstituted, the President may authorise any person or`
  line `body of persons to exercise and discharge all the powers, functions and duties which may, under the`
  line `provisions of this Act or the rules made thereunder, be exercised or discharged by or on behalf of the`
  line `Managing Body.]`
obj_root_law_sections_4_c:
  sectionId (34230)
  sectionNo 4C
  orderNo 7
  title `Secretary General and Treasurer of the Society.`
  content obj_root_law_sections_4_c_content
  footnotes `1. Ins. by Act 14 of 1992, s. 2 (w.e.f. 23-1-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34230&sectionno=4C&orderno=7&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_4_c_content:
  string
  line `^1[4C. Secretary General and Treasurer of the Society.--(1) The Managing Body shall, with the`
  line `previous approval of the President, appoint a Secretary-General and a Treasurer of the Society.`
  line
  line `(2) The term of office and the conditions of service of the Secretary-General and the Treasurer shall`
  line `be such as the Managing Body may determine by rules made under section 5:`
  line
  line `Provided that a the term of office and conditions of service of the Secretary-General and the Treasurer`
  line `may be varied in like manner by the Managing Body.`
  line
  line `(3) Notwithstanding anything contained in any contract or agreement and notwithstanding any`
  line `judgment, decree or order of any court, tribunal or authority or anything contained in any other provision`
  line `of this Act or the rules made thereunder, the term of office and conditions of service of any persons`
  line `appointed as the Secretary-General of the Society at any time before the commencement of the Indian`
  line `Red Cross Society (Amendment) Act, 1992 (14 of 1992) may be varied by the Managing Body with the`
  line `previous approval of the President.]`
obj_root_law_sections_4_d:
  sectionId (34231)
  sectionNo 4D
  orderNo 8
  title `Powers and functions of the Chairman and Vice-Chairman.`
  content obj_root_law_sections_4_d_content
  footnotes `1. Ins. by Act 14 of 1992, s. 2 (w.e.f. 23-1-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34231&sectionno=4D&orderno=8&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_4_d_content:
  string
  line `^1[4D. Powers and functions of the Chairman and Vice-Chairman.--(1) The powers and functions`
  line `of the Chairman shall be--`
  line
  line `(a) to preside over the meetings of the Managing Body and all other Committees set up by the`
  line `Managing Body of which he is the Chairman;`
  line
  line `(b) to re-appropriate on the advice of the Treasurer of the Society, budgetary allocation from the`
  line `major head of account to another major head of account;`
  line
  line `(c) to authorise, on the advice of the Treasurer of the Society, expenditure on items not`
  line `contemplated in the annual Budget of the Society, subject to the availability of funds;`
  line
  line `(d) to institute, if necessary, disciplinary proceedings against officers of and above the rank of`
  line `Deputy Secretary of the Society:`
  line
  line `Provided that the final decision on the basis of the disciplinary proceedings so`
  line `instituted shall be taken,--`
  line
  line `(i) in case of the Secretary-General of the Society, with the previous approval of the President;`
  line
  line `(ii) in other cases, with the previous approval of the Managing Body.`
  line
  line `(2) The powers and functions of the Vice-Chairman shall be,--`
  line
  line `(a) to exercise the powers and perform the functions conferred on the Chairman under subsection (1) or delegated to him under sub-section (3), in the absence of the Chairman on leave or on`
  line `tour abroad or for any other similar reasons;`
  line
  line `(b) to act as ex officio member in all the Committees or Sub-Committees appointed by the`
  line `Managing Body.`
  line
  line `(3) The Chairman and the Vice-Chairman shall, in addition to the powers exercisable by them under`
  line `sub-sections (1) and (2), exercise such other financial and administrative powers as may be delegated to`
  line `them by the Managing Body in accordance with rules made by it under section 5.]`
obj_root_law_sections_4_e:
  sectionId (34232)
  sectionNo 4E
  orderNo 9
  title `Powers of the President to supersede the Managing Body.`
  content obj_root_law_sections_4_e_content
  footnotes `1. Ins. by Act 14 of 1992, s. 2 (w.e.f. 23-1-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34232&sectionno=4E&orderno=9&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_4_e_content:
  string
  line `^1[4E. Powers of the President to supersede the Managing Body.--(1) If, at any time, the President is`
  line `of opinion--`
  line
  line `(a) that there has been gross failure in the management of the affairs of the Society by the`
  line `Managing Body; or`
  line
  line `(b) that the Managing Body is acting in a manner which is prejudicial to carrying out the`
  line `objectives of the Society,`
  line
  line `the President array, by order in writing, supersede the Managing Body for such period, not exceeding six`
  line `months, as may be specified in the order:`
  line
  line `Provided that before issuing an order under this sub-section, the President shall give a reasonable`
  line `opportunity to the Managing Body to show cause why it should not be superseded and shall consider the`
  line `explanations and objections, if any, of the Managing Body.`
  line
  line `(2) Upon the issue of an order under sub-section (1) superseding the Managing Body,--`
  line
  line `(a) all the members of the Managing Body shall, as from the date of supersession, vacate their`
  line `offices as such;`
  line
  line `(b) all the powers, functions and duties which may, under the provisions of this Act or the rules`
  line `made thereunder, be exercised or discharged by or on behalf of the Managing Body shall, until the`
  line `Managing Body is reconstituted, be exercised and discharged by such person or body of persons as`
  line `the President may appoint in this behalf.`
  line
  line `(3) On the expiration of the period of supersession specified in the order issued under sub-section (1),`
  line `the President may extend the period of supersession for a further period not exceeding six months as may`
  line `be recommended by the person or body of persons appointed under clause (b) of sub-section (2):`
  line
  line `Provided that the President may, at any time before the expiration of the period of supersession,`
  line `whether as originally specified under sub-section (1) or extended under this sub-section, take such steps`
  line `as are necessary to reconstitute the Managing Body in accordance with the provisions of section 4B.]`
obj_root_law_sections_5:
  sectionId (34233)
  sectionNo (5)
  orderNo 10
  title `Power to make rules.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34233&sectionno=5&orderno=10&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_5_content:
  string
  line `^1[(1)] The Managing Body ^2[may, ^3[with the previous approval of the`
  line `President], make rules^4`
  line `for the management, functions, control] and procedure of the Society. The rules`
  line `may provide among other matters for the following, namely:--`
  line
  line `(a) the conditions of membership of the Society;`
  line
  line `(b) the appointment and term of office of members of the Managing Body;`
  line
  line `(c) the choice of representatives on international and other Committees;`
  line
  line `^5[(d) the procedure of election of members by State Branch Committees;]`
  line
  line `(e) the constitution of Finance, Medical and other Committees and the delegation of powers to`
  line `them; ^6***`
  line
  line `^7[(f) the powers exercisable by the Managing Body in supervising the activities of State Branch`
  line Committees;
  line
  line `(g) delegation of financial and administrative powers to the Chairman and the`
  line Vice-Chairman;
  line
  line `(h) disqualifications for membership of the Managing Body;`
  line
  line `(i) the term of office and conditions of service of the Secretary-General and the Treasurer and`
  line `other officers of the Society;`
  line
  line `(j) the Tegulation of the procedure generally of the Society and Managing Body.]`
  line
  line `^8[(2) The Central Government shall cause every rule made under this section to be laid as soon as`
  line `may be after the rule is made before each House of Parliament, while it is in session, for a total period of`
  line `thirty days which may be comprised in one session or in two or more successive sessions, and if, before`
  line `the expiry of the session immediately following the session or the successive sessions aforesaid, both`
  line `Houses agree in making any modification in the rule or both Houses agree that the rule should not be`
  line `made, that rule shall thereafter have effect only in such modified form or be of no effect, as the case may`
  line `be; so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that rule.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Section 5 renumbered as sub-section (1) thereof by Act 14 of 1992, s. 3 (w.e.f. 23-1-1992).`
  line
  line `2. Subs. by Act 22 of 1956, s. 3, for "shall, within six months from the commencement of this Act and subject to the condition of`
  line `previous publication, make rules for the management, control".`
  line
  line `3. Subs. by Act 14 of 1992, s. 3, for certain words (w.e.f.23-1-1992).`
  line
  line `4. For such rules, see Gazette of India, 1920, pt. I, p. 2055.`
  line
  line `5. Subs. by Act 14 of 1992, s. 3, for clause (d) (w.e.f.23-1-1992).`
  line
  line `6. The word "and" omitted by Act 22 of 1956, s. 3.`
  line
  line `7. Subs. by Act 14 of 1992, s. 3, for clauses (ee) and (f) (w.e.f. 23-1-1992).`
  line
  line `8. Ins. by s. 3, ibid. (w.e.f. 23-1-1992).`
obj_root_law_sections_6:
  sectionId (34234)
  sectionNo (6)
  orderNo 11
  title `Dissolution and transfer of property of Joint War Committee.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34234&sectionno=6&orderno=11&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_6_content:
  string
  line `Upon the nomination of the`
  line `first members of the Society and the appointment of the Managing Body--`
  line
  line `(a) the Committee shall be dissolved;`
  line
  line `(b) all property, moveable or immoveable, of or belonging to the Committee shall vest in the`
  line `Society and shall be applied by the Managing Body to the objects and purposes hereinafter set out;`
  line and
  line
  line `(c) all the debts and liabilities of the Committee shall be transferred to the Society, and`
  line `shall thereafter be discharged and satisfied by it out of the aforesaid property, and each and`
  line `every member of the Committee shall be wholly discharged therefrom.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (34235)
  sectionNo (7)
  orderNo 12
  title `Purposes to which funds of Society may be applied.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34235&sectionno=7&orderno=12&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_7_content:
  string
  line `Notwithstanding anything contained in`
  line `any appeal for subscriptions or gifts to or for the purposes of the Committee, the Managing Body may in`
  line `its discretion apply--`
  line
  line `(a) either the corpus of the income or any part of such corpus or income of any property`
  line `vested in it under clause (b) of section 6 for the relief of sickness, suffering or distress caused`
  line `by tile operation of war in India or in any other country in which Expeditionary Forces from`
  line `India- may, from time to time, be employed and for purposes cognate to that object and in`
  line `maintaining Red Cross Depots for military purposes;`
  line
  line `(b) in accordance with the provisions of section 8 the income only of any such property`
  line `but not the corpus or any part thereof for the relief of sickness or suffering in India, whether`
  line `due to the operation of war or not, or in pursuance of any of the objects set forth in the First`
  line Schedule.
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (34236)
  sectionNo (8)
  orderNo 13
  title `Constitution of Branch Committees.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34236&sectionno=8&orderno=13&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_8_content:
  string
  line `^1[(1)] If Branch Committees consisting of members of`
  line `the Society arc constituted in ^2[any of the States in India ^3***] specified in the Second Schedule, then,`
  line `subject to the requirements of the Managing Body for the purposes of clause (a) of section 7 ^4[and`
  line `section 13] and any provision for expenses of management, the income of the property which has been`
  line `vested in the Society under clause (b) the section 6 shall be distributed annually among such Branch`
  line `Committees in the proportion shown in the said Schedule, to be expended by them and at their discretion`
  line `upon all or any of the objects referred to in clause (b) of section 7.`
  line
  line `^5[(2) The ^6[Central Government] may, by notification in the Gazette of India, direct that ^7[any part`
  line `part of India] ^8***specified in the first column of the Second Schedule shall be excluded therefrom or`
  line `that ^7[any part of India] ^8*** not specified therein shall be included`
  line `therein and that the percentages specified in the ^9[second column] of the said Schedule shall be varied as`
  line `required by any such exclusion or inclusion.`
  line
  line `(3) On the issue of a notification under sub-section (2) the Second Schedule shall be deemed to be`
  line `amended in accordance with such notification.`
  line
  line `(4) No notification under sub-section (2) shall be made without the consent of every Branch`
  line `Committee constituted in ^10[any State in India ^11***] for the time being included in the Second`
  line Schedule.]
obj_root_law_sections_8_footnotes:
  string
  line `1. Section 8 was renumbered as sub-section (1) of that section by Act 17 of 1937, s. 2.`
  line
  line `2. Subs. by the A. O.1950, as amended by the Adaptation of Laws (Third Amendment) Order, 1951, for "any of the Provinces,`
  line `States and other parts of India and Pakistan".`
  line
  line `3. The words "or in any part of Pakistan" omitted by Act 22 of 1956, s. 4.`
  line
  line `4. Ins. by s. 4, ibid.`
  line
  line `5. Sub-sections (2) to (4) added by Act 17 of 1937, s. 2.`
  line
  line `6. Subs. by the A. O. 1948, for "G. G. in C."`
  line
  line `7. Subs. by the A. O. 1950 as amended by the Adaptation of Laws (Third Amendment) Order, 1951, for "any Province, State or`
  line `other part of India".`
  line
  line `8. The words "or Pakistan" omitted by Act 22 of 1956, s. 4. Earlier it was inserted by the A.O. 1948,`
  line
  line `9. Subs. by Act 22 of 1956, s. 4, for "third column".`
  line
  line `10. Subs. by the A. O. 1950, for "the Provinces, States and other part of India and Pakistan".`
  line
  line `11. The words "or any part of Pakistan" omitted by Act 22 of 1956, s. 4.`
obj_root_law_sections_9:
  sectionId (34237)
  sectionNo (9)
  orderNo 14
  title `Affiliation of other Societies.`
  content obj_root_law_sections_9_content
  footnotes `1 Ins. by s. 5, ibid.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34237&sectionno=9&orderno=14&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_9_content:
  string
  line `The Managing Body may also affiliate to the Society any`
  line `other society or body ^1[whether constituted in India or in any other country] having all or any of the`
  line `objects and purposes referred to in section 7, and may provide for the allocation and distribution of funds,`
  line `through such society or body, to or for any such objects or purposes.`
obj_root_law_sections_10:
  sectionId (34238)
  sectionNo (10)
  orderNo 15
  title `Decision of Managing Body as to purposes final .`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34238&sectionno=10&orderno=15&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_10_content:
  string
  line `The Managing Body shall have`
  line `authority to determine in all cases what matters properly fall within the scope of clause (b) of section 7,`
  line `and its decision in all such matters shall be binding on all Branch Committees and affiliated societies or`
  line bodies.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (34239)
  sectionNo (11)
  orderNo 16
  title `Receipt and use of gifts .`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34239&sectionno=11&orderno=16&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_11_content:
  string
  line `The Managing Body may also receive and hold gifts of`
  line `whatsoever description either for the general purposes of the Society or for any particular purpose,`
  line `and on receipt of such gifts may, subject to the provisions of rules made under section 5, apply the same`
  line `to such purposes, either directly or through Branch Committees or societies or bodies affiliated under`
  line `section 9.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (34240)
  sectionNo (12)
  orderNo 17
  title `Powers of Branch Committees.`
  content obj_root_law_sections_12_content
  footnotes `1 Ins. by s. 7, ibid.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34240&sectionno=12&orderno=17&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_12_content:
  string
  line `Subject to the provisions of rules made under section`
  line `^1[and the powers of supervision exercisable by the Managing Body thereunder], each Branch Committee`
  line `shall have all power ^2*** to receive gifts and expend all monies received by it for its purposes, either`
  line `directly or through other societies or bodies.`
obj_root_law_sections_13:
  sectionId (34241)
  sectionNo (13)
  orderNo 18
  title `Transfer of property to Pakistan.`
  content obj_root_law_sections_13_content
  footnotes `1. Ins. by Act 22 of 1956, s. 8.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00022_192015_1523343659114&sectionId=34241&sectionno=13&orderno=18&orgactid=AC_CEN_12_13_00022_192015_1523343659114
obj_root_law_sections_13_content:
  string
  line `^1[13. Transfer of property to Pakistan.--(1) Notwithstanding anyting contained in this Act, the`
  line `Managing Body, may, from out of the funds specified in column 1 of the Third Schedule, transfer to the`
  line `Pakistan Red Cross Society the amounts specified in that Schedule as being the share of the Pakistan Red`
  line `Cross Society which that Society has agreed to receive for being applied to the purposes for which they`
  line `were held by the Society.`
  line
  line `(2) Upon the transfer of such amounts to the Pakistan Red Cross Society under sub-section (1), the`
  line `Society shall be freed and discharged from all obligations imposed upon it by or under this Act as in force`
  line `before the commencement of the Indian Red Cross Society (Amendment) Act, 1956 (22 of 1956), or`
  line `under any trust or other document in respect of anything to be done in Pakistan or in any part thereof.]`
obj_root_law_translations:
