obj_root_law:
  slug the-national-medical-commission-act-2019
  handle (11820)
  collectionHandle 123456789/1362
  title `The National Medical Commission Act, 2019`
  actNumber (30)
  enactmentDate 2019-08-08
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/11820`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्ट्रीय आयुर्विज्ञान आयोग अधिनियम, 2019`
  actYear (2019)
  ministry `Ministry of Health and Family Welfare`
  department `Department of Health and Family Welfare`
  longTitle `An Act to provide for a medical education system that improves access to quality and affordable medical education, ensures availability of adequate and high quality medical professionals in all parts of the country,that promotes equitable and universal healthcare that encourages community health perspective and makes services of medical professionals accessible to all the citizens,that promotes national health goals,that encourages medical professionals to adopt latest medical research in their work and to contribute to research,that has an objective periodic and transparent assessmet of medical institutions and facilitates maintenance of a medical register for India and enforces high ethical standards in all aspects of medical services,that is flexible to adapt to changing needs and has an effective grievance redressal mechanism and for matters connected therewith or incidental thereto.`
  enforcementDate `2nd September, 2019,Sections 3, 4, 5, 6, 8, 11, 16, 17, 18, 19, 56 and 57, vide notification No. S.O. 3162(E), dated 2nd September, 2019, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  notification undefined
  fetchedAt `2026-05-09T09:25:47.988Z`
  translations obj_root_law_translations
