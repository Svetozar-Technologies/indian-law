obj_root_law:
  object
  (str slug) (str the-nalanda-university-act-2010)
  (str handle) (str 2109)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Nalanda University Act, 2010`)
  (str actNumber) (str 39)
  (str enactmentDate) (str 2010-09-21)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2109`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `नालन्दा विश्‍वविद्यालय अधिनियम, 2010`)
  (str actYear) (str 2010)
  (str ministry) (str `Ministry of External Affairs`)
  (str longTitle) (str `An Act to implement the decisions arrived at the Second East Asia Summit held on the 15th January, 2007, at Philippines and subsequently at the Fourth East Asia Summit held on the 25th October, 2009, at Thailand for the establishment of the Nalanda University in the State of Bihar as an international institution for pursuit of intellectual, philosophical, historical and spiritual studies and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 25-11-2010)
  (str notification) (str `25th November, 2010, vide notification No. S.O. 2809(E), dated 18th November, 2010, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-08T23:59:40.935Z`)
  (str translations) obj_root_law_translations
