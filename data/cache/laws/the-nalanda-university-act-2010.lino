obj_root_law_sections_1:
  sectionId (19068)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19068&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Nalanda University Act, 2010.`
  line
  line `(2) It shall come into force on such date ^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1 25th November, 2010, vide notification No. S.O. 2809(E), dated 18th November, 2010, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (19069)
  sectionNo (2)
  orderNo 2
  title `Declaration of Nalanda University as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19069&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_2_content:
  string
  line `Whereas the`
  line `objects of the institution known as the Nalanda University are such as to make the institution one of`
  line `national importance, it is hereby declared that the institution known as the Nalanda University is an`
  line `institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (19070)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19070&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Statutes;
  line
  line `(c) "Centre" means a centre established or maintained by the University in any place in India or`
  line `in East Asia region for the purposes of coordinating and supervising the work of centres in such place`
  line `or region and for performing such functions as may be conferred on such centre by the Governing`
  line Board;
  line
  line `(d) "East Asia region" means the region comprising the territories of the Member States of the`
  line `East Asia Summit;`
  line
  line `(e) "employee" means any person appointed by the University and includes teachers and other`
  line `staff of the University;`
  line
  line `(f) "Faculty" means a Faculty of the University;`
  line
  line `(g) "Finance Officer" means the Finance Officer of the University appointed under section 17;`
  line
  line `(h) "Governing Board" means the Governing Board of the University constituted under section 7;`
  line
  line `(i) "Hall" means a unit of residence, by whatever name called, for students of the University`
  line `provided, maintained or recognised by it;`
  line
  line `(j) "Member States" means the Member States of the East Asia Summit;`
  line
  line `(k) "Nalanda Mentor Group" means the group of persons constituted by the communication dated`
  line `the 28th June, 2007 of the Government of India in the Ministry of External Affairs, inter alia, to`
  line `examine the framework and structure of International co-operation and partnership which would`
  line `govern the establishment of the University;`
  line
  line `(l) "Ordinances" means the Ordinances of the University;`
  line
  line `(m) "prescribed" means prescribed by Statutes, Ordinances or by Regulations;`
  line
  line `(n) "recognised institution" means an institution of higher learning maintained or recognised by,`
  line `or associated with, the University;`
  line
  line `(o) "Registrar" means the Registrar of the University appointed under section 16;`
  line
  line `(p) "Regulations" means the Regulations of the University;`
  line
  line `(q) "School" means a school of studies of the University;`
  line
  line `(r) "Statutes" means the Statutes of the University;`
  line
  line `(s) "teacher" means professor, associate professor, assistant professor and research staff of the`
  line `University appointed or recognised by the University for imparting instructions or conducting`
  line `research in the University or for giving guidance to students for pursuing any course of study of the`
  line `University and are designated as teachers by the Statutes;`
  line
  line `(t) "University" means the Nalanda University established and incorporated under section 4.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (19071)
  sectionNo (4)
  orderNo 4
  title `Establishment and incorporation of Nalanda University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19071&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_4_content:
  string
  line `(1) The University of Nalanda in the`
  line `State of Bihar, established under the University of Nalanda Act, 2007 (Bihar Act 18 of 2007), shall be`
  line `established as a body corporate under this Act by the name of "Nalanda University".`
  line
  line `(2) The first Visitor, the first Chancellor, the first Vice-Chancellor, the first members of the`
  line `Governing Board and the Academic Council, and all persons who may hereafter become such officers or`
  line `members, so long as they continue to hold such office or membership, shall constitute the University.`
  line
  line `(3) The University shall have perpetual succession and a common seal and shall sue and be sued by`
  line `the said name.`
  line
  line `(4) The Headquarters of the University shall be in the district of Nalanda in the State of Bihar.`
  line
  line `(5) The University may establish or maintain centres at such other places in India as it may deem fit:`
  line
  line `Provided that the University may, with the approval of the Governing Board, establish study centres`
  line `outside India.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (19072)
  sectionNo (5)
  orderNo 5
  title `Effect of establishment of University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19072&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_5_content:
  string
  line `On and from the date of commencement of this Act,--`
  line
  line `(a) any reference to the University of Nalanda in any contract or other instrument shall be deemed`
  line `as a reference to the University;`
  line
  line `(b) all property, movable and immovable, of or belonging to the University of Nalanda shall vest`
  line `in the University;`
  line
  line `(c) all rights and liabilities of the University of Nalanda shall be transferred to, and be the rights`
  line `and liabilities of, the University;`
  line
  line `(d) every person employed by the University of Nalanda immediately before the commencement`
  line `of this Act shall hold his office or service in the University by the same tenure, at the same`
  line `remuneration and upon the same terms and conditions and with the same rights and privileges as to`
  line `pension, leave, gratuity, provident fund and other matters as he would have held the same if this Act had not been enacted, and shall continue to do so unless and until his employment is terminated or`
  line `until such tenure, remuneration and terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the University in accordance with the term of the contract with the employee or, if`
  line `no provision is made therein in this behalf, on payment to him by the University of compensation`
  line `equivalent to three months' remuneration in case of permanent employees and one months`
  line `remuneration in the case of other employees:`
  line
  line `Provided further that every person employed before the commencement of this Act, pending the`
  line `execution of a contract under section 33, shall be deemed to have been appointed in accordance with`
  line `the provisions of a contract consistent with the provisions of this Act and the Statutes:`
  line
  line `Provided also that any reference, by whatever form of words, to the Visitor, Chancellor or`
  line `Vice-Chancellor of the University of Nalanda in any law for the time being in force, or in any`
  line `instrument or other document, shall be construed as a reference respectively to the Visitor, Chancellor`
  line `or Vice-Chancellor of the University;`
  line
  line `(e) the Visitor of the University of Nalanda, appointed under the provisions of the University of`
  line `Nalanda Act, 2007 (Bihar Act 18 of 2007) shall be deemed to have been appointed to be the nominee`
  line `of the Visitor and such nominee be also the first Visitor under this Act for a period of five years from`
  line `the date of commencement of this Act;`
  line
  line `(f) the Chancellor of the University of Nalanda, appointed under the provisions of the University`
  line `of Nalanda Act, 2007 (Bihar Act 18 of 2007) shall be deemed to have been appointed as the`
  line `Chancellor under section 14 of this Act, and shall hold office for a period of three years from the date`
  line `of commencement of this Act;`
  line
  line `(g) the Vice-Chancellor of the University of Nalanda, appointed under the provisions of the`
  line `University of Nalanda Act, 2007 (Bihar Act 18 of 2007) shall be deemed to have been appointed as`
  line `the first Vice-Chancellor under this Act, and shall hold office for a period of five years from the date`
  line `of commencement of this Act; and`
  line
  line `(h) all Colleges, Institutions, Faculties and Departments affiliated to, or admitted to the privileges`
  line `of, or maintained by, the University of Nalanda shall stand affiliated to, or admitted to the privilege`
  line `of, or maintained by, the University.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (19073)
  sectionNo (6)
  orderNo 6
  title Jurisdiction.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19073&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_6_content:
  string
  line `The jurisdiction of the University shall extend to whole of India and to centres`
  line `established within or outside India.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (19074)
  sectionNo (7)
  orderNo 7
  title `Governing Board.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19074&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_7_content:
  string
  line `(1) There shall be a Governing Board of the University consisting of the`
  line `following persons as its members, namely:--`
  line
  line `(a) the Chancellor;`
  line
  line `(b) the Vice-Chancellor;`
  line
  line `(c) five members from amongst the Member States which provide maximum financial assistance`
  line `during a period of three years to be nominated by the Member States;`
  line
  line `(d) one member, not below the rank of Secretary in the Ministry of External Affairs, to be`
  line `nominated by the Central Government;`
  line
  line `(e) two members, representing the State Government of Bihar, to be nominated by the State`
  line Government;
  line
  line `(f) one member not below the rank of Additional Secretary in the Ministry of Human Resource`
  line `Development, to be nominated by the Central Government;`
  line
  line `(g) three members from amongst the persons being renowned academician or educationist, to be`
  line `nominated by the Central Government.`
  line
  line `(2) Each member of the Governing Board referred to in clauses (c) to (g) of sub-section (1), shall hold`
  line `office for a fixed term of three years.`
  line
  line `(3) The Chancellor shall be the Chairperson of the Governing Board.`
  line
  line `(4) The member, being the Secretary in the Ministry of External Affairs, nominated under clause (d)`
  line `of sub-section (1), shall be the Member-Secretary of the Governing Board.`
  line
  line `(5) Subject to the provisions of this Act, the Statutes and the Ordinances made thereunder, the`
  line `Governing Board may regulate its own procedure (including quorum) for the conduct of its meetings.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (19075)
  sectionNo (8)
  orderNo 8
  title `Powers and functions of Governing Board.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19075&sectionno=8&orderno=8&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_8_content:
  string
  line `(1) The Governing Board shall be responsible for`
  line `all the policies and directions of the University and management of its affairs.`
  line
  line `(2) The Governing Board shall exercise such powers as may be prescribed by the Statutes:`
  line
  line `Provided that the Nalanda Mentor Group shall exercise the powers and discharge the functions of the`
  line `Governing Board for a period of one year or till such time the members referred to in clauses (c) to (g) of`
  line `sub-section (1) of section 7 are nominated, whichever is earlier.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (19076)
  sectionNo (9)
  orderNo 9
  title `Objectives of University.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19076&sectionno=9&orderno=9&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_9_content:
  string
  line `(1) The objectives of the University shall be--`
  line
  line `(a) to impart education and to enable research towards capacity building of the Member States in`
  line `the domain of ancient science (in particular, practised in the Nalanda several centuries ago),`
  line `philosophy, language, history and other areas of higher learning vital for improving the quality of life;`
  line
  line `(b) to contribute to the promotion of regional peace and vision by bringing together the future`
  line `leaders of the East Asia, who by relating to their past history can enhance their understanding of each`
  line `others' perspectives and to share that understanding globally;`
  line
  line `(c) to harmonise the academic standards and accreditation norms in teaching, research and`
  line `curriculum that are acceptable to all Member States;`
  line
  line `(d) to create a unique partnership between the scholars and interested persons from the Member`
  line States;
  line
  line `(e) to understand Buddha's teachings in the contemporary context without excluding any other`
  line `thoughts and practices from any other parts of the world;`
  line
  line `(f) to enhance research for greater interaction between Asian countries, particularly between East`
  line `Asia, bound by strong historical commonalities in areas like trade, science, mathematics, astronomy,`
  line `religion, philosophy and cross-cultural current;`
  line
  line `(g) to foster in the students and scholars the spirit of accommodation, understanding and thus to`
  line `train them to become exemplary citizens of democratic societies;`
  line
  line `(h) to contribute to the improvement of the educational system of the Member States in view of`
  line `the teaching in Nalanda several centuries ago;`
  line
  line `(i) to provide education and training in various arts, crafts and skills of the Member States, raising`
  line `their quality and improving their availability to the people.`
  line
  line `(2) The University shall be non-profit public-private partnership, which shall seek support from each`
  line `of the Member States and from other sources but shall be autonomous and accountable to the Governing`
  line Board.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (19077)
  sectionNo (10)
  orderNo 10
  title `Powers of University.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19077&sectionno=10&orderno=10&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_10_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to make provision for providing, upgrading and promoting holistic and inclusive education and`
  line `training and research in such education as set out in the objects, and to create an enabling and`
  line `conducive environment for the pursuit of such education in close co-operation with other experts,`
  line `scholars and interested persons in India, Asian countries and other countries;`
  line
  line `(ii) to set up a consortium of international partners and friendly countries in furtherance of the`
  line `objects of the University;`
  line
  line `(iii) to generate and maintain resources through consultancy services, continuing education`
  line `programmes, national and international collaborations and intellectual property rights;`
  line
  line `(iv) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provisions for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(v) to establish such special centres and specialised laboratories and such other units for research`
  line `and instruction as are necessary for the furtherance of its objects;`
  line
  line `(vi) to plan and prescribe courses of study for degrees, diplomas, certificates or for any other`
  line purpose;
  line
  line `(vii) to hold examinations and grant diplomas or certificates to, and confer degrees and other`
  line `academic distinctions on, persons who have pursued a course of study or conducted research, in the`
  line `manner laid down by the Statutes and Ordinances;`
  line
  line `(viii) to confer honorary degrees or other academic distinctions in the manner prescribed by the`
  line Statutes;
  line
  line `(ix) to institute Professorships, Readerships and Lecturerships and other teaching and academic`
  line `positions, required by the University and to appoint persons to such Chairs, Professorships,`
  line `Readerships and Lecturerships and other teaching and academic positions;`
  line
  line `(x) to appoint visiting professors, Emeritus professors, consultants, scholars and such other`
  line `persons who may contribute to the advancement of the objects of the University;`
  line
  line `(xi) to recognise persons as professors, associate professors, or assistant professors or otherwise`
  line `as teachers of the University;`
  line
  line `(xii) to create administrative and other posts as the University may deem necessary from time to`
  line `time and to make appointments thereto;`
  line
  line `(xiii) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xiv) to establish and maintain centres in India or outside India, as may be determined from time`
  line `to time;`
  line
  line `(xv) to admit to its privileges institutions situated within its jurisdiction as the University`
  line `institutions and to withdraw all or any of those privileges in accordance with such conditions as may`
  line `be prescribed by the Statutes;`
  line
  line `(xvi) to co-operate or collaborate or associate with any other University or authority or institution`
  line `of higher learning or any other public or private body, having in view the promotion of purposes and`
  line `objects similar to those of the University, in such manner as may be prescribed and for such purposes`
  line `as may be determined or agreed upon by the University;`
  line
  line `(xvii) to determine standards of admissions, including examination, evaluation or any other`
  line `method of testing, to the University, and the institutions maintained by or admitted to the privileges of`
  line `the University;`
  line
  line `(xviii) to demand and receive payment of fees and other charges as may be prescribed;`
  line
  line `(xix) to establish Halls and to recognise, guide, supervise and control Halls not maintained by the`
  line `University and other accommodation for students, and to withdraw any such recognition;`
  line
  line `(xx) to make arrangements for promoting health and general welfare of students and employees of`
  line `the University;`
  line
  line `(xxi) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxii) to institute and award Fellowships, Scholarships and Prizes;`
  line
  line `(xxiii) to receive benefactions, donations and gifts in accordance with the Ordinances and to`
  line `acquire, hold, manage and dispose of any property, movable or immovable, including trust and`
  line `endowment properties, for the purposes or objects of the University and to invest funds in such`
  line `manner as it deems fit;`
  line
  line `(xxiv) to borrow, with the approval of the Governing Board;`
  line
  line `(xxv) to recognise for any purpose, either in whole or in part, any institution or members or`
  line `students thereof on such terms and conditions as may, from time to time, be prescribed and to`
  line `withdraw such recognition;`
  line
  line `(xxvi) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions or bodies as it may deem necessary;`
  line
  line `(xxvii) to provide for the printing, reproduction and publication or research and other work which`
  line `may be required by the University;`
  line
  line `(xxviii) to exercise such other powers accorded to it and to do all such other acts as may be`
  line `necessary, incidental or conducive to the promotion of all or any of the objects of the University.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (19078)
  sectionNo (11)
  orderNo 11
  title `University open to all persons.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19078&sectionno=11&orderno=11&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_11_content:
  string
  line `The University shall be open to all persons irrespective of`
  line `gender, caste, creed, disability, ethnicity or socio-economic background.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (19079)
  sectionNo (12)
  orderNo 12
  title Visitor.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19079&sectionno=12&orderno=12&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_12_content:
  string
  line `(1) The President of India shall be the Visitor of the University:`
  line
  line `Provided that the President may, by order, nominate any person to be the Visitor and such person so`
  line `nominated shall hold office for such term, not exceeding five years as may be specified in the order and`
  line `the person so nominated shall exercise the powers and discharge duties of the Visitor.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University and to submit a report thereon; and upon receipt of that report, the Visitor may, after`
  line `obtaining the views of the Governing Board thereon through the Vice-Chancellor, take such action and`
  line `issue such directions as he considers necessary in respect of any of the matters dealt with in the report and`
  line `the University shall be bound to comply with such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection to be made, by such person or persons as he`
  line `may direct, of the University, its buildings, libraries, laboratories and equipments, and of any institution`
  line `or centre maintained by the University or admitted to its privileges, and also of the examinations, teaching`
  line `and other work conducted or done by the University and to cause an inquiry to be made in respect of any`
  line `matter connected with the University.`
  line
  line `(4) The Visitor shall, in every case give notice to the University of his intention to cause an inspection`
  line `or inquiry to be made, and the University shall be entitled to appoint a representative within thirty days or`
  line `such other period as the Visitor may determine who shall have the right to be present and be heard at such`
  line `inspection or inquiry.`
  line
  line `(5) The Visitor may address the Vice-Chancellor with reference to the result of inspection and`
  line `inquiry, and the Vice-Chancellor shall communicate to the Governing Board the views of the Visitor with`
  line `such advice as the Visitor may offer upon the action to be taken thereon.`
  line
  line `(6) The Governing Board shall communicate through the Vice-Chancellor to the Visitor, such action,`
  line `if any, as it proposes to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(7) Where the Governing Board does not, within a reasonable time, take action to the satisfaction of`
  line `the Visitor, he may, after considering any explanation furnished or representation made by the Governing`
  line `Board, issue such directions as he may think fit and the Governing Board shall be bound to comply with`
  line `such directions.`
  line
  line `(8) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in writing,`
  line `annul any proceeding of the University which is not in conformity with this Act, the Statutes, the`
  line `Ordinances or the Regulations.`
  line
  line `(9) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (19080)
  sectionNo (13)
  orderNo 13
  title `Officers of University.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19080&sectionno=13&orderno=13&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_13_content:
  string
  line `The following shall be the officers of the University:--`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Registrars;`
  line
  line `(4) the Finance Officer; and`
  line
  line `(5) such other officers as may be declared by the Statutes to be the officers of the University.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (19081)
  sectionNo (14)
  orderNo 14
  title `The Chancellor.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19081&sectionno=14&orderno=14&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_14_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor for such term and in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the head of the University and shall, if present,`
  line `preside at the Convocations of the University held for conferring degrees and meetings of the Governing`
  line Board.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (19082)
  sectionNo (15)
  orderNo 15
  title `The Vice-Chancellor.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19082&sectionno=15&orderno=15&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_15_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner, for such term and on such emoluments and other conditions of service as may be prescribed by`
  line `the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal academic and executive officer of the University, and`
  line `shall exercise supervision and control over the affairs of the University and give effect to the decisions of`
  line `all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of the opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of the opinion that such action ought not to have been`
  line `taken, it may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by any action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to represent against such action to the`
  line `Governing Board within ninety days from the date on which such action is communicated to him and`
  line `thereupon the Governing Board may confirm, modify or reverse the action taken by the Vice-Chancellor.`
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that a decision of any authority is beyond the powers`
  line `of the authority conferred by the provisions of this Act, the Statutes or the Ordinances or that any decision`
  line `taken is not in the interest of the University, may ask the authority concerned to review its decision within`
  line `sixty days of such decision and if the authority refuses to review its decision either in whole or in part or`
  line `no decision is taken by it within the said period of sixty days, the matter shall be referred to the Visitor`
  line `whose decision thereon shall be final:`
  line
  line `Provided that the decision of the authority concerned shall remain suspended during the period of`
  line `review of such decision by the authority or the Visitor, as the case may be, under this sub-section.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other functions as may be`
  line `prescribed by the Statutes and the Ordinances.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (19083)
  sectionNo (16)
  orderNo 16
  title `The Registrar.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19083&sectionno=16&orderno=16&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_16_content:
  string
  line `(1) The Registrar shall be appointed in such manner and on such terms and`
  line `conditions of service as may be prescribed by the Statutes.`
  line
  line `(2) The Registrar shall have the power to enter into, and sign agreements and authenticate records on`
  line `behalf of the University.`
  line
  line `(3) The Registrar shall exercise such powers and perform such functions as may be prescribed by the`
  line Statutes.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (19084)
  sectionNo (17)
  orderNo 17
  title `The Finance Officer.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19084&sectionno=17&orderno=17&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_17_content:
  string
  line `The Finance Officer shall be appointed in such manner and on such terms`
  line `and conditions of service and shall exercise such powers and perform such functions as may be prescribed`
  line `by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (19085)
  sectionNo (18)
  orderNo 18
  title `The Controller of Examinations.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19085&sectionno=18&orderno=18&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_18_content:
  string
  line `The Controller of Examinations shall be appointed in such`
  line `manner and on such terms and conditions of service and shall exercise such powers and perform such`
  line `duties, as may be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (19086)
  sectionNo (19)
  orderNo 19
  title `The Librarian.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19086&sectionno=19&orderno=19&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_19_content:
  string
  line `The Librarian shall be appointed in such manner and on such terms and`
  line `conditions of service, and shall exercise such powers and perform such duties, as may be prescribed by`
  line `the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (19087)
  sectionNo (20)
  orderNo 20
  title `Other officers.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19087&sectionno=20&orderno=20&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_20_content:
  string
  line `The manner of appointment, emoluments, powers and duties of the other`
  line `officers of the University shall be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (19088)
  sectionNo (21)
  orderNo 21
  title `Privileges and immunities of academic staff, etc.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19088&sectionno=21&orderno=21&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_21_content:
  string
  line `The members of the academic staff and,`
  line `where applicable, their dependents or members of the family, shall enjoy such privileges and immunities`
  line `as the Central Government may, after entering into an agreement with the University, notify under`
  line `section 3 of the United Nations (Privileges and Immunities) Act, 1947 (46 of 1947).`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (19089)
  sectionNo (22)
  orderNo 22
  title `Authorities of the University.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19089&sectionno=22&orderno=22&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_22_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(1) the Governing Board;`
  line
  line `(2) the Academic Council;`
  line
  line `(3) the Boards of Schools of Studies;`
  line
  line `(4) the Finance Committee; and`
  line
  line `(5) such other authorities as may be declared by the Statutes to be the authorities of the`
  line University.
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (19090)
  sectionNo (23)
  orderNo 23
  title `The Academic Council.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19090&sectionno=23&orderno=23&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_23_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and the Ordinances, have the`
  line `control and general regulation of, and be responsible for, the maintenance of standards of learning,`
  line `education, instruction, evaluation and examination within the University and shall exercise such other`
  line `powers and perform such other functions as may be conferred or imposed upon it by the Statutes.`
  line
  line `(2) The constitution of the Academic Council and the term of office of its members shall be`
  line `prescribed by the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (19091)
  sectionNo (24)
  orderNo 24
  title `The School of Studies.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19091&sectionno=24&orderno=24&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_24_content:
  string
  line `(1) There shall be such number of Schools of Studies as the University`
  line `may determine from time to time.`
  line
  line `(2) Without prejudice to the generality of the foregoing provision contained in sub-section (1), the`
  line `University shall have the following Schools, namely:--`
  line
  line `(i) Buddhist Studies, Philosophy and Comparative Religions;`
  line
  line `(ii) Historical Studies;`
  line
  line `(iii) International Relations and Peace Studies;`
  line
  line `(iv) Business Management in relation to Public Policy and Development Studies;`
  line
  line `(v) Languages and Literature;`
  line
  line `(vi) Ecology and Environment Studies;`
  line
  line `(vii) any other school as may be prescribed by the Statutes.`
  line
  line `(3) Every School of Studies shall have a Board comprising of such members as may be prescribed by`
  line `the Statutes.`
  line
  line `(4) The powers and functions of the Boards of School of Studies shall be prescribed by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (19092)
  sectionNo (25)
  orderNo 25
  title `The Finance Committee.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19092&sectionno=25&orderno=25&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_25_content:
  string
  line `The constitution, powers and functions of the Finance Committee`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (19093)
  sectionNo (26)
  orderNo 26
  title `Other authorities.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19093&sectionno=26&orderno=26&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_26_content:
  string
  line `The constitution, powers and functions of the other authorities which may`
  line `be declared by the Statutes to be authorities of the University shall be prescribed by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (19094)
  sectionNo (27)
  orderNo 27
  title Statutes.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19094&sectionno=27&orderno=27&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_27_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:--`
  line
  line `(a) the manner of appointment of the Chancellor;`
  line
  line `(b) the manner of appointment of the Vice-Chancellor, the term of his appointment, the`
  line `emoluments and other conditions of his service and the powers and functions that may be exercised`
  line `and performed by him;`
  line
  line `(c) the manner of appointment of the Registrar, the Finance Officer, the Controller of`
  line `Examinations and other officers and terms and conditions of their service and the powers and`
  line `functions that may be exercised and performed by such officers;`
  line
  line `(d) the other authorities of the University, the terms of office of the members of such authorities`
  line `and the powers and functions that may be exercised and performed by such authorities;`
  line
  line `(e) the appointment of teachers and other employees of the University, their emoluments and`
  line `other conditions of service:`
  line
  line `Provided that the terms and conditions of teachers and employees shall not be varied to their`
  line disadvantage;
  line
  line `(f) the constitution of a pension or provident fund and the establishment of an insurance scheme`
  line `for the benefit of the employees of the University;`
  line
  line `(g) the principles governing the seniority of service of the employees of the University;`
  line
  line `(h) the procedure for regulating the work of the Tribunal of Arbitration;`
  line
  line `(i) the procedure for the settlement of disputes between the employees or students of the`
  line `University, and the University;`
  line
  line `(j) the co-ordination and determination of standards in the University;`
  line
  line `(k) Schools of Studies, members of its Board and the power and functions of such Board;`
  line
  line `(l) all other matters which by this Act are to be, or may be, provided by the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (19095)
  sectionNo (28)
  orderNo 28
  title `Statutes how made.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19095&sectionno=28&orderno=28&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_28_content:
  string
  line `(1) The first Statutes shall be made by the Governing Board, with the prior`
  line `approval of the Visitor, within six months of the commencement of this Act, for operation of University.`
  line
  line `(2) The Governing Board may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Governing Board shall not make, amend or repeal any Statute affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given a reasonable`
  line `opportunity to express its opinion in writing on the proposed changes and any opinion so expressed has`
  line `been considered by the Governing Board.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal thereof shall require the`
  line `assent of the Visitor, who may assent thereto or withhold assent or remit to the Governing Board for`
  line `reconsideration in the light of the observations, if any, made by him.`
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall not be valid unless it`
  line `has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may direct the`
  line `University to make provisions in the Statutes in respect of any matter specified by him and if the`
  line `Governing Board is unable to implement such a direction within sixty days of its receipt, the Visitor may,`
  line `after considering the reasons, if any, communicated by the Governing Board for its inability to comply`
  line `with such directions, make or amend the Statutes suitably.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (19096)
  sectionNo (29)
  orderNo 29
  title Ordinances.
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19096&sectionno=29&orderno=29&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_29_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the Ordinances may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students, the courses of study and fees therefor, the qualifications pertaining`
  line `to degrees, diplomas, certificates and other courses, the conditions for the grant of fellowships,`
  line `awards and the like;`
  line
  line `(b) the conduct of examinations, including the terms and conditions and manner of appointment`
  line `of examiners;`
  line
  line `(c) any other matter which by this Act or the Statutes is to be, or may be, provided for by the`
  line Ordinances.
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Governing Board and the Ordinances so made may be amended, repealed or added to at any time by the`
  line `Governing Board, in the manner prescribed by the Statutes.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (19097)
  sectionNo (30)
  orderNo 30
  title Regulations.
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19097&sectionno=30&orderno=30&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_30_content:
  string
  line `The authorities of the University may make regulations consistent with this Act,`
  line `the Statutes and the Ordinances for the conduct of their own business and that of the committees, if any,`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances, in the manner`
  line `prescribed by the Statutes.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (19098)
  sectionNo (31)
  orderNo 31
  title `Annual report.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19098&sectionno=31&orderno=31&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_31_content:
  string
  line `(1) The annual report of the University shall be prepared under the directions of`
  line `the Governing Board which shall include, among other matters, the steps taken by the University towards`
  line `the fulfilment of its objectives.`
  line
  line `(2) The annual report so prepared shall be submitted to the Visitor on or before such date as may be`
  line `prescribed by the Statutes.`
  line
  line `(3) A copy of the annual report so prepared shall also be submitted to the Member States and`
  line `exhibited on the website of the University.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (19099)
  sectionNo (32)
  orderNo 32
  title `Annual accounts, etc.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19099&sectionno=32&orderno=32&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_32_content:
  string
  line `(1) The annual accounts and the balance sheet of the University shall be`
  line `prepared under the directions of the Governing Board and shall, once at least every year, and at intervals`
  line `of not more than fifteen months, be audited by the Comptroller and Auditor-General of India.`
  line
  line `(2) A copy of the accounts together with the audit report shall be submitted to the Visitor along with`
  line `the observations, if any, of the Governing Board.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to notice of the`
  line `Governing Board and the views of the Governing Board, if any, on such observations shall be submitted`
  line `to the Visitor.`
  line
  line `(4) A copy of the annual report and annual accounts together with the audit report, as submitted to the`
  line `Visitor, shall also be submitted to the Central Government, which shall, as soon as may be, cause the`
  line `same to be laid before both the Houses of Parliament.`
  line
  line `(5) The audited annual accounts, after having been laid before both the Houses of Parliament, shall be`
  line `published in the Gazette of India.`
  line
  line `(6) A copy of the audited annual accounts shall also be submitted to the Member States.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (19100)
  sectionNo (33)
  orderNo 33
  title `Conditions of service of employees.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19100&sectionno=33&orderno=33&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_33_content:
  string
  line `(1) Every employee of the University shall be appointed`
  line `under a written contract, which shall be lodged with the University and a copy of which shall be furnished`
  line `to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Governing Board, one member nominated by the employee concerned and an umpire appointed by the`
  line Visitor.
  line
  line `(3) The decision of the Tribunal shall be final, and no suit shall lie in any civil court in respect of the`
  line `matters decided by the Tribunal.`
  line
  line `(4) Every request made by an employee under sub-section (2), shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation Act, 1996`
  line `(26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be prescribed by the Statutes.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (19101)
  sectionNo (34)
  orderNo 34
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19101&sectionno=34&orderno=34&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_34_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Disciplinary Committee or Examination Committee, as the`
  line `case may be, and who has been debarred from appearing at the examinations of the University for more`
  line `than one year, may, within ten days of the date of receipt of such orders or copy of such resolution by`
  line `him, appeal to the Governing Board and the Governing Board may confirm, modify or reverse the`
  line `decision of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of`
  line `sub-sections (2), (3), (4) and (5) of section 33 shall, as far as may be, apply to a reference made under this`
  line sub-section.
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (19102)
  sectionNo (35)
  orderNo 35
  title `Right to appeal.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19102&sectionno=35&orderno=35&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_35_content:
  string
  line `Every employee or student of the University or of a School of Studies or`
  line `Centre or Institution maintained by the University or admitted to its privileges shall, notwithstanding`
  line `anything contained in this Act, have a right to appeal within such time as may be prescribed by the`
  line `Statutes, to the Governing Board against the decision of any officer or authority of the University or of`
  line `the Principal or the management of any School of Studies or Centre or an Institution, as the case may be,`
  line `and thereupon the Governing Board may confirm, modify or reverse the decision appealed against.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (19103)
  sectionNo (36)
  orderNo 36
  title `Provident and pension funds.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19103&sectionno=36&orderno=36&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_36_content:
  string
  line `The University shall constitute for the benefit of its employees`
  line `such provident or pension fund or provide such insurance schemes as it may deem fit in such manner and`
  line `subject to such conditions as may be prescribed by the Statutes.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (19104)
  sectionNo (37)
  orderNo 37
  title `Disputes as to the constitution of authorities and bodies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19104&sectionno=37&orderno=37&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_37_content:
  string
  line `If any question arises as to whether`
  line `any person has been duly nominated or appointed as, or is entitled to be a member of any authority or`
  line `other body of the University, the matter shall be referred to the Visitor whose decision thereon shall be`
  line final.
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (19105)
  sectionNo (38)
  orderNo 38
  title `Filling of casual vacancies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19105&sectionno=38&orderno=38&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_38_content:
  string
  line `All the casual vacancies among the members (other than ex officio`
  line `members) of any authority or other body of the University shall be filled, as soon as may be convenient,`
  line `by the person or body who appoints, nominates or co-opts the members whose place has become vacant`
  line `and any person so appointed, elected or co-opted to a casual vacancy shall be a member of such authority`
  line `or body for the residue of the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (19106)
  sectionNo (39)
  orderNo 39
  title `Proceedings of authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19106&sectionno=39&orderno=39&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_39_content:
  string
  line `No act or proceedings of`
  line `any authority or any other body of the University shall be invalid merely by reason of the existence of any`
  line `vacancy or vacancies among its members.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (19107)
  sectionNo (40)
  orderNo 40
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19107&sectionno=40&orderno=40&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_40_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or employee of the University for anything which is in good faith done or intended to be done`
  line `in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (19108)
  sectionNo (41)
  orderNo 41
  title `Power to remove difficulties.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19108&sectionno=41&orderno=41&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_41_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Gazette of India, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appears to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of a period of three years`
  line `from the commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (19109)
  sectionNo (42)
  orderNo 42
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19109&sectionno=42&orderno=42&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_42_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be published`
  line `in the Gazette of India and the website of the University.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or successive sessions aforesaid, both the Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (19110)
  sectionNo (43)
  orderNo 43
  title `Transitional provisions.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19110&sectionno=43&orderno=43&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_43_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes,--`
  line
  line `(a) the first Registrar and the first Finance Officer shall be appointed by the Governing Board and`
  line `each of the said officers shall hold office for a term of three years;`
  line
  line `(b) the first Board of School of Studies shall consist of not more than eleven members, who shall`
  line `be nominated by the Governing Board and they shall hold office for a term of three years;`
  line
  line `(c) the first Academic Council shall consist of not more than nineteen members, who shall be`
  line `nominated by the Governing Board and they shall hold office for a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment or nomination, as the case may be, by the Governing Board, and the person so appointed`
  line `or nominated shall hold office for so long as the officer or member in whose place he is appointed or`
  line `nominated would have held office, if such vacancy had not occurred.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (19111)
  sectionNo (44)
  orderNo 44
  title `Repeal of University of Nalanda Act.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00019_201039_1517807327409&sectionId=19111&sectionno=44&orderno=44&orgactid=AC_CEN_10_10_00019_201039_1517807327409
obj_root_law_sections_44_content:
  string
  line `(1) The University of Nalanda Act, 2007`
  line `(Bihar Act 18 of 2007) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal,--`
  line
  line `(a) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted, or other things done under the University of`
  line `Nalanda Act, 2007 (Bihar Act 18 of 2007), shall be deemed to have been respectively made, issued,`
  line `conferred, awarded, granted or done under the corresponding provisions of this Act and, except as`
  line `otherwise provided by or under this Act or the Statutes, continue in force unless and until they are`
  line `superseded by any order made under this Act or the Statutes; and`
  line
  line `(b) all proceedings of Selection Committees for the appointment or promotion of teachers that`
  line `took place before the commencement of this Act and all actions of the Governing Body in respect of`
  line `the recommendations of such Selection Committees where no orders of appointment on the basis`
  line `thereof were passed before the commencement of this Act shall, notwithstanding that the procedure`
  line `for selection has been modified by this Act, be deemed to have been valid but further proceeding in`
  line `connection with such pending selections shall be taken in accordance with the provisions of this Act`
  line `and be continued from the stage where they stood immediately before such commencement, except if`
  line `the concerned authorities take, with the approval of the Visitor, a decision to the contrary.`
obj_root_law_sections_44_footnotes:
  string
  line
