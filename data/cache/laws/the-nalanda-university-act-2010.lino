obj_root_law:
  slug the-nalanda-university-act-2010
  handle (2109)
  collectionHandle 123456789/1362
  title `The Nalanda University Act, 2010`
  actNumber (39)
  enactmentDate 2010-09-21
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2109`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `नालन्दा विश्‍वविद्यालय अधिनियम, 2010`
  actYear (2010)
  ministry `Ministry of External Affairs`
  longTitle `An Act to implement the decisions arrived at the Second East Asia Summit held on the 15th January, 2007, at Philippines and subsequently at the Fourth East Asia Summit held on the 25th October, 2009, at Thailand for the establishment of the Nalanda University in the State of Bihar as an international institution for pursuit of intellectual, philosophical, historical and spiritual studies and for matters connected therewith or incidental thereto.`
  enforcementDate 25-11-2010
  notification `25th November, 2010, vide notification No. S.O. 2809(E), dated 18th November, 2010, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T23:59:40.935Z`
  translations obj_root_law_translations
