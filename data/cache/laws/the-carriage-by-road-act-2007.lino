  (str slug) (str the-carriage-by-road-act-2007)
  (str handle) (str 2043)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Carriage by Road Act, 2007`)
  (str actNumber) (str 41)
  (str enactmentDate) (str 2007-09-29)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2043`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `सड़क मार्ग द्वारा वहन अधिनियम, 2007`)
  (str actYear) (str 2007)
  (str ministry) (str `Ministry of Road Transport and Highways`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the regulation of common carriers, limiting their liability and declaration of value of goods delivered to them to determine their liability for loss of, or damage to, such goods occasioned by the negligence or criminal acts of themselves, their servants or agents and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 20-07-2010)
  (str notification) (str `20th July 2010, vide notification No. S.O. 1738(E), dated 15th August, 2010, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T18:13:12.985Z`)
