obj_root_law_sections_1:
  sectionId (11340)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11340&sectionno=1&orderno=1&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Carriage by Road Act,`
  line 2007.
  line
  line `(2) It extends to the whole of India, except the State of Jammu and Kashmir*.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 20th July 2010, vide notification No. S.O. 1738(E), dated 15thAugust, 2010, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3 (ii).`
  line .
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and`
  line `Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (11341)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11341&sectionno=2&orderno=2&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "common carrier" means a person engaged in the business of collecting, storing, forwarding`
  line `or distributing goods to be carried by goods carriages under a goods receipt or transporting for hire of`
  line `goods from place to place by motorised transport on road, for all persons undiscriminatingly and`
  line `includes a goods booking company, contractor, agent, broker and courier agency engaged in the`
  line `door-to-door transportation of documents, goods or articles utilising the services of a person, either`
  line `directly or indirectly, to carry or accompany such documents, goods or articles, but does not include`
  line `the Government;`
  line
  line `(b) "consignee" means the person named as consignee in the goods forwarding note;`
  line
  line `(c) "consignment" means documents, goods or articles entrusted by the consignor to the common`
  line `carrier for carriage, the description or details of which are given in the goods forwarding note;`
  line
  line `(d) "consignor" means a person, named as consignor in the goods forwarding note, by whom or`
  line `on whose behalf the documents, goods or articles covered by such forwarding note are entrusted to`
  line `the common carrier for carriage thereof;`
  line
  line `(e) "goods" includes--`
  line
  line `(i) containers, pallets or similar articles of transport used to consolidate goods; and`
  line
  line `(ii) animals or livestock;`
  line
  line `(f) "goods forwarding note' means the document executed under section 8;`
  line
  line `(g) "goods receipt" means the receipt issued under section 9;`
  line
  line `(h) "person" includes any association or body of persons, whether incorporated or not, a road`
  line `transport booking company, contractor and an agent or a broker carrying on the business of a`
  line `common carrier;`
  line
  line `(i) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(j) "registering authority" means a State Transport Authority or a Regional Transport Authority`
  line `constituted under section 68 of the Motor Vehicles Act, 1988 (59 of 1988);`
  line
  line `(k) "registration" means the registration granted or renewed under sub-section (5) of section 4.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (11342)
  sectionNo (3)
  orderNo 3
  title `Persons not to engage in business of common carrier without registration.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11342&sectionno=3&orderno=3&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_3_content:
  string
  line `(1) No person`
  line `shall engage in the business of a common carrier, after the commencement of this Act, unless he has been`
  line `granted a certificate of registration.`
  line
  line `(2) Any person who is engaged, whether wholly or partly, in the business of a common carrier,`
  line `immediately before the commencement of this Act, shall,--`
  line
  line `(a) apply for a registration within ninety days from the date of such commencement;`
  line
  line `(b) cease to engage in such business on the expiry of one hundred and eighty days from the date`
  line `of such commencement unless he has applied for registration and the certificate of registration has`
  line `been granted by the registering authority.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (11343)
  sectionNo (4)
  orderNo 4
  title `Application for grant or renewal of registration.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11343&sectionno=4&orderno=4&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_4_content:
  string
  line `(1) Any person, who is engaged or intends to`
  line `engage in the business of a common carrier, shall apply for the grant or renewal of a certificate of`
  line `registration for carrying on the business of common carrier to the registering authority.`
  line
  line `(2) An application under sub-section (1) shall be made, to the registering authority having jurisdiction`
  line `in the area in which the applicant resides or has his principal place of business stating that the application`
  line `is for the main office, in such form and manner and accompanied by such fees payable to the registering`
  line `authority as may be prescribed.`
  line
  line `(3) An application for grant or renewal of certificate of registration for the main office shall contain`
  line `the details of branch office, if any, to be operated outside the jurisdiction of the State or Union territory in`
  line `which the main office is to be registered in such form and manner as may be prescribed:`
  line
  line `Provided that an application for the purpose to open or close a branch office shall be made to the`
  line `registering authority having jurisdiction over the main office.`
  line
  line `(4) A registering authority shall, before granting or renewing a certificate of registration, satisfy itself`
  line `that the applicant fulfills such conditions as may be prescribed.`
  line
  line `(5) The registering authority may, on receipt of an application under sub-section (2) or sub-section (3)`
  line `and after satisfying itself that the applicant fulfills the requirements of sub-section (4), grant the certificate`
  line `of registration or renew it, as the case may be, for carrying on the business of a common carrier, in such`
  line `form and subject to such conditions as may be prescribed:`
  line
  line `Provided that no application for the grant or renewal of a certificate of registration shall be refused by`
  line `the registering authority unless the applicant has been given an opportunity of being heard and the reasons`
  line `for such refusal are given in writing by the registering authority within sixty days from the date of receipt`
  line `of such application:`
  line
  line `Provided further that if such refusal has not been communicated within sixty days of the date of`
  line `application, the registering authority shall grant or renew certificate of registration within a further period`
  line `of thirty days.`
  line
  line `(6) A certificate of registration granted or renewed under sub-section (5) shall contain the details of`
  line `branch offices to be operated in various States and Union territories, and shall be valid for a period of ten`
  line `years from the date of such grant or renewal, as the case may be:`
  line
  line `Provided that in the case of registration in respect of branch offices referred to in sub-section (3), the`
  line `validity of such registration shall be restricted to the validity of the registration granted in respect of the`
  line `main office.`
  line
  line `(7) The holder of a certificate of registration shall--`
  line
  line `(a) maintain a register in such form and manner as may be prescribed;`
  line
  line `(b) for shifting the main office mentioned in the certificate of registration submit an application to`
  line `the registering authority which granted the certificate of registration:`
  line
  line `Provided that such registering authority shall grant or refuse permission for shifting the main`
  line `office within thirty days from the date of receipt of such application and that no application for shifting the main office shall be refused unless the applicant has been given an opportunity of being`
  line `heard and reasons for such refusal are given in writing by the registering authority:`
  line
  line `Provided further that in case the registering authority has not either granted or refused the`
  line `permission within thirty days it shall be deemed that the permission for shifting has been granted;`
  line
  line `(c) submit to the registering authority under whose jurisdiction the main office is located and the`
  line `Transport Research Wing of the Ministry or Department of the Central Government dealing with road`
  line `transport and highways such information and return as may be prescribed within one hundred and`
  line `twenty days after the thirty-first day of March every year;`
  line
  line `(d) display at a prominent place in its or its main office and each branch office, if any, a`
  line `certificate of registration in original or certified copy thereof attested by the concerned registering`
  line `authority, a notary or a Gazetted Officer of the Central or State Government.`
  line
  line `(8) A common carrier shall not load the motor vehicle beyond the gross vehicle weight mentioned in`
  line `the registration certificate whose registration number is mentioned in the goods forwarding note or goods`
  line `receipt, and the common carrier shall not allow such vehicle to be loaded beyond the gross vehicle`
  line weight.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (11344)
  sectionNo (5)
  orderNo 5
  title `Suspension or cancellation of registration.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11344&sectionno=5&orderno=5&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_5_content:
  string
  line `(1) If the registering authority is satisfied that the`
  line `holder of certificate of registration has failed to comply with any of the provisions of sub-section (7) of`
  line `section 4, it may give a notice by registered post or through electronic media or by any verifiable means`
  line `to the holder of certificate of registration to rectify within a period of thirty days and in case such a holder`
  line `fails to do so, it may revoke the certificate of registration on completion of enquiry.`
  line
  line `(2) If a complaint is received by the registering authority against a common carrier from a consignor`
  line `in respect of,--`
  line
  line `(i) non-issuance of receipt of goods;`
  line
  line `(ii) non-disclosure of the whereabouts of the goods in transit when asked by the consignor or`
  line `consignee; or`
  line
  line `(iii) detention of goods for delivery without valid reasons; or`
  line
  line `(iv) demand for unreasonable additional charges at the time of delivery, which were neither`
  line `disclosed nor agreed upon between the consignor and the consignee earlier; or`
  line
  line `(v) non-payment of charges agreed and payable to truck-owners,`
  line
  line `it may give a notice by registered post or through electronic media or by any other verifiable means to the`
  line `holder of certificate of registration to rectify the same within a period of thirty days and in case such`
  line `holder fails to do so, it may revoke certificate of registration for a period as may be prescribed under the`
  line `rules on completion of that enquiry.`
  line
  line `(3) If the registering authority or any other authority so authorised under the Motor Vehicles Act,`
  line `1988 (59 of 1988) has received proof of violation of provision of sub-section (8) of section 4, it shall be`
  line `competent to impose the penalty prescribed under section 194 of the Motor Vehicles Act, 1988 on the`
  line `common carrier, notwithstanding the fact that such penalty have been already imposed on and realised`
  line `from the driver or the owner of the goods vehicle or the consignor, as the case may be.`
  line
  line `(4) Any action for revocation of certificate of registration shall not be taken under sub-sections (1)`
  line `and (2) unless the holder of the certificate of registration is given an opportunity of being heard in the`
  line `enquiry and reasons for such action are given in writing by the registering authority.`
  line
  line `(5) The registering authority in whose jurisdiction the main office of the common carrier is located`
  line `shall be competent to take action under sub-sections (1) and (2) and any other registering authority who`
  line `has noticed the violations or has received complaints under the said sub-sections, shall report such matter`
  line `to the registering authority having jurisdiction over the main office.`
  line
  line `(6) When the certificate of registration is revoked, the holder of the certificate of registration shall`
  line `surrender the certificate of registration to the registering authority within a period of thirty days and it`
  line `would be incumbent on the holder of the certificate of registration to complete the delivery andtransactions in respect of the consignments already accepted by the common carrier from any consignor`
  line `prior to the revocation of the certificate of registration.`
  line
  line `(7) The holder of a certificate of registration may, at any time, surrender the certificate to the`
  line `registering authority which granted the registration and on such surrender the registering authority shall,`
  line `after obtaining declaration from the holder of the certificate of registration that no liability is outstanding`
  line `against him and that he shall discharge such liability, if held liable, revoke the certificate of registration:`
  line
  line `Provided that if the surrender is in respect of a branch office, the endorsement in respect of the branch`
  line `office shall be deleted from the certificate of registration and such deletion shall be notified by the`
  line `registering authority having jurisdiction over the main office to such other authorities as may be`
  line prescribed.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (11345)
  sectionNo (6)
  orderNo 6
  title Appeal.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11345&sectionno=6&orderno=6&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_6_content:
  string
  line `(1) Any person aggrieved by an order of the registering authority refusing to grant or`
  line `renew a certificate of registration or suspending or revoking a registration under this Act, may, within`
  line `sixty days from the date of such order, appeal to the State Transport Appellate Tribunal constituted under`
  line `sub-section (2) of section 89 of the Motor Vehicles Act, 1988 (59 of 1988).`
  line
  line `(2) An appeal under sub-section (1) shall be preferred in duplicate in the form of a memorandum`
  line `setting forth the grounds of objection to the order of the registering authority and shall be accompanied by`
  line `such fee as may be prescribed.`
  line
  line `(3) Without prejudice to the provisions of sub-sections (1) and (2), the provisions of sub-sections (1)`
  line `and (2) of section 89 of the Motor Vehicles Act, 1988 (59 of 1988), as in force immediately before the`
  line `commencement of this Act, with regard to appeal, shall, as far as may, apply to every appeal as if the`
  line `provisions aforesaid were enacted by this Act subject to the modification that any reference therein to the`
  line `"permit" shall be construed as a reference to the "registration".`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (11346)
  sectionNo (7)
  orderNo 7
  title `Submission of annual return.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11346&sectionno=7&orderno=7&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_7_content:
  string
  line `The State Transport Authority in respect of each State or Union`
  line `territory shall submit annually to the Ministry or Department of the Central Government dealing with`
  line `road transport and highways a consolidated annual return giving the details of the goods carried by the`
  line `common carriers in that State or the Union territory, as the case may be, on the basis of the returns`
  line `received from the holders of the registration as specified under clause (c) of sub-section (7) of section 4.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (11347)
  sectionNo (8)
  orderNo 8
  title `Goods forwarding note.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11347&sectionno=8&orderno=8&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_8_content:
  string
  line `(1) Every consignor shall execute a goods forwarding note, in such`
  line `form and manner as may be prescribed, which shall include a declaration about the value of the`
  line `consignment and goods of dangerous or hazardous nature.`
  line
  line `(2) The consignor shall be responsible for the correctness of the particulars furnished by him in the`
  line `goods forwarding note.`
  line
  line `(3) The consignor shall indemnify the common carrier against any damage suffered by him by reason`
  line `of incorrectness or incompleteness of the particulars on the goods forwarding note.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (11348)
  sectionNo (9)
  orderNo 9
  title `Goods receipt.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11348&sectionno=9&orderno=9&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_9_content:
  string
  line `(1) A common carrier shall,--`
  line
  line `(a) in case where the goods are to be loaded by the consignor, on the completion of such loading;`
  line or
  line
  line `(b) in any other case, on the acceptance of the goods by him, issue a goods receipt in such form`
  line `and manner as may be prescribed.`
  line
  line `(2) The goods receipt shall be issued in triplicate and the original shall be given to the consignor.`
  line
  line `(3) The goods receipt shall be prima facie evidence of the weight or measure and other particulars of`
  line `the goods and the number of packages stated therein.`
  line
  line `(4) The goods receipt shall include an undertaking by the common carrier about the liability under`
  line `section 10 or section 11.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (11349)
  sectionNo (10)
  orderNo 10
  title `Liability of common carrier.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11349&sectionno=10&orderno=10&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_10_content:
  string
  line `(1) The liability of the common carrier for loss of, or damage to`
  line `any consignment, shall be limited to such amount as may be prescribed having regard to the value, freight`
  line `and nature of goods, documents or articles of the consignment, unless the consignor or any person duly authorised in that behalf have expressly undertaken to pay higher risk rate fixed by the common carrier`
  line `under section 11.`
  line
  line `(2) The liability of the common carrier in case of any delay up to such period as may be mutually`
  line `agreed upon by and between the consignor and the common carrier and specifically provided in the goods`
  line `forwarding note including the consequential loss or damage to such consignment shall be limited to the`
  line `amount of freight charges where such loss, damage or delay took place while the consignment was under`
  line `the charge of such carrier:`
  line
  line `Provided that beyond the period so agreed upon in the goods forwarding note, compensation shall be`
  line `payable in accordance with sub-section (1) or section 11:`
  line
  line `Provided further that the common carrier shall not be liable if such carrier proves that such loss of, or`
  line `damage to, the consignment or delay in delivery thereof, had not taken place due to his fault or neglect or`
  line `that of his servants or agents thereof.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (11350)
  sectionNo (11)
  orderNo 11
  title `Rates of charge to be fixed by common carrier for carriage of consignment at a higher risk rate.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11350&sectionno=11&orderno=11&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_11_content:
  string
  line `Every common carrier may require payment for the higher risk undertaken by him in carrying a`
  line `particular consignment at such rate of charge as he may fix and correspondingly, his liability would be in`
  line `accordance with the terms as may be agreed upon with the consignor:`
  line
  line `Provided that to entitle such carrier to claim payment at a rate higher than his ordinary rate of charge,`
  line `he should have exhibited a printed or written notice, in English and the vernacular language of the State,`
  line `of the higher rate of charge in the place or premises where he carries on the business of common carrier.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (11351)
  sectionNo (12)
  orderNo 12
  title `Conditions limiting exonerating the liability of the common carrier.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11351&sectionno=12&orderno=12&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_12_content:
  string
  line `(1) Every common`
  line `carrier shall be liable to the consignor for the loss or damage to any consignment in accordance with the`
  line `goods forwarding note, where such loss or damage has arisen on account of any criminal act of the`
  line `common carrier, or any of his servants or agents.`
  line
  line `(2) In any suit brought against the common carrier for the loss, damage or non-delivery of`
  line `consignment, it shall not be necessary for the plaintiff to prove that such loss, damage or non-delivery`
  line `was owing to the negligence or criminal act of the common carrier, or any of his servants or agents.`
  line
  line `(3) Where any consignment has been detained for examination or scrutiny by a competent authority`
  line `and upon such examination or scrutiny it is found that certain prohibited goods or goods on which due tax`
  line `was not paid or insufficiently paid have been entrusted to the common carrier by the consignor which`
  line `have not been described in the goods forwarding note, the cost of such examination or scrutiny shall be`
  line `borne by the consignor and the common carrier shall not be liable for any loss, damage or deterioration`
  line `caused by such detention of the consignment for examination or scrutiny:`
  line
  line `Provided that the onus of proving that such incorrect description of goods in the goods forwarding`
  line `note was received from the consignor shall be on the common carrier.`
  line
  line `Explanation.--For the purposes of this section, "competent authority" means any person or authority`
  line `who is empowered to examine or scrutinise goods by or under any law for the time being in force to`
  line `secure compliance of provisions of that law.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (11352)
  sectionNo (13)
  orderNo 13
  title `Provision for carriage of goods of dangerous or hazardous nature to human life.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11352&sectionno=13&orderno=13&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_13_content:
  string
  line `(1) No`
  line `goods of dangerous or hazardous nature to human life shall be carried by a common carrier except in`
  line `accordance with such procedure and after complying with such safeguards as may be prescribed.`
  line
  line `(2) The Central Government may, by rules made in this behalf, specify the goods of dangerous or`
  line `hazardous nature to human life and the label or class of labels to be carried in, or displayed on, the motor`
  line `vehicle or such goods in the course of transportation.`
  line
  line `(3) Notwithstanding anything contained in any other law for the time being in force, every common`
  line `carrier shall scrutinise and ensure before starting transportation of any consignment containing goods of`
  line `dangerous or hazardous nature to human life that the consignment is covered by, one or more insurance`
  line `policies under a contract of insurance in respect of such goods providing relief in case of death or injury`
  line `to a person or damage to any property or the consignment, if an accident takes place.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (11353)
  sectionNo (14)
  orderNo 14
  title `Power of Central Government to prohibit carriage of certain class of goods.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11353&sectionno=14&orderno=14&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_14_content:
  string
  line `The Central`
  line `Government may, by notification in the Official Gazette, specify, in public interest, the goods or class or`
  line `classes of goods which shall not be carried by a common carrier.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (11354)
  sectionNo (15)
  orderNo 15
  title `Right of common carrier in case of consignee’s default.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11354&sectionno=15&orderno=15&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_15_content:
  string
  line `(1) If the consignee fails to take`
  line `delivery of any consignment of goods within a period of thirty days from the date of notice given by the`
  line `common carrier, such consignment may be deemed as unclaimed:`
  line
  line `Provided that in case of perishable consignment, the period of thirty days shall not apply and the`
  line `consignment shall be deemed unclaimed after a period of twenty-four hours of service of notice or any`
  line `lesser period as may be mutually agreed to by and between the common carrier and the consignor.`
  line
  line `(2) In the case of an unclaimed consignment under sub-section (1), the common carrier may,--`
  line
  line `(a) if such consignment is perishable in nature, have the right to sell the consignment; or`
  line
  line `(b) if such consignment is not perishable in nature, cause a notice to be served upon the consignee`
  line `or upon the consignor if the consignee is not available, requiring him to remove the goods within a`
  line `period of fifteen days from the date of receipt of the notice and in case of failure to comply with the`
  line `notice, the common carrier shall have the right to sell such consignment without any further notice to`
  line `the consignee or the consignor, as the case may be.`
  line
  line `(3) The common carrier shall, out of the sale proceeds received under sub-section (2), retain a sum`
  line `equal to the freight, storage and other charges due including expenses incurred for the sale, and the`
  line `surplus, if any, from such sale proceeds shall be returned to the consignee or the consignor, as the case`
  line `may be.`
  line
  line `(4) Unless otherwise agreed upon between the common carrier and consignor, the common carrier`
  line `shall be entitled to detain or dispose off the consignment in part or full to recover his dues in the event of`
  line `the consignee failing to make payment of the freight and other charges payable to the common carrier at`
  line `the time of taking delivery.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (11355)
  sectionNo (16)
  orderNo 16
  title `Notice for institution of a suit.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11355&sectionno=16&orderno=16&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_16_content:
  string
  line `No suit or other legal proceeding shall be instituted against a`
  line `common carrier for any loss of, or damage to, the consignment, unless notice in writing of the loss or`
  line `damage to the consignment has been served on the common carrier before the institution of the suit or`
  line `other legal proceeding and within one hundred and eighty days from the date of booking of the`
  line `consignment by the consignor.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (11356)
  sectionNo (17)
  orderNo 17
  title `General responsibility of common carrier.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11356&sectionno=17&orderno=17&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_17_content:
  string
  line `Save as otherwise provided in this Act, a common`
  line `carrier shall be responsible for the loss, destruction, damage or deterioration in transit or non-delivery of`
  line `any consignment entrusted to him for carriage, arising from any cause except the following, namely:--`
  line
  line `(a) act of God;`
  line
  line `(b) act of war or public enemy;`
  line
  line `(c) riots and civil commotion;`
  line
  line `(d) arrest, restraint or seizure under legal process;`
  line
  line `(e) order or restriction or prohibition imposed by the Central Government or a State Government`
  line `or by an officer or authority subordinate to the Central Government or a State Government authorised`
  line `by it in this behalf:`
  line
  line `Provided that the common carrier shall not be relieved of its responsibility for the loss, destruction,`
  line `damage, deterioration or non-delivery of the consignment if the common carrier could have avoided such`
  line `loss, destruction, damage or deterioration or non-delivery had the common carrier exercised due`
  line `deligence and care in the carriage of the consignment.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (11357)
  sectionNo (18)
  orderNo 18
  title `Punishment for contravention in relation to non-registration, carrying goods of dangerous or hazardous nature, or prohibited goods.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11357&sectionno=18&orderno=18&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_18_content:
  string
  line `(1) Whoever contravenes the provisions of section 3,`
  line `section 13 or a notification issued under section 14 shall be punishable for the first offence with fine which may extend to five thousand rupees, and for the second or subsequent offence with fine which may`
  line `extend to ten thousand rupees.`
  line
  line `(2) If the person committing an offence under this Act is a company, every person who, at the time`
  line `the offence was committed, was in charge of, and was responsible to, the company for the conduct of the`
  line `business of the company, as well as the company, shall be deemed to be guilty of the offence and shall be`
  line `liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall be proceeded against and`
  line `punished accordingly.`
  line
  line `Explanation.--For the purpose of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (11358)
  sectionNo (19)
  orderNo 19
  title `Composition of offences.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11358&sectionno=19&orderno=19&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_19_content:
  string
  line `(1) Any offence committed under section 18, may either before or`
  line `after the institution of the prosecution, be compounded by such officers or authorities and for such`
  line `amount as the State Government may, by notification in the Official Gazette, specify.`
  line
  line `(2) Where an offence has been compounded under sub-section (1), the offender shall be discharged`
  line `and no further proceedings shall be taken against him in respect of such offence.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (11359)
  sectionNo (20)
  orderNo 20
  title `Power to make rules.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11359&sectionno=20&orderno=20&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_20_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the form and manner of making an application for grant or renewal of a certificate of`
  line `registration for main office or branch office and the fee thereof under sub-sections (2) and (3) of`
  line `section 4;`
  line
  line `(b) the other conditions of eligibility which are required to be fulfilled by an applicant under`
  line `clause (d) of sub-section (4) of section 4;`
  line
  line `(c) the form in which and the conditions subject to which certificate of registration or renewal`
  line `may be granted under sub-section (5) of section 4;`
  line
  line `(d) the form and manner of maintaining a register under clause (a) of sub-section (7) of section 4;`
  line
  line `(e) the information and return which may be furnished to the registering authority and the`
  line `transport research wing under clause (c) of sub-section (7) of section 4;`
  line
  line `(f) fee for submitting the memorandum of appeal under sub-section (2) of section 6;`
  line
  line `(g) the form and manner in which a goods forwarding note shall be executed by the consignor`
  line `under sub-section (1) of section 8;`
  line
  line `(h) the form and manner in which a common carrier shall issue goods receipt under`
  line `sub-section (1) of section 9;`
  line
  line `(i) liability of the common carrier for loss of, or damage to any consignment under`
  line `sub-section (1) of section 10;`
  line
  line `(j) the procedure and safeguards to be complied with for carrying goods of dangerous or`
  line `hazardous nature under sub-section (1) of section 13;`
  line
  line `(k) the specification of the goods of dangerous or hazardous nature to human life and the label or`
  line `class of labels to be carried or displayed in or on the motor vehicle or on such goods in the course of`
  line `their transportation under sub-section (2) of section 13; and`
  line
  line `(l) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made under this section and every notification issued under section 14 shall be laid, as`
  line `soon as may be after it is made or issued, before each House of Parliament, while it is in session, for a`
  line `total period of thirty days which may be comprised in one session or in two or more successive sessions,`
  line `and if, before the expiry of the session immediately following the session or the successive sessions`
  line `aforesaid, both Houses agree in making any modification in the rule or the notification, or both Houses`
  line `agree that the rule or the notification should not be made or issued, the rule or the notification shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule or notification.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (11360)
  sectionNo (21)
  orderNo 21
  title `Power to remove difficulties.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11360&sectionno=21&orderno=21&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_21_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by general or special order published in the Official Gazette, make`
  line `such provisions, not inconsistent with the provisions of this Act as appear to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of two years from the`
  line `date of commencement of this Act.`
  line
  line `(2) Every order made under sub-section (1) shall be laid, as soon as may be, after it is made, before`
  line `each House of Parliament.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (11361)
  sectionNo (22)
  orderNo 22
  title `Repeal and saving.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_000010_200741_1517807327557&sectionId=11361&sectionno=22&orderno=22&orgactid=AC_CEN_30_42_000010_200741_1517807327557
obj_root_law_sections_22_content:
  string
  line `(1) The Carriers Act, 1865(3 of 1865) is hereby repealed.`
  line
  line `(2) Notwithstanding the repeal of the Carriers Act, 1865 (3 of 1865) anything done or any action`
  line `taken under the said Act shall, in so far as such thing or action is not inconsistent with the provisions of`
  line `this Act, be deemed to have been done or taken under the provisions of this Act and shall continue in`
  line `force accordingly until superseded by anything done or any action taken under this Act.`
  line
  line `(3) The mention of particular matters in this section shall not be held to prejudice or affect the general`
  line `application of section 6 of the General Clauses Act, 1897 (10 of 1897) with regard to the effect of repeals.`
obj_root_law_sections_22_footnotes:
  string
  line
