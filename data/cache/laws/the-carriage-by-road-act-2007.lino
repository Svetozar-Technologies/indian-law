obj_root_law:
  slug the-carriage-by-road-act-2007
  handle (2043)
  collectionHandle 123456789/1362
  title `The Carriage by Road Act, 2007`
  actNumber (41)
  enactmentDate 2007-09-29
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2043`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `सड़क मार्ग द्वारा वहन अधिनियम, 2007`
  actYear (2007)
  ministry `Ministry of Road Transport and Highways`
  department undefined
  longTitle `An Act to provide for the regulation of common carriers, limiting their liability and declaration of value of goods delivered to them to determine their liability for loss of, or damage to, such goods occasioned by the negligence or criminal acts of themselves, their servants or agents and for matters connected therewith or incidental thereto.`
  enforcementDate 20-07-2010
  notification `20th July 2010, vide notification No. S.O. 1738(E), dated 15th August, 2010, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T18:13:12.985Z`
  translations obj_root_law_translations
