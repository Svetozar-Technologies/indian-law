obj_root_law:
  object
  (str slug) (str the-central-road-and-infrastructure-fund-act-2000)
  (str handle) (str 1931)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Central Road and Infrastructure Fund Act, 2000`)
  (str actNumber) (str 54)
  (str enactmentDate) (str 2000-12-27)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1931`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `केन्द्रीय सड़क निधि अधिनियम, 2000`)
  (str actYear) (str 2000)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Economic Affairs`)
  (str longTitle) (str `An Act to give statutory status to the existing Central Road Fund governed by the Resolution of Parliament passed in 1988, for development and maintenance of national highways and improvement of safety at railway crossings, and for these purposes to levy and collect by way of cess, a duty of excise and duty of customs on motor spirit commonly known as petrol, high speed diesel oil and for other matters connected therewith.`)
  (str enforcementDate) (str 01-11-2000)
  (str notification) (undefined)
