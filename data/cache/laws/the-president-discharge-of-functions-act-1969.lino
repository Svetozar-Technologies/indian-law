obj_root_law_sections_1:
  sectionId (34297)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the President (Discharge of Functions) Act, 1969.`
  footnotes obj_root_law_sections_1_footnotes
