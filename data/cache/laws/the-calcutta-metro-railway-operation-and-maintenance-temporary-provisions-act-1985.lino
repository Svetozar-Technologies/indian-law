obj_root_law_sections_1:
  sectionId (40096)
  sectionNo (1)
  orderNo 1
  title `Short title, commencement and application.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40096&sectionno=1&orderno=1&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Calcutta Metro`
  line `Railway (Operation and Maintenance) Temporary Provisions Act, 1985.`
  line
  line `(2) It shall be deemed to have come into force on the 22nd day of October, 1984.`
  line
  line `(3) It shall apply to the metropolitan city of Calcutta.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (40097)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40097&sectionno=2&orderno=2&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Calcutta metro railway administration" or "metro railway administration" means the General`
  line `Manager of the metro railway appointed under section 3 of the Construction Act;`
  line
  line `(b) "commissioner" means a commissioner of the metro railway appointed under section 27 of`
  line `the Construction Act;`
  line
  line `(c) "Construction Act" means the Metro Railways (Construction of Works) Act, 1978 (33 of`
  line `1978);`
  line
  line `(d) "metro railway" means such portion of the metro railway constructed in the metropolitan city`
  line `of Calcutta under the provisions of the Construction Act as may, for the time being, be available for`
  line `public carriage of passengers, and includes--`
  line
  line `(i) all land within the boundary marks indicating the limits of the land appurtenant to the`
  line `metro railway;`
  line
  line `(ii) all lines of rails, sidings, yards or branches worked over for the purposes of, or in`
  line `connection with, the metro railway;`
  line
  line `(iii) all stations, offices, ventilation shafts and ducts, warehouses, workshops, manufactories,`
  line `fixed plants and machineries, sheds, depots and other works constructed for the purpose of, or in`
  line `connection with, the metro railway;`
  line
  line `(e) "prescribed" means prescribed by rules made under this Act.`
  line
  line `(2) All other words and expressions used herein and not defined but defined in the Indian Railways`
  line `Act, 1890 (9 of 1890), or the Metro Railways (Construction of Works) Act, 1978 (33 of 1978), shall have`
  line `the meanings, respectively, assigned to them in those Acts.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (40120)
  sectionNo (3)
  orderNo 3
  title `Calcutta metro railway administration to be responsible for the operation and maintenance of the metro railway.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40120&sectionno=3&orderno=3&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_3_content:
  string
  line `(1) Subject to the other provisions of this Act, the Calcutta metro railway`
  line `administration shall be responsible for the operation and maintenance of the metro railway.`
  line
  line `(2) The Calcutta metro railway administration may, for the efficient performance of its functions`
  line `under this Act, appoint such officers and other employees as it considers necessary on such terms and`
  line `conditions of service as may be prescribed.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (40099)
  sectionNo (4)
  orderNo 4
  title `Previous sanction of the Central Government required for the opening of metro railway.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40099&sectionno=4&orderno=4&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_4_content:
  string
  line `(1)`
  line `No metro railway shall be opened for the public carriage of passengers except with the previous sanction`
  line `of the Central Government.`
  line
  line `(2) Before giving its sanction under sub-section (1), the Central Government shall, after considering`
  line `the report given (whether before or after the commencement of this Act) by the commissioner under`
  line `clause (a) of sub-section (2) of section 27 of the Construction Act and other relevant factors, satisfy itself`
  line `that the metro railway can be opened without danger to the public using it.`
  line
  line `(3) A sanction given under this section may be either absolute or subject to such conditions as the`
  line `Central Government thinks necessary for the safety of the public.`
  line
  line `(4) Where any sanction for the opening of the metro railway under this section is given subject to any`
  line `conditions, such railway shall not be worked or used until such conditions are fulfilled to the satisfaction`
  line `of the Central Government.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (40100)
  sectionNo (5)
  orderNo 5
  title `Carriage of goods.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40100&sectionno=5&orderno=5&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_5_content:
  string
  line `(1) No person shall, while travelling in the metro railway, carry with him any`
  line `goods other than a small baggage containing personal belongings not exceeding such volume and weight`
  line `as may be prescribed.`
  line
  line `(2) Where any person travels in the metro railway in contravention of the provisions of sub-section`
  line `(1), he shall, notwithstanding that he holds a valid pass or ticket for any travel in such railway, be liable to`
  line `be removed from the train by any metro railway official authorised by the metro railway administration in`
  line `this behalf or by any other person whom such metro railway official may call to his aid.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (40101)
  sectionNo (6)
  orderNo 6
  title `Reservation of compartments for females not necessary.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40101&sectionno=6&orderno=6&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_6_content:
  string
  line `It shall not be necessary for the`
  line `metro railway administration to reserve any compartment in any train for the exclusive use of females.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (40102)
  sectionNo (7)
  orderNo 7
  title `Dangerous or offensive goods.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40102&sectionno=7&orderno=7&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_7_content:
  string
  line `(1) No person shall take or cause to be taken any dangerous or`
  line `offensive goods upon the metro railway.`
  line
  line `(2) If any metro railway official has reason to believe that any such goods are contained in a package`
  line `in the custody of any passenger, he may cause the package to be opened for the purpose of ascertaining its`
  line contents.
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (40103)
  sectionNo (8)
  orderNo 8
  title `Penalty for taking or causing to take offensive or dangerous goods upon the metro railway.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40103&sectionno=8&orderno=8&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_8_content:
  string
  line `(1) If, in contravention of sub-section (1) of section 7, a person takes or causes to be taken any offensive`
  line `goods upon the metro railway, he shall be punishable with fine which may extend to five hundred rupees.`
  line
  line `(2) If, in contravention of sub-section (1) of section 7, a person takes or causes to be taken any`
  line `dangerous goods upon the metro railway, he shall be punishable with imprisonment for a term which may`
  line `extend to four years and with fine which may extend to five thousand rupees.`
  line
  line `(3) In addition to the penalties specified in sub-section (1) or sub-section (2), a person taking or`
  line `causing to be taken any offensive goods or dangerous goods upon the metro railway shall be responsible`
  line `also for any loss, injury or damage which may be caused by reason of such goods having been so brought`
  line `upon the metro railway.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (40104)
  sectionNo (9)
  orderNo 9
  title `Smoking in compartments, etc.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40104&sectionno=9&orderno=9&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_9_content:
  string
  line `(1) No person shall smoke in any compartment or carriage of`
  line `the metro railway or in any underground metro railway station.`
  line
  line `(2) Whoever contravenes the provisions of sub-section (1) shall be punishable with fine which may`
  line `extend to two hundred and fifty rupees.`
  line
  line `(3) If any person persists in so smoking after being warned by any metro railway official to desist, he`
  line `may, in addition to incurring the liability mentioned in sub-section (2), be removed from the compartment or carriage in which he is travelling or from the underground station at which he may be found smoking`
  line `by any metro railway official authorised by the metro railway administration in this behalf.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (40105)
  sectionNo (10)
  orderNo 10
  title `Drunkenness or nuisance upon the metro railway.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40105&sectionno=10&orderno=10&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_10_content:
  string
  line `(1) If any person,--`
  line
  line `(a) is in a state of intoxication; or`
  line
  line `(b) commits any nuisance or act of indecency, or uses obscene or abusive language; or`
  line
  line `(c) wilfully or without excuse interferes in any way with the comfort of any passenger,`
  line
  line `in any carriage or upon any part of the metro railway, he shall be punishable with fine which may extend`
  line `to two hundred and fifty rupees and shall also be liable to forfeiture of the fare which he may have paid or`
  line `any pass or ticket which he may have obtained or purchased, or be removed from such carriage or part by`
  line `any metro railway official authorised by the metro railway administration in this behalf.`
  line
  line `(2) If any metro railway official is in a state of intoxication while on duty, he shall be punishable with`
  line `fine which may extend to two hundred and fifty rupees, or, where the improper performance of the duty`
  line `would be likely to endanger the safety of any passenger travelling or being upon the metro railway, with`
  line `imprisonment for a term which may extend to two years, or with fine which may extend to five hundred`
  line `rupees, or with both.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (40106)
  sectionNo (11)
  orderNo 11
  title `Prohibition of demonstrations upon the metro railway.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40106&sectionno=11&orderno=11&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_11_content:
  string
  line `(1) No demonstration of any kind`
  line `whatsoever shall be held on any part of the metro railway or other premises thereof and it shall be open to`
  line `the metro railway administration to exclude from such premises any person attending such`
  line `demonstrations whether or not he is in possession of a pass or ticket entitling him to be in the said`
  line premises.
  line
  line `(2) No person shall paste or put up any poster or write or draw anything or matter in any compartment`
  line `or carriage of the metro railway, or any premises thereof, without any lawful authority and any person`
  line `found engaged in doing any such act may be removed from the compartment, carriage or premises by any`
  line `metro railway official authorised by the metro railway administration in this behalf.`
  line
  line `(3) Whoever contravenes any of the provisions of sub-section (1) or sub-section (2), or being asked`
  line `by any metro railway official to leave any compartment, carriage or premises refuses to do so, shall be`
  line `punishable with imprisonment for a term which may extend to three months, or with fine which may`
  line `extend to five hundred rupees, or with both.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (40107)
  sectionNo (12)
  orderNo 12
  title `Penalty for travelling on roof, etc., of a train.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40107&sectionno=12&orderno=12&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_12_content:
  string
  line `If any passenger travels on the roof of a train or`
  line `persists in travelling in any part of a train not intended for the use of passengers or projects any part of his`
  line `body out of a train after being warned by any metro railway official to desist, he shall be punishable with`
  line `imprisonment for a term which may extend to one month, or with fine which may extend to fifty rupees,`
  line `or with both, and shall also be liable to be removed from the train by any metro railway official`
  line `authorised by the metro railway administration in this behalf.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (40119)
  sectionNo (13)
  orderNo 13
  title `Penalty for unlawfully entering or remaining upon the metro railway or walking on the metro railway line.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40119&sectionno=13&orderno=13&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_13_content:
  string
  line `(1) If a person enters into or upon the metro railway without any lawful authority`
  line `or having entered with lawful authority remains there unlawfully and refuses to leave on being requested`
  line `to do so by any metro railway official, he shall be punishable with imprisonment for a term which may`
  line `extend to three months, or with fine which may extend to two hundred and fifty rupees, or with both.`
  line
  line `(2) If any person walks on the metro railway line without any lawful authority, he shall be punishable`
  line `with imprisonment for a term which may extend to six months, or with fine which may extend to five`
  line `hundred rupees, or with both.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (40109)
  sectionNo (14)
  orderNo 14
  title `Endangering the safety of passengers.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40109&sectionno=14&orderno=14&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_14_content:
  string
  line `If any metro railway official, when on duty, endangers`
  line `the safety of any passenger,--`
  line
  line `(a) by any rash or negligent act or omission; or`
  line
  line `(b) by disobeying any rule or order which such official was bound by the terms of his`
  line `employment to obey, and of which he had notice,`
  line
  line `he shall be punishable with imprisonment for a term which may extend to five years, or with fine which`
  line `may extend to six thousand rupees, or with both.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (40110)
  sectionNo (15)
  orderNo 15
  title `Abandoning train, etc., without authority.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40110&sectionno=15&orderno=15&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_15_content:
  string
  line `If any metro railway official, when on duty, is`
  line `entrusted with any responsibility connected with the running of a train, or any other rolling stock from`
  line `one station or place to another station or place, and he abandons his duty before reaching such station or`
  line `place, without authority or without properly handing over such train or rolling stock to another authorised`
  line `metro railway official, he shall be punishable with imprisonment for a term which may extend to four`
  line `years, or with fine which may extend to five thousand rupees, or with both.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (40111)
  sectionNo (16)
  orderNo 16
  title `Obstructing running of trains, etc.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40111&sectionno=16&orderno=16&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_16_content:
  string
  line `If any person obstructs or causes to be obstructed or`
  line `attempts to obstruct any train or other rolling stock upon the metro railway by squatting, picketing, or`
  line `keeping without authority any rolling stock on the metro railway or tampering with any signalling`
  line `installations or by interfering with the working mechanism thereof, or otherwise, he shall be liable to be`
  line `removed by any metro railway official authorised by the metro railway administration in this behalf and`
  line `shall also be punishable with imprisonment for a term which may extend to four years, or with fine which`
  line `may extend to five thousand rupees, or with both.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (40112)
  sectionNo (17)
  orderNo 17
  title `Offences by companies.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40112&sectionno=17&orderno=17&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_17_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who, at the time the offence was committed, was in charge of, and was`
  line `responsible to, the company, for the conduct of the business of the company, as well as the company,`
  line `shall be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall be deemed to be guilty of`
  line `that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (40113)
  sectionNo (18)
  orderNo 18
  title `Application of Act 9 of 1890 and the rules, etc., made thereunder to the metro railway.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40113&sectionno=18&orderno=18&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_18_content:
  string
  line `Save as otherwise expressly provided in this Act, the provisions of the Indian Railways Act, 1890, and`
  line `the rules, orders or notifications made or issued thereunder shall, so far as may be, and subject to such`
  line `modifications as may be necessary, apply to the operation and maintenance of the metro railway, as if`
  line `such metro railway were a railway as defined under that Act, and the references to "railway`
  line `administration" and "inspector" in that Act shall be construed as references to the "metro railway`
  line `administration" and "commissioner" respectively.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (40114)
  sectionNo (19)
  orderNo 19
  title `Effect of Act and rules, etc., inconsistent with other enactments.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40114&sectionno=19&orderno=19&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_19_content:
  string
  line `The provisions of this Act`
  line `or any rule made or any notification issued thereunder shall have effect notwithstanding anything`
  line `inconsistent therewith contained in any enactment other than this Act or in any instrument having effect`
  line `by virtue of any enactment other than this Act.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (40115)
  sectionNo (20)
  orderNo 20
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40115&sectionno=20&orderno=20&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_20_content:
  string
  line `(1) No suit, prosecution or other legal proceeding`
  line `shall lie against the Central Government, the metro railway administration or any officer or other`
  line `employee of that Government or the metro railway administration for anything which is in good faith`
  line `done or intended to be done under this Act.`
  line
  line `(2) No suit, prosecution or other legal proceeding shall lie against the Central Government or the`
  line `metro railway administration or any officer or other employee of that Government or the metro railway`
  line `administration for any damage caused or likely to be caused by anything which is in good faith done or`
  line `intended to be done under this Act.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (40116)
  sectionNo (21)
  orderNo 21
  title `Power to remove difficulties.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40116&sectionno=21&orderno=21&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_21_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order, do anything not inconsistent with such provisions which`
  line `appears to it to be necessary or expedient for the purpose of removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of two years from the`
  line `commencement of this Act.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (40117)
  sectionNo (22)
  orderNo 22
  title `Power to make rules.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40117&sectionno=22&orderno=22&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_22_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for the following matters, namely:--`
  line
  line `(a) the terms and conditions of service of the officers and other employees of the metro railway`
  line `administration under sub-section (2) of section 3;`
  line
  line `(b) the cases in which and the extent to which the procedure specified in section 4 for the opening`
  line `of the metro railway for public carriage of passengers may be dispensed with;`
  line
  line `(c) the volume and weight of the baggage containing personal belongings that may be carried by`
  line `a person while travelling in the metro railway;`
  line
  line `(d) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (40118)
  sectionNo (23)
  orderNo 23
  title `Repeal and saving.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00025_198510_1517807326841&sectionId=40118&sectionno=23&orderno=23&orgactid=AC_CEN_17_19_00025_198510_1517807326841
obj_root_law_sections_23_content:
  string
  line `(1) The Calcutta Metro Railway (Operation and Maintenance) Temporary`
  line `Provisions Ordinance, 1984 (13 of 1984), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance, shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_translations:
