  (str title) (str `The Special Protection Group Act, 1988`)
  (str actNumber) (str 34)
  (str enactmentDate) (str 1988-06-02)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1824`)
  (str sources) obj_root_law_sources
