obj_root_law_sections_1:
  sectionId (14324)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14324&sectionno=1&orderno=1&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Durgah Khawaja Saheb Act,`
  line 1955.
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1.1st March, 1956, vide Notification No. S.R.O. 482(E), dated 24th February, 1956, see Gazette of India, Extraordinary, Part`
  line `II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (14325)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14325&sectionno=2&orderno=2&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Chief Commissioner" means the Chief Commissioner of Ajmer, acting in his individual`
  line capacity;
  line
  line `(b) "Committee" means the Committee consituted under section 4;`
  line
  line `(c) "Durgah" means the institution known as the Durgah Khawaja Saheb, Ajmer, and includes the`
  line `premises called the Durgah Sharif with all buildings contained therein, together with all additions`
  line `thereto or all alerations thereof which may hereafter be made from time to time;`
  line
  line `(d) "Durgah Endowment" includes--`
  line
  line `(i) the Durgah Khawaja Saheb, Ajmer;`
  line
  line `(ii) all buildings and movable property within the boundaries of the Durgah Sharif;`
  line
  line `(iii) Durgah Jagir, including all land, houses and shops and all immovable property wherever`
  line `situated belonging to the Durgah Sharif;`
  line
  line `(iv) all other property and all income derived from any source whatsoever dedicated to the`
  line `Durgah or placed for any religious, pious or charitable purposes under the Durgah`
  line `Administration, including the Jagirdari villages of Hokran and Kishanpur in Ajmer; and`
  line
  line `(v) all such nazars of offerings as are received on behalf of the Durgah by the Nazim or any`
  line `person authorised by him;`
  line
  line `(e) "Nazim" means the Nazim appointed under section 9.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (14326)
  sectionNo (3)
  orderNo 3
  title `Act to override Act XX of 1863.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14326&sectionno=3&orderno=3&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_3_content:
  string
  line `This Act shall have effect notwithstanding anything`
  line `inconsistent therewith contained in the Religious Endowments Act, 1863 (XX of 1863).`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (14327)
  sectionNo (4)
  orderNo 4
  title `The Committee.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14327&sectionno=4&orderno=4&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_4_content:
  string
  line `(1) The administration, control and management of the Durgah Endowment`
  line `shall be vested in a Committee constituted in the manner hereinafter provided.`
  line
  line `(2) The Committee shall by the name of "The Durgah Committee, Ajmer", be a body corporate and`
  line `shall have perpetual succession and a common seal and shall by the said name sue and be sued through its`
  line president.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (14328)
  sectionNo (5)
  orderNo 5
  title `Composition of Committee.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14328&sectionno=5&orderno=5&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_5_content:
  string
  line `The Committee shall consist of not less than five and not more than`
  line `nine members all of whom shall be Hanafi Muslims and shall be appointed by the Central Government.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (14329)
  sectionNo (6)
  orderNo 6
  title `Term of office and resignation and removal of members and casual vacancies.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14329&sectionno=6&orderno=6&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_6_content:
  string
  line `(1) A member`
  line `of the Committee shall hold office for a period of five years from the date of his appointment but may resign his office earlier by giving notice in writing thereof to the Central Government and shall cease to`
  line `be a member on the resignation being accepted by that Government.`
  line
  line `(2) The Central Government may remove from office any member of the Committee--`
  line
  line `(a) who is of unsound mind and stands so declared by a competent court, or`
  line
  line `(b) who has applied for being adjudged an insolvent, or is an undischarged insolvent, or`
  line
  line `(c) who has been convicted of any offence involving moral turpitude, or`
  line
  line `(d) who has absented himself for a period of twelve consecutive months from the meetings of the`
  line `Committee; or`
  line
  line `(e) whose presence on the Committee would, in the opinion of the Central Government, be`
  line `prejudicial to the interests of the Durgah.`
  line
  line `(3) Casual vacancies among members of the Committee shall be filled by appointment made by the`
  line `Central Government inconsultation with the remaining members of the Committee.`
  line
  line `(4) The term of office of a member appointed to fill a casual vacancy shall be for so long only as the`
  line `member whose place has been filled would have been entitled to hold office if the vacancy had not`
  line occurred.
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (14330)
  sectionNo (7)
  orderNo 7
  title `President and vice-president.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14330&sectionno=7&orderno=7&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_7_content:
  string
  line `(1) The Committee shall elect a president and a vice-president`
  line `from among its members.`
  line
  line `(2) When the office of the president is vacant or in the absence of the president from any meeting, the`
  line `vice-president shall perform the functions of the president.`
  line
  line `(3) In the absence of the president and vice president, a meeting of the Committee may be presided`
  line `over by a member elected by the majority of the members present at the meeting.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (14331)
  sectionNo (8)
  orderNo 8
  title `Supersession of the Committee.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14331&sectionno=8&orderno=8&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_8_content:
  string
  line `If in the opinion of the Central Government the Committee is`
  line `guilty of gross mismanagement of the affairs of the Durgah or of neglect in the performance of its`
  line `functions, the Central Government may supersede the Committee and entrust any person with full powers`
  line `of the Committee until a new Committee is constituted in accordance with the provisions of this Act.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (14332)
  sectionNo (9)
  orderNo 9
  title `Power of Central Government to appoint Nazim.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14332&sectionno=9&orderno=9&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government may, in`
  line `consultation with the Committee, appoint a person to be the Nazim of the Durgah and the Nazim shall in`
  line `virtue of his office be the secretary of the Committee:`
  line
  line `Provided that no such consultation shall be necessary in the case of the appointment of the first`
  line Nazim.
  line
  line `(2) The Nazim shall be paid such salary and allowances as the Central Government may fix out of the`
  line `revenues of the Durgah Endowment.`
  line
  line `(3) The Committee shall exercise its powers of administration, control and management of the`
  line `Durgah Endowment through the Nazim.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (14333)
  sectionNo (10)
  orderNo 10
  title `Advisory Committee to advise Nazim.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14333&sectionno=10&orderno=10&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_10_content:
  string
  line `For the purpose of advising the Nazim in the discharge`
  line `of his functions under this Act and also for such other purposes as may be specified in any bye-laws of`
  line `the Committee, the Central Government may, in consultation with the Chief Commissioner, constitute an`
  line `Advisory Committee consisting of such number of persons, being Hanafi Muslims, not exceeding seven,`
  line `as the Central Government may think fit, such persons being chosen from among the residents of the`
  line `State of Ajmer or any of the neighbouring States.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (14334)
  sectionNo (11)
  orderNo 11
  title `Powers and duties of the Committee.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14334&sectionno=11&orderno=11&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_11_content:
  string
  line `The powers and duties of the Committee shall be--`
  line
  line `(a) to administer, control and manage the Durgah Endowment;`
  line
  line `(b) to keep the buildings within the boundaries of the Durgah Sharif and all buildings, houses and`
  line `shops comprised in the Drugah Endowment in proper order and in a state of good repair;`
  line
  line `(c) to receive all moneys and other income of the Durgah Endowment;`
  line
  line `(d) to see that the Endowment funds are spent in the manner desired by the donors;`
  line
  line `(e) to pay salaries, allowances and perquisites and make all other payments due out of, or charged`
  line `on, the revenues or income of the Durgah Endowment.`
  line
  line `(f) to determine the privileges of the Khadims and to regulate their presence in the Durgah by the`
  line `grant to them of licences in that behalf, if the Committee thinks it necessary so to do;`
  line
  line `(g) to define the powers and duties of the Advisory Committee;`
  line
  line `(h) to determine the functions and powers, if any, which the Sajjadanashin may exercise in`
  line `relation to the Durgah;`
  line
  line `(i) to appoint, suspend or dismiss servants of the Durgah Endowment;`
  line
  line `(j) to make such provision for the education and maintenance of the indigent descendants of`
  line `Khawaja Moin-ud-din Chishti and their families and the indigent Khadims and their families residing`
  line `in India as the Committee considers expedient consistently with the financial position of the Durgah;`
  line
  line `(k) to delegate to the Nazim such powers and functions as the Committee may think fit;`
  line
  line `(l) to do all other such things as may be incidental or conducive to the efficient administration of`
  line `the Durgah.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (14335)
  sectionNo (12)
  orderNo 12
  title `Remuneration of the Sajjadanashin.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14335&sectionno=12&orderno=12&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_12_content:
  string
  line `There shall be paid to the person for the time being`
  line `holding the office of the Sajjadanashin remuneration at the rate of rupees two hundred per mensem out of`
  line `the revenues of the Durgah Endowment.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (14336)
  sectionNo (13)
  orderNo 13
  title `Succession to the office of Sajjadanashin.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14336&sectionno=13&orderno=13&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_13_content:
  string
  line `(1) As soon as the office of the Sajjadanashin falls`
  line `vacant, the Committee shall, with the previous approval of the Chief Commissioner, make such interim`
  line `arrangements for the performance of the functions of the Sajjadanashin as it may think fit, and`
  line `immediately thereafter publish a notice in such form and manner as may be determined by the`
  line `Committee, inviting applications within one month of such publication from persons claiming to succeed`
  line `to that office.`
  line
  line `(2) Where only one person claims to succeed to the office of the Sajjadanashin and the Committee is`
  line `satisfied as to his right to succeed, it shall, with the previous approval of the Chief Commissioner, pass an`
  line `order in writing according recognition as Sajjadanashin to such person.`
  line
  line `(3) Where more persons than one claim to succeed to the office of the Sajjadanashin, the Committee`
  line `shall, after consultation with the Chief Commissioner, refer the dispute to the Judicial Commissioner of`
  line `Ajmer for a decision regarding the claim to succeed to that office, and the Judicial Commissioner, after`
  line `taking such evidence as he considers necessary and after giving an opportunity to the claimants to be`
  line `heard in respect of their claims, shall communicate his decision to the Committee.`
  line
  line `(4) The Commitee, on the receipt of the decision, shall, with the previous approval of the Chief`
  line `Commissioner, pass an order in writing in accordance with such decision declaring the person found`
  line `entitled to succeed to the office of the Sajjadanashin and according recognition as Sajjadanashin to such`
  line person.
  line
  line `(5) An order passed by the Committee under sub-section (2) or sub-section (4) shall be final and shall`
  line `not be questioned in any court.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (14337)
  sectionNo (14)
  orderNo 14
  title `Power to solicit or receive offerings on behalf of the Durgah.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14337&sectionno=14&orderno=14&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_14_content:
  string
  line `^1[(1)] It shall be lawful for the`
  line `Nazim or any person authorised by him in this behalf to solicit and receive on behalf of the Durgah any`
  line `nazars or offerings from any person, and notwithstanding anything contained in any rule of law or`
  line `decision to the contrary, no person other than the Nazim of any person authorised by him in this behalf`
  line `shall receive or be entitled to receive nazars or offerings or behalf of the Durgah.`
  line
  line `^2[(2) Whoever solicits or receives any nazars or offerings in contravention of the provisions of subsection`
  line `(1), shall be punishable with fine which may extend to one thousand rupees.`
  line
  line `(3) The Nazim, the Sajjadanashin, the employees and servants of the Durgah Endowment and all`
  line `other persons authorised to do any act under this Act shall, while acting or purporting to act in pursuance`
  line `of any of the provisions made by or under this Act, be deemed to be public servants within the meaning of`
  line `section 21 of the Indian Penal Code.]`
obj_root_law_sections_14_footnotes:
  string
  line `1. Section 14 re-numbered as sub-section (1) thereof by Act 20 of 1964, s. 2 (w.e.f. 1-6-1964).`
  line
  line `2. Ins. by s. 2, ibid. (w.e.f. 1-6-1964).`
obj_root_law_sections_15:
  sectionId (14338)
  sectionNo (15)
  orderNo 15
  title `Committee to observe Muslim Law and tenets of the Chishti Saint.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14338&sectionno=15&orderno=15&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_15_content:
  string
  line `Save as otherwise`
  line `provided under any enactment for the time being in force, the committee shall, in exercise of its powers`
  line `and the discharge of its duties, follow the rules of Muslim Law applicable to Hanafi Muslims in India,`
  line `and shall conduct and regulate the established rites and ceremonies in accordance with the tenets of the`
  line `Chishti Saint.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (14339)
  sectionNo (16)
  orderNo 16
  title `Board of Arbitration.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14339&sectionno=16&orderno=16&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_16_content:
  string
  line `(1) If any dispute arises between the Committee on the one part and the`
  line `Sajjadanashin, any Khadim, and any person claiming to be the servant of the Durgah under some`
  line `hereditary right or any one or more of them on the other part and such dispute does not, in the opinion of`
  line `the Committee, relate to any religious usage or custom or to the performance of any religious office, it`
  line `shall at the request of either party to the dispute, be referred to a Board of Arbitration consisting of--`
  line
  line `(i) a nominee of the Committee;`
  line
  line `(ii) a nominee of the other party to the dispute; and`
  line
  line `(iii) a person who holds or has held the office of, or is acting or has acted as, a district judge, to be`
  line `appointed by the Central Government, and the award of the Board shall be final and shall not be`
  line `questioned in any Court.`
  line
  line `(2) No suit shall lie in any Court in respect of any matter which is required by sub-section (1) to be`
  line `referred to a Board of Arbitration.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (14340)
  sectionNo (17)
  orderNo 17
  title `Defect in the constitution of, or vacancy in, the Committee not to invalidate acts and proceedings.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14340&sectionno=17&orderno=17&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_17_content:
  string
  line `No act or proceeding of the Committee shall be invalidated merely by reason of the`
  line `existence of a vacancy among its members or a defect in the constitution thereof.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (14341)
  sectionNo (18)
  orderNo 18
  title `Enforcement of final orders of Committee.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14341&sectionno=18&orderno=18&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_18_content:
  string
  line `Where in the exercise of its powers and`
  line `performance of its duties the Committee passes any final order against any person directing him to do, or`
  line `to abstain from doing something, the person against whom the order is directed shall be bound to comply`
  line `with the order and in case of non-compliance with such order any civil court within the local limits of`
  line `whose jurisdiction the person against whom the order has been passed, resides or carries on business may`
  line `execute the order in the same manner and by the same procedure as if it were a decree or order passed by`
  line `itself in a suit.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (14342)
  sectionNo (19)
  orderNo 19
  title `Audit of accounts and annual report.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14342&sectionno=19&orderno=19&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_19_content:
  string
  line `(1) The accounts of the Durgah shall be audited every`
  line `year by such persons and in such manner as the Central Government may direct.`
  line
  line `(2) The Committee shall every year prepare a report on the administration of the Durgah, which,`
  line `together with the accounts of the Durgah and the report of the auditor thereon, shall be published in the`
  line `Official Gazette.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (14343)
  sectionNo (20)
  orderNo 20
  title Bye-laws.
  content obj_root_law_sections_20_content
  footnotes `1. Ins. by Act 20 of 1983, s. 2 and the Schedule (w.e.f. 15-3-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14343&sectionno=20&orderno=20&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_20_content:
  string
  line `(1) The Committee may make bye-laws to carry out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power such bye-laws may`
  line `provide for--`
  line
  line `(a) the division of duties among the president and the members of the Committee;`
  line
  line `(b) the time and place of, the quorum for, and procedure and conduct of business at, the meetings`
  line `of the Committee;`
  line
  line `(c) the security, if any, to be taken from the employees of the Committee;`
  line
  line `(d) the books and accounts to be kept at the office of the Committee;`
  line
  line `(e) the custody and investment of the property and the funds of the Durgah;`
  line
  line `(f) the details to be included in or excluded from the budget of the Durgah;`
  line
  line `(g) the persons by whom receipts may be granted for money paid to the Committee;`
  line
  line `(h) the maintenance of peace and order within the Durgah compound and regulating the conduct`
  line `of persons within the precincts of the Durgah;`
  line
  line `(i) the duties and powers of the employees of the Durgah;`
  line
  line `(j) the regulation of the cooking of degs and distribution of the food so cooked, notwithstanding`
  line `any judicial decision relating to the right of any person or class of persons to participate in such`
  line `cooking or distribution;`
  line
  line `(k) the powers and functions of the Advisory Committee and the matters in which the advice of`
  line `the Advisory Committee may be sought by the Nazim;`
  line
  line `(l) the manner of entering into contracts by or on behalf of the Committee.`
  line
  line `(3) Any power to make bye-laws conferred by this section is conferred subject to the condition of the`
  line `bye-laws being first published in draft for objections by being hung up on the premises of the Durgah and`
  line `of their not taking effect until they have been approved and confirmed by the Central Government and`
  line `published in the Official Gazette.`
  line
  line `(4) The Central Government in approving and confirming a bye-law may make any change therein`
  line `which appears to be necessary.`
  line
  line `(5) The Central Government may, after previous publication of its intention cancel any bye-law`
  line `which it has approved and confirmed, and thereupon the bye-law shall cease to have effect.`
  line
  line `^1[(6) Every bye-law made under this section and every order made by the Central Government under`
  line `sub-section(5) shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the bye-law or order, or`
  line `both Houses agree that the bye-law or order should not be made, the bye-law or order shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that bye-law or order.]`
obj_root_law_sections_21:
  sectionId (14344)
  sectionNo (21)
  orderNo 21
  title `Transitional provisions.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14344&sectionno=21&orderno=21&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_21_content:
  string
  line `The person holding, the office of Sajjadanashin immediately before`
  line `the commencement of this Act shall, on and from such commencement, continue to hold that office`
  line `subject to the other provisions of this Act and to the final decision in the suit relating to that office which`
  line `is pending on such commencement and to which the said person is a party.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (14345)
  sectionNo (22)
  orderNo 22
  title Repeal.
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00001_195536_1517807318826&sectionId=14345&sectionno=22&orderno=22&orgactid=AC_CEN_25_35_00001_195536_1517807318826
obj_root_law_sections_22_content:
  string
  line `The Durgah Khawaja,Saheb Act, 1936 (XXIII of 1936) and the Durgah Khawaja Saheb`
  line `(Emergency Provisions) Act, 1950 (XVII of 1950) are hereby repealed.`
obj_root_law_sections_22_footnotes:
  string
  line
