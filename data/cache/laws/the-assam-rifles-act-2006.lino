  (str slug) (str the-assam-rifles-act-2006)
  (str handle) (str 2037)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Assam Rifles Act, 2006`)
  (str actNumber) (str 47)
  (str enactmentDate) (str 2006-11-03)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2037`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `असम राइफल्स अधिनियम, 2006`)
  (str actYear) (str 2006)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of Internal Security`)
  (str longTitle) (str `An Act to consolidate and amend the law relating to the governance of the Assam Rifles, an Armed Force of the Union for ensuring the security of the borders of India, to carry out Counter Insurgency Operations in the specified areas and to act in aid of civil authorities for the maintenance of the law and order and for matters connected therewith.`)
  (str enforcementDate) (str 20-02-2006)
  (str notification) (str `20th February, 2006, vide notification No. S.O. 517(E) dated 20th February, 2006, see Gazette of India, Extraordinary, Part II sec.3(ii).`)
