obj_root_law:
  slug the-assam-rifles-act-2006
  handle (2037)
  collectionHandle 123456789/1362
  title `The Assam Rifles Act, 2006`
  actNumber (47)
  enactmentDate 2006-11-03
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2037`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `असम राइफल्स अधिनियम, 2006`
  actYear (2006)
  ministry `Ministry of Home Affairs`
  department `Department of Internal Security`
  longTitle `An Act to consolidate and amend the law relating to the governance of the Assam Rifles, an Armed Force of the Union for ensuring the security of the borders of India, to carry out Counter Insurgency Operations in the specified areas and to act in aid of civil authorities for the maintenance of the law and order and for matters connected therewith.`
  enforcementDate 20-02-2006
  notification `20th February, 2006, vide notification No. S.O. 517(E) dated 20th February, 2006, see Gazette of India, Extraordinary, Part II sec.3(ii).`
  fetchedAt `2026-05-09T17:50:56.718Z`
  translations obj_root_law_translations
