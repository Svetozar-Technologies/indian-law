obj_root_law_sections_1:
  sectionId (16701)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16701&sectionno=1&orderno=1&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Telecom Regulatory`
  line `Authority of India Act, 1997.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall be deemed to have come into force on the 25th day of January, 1997.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (16702)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16702&sectionno=2&orderno=2&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means the date with effect from which the Authority is established under`
  line `sub-section (1) of section 3;`
  line
  line `^1[(aa) "Appellate Tribunal" means the Telecom Disputes Settlement and Appellate Tribunal`
  line `established under section 14;]`
  line
  line `(b) "Authority" means the Telecom Regulatory Authority of India established under`
  line `sub-section (1) of section 3;`
  line
  line `(c) "Chairperson" means the Chairperson of the Authority appointed under sub-section (3) of`
  line `section 3;`
  line
  line `(d) "Fund" means the Fund constituted under sub-section (1) of section 22;`
  line
  line `(e) licensee means any person licensed under sub-section (1) of section 4 of the Indian`
  line `Telegraph Act, 1885 (13 of 1885) for providing specified public telecommunication services;`
  line
  line `^1[(ea) "licensor" means the Central Government or the telegraph authority who grants a licence`
  line `under section 4 of the Indian Telegraph Act, 1885 (13 of 1885);]`
  line
  line `(f) "member" means a member of the Authority appointed under sub-section (3) of section 3 and`
  line `includes the Chairperson and the Vice-Chairperson;`
  line
  line `(g) "notification" means a notification published in the Official Gazette;`
  line
  line `(h) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(i) "regulations" means regulations made by the Authority under this Act;`
  line
  line `(j) "service provider" means the ^2[Government as a service provider] and includes a licensee;`
  line
  line `(k) "telecommunication service" means service of any description (including electronic mail,`
  line `voice mail, data services, audio tex services, video tex services, radio paging and cellular mobile`
  line `telephone services) which is made available to users by means of any transmission or reception of signs, signals, writing, images and sounds or intelligence of any nature, by wire, radio, visual or other`
  line `electro-magnetic means but shall not include broadcasting services.`
  line
  line `^3[Provided that the Central Government may notify other service to be telecommunication service`
  line `including broadcasting services.]`
  line
  line `(2) Words and expressions used and not defined in this Act but defined in the Indian Telegraph Act,`
  line `1885 (13 of 1885) or the Indian Wireless Telegraphy Act, 1933 (17 of 1933), shall have the meanings`
  line `respectively assigned to them in those Acts.`
  line
  line `(3) Any reference in this Act to a law which is not in force in the State of Jammu and Kashmir* shall in relation to that State be construed as a reference to the corresponding law, if any, in that State.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Ins. by s. 3, ibid. (w.e.f. 24-1-2000).`
  line
  line `2. Subs. by s. 3, ibid., for "Government" (w.e.f. 24-1-2000).`
  line
  line `3. Ins. by Act 2 of 2000, s. 3 (w.e.f. 24-1-2000).`
  line
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_3:
  sectionId (16703)
  sectionNo (3)
  orderNo 3
  title `Establishment and incorporation of Authority.`
  content obj_root_law_sections_3_content
  footnotes `1 Subs. by s. 4, ibid., for sub-section (3) (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16703&sectionno=3&orderno=3&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_3_content:
  string
  line `(1) With effect from such date as the Central`
  line `Government may, by notification appoint, there shall be established, for the purposes of this Act, an`
  line `Authority to be called the Telecom Regulatory Authority of India.`
  line
  line `(2) The Authority shall be a body corporate by the name aforesaid, having perpetual succession and a`
  line `common seal, with power, subject to the provisions of this Act, to acquire, hold and dispose of property,`
  line `both movable and immovable, and to contract, and shall, by the said name, sue or be sued.`
  line
  line `^1[(3) The Authority shall consist of a Chairperson, and not more than two whole-time members and`
  line `not more than two part-time members, to be appointed by the Central Government.]`
  line
  line `(4) The head office of the Authority shall be at New Delhi.`
obj_root_law_sections_4:
  sectionId (16704)
  sectionNo (4)
  orderNo 4
  title `Qualifications for appointment of Chairperson and other members.`
  content obj_root_law_sections_4_content
  footnotes `1 . Subs. by s. 5, ibid., for section 4 (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16704&sectionno=4&orderno=4&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_4_content:
  string
  line `^1[4. Qualifications for appointment of Chairperson and other members.-- The Chairperson and`
  line `other members of the Authority shall be appointed by the Central Government from amongst persons who`
  line `have special knowledge of, and professional experience in, telecommunication, industry, finance,`
  line `accountancy, law, management or consumer affairs:`
  line
  line `Provided that a person who is, or has been, in the service of Government shall not be appointed as a`
  line `member unless such person has held the post of Secretary or Additional Secretary, or the post of`
  line `Additional Secretary and Secretary to the Government of India or any equivalent post in the Central`
  line `Government or the State Government for a period of not less than three years.]`
obj_root_law_sections_5:
  sectionId (16705)
  sectionNo (5)
  orderNo 5
  title `Term of office, conditions of service, etc., of Chairperson and other members.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16705&sectionno=5&orderno=5&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_5_content:
  string
  line `(1) Before`
  line `appointing any person as the Chairperson or member, the Central Government shall satisfy itself that the`
  line `person does not have any such financial or other interest as is likely to affect prejudicially his functions as`
  line `such member.`
  line
  line `^1[(2) The Chairperson and other members shall hold office for a term not exceeding three years, as the`
  line `Central Government may notify in this behalf, from the date on which they enter upon their offices or`
  line `until they attain the age of sixty-five years, whichever is earlier.`
  line
  line `(3) On the commencement of the Telecom Regulatory Authority of India (Amendment) Act, 2000`
  line `(2 of 2000), a person appointed as Chairperson of the Authority and every other person appointed as`
  line `member and holding office as such immediately before such commencement shall vacate their respective`
  line `offices and such Chairperson and such other members shall be entitled to claim compensation not`
  line `exceeding three months pay and allowances for the premature termination of the term of their offices or`
  line `of any contract of service.]`
  line
  line `(4) The employee of the Government on his ^2[selection as the Chairperson or whole-time member]`
  line `shall have to retire from service before ^3[joining as the Chairperson or a whole-time member, as the case`
  line `may be.]`
  line
  line `(5) The salary and allowances payable to and the other terms and conditions of service of the`
  line `Chairperson and ^4[whole-time members] shall be such as may be prescribed.`
  line
  line `(6) The salary, allowances and other conditions of service of the Chairperson or of a member shall not`
  line `be varied to his disadvantage after appointment.`
  line
  line `^5[(6A) The part-time members shall receive such allowances as may be prescribed.]`
  line
  line `(7) Notwithstanding anything contained in sub-section (2) ^6***, a member may--`
  line
  line `(a) relinquish his office by giving in writing to the Central Government notice of not less than`
  line `three months; or`
  line
  line `(b) be removed from his office in accordance with the provisions of section 7.`
  line
  line `^7[(8) The Chairperson and the whole-time members shall not, for a period of two years from the date`
  line `on which they cease to hold office as such, except with the previous approval of the Central Government,`
  line accept--
  line
  line `(a) any employment either under the Central Government or under any State Government; or`
  line
  line `(b) any appointment in any company in the business of telecommunication services.]`
  line
  line `(9) A vacancy caused to the office of the Chairperson or any other member shall be filled up within a`
  line `period of three months from the date on which such vacancy occurs.`
  line
  line `^8* * * * *`
obj_root_law_sections_5_footnotes:
  string
  line `1 Subs. by s. 6, ibid., for sub-sections (2) and (3) (w.e.f. 24-1-2000).`
  line
  line `2 Subs. by s. 6, ibid., for "selection as member" (w.e.f. 24-1-2000).`
  line
  line `3 Subs. by s. 6, ibid., for "joining as member" (w.e.f. 24-1-2000).`
  line
  line `4 Subs. by Act 2 of 2000, s. 6, for "other members" (w.e.f. 24-1-2000).`
  line
  line `5 Ins. by s. 6, ibid. (w.e.f. 24-1-2000).`
  line
  line `6. The words, brackets and figure "or sub-section (3)" omitted by s. 6, ibid. (w.e.f. 24-1-2000).`
  line
  line `7 Subs. by Act 20 of 2014, s. 2, for sub-section (8) (w.e.f. 28-5-2014).`
  line
  line `8. The Explanation omitted by s. 2, ibid. (w.e.f. 28-5-2014).`
obj_root_law_sections_6:
  sectionId (16706)
  sectionNo (6)
  orderNo 6
  title `Powers of Chairperson and Vice-Chairperson.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16706&sectionno=6&orderno=6&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_6_content:
  string
  line `(1) The Chairperson shall have powers of`
  line `general superintendence and directions in the conduct of the affairs of the Authority and he shall, in`
  line `addition to presiding over the meetings of the Authority, exercise and discharge such powers and`
  line `functions of the Authority and shall discharge such other powers and functions as may be prescribed.`
  line
  line `(2) The Central Government may appoint one of the members to be a Vice-Chairperson of the`
  line `Authority who shall exercise and discharge such powers and functions of the Chairperson as may be`
  line `prescribed or as may be delegated to him by the Authority.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (16707)
  sectionNo (7)
  orderNo 7
  title `Removal and suspension of member from office in certain circumstances.`
  content obj_root_law_sections_7_content
  footnotes `1 Subs. by Act 2 of 2000, s. 7, for sub-sections (2) and (3) (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16707&sectionno=7&orderno=7&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_7_content:
  string
  line `(1) The Central`
  line `Government may remove from office any member, who,--`
  line
  line `(a) has been adjudged an insolvent; or`
  line
  line `(b) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as a member; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions as`
  line `a member; or`
  line
  line `(e) has so abused his position as to render his continuance in office prejudicial to the public`
  line interest.
  line
  line `^1[(2) No such member shall be removed from his office under clause (d) or clause (e) of`
  line `sub-section (1) unless he has been given a reasonable opportunity of being heard in the matter.]`
obj_root_law_sections_8:
  sectionId (16708)
  sectionNo (8)
  orderNo 8
  title Meetings.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16708&sectionno=8&orderno=8&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_8_content:
  string
  line `(1) The Authority shall meet at such times and places, and shall observe such rules of`
  line `procedure in regard to the transaction of business at its meetings (including quorum at such meetings) as`
  line `may be provided by regulations.`
  line
  line `(2) The Chairperson or, if for any reason, he is unable to attend a meeting of the Authority,`
  line `Vice-Chairperson and in his absence, any other member chosen by the members present from amongst`
  line `themselves at the meeting shall presided at the meeting.`
  line
  line `(3) All questions which come up before any meeting of the Authority shall be decided by a majority`
  line `vote of the members present and voting, and in the event of an equality of votes, the Chairperson or in his`
  line `absence, the person presiding, shall have a second or casting vote.`
  line
  line `(4) The Authority may make regulations for the transaction of business at its meetings.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (16709)
  sectionNo (9)
  orderNo 9
  title `Vacancies, etc., not to invalidate proceedings of Authority.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16709&sectionno=9&orderno=9&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_9_content:
  string
  line `No act or proceeding of the`
  line `Authority shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Authority; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Authority; or`
  line
  line `(c) any irregularity in the procedure of the Authority not affecting the merits of the case.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (16710)
  sectionNo (10)
  orderNo 10
  title `Officers and other employees of Authority.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16710&sectionno=10&orderno=10&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_10_content:
  string
  line `(1) The Authority may appoint officers and such`
  line `other employees as it considers necessary for the efficient discharge of its functions under this Act.`
  line
  line `(2) The salary and allowances payable to and the other conditions of service of the officers and other`
  line `employees of the Authority appointed under sub-section (1) shall be such as may be ^1[prescribed]:`
  line
  line `^2[Provided that any regulation, in respect of the salary and allowances payable to and other conditions`
  line `of service of the officers and other employees of the Authority, made before the commencement of the`
  line `Telecom Regulatory Authority of India (Amendment) Act, 2000 (2 of 2000), shall cease to have effect`
  line `immediately on the notification of rules made under clause (ca) of sub-section (2) of section 35.]`
obj_root_law_sections_10_footnotes:
  string
  line `1 Subs. by Act 2 of 2000, s. 8, for "determined by regulations" (w.e.f. 24-1-2000).`
  line
  line `2 Ins. by s. 8, ibid. (w.e.f. 24-1-2000).`
obj_root_law_sections_11:
  sectionId (16711)
  sectionNo (11)
  orderNo 11
  title `Functions of Authority.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16711&sectionno=11&orderno=11&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_11_content:
  string
  line `^1[(1) Notwithstanding anything contained in the Indian Telegraph Act,`
  line `1885 (13 of 1885), the functions of the Authority shall be to--`
  line
  line `(a) make recommendations, either suo motu or on a request from the licensor, on the following`
  line `matters, namely:--`
  line
  line `(i) need and timing for introduction of new service provider;`
  line
  line `(ii) terms and conditions of licence to a service provider;`
  line
  line `(iii) revocation of license for non-compliance of terms and conditions of licence;`
  line
  line `(iv) measures to facilitate competition and promote efficiency in the operation of`
  line `telecommunication services so as to facilitate growth in such services;`
  line
  line `(v) technological improvements in the services provided by the service providers;`
  line
  line `(vi) type of equipment to be used by the service providers after inspection of equipment used`
  line `in the network;`
  line
  line `(vii) measures for the development of telecommunication technology and any other matter`
  line `relatable to telecommunication industry in general;`
  line
  line `(viii) efficient management of available spectrum;`
  line
  line `(b) discharge the following functions, namely:--`
  line
  line `(i) ensure compliance of terms and conditions of licence;`
  line
  line `(ii) notwithstanding anything contained in the terms and conditions of the licence granted`
  line `before the commencement of the Telecom Regulatory Authority of India (Amendment)`
  line `Act, 2000 (2 of 2000), fix the terms and conditions of inter-connectivity between the service`
  line providers;
  line
  line `(iii) ensure technical compatibility and effective inter-connection between different service`
  line providers;
  line
  line `(iv) regulate arrangement amongst service providers of sharing their revenue derived from`
  line `providing telecommunication services;`
  line
  line `(v) lay-down the standards of quality of service to be provided by the service providers and`
  line `ensure the quality of service and conduct the periodical survey of such service provided by the`
  line `service providers so as to protect interest of the consumers of telecommunication service;`
  line
  line `(vi) lay-down and ensure the time period for providing local and long distance circuits of`
  line `telecommunication between different service providers;`
  line
  line `(vii) maintain register of inter-connect agreements and of all such other matters as may be`
  line `provided in the regulations;`
  line
  line `(viii) keep register maintained under clause (vii) open for inspection to any member of public`
  line `on payment of such fee and compliance of such other requirement as may be provided in the`
  line regulations;
  line
  line `(ix) ensure effective compliance of universal service obligations;`
  line
  line `(c) levy fees and other charges at such rates and in respect of such services as may be determined`
  line `by regulations;`
  line
  line `(d) perform such other functions including such administrative and financial functions as may be`
  line `entrusted to it by the Central Government or as may be necessary to carry out the provisions of this`
  line `Act:`
  line
  line `Provided that the recommendations of the Authority specified in clause (a) of this sub-section`
  line `shall not be binding upon the Central Government:`
  line
  line `Provided further that the Central Government shall seek the recommendations of the Authority in`
  line `respect of matters specified in sub-clauses (i) and (ii) of clause (a) of this sub-section in respect of`
  line `new licence to be issued to a service provider and the Authority shall forward its recommendations`
  line `within a period of sixty days from the date on which that Government sought the recommendations:`
  line
  line `Provided also that the Authority may request the Central Government to furnish such information`
  line `or documents as may be necessary for the purpose of making recommendations under sub-clauses (i)`
  line `and (ii) of clause (a) of this sub-section and that Government shall supply such information within a`
  line `period of seven days from receipt of such request:`
  line
  line `Provided also that the Central Government may issue a licence to a service provider if no`
  line `recommendations are received from the Authority within the period specified in the second proviso or`
  line `within such period as may be mutually agreed upon between the Central Government and the`
  line `Authority:`
  line
  line `Provided also that if the Central Government, having considered that recommendation of the`
  line `Authority, comes to a prima facie conclusion that such recommendation cannot be accepted or needs`
  line `modifications, it shall refer the recommendation back to the Authority for its reconsideration, and the`
  line `Authority may, within fifteen days from the date of receipt of such reference, forward to the Central`
  line `Government its recommendation after considering the reference made by that Government. After`
  line `receipt of further recommendation if any, the Central Government shall take a final decision.]`
  line
  line `(2) Notwithstanding anything contained in the Indian Telegraph Act, 1885 (13 of 1885), the`
  line `Authority may, from time to time, by order, notify in the Official Gazette the rates at which the`
  line `telecommunication services within India and outside India shall be provided under this Act including`
  line `the rates at which messages shall be transmitted to any country outside India:`
  line
  line `Provided that the Authority may notify different rates for different persons or class of persons for`
  line `similar telecommunication services and where different rates are fixed as aforesaid the Authority shall`
  line `record the reasons therefor.`
  line
  line `(3) While discharging its functions ^2[under sub-section (1) or sub-section (2)], the Authority shall not`
  line `act against the interest of the sovereignty and integrity of India, the security of the State, friendly relations`
  line `with foreign States, public order, decency or morality.`
  line
  line `(4) The Authority shall ensure transparency while exercising its powers and discharging its functions.`
obj_root_law_sections_11_footnotes:
  string
  line `1 Subs. by s. 9, ibid., for sub-section (1) (w.e.f. 24-1-2000).`
  line
  line `2 Subs. by Act 2 of 2000, s. 9, for "under sub-section (1)" (w.e.f. 24-1-2000).`
obj_root_law_sections_12:
  sectionId (16712)
  sectionNo (12)
  orderNo 12
  title `Powers of Authority to call for information, conduct investigations, etc.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16712&sectionno=12&orderno=12&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_12_content:
  string
  line `(1) Where the`
  line `Authority considers it expedient so to do, it may, by order in writing,--`
  line
  line `(a) call upon any service provider at any time to furnish in writing such information or`
  line `explanation relating to its affairs as the Authority may require; or`
  line
  line `(b) appoint one or more persons to make an inquiry in relation to the affairs of any service`
  line `provider; and`
  line
  line `(c) direct any of its officers or employees to inspect the books of account or other documents of`
  line `any service provider.`
  line
  line `(2) Where any inquiry in relation to the affairs of a service provider has been undertaken under`
  line `sub-section (1),--`
  line
  line `(a) every officer of the Government Department, if such service provider is a department of the`
  line Government;
  line
  line `(b) every director, manager, secretary or other officer, if such service provider is a company; or`
  line
  line `(c) every partner, manager, secretary or other officer, if such service provider is a firm; or`
  line
  line `(d) every other person or body of persons who has had dealings in the course of business with any`
  line `of the persons mentioned in clauses (b) and (c),`
  line
  line `shall be bound to produce before the Authority making the inquiry, all such books of account or other`
  line `documents in his custody or power relating to, or having a bearing on the subject-matter of such inquiry`
  line `and also to furnish to the Authority with any such statement or information relating thereto, as the case`
  line `may be, required of him, within such time as may be specified.`
  line
  line `(3) Every service provider shall maintain such books of account or other documents as may be`
  line prescribed.
  line
  line `(4) The Authority shall have the power to issue such directions to service providers as it may consider`
  line `necessary for proper functioning by service providers.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (16713)
  sectionNo (13)
  orderNo 13
  title `Power of Authority to issue directions.`
  content obj_root_law_sections_13_content
  footnotes `1 Ins. by s. 10, ibid. (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16713&sectionno=13&orderno=13&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_13_content:
  string
  line `The Authority may, for the discharge of its functions`
  line `under sub-section (1) of section 11, issue such directions from time to time to the service providers, as it`
  line `may consider necessary:`
  line
  line `^1[Provided that no direction under sub-section (4) of section 12 or under this section shall be issued`
  line `except on the matters specified in clause (b) of sub-section (1) of section 11.]`
obj_root_law_sections_14:
  sectionId (16714)
  sectionNo (14)
  orderNo 14
  title `Establishment of Appellate Tribunal.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16714&sectionno=14&orderno=14&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_content:
  string
  line `^1[The Central Government shall, by notification, establish`
  line `an Appellate Tribunal to be known as the Telecom Disputes Settlement and Appellate Tribunal to--`
  line
  line `(a) adjudicate any dispute--`
  line
  line `(i) between a licensor and a licensee;`
  line
  line `(ii) between two or more service providers;`
  line
  line `(iii) between a service provider and a group of consumers:`
  line
  line `Provided that nothing in this clause shall apply in respect of matters relating to--`
  line
  line `(A) the monopolistic trade practice, restrictive trade practice and unfair trade practice which`
  line `are subject to the jurisdiction of the Monopolies and Restrictive Trade Practices Commission`
  line `established under sub-section (1) of section 5 of the Monopolies and Restrictive Trade Practices`
  line `Act, 1969 (54 of 1969);`
  line
  line `(B) the complaint of an individual consumer maintainable before a Consumer Disputes`
  line `Redressal Forum or a Consumer Disputes Redressal Commission or the National Consumer`
  line `Redressal Commission established under section 9 of the Consumer Protection Act, 1986`
  line `(68 of 1986);`
  line
  line `(C) the dispute between telegraph authority and any other person referred to in sub-section`
  line `(1) of section 7B of the Indian Telegraph Act, 1885 (13 of 1885);`
  line
  line `(b) hear and dispose of appeal against any direction, decision or order of the Authority under this`
  line Act.
  line
  line `^2[(c) exercise jurisdiction, powers and authority conferred on—`
  line
  line `(i) the Appellate Tribunal under the Information Technology Act, 2000 (21 of 2000); and`
  line
  line `(ii) the Appellate Tribunal under the Airports Economic Regulatory Authority of India Act,`
  line `2008 (27 of 2008).]`
obj_root_law_sections_14_footnotes:
  string
  line `1 Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  line
  line `2. Ins. by Act 7 of 2017, s. 168 (w.e.f. 26-5-2017).`
obj_root_law_sections_14_a:
  sectionId (16715)
  sectionNo 14A
  orderNo 15
  title `Application for settlement of disputes and appeals to Appellate Tribunal.`
  content obj_root_law_sections_14_a_content
  footnotes `1 Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16715&sectionno=14A&orderno=15&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_a_content:
  string
  line `^1[14A. Application for settlement of disputes and appeals to Appellate Tribunal.-- (1) The Central`
  line `Government or a State Government or a local authority or any person may make an application to the`
  line `Appellate Tribunal for adjudication of any dispute referred to in clause (a) of section 14.`
  line
  line `(2) The Central Government or a State Government or a local authority or any person aggrieved by`
  line `any direction, decision or order made by the Authority may prefer an appeal to the Appellate Tribunal.`
  line
  line `(3) Every appeal under sub-section (2) shall be preferred within a period of thirty days from the date`
  line `on which a copy of the direction or order or decision made by the Authority is received by the Central`
  line `Government or the State Government or the local authority or the aggrieved person and it shall be in such`
  line `form, verified in such manner and be accompanied by such fee as may be prescribed:`
  line
  line `Provided that the Appellate Tribunal may entertain any appeal after the expiry of the said period of`
  line `thirty days if it is satisfied that there was sufficient cause for not filing it within that period.`
  line
  line `(4) On receipt of an application under sub-section (1) or an appeal under sub-section (2), the`
  line `Appellate Tribunal may, after giving the parties to the dispute or the appeal an opportunity of being heard,`
  line `pass such orders thereon as it thinks fit.`
  line
  line `(5) The Appellate Tribunal shall send a copy of every order made by it to the parties to the dispute or`
  line `the appeal and to the Authority, as the case may be.`
  line
  line `(6) The application made under sub-section (1) or the appeal preferred under sub-section (2) shall be`
  line `dealt with by it as expeditiously as possible and endeavour shall be made by it to dispose of the`
  line `application or appeal finally within ninety days from the date of receipt of application or appeal, as the`
  line `case may be:`
  line
  line `Provided that where any such application or appeal could not be disposed of within the said period of`
  line `ninety days, the Appellate Tribunal shall record its reasons in writing for not disposing of the application`
  line `or appeal within that period.`
  line
  line `(7) The Appellate Tribunal may, for the purpose of examining the legality or propriety or correctness`
  line `of any dispute made in any application under sub-section (1) or of any direction or order or decision of`
  line `the Authority referred to in the appeal preferred under sub-section (2), on its own motion or otherwise,`
  line `call for the records relevant to disposing of such application or appeal and make such orders as it thinks`
  line fit.]
obj_root_law_sections_14_b:
  sectionId (16716)
  sectionNo 14B
  orderNo 16
  title `Composition of Appellate Tribunal.`
  content obj_root_law_sections_14_b_content
  footnotes `1 Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16716&sectionno=14B&orderno=16&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_b_content:
  string
  line `^1[14B. Composition of Appellate Tribunal.-- (1) The Appellate Tribunal shall consist of a`
  line `Chairperson and not more than two Members to be appointed, by notification, by the Central`
  line Government.
  line
  line `(2) The selection of Chairperson and Members of the Appellate Tribunal shall be made by the Central`
  line `Government in consultation with the Chief Justice of India.`
  line
  line `(3) Subject to the provisions of this Act,--`
  line
  line `(a) the jurisdiction of the Appellate Tribunal may be exercised by the Benches thereof;`
  line
  line `(b) a Bench may be constituted by the Chairperson of the Appellate Tribunal with one or two`
  line `Members of such Tribunal as the Chairperson may deem fit;`
  line
  line `(c) the Benches of the Appellate Tribunal shall ordinarily sit at New Delhi and at such other`
  line `places as the Central Government may, in consultation with the Chairperson of the Appellate`
  line `Tribunal, notify;`
  line
  line `(d) the Central Government shall notify the areas in relation to which each Bench of the Appellate`
  line `Tribunal may exercise its jurisdiction.`
  line
  line `(4) Notwithstanding anything contained in sub-section (2), the Chairperson of the Appellate Tribunal`
  line `may transfer a Member of such Tribunal from one Bench to another Bench.`
  line
  line `(5) If at any stage of the hearing of any case or matter it appears to the Chairperson or a Member of`
  line `the Appellate Tribunal that the case or matter is of such a nature that it ought to be heard by a Bench`
  line `consisting of two Members, the case or matter may be transferred by the Chairperson to such Bench as`
  line `the Chairperson may deem fit.]`
obj_root_law_sections_14_c:
  sectionId (16717)
  sectionNo 14C
  orderNo 17
  title `Qualifications for appointment of Chairperson and Members.`
  content obj_root_law_sections_14_c_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16717&sectionno=14C&orderno=17&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_c_content:
  string
  line `^1[14C. Qualifications for appointment of Chairperson and Members.-- A person shall not be`
  line `qualified for appointment as the Chairperson or a Member of the Appellate Tribunal unless he--`
  line
  line `(a) in the case of Chairperson, is, or has been, a Judge of the Supreme Court or the Chief Justice`
  line `of a High Court;`
  line
  line `(b) in the case of a Member, has held the post of Secretary to the Government of India or any`
  line `equivalent post in the Central Government or the State Government for a period of not less than two`
  line `years or a person who is well versed in the field of technology, telecommunication, industry,`
  line `commerce or administration.]`
obj_root_law_sections_14_d:
  sectionId (16718)
  sectionNo 14D
  orderNo 18
  title `Term of office.`
  content obj_root_law_sections_14_d_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16718&sectionno=14D&orderno=18&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_d_content:
  string
  line `^1[14D. Term of office.-- The Chairperson and every other Member of the Appellate Tribunal shall hold`
  line `office as such for a term not exceeding three years from the date on which he enters upon his office:`
  line
  line `Provided that no Chairperson or other Member shall hold office as such after he has attained,--`
  line
  line `(a) in the case of Chairperson, the age of seventy years;`
  line
  line `(b) in the case of any other Member, the age of sixty-five years.]`
obj_root_law_sections_14_e:
  sectionId (16719)
  sectionNo 14E
  orderNo 19
  title `Terms and conditions of service.`
  content obj_root_law_sections_14_e_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16719&sectionno=14E&orderno=19&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_e_content:
  string
  line `^1[14E. Terms and conditions of service.-- The salary and allowances payable to and the other terms`
  line `and conditions of service of the Chairperson and other Members of the Appellate Tribunal shall be such`
  line `as may be prescribed:`
  line
  line `Provided that neither the salary and allowances nor the other terms and conditions of service of the`
  line `Chairperson or a Member of the Appellate Tribunal shall be varied to his disadvantage after appointment.]`
obj_root_law_sections_14_f:
  sectionId (16720)
  sectionNo 14F
  orderNo 20
  title Vacancies.
  content obj_root_law_sections_14_f_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16720&sectionno=14F&orderno=20&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_f_content:
  string
  line `^1[14F. Vacancies.-- If, for reason other than temporary absence, any vacancy occurs in the office of the`
  line `Chairperson or a Member of the Appellate Tribunal, the Central Government shall appoint another person`
  line `in accordance with the provisions of this Act to fill the vacancy and the proceedings may be continued`
  line `before the Appellate Tribunal from the stage at which the vacancy is filled.]`
obj_root_law_sections_14_g:
  sectionId (16721)
  sectionNo 14G
  orderNo 21
  title `Removal and resignation.`
  content obj_root_law_sections_14_g_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16721&sectionno=14G&orderno=21&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_g_content:
  string
  line `^1[14G. Removal and resignation.--(1) The Central Government may remove from office, the`
  line `Chairperson or any Member of the Appellate Tribunal, who--`
  line
  line `(a) has been adjudged an insolvent; or`
  line
  line `(b) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as the Chairperson or a Member; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions as`
  line `the Chairperson or a Member; or`
  line
  line `(e) has so abused his position as to render his continuance in office prejudicial to the public`
  line interest.
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Chairperson or a Member of the`
  line `Appellate Tribunal shall not be removed from his office on the ground specified in clause (d) or clause (e)`
  line `of that sub-section unless the Supreme Court on a reference being made to it in this behalf by the Central`
  line `Government, has, on an enquiry, held by it in accordance with such procedure as it may specify in this`
  line `behalf, reported that the Chairperson or a Member ought on such ground or grounds to be removed.`
  line
  line `(3) The Central Government may suspend from office, the Chairperson or a Member of the Appellate`
  line `Tribunal in respect of whom a reference has been made to the Supreme Court under sub-section (2), until`
  line `the Central Government has passed an order on receipt of the report of the Supreme Court on such`
  line reference.]
obj_root_law_sections_14_ga:
  sectionId (49801)
  sectionNo 14GA.
  orderNo 22
  title `Qualifications, terms and conditions of service of Chairperson and Member.`
  content obj_root_law_sections_14_ga_content
  footnotes obj_root_law_sections_14_ga_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=49801&sectionno=14GA.&orderno=22&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_ga_content:
  string
  line `^1[14GA. Qualifications, terms and conditions of service of Chairperson and Member.`
  line `Notwithstanding anything contained in this Act, the qualifications, appointment, term of office, salaries`
  line `and allowances, resignation, removal and the other terms and conditions of service of the Chairperson and`
  line `other Members of the Appellate Tribunal appointed after the commencement of ^2[the Tribunals Reforms`
  line `Act, 2021, shall be governed by the provisions of Chapter II of the said Act]:`
  line
  line `Provided that the Chairperson and Member appointed before the commencement of Part XIV of`
  line `Chapter VI of the Finance Act, 2017, shall continue to be governed by the provisions of this Act and the`
  line `rules made there under as if the provisions of section 184 of the Finance Act, 2017 had not come into`
  line force.]
obj_root_law_sections_14_ga_footnotes:
  string
  line `1. Ins. by Act 7 of 2017, s. 168 (w.e.f. 26-5-2017).`
  line
  line `2. Subs. by Act 33 of 2021, s. 20, for “Part XIV of Chapter VI of the Finance Act, 2017, shall be governed by the provisions of section 184 of that Act” (w.e.f. 4-4-2021).`
obj_root_law_sections_14_h:
  sectionId (16722)
  sectionNo 14H
  orderNo 23
  title `Staff of Appellate Tribunal.`
  content obj_root_law_sections_14_h_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16722&sectionno=14H&orderno=23&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_h_content:
  string
  line `(1) The Central Government shall provide the Appellate`
  line `Tribunal with such officers and employees as it may deem fit.`
  line
  line `(2) The officers and employees of the Appellate Tribunal shall discharge their functions under the`
  line `general superintendence of its Chairperson.`
  line
  line `(3) The salaries and allowances and other conditions of service of the officers and employees of the`
  line `Appellate Tribunal shall be such as may be prescribed.`
obj_root_law_sections_14_i:
  sectionId (16754)
  sectionNo 14-I
  orderNo 24
  title `Distribution of business amongst Benches.`
  content obj_root_law_sections_14_i_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16754&sectionno=14-I&orderno=24&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_i_content:
  string
  line `^1[14-I. Distribution of business amongst Benches.--Where Benches are constituted, the Chairperson`
  line `of the Appellate Tribunal may, from time to time, by notification, make provisions as to the distribution`
  line `of the business of the Appellate Tribunal amongst the Benches and also provide for the matters which`
  line `may be dealt with by each Bench.]`
obj_root_law_sections_14_j:
  sectionId (16755)
  sectionNo 14J
  orderNo 25
  title `Power of Chairperson to transfer cases.`
  content obj_root_law_sections_14_j_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16755&sectionno=14J&orderno=25&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_j_content:
  string
  line `^1[14J. Power of Chairperson to transfer cases.-- On the application of any of the parties and after`
  line `notice to the parties, and after hearing such of them as he may desire to be heard, or on his own motion`
  line `without such notice, the Chairperson of the Appellate Tribunal may transfer any case pending before one`
  line `Bench, for disposal, to any other Bench.]`
obj_root_law_sections_14_k:
  sectionId (16756)
  sectionNo 14K
  orderNo 26
  title `Decision to be by majority`
  content obj_root_law_sections_14_k_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16756&sectionno=14K&orderno=26&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_k_content:
  string
  line `^1[14K. Decision to be by majority.-- If the Members of a Bench consisting of two Members differ in`
  line `opinion on any point, they shall state the point or points on which they differ, and make a reference to the`
  line `Chairperson of the Appellate Tribunal who shall hear the point or points himself and such point or points`
  line `shall be decided according to the opinion of the majority who have heard the case, including those who`
  line `first heard it.]`
obj_root_law_sections_14_l:
  sectionId (16757)
  sectionNo 14L
  orderNo 27
  title `Members, etc., to be public servants.`
  content obj_root_law_sections_14_l_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16757&sectionno=14L&orderno=27&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_l_content:
  string
  line `^1[14L. Members, etc., to be public servants--The Chairperson, Members and other officers and`
  line `employees of the Appellate Tribunal shall be deemed to be public servants within the meaning of`
  line `section 21 of the Indian Penal Code (45 of 1860).]`
obj_root_law_sections_14_m:
  sectionId (16758)
  sectionNo 14M
  orderNo 28
  title `Transfer of pending cases`
  content obj_root_law_sections_14_m_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16758&sectionno=14M&orderno=28&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_m_content:
  string
  line `^1[14M. Transfer of pending cases.-- All applications, pending for adjudication of disputes before the`
  line `Authority immediately before the date of establishment of the Appellate Tribunal under this Act, shall`
  line `stand transferred on that date to such Tribunal:`
  line
  line `Provided that all disputes being adjudicated under the provisions of Chapter IV as it stood`
  line `immediately before the commencement of the Telecom Regulatory Authority of India (Amendment)`
  line `Act, 2000 (2 of 2000), shall continue to be adjudicated by the Authority in accordance with the provisions`
  line `contained in that Chapter, till the establishment of the Appellate Tribunal under this Act:`
  line
  line `Provided further that all cases referred to in the first proviso shall be transferred by the Authority to`
  line `the Appellate Tribunal immediately on its establishment under section 14.]`
obj_root_law_sections_14_n:
  sectionId (16759)
  sectionNo 14N
  orderNo 29
  title `Transfer of appeals.`
  content obj_root_law_sections_14_n_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16759&sectionno=14N&orderno=29&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_14_n_content:
  string
  line `^1[14N. Transfer of appeals.-- (1) All appeals pending before the High Court immediately before the`
  line `commencement of the Telecom Regulatory Authority of India (Amendment) Act, 2000 (2 of 2000), shall`
  line `stand transferred to the Appellate Tribunal on its establishment under section 14.`
  line
  line `(2) Where any appeal stands transferred from the High Court to the Appellate Tribunal under`
  line `sub-section (1),--`
  line
  line `(a) the High Court shall, as soon as may be after such transfer, forward the records of such appeal`
  line `to the Appellate Tribunal; and`
  line
  line `(b) the Appellate Tribunal may, on receipt of such records, proceed to deal with such appeal, so`
  line `far as may be from the stage which was reached before such transfer or from any earlier stage or`
  line `de novo as the Appellate Tribunal may deem fit.]`
obj_root_law_sections_15:
  sectionId (16760)
  sectionNo (15)
  orderNo 30
  title `Civil court not to have jurisdiction`
  content obj_root_law_sections_15_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16760&sectionno=15&orderno=30&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_15_content:
  string
  line `^1[15. Civil court not to have jurisdiction.-- No civil court shall have jurisdiction to entertain any suit`
  line `or proceeding in respect of any matter which the Appellate Tribunal is empowered by or under this Act to`
  line `determine and no injunction shall be granted by any court or other authority in respect of any action taken`
  line `or to be taken in pursuance of any power conferred by or under this Act.]`
obj_root_law_sections_16:
  sectionId (16761)
  sectionNo (16)
  orderNo 31
  title `Procedure and powers of Appellate Tribunal`
  content obj_root_law_sections_16_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16761&sectionno=16&orderno=31&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_16_content:
  string
  line `^1[16. Procedure and powers of Appellate Tribunal.-- (1) The Appellate Tribunal shall not be bound`
  line `by the procedure laid down by the Code of Civil Procedure, 1908 (5 of 1908), but shall be guided by the`
  line `principles of natural justice and, subject to the other provisions of this Act, the Appellate Tribunal shall`
  line `have powers to regulate its own procedure.`
  line
  line `(2) The Appellate Tribunal shall have, for the purposes of discharging its functions under this Act, the`
  line `same powers as are vested in a civil court under the Code of Civil Procedure, 1908 (5 of 1908), while`
  line `trying a suit, in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) receiving evidence on affidavits;`
  line
  line `(d) subject to the provisions of sections 123 and 124 of the Indian Evidence Act, 1872 (1 of`
  line `1872), requisitioning any public record or document or a copy of such record or document, from any`
  line office;
  line
  line `(e) issuing commissions for the examination of witnesses or documents;`
  line
  line `(f) reviewing its decisions;`
  line
  line `(g) dismissing an application for default or deciding it, ex parte;`
  line
  line `(h) setting aside any order of dismissal of any application for default or any order passed by it,`
  line `ex parte; and`
  line
  line `(i) any other matter which may be prescribed.`
  line
  line `(3) Every proceeding before the Appellate Tribunal shall be deemed to be a judicial proceeding`
  line `within the meaning of sections 193 and 228, and for the purposes of section 196, of the Indian Penal Code`
  line `(45 of 1860) and the Appellate Tribunal shall be deemed to be a civil court for the purposes of section 195`
  line `and Chapter XXVI of the Code of Criminal Procedure, 1973 (2 of 1974).]`
obj_root_law_sections_17:
  sectionId (16762)
  sectionNo (17)
  orderNo 32
  title `Right to legal representation.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16762&sectionno=17&orderno=32&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_17_content:
  string
  line `^1[17. Right to legal representation.-- The applicant or appellant may either appear in person or`
  line `authorise one or more chartered accountants or company secretaries or cost accountants or legal`
  line `practitioners or any of its officers to present his or its case before the Appellate Tribunal.`
  line
  line `Explanation.-- for the purposes of this section,--`
  line
  line `(a) "chartered accountant" means a chartered accountant as defined in clause (b) of`
  line `sub-section (1) of section 2 of the Chartered Accountants Act, 1949 (38 of 1949) and who has`
  line `obtained a certificate of practice under sub-section (1) of section 6 of that Act;`
  line
  line `(b) "company secretary" means a company secretary as defined in clause (c) of sub-section (1) of`
  line `section 2 of the Company Secretaries Act, 1980 (56 of 1980) and who has obtained a certificate of`
  line `practice under sub-section (1) of section 6 of that Act;`
  line
  line `(c) "cost accountant" means a cost accountant as defined in clause (b) of sub-section (1) of`
  line `section 2 of the Cost and Works Accountants Act, 1959 (23 of 1959) and who has obtained a`
  line `certificate of practice under sub-section (1) of section 6 of that Act;]`
  line
  line `(d) "legal practitioner" means an advocate, vakil or an attorney of any High Court, and includes a`
  line `pleader in practice.]`
obj_root_law_sections_18:
  sectionId (16763)
  sectionNo (18)
  orderNo 33
  title `Appeal to Supreme Court.`
  content obj_root_law_sections_18_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16763&sectionno=18&orderno=33&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_18_content:
  string
  line `^1[18. Appeal to Supreme Court.-- (1) Notwithstanding anything contained in the Code of Civil`
  line `Procedure, 1908 (5 of 1908), or in any other law, an appeal shall lie against any order, not being an`
  line `interlocutory order, of the Appellate Tribunal to the Supreme Court on one or more of the grounds`
  line `specified in section 100 of that Code.`
  line
  line `(2) No appeal shall lie against any decision or order made by the Appellate Tribunal with the consent`
  line `of the parties.`
  line
  line `(3) Every appeal under this section shall be preferred within a period of ninety days from the date of`
  line `the decision or order appealed against:`
  line
  line `Provided that the Supreme Court may entertain the appeal after the expiry of the said period of ninety`
  line `days, if it is satisfied that the appellant was prevented by sufficient cause from preferring the appeal in`
  line time.]
obj_root_law_sections_19:
  sectionId (16764)
  sectionNo (19)
  orderNo 34
  title `Orders passed by Appellate Tribunal to be executable as a decree`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16764&sectionno=19&orderno=34&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_19_content:
  string
  line `^1[19. Orders passed by Appellate Tribunal to be executable as a decree.-- (1) An order passed by`
  line `the Appellate Tribunal under this Act shall be executable by the Appellate Tribunal as a decree of civil`
  line `court, and for this purpose, the Appellate Tribunal shall have all the powers of a civil court.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Appellate Tribunal may transmit any`
  line `order made by it to a civil court having local jurisdiction and such civil court shall execute the order as if`
  line `it were a decree made by that court.]`
obj_root_law_sections_20:
  sectionId (16765)
  sectionNo (20)
  orderNo 35
  title `Penalty for wilful failure to comply with orders of Appellate Tribunal.`
  content obj_root_law_sections_20_content
  footnotes `1. Subs. by s. 11, ibid., for Chapter IV (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16765&sectionno=20&orderno=35&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_20_content:
  string
  line `^1[20. Penalty for wilful failure to comply with orders of Appellate Tribunal.-- If any person`
  line `wilfully fails to comply with the order of the Appellate Tribunal, he shall be punishable with fine which`
  line `may extend to one lakh rupees and in case of a second or subsequent offence with fine which may extend`
  line `to two lakh rupees and in the case of continuing contravention with additional fine which may extend to`
  line `two lakh rupees for every day during which such default continues.]`
obj_root_law_sections_21:
  sectionId (16766)
  sectionNo (21)
  orderNo 36
  title `Grants by Central Government.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16766&sectionno=21&orderno=36&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_21_content:
  string
  line `The Central Government may, after due appropriation made`
  line `by Parliament by law in this behalf, make to the Authority grants of such sums of money as are required`
  line `to pay salaries and allowances payable to the Chairperson and the members and the administrative`
  line `expenses including the salaries, allowances and pension payable to or in respect of officers and other`
  line `employees of the Authority.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (16767)
  sectionNo (22)
  orderNo 37
  title Fund.
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16767&sectionno=22&orderno=37&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_22_content:
  string
  line `(1) There shall be constituted a Fund to be called the Telecom Regulatory Authority of`
  line `India General Fund and there shall be credited thereto--`
  line
  line `(a) all grants, fees and charges received by the Authority under this Act; and`
  line
  line `(b) all sums received by the Authority from such other sources as may be decided upon by the`
  line `Central Government.`
  line
  line `(2) The Fund shall be applied for meeting--`
  line
  line `(a) the salaries and allowances payable to the Chairperson and members and the administrative`
  line `expenses including the salaries, allowances and pension payable to or in respect of officers and other`
  line `employees of the Authority; and`
  line
  line `(b) the expenses on objects and for purposes authorised by this Act.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (16768)
  sectionNo (23)
  orderNo 38
  title `Accounts and audit.`
  content obj_root_law_sections_23_content
  footnotes `1 Ins. by Act 2 of 2000, s. 12 (w.e.f. 24-1-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16768&sectionno=23&orderno=38&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_23_content:
  string
  line `(1) The Authority shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts in such form as may be prescribed by the Central`
  line `Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Authority shall be audited by the Comptroller and Auditor-General of India at`
  line `such intervals as may be specified by him and any expenditure incurred in connection with such auditor`
  line `shall be payable by the Authority to the Comptroller and Auditor-General of India.`
  line
  line `^1[Explanation.-- For the removal of doubts, it is hereby declared that the decisions of the Authority`
  line `taken in the discharge of its functions under clause (b) of sub-section (1) and sub-section (2) of section 11`
  line `and section 13, being matters appealable to the Appellate Tribunal, shall not be subject to audit under this`
  line section.]
  line
  line `(3) The Comptroller and Auditor-General of India and any other person appointed by him in`
  line `connection with the audit of the accounts of the Authority shall have the same rights and privileges and`
  line `authority in connection with such audit as the Comptroller and Auditor-General generally has, in`
  line `connection with the audit of the Government accounts and, in particular, shall have the right to demand`
  line `the production of books, accounts, connected vouchers and other documents and papers and to inspect`
  line `any of the offices of the Authority.`
  line
  line `(4) The accounts of the Authority as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_24:
  sectionId (16769)
  sectionNo (24)
  orderNo 39
  title `Furnishing of returns, etc., to Central Government.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16769&sectionno=24&orderno=39&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_24_content:
  string
  line `(1) The Authority shall furnish to the`
  line `Central Government at such time and in such form and manner as may be prescribed or as the Central`
  line `Government may direct, such returns and statements and such particulars in regard to any proposed or`
  line `existing programme for the promotion and development of the telecommunication services, as the Central`
  line `Government may from time to time, require.`
  line
  line `(2) The Authority shall prepare once every year in such form and at such time as may be prescribed,`
  line `an annual report giving a summary of its activities during the previous year and copies of the report shall`
  line `be forwarded to the Central Government.`
  line
  line `(3) A copy of the report received under sub-section (2) shall be laid, as soon as may be after it is`
  line `received, before each House of Parliament.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (16770)
  sectionNo (25)
  orderNo 40
  title `Power of Central Government to issue directions.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16770&sectionno=25&orderno=40&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_25_content:
  string
  line `(1) The Central Government may, from to`
  line `time to time, issue to the Authority such directions as it may think necessary in the interest of the`
  line `sovereignty and integrity of India, the security of the State, friendly relations with foreign States, public`
  line `order, decency or morality.`
  line
  line `(2) Without prejudice to the foregoing provisions, the Authority shall, in exercise of its powers or the`
  line `performance of its functions, be bound by such directions on questions of policy as the Central`
  line `Government may give in writing to it from time to time:`
  line
  line `Provided that the Authority shall, as far as practicable, be given an opportunity to express its views`
  line `before any direction is given under this sub-section.`
  line
  line `(3) The decision of the Central Government whether a question is one of policy or not shall be final.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (16771)
  sectionNo (26)
  orderNo 41
  title `Members, officers and employees of Authority to be public servants.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16771&sectionno=26&orderno=41&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_26_content:
  string
  line `All members, officers`
  line `and other employees of the Authority shall be deemed, when acting or purporting to act in pursuance of`
  line `any of the provisions of this Act to be public servants within the meaning of section 21 of the Indian`
  line `Penal Code (45 of 1860).`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (16772)
  sectionNo (27)
  orderNo 42
  title `Bar of jurisdiction.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16772&sectionno=27&orderno=42&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_27_content:
  string
  line `No civil court shall have jurisdiction in respect of any matter which the`
  line `Authority is empowered by or under this Act to determine.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (16773)
  sectionNo (28)
  orderNo 43
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16773&sectionno=28&orderno=43&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_28_content:
  string
  line `No suit, prosecution or other legal proceedings shall`
  line `lie against the Central Government or the Authority or any officer of Central Government or any member,`
  line `officer or other employees of the Authority for anything which is in good faith done or intended to be`
  line `done under this Act or the rules or regulations made thereunder.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (16774)
  sectionNo (29)
  orderNo 44
  title `Penalty for contravention of directions of Authority`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16774&sectionno=29&orderno=44&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_29_content:
  string
  line `If a person violates directions of the`
  line `Authority, such person shall be punishable with fine which may extend to one lakh rupees and in case of`
  line `second or subsequent offence with fine which may extend to two lakh rupees and in the case of`
  line `continuing contravention with additional fine which may extend to two lakh rupees for every day during`
  line `which the default continues.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (16775)
  sectionNo (30)
  orderNo 45
  title `Offences by companies.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16775&sectionno=30&orderno=45&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_30_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed was in charge of, and was responsible to, the company for the conduct of the business of the company, as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act if he proves that the offence was committed without his knowledge or`
  line `that he has exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to, any neglect on the part of any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of the offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.-- For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (16776)
  sectionNo (31)
  orderNo 46
  title `Offences by Government Departments`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16776&sectionno=31&orderno=46&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_31_content:
  string
  line `(1) Where an offence under this Act has been`
  line `committed by any Department of Government, the Head of the Department shall be deemed to be guilty`
  line `of the offence and shall be liable to be proceeded against and punished accordingly unless he proves that`
  line `the offence was committed without his knowledge or that he exercised all due diligence to prevent the`
  line `commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a Department of Government and it is proved that the offence has been committed with the`
  line `consent or connivance of, or is attributable to any neglect on the part of, any officer, other than the Head`
  line `of the Department, such officer shall also be deemed to be guilty of that offence and shall be liable to be`
  line `proceeded against and punished accordingly.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (16777)
  sectionNo (32)
  orderNo 47
  title `Exemption from tax on wealth and income.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16777&sectionno=32&orderno=47&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_32_content:
  string
  line `Notwithstanding anything contained in the`
  line `Wealth-tax Act, 1957 (27 of 1957), the Income-tax Act, 1961 (43 of 1961), or any other enactment for the`
  line `time being in force relating to tax on wealth, income, profits or gains, the Authority shall not be liable to`
  line `pay wealth-tax, income-tax or any other tax in respect of their wealth, income, profits or gains derived.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (16778)
  sectionNo (33)
  orderNo 48
  title Delegation
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16778&sectionno=33&orderno=48&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_33_content:
  string
  line `Notwithstanding anything contained in the`
  line `Wealth-tax Act, 1957 (27 of 1957), the Income-tax Act, 1961 (43 of 1961), or any other enactment for the`
  line `time being in force relating to tax on wealth, income, profits or gains, the Authority shall not be liable to`
  line `pay wealth-tax, income-tax or any other tax in respect of their wealth, income, profits or gains derived.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (16779)
  sectionNo (34)
  orderNo 49
  title `Cognizance of offences`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16779&sectionno=34&orderno=49&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_34_content:
  string
  line `(1) No court shall take cognizance of any offence punishable under`
  line `this Act or the rules or regulations made thereunder, save on a complaint made by the Authority.`
  line
  line `(2) No court inferior to that of a Chief Metropolitan Magistrate or a Chief Judicial Magistrate of first`
  line `class shall try any offence punishable under this Act.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (16780)
  sectionNo (35)
  orderNo 50
  title `Power to make rules.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16780&sectionno=35&orderno=50&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_35_content:
  string
  line `(1) The Central Government may, by notification, make rules for`
  line `carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:`
  line
  line `(a) the salary and allowances payable to and the other conditions of service of the Chairperson`
  line `and members under sub-section (5) of section 5;`
  line
  line `^1[(aa) the allowances payable to the part-time members under sub-section (6A) of section 5;]`
  line
  line `(b) the powers and functions of the Chairperson under sub-section (1) of section 6;`
  line
  line `(c) the procedure for conducting an inquiry made under sub-section (2) of section 7;`
  line
  line `^2[(ca) the salary and allowances and other conditions of service of officers and other employees`
  line `of the Authority under sub-section (2) of section 10;]`
  line
  line `(d) the category of books of account or other documents which are required to be maintained`
  line `under sub-section (3) of section 12;`
  line
  line `^2[(da) the form, the manner of its verification and the fee under sub-section (3) of section 14A;`
  line
  line `(db) the salary and allowances payable to and other terms and conditions of service of the`
  line `Chairperson and other Members of the Appellate Tribunal under section 14E;`
  line
  line `(dc) the salary and allowances and other conditions of service of the officers and employees of`
  line `the Appellate Tribunal under sub-section (3) of section 14H;`
  line
  line `(dd) any other power of a civil court required to be prescribed under clause (i) of sub-section (2)`
  line `of section 16;]`
  line
  line `(e) the period within which an application is to be made under sub-section (1) of section 15;`
  line
  line `(f) the manner in which the accounts of the Authority shall be maintained under sub-section (1) of`
  line `section 23;`
  line
  line `(g) the time within which and the form and manner in which returns and report are to be made to`
  line `the Central Government under sub-sections (1) and (2) of section 24;`
  line
  line `(h) any other matter which is to be, or may be, prescribed, or in respect of which provision is to`
  line `be made, by rules.`
obj_root_law_sections_35_footnotes:
  string
  line `1. Ins. by Act 2 of 2000, s. 13 (w.e.f. 24-1-2000).`
  line
  line `2. Ins. by Act 2 of 2000, s. 13 (w.e.f. 24-1-2000).`
obj_root_law_sections_36:
  sectionId (16781)
  sectionNo (36)
  orderNo 51
  title `Power to make regulations`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16781&sectionno=36&orderno=51&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_36_content:
  string
  line `(1) The Authority may, by notification, make regulations`
  line `consistent with this Act and the rules made thereunder to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the times and places of meetings of the Authority and the procedure to be followed at such`
  line `meetings under sub-section (1) of section 8, including quorum necessary for the transaction of`
  line business;
  line
  line `(b) the transaction of business at the meetings of the Authority under sub-section (4) of section 8;`
  line
  line `^1* * * * *`
  line
  line `(d) matters in respect of which register is to be maintained by the Authority ^2[under`
  line `sub-clause (vii) of clause (b)] of sub-section (1) of section 11;`
  line
  line `(e) levy of fee and lay down such other requirements on fulfilment of which a copy of register`
  line `may be obtained ^3[under sub-clause (viii) of clause (b)] of sub-section (1) of section 11;`
  line
  line `(f) levy of fees and other charges ^4[under clause (c)] of sub-section (1) of section 11;`
obj_root_law_sections_36_footnotes:
  string
  line `1.. Cl. (c) omitted by s. 14, ibid. (w.e.f. 24-1-2000).`
  line
  line `2. Subs. by s. 14, ibid., for under clause (l) (w.e.f. 24-1-2000).`
  line
  line `3. Subs. by s. 14, ibid., for under clause (m) (w.e.f. 24-1-2000).`
  line
  line `4. Subs. by s. 14, ibid., for under clause (p) (w.e.f. 24-1-2000).`
obj_root_law_sections_37:
  sectionId (16782)
  sectionNo (37)
  orderNo 52
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16782&sectionno=37&orderno=52&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_37_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (16783)
  sectionNo (38)
  orderNo 53
  title `Application of certain laws.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16783&sectionno=38&orderno=53&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_38_content:
  string
  line `The provisions of this Act shall be in addition to the provisions of`
  line `the Indian Telegraph Act, 1885 (13 of 1885) and the Indian Wireless Telegraphy Act, 1933 (17 of 1933)`
  line `and, in particular, nothing in this Act shall affect any jurisdiction, powers and functions required to be`
  line `exercised or performed by the Telegraph Authority in relation to any area falling within the jurisdiction of`
  line `such Authority.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (16784)
  sectionNo (39)
  orderNo 54
  title `Power to remove difficulties`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16784&sectionno=39&orderno=54&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_39_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (16785)
  sectionNo (40)
  orderNo 55
  title `Repeal and saving.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_58_00002_199724_1517807323214&sectionId=16785&sectionno=40&orderno=55&orgactid=AC_CEN_37_58_00002_199724_1517807323214
obj_root_law_sections_40_content:
  string
  line `(1) The Telecom Regulatory Authority of India Ordinance 1997`
  line `(Ord. 11 of 1997) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_40_footnotes:
  string
  line
