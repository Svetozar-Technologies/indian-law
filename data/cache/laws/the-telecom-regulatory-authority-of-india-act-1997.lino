obj_root_law:
  slug the-telecom-regulatory-authority-of-india-act-1997
  handle (1929)
  collectionHandle 123456789/1362
  title `The Telecom Regulatory Authority of India Act, 1997`
  actNumber (24)
  enactmentDate 1997-03-28
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1929`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भारतीय दूर-संचार विनियामकप्राधिकरणअधिनियम, 1997`
  actYear (1997)
  ministry `Ministry of Communications`
  department `Department of Telecommunications`
  longTitle `An Act to provide for the establishment of the Telecom Regulatory Authority of India and the Telecom Disputes Settlement and Appellate Tribunal to regulate the telecommunication services, adjudicate disputes, dispose of appeals and to protect the interests of service providers and consumers of the telecom sector, to promote and ensure orderly growth of the telecom sector and for matters connected therewith or incidental thereto.`
  enforcementDate 25-01-1997
  notification undefined
  fetchedAt `2026-05-09T18:30:48.066Z`
  translations obj_root_law_translations
