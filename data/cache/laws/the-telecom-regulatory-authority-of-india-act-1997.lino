  (str handle) (str 1929)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Telecom Regulatory Authority of India Act, 1997`)
  (str actNumber) (str 24)
  (str enactmentDate) (str 1997-03-28)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1929`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भारतीय दूर-संचार विनियामकप्राधिकरणअधिनियम, 1997`)
  (str actYear) (str 1997)
  (str ministry) (str `Ministry of Communications`)
  (str department) (str `Department of Telecommunications`)
  (str longTitle) (str `An Act to provide for the establishment of the Telecom Regulatory Authority of India and the Telecom Disputes Settlement and Appellate Tribunal to regulate the telecommunication services, adjudicate disputes, dispose of appeals and to protect the interests of service providers and consumers of the telecom sector, to promote and ensure orderly growth of the telecom sector and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 25-01-1997)
  (str notification) (undefined)
