  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_A1944-01_1671705649438&sectionId=72007&sectionno=23I&orderno=65&orgactid=AC_CEN_2_2_00036_A1944-01_1671705649438
obj_root_law_sections_23_i_content:
  string
  line `^1[^2[23I. Transitional provision.--On and from the date on which the Finance Bill, 2017 receives the`
  line `assent of the President, every application and proceeding pending before the erstwhile Authority for`
  line `Advance Rulings (Central Excise, Customs and Service Tax) shall stand transferred to the Authority from`
  line `the stage at which such application or proceeding stood as on the date of such assent.]]`
