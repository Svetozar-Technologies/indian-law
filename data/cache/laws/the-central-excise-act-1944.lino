obj_root_law_sections_40:
  sectionId (72074)
  sectionNo (40)
  orderNo 130
  title `Protection of action taken under the Act.`
  content obj_root_law_sections_40_content
  footnotes `1. Subs. by Act 22 of 1973, s. 5, for section 40 (w.e.f. 1-9-1973).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_A1944-01_1671705649438&sectionId=72074&sectionno=40&orderno=130&orgactid=AC_CEN_2_2_00036_A1944-01_1671705649438
obj_root_law_sections_40_content:
  string
  line `^1[40. Protection of action taken under the Act.--(1) No suit, prosecution or other legal proceeding`
  line `shall lie against the Central Government or any officer of the Central Government or a State Government`
  line `for anything which is done, or intended to be done, in good faith, in pursuance of this Act or any rule made`
  line thereunder.
  line
  line `(2) No proceeding, other than a suit, shall be commenced against the Central Government or any officer`
  line `of the Central Government or a State Government for anything done or purported to have been done in`
  line `pursuance of this Act or any rule made thereunder, without giving the Central Government or such officer`
  line `a month’s previous notice in writing of the intended proceeding and of the cause thereof or after the`
  line `expiration of three months from the accrual of such cause.]`
