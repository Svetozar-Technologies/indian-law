  object
  (str sectionId) (str 72008)
  (str sectionNo) (str 24)
  (str orderNo) (int 66)
  (str title) (str [Omitted.].)
  (str content) (str `[24. [Penalties for carrying excisable goods in certain vessels].--Omitted by Finance Act 2002 (20 of
2002), s. 139 (w.e.f. 11-5-2002).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_A1944-01_1671705649438&sectionId=72008&sectionno=24&orderno=66&orgactid=AC_CEN_2_2_00036_A1944-01_1671705649438)
