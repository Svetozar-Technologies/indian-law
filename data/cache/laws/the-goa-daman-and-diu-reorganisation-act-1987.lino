obj_root_law_sections_1:
  sectionId (39309)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Goa, Daman and Diu Reorganisation Act, 1987.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39309&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39310)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39310&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Administrator" means the administrator appointed by the President under article 239;`
  line
  line `(b) "appointed day"`
  line `^1 means the day which the Central Government may, by notification, appoint;`
  line
  line `(c) "article" means an article of the Constitution;`
  line
  line `(d) "assembly constituency" and "parliamentary constituency" have the same meanings as in the`
  line `Representation of the People Act, 1950 (43 of 1950);`
  line
  line `(e) "Election Commission" means the Election Commission appointed by the President under`
  line `article 324;`
  line
  line `(f) "existing Union territory" means the Union territory of Goa, Daman and Diu as existing`
  line `immediately before the appointed day;`
  line
  line `(g) "law" includes any enactment, ordinance, regulation, order, bye-law, rule, scheme,`
  line `notification or other instrument having immediately before the appointed day, the force of law in the`
  line `whole or any part of the existing Union territory;`
  line
  line `(h) "notification" means a notification published in the Official Gazette;`
  line
  line `(i) "population ratio", in relation to the State of Goa and the Union, means the ratio of 42: 3.25;`
  line
  line `(j) "sitting member", in relation to the House of the People or of the Legislative Assembly of the`
  line `existing Union territory means a person who, immediately before the appointed day, is a member of`
  line `that House or that Assembly;`
  line
  line `(k) "treasury" includes a sub-treasury.`
obj_root_law_sections_2_footnotes:
  string
  line `1 30th May, 1987, vide notification No. S.O. 518(E), dated 26th May, 1987, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_3:
  sectionId (39311)
  sectionNo (3)
  orderNo 3
  title `Formation of State of Goa.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39311&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_3_content:
  string
  line `On and from the appointed day, there shall be formed a new State to`
  line `be known as the State of Goa comprising the territories which immediately before that day were`
  line `comprised in the Goa district of the existing Union territory.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39312)
  sectionNo (4)
  orderNo 4
  title `Formation of Union territory of Daman and Diu.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39312&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_4_content:
  string
  line `On and from the appointed day, there shall`
  line `be formed a new Union territory to be known as the Union territory of Daman and Diu comprising the`
  line `territories which, immediately before that day, were comprised in the Daman and Diu districts of the`
  line `existing Union territory.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39313)
  sectionNo (5)
  orderNo 5
  title [Repealed].
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39313&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_5_content:
  string
  line `[Amendment of First Schedule to the Constitution].—Rep. by the Repealing and Amending Act,`
  line `2001 (30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39314)
  sectionNo (6)
  orderNo 6
  title [Repealed].
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39314&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_6_content:
  string
  line `[Amendment of the Fourth Schedule to the Constitution].—Rep. by s. 2 and the First Schedule,`
  line `ibid. (w.e.f. 3-9-2001).`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (39315)
  sectionNo (7)
  orderNo 7
  title `Election to fill the seat allotted to the State of Goa.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39315&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_7_content:
  string
  line `As soon as may be after the appointed day,`
  line `election shall be held to fill the seat allotted in the Council of States to the State of Goa.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (39316)
  sectionNo (8)
  orderNo 8
  title `Allocation of seats in the House of the People.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39316&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_8_content:
  string
  line `On and from the appointed day, there shall be`
  line `allotted two seats to the State of Goa, and one seat to the Union territory of Daman and Diu in the House`
  line `of the People and the First Schedule to the Representation of the People Act, 1950 (43 of 1950) shall be`
  line `deemed to be amended accordingly.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (39317)
  sectionNo (9)
  orderNo 9
  title `Parliamentary constituency of the Union territory of Daman and Diu.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39317&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_9_content:
  string
  line `The whole of the`
  line `Union territory of Daman and Diu shall form one parliamentary constituency to be called the Daman and`
  line `Diu parliamentary constituency and as soon as may be after the appointed day, election shall be held to`
  line `the House of the People to elect a representative from that constituency, as if the seat of the member`
  line `elected to the House of the People from that constituency has become vacant and the provisions of section`
  line `149 of the Representation of the People Act, 1951 (43 of 1951) shall, so far as may be, apply in relation to`
  line `such election.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (39318)
  sectionNo (10)
  orderNo 10
  title `Parliamentary constituencies.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39318&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_10_content:
  string
  line `On and from the appointed day,—`
  line
  line `(a) the Panaji parliamentary constituency, excluding the Daman and Diu assembly constituencies,`
  line `and the Mormugao parliamentary constituency in the existing Union territory shall be deemed to be`
  line `the parliamentary constituencies of the State of Goa and accordingly, in Part A of Schedule XXVI to`
  line `the Delimitation of Parliamentary and Assembly Constituencies Order, 1976, for the figures and`
  line `words "12-Cumbarjua, 13-Santo Andre, 29-Daman and 30-Diu", the figures and words "12-`
  line `Cumbarjua and 13-Santo Andre" shall be substituted;`
  line
  line `(b) the Daman and Diu assembly constituencies in the existing Union territory shall be deemed to`
  line `comprise the parliamentary constituency of the Union territory of Daman and Diu.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (39319)
  sectionNo (11)
  orderNo 11
  title `Provisions as to sitting members.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39319&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_11_content:
  string
  line `(1) The sitting member of the House of the People`
  line `representing the Panaji parliamentary constituency which, on the appointed day, by virtue of the`
  line `provisions of clause (a) of section 10 stands altered and becomes a parliamentary constituency of the`
  line `State of Goa shall, as from that day, be deemed to have been duly elected to that House by that`
  line `constituency as so altered.`
  line
  line `(2) The sitting member of the House of the People representing the Mormugao parliamentary`
  line `constituency which, on the appointed day, by virtue of the provisions of clause (a) of section 10 becomes`
  line `a parliamentary constituency of the State of Goa shall, as from that day, be deemed to have been duly`
  line `elected to that House by that constituency in that State.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (39320)
  sectionNo (12)
  orderNo 12
  title `Provisions as to Legislative Assembly.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39320&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_12_content:
  string
  line `On and from the appointed day, the total number of`
  line `seats in the Legislative Assembly of the State of Goa to be filled by persons, chosen by direct election`
  line `from assembly constituencies shall be forty and the Second Schedule to the Representation of the People`
  line `Act 1950 (43 of 1950), shall be deemed to be amended accordingly.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (39321)
  sectionNo (13)
  orderNo 13
  title `Provisional Legislative Assembly.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39321&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_13_content:
  string
  line `(1) Notwithstanding anything contained in this Act`
  line `(including provisions relating to the strength of the Legislative Assembly of the State of Goa), on and`
  line `from the appointed day and until the Legislative Assembly of that State has been duly constituted and`
  line `summoned to meet for the first session, there shall be a provisional Legislative Assembly which shall`
  line `consist of,—`
  line
  line `(a) members elected by the territorial constituencies of the Legislative Assembly of the existing`
  line `Union territory, other than those members elected by the territorial constituencies of Daman and Diu;`
  line and
  line
  line `(b) members nominated to that Assembly.`
  line
  line `(2) The period of five years referred to in clause (1) of Article 172 shall, in the case of provisional`
  line `Legislative Assembly referred to in sub-section (1), be deemed to have commenced on the date on which`
  line `the duration of the Legislative Assembly of the existing Union territory commenced under section 5 of the`
  line `Government of Union Territories Act, 1963 (20 of 1963).`
  line
  line `(3) For so long as the provisional Legislative Assembly constituted under this section is in`
  line existence,—
  line
  line `(a) it shall be deemed to be the Legislative Assembly of the State of Goa duly constituted under`
  line `the Constitution and shall be competent to discharge all the functions of a Legislative Assembly of a`
  line `State under the Constitution; and`
  line
  line `(b) the members thereof, referred to in clause (a) of sub-section (1), shall be deemed to be`
  line `the members of the Legislative Assembly of the State of Goa duly elected under the Constitution.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (39322)
  sectionNo (14)
  orderNo 14
  title [Repealed].
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39322&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_14_content:
  string
  line `[Amendment of Delimitation Orders].—Rep. by the Repealing and Amending Act, 2001`
  line `(30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (39323)
  sectionNo (15)
  orderNo 15
  title `Speaker of the provisional Legislative Assembly.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39323&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_15_content:
  string
  line `The person who immediately before the`
  line `appointed day is the Speaker of the Legislative Assembly of the existing Union territory shall, on and`
  line `from that day, be the Speaker of the provisional Legislative Assembly.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (39324)
  sectionNo (16)
  orderNo 16
  title `Rules of procedure.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39324&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_16_content:
  string
  line `The rules of procedure and conduct of business of the Legislative`
  line `Assembly of the existing Union territory, as in force immediately before the appointed day shall, until`
  line `rules are made under clause (1) of article 208, be the rules of procedure and conduct of business of the`
  line `provisional Legislative Assembly referred to in section 13; subject to such modifications and adaptations`
  line `as may be made therein by the Speaker thereof.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (39325)
  sectionNo (17)
  orderNo 17
  title `Delimitation of constituencies.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39325&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_17_content:
  string
  line `(1) The Election Commission shall, in the manner herein`
  line `provided, distribute, whether before or after the appointed day, the seats assigned to the Legislative`
  line `Assembly of the State of Goa under section 12 to single-member territorial constituencies and delimit`
  line `them having regard to the provisions of the Constitution and to the following provisions, namely:—`
  line
  line `(a) all constituencies shall, as far as practicable, be geographically compact areas, and in`
  line `delimiting them regard shall be had to physical features, existing boundaries of administrative units,`
  line `facilities of communication and convenience to the public; and`
  line
  line `(b) constituencies in which seats are reserved for the Scheduled Castes and the Scheduled`
  line `Tribes shall, as far as practicable, be located in areas where the proportion of their population to the`
  line `total population is the largest.`
  line
  line `(2) For the purpose of assisting it in the performance of its functions under sub-section (1), the`
  line `Election Commission shall associate with itself as associate members,—`
  line
  line `(a) the sitting members of the House of the People referred to in section 11; and`
  line
  line `(b) such six of the members of the Legislative Assembly of the existing Union territory or, as the`
  line `case may be, the provisional Legislative Assembly referred to in section 13 as the Speaker thereof`
  line `may nominate:`
  line
  line `Provided that none of the associate members shall have a right to vote or to sign any decision of the`
  line `Election Commission.`
  line
  line `(3) If, owing to death or resignation, the office of an associate member falls vacant, it shall be filled if`
  line `practicable, in accordance with the provisions of sub-section (2).`
  line
  line `(4) The Election Commission shall—`
  line
  line `(a) publish its proposals for the delimitation of constituencies together with the dissenting`
  line `proposals, if any, of any associate member who desires publication thereof, in the Official Gazette`
  line `and in such other manner as the Commission may consider fit, together with a notice inviting`
  line `objections and suggestions in relation to the proposals and specifying a date on or after which the`
  line `proposals will be further considered by it;`
  line
  line `(b) consider all objections and suggestions which may have been received by it before the date so`
  line specified;
  line
  line `(c) after considering all objections and suggestions which may have been received by it before the`
  line `date so specified, determine by one or more orders the delimitation of constituencies and cause`
  line `such order or orders to be published in the Official Gazette; and upon such publication, the order`
  line `or orders shall have the full force of law and shall not be called in question in any Court.`
  line
  line `(5) As soon as may be after such publication, every such order relating to assembly`
  line `constituencies shall be laid before the Legislative Assembly of the existing Union territory or, as the case`
  line `may be, the provisional Legislative Assembly referred to in section 13.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (39326)
  sectionNo (18)
  orderNo 18
  title `Power of Election Commission to maintain delimitation orders up-to-date.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39326&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_18_content:
  string
  line `(1) The Election`
  line `Commission may, from time to time, by notification in the Official Gazette,—`
  line
  line `(a) correct any printing mistakes in any order made under section 17 or any error arising therein`
  line `from inadvertent slip or omission;`
  line
  line `(b) where the boundaries or name of any territorial division mentioned in any such order are or is`
  line `altered, make such amendments as appear to it to be necessary or expedient for bringing such order`
  line up-to-date.
  line
  line `(2) Every notification under this section relating to an assembly constituency shall be laid, as soon as`
  line `may be after it is issued, before the Legislative Assembly of the existing Union territory, the provisional`
  line `Legislative Assembly referred to in section 13 or the Legislative Assembly of the State of Goa, as the`
  line `case may be.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (39327)
  sectionNo (19)
  orderNo 19
  title [Repealed].
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39327&sectionno=19&orderno=19&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_19_content:
  string
  line `[Amendment of Scheduled Castes and Scheduled Tribes Orders].—Rep. by the Repealing and`
  line `Amending Act, 2001(30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (39328)
  sectionNo (20)
  orderNo 20
  title `Common High Court for Maharashtra, Goa, Dadra and Nagar Haveli and Daman and Diu.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39328&sectionno=20&orderno=20&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_20_content:
  string
  line `(1) On and from the appointed day,—`
  line
  line `(a) there shall be a common High Court for the States of Maharashtra and Goa, and for the Union`
  line `territories of Dadra and Nagar Haveli, and Daman and Diu, to be called the High Court of Bombay`
  line `(hereinafter referred to as the common High Court);`
  line
  line `(b) the Judges of the High Court of Bombay (hereinafter referred to as the existing High Court),`
  line `holding office immediately before that day shall, unless they have elected otherwise, become, on that`
  line `day, the Judges of the common High Court.`
  line
  line `(2) The expenditure in respect of the salaries and allowances of the Judges of the common High Court`
  line `shall be allocated amongst the States of Maharashtra and Goa and the Union in such proportion as the`
  line `President may, by order, determine.`
  line
  line `(3) On and from the appointed day, the common High Court shall have, in respect of the territories`
  line `comprised in the States of Maharashtra and Goa and the Union territories of Dadra and Nagar Haveli and`
  line `Daman and Diu, all such jurisdiction, powers and authority as, under the law in force immediately before`
  line `the appointed day, are exercisable in respect of those territories by the High Court of Bombay.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (39329)
  sectionNo (21)
  orderNo 21
  title `Provision as to advocates.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39329&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_21_content:
  string
  line `(1) On and from the appointed day,—`
  line
  line `(a) in the Advocates Act, 1961 (43 of 1961), in section 3, in sub-section (1), for Clause (ccc), the`
  line `following clause shall be substituted, namely:—`
  line
  line `"(ccc) for the States of Maharashtra and Goa and the Union territories of Dadra and Nagar`
  line `Haveli and Daman and Diu, to be known as the Bar Council of Maharashtra and Goa;";`
  line
  line `(b) the Bar Council of Maharashtra shall be deemed to be the Bar Council of Maharashtra and`
  line `Goa with the Advocate-General of the State of Goa also as an ex officio member.`
  line
  line `(2) Any person who, immediately before the appointed day, is an advocate entitled to practice in the`
  line `existing High Court shall be entitled to practice as an advocate in the common High Court.`
  line
  line `(3) All persons who, immediately before the appointed day, are advocates on the roll of the Bar`
  line `Council of Maharashtra, shall, as from that day, become advocates on the roll of the Bar Council of`
  line `Maharashtra and Goa.`
  line
  line `(4) The right of audience in the common High Court shall be regulated in accordance with the like`
  line `principles as, immediately before the appointed day, are in force with respect to the right of audience in`
  line `existing High Court;`
  line
  line `Provided that as between the Advocates-General of the States of Maharashtra and Goa, the right of`
  line `audience shall be determined with reference to their dates of enrolment as advocates.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (39330)
  sectionNo (22)
  orderNo 22
  title `Practice and procedure in the common High Court.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39330&sectionno=22&orderno=22&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_22_content:
  string
  line `Subject to the provisions of this Part, the`
  line `law in force immediately before the appointed day with respect to practice and procedure in the existing`
  line `High Court shall, with the necessary modifications, apply in relation to the common High Court.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (39331)
  sectionNo (23)
  orderNo 23
  title `Custody of seal of the common High Court.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39331&sectionno=23&orderno=23&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_23_content:
  string
  line `The law in force immediately before the`
  line `appointed day with respect to the custody of the seal of the existing High Court shall, with the necessary`
  line `modifications, apply with respect to the custody of the seal of the common High Court.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (39332)
  sectionNo (24)
  orderNo 24
  title `Form of writs and other processes.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39332&sectionno=24&orderno=24&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_24_content:
  string
  line `The law in force immediately before the appointed day`
  line `with respect to the form of writs and other processes used, issued or awarded by the existing High Court`
  line `shall, with necessary modifications, apply with respect to the form of writs and other processes used,`
  line `issued or awarded by the common High Court.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (39333)
  sectionNo (25)
  orderNo 25
  title `Powers of Judges.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39333&sectionno=25&orderno=25&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_25_content:
  string
  line `The law in force immediately before the appointed day with respect to the`
  line `powers of the Chief Justice, single Judges and division Courts of the existing High Court and with respect`
  line `to all matters, ancillary to the exercise of those powers shall, with the necessary modification apply in`
  line `relation to the common High Court.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (39334)
  sectionNo (26)
  orderNo 26
  title `Principal seat and other places of sitting of the common High Court.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39334&sectionno=26&orderno=26&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_26_content:
  string
  line `(1) The principal seat`
  line `of the common High Court shall be at the same place at which the principal seat of the existing High`
  line `Court is located immediately before the appointed day.`
  line
  line `(2) The president may, by notified order, provide for the establishment of a permanent bench or`
  line `benches of the common High Court at one or more places within the territories to which the jurisdiction`
  line `of the High Court extends, other than the principal seat of the High Court, and for any matters connected`
  line `therewith:`
  line
  line `Provided that before issuing any order under this sub-section, the President shall consult the Chief`
  line `Justice of the common High Court, and the Governor of the State in which the bench or benches is or are`
  line `proposed to be established.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1) or sub-section (2), the Judges and division`
  line `Courts of the common High Court may also sit at such other place or places within the territories to which`
  line `the jurisdiction of that High Court extends as the Chief Justice of that High Court may, with the approval`
  line `of the Governor of the State or the Administrator of the Union territory concerned, appoint.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (39335)
  sectionNo (27)
  orderNo 27
  title `Procedure as to appeals to Supreme Court.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39335&sectionno=27&orderno=27&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_27_content:
  string
  line `The law in force immediately before the`
  line `appointed day relating to appeals to the Supreme Court from the existing High Court and the Judges and`
  line `division Courts thereof shall, with the necessary modifications, apply in relation to the common High`
  line Court.
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (39336)
  sectionNo (28)
  orderNo 28
  title `Transfer of proceedings to the common High Court.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39336&sectionno=28&orderno=28&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_28_content:
  string
  line `(1) All proceedings pending in the`
  line `existing High Court immediately before the appointed day shall, from such day, stand transferred to the`
  line `common High Court.`
  line
  line `(2) Every proceeding transferred under sub-section (1) shall be disposed of by the common High`
  line `Court as if such proceeding was entertained by that High Court.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (39337)
  sectionNo (29)
  orderNo 29
  title `Interpretation, etc.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39337&sectionno=29&orderno=29&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_29_content:
  string
  line `(1) For the purposes of section 28,—`
  line
  line `(a) proceedings shall be deemed to be pending in a Court until that court has disposed of all`
  line `issues between the parties, including any issues with respect to the taxation of the costs of the`
  line `proceedings and shall include appeals, applications for leave to appeal to the Supreme Court,`
  line `applications for review, petitions for revision and petitions for writs; and`
  line
  line `(b) references to a High Court shall be construed as including references to a Judge or division`
  line `Court thereof and references to an order made by a Court or a Judge shall be construed as including`
  line `references to a sentence, judgment or decree passed or made by that Court or Judge.`
  line
  line `(2) Any person who, immediately before the appointed day, is an advocate entitled to practice in the`
  line `existing High Court and was authorised to appear or to act in any proceedings transferred from that High`
  line `Court to the common High Court under section 28 shall have the right to appear or to act, as the case may`
  line `be, in the common High Court in relation to those proceedings.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (39338)
  sectionNo (30)
  orderNo 30
  title Saving.
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39338&sectionno=30&orderno=30&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_30_content:
  string
  line `Nothing in this Part shall affect the application to the common High Court of any`
  line `provisions of the Constitution, and this Part shall have effect subject to any provision that may be made`
  line `on or after the appointed day with respect to that High Court by any Legislature or other authority having`
  line `power to make such provision.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (39339)
  sectionNo (31)
  orderNo 31
  title `Authorisation of expenditure pending its sanction by the Legislature.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39339&sectionno=31&orderno=31&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_31_content:
  string
  line `(1) The President`
  line `may, at any time before the appointed day, authorise by order such expenditure from the Consolidated`
  line `Fund of the State of Goa as he deems necessary for a period of not more than six months beginning with`
  line `the appointed day, pending the sanction of such expenditure by the Legislative Assembly of the State of`
  line `Goa:`
  line
  line `Provided that the Governor of Goa may, after the appointed day, authorise by order such further`
  line `expenditure as he deems necessary from the Consolidated Fund of the State of Goa for any period not`
  line `extending beyond the said period of six months.`
  line
  line `(2) The President or, as the case may be, the Governor of Goa shall make separate orders under`
  line `sub-section (1) in respect of periods falling in different financial years.`
  line
  line `(3) The President may, at any time, before or after the appointed day, authorise by order such`
  line `expenditure from the Consolidated Fund of India as he deems necessary for a period of not more than six`
  line `months beginning with the appointed day for the administration of the affairs of the Union territory of`
  line `Daman and Diu pending the sanction of such expenditure by Parliament.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (39340)
  sectionNo (32)
  orderNo 32
  title `Reports relating to the accounts of the existing Union territory.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39340&sectionno=32&orderno=32&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_32_content:
  string
  line `(1) The reports of the`
  line `Comptroller and Auditor-General of India referred to in section 49 of the Government of Union`
  line `Territories Act, 1963 (20 of 1963), relating to the accounts of the existing Union territory in respect of`
  line `any period prior to the appointed day, shall be submitted to the Governor of the State of Goa and the`
  line `President who shall cause them to be laid before the Legislative Assembly of that State or the House of`
  line `the People, as the case may be.`
  line
  line `(2) The Governor may, by order,—`
  line
  line `(a) declare any expenditure incurred out of the Consolidated Fund of the existing Union territory`
  line `on any service in respect of any period prior to the appointed day during the financial year 1987-88 or`
  line `in respect of any earlier financial year in excess of the amount granted for that service and for that`
  line `year as disclosed in the report referred to in sub-section (1) to have been duly authorised; and`
  line
  line `(b) provide for any action to be taken on any matter arising out of the said reports.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (39341)
  sectionNo (33)
  orderNo 33
  title `Distribution of revenues.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39341&sectionno=33&orderno=33&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_33_content:
  string
  line `The President shall, by order, determine the grants-in-aid of the`
  line `revenues of the State of Goa and the share of that State in the Union duties of excise, estate duty and taxes`
  line `on income and for that purpose amend thereby the relevant provisions of the Additional Duties of Excise`
  line `(Goods of Special Importance) Act, 1957 (58 of 1957), the Union Duties of Excise (Distribution)`
  line `Act, 1979 (24 of 1979), the Estate Duty (Distribution) Act, 1962 (9 of 1962) and the Construction`
  line `(Distribution of Revenues) Order,1985 in such manner as he thinks fit.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (39342)
  sectionNo (34)
  orderNo 34
  title Definition.
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39342&sectionno=34&orderno=34&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_34_content:
  string
  line `In this Part "Union purposes" means the purposes of Government relatable to any of`
  line `the matters mentioned in List I in the Seventh Schedule to the Constitution.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (39343)
  sectionNo (35)
  orderNo 35
  title `Land and goods.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39343&sectionno=35&orderno=35&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_35_content:
  string
  line `(1) Subject to the other provisions of this Part, all land and all stores, articles`
  line `and other goods held immediately before the appointed day, by the Union for the purposes of the`
  line `governance of the existing Union territory, shall, on and from that day, pass to the State of Goa, unless`
  line `any such land, stores, articles or goods are situate in the districts of Daman and Diu of the existing Union`
  line `territory or are held for Union purposes:`
  line
  line `Provided that where the Central Government is of the opinion that any goods or class of goods should`
  line `be distributed otherwise than according to the situation of the goods, the Central Government may issue`
  line `such directions as it thinks fit for a just and equitable distribution of the goods.`
  line
  line `(2) The stores held for specific purposes, such as use or utilisation in particular institutions,`
  line `workshops or undertakings or on particular works under construction, shall be retained by the Union if`
  line `such institution, workshop, undertaking or work is situated in the districts of Daman and Diu of the`
  line `existing Union territory.`
  line
  line `(3) In this section, the expression land includes immovable property of every kind and any rights in`
  line `or over such property.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (39344)
  sectionNo (36)
  orderNo 36
  title `Cash balances.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39344&sectionno=36&orderno=36&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_36_content:
  string
  line `The total of the cash balances in all treasuries, the Reserve Bank of India, the`
  line `State Bank of India and any nationalised bank, of the existing Union territory immediately before the`
  line `appointed day shall be divided between the State of Goa and the Union according to the population ratio:`
  line
  line `Provided that for the purposes of such division, there shall be no transfer of cash balances from any`
  line `treasury to any other treasury and the apportionment shall be effected by adjusting the balances in the`
  line `books of the Reserve Bank of India.`
  line
  line `Explanation.—In this section, "balance" includes a debit balance.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (39345)
  sectionNo (37)
  orderNo 37
  title `Arrears of taxes.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39345&sectionno=37&orderno=37&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_37_content:
  string
  line `(1) The right to recover arrears of any tax or duty (including arrears of land`
  line `revenue) on any property situated in the district of Goa of the existing Union territory shall belong to the`
  line `State of Goa.`
  line
  line `(2) The right to recover arrears of any tax or duty, other than a tax or duty specified in sub-section (1),`
  line `shall belong to the State of Goa if the place of assessment of that tax or duty is included in the district of`
  line `Goa of the existing Union territory.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (39346)
  sectionNo (38)
  orderNo 38
  title `Right to recover loans and advances.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39346&sectionno=38&orderno=38&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_38_content:
  string
  line `The right to recover any loans or advances made by the`
  line `Union before the appointed day to any local body, society, agriculturist or other person in the district of`
  line `Goa of the existing Union territory shall belong to the State of Goa:`
  line
  line `Provided that right to recover loans or advances of pay and travelling allowance to a Government`
  line `servant made before the appointed day by the Administrator shall pass to the State of Goa if such`
  line `Government servant is allotted to that State.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (39347)
  sectionNo (39)
  orderNo 39
  title `Investments in and loans, etc., to certain corporate bodies.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39347&sectionno=39&orderno=39&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_39_content:
  string
  line `Where any body corporate`
  line `constituted under a Central Act or a State Act for the existing Union territory, or any part thereof, has, by`
  line `virtue of the provisions of Part II, become an inter-State body corporate, the investments in, or loans or`
  line `advances to any such body by the Union made before the appointed day shall be divided between the`
  line `State of Goa and the Union in such manner as may be agreed between them before the expiration of one`
  line `year from the appointed day, or in default of such agreement in such manner as the Central Government`
  line `may, by order, direct.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (39348)
  sectionNo (40)
  orderNo 40
  title `Assets and liabilities of State undertakings.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39348&sectionno=40&orderno=40&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_40_content:
  string
  line `The assets and liabilities relating to any`
  line `commercial undertaking of the existing Union territory shall,—`
  line
  line `(a) if the undertaking is located in the district of Goa of the existing Union territory, pass to the`
  line `State of Goa;`
  line
  line `(b) if the undertaking is located in the district of Goa, as well as the districts of Daman and Diu,`
  line `of the existing Union territory, be divided in such manner as may be agreed upon between the State of`
  line `Goa and the Union before the expiration of one year from the appointed day, or in default of such`
  line `agreement, as the Central Government may, by order, direct.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (39349)
  sectionNo (41)
  orderNo 41
  title `Refund of taxes collected in excess.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39349&sectionno=41&orderno=41&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_41_content:
  string
  line `The liability of the Union to refund—`
  line
  line `(a) any tax or duty on property, including land revenue collected in excess shall go to the State of`
  line `Goa if the property is situated in the district of Goa of the existing Union territory;`
  line
  line `(b) any other tax or duty collected in excess shall go to the State of Goa if the place of assessment`
  line `of that tax or duty is included in the district of Goa of the existing Union territory.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (39350)
  sectionNo (42)
  orderNo 42
  title `Certain deposits.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39350&sectionno=42&orderno=42&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_42_content:
  string
  line `The liability of the Union in respect of any civil deposit or local fund shall,`
  line `on and from the appointed day, be the liability of the State of Goa, if the deposit has been made in the`
  line `district of Goa of the existing Union territory.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (39351)
  sectionNo (43)
  orderNo 43
  title `Provident fund.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39351&sectionno=43&orderno=43&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_43_content:
  string
  line `(1) The liability of the Union in respect of the provident fund account of a`
  line `Government servant employed in connection with the administration of the existing Union territory and in`
  line `service on the appointed day shall, on and from that day, be the liability of the State of Goa if that`
  line `Government servant is permanently allotted to that State.`
  line
  line `(2) The liability of the Union in respect of the provident fund account of a Government servant`
  line `employed in connection with the administration of the existing Union territory who has retired from`
  line `service before the appointed day shall be the liability of the State of Goa in the first instance and shall be`
  line `adjusted between the State of Goa and the Union according to the population ratio.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (39352)
  sectionNo (44)
  orderNo 44
  title `Pensions granted by the Administrator, etc.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39352&sectionno=44&orderno=44&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_44_content:
  string
  line `(1) Subject to the adjustments mentioned in`
  line `sub-section (4), the State of Goa shall, in respect of pensions granted before the appointed day by the`
  line `Administrator, pay the pensions drawn in the treasuries in the Goa district of the existing Union territory.`
  line
  line `(2) Subject to the adjustments mentioned in sub-section (4), the liability in respect of pensions of`
  line `Government servants employed in connection with the affairs of the existing Union territory who retire or`
  line `proceed on leave preparatory to retirement before the appointed day but whose claims for pensions are`
  line `outstanding immediately before that day, shall be the liability of the State of Goa.`
  line
  line `(3) The liability of the Union in respect of pensions granted before the appointed day by the`
  line `Administrator and drawn in any treasury outside the existing Union territory shall be the liability of the`
  line `State of Goa subject to adjustments to be made in accordance with sub-section (4), as if such pensions had`
  line `been drawn in the treasuries referred to in sub-section (1).`
  line
  line `(4) In respect of the period commencing on the appointed day and ending on the 31st day of March,`
  line `1988, and in respect of each subsequent financial year, the total payments made by the State of Goa in`
  line `respect of pensions referred to in sub-section (1) and sub-section (2) shall be apportioned between the`
  line `State of Goa and the Union in the population ratio.`
  line
  line `(5) The liability in respect of the pension of any Government servant employed immediately before`
  line `the appointed day in connection with the affairs of the existing Union territory and retiring on or after that`
  line `day, shall be that of the State of Goa or the Union, as the case may be, but the portion of the pension in`
  line `respect of the period of service of any such Government servant before the appointed day shall be`
  line `apportioned between the State of Goa and the Union in the population ratio.`
  line
  line `(6) Any reference in this section to a pension shall be construed as including a reference to the`
  line `commuted value of the pension.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (39353)
  sectionNo (45)
  orderNo 45
  title Contracts.
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39353&sectionno=45&orderno=45&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_45_content:
  string
  line `(1) Where before the appointed day, the Union has made any contract in the exercise`
  line `of its executive power for any purposes of the existing Union territory that contract shall be deemed to`
  line `have been made in the exercise of the executive power of the State of Goa,—`
  line
  line `(a) if the purposes of the contract are, on and from the appointed day, exclusively purposes of that`
  line `State; and`
  line
  line `(b) if the purposes of the contract are, on and from that day, not exclusively purposes of any area`
  line `in the districts of Daman and Diu of the existing Union territory,`
  line
  line `and all rights and liabilities which have accrued, or may accrue, under any such contract shall, to the`
  line `extent to which they would have been rights or liabilities of the Union, be rights or liabilities of the State`
  line `of Goa:`
  line
  line `Provided that in any such case as is referred to in clause (b), the initial allocation of rights and`
  line `liabilities made by this sub-section shall be subject to such financial adjustments as may be agreed upon`
  line `between the State of Goa and the Union or in default of such agreement, as the Central Government may,`
  line `by order, direct.`
  line
  line `(2) For the purposes of this section, there shall be deemed to be included in the liabilities which have`
  line `accrued or may accrue under any contract—`
  line
  line `(a) any liability to satisfy an order or award made by any court or other tribunal in proceedings`
  line `relating to the contract; and`
  line
  line `(b) any liability in respect of expenses incurred in, or in connection with, any such proceedings.`
  line
  line `(3) This section shall have effect subject to the other provisions of this Part relating to the`
  line `apportionment of liabilities in respect of loans, guarantees and other financial obligations.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (39354)
  sectionNo (46)
  orderNo 46
  title `Liability in respect of actionable wrong.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39354&sectionno=46&orderno=46&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_46_content:
  string
  line `Where, immediately before the appointed day, the`
  line `Union in connection with the governance of the existing Union territory is subject to any liability in`
  line `respect of an actionable wrong, other than breach of contract, that liability shall,—`
  line
  line `(a) if the cause of action arose wholly within the district of Goa of the existing Union territory, be`
  line `a liability of the State of Goa; and`
  line
  line `(b) in any other case, be initially a liability of the State of Goa but subject to such financial`
  line `adjustments as may be agreed upon between the State of Goa and the Union, or in default of such`
  line `agreement, as the Central Government may, by order, direct.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (39355)
  sectionNo (47)
  orderNo 47
  title `Liability as guarantor of co-operative societies.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39355&sectionno=47&orderno=47&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_47_content:
  string
  line `Where, immediately before the appointed`
  line `day, the Union in connection with the governance of the existing Union territory is liable as guarantor in`
  line `respect of any liability of a registered co-operative society or other person, that liability of the Union shall`
  line `be a liability of the State of Goa—`
  line
  line `(a) if the area of the operations of such society or person is limited to the territories in the district`
  line `of Goa of the existing Union territory; and`
  line
  line `(b) if the area of the operations of such society or person extends to the whole of the existing`
  line `Union territory:`
  line
  line `Provided that in any such case as is referred to in clause (b), the initial allocation of liabilities under`
  line `this section shall be subject to such financial adjustments as may be agreed upon between the State of Goa`
  line `and the Union or in default of such agreement, as the Central Government may, by order, direct.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (39356)
  sectionNo (48)
  orderNo 48
  title `Items in suspense.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39356&sectionno=48&orderno=48&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_48_content:
  string
  line `If any item in suspense is ultimately found to affect an asset or liability of`
  line `the nature referred to in any of the foregoing provisions of this Part, it shall be dealt with in accordance`
  line `with that provision.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (39357)
  sectionNo (49)
  orderNo 49
  title `Residuary provision.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39357&sectionno=49&orderno=49&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_49_content:
  string
  line `The benefit or burden of any assets or liabilities of the Union in`
  line `connection with the governance of the existing Union territory not dealt with in the foregoing provisions`
  line `of this Part shall be retained by the Union for the purposes of the governance of the Union territory of`
  line `Daman and Diu.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (39358)
  sectionNo (50)
  orderNo 50
  title `Apportionment of assets or liabilities by agreement.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39358&sectionno=50&orderno=50&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_50_content:
  string
  line `Where the State of Goa and the Union`
  line `agree that the benefit or burden of any particular asset or liability should be apportioned between them in`
  line `a manner other than that provided for in the foregoing provisions of this Part, then, notwithstanding`
  line `anything contained therein, the benefit or burden of that asset or liability shall be apportioned in the`
  line `manner agreed upon.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (39359)
  sectionNo (51)
  orderNo 51
  title `Power of Central Government to order allocation or adjustment in certain cases.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39359&sectionno=51&orderno=51&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_51_content:
  string
  line Where,
  line `by virtue of any of the provisions of this Part, the Union becomes entitled to any property or obtains any`
  line `benefits or the State of Goa becomes subject to any liability, and the Central Government is of opinion on`
  line `a reference made within a period of three years from the appointed day by the State of Goa that it is just`
  line `and equitable that that property or those benefits should be transferred to, or shared with, the State of Goa`
  line `or that a contribution towards that liability should be made by the Union the said property or benefits`
  line `shall be allocated in such manner, or the Union shall make to the State of Goa such contribution in respect`
  line `thereof, as the Central Government may, after consultation with the Government of the State of Goa by`
  line `order, determine.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (39360)
  sectionNo (52)
  orderNo 52
  title `Continuance of certain arrangements.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39360&sectionno=52&orderno=52&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_52_content:
  string
  line `Where any arrangement in regard to the supply of`
  line `electric power or the supply of water for any area in the districts of Daman and Diu of the existing Union`
  line `territory or in regard to the execution of any project for such supply from an area included in the State of`
  line `Goa by the provisions of Part II exists, such arrangement will be continued, unless terminated by`
  line `agreement, between the State of Goa and the Union in accordance with such terms and conditions as`
  line `may be mutually agreed upon by the State Government of Goa and the Union within a period of one year`
  line `from the appointed day, and, where no such agreement is arrived at within such period, the Central`
  line `Government may give such directions as it deems fit to that State Government or the authority concerned`
  line `for the continuance, so far as is practicable, of the previous arrangement.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (39361)
  sectionNo (53)
  orderNo 53
  title `Provision as to co-operative banks.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39361&sectionno=53&orderno=53&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_53_content:
  string
  line `Notwithstanding anything contained in section 22 of`
  line `the Banking Regulation Act, 1949 (10 of 1949), where by virtue of the provisions of Part II, a cooperative bank is newly formed on the appointed day or within three months thereof in the State of Goa or`
  line `the Union territory of Daman and Diu, it may commence and conduct banking business without obtaining`
  line `a licence under that section from the Reserve Bank of India, until it is granted such a licence or until it is`
  line `informed by the Reserve Bank of India that such a licence cannot be granted to it:`
  line
  line `Provided that such bank applies to the Reserve Bank of India for such a licence within a period of`
  line `three months from the date of formation of the Bank.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (39362)
  sectionNo (54)
  orderNo 54
  title `General provisions as to statutory corporations.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39362&sectionno=54&orderno=54&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_54_content:
  string
  line `(1) Where any body corporate constituted`
  line `under any Central Act, State Act or Provincial Act for the existing Union territory or any part thereof has,`
  line `by virtue of the provisions of Part II, become an inter-State body corporate, then, the body corporate shall,`
  line `on and from the appointed day, continue to function and operate in those areas in respect of which it was`
  line `functioning and operating immediately before that day, subject to such directions as may from time to`
  line `time be issued by the Central Government until other provision is made by law in respect of the said`
  line `body corporate.`
  line
  line `(2) Any direction issued by the Central Government under sub-section (1) in respect of any such`
  line `body corporate may include a direction that any law by which the said body corporate is governed shall,`
  line `in its application to that body corporate, have effect, subject to such exceptions and modifications as may`
  line `be specified in the direction.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (39363)
  sectionNo (55)
  orderNo 55
  title `Temporary provisions as to continuance of certain existing road transport permits.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39363&sectionno=55&orderno=55&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_55_content:
  string
  line `(1)`
  line `Notwithstanding anything contained in section 63 of the Motor Vehicles Act, 1939 (4 of 1939), a permit`
  line `granted in the existing Union territory shall, if such permit was immediately before the appointed day,`
  line `valid and effective in any area therein, be deemed to continue to be valid and effective in that area up to`
  line `the 31st day of March,1988, subject to the provisions of that Act as for the time being in force in that area`
  line `and it shall not be necessary for any such permit to be countersigned by any State or Regional Transport`
  line `Authority for the purpose of validating it for use in such area:`
  line
  line `Provided that the Central Government may, after consultation with the State Government of Goa add`
  line `to, amend or vary the conditions attached to the permit by the authority by which the permit was granted.`
  line
  line `(2) No toll, entrance fees or other charges of a like nature shall be levied for a period up to and`
  line `inclusive of the 31st day of March, 1988, in respect of any transport vehicle for its operations in either the`
  line `State of Goa or the Union territory of Daman and Diu under any such permit, if such vehicle was`
  line `immediately before that day exempt from the payment of any such toll, entrance fees or other charges for`
  line `its operations within the existing Union territory:`
  line
  line `Provided that the Central Government may, after consultation with the State Government of Goa`
  line `authorise the levy of any such toll, entrance fees or other charges, as the case may be.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (39364)
  sectionNo (56)
  orderNo 56
  title `Special provision relating to retrenchment compensation in certain cases.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39364&sectionno=56&orderno=56&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_56_content:
  string
  line `Where, by virtue`
  line `of the provisions of Part II, any body corporate constituted under a Central Act, State Act or Provincial`
  line `Act, any co-operative society registered under any law relating to cooperative societies or any commercial`
  line `or industrial undertaking is reconstituted or reorganised in any manner whatsoever or is amalgamated`
  line `with any other body corporate, co-operative society or undertaking, or is dissolved, and in consequence of`
  line `such reconstitution, reorganisation, amalgamation or dissolution, any workman employed by such`
  line `body corporate or any such co-operative society or undertaking, is transferred to, or re-employed by any`
  line `other body corporate, or in any other co-operative society or undertaking, then, notwithstanding anything`
  line `contained in section 25F, section 25FF or section 25FFF, of the Industrial Disputes Act, 1947`
  line `(14 of 1947), such transfer or re-employment shall not entitle him to any compensation under that section:`
  line
  line `Provided that—`
  line
  line `(a) the terms and conditions of service applicable to the workman after such transfer or`
  line `re-employment are not less favourable to the workman than those applicable to him immediately`
  line `before the transfer or re-employment; and`
  line
  line `(b) the employer in relation to the body corporate, the co-operative society or the undertaking`
  line `where the workman transferred or re-employed, is by agreement or otherwise, legally liable to pay to`
  line `the workman, in the event of his retrenchment, compensation under section 25F, section 25FF or`
  line `section 25FFF of the Industrial Disputes Act, 1947 (14 of 1947), on the basis that his service has been`
  line `continuous and has not been interrupted by the transfer or re-employment.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (39365)
  sectionNo (57)
  orderNo 57
  title `Special provision as to income-tax.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39365&sectionno=57&orderno=57&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_57_content:
  string
  line `Where the assets, rights and liabilities of`
  line `any body corporate carrying on business are, under the provisions of this Part, transferred to`
  line `any other bodies corporate which after the transfer carry on the same business, the losses of profits or`
  line `gains sustained by the body corporate first mentioned which, but for such transfer, would have been`
  line `allowed to be carried forward and set off in accordance with the provisions of Chapter VI of the`
  line `Income-tax Act, 1961 (43 of 1961) shall be apportioned amongst the transferee bodies corporate in`
  line `accordance with the rules to be made by the Central Government in this behalf and, upon such`
  line `apportionment, the share of loss allotted to each transferee body corporate shall be dealt with in`
  line `accordance with the provisions of Chapter VI of the said Act as if the transferee body corporate had itself`
  line `sustained such loss in a business carried on by it in the years in which these losses were sustained.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (39366)
  sectionNo (58)
  orderNo 58
  title `Continuance of existing facilities in certain institutions.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39366&sectionno=58&orderno=58&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_58_content:
  string
  line `On and from the appointed day, the`
  line `Government of Goa shall, in respect of the technical institutions located in the State of Goa continue to`
  line `provide facilities to the persons resident in the territories comprising the Union territory of Daman and`
  line `Diu which shall not in any respect be less favourable than those which were being provided to them`
  line `immediately before that day upon such terms and conditions (including those relating to any contribution`
  line `or payment to be made for the provisions of such facilities) as may be agreed upon between the State of`
  line `Goa and the Union before the 1st day of April, 1988, or if no such agreement is reached by the said date,`
  line `as may be fixed by the order of the Central Government.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (39367)
  sectionNo (59)
  orderNo 59
  title `Provisions relating to All India Services.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39367&sectionno=59&orderno=59&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_59_content:
  string
  line `(1) In this section, the expression "State Cadre",—`
  line
  line `(a) in relation to the Indian Administrative Service, has the meaning assigned to it in the Indian`
  line `Administrative Service (Cadre) Rules, 1954;`
  line
  line `(b) in relation to the Indian Police Service, has the meaning assigned to it in the Indian Police`
  line `Service (Cadre) Rules, 1954, and`
  line
  line `(c) in relation to the Indian Forest Service, has the meaning assigned to it in the Indian Forest`
  line `Service (Cadre) Rules, 1966.`
  line
  line `(2) The strength and composition of the State Cadre of Goa shall, on and from the appointed day, be`
  line `such as is determined by the Central Government in consultation with the State Government.`
  line
  line `(3) The members of each of the said Services borne on the Union territories cadre immediately before`
  line `the appointed day shall continue to be in the cadre of the same service of the Union territory in which they`
  line `stand allocated before the appointed day.`
  line
  line `(4) Nothing in this section shall be deemed to affect the operation, on or after the appointed day, of`
  line `the All India Services Act, 1951 (61 of 1951), or the rules made thereunder, in relation to the State cadres`
  line `of the said services and in relation to the members of those services borne on the said cadres.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (39368)
  sectionNo (60)
  orderNo 60
  title `Provisions relating to other services.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39368&sectionno=60&orderno=60&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_60_content:
  string
  line `(1) Every person employed in connection with the affairs`
  line `of the Union territory or the State of Goa and serving, immediately before the appointed day, in the`
  line `district of Goa of the existing Union territory shall, on and from that day,—`
  line
  line `(a) continue to serve in connection with the affairs of the State of Goa; and`
  line
  line `(b) be deemed to be provisionally allotted to serve in connection with the affairs of the said State:`
  line
  line `Provided that nothing in clause (b) shall apply to a person to whom the provisions of section 59 apply`
  line `or to a person on deputation from any State.`
  line
  line `(2) As soon as may be after the appointed day, the Central Government shall by general or special`
  line `order, determine whether every person referred to in clause (b) of sub-section (1) shall be finally allotted`
  line `for service in the State of Goa or under the Union in connection with the affairs of the Union territory of`
  line `Daman and Diu and the date with effect from which such allotment shall take effect or be deemed to have`
  line `taken effect.`
  line
  line `(3) Every person who is finally allotted under the provisions of sub-section (2) to the State of Goa or`
  line `the Union shall, if he is not already serving therein or thereunder be made available for serving in that`
  line `State or under the Union from such date as may be agreed upon between the State of Goa and the Union`
  line `or in default of such agreement, as may be determined by the Central Government.`
  line
  line `(4) As soon as may be after the Central Government passes orders finally allotting an employee in`
  line `terms of sub-section (2), the State of Goa or the Union shall take steps to integrate him into the services`
  line `under its control in accordance with such special or general orders or instructions as may be issued by the`
  line `Central Government from time to time in this behalf.`
  line
  line `(5) The Central Government may, by order establish one or more Advisory Committees for the`
  line `purpose of assisting it in regard to—`
  line
  line `(a) the division of the services between the State of Goa and the Union; and`
  line
  line `(b) the ensuring of fair and equitable treatment to all persons affected by the provisions of this`
  line `section and the proper consideration of any representations made by such persons:`
  line
  line `Provided that notwithstanding anything to the contrary contained in any law or rule for the time being`
  line `in force, no representation shall be against any order passed by the competent authority on matters arising`
  line `out of the division and integration of services under this Act, on the expiry of three months from the date`
  line `of publication or service, whichever is earlier, of such order:`
  line
  line `Provided further that, notwithstanding anything contained in the preceding proviso, the Central`
  line `Government may suo motu or otherwise and for reasons to be recorded, reopen any matter and pass such`
  line `orders thereon, as may appear to it to be appropriate if it is satisfied that it is necessary so to do, in order`
  line `to prevent any miscarriage of justice to any affected employee.`
  line
  line `(6) Nothing in this section shall be deemed to affect, on or after the appointed day, the operation of`
  line `the provisions of Chapter I of Part XIV of the Constitution in relation to the determination of the`
  line `conditions of service of persons serving in connection with the affairs of the State of Goa or the Union:`
  line
  line `Provided that the conditions of service applicable immediately before the appointed day to the case of`
  line `any person referred to in sub-section (1) or sub-section (2) shall not be varied to his disadvantage except`
  line `with the previous approval of the Central Government.`
  line
  line `(7) All service prior to the appointed day rendered by a person allotted under sub-section (2) in`
  line `connection with the affairs of the existing Union territory shall for purposes of the rules regarding his`
  line `conditions of service, be deemed to have been rendered in connection with the affairs of the State or the`
  line `Union to which he is finally allotted.`
  line
  line `(8) The provisions of this section other than clause (a) of sub-section (1) shall not apply in relation to`
  line `any person to whom the provisions of section 59 apply.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (39369)
  sectionNo (61)
  orderNo 61
  title `Provisions as to continuance of officers in the same posts.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39369&sectionno=61&orderno=61&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_61_content:
  string
  line `Every person who immediately`
  line `before the appointed day is holding or discharging the duties of any post or office in connection with the`
  line `affairs of the existing Union territory shall continue to hold the same post or office and shall be deemed,`
  line `on and from that day, to have been duly appointed on the same terms and conditions of appointment and`
  line `on the same tenure to that post or office by the Government of, or the other appropriate authority, in the`
  line `State of Goa or of the Union, as the case may be:`
  line
  line `Provided that nothing in this section shall be deemed to prevent a competent authority, on or after the`
  line `appointed day, from passing in relation to such person, any order affecting his continuance in such post or`
  line office.
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (39370)
  sectionNo (62)
  orderNo 62
  title `Powers of Central Government to give direction.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39370&sectionno=62&orderno=62&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_62_content:
  string
  line `The Central Government may give such`
  line `directions to the State Government as may appear to it to be necessary for the purpose of giving effect to`
  line `the foregoing provisions of this Part and the said Government shall comply with such directions.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (39371)
  sectionNo (63)
  orderNo 63
  title [Repealed].
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39371&sectionno=63&orderno=63&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_63_content:
  string
  line `[Amendment of certain Articles].—Rep. by the Repealing and Amending Act, 2001`
  line `(30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (39372)
  sectionNo (64)
  orderNo 64
  title [Repealed].
  content `[Amendment of Act 37 of 1956].—Rep. by s. 2 and the First Schedule, ibid. (w.e.f. 3-9-2001).`
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39372&sectionno=64&orderno=64&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (39373)
  sectionNo (65)
  orderNo 65
  title [Repealed].
  content `[Amendment of Act 20 of 1963].—Rep. by s. 2 and the First Schedule, ibid. (w.e.f. 3-9-2001).`
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39373&sectionno=65&orderno=65&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (39374)
  sectionNo (66)
  orderNo 66
  title `Territorial extent of laws.`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39374&sectionno=66&orderno=66&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_66_content:
  string
  line `The provisions of Part II shall not be deemed to have effected any`
  line `change in the territories to which any law in force immediately before the appointed day extends or`
  line `applies, and the territorial references in any such law to the existing Union territory shall, until otherwise`
  line `provided by a competent Legislature or other competent authority, be construed as meaning the territories`
  line `within the existing Union territory before the appointed day.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (39375)
  sectionNo (67)
  orderNo 67
  title `Power to adapt laws.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39375&sectionno=67&orderno=67&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_67_content:
  string
  line `For the purpose of facilitating the application in relation to the State of`
  line `Goa or the Union territory of Daman and Diu of any law made before the appointed day, the appropriate`
  line `Government may, within two years from that day, by order, make such adaptations and modifications of`
  line `the law, whether by way of repeal or amendment, as may be necessary or expedient, and thereupon every`
  line `such law shall have effect subject to the adaptations and modifications so made until altered, repealed or`
  line `amended by a competent Legislature or other competent authority.`
  line
  line `Explanation.— In this section, the expression "appropriate Government" means, as respects any law`
  line `relating to a matter enumerated in the Union List in the Seventh Schedule to the Constitution, the Central`
  line `Government, and as respects any other law,`
  line
  line `(i) in its application to the State of Goa, the State Government, and`
  line
  line `(ii) in its application to the Union territory of Daman and Diu, the Central Government.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (39376)
  sectionNo (68)
  orderNo 68
  title `Power to construe laws.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39376&sectionno=68&orderno=68&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_68_content:
  string
  line `Notwithstanding that no provision or insufficient provision has been`
  line `made under section 67 for the adaptation of a law made before the appointed day, any court, tribunal or`
  line `authority required or empowered to enforce such law may, for the purpose of facilitating its application in`
  line `relation to the State of Goa, or the Union territory of Daman and Diu construe the law in such manner not`
  line `affecting the substance as may be necessary or proper in regard to the matter before the court, tribunal or`
  line `authority, as the case may be.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (39377)
  sectionNo (69)
  orderNo 69
  title `Provisions as to continuance of courts, etc.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39377&sectionno=69&orderno=69&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_69_content:
  string
  line `All courts and tribunals and all authorities`
  line `discharging lawful functions throughout the existing Union territory or any part thereof immediately`
  line `before the appointed day shall unless their continuance is inconsistent with the provisions of this Act or`
  line `until other provision is made by a competent Legislature or other competent authority, continue to`
  line `exercise their respective functions.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (39378)
  sectionNo (70)
  orderNo 70
  title `Effect of provisions of Act inconsistent with other laws.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39378&sectionno=70&orderno=70&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_70_content:
  string
  line `The provisions of this Act shall have`
  line `effect notwithstanding anything inconsistent therewith contained in any other law.`
obj_root_law_sections_70_footnotes:
  string
  line
obj_root_law_sections_71:
  sectionId (39379)
  sectionNo (71)
  orderNo 71
  title `Power to remove difficulties.`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39379&sectionno=71&orderno=71&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_71_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the President may, by order, do anything not inconsistent with such provisions which appears`
  line `to him to be necessary or expedient for the purpose of removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of three years from the appointed day.`
  line
  line `(2) Every order made under this section shall be laid before each House of Parliament.`
obj_root_law_sections_71_footnotes:
  string
  line
obj_root_law_sections_72:
  sectionId (39380)
  sectionNo (72)
  orderNo 72
  title `Power to make rules.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00003_198718_1517807317832&sectionId=39380&sectionno=72&orderno=72&orgactid=AC_CEN_5_5_00003_198718_1517807317832
obj_root_law_sections_72_content:
  string
  line `(1) The Central Government may, by notification, make rules to give`
  line `effect to the provisions of this Act.`
  line
  line `(2) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
