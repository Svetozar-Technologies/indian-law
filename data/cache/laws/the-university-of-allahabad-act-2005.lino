obj_root_law_sections_1:
  sectionId (41209)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 14th July, 2005, vide notification No. S.O. 978(E), dated 11th July, 2005, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41209&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the University of Allahabad Act,`
  line 2005.
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_2:
  sectionId (41210)
  sectionNo (2)
  orderNo 2
  title `Declaration of University of Allahabad as Institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41210&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_2_content:
  string
  line `Whereas the`
  line `objects of the University of Allahabad in the State of Uttar Pradesh are such as to make it an Institution of`
  line `national importance, it is hereby declared that the said University is an Institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (41211)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41211&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_3_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic Council' means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Statutes;
  line
  line `(c) "appointed day" means the date of establishment of the University of Allahabad under`
  line `sub-section (1) of section 4;`
  line
  line `(d) "Centre" means a unit of the University or of a University Institute providing teaching,`
  line `consultancy and research facilities;`
  line
  line `(e) "Chancellor" means the Chancellor of the University appointed under section 13;`
  line
  line `(f) "Constituent College" means a college prescribed as such by the Statutes;`
  line
  line `(g) "Constituent Institute" means an Institute prescribed as such by the Statutes;`
  line
  line `(h) "Court" means the Court of the University;`
  line
  line `(i) "Department" means a Department of a Faculty;`
  line
  line `(j) "Director" means the head of a University Institute or Constituent Institute;`
  line
  line `(k) "employee" means any person appointed by the University and includes teachers and other`
  line `staff of the University;`
  line
  line `(l) "Executive Council" means the Executive Council of the University;`
  line
  line `(m) "Faculty" means a Faculty of the University;`
  line
  line `(n) "Finance Officer" means the Finance Officer of the University appointed under section 18;`
  line
  line `(o) "Ordinances" means the Ordinances of the University;`
  line
  line `(p) "Principal' means the head of a University College or a Constituent College;`
  line
  line `(q) "Pro-Vice-Chancellor" means the Pro-Vice-Chancellor of the University appointed under`
  line `section 15;`
  line
  line `(r) "Registrar" means the Registrar of the University appointed under section 17;`
  line
  line `(s) "Regulations" means the Regulations of the University;`
  line
  line `(t) "Statutes" means the Statutes of the University;`
  line
  line `(u) "teacher" means Professors, Readers and Lecturers appointed or recognised by the University;`
  line
  line `(v) "University" means the University of Allahabad established and incorporated under section 4;`
  line
  line `(w) "University appointed teacher" means a teacher appointed by the University for imparting`
  line `instruction and conducting research in the University or any college or institution maintained by the`
  line University;
  line
  line `(x) "University College" means a college or an institution maintained by the University or`
  line `admitted to the privileges of the University as a Faculty;`
  line
  line `(y) "University Institute" means an Institute, established and maintained by the University;`
  line
  line `(z) "University recognised teacher" means a teacher recognised by the University for imparting`
  line `instruction and conducting research in a college or institution admitted to the privileges of the`
  line `University; and`
  line
  line `(za) "Vice-Chancellor" means the Vice-Chancellor of the University appointed under section 14.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (41212)
  sectionNo (4)
  orderNo 4
  title `Incorporation of University of Allahabad.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41212&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_4_content:
  string
  line `(1) The University of Allahabad in the State of Uttar`
  line `Pradesh, established under the Uttar Pradesh State Universities Act, 1973 (President's Act 10 of 1973),`
  line `shall be established as a body corporate under this Act having perpetual succession and a common seal`
  line `and shall sue and be sued by the said name.`
  line
  line `(2) The first Chancellor, the first Vice-Chancellor and the first members of the Court, the Executive`
  line `Council and the Academic Council, and all persons who may hereafter become such officers or members,`
  line
  line `so long as they continue to hold such office or membership, shall constitute the University.`
  line
  line `(3) The headquarters of the University shall be at Allahabad.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (41213)
  sectionNo (5)
  orderNo 5
  title `Effect of incorporation of Allahabad University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41213&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_5_content:
  string
  line `On and from the appointed day,--`
  line
  line `(a) any reference to the University of Allahabad in any law (other than this Act) or in any contract`
  line `or other instrument shall be deemed as a reference to the University;`
  line
  line `(b) all properties, movable and immovable, of or belonging to the University of Allahabad shall`
  line `vest in the University;`
  line
  line `(c) all rights and liabilities of the University of Allahabad shall be transferred to, and be the rights`
  line `and liabilities of, the University;`
  line
  line `(d) every person employed by the University of Allahabad immediately before the appointed day`
  line `shall hold his office or service in the University by the same tenure, at the same remuneration and`
  line `upon the same terms and conditions and with the same rights and privileges as to pension, leave,`
  line `gratuity, provident fund and other matters as he would have held the same if this Act had not been`
  line `passed, and shall continue to do so unless and until his employment is terminated or until such tenure,`
  line `remuneration and terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the University in accordance with the term of the contract with the employee or, if`
  line `no provision is made therein in this behalf, on payment to him by the University of compensation`
  line `equivalent to three months' remuneration in case of permanent employees and one month's`
  line `remuneration in the case of other employees:`
  line
  line `Provided further that every person employed before the appointed day, pending the execution of a`
  line `contract under section 34, shall be deemed to have been appointed in accordance with the provisions`
  line `of a contract consistent with the provisions of this Act and the Statutes:`
  line
  line `Provided also that any reference, by whatever form of words, to the Vice-Chancellor and ProVice-Chancellor of the University of Allahabad in any law for the time being in force, or in any`
  line `instrument or other document, shall be construed as a reference respectively to the Vice-Chancellor`
  line `and the Pro-Vice-Chancellor of the University;`
  line
  line `(e) the Vice-Chancellor of the University, appointed under the provisions of the Uttar Pradesh`
  line `State Universities Act, 1973 (President's Act 10 of 1973) shall be deemed to have been appointed as the Vice-Chancellor under this Act, and shall hold office for a period of three months or till such time`
  line `the Vice-Chancellor is appointed, whichever is earlier.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (41214)
  sectionNo (6)
  orderNo 6
  title `Objects of University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41214&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_6_content:
  string
  line `The objects of the University shall be to disseminate and advance`
  line `knowledge by providing instructional and research facilities in such branches of learning as it may deem`
  line `fit; to make provisions for integrated courses in the humanities, the social sciences, the basic and applied`
  line `science and technology in the educational programmes of the University; to take appropriate measures for`
  line `promoting innovations in teaching-learning process, interdisciplinary and professional studies and`
  line `research, removal of gender disparities and the digital divide, and the application of knowledge to social`
  line `advancement, national progress and human welfare; and to educate and train human resource for the`
  line `development of the country.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (41215)
  sectionNo (7)
  orderNo 7
  title `Powers of University.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41215&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_7_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provisions for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing and to withdraw any such diplomas, certificates, degrees or other academic`
  line `distinctions for good and sufficient cause;`
  line
  line `(iii) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(iv) to organise and to undertake open learning programmes, extramural studies, training and`
  line `extension services;`
  line
  line `(v) to institute Chairs, Principalships, Professorships, Readerships and Lecturerships and other`
  line `teaching and academic positions, required by the University and to appoint persons to such Chairs,`
  line `Principalships, Professorships, Readerships and Lecturerships and other teaching and academic`
  line positions;
  line
  line `(vi) to recognise persons as University recognised teachers;`
  line
  line `(vii) to declare persons working in any other University or organisation, as teachers of the`
  line University;
  line
  line `(viii) to appoint, on contract or otherwise, visiting Professors, Emeritus Professors, Consultants,`
  line `Scholars and such other persons who may contribute to the advancement of the objects of the`
  line University;
  line
  line `(ix) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(x) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xi) to establish and maintain University Colleges and University Institutes for imparting`
  line `instruction and conducting research;`
  line
  line `(xii) to admit to its privileges colleges and institutions situated within the territorial jurisdiction of`
  line `the University, as University Colleges, Constituent Institutes and Constituent Colleges, and to`
  line `withdraw all or any of those privileges in accordance with such conditions as may be prescribed by`
  line `the Statutes;`
  line
  line `(xiii) to confer autonomous status on a college or an institution or a Department, as the case may`
  line `be, and to withdraw such status, in accordance with the Statutes;`
  line
  line `(xiv) to co-operate or collaborate or associate with any other University or authority or institution`
  line `of higher learning in such manner as may be prescribed and for such purposes as the University may`
  line determine;
  line
  line `(xv) to determine standards of admission, including examination, evaluation or any other method`
  line `of testing, to the University, and the institutions maintained by or admitted to the privileges of the`
  line University;
  line
  line `(xvi) to demand and receive payment of fees and other charges;`
  line
  line `(xvii) to establish and recognise hostels and supervise the residence of the students of the`
  line `University, make arrangements for promoting their health and general welfare and guide the`
  line `Constituent Colleges and the Constituent Institutes to like ends in respect of the students enrolled`
  line thereat;
  line
  line `(xviii) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xix) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xx) to receive benefactions, donations and gifts and to acquire, hold, manage and dispose of any`
  line `property, movable or immovable, including trust and endowment properties, for the purposes of the`
  line `University:`
  line
  line `Provided that no immovable property shall be disposed off except with the prior approval of the`
  line `Central Government;`
  line
  line `(xxi) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University; and`
  line
  line `(xxii) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of the objects of the University.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (41216)
  sectionNo (8)
  orderNo 8
  title Jurisdiction.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41216&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_8_content:
  string
  line `(1) Save as otherwise provided by this Act, the powers conferred on the University`
  line `shall be exercisable in respect of the area within a radius of sixteen kilometres from the Convocation Hall`
  line `of the University, without prejudice to the territorial jurisdiction over the said area that may be assigned to`
  line `any other University.`
  line
  line `(2) On and from the appointed day, all institutions admitted to the privileges of, or maintained by, the`
  line `University of Allahabad as incorporated under the Uttar Pradesh State Universities Act, 1973 (President's`
  line `Act 10 of 1973) shall stand admitted to the privileges of, or maintained by, the University and shall be`
  line `governed by such conditions as may be prescribed by Statutes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (41217)
  sectionNo (9)
  orderNo 9
  title `University open to all persons irrespective of gender, class or creed.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41217&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_9_content:
  string
  line `The University shall be`
  line `open to all persons of either sex and of whatever caste, creed, race or class and it shall not be lawful for`
  line `the University to adopt or impose on any person, any test whatsoever of religious belief or profession in`
  line `order to entitle him to be appointed as a teacher of the University or to hold any office therein or be`
  line `admitted as a student in the University or to graduate thereat or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for the employment or admission of women, physically handicapped or of persons belonging`
  line `to the weaker sections of the society and, in particular, of the Scheduled Castes and the Scheduled Tribes.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (41218)
  sectionNo (10)
  orderNo 10
  title `The Visitor.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41218&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_10_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University, including the colleges and institutions maintained by it, and to submit a report thereon;`
  line `and upon receipt of such report, the Visitor may, after obtaining the views of the Executive Council`
  line `thereon through the Vice-Chancellor, take such action and issue such directions as he considers necessary`
  line `in respect of any of the matters dealt with in the report and the University shall be bound to comply with`
  line `such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection to be made, by such person or persons as he`
  line `may direct, of the University, its buildings, libraries, laboratories and equipment, and of any college or`
  line `institution maintained by the University or admitted to its privileges; and also of the examinations,`
  line `teaching and other work conducted or done by the University and to cause an inquiry to be made in like`
  line `manner in respect of any matter connected with the administration or finances of the University, and the`
  line `said colleges and institutions.`
  line
  line `(4) The Visitor shall, in every matter referred to in sub-section (3), give notice of his intention to`
  line `cause an inspection or inquiry to be made--`
  line
  line `(a) to the University, if such inspection or inquiry is to be made in respect of the University or`
  line `any college or institution maintained by it, or`
  line
  line `(b) to the Management of the college or institution, if the inspection or inquiry is to be made in`
  line `respect of a college or institution admitted to the privileges of the University, and the University or`
  line `the Management, as the case may be, shall have the right to make such representations to the Visitor,`
  line `as it may consider necessary.`
  line
  line `(5) After considering the representations, if any, made by the University or the Management, as the`
  line `case may be, the Visitor may cause to be made such inspection or inquiry as is referred to in sub-section`
  line `(3).`
  line
  line `(6) Where any inspection or inquiry has been caused to be made by the Visitor, the University or the`
  line `Management shall be entitled to appoint a representative, who shall have the right to be present and be`
  line `heard at such inspection or inquiry.`
  line
  line `(7) The Visitor may, if the inspection or inquiry is made in respect of the University or any college or`
  line `institution maintained by it, address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry together with such views and advice with regard to the action to be taken thereon, as the Visitor`
  line `may be pleased to offer, and on receipt of address made by the Visitor, the Vice-Chancellor shall`
  line `communicate to the Executive Council, the views of the Visitor with such advice as the Visitor may offer`
  line `upon the action to be taken thereon.`
  line
  line `(8) The Visitor may, if the inspection or inquiry is made in respect of any college or institution`
  line `admitted to the privileges of the University, address the Management concerned through the ViceChancellor with reference to the result of such inspection or inquiry, his views thereon and such advice as`
  line `he may be pleased to offer upon the action to be taken thereon.`
  line
  line `(9) The Executive Council or the Management, as the case may be, communicate, through the ViceChancellor to the Visitor such action, if any, as it proposes to take or has been taken upon the result of`
  line `such inspection or inquiry.`
  line
  line `(10) Where, the Executive Council or the Management, as the case may be, does not, within a`
  line `reasonable time, take action to the satisfaction of the Visitor, the Visitor may, after considering any`
  line `explanation furnished or representation made by the Executive Council or the Management, issue such`
  line `directions as he may think fit and the Executive Council or the Management, as the case may be, shall`
  line `comply with such directions.`
  line
  line `(11) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annul any proceeding of the University which is not in conformity with the Act or the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, the Visitor shall call upon the Registrar to show cause`
  line `why such an order should not be made, and, if any cause is shown within a reasonable time, he shall`
  line `consider the same.`
  line
  line `(12) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (41219)
  sectionNo (11)
  orderNo 11
  title `The Chief Rector.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41219&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_11_content:
  string
  line `The Governor of the State of Uttar Pradesh shall be the Chief Rector of the`
  line University.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (41220)
  sectionNo (12)
  orderNo 12
  title `Officers of University.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41220&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_12_content:
  string
  line `The following shall be the officers of the University,--`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Pro-Vice-Chancellor;`
  line
  line `(4) the Deans of Faculties;`
  line
  line `(5) the Registrar;`
  line
  line `(6) the Finance Officer; and`
  line
  line `(7) such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (41221)
  sectionNo (13)
  orderNo 13
  title `The Chancellor.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41221&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_13_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the head of the University and shall, if present,`
  line `preside at the Convocations of the University held for conferring degrees and meetings of the Court.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (41222)
  sectionNo (14)
  orderNo 14
  title `The Vice-Chancellor.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41222&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_14_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner and on such terms and conditions of service as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of the opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority at its next meeting the action taken by him on such matter:`
  line
  line `Provided that such exercise of power shall be made only in emergent situations and in no case in`
  line `respect of creation, and upgradation of posts and appointments thereto:`
  line
  line `Provided further that if the authority concerned is of the opinion that such action ought not to have`
  line `been taken, it may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided also that any person in the service of the University who is aggrieved by the action taken by`
  line `the Vice-Chancellor under this subsection shall have the right to appeal against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated`
  line `to him and thereupon the Executive Council may confirm, modify or reverse the action taken by the ViceChancellor.`
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the University is`
  line `beyond the powers of the authority conferred by the provisions of this Act, the Statutes or the Ordinances`
  line `or that any decision taken is not in the interest of the University, may ask the authority concerned to`
  line `review its decision within sixty days of such decision and if the authority refuses to review the decision`
  line `either in whole or in part or no decision is taken by it within the said period of sixty days, the matter shall`
  line `be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (41223)
  sectionNo (15)
  orderNo 15
  title `The Pro-Vice-Chancellor.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41223&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_15_content:
  string
  line `The Pro-Vice-Chancellor shall be appointed in such manner and on`
  line `such terms and conditions of service, and shall exercise such powers and perform such duties, as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (41224)
  sectionNo (16)
  orderNo 16
  title `The Deans of Faculties.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41224&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_16_content:
  string
  line `Every Dean of Faculty shall be appointed in such manner and shall`
  line `exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (41225)
  sectionNo (17)
  orderNo 17
  title `The Registrar.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41225&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_17_content:
  string
  line `(1) The Registrar shall be appointed in such manner and on such terms and`
  line `conditions of service as may be prescribed by the Statutes.`
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such powers and perform such duties as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (41226)
  sectionNo (18)
  orderNo 18
  title `The Finance Officer.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41226&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_18_content:
  string
  line `The Finance Officer shall be appointed in such manner and on such terms`
  line `and conditions of service, and shall exercise such powers and perform such duties, as may be prescribed`
  line `by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (41227)
  sectionNo (19)
  orderNo 19
  title `Other officers.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41227&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_19_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (41228)
  sectionNo (20)
  orderNo 20
  title `Authorities of University.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41228&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_20_content:
  string
  line `The following shall be the authorities of the University,--`
  line
  line `(1) the Court;`
  line
  line `(2) the Executive Council;`
  line
  line `(3) the Academic Council;`
  line
  line `(4) the Boards of Faculties;`
  line
  line `(5) the Finance Committee; and`
  line
  line `(6) such other authorities as may be declared by the Statutes to be authorities of the University.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (41229)
  sectionNo (21)
  orderNo 21
  title `The Court.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41229&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_21_content:
  string
  line `(1) The constitution of the Court and the term of office of its members shall be`
  line `prescribed by the Statutes.`
  line
  line `(2) Subject to the provisions of this Act, the Court shall have the following powers and functions,`
  line `namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and annual accounts of the University`
  line `and the audit report on such accounts;`
  line
  line `(c) to advise the Visitor in respect of any matter which may be referred to it for advice; and`
  line
  line `(d) to perform such other functions as may be prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (41230)
  sectionNo (22)
  orderNo 22
  title `The Executive Council.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41230&sectionno=22&orderno=22&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_22_content:
  string
  line `(1) The Executive Council shall be the principal executive body of the`
  line University.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (41231)
  sectionNo (23)
  orderNo 23
  title `The Academic Council.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41231&sectionno=23&orderno=23&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_23_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and the Ordinances, co-ordinate`
  line `and exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (41232)
  sectionNo (24)
  orderNo 24
  title `The Finance Committee.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41232&sectionno=24&orderno=24&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_24_content:
  string
  line `The constitution, powers and functions of the Finance Committee`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (41233)
  sectionNo (25)
  orderNo 25
  title `Other authorities.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41233&sectionno=25&orderno=25&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_25_content:
  string
  line `The constitution, powers and functions of the Boards of Faculties and such`
  line `other authorities as may be declared by the Statutes to be authorities of the University shall be prescribed`
  line `by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (41234)
  sectionNo (26)
  orderNo 26
  title `The Faculties and Departments.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41234&sectionno=26&orderno=26&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_26_content:
  string
  line `(1) The University shall have such Faculties as are prescribed`
  line `by the Statutes.`
  line
  line `(2) Each Faculty shall have such Departments as are prescribed by the Statutes, and each Department`
  line `shall have such subjects of study as may be assigned to it by the Ordinances.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (41235)
  sectionNo (27)
  orderNo 27
  title `Power to make Statutes.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41235&sectionno=27&orderno=27&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_27_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all`
  line `or any of the following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of the authorities and other bodies of the University as`
  line `may be constituted from time to time;`
  line
  line `(b) the appointment and continuance in office of the members of the said authorities and bodies,`
  line `the filling up of vacancies of members, and all other matters relating to those authorities and other`
  line `bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments and`
  line `conditions of service;`
  line
  line `(d) the appointment of teachers, academic staff and other employees of the University, their`
  line `emoluments and conditions of service;`
  line
  line `(e) the recognition of persons as University recognised teachers;`
  line
  line `(f) the declaration of persons working in other Universities or other organisations as teachers of`
  line `the University for a specified period;`
  line
  line `(g) the conditions of service of employees of the University including provisions for pension,`
  line `insurance and provident fund, the manner of termination of service and disciplinary action relating to`
  line `such employees;`
  line
  line `(h) the principles governing the seniority of service of the employees of the University;`
  line
  line `(i) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(j) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(k) the conditions under which colleges and institutions may be admitted to the privileges of the`
  line `University and the withdrawal of such privileges;`
  line
  line `(l) the establishment and abolition of Faculties, Departments, University Institutes, Centres and`
  line `University Colleges;`
  line
  line `(m) the conferment of autonomous status on a college or institution or a Department and the`
  line `withdrawal of such status;`
  line
  line `(n) the conferment of honorary degrees;`
  line
  line `(o) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(p) the registration of graduates;`
  line
  line `(q) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(r) the maintenance of discipline among the employees and students; and`
  line
  line `(s) all other matters which by this Act are to be or may be provided for by the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (41236)
  sectionNo (28)
  orderNo 28
  title `Statutes, how to be made.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41236&sectionno=28&orderno=28&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_28_content:
  string
  line `(1) The First Statutes are those set out in the Schedule.`
  line
  line `(2) The Executive Council may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Executive Council shall not make, amend or repeal any Statute affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Executive Council.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require`
  line `the assent of the Visitor who may assent thereto or withhold assent or remit to the Executive Council for`
  line re-consideration.
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may make new or`
  line `additional Statutes, or amend or repeal the Statutes referred to in sub-section (1), during the period of`
  line `three years immediately after the commencement of this Act:`
  line
  line `Provided that the Visitor may, on the expiry of the said period of three years, make, within one year`
  line `from the date of such expiry, such detailed Statutes as he may consider necessary and such detailed`
  line `Statutes shall be laid before both Houses of Parliament.`
  line
  line `(6) Notwithstanding anything contained in this section, the Visitor may direct the University to make`
  line `provisions in the Statutes in respect of any matter specified by him and if the Executive Council is unable`
  line `to implement such direction within sixty days of its receipt, the Visitor may, after considering the reasons,`
  line `if any, communicated by the Executive Council for its inability to comply with such direction, make or`
  line `amend the Statutes suitably.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (41237)
  sectionNo (29)
  orderNo 29
  title `Power to make Ordinances.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41237&sectionno=29&orderno=29&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_29_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission and enrolment of students to the University and institutions maintained by or`
  line `admitted to the privileges of the University;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(f) the institution of, and conditions for award of fellowships, scholarships, studentships, medals`
  line `and prizes;`
  line
  line `(g) the conduct of examinations, including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing of special courses of studies for them;`
  line
  line `(j) the establishment of Centres, University Institutes, Boards of Studies, Specialised Laboratories`
  line `and Committees;`
  line
  line `(k) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(l) the manner of co-operation and collaboration with other Universities, Institutions and other`
  line `Agencies including learned bodies or associations;`
  line
  line `(m) the setting up of a machinery for redressal of grievances of employees; and`
  line
  line `(n) all other matters which by this Act or the Statutes, are to be or may be, provided for by the`
  line Ordinances.
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Central Government and the Ordinances so made may be amended, repealed or added to at any time by`
  line `the Executive Council in the manner prescribed by the Statutes.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (41238)
  sectionNo (30)
  orderNo 30
  title Regulations.
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41238&sectionno=30&orderno=30&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_30_content:
  string
  line `The authorities of the University may make Regulations consistent with this Act,`
  line `the Statutes and the Ordinances for the conduct of their own business and that of the Committees, if any,`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances and for such matters as`
  line `may be prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (41239)
  sectionNo (31)
  orderNo 31
  title `Annual report.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41239&sectionno=31&orderno=31&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_31_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Executive Council, which shall include, among other matters, the steps taken by the University`
  line `towards the fulfilment of its objects and shall be submitted to the Court on or after such date as may be`
  line `prescribed by the Statutes and the Court shall consider the report in its annual meeting.`
  line
  line `(2) The Court shall submit the annual report to the Visitor along with its comments, if any.`
  line
  line `(3) A copy of the annual report, as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (41240)
  sectionNo (32)
  orderNo 32
  title `Accounts and audit.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41240&sectionno=32&orderno=32&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_32_content:
  string
  line `(1) The annual accounts and balance sheet of the University shall be`
  line `prepared under the directions of the Executive Council and shall once at least every year, and at intervals of not more than fifteen months, be audited by the Comptroller and Auditor-General of India or by such`
  line `persons as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts together with the audit report thereon shall be submitted to the`
  line `Court and the Visitor along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Court and the observations of the Court, if any, shall, after being considered by the Executive Council, be`
  line `submitted to the Visitor.`
  line
  line `(4) A copy of the annual accounts together with the audit report as submitted to the Visitor, shall also`
  line `be submitted to the Central Government, which shall, as soon as may be, cause the same to be laid before`
  line `both Houses of Parliament.`
  line
  line `(5) The audited annual accounts after having been laid before both Houses of Parliament shall be`
  line `published in the Gazette of India.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (41241)
  sectionNo (33)
  orderNo 33
  title `Furnishing returns, etc.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41241&sectionno=33&orderno=33&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_33_content:
  string
  line `The University shall furnish to the Central Government such returns`
  line `or other information with respect to its property or activities as the Central Government may, from time to`
  line `time, require.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (41242)
  sectionNo (34)
  orderNo 34
  title `Conditions of service of employees.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41242&sectionno=34&orderno=34&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_34_content:
  string
  line `(1) Every employee of the University shall be appointed`
  line `under a written contract, which shall be lodged with the University and a copy of which shall be furnished`
  line `to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Executive Council, one member nominated by the employee concerned and an umpire appointed by`
  line `the Visitor.`
  line
  line `(3) The decision of the Tribunal shall be final and no suit shall lie in any civil court in respect of the`
  line `matters decided by the Tribunal.`
  line
  line `(4) Every request made by the employee under sub-section (2), shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation Act, 1996`
  line `(26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be prescribed by the Statutes.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (41243)
  sectionNo (35)
  orderNo 35
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41243&sectionno=35&orderno=35&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_35_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the case`
  line `may be, and who has been debarred from appearing at the examinations of the University for more than`
  line `one year, may, within ten days of the date of receipt of such orders or copy of such resolution by him,`
  line `appeal to the Executive Council and the Executive Council may confirm, modify or reverse the decision`
  line `of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-sections`
  line `(2), (3), (4) and (5) of section 34 shall, as far as may be, apply to a reference made under this sub-section.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (41244)
  sectionNo (36)
  orderNo 36
  title `Right to appeal.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41244&sectionno=36&orderno=36&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_36_content:
  string
  line `Every employee or student of the University or of an Institution maintained by`
  line `the University or admitted to its privileges shall, notwithstanding anything contained in this Act, have a`
  line `right to appeal within such time as may be prescribed by the Statutes, to the Executive Council against the`
  line `decision of any officer or authority of the University, and thereupon the Executive Council may confirm,`
  line `modify or reverse the decision appealed against.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (41245)
  sectionNo (37)
  orderNo 37
  title `Provident and pension funds.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41245&sectionno=37&orderno=37&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_37_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such provident fund or pension fund or provide such insurance schemes as it may deem fit in`
  line `such manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or pension fund has been so constituted, the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund as if it`
  line `were a Government provident fund.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (41246)
  sectionNo (38)
  orderNo 38
  title `Disputes as to constitution of University authorities and bodies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41246&sectionno=38&orderno=38&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_38_content:
  string
  line `If any question arises as to`
  line `whether any person has been duly appointed or elected as, or is entitled to be, a member of any authority`
  line `or other body of the University, the matter shall be referred to the Visitor whose decision thereon shall be`
  line final.
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (41247)
  sectionNo (39)
  orderNo 39
  title `Filling of casual vacancies.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41247&sectionno=39&orderno=39&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_39_content:
  string
  line `All casual vacancies among the members, other than ex officio`
  line `members, of any authority or other body of the University shall be filled, as soon as may be, by the person`
  line `or body who appoints, elects or co-opts the member whose place has become vacant and person`
  line `appointed, elected or co-opted to a casual vacancy shall be a member of such authority or body for the`
  line `residue of the term for which the person whose place he fills would have been member.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (41248)
  sectionNo (40)
  orderNo 40
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41248&sectionno=40&orderno=40&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_40_content:
  string
  line `No act or`
  line `proceedings of any authority or other body of the University shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (41249)
  sectionNo (41)
  orderNo 41
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41249&sectionno=41&orderno=41&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_41_content:
  string
  line `No suit or other legal proceeding shall lie against any`
  line `officer or other employee of the University for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (41250)
  sectionNo (42)
  orderNo 42
  title `Mode of proof of University record.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41250&sectionno=42&orderno=42&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_42_content:
  string
  line `Notwithstanding anything contained in the Indian`
  line `Evidence Act, 1872 (1 of 1872) or in any other law for the time being in force, a copy of any receipt,`
  line `application, notice, order, proceeding or resolution of any authority or other body of the University, or`
  line `any other document in possession of the University, or any entry in any register duly maintained by the`
  line `University, if certified by the Registrar, shall be received as prima facie evidence of such receipt,`
  line `application, notice, order, proceeding, resolution or document or the existence of entry in the register and`
  line `shall be admitted as evidence of the matters and transactions therein where the original thereof would, if`
  line `produced, have been admissible in evidence.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (41251)
  sectionNo (43)
  orderNo 43
  title `Power to remove difficulties.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41251&sectionno=43&orderno=43&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_43_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under sub-section (1) shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the order or both Houses agree that the order should not be made, the order shall thereafter have effect`
  line `only in such modified form or be of no effect, as the case may be; so, however, that any such modification`
  line `or annulment shall be without prejudice to the validity of anything previously done under that order.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (41252)
  sectionNo (44)
  orderNo 44
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41252&sectionno=44&orderno=44&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_44_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.`
  line
  line `(3) The power to make Statutes, Ordinances or Regulations shall include the power to give`
  line `retrospective effect, from a date not earlier than the date of commencement of this Act, to the Statute,`
  line `Ordinance or Regulation or any of them but no retrospective effect shall be given to any Statute, Ordinance or Regulation so as to prejudicially affect the interests of any person to whom such Statute,`
  line `Ordinance or Regulation may be applicable.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (41253)
  sectionNo (45)
  orderNo 45
  title `Transitional provisions.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41253&sectionno=45&orderno=45&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_45_content:
  string
  line `(1) Notwithstanding anything contained in this Act and the Statutes,--`
  line
  line `(a) the first Chancellor and the first Vice-Chancellor shall be appointed by the Central`
  line `Government in such manner and on such conditions as may be deemed fit and each of the said`
  line `officers shall hold office for such term, not exceeding five years, as may be specified by the Central`
  line Government;
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Central Government`
  line `and each of the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Court and the first Executive Council shall consist of not more than thirty-one`
  line `members and fifteen members, respectively, who shall be nominated by the Central Government and`
  line `shall hold office for a term of three years;`
  line
  line `(d) the first Academic Council shall consist of not more than thirty-one members, who shall be`
  line `nominated by the Central Government and shall hold office for a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above-mentioned offices or authorities, the same shall be`
  line `filled by appointment or nomination, as the case may be, by the Central Government, and the person so`
  line `appointed or nominated shall hold office for so long as the officer or member in whose place he is`
  line `appointed or nominated would have held office if such vacancy had not occurred.`
  line
  line `(2) Till such time as the first Ordinances are not made under sub-section (2) of section 29, in respect`
  line `of the matters that are to be provided for by the Ordinances under this Act and Statutes, the relevant`
  line `provisions of the Statutes and the Ordinances made immediately before the commencement of this Act`
  line `under the provisions of the Uttar Pradesh State Universities Act, 1973 (President's Act 10 of 1973) shall`
  line `be applicable insofar as they are not inconsistent with the provisions of this Act and the Statutes.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (41254)
  sectionNo (46)
  orderNo 46
  title `Amendment of Presidents Act 10 of 1973.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00023_200526_1517807325721&sectionId=41254&sectionno=46&orderno=46&orgactid=AC_CEN_9_30_00023_200526_1517807325721
obj_root_law_sections_46_content:
  string
  line `(1) In the Uttar Pradesh State Universities Act,`
  line 1973,--
  line
  line `(a) the word "Allahabad", except in clause (b) of sub-section (2) of section 12, sub-section (1) of`
  line `section 31B, clause (b) of sub-section (1) of section 74, clause (j) of sub-section (3) of section 74, and`
  line `entries relating to Serial No. 5 in the Schedule, wherever it occurs, shall be omitted;`
  line
  line `(b) in the Schedule, Serial No. 2 and the entries relating thereto shall be omitted.`
  line
  line `(2) Notwithstanding such omission,--`
  line
  line `(a) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted, or other things done (including the registration`
  line `of graduates) under the Uttar Pradesh State Universities Act, 1973 (President's Act 10 of 1973), shall`
  line `be deemed to have been respectively made, issued, conferred, awarded, granted or done under the`
  line `corresponding provisions of this Act and, except as otherwise provided by or this Act or the Statutes,`
  line `continue in force unless and until they are superseded by any order made under this Act or the`
  line `Statutes; and`
  line
  line `(b) all proceedings of Selection Committees for the appointment or promotion of teachers that`
  line `took place before the commencement of this Act and all actions of the Executive Council in respect of`
  line `the recommendations of such Selection Committees where no orders of appointment on the basis`
  line `thereof were passed before the commencement of this Act shall, notwithstanding that the procedure`
  line `for selection has been modified by this Act, be deemed to have been valid but further proceeding in`
  line `connection with such pending selections shall be taken in accordance with the provisions of this Act`
  line `and be continued from the stage where they stood immediately before such commencement, except if`
  line `the concerned authorities take, with the approval of the Visitor, a decision to the contrary.`
obj_root_law_sections_46_footnotes:
  string
  line
