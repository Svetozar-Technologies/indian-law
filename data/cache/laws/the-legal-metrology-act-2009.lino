  slug the-legal-metrology-act-2009
  handle (2102)
  collectionHandle 123456789/1362
  title `The Legal Metrology Act, 2009`
  actNumber (01)
  enactmentDate 2010-01-13
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2102`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `विधिक मापविज्ञान अधिनियम, 2009`
  actYear (2010)
  ministry `Ministry of Consumer Affairs, Food and Public Distribution`
  department `Department of Consumer Affairs`
  longTitle `An Act to establish and enforce standards of weights and measures, regulate trade and commerce in weights, measures and other goods which are sold or distributed by weight, measure or number and for matters connected therewith or incidental thereto.`
  enforcementDate 01-03-2011
  notification `1st March, 2011, vide notification No. S.O. 1(E), dated 31st December, 2010, see Gazette of India, Extraordinary, Part II, Sec. 3(ii).`
