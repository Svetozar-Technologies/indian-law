  slug the-lokpal-and-lokayuktas-act-2013
  handle (2122)
  collectionHandle 123456789/1362
  title `The Lokpal and Lokayuktas Act, 2013`
  actNumber (01)
  enactmentDate 2014-01-01
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2122`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `लोकपाल और लोकायुक्‍त अधिनियम, 2013.`
  actYear (2014)
  ministry `Ministry of Personnel, Public Grievances and Pensions`
  department `Department of Personnel and Training`
  longTitle `An Act to provide for the establishment of a body of Lokpal for the Union and Lokayukta for States to inquire into allegations of corruption against certain public functionaries and for matters connected therewith or idental thereto.`
