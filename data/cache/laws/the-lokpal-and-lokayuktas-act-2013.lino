obj_root_law_translations_hi_sections_1_content:
  string
  line `लोकपाल और लोकायुक्त अधिधियम, 2013`
  line _________
  line `िाराओं का क्र म`
  line _________
  line िाराएं
  line `भाग 1 प्`
  line ांरधभक
  line `1. संधिप् त िाम, धिस्ता र, लागू होिा और प् ारंभ।`
  line `भाग 2`
  line `संघ के धलए लोकपाल`
  line `अध्या य 1`
  line पररभाषाएं
  line `2. पररभाषाएं।`
  line `अध्या य 2`
  line `लोकपाल की स् था पिा`
  line `3. लोकपाल की स् था पिा।`
  line `4. चयि सधमधत की धसफाररशों पर अध्य ि और सदस्यों की धियुधक्त।`
  line `5. अध्य ि या सदस्यों की ररधक् त यों का भरा जािा।`
  line `6. अध्य ि और सदस्यों की पदािधि।`
  line `7. अध्य ि और सदस्यों का िेति, भत्ते और सेिा की अन्य शतें।`
  line `8. अध्य ि और सदस्यों द्व ारा पद पर ि रहिे के पश्चा त् धियोजि पर धिर्बंिि।`
  line `9. कधतपय पररधस्थ धतयों में सदस्य का अध्य ि के रू प में कायय करिा या उसके कृत्यों का धिियहि करिा।`
  line `10. लोकपाल का सधचि, अन्य अधिकारी तथा कमयचाररिृंद।`
  line `अध्या य 3`
  line `जांच खं ड`
  line `11. जांच खंड।`
  line `अध्या य 4`
  line `अधभयोजि खंड`
  line `1 2. अधभयोजि खंड।`
  line `अध्या य 5`
  line `लोकपाल के व् य यों का भारत की संधचत धिधि पर भाररत होिा`
  line `13. लोकपाल के व् य यों का भारत की संधचत धिधि पर भाररत होिा।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `अध्या य 6`
  line `जांच के सर्बंि में अधिकाररता`
  line `14. प् िािमंत्री, मंधत्रयों, संसद् सदस्यों, केन्री य सरकार के समू ह क, समूह ख, समूह ग और समूह घ अधिकाररयों और`
  line `पदाधिकाररयों का लोकपाल की अधिकाररता के अंतगयत होिा।`
  line `15. ककसी न् या यालय या सधमधत या प् ाधिकारी के समि जांच के धलए लंधर्बत मामलों का प् भाधित ि होिा।`
  line `16. लोकपाल की न् या यपीठों का गठि।`
  line `17. न् या यपीठों के र्ब ीच का यय का धितरण।`
  line `18. अध्य ि की मामले अंतररत करिे की शधक्त।`
  line `19. र्बहु मत द्व ारा धिधिश्च य ककया जािा।`
  line `अध्या य 7 प्`
  line `ारंधभक जांच और अन्िे षण के संर्बंि में प् कक्रया`
  line `20. धशकायतों और प् ारंधभक जांच तथा अन्िे षण से संर्बंधित उपर्बंि।`
  line `21. उि व् य धक् त यों को सुिा जािा धजि पर प् धतकूल प् भाि पड़िे की संभाििा है।`
  line `22. लोकपाल द्व ारा ककसी लोक सेिक या ककसी अन्य व् य धक् त से सूचिा आकद प्स् तु त करिे की अपेिा करिा।`
  line `23. अधभयोजि प् ारंभ करिे के धलए मंजूरी देिे की लोकपाल की शधक्त।`
  line `24. ऐसे लोक सेिक के धिरुद्ध, जो प् िािमंत्री, मंत्री या संसद् सदस्य है, अन्िे षण पर कारयिाई।`
  line `अध्या य 8`
  line `लोकपाल की शधक्त यां`
  line `25. लोकपाल की अिीिण संर्बंिी शधक्त यां।`
  line `26. तलाशी और अधभग्रहण।`
  line `27. कधतपय मामले में लोकपाल को धसधिल न् या यालय की शधक्त यां होिा।`
  line `28. केन्री य या राज्य सरकार के अधिकारर यों की सेिाओं का उपयोग करिे की लोकपाल की शधक्त।`
  line `29. आधस्त यों की अिंधतम कुकी।`
  line `30. आधस्त यों की कुकी की पुधि।`
  line `31. धिशेष पररधस्थ धतयों में भ्र िा चार के साििों द्व ारा उद्भूत या उपाप्त आधस्त यों, आगमों, प् ाधप्त यों और फायदों का`
  line अधिहरण।
  line `32. भ्र िा चार के अधभकथि से संर्बद्ध लोक सेिक के स् था िांतरण या धिलंर्बि की धसफाररश करिे की लोकपाल की शधक्त।`
  line `33. प् ारंधभक जांच के दौराि अधभलेखों के िि ककए जािे को रोकिे के धलए धिदेश देिे की लोकपाल की शधक्त।`
  line `34. प्त् या योजि की शधक्त।`
  line `अध्या य 9`
  line `धिशेष न् या यालय`
  line `35. केन्री य सरकार द्व ारा धिशेष न् या यालयों को गरठत ककया जािा।`
  line `36. कधतपय मामलों में संधिदाकारी राज्य को अिुरोि पत्र।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
