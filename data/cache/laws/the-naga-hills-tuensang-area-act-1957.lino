obj_root_law_sections_1:
  sectionId (47582)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00030_195742_1517807321919&sectionId=47582&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00030_195742_1517807321919
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Naga Hills-Tuensang Area`
  line `Act, 1957.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st December, 1957, vide notification No. S.R.O. 3843, dated 30th November, 1957, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3.`
obj_root_law_sections_2:
  sectionId (47583)
  sectionNo (2)
  orderNo 2
  title `Formation of Naga Hills-Tuensang Area.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00030_195742_1517807321919&sectionId=47583&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00030_195742_1517807321919
obj_root_law_sections_2_content:
  string
  line `As from the commencement of this Act, there shall`
  line `be formed a new administrative unit in the State of Assam by the name of Naga Hills-Tuensang Area`
  line `comprising the tribal areas which at such commencement were known as the Naga Hills District and`
  line `Tuensang Frontier Division of the North East Frontier Agency.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47584)
  sectionNo (3)
  orderNo 3
  title `Amendment of the Sixth Schedule to the Constitution.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00030_195742_1517807321919&sectionId=47584&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00030_195742_1517807321919
obj_root_law_sections_3_content:
  string
  line `In the Sixth Schedule to the`
  line `Constitution, in paragraph 20,—`
  line
  line `(a) after sub-paragraph (2A), the following sub-paragraph shall be inserted, namely:—`
  line
  line `"(2B) The Naga Hills-Tuensang Area shall comprise the areas which at the commencement of`
  line `this Constitution were known as the Naga Hills District and the Naga Tribal Area.";`
  line
  line `(b) in sub-paragraph (3), after the words "Administrative area", the brackets and words "(other`
  line `than the Naga Hills-Tuensang Area)" shall be inserted;`
  line
  line `(c) in Part A of the Table, item 4 shall be omitted; and`
  line
  line `(d) in Part B of the Table, for item 2, the following item shall be substituted, namely:—`
  line
  line `"2. The Naga Hills-Tuensang Area.".`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47585)
  sectionNo (4)
  orderNo 4
  title `Amendment of the Delimitation Order.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00030_195742_1517807321919&sectionId=47585&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00030_195742_1517807321919
obj_root_law_sections_4_content:
  string
  line `In the Delimitation of Parliamentary and Assembly`
  line `Constituencies Order, 1956,—`
  line
  line `(a) in the First Schedule, in the entry in column 3 against serial No. 37, the words "Naga Hills",`
  line `shall be omitted; and`
  line
  line `(b) in the Second Schedule, in the Part relating to Assam, the heading "Naga Hills District" and`
  line `all entries against serial Nos. 16, 17 and 18 shall be omitted.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47586)
  sectionNo (5)
  orderNo 5
  title [Repealed.].
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00030_195742_1517807321919&sectionId=47586&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00030_195742_1517807321919
obj_root_law_sections_5_content:
  string
  line `[Amendment of the Representation of the People Act, 1950.] Rep. by the Repealing and Amending`
  line `Act, 1960 (58 of 1960), s. 2 and the First Schedule (w.e.f. 26-12-1960).`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47587)
  sectionNo (6)
  orderNo 6
  title `Provision as to the sitting member of Parliament.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00030_195742_1517807321919&sectionId=47587&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00030_195742_1517807321919
obj_root_law_sections_6_content:
  string
  line `Notwithstanding the alteration in the extent`
  line `of the Autonomous Districts Parliamentary constituency in Assam effected by section 4, the sitting`
  line `member of the House of the People representing that constituency shall be deemed to have been elected to`
  line `the House of the People by that constituency as so altered.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47588)
  sectionNo (7)
  orderNo 7
  title `Territorial extent of laws not to be affected.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00030_195742_1517807321919&sectionId=47588&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00030_195742_1517807321919
obj_root_law_sections_7_content:
  string
  line `The provisions of section 2 shall not be deemed to`
  line `have effected any change in the areas to which any law in force immediately before the commencement`
  line `of this Act extends or applies, and territorial references in any such law to the Naga Hills District, the`
  line `Naga Tribal Area or the Tuensang Frontier Division shall, until otherwise provided by a competent`
  line `legislature or other competent authority, continue to have the same meaning.`
  line
  line `Explanation.—In this section, law means any law, ordinance, regulation, order, bye-law, rule, scheme,`
  line `notification or other instrument having the force of law in India or any part thereof.`
obj_root_law_sections_7_footnotes:
  string
  line
