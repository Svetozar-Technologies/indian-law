obj_root_law_sections_1:
  sectionId (47394)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and application.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47394&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the SAARC Convention`
  line `(Suppression of Terrorism) Act, 1993.`
  line
  line `(2) It extends to the whole of India and, subject to the provisions of section 6, it applies also to any`
  line `offence under this Act committed outside India by any person.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (47395)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47395&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Convention" means the South Asian Association for Regional Cooperation Convention on`
  line `Suppression of Terrorism signed at Kathmandu on the 4th day of November, 1987 as set out in the`
  line Schedule;
  line
  line `(b) "Convention country" means a country in which the Convention is for the time being in force.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47396)
  sectionNo (3)
  orderNo 3
  title `Application of the Convention.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47396&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_3_content:
  string
  line `Notwithstanding anything to the contrary contained in any other`
  line `law, the provisions of Articles I to VIII of the Convention shall have the force of law in India.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47397)
  sectionNo (4)
  orderNo 4
  title Hostage-taking.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47397&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_4_content:
  string
  line `(1) Whoever, by force or threat of force or by any other form of intimation,`
  line `seizes or detains any person and threatens to kill or injure that person with intent to cause a Convention`
  line `country to do or abstain from doing any act as the means of avoiding the execution of such threat,`
  line `commits the offence of hostage-taking.`
  line
  line `(2) Whoever commits the offence of hostage-taking shall be punished with imprisonment for a term`
  line `which may extend to ten years, and shall also be liable to fine.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47398)
  sectionNo (5)
  orderNo 5
  title `Provisions as to Extradition Act.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47398&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_5_content:
  string
  line `For the purposes of the Extradition Act, 1962 (34 of 1962), in`
  line `relation to a Convention country, an offence under sub-section (1) of section 4 or any other offence`
  line `specified in Article I of the Convention, shall not be considered to be an offence of a political character.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47399)
  sectionNo (6)
  orderNo 6
  title `Offences committed outside India.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47399&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_6_content:
  string
  line `(1) When an offence under sub-section (1) of section 4 or`
  line `any other offence specified in Article I of the Convention is committed outside India,--`
  line
  line `(a) by a citizen of India, whether on the high seas or elsewhere;`
  line
  line `(b) by a person, not being such citizen, on any ship or aircraft, registered in India; or`
  line
  line `(c) by a person, not being such citizen, in a Convention country,`
  line `he may be dealt with in respect of such offence as if it had been committed at any place within India at`
  line `which he may be found.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Central Government may, by general`
  line `or special order published in the Official Gazette, direct that the offence under sub-section (1) of section 4`
  line `or any other offence specified in Article I of the Convention may be inquired into or tried at any place`
  line `within India.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47400)
  sectionNo (7)
  orderNo 7
  title `Previous sanction necessary for prosecution.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47400&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_7_content:
  string
  line `No prosecution for an offence under this Act`
  line `shall be instituted except with the previous sanction of the Central Government and the sanction granted under this section shall be deemed to be a sanction granted under section 188 of the Code of Criminal`
  line `Procedure, 1973 ( 2 of 1974).`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47401)
  sectionNo (8)
  orderNo 8
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00012_199336_1517807323030&sectionId=47401&sectionno=8&orderno=8&orgactid=AC_CEN_10_10_00012_199336_1517807323030
obj_root_law_sections_8_content:
  string
  line `(1) No suit, prosecution or other legal proceeding`
  line `shall lie against any person for anything which is in good faith done or intended to be done in pursuance`
  line `of the provisions of this Act.`
  line
  line `(2) No suit or other legal proceeding shall lie against the Central Government for any damage caused`
  line `or likely to be caused for anything which is in good faith done or intended to be done in pursuance of the`
  line `provisions of this Act.`
obj_root_law_sections_8_footnotes:
  string
  line
