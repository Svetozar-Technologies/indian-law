obj_root_law:
  slug the-hind-cycles-limited-and-sen-raleigh-limited-nationalisation-act-1980
  handle (1769)
  collectionHandle 123456789/1362
  title `The Hind Cycles Limited and Sen-Raleigh Limited (Nationalisation) Act, 1980`
  actNumber (70)
  enactmentDate 1980-12-27
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1769`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `हिंद साइकिल्स लिमिटेड और सेन रेले लिमिटेड (राष्‍ट्रीयकरण) अधिनियम, 1980`
  actYear (1980)
  ministry `Ministry of Heavy Industries and Public Enterprises`
  department `Department of Heavy Industry`
  longTitle `An Act to provide for the acquisition of the undertakings of the Hind Cycles Limited, and Sen-Raleigh Limited, with a view to securing the proper management of such undertakings so as to subserve the interests of the general public by ensuring the continued manufacture, production and distribution of bicycles, and their component parts and accessories which are essential to the needs of the economy of the country and for matters connected therewith or incidental thereto.`
  enforcementDate 15-10-1980
  fetchedAt `2026-05-08T22:34:22.844Z`
  translations obj_root_law_translations
