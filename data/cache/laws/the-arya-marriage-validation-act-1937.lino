obj_root_law_sections_1:
  object
  (str sectionId) (str 29791)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and extent.`)
  (str content) (str `(1) This Act may be called the Arya Marriage Validation Act, 1937.

^1[(2) It extends to the whole of India except ^2[the territories which, immediately before the
1st November, 1956, were comprised in Part B States] and applies also to citizens of India wherever they
may be.]`)
  (str footnotes) (str `1. Subs. by the A.O. 1950, for sub-section (2).

2. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Part B States".`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00061_193719_1523351569548&sectionId=29791&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00061_193719_1523351569548)
obj_root_law_sections_2:
  object
  (str sectionId) (str 29792)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Marriage between Arya Samajists not to be invalid.`)
  (str content) (str `Notwithstanding any provision of Hindu
Law, usage or custom to the contrary no marriage contracted whether before or after the commencement
of this Act between two persons being at the time of the marriage Arya Samajists shall be invalid or shall
be deemed over to have been invalid by reason only of the fact that the parties at any time belonged to
different castes or different sub-castes of Hindus or that either or both of the parties at any time before the
marriage belonged to a religion other than Hinduism.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00061_193719_1523351569548&sectionId=29792&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00061_193719_1523351569548)
