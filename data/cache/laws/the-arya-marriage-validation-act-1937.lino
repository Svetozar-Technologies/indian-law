  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00061_193719_1523351569548&sectionId=29791&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00061_193719_1523351569548
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Arya Marriage Validation Act, 1937.`
  line
  line `^1[(2) It extends to the whole of India except ^2[the territories which, immediately before the`
  line `1st November, 1956, were comprised in Part B States] and applies also to citizens of India wherever they`
  line `may be.]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for sub-section (2).`
  line
  line `2. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Part B States".`
obj_root_law_sections_2:
  sectionId (29792)
  sectionNo (2)
  orderNo 2
  title `Marriage between Arya Samajists not to be invalid.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00061_193719_1523351569548&sectionId=29792&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00061_193719_1523351569548
obj_root_law_sections_2_content:
  string
  line `Notwithstanding any provision of Hindu`
  line `Law, usage or custom to the contrary no marriage contracted whether before or after the commencement`
  line `of this Act between two persons being at the time of the marriage Arya Samajists shall be invalid or shall`
  line `be deemed over to have been invalid by reason only of the fact that the parties at any time belonged to`
  line `different castes or different sub-castes of Hindus or that either or both of the parties at any time before the`
  line `marriage belonged to a religion other than Hinduism.`
obj_root_law_sections_2_footnotes:
  string
  line
