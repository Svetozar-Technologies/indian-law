  (str url) (str `https://www.indiacode.nic.in/bitstream/123456789/1887/2/h198846.pdf`)
  (str title) (str `स्वापक ओषधि और मन:प्रभावी पदार्थ अवैध व्‍यापार निवारण अधिनियम,1988`)
