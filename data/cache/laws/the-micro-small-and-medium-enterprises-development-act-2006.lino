obj_root_law_sections_1:
  sectionId (9883)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9883&sectionno=1&orderno=1&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Micro, Small and Medium`
  line `Enterprises Development Act, 2006.`
  line
  line `(2) It shall come into force on such date^1 as the Central Government may, by notification, appoint;`
  line
  line `and different dates may be appointed for different provisions of this Act and any reference in any such`
  line `provision to the commencement of this Act shall be construed as a reference to the coming into force of`
  line `that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1 2nd October, 2006, vide notification No. S.O. 1154(E) dated 18th July, 2006, see Gazette of India, Extraordinary Part II`
  line `sec.3(ii).`
obj_root_law_sections_2:
  sectionId (9884)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9884&sectionno=2&orderno=2&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Advisory Committee" means the committee constituted by the Central Government under`
  line `sub-section (2) of section 7;`
  line
  line `(b) "appointed day' means the day following immediately after the expiry of the period of fifteen`
  line `days from the day of acceptance or the day of deemed acceptance of any goods or any services by a`
  line `buyer from a supplier.`
  line
  line `Explanation.--For the purposes of this clause,--`
  line
  line `(i) "the day of acceptance" means,--`
  line
  line `(a) the day of the actual delivery of goods or the rendering of services; or`
  line
  line `(b) where any objection is made in writing by the buyer regarding acceptance of goods or`
  line `services within fifteen days from the day of the delivery of goods or the rendering of services,`
  line `the day on which such objection is removed by the supplier;`
  line
  line `(ii) "the day of deemed acceptance" means, where no objection is made in writing by the`
  line `buyer regarding acceptance of goods or services within fifteen days from the day of the delivery`
  line `of goods or the rendering of services, the day of the actual delivery of goods or the rendering of`
  line services;
  line
  line `(c) "Board" means the National Board for Micro, Small and Medium Enterprises established`
  line `under section 3;`
  line
  line `(d) "buyer" means whoever buys any goods or receives any services from a supplier for`
  line consideration;
  line
  line `(e) "enterprise" means an industrial undertaking or a business concern or any other establishment,`
  line `by whatever name called, engaged in the manufacture or production of goods, in any manner,`
  line `pertaining to any industry specified in the First Schedule to the Industries (Development and`
  line `Regulation) Act, 1951 (55 of 1951) or engaged in providing or rendering of any service or services;`
  line
  line `(f) "goods" means every kind of movable property other than actionable claims and money;`
  line
  line `(g) "medium enterprise" means an enterprise classified as such under sub-clause (iii) of clause (a)`
  line `or sub-clause (iii) of clause (b) of sub-section (1) of section 7;`
  line
  line `(h) "micro enterprise' means an enterprise classified as such under sub-clause (i) of clause (a) or`
  line `sub-clause (i) of clause (b) of sub-section (1) of section 7;`
  line
  line `(i) "National Bank" means the National Bank for Agriculture and Rural Development established`
  line `under section 3 of the National Bank for Agriculture and Rural Development Act, 1981 (51 of 1981);`
  line
  line `(j) "notification" means a notification published in the Official Gazette;`
  line
  line `(k) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(l) "Reserve Bank" means the Reserve Bank of India constituted under section 3 of the Reserve`
  line `Bank of India Act, 1934 (2 of 1934);`
  line
  line `(m) "small enterprise" means an enterprise classified as such under sub-clause (ii) of clause (a) or`
  line `sub-clause (ii) of clause (b) of sub-section (1) of section 7;`
  line
  line `(n) "supplier" means a micro or small enterprise, which has filed a memorandum with the`
  line `authority referred to in sub-section (1) of section 8, and includes,--`
  line
  line `(i) the National Small Industries Corporation, being a company, registered under the`
  line `Companies Act, 1956 (1 of 1956);`
  line
  line `(ii) the Small Industries Development Corporation of a State or a Union territory, by`
  line `whatever name called, being a company registered under the Companies Act, 1956 (1 of 1956);`
  line
  line `(iii) any company, co-operative society, trust or a body, by whatever name called, registered`
  line `or constituted under any law for the time being in force and engaged in selling goods produced by`
  line `micro or small enterprises and rendering services which are provided by such enterprises;`
  line
  line `(o) "Small Industries Bank" means the Small Industries Development Bank of India established`
  line `under sub-section (1) of section 3 of the Small Industries Development Bank of India Act, 1989 (39`
  line `of 1989);`
  line
  line `(p) "State Government", in relation to a Union territory, means the Administrator thereof`
  line `appointed under article 239 of the Constitution.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (9885)
  sectionNo (3)
  orderNo 3
  title `Establishment of Board.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9885&sectionno=3&orderno=3&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_3_content:
  string
  line `(1) With effect from such date as the Central Government may, by`
  line `notification, appoint, there shall be established, for the purposes of this Act, a Board to be known as the`
  line `National Board for Micro, Small and Medium Enterprises.`
  line
  line `(2) The head office of the Board shall be at Delhi.`
  line
  line `(3) The Board shall consist of the following members, namely:--`
  line
  line `(a) the Minister in charge of the Ministry or Department of the Central Government having`
  line `administrative control of the micro, small and medium enterprises who shall be the ex officio`
  line `Chairperson of the Board;`
  line
  line `(b) the Minister of State or a Deputy Minister, if any, in the Ministry or Department of the Central`
  line `Government having administrative control of the micro, small and medium enterprises who shall be`
  line `ex officio Vice-Chairperson of the Board, and where there is no such Minister of State or Deputy Minister, such person as may be appointed by the Central Government to be the Vice-Chairperson of`
  line `the Board;`
  line
  line `(c) six Ministers of the State Governments having administrative control of the departments of`
  line `small scale industries or, as the case may be, micro, small and medium enterprises, to be appointed by`
  line `the Central Government to represent such regions of the country as may be notified by the Central`
  line `Government in this behalf, ex officio;`
  line
  line `(d) three Members of Parliament of whom two shall be elected by the House of the People and`
  line `one by the Council of States;`
  line
  line `(e) the Administrator of a Union territory to be appointed by the Central Government, ex officio;`
  line
  line `(f) the Secretary to the Government of India in charge of the Ministry or Department of the`
  line `Central Government having administrative control of the micro, small and medium enterprises, ex`
  line officio;
  line
  line `(g) four Secretaries to the Government of India, to represent the Ministries of the Central`
  line `Government dealing with commerce and industry, finance, food processing industries, labour and`
  line `planning to be appointed by the Central Government, ex officio;`
  line
  line `(h) the Chairman of the Board of Directors of the National Bank, ex officio;`
  line
  line `(i) the chairman and managing director of the Board of Directors of the Small Industries Bank, ex`
  line officio;
  line
  line `(j) the chairman, Indian Banks Association, ex officio;`
  line
  line `(k) one officer of the Reserve Bank, not below the rank of an Executive Director,to be appointed`
  line `by the Central Government to represent the Reserve Bank;`
  line
  line `(l) twenty persons to represent the associations of micro, small and midium enterprises, including`
  line `not less than three persons representing associations of women's enterprises and not less than three`
  line `persons representing associations of micro enterprises, to be appointed by the Central Government;`
  line
  line `(m) three persons of eminence, one each from the fileds of economics, industry and science and`
  line `technology, not less than one of whom shall be a woman, to be appointed by the Central Government;`
  line
  line `(n) two representatives of Central Trade Union Organisations, to be appointed by the Central`
  line `Government; and`
  line
  line `(o) one officer not below the rank of Joint Secretary to the Government of India in the Ministry or`
  line `Department of the Central Government having administrative control of the micro, small and medium`
  line `enterprises to be appointed by the Central Government, who shall be the Member-Secretary of the`
  line `Board, ex officio.`
  line
  line `(4) The term of office of the members of the Board, other than ex officio members of the Board, the`
  line `manner of filling vacancies, and the procedure to be followed in the discharge of their functions by the`
  line `members of the Board, shall be such as may be prescribed:`
  line
  line `Provided that the term of office of an ex officio member of the Board shall continue so long as he`
  line `holds the office by virtue of which he is such a member.`
  line
  line `(5) No act or proceedings of the Board shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Board; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Board; or`
  line
  line `(c) any irregularity in the procedure of the Board not affecting the merits of the case.`
  line
  line `(6) The Board shall meet at least once in every three months in a year.`
  line
  line `(7) The Board may associate with itself, in such manner and for such purposes as it may deem`
  line `necessary, any person or persons whose assistance or advice it may desire in complying with any of the provisions of this Act and a person so associated shall have the right to take part in the discussions of the`
  line `Board relevant to the purposes for which he has been associated but shall not have the right to vote.`
  line
  line `(8) Without prejudice to sub-section (7)the Chairperson of the Board shall, for not less than two of the`
  line `meetings of the Board in a year, invite such Ministers of the State Governments having administrative`
  line `control of the departments of small scale industries or, as the case may be, the micro, small and medium`
  line `enterprises, or the Administrators of Union territories and representatives of such other associations of`
  line `micro, small and medium enterprises, as he may deem necessary for carrying out the purposes of this Act.`
  line
  line `(9) It is hereby delcared that the office of member of the Board shall not disqualify its holder for`
  line `being chosen as, or for being, a member of either House of Parliament.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (9886)
  sectionNo (4)
  orderNo 4
  title `Removal of member from Board.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9886&sectionno=4&orderno=4&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_4_content:
  string
  line `(1) The Central Government may remove a member of the`
  line `Board from it, if he--`
  line
  line `(a) is, or at any time has been, adjudged as insolvent; or`
  line
  line `(b) is, or becomes, of unsound mind and stands so declared by a competent court; or`
  line
  line `(c) refuses to act or becomes incapable of acting as a member of the Board; or`
  line
  line `(d) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(e) has so abused, in the opinion of the Central Government, his position as a member of the`
  line `Board as to render his continuance in the Board detrimental to the interests of the general public.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no member shall be removed from his`
  line `office on the grounds specified in clauses (c) to (e) of that sub-section unless he has been given a`
  line `reasonable opportunity of being heard in the matter.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (9887)
  sectionNo (5)
  orderNo 5
  title `Functions of Board.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9887&sectionno=5&orderno=5&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_5_content:
  string
  line `The Board shall, subject to the general directions of the Central`
  line `Government, perform all or any of the following functions, namely:--`
  line
  line `(a) examine the factors affecting the promotion and development of micro, small and medium`
  line `enterprises and review the policies and programmes of the Central Government in regard to`
  line `facilitating the promotion and development and enhancing the competitiveness of such enterprises`
  line `and the impact thereof on such enterprises;`
  line
  line `(b) make recommendations on matters referred to in clause (a) or on any other matter referred to`
  line `it by the Central Government which, in the opinion of that Government, is necessary or expedient for`
  line `facilitating the promotion and development and enhancing the competitiveness of the micro, small`
  line `and medium enterprises; and`
  line
  line `(c) advise the Central Government on the use of the Fund or Funds constituted under section 12.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (9888)
  sectionNo (6)
  orderNo 6
  title `Powers and functions of Member-Secretary of Board.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9888&sectionno=6&orderno=6&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_6_content:
  string
  line `Subject to other provisions of this Act,`
  line `the Member-Secretary of the Board shall exercise such powers and perform such functions as may be`
  line prescribed.
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (9889)
  sectionNo (7)
  orderNo 7
  title `Classification of enterprises.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9889&sectionno=7&orderno=7&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_7_content:
  string
  line `(1) Notwithstanding anything contained in section 11B of the`
  line `Industries (Development and Regulation) Act, 1951 (65 of 1951),the Central Government may, for the`
  line `purposes of this Act, by notification and having regard to the provisions of sub-sections (4) and (5),`
  line `classify any class or classes of enterprises, whether proprietorship, Hindu undivided family, association of`
  line `persons, co-operative society, partnership firm, company or undertaking, by whatever name called,--`
  line
  line `(a) in the case of the enterprises engaged in the manufacture or production of goods pertaining to`
  line `any industry specified in the First Schedule to the Industries (Development and Regulation) Act, 1951`
  line `(65 of 1951),as--`
  line
  line `(i) a micro enterprise, where the investment in plant and machinery does not exceed twentyfive`
  line `lakh rupees;`
  line
  line `(ii) a small enterprise, where the investment in plant and machinery is more than twenty-five`
  line `lakh rupees but does not exceed five crore rupees; or`
  line
  line `(iii) a medium enterprise, where the investment in plant and machinery is more than five`
  line `crore rupees but does not exceed ten crore rupees;`
  line
  line `(b) in the case of the enterprises engaged in providing or rendering of services, as--`
  line
  line `(i) a micro enterprise, where the investment in equipment does not exceed ten lakh rupees;`
  line
  line `(ii) a small enterprise, where the investment in equipment is more than ten lakh rupees but`
  line `does not exceed two crore rupees; or`
  line
  line `(iii) a medium enterprise, where the investment in equipment is more than two crore rupees`
  line `but does not exceed five crore rupees.`
  line
  line `Explanation 1.--For the removal of doubts, it is hereby clarified that in calculating the investment in`
  line `plant and machinery, the cost of pollution control, research and development, industrial safety devices`
  line `and such other items as may be specified, by notification, shall be excluded.`
  line
  line `Explanation 2.--It is clarified that the provisions of section 29B of the Industries (Development and`
  line `Regulation) Act, 1951 (65 of 1951), shall be applicable to the enterprises specified in sub-clauses (i) and`
  line `(ii) of clause (a) of sub-section (1) of this section.`
  line
  line `(2) The Central Government shall, by notification, constitute an Advisory Committee consisting of`
  line `the following members, namely:--`
  line
  line `(a) the Secretary to the Government of India in the Ministry or Department of the Central`
  line `Government having administrative control of the small and medium enterprises who shall be the`
  line `Chairperson, ex officio;`
  line
  line `(b) not more than five officers of the Central Government possessing necessary expertise in`
  line `matters relating to micro, small and medium enterprises, members, ex officio;`
  line
  line `(c) not more than three representatives of the State Governments, members, ex officio; and`
  line
  line `(d) one representative each of the associations of micro, small and medium enterprises, members,`
  line `ex officio.`
  line
  line `(3) The Member-Secretary of the Board shall also be the ex officio Member-Secretary of the Advisory`
  line Committee.
  line
  line `(4) The Central Government shall, prior to classifying any class or classes of enterprises under`
  line `sub-section (1), obtain the recommendations of the Advisory Committee.`
  line
  line `(5) The Advisory Committee shall examine the matters referred to it by the Board in connection with`
  line `any subject referred to in section 5 and furnish its recommendations to the Board.`
  line
  line `(6) The Central Government may seek the advice of the Advisory Committee on any of the matters`
  line `specified in section 9, 10, 11, 12 or 14 of Chapter IV.`
  line
  line `(7) The State Government may seek advice of the Advisory Committee on any of the matters`
  line `specified in the rules made under section 30.`
  line
  line `(8) The Advisory Committee shall, after considering the following matters, communicate its`
  line `recommendations or advice to the Central Government or, as the case may be, State Government or the`
  line `Board, namely:--`
  line
  line `(a) the level of employment in a class or classes of enterprises;`
  line
  line `(b) the level of investments in plant and machinery or equipment in a class or classes of`
  line enterprises;
  line
  line `(c) the need of higher investment in plant and machinery or equipment for technological`
  line `upgradation, employment generation and enhanced competitiveness of the class or classes of`
  line enterprises;
  line
  line `(d) the possibility of promoting and diffusing entrepreneurship inmicro, small or medium`
  line `enterprises; and`
  line
  line `(e) the international standards for classification of small and medium enterprises.`
  line
  line `(9) Notwithstanding anything contained in section 11B of the Industries (Development and`
  line `Regulation) Act, 1951 (65 of 1951) and clause (h) of section 2 of the Khadi and Village Industries`
  line `Commission Act, 1956 (61 of 1956),the Central Government may, while classifying any class or classes`
  line `of enterprises under sub-section (1), vary, from time to time, the criterion of investment and also consider`
  line `criteria or standards in respect of employment or turnover of the enterprises and include in such`
  line `classification the micro or tiny enterprises or the village enterprises, as part of small enterprises.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (9890)
  sectionNo (8)
  orderNo 8
  title `Memorandum of micro, small and medium enterprises.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9890&sectionno=8&orderno=8&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_8_content:
  string
  line `(1) Any person who intends to`
  line establish,--
  line
  line `(a) a micro or small enterprise, may, at his discretion; or`
  line
  line `(b) a medium enterprise engaged in providing or rendering of services may, at his discretion; or`
  line
  line `(c) a medium enterprise engaged in the manufacture or production of goods pertaining to any`
  line `industry specified in the First Schedule to the Industries (Development and Regulation) Act, 1951 (65`
  line `of 1951),`
  line
  line `shall file the memorandum of micro, small or, as the case may be, of medium enterprise with such`
  line `authority as may be specified by the State Government under sub-section (4) or the Central Government`
  line `under sub-section (3):`
  line
  line `Provided that any person who, before the commencement of this Act, established--`
  line
  line `(a) a small scale industry and obtained a registration certificate, may, at his discretion; and`
  line
  line `(b) an industry engaged in the manufacture or production of goods pertaining to any industry`
  line `specified in the First Schedule to the Industries (Development and Regulation) Act, 1951 (65 of`
  line `1951),having investment in plant and machinery of more than one crore rupees but not exceeding ten`
  line `crore rupees and, in pursuance of the notification of the Government of India in the erstwhile Ministry`
  line `of Industry (Department of Industrial Development) number S.O. 477(E), dated the 25th July, 1991`
  line `filed an Industrial Entrepreneur's Memorandum,`
  line
  line `shall within one hundred and eighty days from the commencement of this Act, file the memorandum, in`
  line `accordance with the provisions of this Act.`
  line
  line `(2) The form of the memorandum, the procedure of its filing and other matters incidental thereto shall`
  line `be such as may be notified by the Central Government after obtaining the recommendations of the`
  line `Advisory Committee in this behalf.`
  line
  line `(3) The authority with which the memorandum shall be filed by a medium enterprise shall be such as`
  line `may be specified, by notification, by the Central Government.`
  line
  line `(4) The State Government shall, by notification, specify the authority with which a micro or small`
  line `enterprise may file the memorandum.`
  line
  line `(5) The authorities specified under sub-sections (3) and (4) shall follow, for the purposes of this`
  line `section, the procedure notified by the Central Government under sub-section (2).`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (9891)
  sectionNo (9)
  orderNo 9
  title `Measures for promotion and development.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9891&sectionno=9&orderno=9&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_9_content:
  string
  line `The Central Government may, from time to time,`
  line `for the purposes of facilitating the promotion and development and enhancing the competitiveness of`
  line `micro, small and medium enterprises, particularly of the micro and small enterprises, by way of`
  line `development of skill in the employees, management and entrepreneurs, provisioning for technological`
  line `upgradation,marketing assistance or infrastructure facilities and cluster development of such enterprises`
  line `with a view to strengthening backward and forward linkages, specify, by notification, such programmes,`
  line `guidelines or instructions, as it may deem fit.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (9892)
  sectionNo (10)
  orderNo 10
  title `Credit facilities.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9892&sectionno=10&orderno=10&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_10_content:
  string
  line `The policies and practices in respect of credit to the micro, small and medium`
  line `enterprises shall be progressive and such as may be specified in the guidelines or instructions issued by`
  line `the Reserve Bank, from time to time, to ensure timely and smooth flow of credit tosuch enterprises,`
  line `minimise the incidence of sickness among and enhance the competitiveness of such enterprises.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (9893)
  sectionNo (11)
  orderNo 11
  title `Procurement preference policy.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9893&sectionno=11&orderno=11&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_11_content:
  string
  line `For facilitating promotion and development of micro and`
  line `small enterprises, the Central Government or the State Government may, by order notify from time to`
  line `time, preference policies in respect of procurement of goods and services, produced and provided by`
  line `micro and small enterprises, by its Ministries or departments, as the case may be, or its aided institutions`
  line `and public sector enterprises.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (9894)
  sectionNo (12)
  orderNo 12
  title Funds.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9894&sectionno=12&orderno=12&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_12_content:
  string
  line `There shall be constituted, by notification, one or more Funds to be called by such name`
  line `as may be specified in the notification and there shall be credited thereto any grants made by the Central`
  line `Government under section 13.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (9895)
  sectionNo (13)
  orderNo 13
  title `Grants by Central Government.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9895&sectionno=13&orderno=13&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_13_content:
  string
  line `The Central Government may, after due appropriation made`
  line `by Parliament by law in this behalf, credit to the Fund or Funds by way of grants for the purposes of this`
  line `Act, such sums of money as that Government may consider necessary to provide.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (9896)
  sectionNo (14)
  orderNo 14
  title `Administration and utilisation of Fund or Funds.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9896&sectionno=14&orderno=14&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_14_content:
  string
  line `(1) The Central Government shall have the`
  line `power to administer the Fund or Funds in such manner as may be prescribed.`
  line
  line `(2) The Fund or Funds shall be utilised exclusively for the measures specified in sub-section (1) of`
  line `section 9.`
  line
  line `(3) The Central Government shall be responsible for the coordination and ensuring timely utilisation`
  line `and release of sums in accordance with such criteria as may be prescribed.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (9897)
  sectionNo (15)
  orderNo 15
  title `Liability of buyer to make payment.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9897&sectionno=15&orderno=15&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_15_content:
  string
  line `Where any supplier supplies any goods or renders any`
  line `services to any buyer, the buyer shall make payment therefor on or before the date agreed upon between`
  line `him and the supplier in writing or, where there is no agreement in this behalf, before the appointed day:`
  line
  line `Provided that in no case the period agreed upon between the supplier and the buyer in writing shall`
  line `exceed forty-five days from the day of acceptance or the day of deemed acceptance.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (9898)
  sectionNo (16)
  orderNo 16
  title `Date from which and rate at which interest is payable.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9898&sectionno=16&orderno=16&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_16_content:
  string
  line `Where any buyer fails to make`
  line `payment of the amount to the supplier, as required under section 15, the buyer shall, notwithstanding`
  line `anything contained in any agreement between the buyer and the supplier or in any law for the time being`
  line `in force, be liable to pay compound interest with monthly rests to the supplier on that amount from the`
  line `appointed day or, as the case may be, from the date immediately following the date agreed upon, at three`
  line `times of the bank rate notified by the Reserve Bank.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (9899)
  sectionNo (17)
  orderNo 17
  title `Recovery of amount due.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9899&sectionno=17&orderno=17&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_17_content:
  string
  line `For any goods supplied or services rendered by the supplier, the`
  line `buyer shall be liable to pay the amount with interest thereon as provided under section 16.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (9900)
  sectionNo (18)
  orderNo 18
  title `Reference to Micro and small Enterprises Facilitation Council.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9900&sectionno=18&orderno=18&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_18_content:
  string
  line `(1) Notwithstanding anything`
  line `contained in any other law for the time being in force, any party to a dispute may, with regard to any`
  line `amount due under section 17, make a reference to the Micro and Small Enterprises Facilitation Council.`
  line
  line `(2) On receipt of a reference under sub-section (1), the Council shall either itself conduct conciliation`
  line `in the matter or seek the assistance of any institution or centre providing alternate dispute resolution`
  line `services by making a reference to such an institution or centre, for conducting conciliation and the`
  line `provisions of sections 65 to 81 of the Arbitration and Conciliation Act, 1996 (26 of 1996) shall apply to`
  line `such a dispute as if the conciliation was initiated under Part III of that Act.`
  line
  line `(3) Where the conciliation initiated under sub-section (2) is not successful and stands terminated`
  line `without any settlement between the parties, the Council shall either itself take up the dispute for`
  line `arbitration or refer ittoany institution or centre providing alternate dispute resolution services for such`
  line `arbitration and the provisions of the Arbitration and Conciliation Act, 1996 (26 of 1996) shall then apply`
  line `to the dispute as if the arbitration was in pursuance of an arbitration agreement referred to in`
  line `sub-section(1) of section 7 of that Act.`
  line
  line `(4) Notwithstanding anything contained in any other law for the time being in force, the Micro and`
  line `Small Enterprises Facilitation Council or the centre providing alternate dispute resolution services shall`
  line `have jurisdiction to act as an Arbitrator or Conciliator under this section in a dispute between the supplier`
  line `located within its jurisdiction and a buyer located anywhere in India.`
  line
  line `(5) Every reference made under this section shall be decided within a period of ninety days from the`
  line `date of making such a reference.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (9901)
  sectionNo (19)
  orderNo 19
  title `Application for setting aside decree, award or order.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9901&sectionno=19&orderno=19&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_19_content:
  string
  line `No application for setting aside any`
  line `decree, award or other order made either by the Council itself or by any institution or centre providing`
  line `alternate dispute resolution services to which a reference is made by the Council, shall be entertained by`
  line `any court unless the appellant (not being a supplier) has deposited with it seventy-five per cent. of the`
  line `amount in terms of the decree, award or, as the case may be, the other order in the manner directed by`
  line `such court:`
  line
  line `Provided that pending disposal of the application to set aside the decree, award or order, the court`
  line `shall order that such percentage of the amount deposited shall be paid to the supplier, as it considers`
  line `reasonable under the circumstances of the case, subject to such conditions as it deems necessary to`
  line impose.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (9902)
  sectionNo (20)
  orderNo 20
  title `Establishment of Micro and Small Enterprises Facilitation Council.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9902&sectionno=20&orderno=20&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_20_content:
  string
  line `The State Government`
  line `shall, by notification, establish one or more Micro and Small Enterprises Facilitation Councils, at such`
  line `places, exercising such jurisdiction and for such areas, as may be specified in the notification.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (9903)
  sectionNo (21)
  orderNo 21
  title `Composition of Micro and Small Enterprises Facilitation Council.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9903&sectionno=21&orderno=21&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_21_content:
  string
  line `(1) The Micro and Small`
  line `Enterprise Facilitation Council shall consist of not less than three but not more than five members to be`
  line `appointed from amongst the following categories, namely:--`
  line
  line `(i) Director of Industries, by whatever name called, or any other officer not below the rank of`
  line `such Director, in the Department of the State Government having administrative control of the small`
  line `scale industries or, as the case may be, micro, small and medium enterprises; and`
  line
  line `(ii) one or more office-bearers or representatives of associations of micro or small industry or`
  line `enterprises in the State; and`
  line
  line `(iii) one or more representatives of banks and financial institutions lending to micro or small`
  line `enterprises; or`
  line
  line `(iv) one or more persons having special knowledge in the field of industry, finance, law, trade or`
  line commerce.
  line
  line `(2) The person appointed under clause (i) of sub-section (1) shall be the Chairperson of the Micro and`
  line `Small Enterprises Facilitation Council.`
  line
  line `(3) The composition of the Micro and Small Enterprises Facilitation Council, the manner of filling`
  line `vacancies of its members and the procedure to be followed in the discharge of their functions by the`
  line `members shall be such as may be prescribed by the State Government.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (9904)
  sectionNo (22)
  orderNo 22
  title `Requirement to specify unpaid amount with interest in the annual statement of accounts.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9904&sectionno=22&orderno=22&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_22_content:
  string
  line `Where any buyer is required to get his annual accounts audited under any law for the time being in force,`
  line `such buyer shall furnish the following additional information in his annual statement of accounts,`
  line `namely:--`
  line
  line `(i)the principal amount and the interest due thereon (to be shown separately) remaining unpaid to`
  line `any supplier as at the end of each accounting year;`
  line
  line `(ii) the amount of interest paid by the buyer in terms of section 16, along with the amount of the`
  line `payment made to the supplier beyond the appointed day during each accounting year;`
  line
  line `(iii) the amount of interest due and payable for the period of delay in making payment (which`
  line `have been paid but beyond the appointed day during the year) but without adding the interest`
  line `specified under this Act;`
  line
  line `(iv) the amount of interest accrued and remaining unpaid at the end of each accounting year; and`
  line
  line `(v) the amount of further interest remaining due and payable even in the succeeding years, until`
  line `such date when the interest dues as above are actually paid to the small enterprise, for the purpose of`
  line `disallowance as a deductible expenditure under section 23.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (9905)
  sectionNo (23)
  orderNo 23
  title `Interest not to be allowed as deduction from income.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9905&sectionno=23&orderno=23&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_23_content:
  string
  line `Notwithstanding anything contained in`
  line `the Income-tax Act, 1961 (43 of 1961), the amount of interest payable or paid by any buyer, under or in`
  line `accordance with the provisions of this Act, shall not, for the purposes of computation of income under the`
  line `Income-tax Act, 1961, be allowed as deduction.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (9906)
  sectionNo (24)
  orderNo 24
  title `Overriding effect.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9906&sectionno=24&orderno=24&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_24_content:
  string
  line `The provisions of sections 15 to 23 shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (9907)
  sectionNo (25)
  orderNo 25
  title `Scheme for closure of business of micro, small and medium enterprises.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9907&sectionno=25&orderno=25&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_25_content:
  string
  line Notwithstanding
  line `anything contained in any law for the time being in force, the Central Government may, with a view to`
  line `facilitating closure of business by a micro, small or medium enterprise, not being a company registered`
  line `under the Companies Act, 1956 (1 of 1956), notify a Scheme within one year from the date of`
  line `commencement of this Act.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (9908)
  sectionNo (26)
  orderNo 26
  title `Appointment of Officers and other employees.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9908&sectionno=26&orderno=26&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_26_content:
  string
  line `(1) The Central Government or the State`
  line `Government may appoint such officers with such designations and such other employees as it thinks fit`
  line `for the purposes of this Act and may entrust to them such of the powers and functions under this Act as it`
  line `may deem fit.`
  line
  line `(2) The Officers appointed under sub-section (1) may, for the purposes of this Act, by order require`
  line `any person to furnish such information, in such form, as may be prescribed.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (9909)
  sectionNo (27)
  orderNo 27
  title `Penalty for contravention of section 8 or section 22 or section 26.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9909&sectionno=27&orderno=27&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_27_content:
  string
  line `(1) Whoever intentionally`
  line `contravenes or attempts to contravene or abets the contravention of any of the provisions contained in`
  line `sub-section (1) of section 8 or sub-section (2) of section 26 shall be punishable--`
  line
  line `(a) in the case of the first conviction, with fine which may extend to rupees one thousand; and`
  line
  line `(b) in the case of second or subsequent conviction, with fine which shall not be less than rupees`
  line `one thousand but may extend to rupees ten thousand.`
  line
  line `(2) Where a buyer contravenes the provisions of section 22, he shall be punishable with fine`
  line `which shall not be less than rupees ten thousand.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (9910)
  sectionNo (28)
  orderNo 28
  title `Jurisdiction of courts.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9910&sectionno=28&orderno=28&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_28_content:
  string
  line `No court inferior to that of a Metropolitan Magistrate or a Magistrate of`
  line `the first class shall try any offence punishable under this Act`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (9911)
  sectionNo (29)
  orderNo 29
  title `Power to make rules.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9911&sectionno=29&orderno=29&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_29_content:
  string
  line `(1) The Central Government may, by notification, make rules to carry`
  line `out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the term of office of the members of the Board, the manner of filling vacancies, and the`
  line `procedure to be followed in the discharge of functions by the members of the Board under`
  line `sub-section (4) of section 3;`
  line
  line `(b) the powers and functions of the Member-Secretary under section 6;`
  line
  line `(c) the manner in which the Fund may be administered under sub-section (1) of section 14;`
  line
  line `(d) the criteria based on which sums may be released under sub-section (3) of section 14;`
  line
  line `(e) the information to be furnished and the form in which it is to be furnished under`
  line `sub-section (2) of section 26; and`
  line
  line `(f) any other matter which is to be or may be prescribed under this Act.`
  line
  line `(3) Every notification issued under section 9 and every rule made by the Central Government under`
  line `this section shall be laid, as soon as may be after it is made, before each House of Parliament, while it is`
  line `in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the notification or rule or`
  line `both Houses agree that the notification or rule should not be made, the notification or rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that notification or rule.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (9912)
  sectionNo (30)
  orderNo 30
  title `Power to make rules by State Government.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9912&sectionno=30&orderno=30&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_30_content:
  string
  line `(1) The State Government may, by notification,`
  line `make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the composition of the Micro and Small Enterprises Facilitation Council, the manner of filling`
  line `vacancies of the members and the procedure to be followed in the discharge of their functions by the`
  line `members of the Micro and Small Enterprises Facilitation Council under sub-section (3) of section 21;`
  line
  line `(b) any other matter which is to be, or may be, prescribed under this Act.`
  line
  line `(3) The rule made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of the State Legislature where there are two Houses, and where there is one House of the State`
  line `Legislature, before that House.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (9913)
  sectionNo (31)
  orderNo 31
  title `Power to remove difficulties.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9913&sectionno=31&orderno=31&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_31_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (9914)
  sectionNo (32)
  orderNo 32
  title `Repeal of Act 32 of 1993.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00002_200627_1517807324919&sectionId=9914&sectionno=32&orderno=32&orgactid=AC_CEN_46_77_00002_200627_1517807324919
obj_root_law_sections_32_content:
  string
  line `(1) The Interest on Delayed Payments to Small Scale and Ancillary`
  line `Industrial Undertakings Act, 1993is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the Act so repealed under`
  line `sub-section (1), shall be deemed to have been done or taken under the corresponding provisions of this`
  line Act.
obj_root_law_sections_32_footnotes:
  string
  line
