  object
  (str title) (str `सूक्ष्‍म, लघु और मध्‍यम उद्यम विकासअधिनियम, 2006`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2013/5/H2006-27.pdf`)
