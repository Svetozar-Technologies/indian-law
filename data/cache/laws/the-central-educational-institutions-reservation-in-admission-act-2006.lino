obj_root_law_sections_1:
  sectionId (40840)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00031_200705_1517807327501&sectionId=40840&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00031_200705_1517807327501
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Central Educational Institutions (Reservation in`
  line `Admission) Act, 2006.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (40841)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1.Ins. by Act 31 of 2012, s.2 (w.e.f. 19-6-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00031_200705_1517807327501&sectionId=40841&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00031_200705_1517807327501
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "academic session" means the period in a calendar year, or a part thereof, during which a`
  line `Central Educational Institution is open for teaching or instruction in any branch of study or faculty;`
  line
  line `(b) "annual permitted strength" means the number of seats, in a course or programme for teaching`
  line `or instruction in each branch of study or faculty authorised by an appropriate authority for admission`
  line `of students to a Central Educational Institution;`
  line
  line `(c) "appropriate authority" means the University Grants Commission, the Bar Council of India,`
  line `the Medical Council of India, the All India Council for Technical Education or any other authority or`
  line `body established by or under a Central Act for the determination, coordination or maintenance of the`
  line `standards of higher education in any Central Educational Institution;`
  line
  line `(d) "Central Educational Institution" means--`
  line
  line `(i) a university established or incorporated by or under a Central Act;`
  line
  line `(ii) an institution of national importance set up by an Act of Parliament;`
  line
  line `(iii) an institution, declared as a deemed University under section 3 of the University Grants`
  line `Commission Act, 1956 (3 of 1956), and maintained by or receiving aid from the Central`
  line Government;
  line
  line `(iv) an institution maintained by or receiving aid from the Central Government, whether`
  line `directly or indirectly, and affiliated to an institution referred to in clause (i) or clause (ii), or a`
  line `constituent unit of an institution referred to in clause (iii);`
  line
  line `(v) an educational institution set up by the Central Government under the Societies`
  line `Registration Act, 1860(21 of 1860);`
  line
  line `(e) "faculty" means the faculty of a Central Educational Institution;`
  line
  line `(f) "Minority Educational Institution" means an institution established and administered by the`
  line `minorities under clause (1) of article 30 of the Constitution and so declared by an Act of Parliament`
  line `or by the Central Government or declared as a Minority Educational Institution under the National`
  line `Commission for Minority Educational Institutions Act, 2004 (2 of 2005);`
  line
  line `(g)"Other Backward Classes" means the class or classes of citizens who are socially and`
  line `educationally backward, and are so determined by the Central Government;`
  line
  line `(h) "Scheduled Castes" means the Scheduled Castes notified under article 341 of the`
  line Constitution;
  line
  line `(i) "Scheduled Tribes" means the Scheduled Tribes notified under article 342 of the Constitution;`
  line
  line ^1
  line `[(ia) "specified north-eastern region" means the area comprising of the States of Arunachal`
  line `Pradesh, Manipur, Meghalaya, Mizoram, Nagaland, Sikkim, Tripura and the tribal areas of Assam`
  line `referred to in the Sixth Schedule to the Constitution;`
  line
  line `(ib) "State seats", in relation to a Central Educational Institution, means such seats, if any, out of`
  line `the annual permitted strength in each branch of study or faculty as are earmarked to be filled from`
  line `amongst the eligible students of the State in which such institution is situated;]`
  line
  line `(j) "teaching or instruction in any branch of study" means teaching or instruction in a branch of`
  line `study leading to three principal levels of qualifications at bachelor (undergraduate) masters`
  line `(postgraduate) and doctoral levels .`
obj_root_law_sections_3:
  sectionId (40842)
  sectionNo (3)
  orderNo 3
  title `Reservation of seats in Central Educational Institutions.`
  content obj_root_law_sections_3_content
  footnotes `1. Ins. by s.3, ibid. (w.e.f. 19-6-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00031_200705_1517807327501&sectionId=40842&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00031_200705_1517807327501
obj_root_law_sections_3_content:
  string
  line `The reservation of seats in admission`
  line `and its extent in a Central Educational Institution shall be provided in the following manner, namely:--`
  line
  line `(i) out of the annual permitted strength in each branch of study or faculty, fifteen per cent. seats`
  line `shall be reserved for the Scheduled Castes;`
  line
  line `(ii) out of the annual permitted strength in each branch of study or faculty, seven and one-half per`
  line `cent. seats shall be reserved for the Scheduled Tribes;`
  line
  line `(iii) out of the annual permitted strength in each branch of study or faculty, twenty-seven per cent.`
  line `seats shall be reserved for the Other Backward Classes:`
  line
  line ^1
  line `[Provided that the State seats, if any, in a Central Educational Institution situated in the tribal areas`
  line `referred to in the Sixth Schedule to the Constitution shall be governed by such reservation policy for the`
  line `Scheduled Castes, the Scheduled Tribes and the Other Backward Classes, as may be specified, by`
  line `notification in the Official Gazette, by the Government of the State where such institution is situated:`
  line
  line `Provided further that if there are no State seats in a Central Educational Institution and the seats`
  line `reserved for the Scheduled Castes exceed the percentage specified under clause (i) or the seats reserved`
  line `for the Scheduled Tribes exceed the percentage specified under clause (ii) or the seats reserved for the`
  line `Scheduled Castes and the Scheduled Tribes taken together exceed the sum of percentages specified under`
  line `clauses (i) and (ii), but such seats are--`
  line
  line `(a)less than fifty per cent. of the annual permitted strength on the date immediately preceding`
  line `the date of commencement of this Act, the total percentage of the seats required to be reserved for`
  line `the Other Backward Classes under clause (iii) shall be restricted to the extent such sum of`
  line `percentages specified under clauses (i) and (ii) falls short of fifty percent.of the annual permitted`
  line strength;
  line
  line `(b) more than fifty per cent. of the annual permitted strength on the date of immediately`
  line `preceding the date of commencement of this Act, in that case no seats shall be reserved for the Other`
  line `Backward Classes under clause (iii) but the extent of the reservation of seats for the Scheduled`
  line `Castes and the Scheduled Tribes shall not be reduced in respect of Central Educational Institutions in`
  line `the specified north-eastern region.].`
obj_root_law_sections_4:
  sectionId (40843)
  sectionNo (4)
  orderNo 4
  title `Act not to apply in certain cases.`
  content obj_root_law_sections_4_content
  footnotes `1. Cl. (a) omitted by s. 4, ibid. (w.e.f. 19-6-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00031_200705_1517807327501&sectionId=40843&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00031_200705_1517807327501
obj_root_law_sections_4_content:
  string
  line `The provisions of section 3 of this Act shall not apply to--`
  line
  line `^1* * * * *`
  line
  line `(b) the institutions of excellence, research institutions, institutions of national and strategic`
  line `importance specified in the Schedule to this Act:`
  line
  line `Provided that the Central Government may, as and when considered necessary, by notification in`
  line `the Official Gazette, amend the Schedule;`
  line
  line `(c) a Minority Educational Institution as defined in this Act;`
  line
  line `(d) a course or programme at high levels of specialisation, including at the post-doctoral level,`
  line `within any branch of study or faculty, which the Central Government may, in consultation with the`
  line `appropriate authority, specify.`
obj_root_law_sections_5:
  sectionId (40844)
  sectionNo (5)
  orderNo 5
  title `Mandatory increase of seats.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00031_200705_1517807327501&sectionId=40844&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00031_200705_1517807327501
obj_root_law_sections_5_content:
  string
  line `(1) Notwithstanding anything contained in clause (iii) of section 3`
  line `and in any other law for the time being in force, every Central Educational Institution shall, with the prior`
  line `approval of the appropriate authority, increase the number of seats in a branch of study or faculty over`
  line `and above its annual permitted strength so that the number of seats, excluding those reserved for the`
  line `persons belonging to the Scheduled Castes, the Scheduled Tribes and the Other Backward Classes, is not`
  line `less than the ^1`
  line `[number of such seats available or actually filled, whichever be less,] for the academic`
  line `session immediately preceding the date of the coming into force of this Act.`
  line
  line `(2) Where, on a representation by any Central Educational Institution, the Central Government, in`
  line `consultation with the appropriate authority, is satisfied that for reasons of financial, physical or academic`
  line `limitations or in order to maintain the standards of education, the annual permitted strength in any branch`
  line `of study or faculty of such institution cannot be increased for the academic session following the`
  line `commencement of this Act, it may permit by notification in the Official Gazette, such institution to`
  line `increase the annual permitted strength over a maximum period of ^2`
  line `[six years] beginning with the`
  line `academic session following the commencement of this Act; and then, the extent of reservation for the`
  line `Other Backward Classes as provided in clause (iii) of section 3 shall be limited for that academic session`
  line `in such manner that the number of seats available to the Other Backward Classes for each academic`
  line `session are commensurate with the increase in the permitted strength for each year.`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 31 of 2012, s. 5, for "number of such seats available" (w.e.f. 19-6-2012).`
  line
  line `2. Subs. by s. 5, ibid., for "three years" (w.e.f. 19-6-2012).`
obj_root_law_sections_6:
  sectionId (40845)
  sectionNo (6)
  orderNo 6
  title `Reservation of seats in admissions to begin in calendar year, 2008.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by s. 6, ibid., for "2007" (w.e.f. 19-6-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00031_200705_1517807327501&sectionId=40845&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00031_200705_1517807327501
obj_root_law_sections_6_content:
  string
  line `6. Reservation of seats in admissions to begin in calendar year, ^1`
  line `[2008].--The Central Educational`
  line `Institutions shall take all necessary steps, which are required in giving effect to the provisions of sections`
  line `3, 4 and 5 of this Act, for the purposes of reservation of seats in admissions to its academic sessions`
  line `commencing on and from the calendar year, ^1`
  line 2008.
obj_root_law_sections_7:
  sectionId (40846)
  sectionNo (7)
  orderNo 7
  title `Laying of notifications before Parliament.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00031_200705_1517807327501&sectionId=40846&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00031_200705_1517807327501
obj_root_law_sections_7_content:
  string
  line `Every notification made under this Act shall be laid,`
  line `as soon as may be after it is made, before each House of Parliament while it is in session, for a total`
  line `period of thirty days which may be comprised in one session or in two or more successive sessions, and`
  line `if, before the expiry of the session immediately following the session or the successive sessions aforesaid,`
  line `both Houses agree in making any modification in the notification or both Houses agree that the`
  line `notification should not be made, the notification shall thereafter have effect only in such modified form or`
  line `be of no effect, as the case may be; so, however, that any such modification or annulment shall be without`
  line `prejudice to the validity of anything previously done under that notification.`
obj_root_law_sections_7_footnotes:
  string
  line
