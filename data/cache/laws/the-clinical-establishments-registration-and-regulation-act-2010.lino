  (str title) (str `नैदानिक स्‍थापन (रजिस्‍ट्रीकरण और विनियमन)अधिनियम, 2010`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2048/2/H2010-23.pdf`)
