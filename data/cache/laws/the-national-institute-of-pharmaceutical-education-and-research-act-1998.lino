obj_root_law_sections_1:
  sectionId (24702)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_199813_1517807323357&sectionId=24702&sectionno=1&orderno=1&orgactid=AC_CEN_12_72_00001_199813_1517807323357
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National ^1[`
  line `Institutes] of Pharmaceutical Education and Research Act, 1998.`
  line
  line `(2) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for "Institute" (w.e.f. 25-5-2022).`
  line
  line `2. 8th July, 1998, vide notification No. S.O. 1412(E), dated 7th July, 1998, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (24703)
  sectionNo (2)
  orderNo 2
  title `Declaration of certain institutions as institutions of national importance.`
  content obj_root_law_sections_2_content
  footnotes `1. Subs. by Act 43 of 2021, s. 4, for section 2 (w.e.f. 25-5-2022).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_199813_1517807323357&sectionId=24703&sectionno=2&orderno=2&orgactid=AC_CEN_12_72_00001_199813_1517807323357
obj_root_law_sections_2_content:
  string
  line `^1[2. Declaration of certain institutions as institutions of national importance.—(1) Whereas the objects of the institutions mentioned in the Schedule, are such as to make them institutions of national importance, it is hereby declared that each such Institute is an institution of national importance.`
  line
  line `(2) It is hereby declared that every Institute established under sub-section (2A) of section 4, on and after the commencement of the National Institute of Pharmaceutical Education and Research (Amendment) Act, 2021 (43 of 2021), shall be an institution of national importance.]`
obj_root_law_sections_3:
  sectionId (24704)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_199813_1517807323357&sectionId=24704&sectionno=3&orderno=3&orgactid=AC_CEN_12_72_00001_199813_1517807323357
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `^1[(a) "appointed day", in relation to an Institute mentioned in column (3) of the Schedule, means the date of its establishment as mentioned against it in column (4) of that Schedule;]`
  line
  line `(b) "Board" means the Board of Governors of ^2[an Institute] constituted under sub-section (3) of section 4;`
  line
  line `(c) "Chairperson" means the Chairperson of ^2[an Institute ] nominated under clause (a) of sub-section (3) of section (4);`
  line
  line `^3[(ca) "Council" means the Council established under sub-section (1) of section 30A; ]`
  line
  line `(d) "Dean" means the Dean of ^2[an Institute ] appointed under section 17;`
  line
  line `(e) "Director" means the Director of ^2[an Institute ] appointed under section 16;`
  line
  line `(f) "Fund" means the fund of ^2[an Institute ] to be maintained under section 21;`
  line
  line `^4[(g) "Institute" means any of the institutions mentioned in column (3) of the Schedule;`
  line
  line `(ga) "member" means a member of the Council nominated or elected under sub-section (2) of`
  line `section 30A;`
  line
  line `(gb) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(gc) "Schedule" means the Schedule to this Act; ]`
  line
  line `(h) "Senate" means the Senate of ^2[an Institute ] referred to in section 13;`
  line
  line `(i) "Society" means the National Institute of Pharmaceutical Education and Research Society,`
  line `Sector-67, S.A.S. Nagar (Mohali), District Ropar, Punjab registered under the Societies Registration`
  line `Act, 1860 (21 of 1860);`
  line
  line `(j) "Statutes" and "Ordinances" mean the Statutes and the Ordinances of`
  line `^2[an Institute ] made under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 43 of 2021, s. 5, for clause (a) (w.e.f. 25-5-2022).`
  line
  line `2. Subs. by s. 5, ibid., for "the Institute" (w.e.f. 25-5-2022).`
  line
  line `3. Ins. by s. 5, ibid. (w.e.f. 25-5-2022).`
  line
  line `4. Subs. by s. 5, ibid., for clause (g) (w.e.f. 25-5-2022)`
obj_root_law_sections_4:
  sectionId (24705)
  sectionNo (4)
  orderNo 4
  title `Establishment and incorporation of Institutes.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_199813_1517807323357&sectionId=24705&sectionno=4&orderno=4&orgactid=AC_CEN_12_72_00001_199813_1517807323357
obj_root_law_sections_4_content:
  string
  line `^1 [ 4.Establishment and incorporation of Institutes.]--^2 [(1) Each of the Institutes mentioned in column (3) of the Schedule shall be a body corporate.]`
  line
  line `(2) ^3[Each Institute] shall have perpetual succession and a common seal with power, subject to the provisions of this Act, to acquire, hold and dispose of property and to contract, and shall, by that name, sue and be sued.`
  line
  line `^4[(2A) The Central Government may, by notification in the Official Gazette, establish similar`
  line `Institutes in different parts of the country.]`
  line
  line `^5 [(3) The Board of Governors of an Institute shall consist of the following persons, namely:--`
  line
  line `(a) a Chairperson, who shall be an eminent academician or scientist or technologist or professional, to be nominated by the Visitor;`
  line
  line `(b) the Director of the Institute, ex officio;`
  line
  line `(c) the Joint Secretary to the Government of India in Department of Pharmaceuticals dealing with the national institutes of pharmaceutical education and research, ex officio;`
  line
  line `(d) the Secretary, dealing with medical or technical education in the State Government concerned, ex officio;]`
  line
  line `(e) the representative of Drug Controller General of India, Ministry of Health and Family Welfare of the Government of India, ex officio;`
  line
  line `(f) three eminent pharmaceutical experts, at least one of whom shall be a woman, having special knowledge or practical experience in education, research and biotechnology, to be nominated by the Council;`
  line
  line `(g) two pharmaceutical industrialists to be nominated by the Council;`
  line
  line `(h) two professors of the institute, to be nominated by the Senate:`
  line
  line `Provided that one member from amongst members to be nominated under clauses (f), (g) and (h) shall be either from the Scheduled Castes or from the Scheduled Tribes. ]`
  line
  line `(4) The term of office of the Chairperson and Governors other than ex officio Governors shall be three years and they shall be entitled for such allowances as may be determined by the Central Government:`
  line
  line ^6*
  line
  line *
  line
  line *
  line
  line *
  line *
  line
  line `(5) The term of office of Governor nominated to fill a casual vacancy shall continue for the remainder`
  line `of the term of the Governor in whose place he has been nominated.`
  line
  line `(6) The Board shall meet at least three times in a year at such place and time and observe such rules`
  line `of procedure in regard to the transaction of business at its meetings as may be determined by the Board.`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 43 of 2021, s. 6, for marginal heading (w.e.f. 25-5-2022).`
  line
  line `2. Subs. by s. 6, ibid., for sub-section (1) (w.e.f. 25-5-2022).`
  line
  line `3. Subs. by s. 6, ibid., for "The Institute" (w.e.f. 25-5-2022).`
  line
  line `4. Ins. by Act 19 of 2007, s. 3 (w.e.f. 29-1-2007).`
  line
  line `5. Subs. by Act 43 of 2021, s. 6, for sub-section (3) (w.e.f. 25-5-2022).`
  line
  line `6. Proviso omitted by s. 6, ibid. (w.e.f. 25-5-2022).`
