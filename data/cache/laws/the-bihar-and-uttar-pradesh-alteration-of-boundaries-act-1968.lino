  object
  (str hi) obj_root_law_translations_hi
obj_root_law_translations_hi:
  object
  (str title) (str `बिहार और उत्तर प्रदेश (सीमा-परिवर्तन) अधिनियम, 1968`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1501/3/H1968-24.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:28:12.583Z`)
