obj_root_law:
  slug the-infant-milk-substitutes-feeding-bottles-and-infant-foods-regulation-of-production-supply-and-distribution-act-1992
  handle (1958)
  collectionHandle 123456789/1362
  title `The Infant Milk Substitutes, Feeding Bottles and Infant Foods (Regulation of Production, Supply and Distribution) Act, 1992`
  actNumber (41)
  enactmentDate 1992-12-29
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1958`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `शिशु दुग्ध अनुकल्प, पोषण बोतल और शिशुखाद्य (उत्पादन, प्रदाय और वितरणविनियम) अधिनियम, 1992`
  actYear (1992)
  ministry `Ministry of Women and Child Development`
  department undefined
  longTitle `An Act to provide for the regulation of production, supply and distribution of infant milk substitutes, feeding bottles and infant foods with a view to the protection and promotion of breast-feeding and ensuring the proper use of infant foods and for matters connected therewith or incidental thereto.`
