  (str slug) (str the-infant-milk-substitutes-feeding-bottles-and-infant-foods-regulation-of-production-supply-and-distribution-act-1992)
  (str handle) (str 1958)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Infant Milk Substitutes, Feeding Bottles and Infant Foods (Regulation of Production, Supply and Distribution) Act, 1992`)
  (str actNumber) (str 41)
  (str enactmentDate) (str 1992-12-29)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1958`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `शिशु दुग्ध अनुकल्प, पोषण बोतल और शिशुखाद्य (उत्पादन, प्रदाय और वितरणविनियम) अधिनियम, 1992`)
  (str actYear) (str 1992)
  (str ministry) (str `Ministry of Women and Child Development`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the regulation of production, supply and distribution of infant milk substitutes, feeding bottles and infant foods with a view to the protection and promotion of breast-feeding and ensuring the proper use of infant foods and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-08-1993)
  (str notification) (str `1st August 1993, vide notification No. G.S.R. 527(E), dated 31st July, 1993, see Gazette of India, Extraordinary, Part I, sec. 3(i).`)
