obj_root_law_sections_1:
  sectionId (12695)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12695&sectionno=1&orderno=1&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Infant Milk Substitutes,`
  line `Feeding Bottles and Infant Foods (Regulation of Production, Supply and Distribution) Act, 1992.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st August 1993, vide notification No. G.S.R. 527(E), dated 31st July, 1993, see Gazette of India, Extraordinary, Part I,`
  line `sec. 3(i).`
obj_root_law_sections_2:
  sectionId (12696)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12696&sectionno=2&orderno=2&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `^1[(a) "advertisement" includes any notice, circular, label, wrapper or any other document or`
  line `visible representation or announcement made by means of any light, sound, smoke or gas or by means`
  line `of electronic transmission or by audio or visual transmission;]`
  line
  line `(b) "container" means a box, bottle, casket, tin, can, barrel, case, tube, receptacle, sack, wrapper`
  line `or other thing in which any infant milk substitute, feeding bottle or infant food is placed or packed for`
  line `sale or distribution;`
  line
  line `(c) "feeding bottle" means any bottle or receptacle used for the purpose of feeding infant milk`
  line `substitutes, and includes a teat and a valve attached or capable of being attached to such bottle or`
  line receptacle;
  line
  line `(d) "health care system" means an institution or organisation engaged, either directly or`
  line `indirectly, in health care for mothers, infants or pregnant women, and includes a health worker in`
  line `private practice, ^2[a pharmacy, drug store and any association of health workers];`
  line
  line `(e) "health worker" means a person engaged in health care for mothers, infants or pregnant`
  line women;
  line
  line `(f) "infant food" means any food (by whatever name called) being marketed or otherwise`
  line `represented as a complement to mothers milk to meet the growing nutritional needs of the infant`
  line `^3[after the age of six months and up to the age of two years];`
  line
  line `(g) "infant milk substitute" means any food being marketed or otherwise represented as a partial`
  line `or total replacement for mothers milk ^4[for infant up to the age of two years];`
  line
  line `(h) "label" means a display of written, marked, stamped, printed or graphic matter affixed to, or`
  line `appearing upon, any container;`
  line
  line `(i) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^5[(j) "promotion" means to employ directly or indirectly any method of encouraging any person`
  line `to purchase or use infant milk substitute, feeding bottle or infant food.]`
  line
  line `(2) Any reference in this Act to any other enactment or any provision thereof, shall, in relation to an`
  line `area in which such enactment or such provision is not in force, be construed as a reference to the`
  line `corresponding law or the relevant provision of the corresponding law, if any, in force in that area.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 38 of 2003, s. 2, for clause (a) (w.e.f. 1-11-2003).`
  line
  line `2. Subs. by s. 2, ibid., for "but does not include a pharmacy or drug store" (w.e.f. 1-11-2003).`
  line
  line `3. Subs. by s. 2, ibid., for "after the age of four months" (w.e.f. 1-11-2003).`
  line
  line `4. Subs. by s. 2, ibid., for ", whether or not it is suitable for such replacement" (w.e.f. 1-11-2003).`
  line
  line `5. Ins. by s. 2, ibid. (w.e.f. 1-11-2003).`
obj_root_law_sections_3:
  sectionId (12697)
  sectionNo (3)
  orderNo 3
  title `Certain prohibitions in relation to infant milk substitutes, feeding bottles and infant foods.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12697&sectionno=3&orderno=3&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_3_content:
  string
  line `No person shall--`
  line
  line `(a) advertise, or take part in the publication of any advertisement, for the distribution, sale or`
  line `supply of infant milk substitutes ^1[, feeding bottles or infant foods]; or`
  line
  line `(b) give an impression or create a belief in any manner that feeding of ^2[infant milk substitutes`
  line `and infant foods are] equivalent to, or better than, mother's milk; or`
  line
  line `^3[(c) take part in the promotion of infant milk substitutes, feeding bottles or infant foods.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 38 of 2003, s. 3, for "or feeding bottles" (w.e.f. 1-11-2003).`
  line
  line `2. Subs. by s. 3, ibid., for "infant milk substitutes is" (w.e.f. 1-11-2003).`
  line
  line `3. Subs. by s. 3, ibid., for clause (c) (w.e.f. 1-11-2003).`
obj_root_law_sections_4:
  sectionId (12698)
  sectionNo (4)
  orderNo 4
  title `Prohibition of incentives for the use or sale of infant milk substitutes or feeding bottles.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by s. 4, ibid., for "feeding bottles" (w.e.f. 1-11-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12698&sectionno=4&orderno=4&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_4_content:
  string
  line `4. Prohibition of incentives for use or sale of infant milk substitutes or ^1[feeding bottles or infant`
  line `foods].--No person shall--`
  line
  line `(a) supply or distribute samples of infant milk substitutes or ^1[feeding bottles or infant foods] or`
  line `gifts of utensils or other articles; or`
  line
  line `(b) contact any pregnant woman or the mother of an infant; or`
  line
  line `(c) offer inducement of any other kind,`
  line
  line `for the purpose of promoting the use or sale of infant milk substitutes or ^1[feeding bottles or infant foods].`
obj_root_law_sections_5:
  sectionId (12699)
  sectionNo (5)
  orderNo 5
  title `Donations of infant milk substitutes or feeding bottles or equipment of materials relating thereto.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by s. 5, ibid., for "feeding bottles" (w.e.f. 1-11-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12699&sectionno=5&orderno=5&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_5_content:
  string
  line `Subject to the provisions of sub-section (4) of section 8, no person shall donate or distribute--`
  line
  line `(a) infant milk substitutes or ^1[feeding bottles or infant foods] to any other person except to an`
  line orphanage;
  line
  line `(b) any informational or educational equipment or material relating to infant milk substitutes or`
  line `^1[feeding bottles or infant foods]:`
  line
  line `Provided that nothing in this clause shall apply to the donation or distribution, subject to such`
  line `conditions and restrictions as may be prescribed, of such equipment or material through the health`
  line `care system.`
obj_root_law_sections_6:
  sectionId (12700)
  sectionNo (6)
  orderNo 6
  title `Information on containers and labels of infant milk substitutes of infant foods`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12700&sectionno=6&orderno=6&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_6_content:
  string
  line `(1) Without`
  line `prejudice to the provisions of ^1[the Food Safety and Standards Act, 2006] and the rules made thereunder, no`
  line `person shall produce, supply or distribute any infant milk substitute or infant food unless every container`
  line `thereof or any label affixed thereto indicates in a clear, conspicuous and in an easily readable and`
  line `understandable manner, the words "important notice" in capital letters in such language as may be`
  line `prescribed and indicating thereunder the following particulars in the same language, namely:--`
  line
  line `(a) a statement "mother's milk is best for your baby" in capital letters;`
  line
  line `(b) a statement that infant milk substitute or infant food should be used only on the advice of a`
  line `health worker as to the need for its use and the proper method of its use;`
  line
  line `(c) a warning that infant milk substitute or infant food is not the sole source of nourishment of an`
  line infant;
  line
  line `(d) the instructions for its appropriate preparation and a warning against the health hazards of its`
  line `inappropriate preparation;`
  line
  line `(e) the ingredients used;`
  line
  line `(f) the composition or analysis;`
  line
  line `(g) the storage conditions required;`
  line
  line `(h) the batch number, date of its manufacture and the date before which it is to be consumed,`
  line `taking into account the climatic and storage conditions of the country;`
  line
  line `(i) such other particulars as may be prescribed.`
  line
  line `(2) No container or label referred to in sub-section (1) relating to 1`
  line `infant milk substitute or infant`
  line `food shall--`
  line
  line `(a) have pictures of an infant or a woman or both; or`
  line
  line `(b) have pictures or other graphic material or phrases designed to increase the saleability of`
  line `^2[infant milk substitute or infant food]; or`
  line
  line `(c) use on it the word "humanised" or "maternalised" or any other similar word; or`
  line
  line `(d) bear on it such other particulars as may be prescribed.`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 34 of 2006, for "the Prevention of the Food Adulteration Act, 1954 (37 of 1954)" (w.e.f. 29-7-2010).`
  line
  line `2. Subs. by Act 38 of 2003, s. 6, for "infant milk substitute" (w.e.f. 1-11-2003).`
obj_root_law_sections_7:
  sectionId (12701)
  sectionNo (7)
  orderNo 7
  title `Educational and other materials relating to feeding of infants to contain certain particulars.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12701&sectionno=7&orderno=7&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_7_content:
  string
  line `(1) ^1[Every educational or other material including advertisements or material relating to`
  line `promotion of infant milk substitutes, feeding bottles and infant foods], whether audio or visual, dealing`
  line `with pre-natal or post-natal care or with the feeding of an infant and intended to reach pregnant women or`
  line `mothers of infants shall include clear information relating to--`
  line
  line `(a) the benefits and superiority of breast-feeding;`
  line
  line `(b) the preparation for, and the continuance of, breast-feeding;`
  line
  line `(c) the harmful effects on breast-feeding due to the partial adoption of bottle feeding;`
  line
  line `(d) the difficulties in reverting to breast-feeding of infants after a period of feeding by infant milk`
  line substitute;
  line
  line `(e) the financial and social implications in making use of infant milk substitutes and feeding`
  line bottles;
  line
  line `(f) the health hazards of improper use of infant milk substitutes and feeding bottles;`
  line
  line `^2[(fa) the date of printing and publication of such material and the name of the printer and`
  line publisher;]
  line
  line `(g) such other matters as may be prescribed.`
  line
  line `(2) No material referred to in sub-section (1) shall be utilised to promote the use or sale of infant milk`
  line `substitutes or ^3[feeding bottles or infant foods].`
obj_root_law_sections_7_footnotes:
  string
  line `1. Subs. by s. 7, ibid., for "Every educational or other material" (w.e.f. 1-11-2003).`
  line
  line `2. Ins. by s. 7, ibid. (w.e.f. 1-11-2003).`
  line
  line `3. Subs. by s. 7, ibid., for "feeding bottles" (w.e.f. 1-11-2003).`
obj_root_law_sections_8:
  sectionId (12702)
  sectionNo (8)
  orderNo 8
  title `Health care system.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12702&sectionno=8&orderno=8&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_8_content:
  string
  line `(1) No person shall use any health care system for the display of placards or`
  line `posters relating to, or for the distribution of, materials for the purpose of promoting the use or sale of`
  line `infant milk substitutes or feeding bottles or infant foods:`
  line
  line `Provided that the provisions of this sub-section shall not apply to--`
  line
  line `(a) the donation or distribution of informational or educational equipment or material made in`
  line `accordance with the proviso to clause (b) of section 5; and`
  line
  line `(b) the dissemination of information to a health worker about the scientific and factual matters`
  line `relating to the use of infant milk substitutes or feeding bottles or infant foods along with the`
  line `information specified in sub-section (1) of section 7.`
  line
  line `(2) No person who produces, supplies, distributes or sells infant milk substitutes or feeding bottles or`
  line `infant foods shall make any payment to any person who works in the health care system for the purpose`
  line `of promoting the use or sale of such substitutes or bottles or foods.`
  line
  line `(3) No person, other than a health worker, shall demonstrate feeding with infant milk substitutes or`
  line `infant foods to a mother of an infant or to any member of her family and such health worker shall also clearly explain to such mother or such other member the hazards of improper use of infant milk`
  line `substitutes or feeding bottles or infant foods.`
  line
  line `(4) No person, other than an institution or organisation, engaged in health care for mothers, infants or`
  line `pregnant women, shall distribute infant milk substitutes or feeding bottles to a mother who cannot resort`
  line `to breast-feeding and who cannot afford to purchase infant milk substitutes or feeding bottles.`
  line
  line `(5) An orphanage may purchase infant milk substitutes or feeding bottles at a price lower than their`
  line `sale price for the purpose of utilising them in the said orphanage.`
  line
  line `Explanation.--For the purposes of this sub-section, such purchases shall not amount to an`
  line `inducement for promoting the use or sale of infant milk substitutes or feeding bottles.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (12703)
  sectionNo (9)
  orderNo 9
  title `Inducement to health worker for promoting use of infant milk substitutes, etc.`
  content obj_root_law_sections_9_content
  footnotes `1. Subs. by Act 38 of 2003, s. 8, for sub-section (2) (w.e.f. 1-11-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12703&sectionno=9&orderno=9&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_9_content:
  string
  line `(1) No person`
  line `who produces, supplies, distributes or sells infant milk substitutes or feeding bottles or infant foods shall`
  line `offer or give, directly or indirectly, any financial inducements or gifts to a health worker or to any`
  line `member of his family for the purpose of promoting the use of such substitutes or bottles or foods.`
  line
  line `^1[(2) No producer, supplier or distributor referred to in sub-section (1), shall offer or give any`
  line `contribution or pecuniary benefit to a health worker or any association of health workers, including`
  line `funding of seminar, meeting, conference, educational course, contest, fellowship, research work or`
  line sponsorship.]
obj_root_law_sections_10:
  sectionId (12704)
  sectionNo (10)
  orderNo 10
  title `Special provision relating to employees of person who produces, supplies, distributes or sells infant milk substitutes, etc.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12704&sectionno=10&orderno=10&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_10_content:
  string
  line `(1) No person who produces, supplies, distributes or sells infant milk`
  line `substitutes or feeding bottles or infant foods shall fix the remuneration of any of his employees or give`
  line `any commission to such employees on the basis of the volume of sale of such substitutes or bottles or`
  line `foods made by such employees.`
  line
  line `(2) The employees of such person shall not perform any function which relates to educating a`
  line `pregnant woman or mother of an infant on pre-natal or post-natal care of the infant.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (12705)
  sectionNo (11)
  orderNo 11
  title `Standards of infant milk substitutes, feeding bottles or infant foods.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 34 of 2006, s. 100, for "the Prevention of Food Adulteration Act, 1954 (37 of 1954)" (w.e.f. 29-7-2010).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12705&sectionno=11&orderno=11&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_11_content:
  string
  line `(1) No person shall sell`
  line `or otherwise distribute any infant milk substitute or infant food unless it conforms to the standards,`
  line `specified for such substitute or food under ^1[the Food Safety and Standards Act, 2006], and the rules made`
  line `thereunder and the container thereof has the relevant Standard Mark specified by the Bureau of Indian`
  line `Standards established under section 3 of the Bureau of Indian Standards Act, 1986 (63 of 1986) to`
  line `indicate that the infant milk substitute or infant food conforms to such standards:`
  line
  line `Provided that where no standards have been specified for any infant milk substitute or infant food`
  line `under ^1[the Food Safety and Standards Act, 2006], no person shall sell or otherwise distribute such`
  line `substitute or food unless he has obtained the approval of the Central Government in relation to such`
  line `substitute or food and the label affixed to the container thereof under the rules made under that Act.`
  line
  line `(2) No person shall sell or otherwise distribute any feeding bottle unless it conforms to the Standard`
  line `Mark specified by the Bureau of Indian Standards referred to in sub-section (1) for feeding bottles and`
  line `such mark is affixed on its container.`
obj_root_law_sections_12:
  sectionId (12706)
  sectionNo (12)
  orderNo 12
  title `Powers of entry and search.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12706&sectionno=12&orderno=12&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_12_content:
  string
  line `(1) Any food inspector appointed under section 9 of the`
  line `Prevention of Food Adulteration Act, 1954 (37 of 1954) (hereinafter referred to as the food inspector) or`
  line `any officer not below the rank of a Class I officer authorised in this behalf by the State Government`
  line `(hereinafter referred to as the authorised officer) may, if he has any reason to believe that any provision of`
  line `section 6 or section 11 has been or is being contravened, enter and search at any reasonable time any`
  line `factory, building, business premises or any other place where any trade or commerce in infant milk`
  line `substitutes or feeding bottles or infant foods is carried on or such substitutes or bottles or foods are`
  line `produced, supplied or distributed.`
  line
  line `(2) The provisions of the Code of Criminal Procedure, 1973 (2 of 1974), relating to searches and`
  line `seizures shall, so far as may be, apply to every search or seizure made under this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (12707)
  sectionNo (13)
  orderNo 13
  title `Power to seize infant milk substitutes, etc., or containers thereof.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 34 of 2006, s. 100, for "Food Inspector" (w.e.f. 29-7-2010).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12707&sectionno=13&orderno=13&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_13_content:
  string
  line `(1) If any ^1[the Food`
  line `Safety Officer] or authorised officer has reason to believe that in respect of any infant milk substitute or`
  line `feeding bottle or infant food or container thereof, the provisions of this Act have been or are being`
  line `contravened, he may seize such substitute or bottle or food or container.`
  line
  line `(2) No such substitute or food or bottle or container shall be retained by any ^1[the Food Safety`
  line `Officer] or authorised officer for a period exceeding ninety days from the date of its seizure unless the`
  line `approval of the District Judge, within the local limits of whose jurisdiction such seizure has been made,`
  line `has been obtained for such retention.`
obj_root_law_sections_14:
  sectionId (12708)
  sectionNo (14)
  orderNo 14
  title Confiscation.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12708&sectionno=14&orderno=14&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_14_content:
  string
  line `Any infant milk substitute or feeding bottle or infant food or container thereof, in`
  line `respect of which any provision of this Act has been or is being contravened, shall be liable to`
  line `confiscation:`
  line
  line `Provided that where it is established to the satisfaction of the court adjudging the confiscation that the`
  line `person in whose possession, power or control any such substitute or bottle or food or container is found is`
  line `not responsible for the contravention of the provisions of this Act, the court may, instead of making an`
  line `order for the confiscation of such substitute or bottle or food or container, make such other order`
  line `authorised by this Act against the person guilty of the breach of the provisions of this Act as it may think`
  line fit.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (12709)
  sectionNo (15)
  orderNo 15
  title `Power to give option to pay cost in lieu of confiscation.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12709&sectionno=15&orderno=15&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_15_content:
  string
  line `(1) Whenever any confiscation is`
  line `authorised by this Act, the court adjudging it may, subject to such conditions as may be specified in the`
  line `order adjudging the confiscation, give to the owner thereof an option to pay in lieu of confiscation such`
  line `cost not exceeding the value of the infant milk substitute or feeding bottle or infant food or container`
  line `thereof in respect of which the confiscation is authorised as the court thinks fit.`
  line
  line `(2) On payment of the cost ordered by the court the seized infant milk substitute or feeding bottle or`
  line `infant food or container shall be returned to the person from whom it was seized on the condition that`
  line `such person shall, before making any distribution, sale or supply of such substitute or bottle or food or`
  line `container, give effect to the provisions of this Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (12710)
  sectionNo (16)
  orderNo 16
  title `Confiscation not to interfere with other punishments.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12710&sectionno=16&orderno=16&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_16_content:
  string
  line `No confiscation made or cost ordered`
  line `to be paid under this Act shall prevent the infliction of any punishment to which the person affected`
  line `thereby is liable under the provisions of this Act or under any other law.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (12711)
  sectionNo (17)
  orderNo 17
  title Adjudication.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12711&sectionno=17&orderno=17&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_17_content:
  string
  line `Any confiscation may be adjudged or costs may be ordered to be paid,--`
  line
  line `(a) without any limit, by the principal civil court of original jurisdiction within the local limits of`
  line `whose jurisdiction such confiscation has been made or costs have been ordered to be paid, as the case`
  line `may be;`
  line
  line `(b) subject to such limits as may be specified by the Central Government in this behalf, by such`
  line `other court, not below a civil court having pecuniary jurisdiction exceeding five thousand rupees, as`
  line `the Central Government may, by notification in the Official Gazette, authorise in this behalf.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (12712)
  sectionNo (18)
  orderNo 18
  title `Giving of opportunity to the owner of the seized infant milk substitute or feeding bottle or infant food or container thereof.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12712&sectionno=18&orderno=18&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_18_content:
  string
  line `(1) No order adjudicating confiscation or directing payment of costs`
  line `shall be made unless the owner of the infant milk substitute or feeding bottle or infant food or container`
  line `thereof has been given a notice in writing informing him of the grounds on which it is proposed to`
  line `confiscate such substitute or bottle or food or container and giving him a reasonable opportunity of`
  line `making a representation in writing, within such reasonable time as may be specified in the notice, against`
  line `the confiscation and if he so desires, of being heard in the matter:`
  line
  line `Provided that where no such notice is given within a period of ninety days from the date of the seizure`
  line `of the infant milk substitute or feeding bottle or infant food or container thereof, such substitute or bottle`
  line `or food or container shall be returned after the expiry of that period to the person from whose possession`
  line `it was seized.`
  line
  line `(2) Save as otherwise provided in sub-section (1), the provisions of the Code of Civil Procedure, 1908`
  line `(5 of 1908), shall, so far as may be, apply to every proceeding referred to in sub-section (1).`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (12713)
  sectionNo (19)
  orderNo 19
  title Appeal.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12713&sectionno=19&orderno=19&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_19_content:
  string
  line `(1) Any person aggrieved by any decision of the court adjudicating a confiscation or`
  line `ordering the payment of costs may prefer an appeal to the court to which an appeal lies from the decision`
  line `of such court.`
  line
  line `(2) The appellate court may, after giving the appellant an opportunity of being heard, pass such order`
  line `as it thinks fit confirming, modifying or revising the decision or order appealed against or may send back`
  line `the case with such directions as it may think fit for a fresh decision or adjudication, as the case may be,`
  line `after taking additional evidence if necessary:`
  line
  line `Provided that an order enhancing any fine in lieu of confiscation or for confiscating goods of greater`
  line `value shall not be made under this section unless the appellant has had an opportunity of making a`
  line `representation and if he so desires of being heard in his defence.`
  line
  line `(3) No further appeal shall lie against the order of the court made under sub-section (2).`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (12714)
  sectionNo (20)
  orderNo 20
  title Penalty.
  content obj_root_law_sections_20_content
  footnotes `1. Subs. by Act 38 of 2003, s. 9, for "section 11" (w.e.f. 1-11-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12714&sectionno=20&orderno=20&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_20_content:
  string
  line `(1) Any person who contravenes the provisions of section 3, 4, 5, 7, 8, 9, 10 or`
  line `sub-section (2) of ^1[section 11 and the rules made under section 26 of the Act] shall be punishable with`
  line `imprisonment for a term which may extend to three years, or with fine which may extend to five thousand`
  line `rupees, or with both.`
  line
  line `(2) Any person who contravenes the provisions of section 6 or sub-section (1) of ^1[section 11 and the`
  line `rules made under section 26 of the Act] shall be punishable with imprisonment for a term which shall not`
  line `be less than six months but which may extend to three years and with fine which shall not be less than`
  line `two thousand rupees:`
  line
  line `Provided that the court may, for any adequate and special reasons to be mentioned in the judgment,`
  line `impose a sentence of imprisonment for a term which shall not be less than three months but which may`
  line `extend to two years and with fine which shall not be less than one thousand rupees.`
obj_root_law_sections_21:
  sectionId (12715)
  sectionNo (21)
  orderNo 21
  title `Cognizance of offences.`
  content obj_root_law_sections_21_content
  footnotes `1. Subs. by Act 34 of 2006, s. 100, for clause (a) (w.e.f. 29-7-2010).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12715&sectionno=21&orderno=21&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_21_content:
  string
  line `(1) Save as otherwise provided in section 173 of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974), no court shall take cognizance of any offence punishable under this Act`
  line `except upon a complaint in writing made by--`
  line
  line `^1[(a) the Designated Officer or the Food Safety Officer directed under sub-section (5) of section`
  line `42 of the Food Safety and Standards Act, 2006 (34 of 2006); or]`
  line
  line `(b) an officer not below the rank of a Class I officer authorised in this behalf, by general or`
  line `special order, by the Government; or`
  line
  line `(c) a representative of such voluntary organisation engaged in the field of child welfare and`
  line `development and child nutrition as the Government may, by notification in the Official Gazette,`
  line `authorise in this behalf.`
  line
  line `(2) Where a complaint has been made by a representative of the voluntary organisation authorised`
  line `under clause (c) of sub-section (1) and the court has issued a summons or, as the case may be, a warrant`
  line `under sub-section (1) of section 204 of the Code of Criminal Procedure, 1973 (2 of 1974), the Assistant`
  line `Public Prosecutor for that court shall take charge of the case and conduct the prosecution.`
obj_root_law_sections_22:
  sectionId (12716)
  sectionNo (22)
  orderNo 22
  title `Offences by companies.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12716&sectionno=22&orderno=22&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_22_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who, at the time the offence was committed, was in charge of, and was`
  line `responsible to, the company for the conduct of the business of the company, as well as the company, shall`
  line `be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm of other association of`
  line `individuals; and`
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (12717)
  sectionNo (23)
  orderNo 23
  title `Offences to be cognizable and bailable.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12717&sectionno=23&orderno=23&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_23_content:
  string
  line `Notwithstanding anything contained in the Code of`
  line `Criminal Procedure, 1973 (2 of 1974), an offence punishable under this Act shall be--`
  line
  line `(a) bailable;`
  line
  line `(b) cognizable.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (12718)
  sectionNo (24)
  orderNo 24
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_24_content
  footnotes `1. Subs. by Act 38 of 2003, s. 10, for "or of any State Government" (w.e.f. 1-11-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12718&sectionno=24&orderno=24&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_24_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government or any State Government or any officer of the Central Government`
  line `^1[or a representative of such voluntary organisation which is notified under clause (c) of sub-section (1) of`
  line `section 21] for anything which is in good faith done or intended to be done under this Act.`
obj_root_law_sections_25:
  sectionId (12719)
  sectionNo (25)
  orderNo 25
  title `Application of Act 37 of 1954 not barred.`
  content obj_root_law_sections_25_content
  footnotes `1. Subs. by Act 34 of 2006, s. 100, for "the Prevention of Food Adulteration Act, 1954 (37 of 1954)" (w.e.f. 29-7-2010).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12719&sectionno=25&orderno=25&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_25_content:
  string
  line `The provisions of this Act, or the rules made`
  line `thereunder shall be in addition to, and not in derogation of, ^1[the Food Safety and Standards Act, 2006], or`
  line `the rules made thereunder.`
obj_root_law_sections_26:
  sectionId (12720)
  sectionNo (26)
  orderNo 26
  title `Power to make rules.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00006_199241_1517807323765&sectionId=12720&sectionno=26&orderno=26&orgactid=AC_CEN_13_14_00006_199241_1517807323765
obj_root_law_sections_26_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the conditions and restrictions subject to which educational equipment and other material may`
  line `be donated or distributed under the proviso to clause (b) of section 5;`
  line
  line `(b) the language in which the notice and other particulars shall be indicated under sub-section (1)`
  line `of section 6;`
  line
  line `(c) the particulars which are to be indicated under clause (i) of sub-section (1) of section 6;`
  line
  line `(d) the particulars which a container or label shall not bear under clause (d) of sub-section (2) of`
  line `section 6;`
  line
  line `(e) the matters to be included in the information which reaches pregnant women or mothers of`
  line `infants under clause (g) of sub-section (1) of section 7;`
  line
  line `(f) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each House`
  line `of Parliament, while it is in session, for a total period of thirty days which may be comprised in one`
  line `session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `शिशु दुग्ध अनुकल्प, पोषण बोतल और शिशुखाद्य (उत्पादन, प्रदाय और वितरणविनियम) अधिनियम, 1992`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1958/2/hH1992-41.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T12:39:44.746Z`
  pageCount 9
  sections obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
  obj_root_law_translations_hi_sections_3
  obj_root_law_translations_hi_sections_4
  obj_root_law_translations_hi_sections_5
  obj_root_law_translations_hi_sections_6
  obj_root_law_translations_hi_sections_7
