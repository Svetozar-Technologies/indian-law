obj_root_law_sections_1:
  sectionId (47406)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47406&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Geneva Conventions`
  line `Act, 1960.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 14th August, 1961, vide notification No. S.R.O. 222(E), dated 2nd August, 1961, see Gazette of India, Extraordinary, Part II,`
  line `sec. 4(ii).`
obj_root_law_sections_2:
  sectionId (47407)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47407&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Conventions" means the Conventions set out in the Schedules; and the First Convention, the`
  line `Second Convention, the Third Convention and the Fourth Convention mean the Conventions set out`
  line `in the First, Second, Third and Fourth Schedules, respectively;`
  line
  line `(b) "court" does not include a court-martial or military court;`
  line
  line `(c) "protected internee" means a person protected by the Fourth Convention and interned in India;`
  line
  line `(d) "protecting power", in relation to a protected internee or a protected prisoner of war, means`
  line `the power or organisation which is carrying out, in the interests of the power of which he is a national`
  line `or of whose forces he is or was at any material time a member, the duties assigned to protecting`
  line `powers under the Third Convention or, as the case may be, the Fourth Convention;`
  line
  line `(e) "protected prisoner of war" means a person protected by the Third Convention.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47408)
  sectionNo (3)
  orderNo 3
  title `Punishment of grave breaches of conventions.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47408&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_3_content:
  string
  line `(1) If any person within or without India`
  line `commits or attempts to commit, or abets or procures the commission by any other person of, a grave`
  line `breach of any of the Conventions he shall be punished,--`
  line
  line `(a) Where the offence involves the wilful killing of a person protected by any of the Conventions,`
  line `with death or with imprisonment for life; and`
  line
  line `(b) in any other case, with imprisonment for a term which may extend to fourteen years.`
  line
  line `(2) Sub-section (1) applies to persons regardless of their nationality or citizenship.`
  line
  line `(3) For the purposes of this section,--`
  line
  line `(a) a grave breach of the First Convention is a breach of that Convention involving an act referred`
  line `to in article 50 of that Convention committed against persons or property protected by`
  line `that Convention;`
  line
  line `(b) a grave breach of the Second Convention is a breach of that Convention involving an act`
  line `referred to in article 51 of that Convention committed against persons or property protected by`
  line `that Convention;`
  line
  line `(c) a grave breach of the Third Convention is a breach of that Convention involving an act`
  line `referred to in article 130 of that Convention committed against persons or property protected by that`
  line `Convention; and`
  line
  line `(d) a grave breach of the Fourth Convention is a breach of that Convention involving an act`
  line `referred to in article 147 of that Convention committed against persons or property protected by that`
  line Convention.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47409)
  sectionNo (4)
  orderNo 4
  title `Liability of persons for offences committed outside India.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47409&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_4_content:
  string
  line `When an offence under this Chapter`
  line `is committed by any person outside India, he may be dealt with in respect of such offence as if it had been`
  line `committed at any place within India at which he may be found.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47410)
  sectionNo (5)
  orderNo 5
  title `Jurisdiction of court.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47410&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_5_content:
  string
  line `No court inferior to that of a chief presidency magistrate or a Court of`
  line `Session shall try any offence punishable under this Chapter.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47411)
  sectionNo (6)
  orderNo 6
  title `Proof of application of Convention.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47411&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_6_content:
  string
  line `If in any proceeding under this Chapter in respect of a`
  line `grave breach of any of the Conventions a question arises under Article 2 of that Convention`
  line `(which relates to the circumstances in which the Convention applies), a certificate under the hand of a`
  line `Secretary to the Government of India certifying to any matter relevant to that question shall be conclusive`
  line `evidence of the matter so certified.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47412)
  sectionNo (7)
  orderNo 7
  title `Jurisdiction of courts martial.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47412&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_7_content:
  string
  line `The Army Act, 1950 (46 of 1950), the Air Force`
  line `Act, 1950 (45 of 1950), or the Navy Act, 1957 (62 of 1957), relating to trial by court-martial of persons`
  line `who commit civil offences shall have effect for the purposes of the jurisdiction of courts-martial as if this`
  line `Chapter had not been passed.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47413)
  sectionNo (8)
  orderNo 8
  title `Notice of trial of protected persons to be served on protecting power, etc.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47413&sectionno=8&orderno=8&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_8_content:
  string
  line `(1) The court`
  line `before which--`
  line
  line `(a) a protected prisoner of war is brought up for trial for any offence; or`
  line
  line `(b) a protected internee is brought up for trial for an offence for which that court has power to`
  line `sentence him to death or to imprisonment for a term of two years or more,`
  line
  line `shall not proceed with the trial until it is proved to the satisfaction of the court that a notice containing`
  line `the particulars mentioned in the next following sub-section, so far as they are known to the prosecutor,`
  line `has been served not less than three weeks previously on the protecting power`
  line `(if there is a protecting power) and, if the accused is a protected prisoner of war on the accused and the`
  line `prisoners' representative.`
  line
  line `(2) The particulars referred to in the foregoing sub-section are--`
  line
  line `(a) the full name and description of the accused, including the date of his birth and his profession`
  line `or trade, if any, and if the accused is a protected prisoner of war, his rank and arm, regimental,`
  line `personal or serial number;`
  line
  line `(b) his place of detention, internment or residence;`
  line
  line `(c) the offence with which he is charged; and`
  line
  line `(d) the court before which the trial is to take place and the time and place appointed for the trial.`
  line
  line `(3) For the purposes of this section a document purporting--`
  line
  line `(a) to be signed on behalf of the protecting power or by the prisoners representative or by the`
  line `person accused, as the case may be; and`
  line
  line `(b) to be an acknowledgment of the receipt by that power, representative or person on a specified`
  line `day of a notice described therein as a notice under this section,`
  line
  line `shall, unless the contrary is shown, be sufficient evidence that the notice required by sub-section (1)`
  line `was served on that power, representative or person on that day.`
  line
  line `(4) In this section, the expression "prisoners' representative" in relation to a particular protected`
  line `prisoner of war at a particular time means the person by whom the functions of prisoners' representative`
  line `within the meaning of article 79 of the Third Convention were exercisable in relation to that prisoner at`
  line `the camp or place at which that prisoner was, at or last before that time, detained as a protected prisoner`
  line `of war.`
  line
  line `(5) Any court which adjourns a trial for the purpose of enabling the requirements of this section to be`
  line `complied with may, notwithstanding anything in any other law, authorise the detention of the accused in`
  line `such custody as it may think fit for the period of the adjournment.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (47414)
  sectionNo (9)
  orderNo 9
  title `Legal re-presentation of certain persons.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47414&sectionno=9&orderno=9&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_9_content:
  string
  line `(1) The court before which--`
  line
  line `(a) any person is brought up for trial for an offence under section 3 of this Act; or`
  line
  line `(b) a protected prisoner of war is brought up for trial for any offence,`
  line
  line `shall not proceed with the trial unless--`
  line
  line `(i) the accused is represented by a legal practitioner; and`
  line
  line `(ii) it is proved to the satisfaction of the court that a period of not less than fourteen days has`
  line `elapsed since instructions for the representation of the accused at the trial were first given to the`
  line `legal practitioner,`
  line
  line `and if the court adjourns the trial for the purpose of enabling the requirements of this sub-section to be`
  line `complied with, then, notwithstanding anything in any other law, the Court may authorise the detention of`
  line `the accused in such custody as it may think fit for the period of the adjournment.`
  line
  line `(2) Where the accused is a protected prisoner of war, in the absence of a legal practitioner accepted by`
  line `the accused as representing him, the legal practitioner instructed for the purpose on behalf of the`
  line `protecting power shall, without prejudice to the requirements of clause (ii) of the foregoing sub-section,`
  line `be regarded for the purposes of that sub-section as representing the accused.`
  line
  line `(3) If the court adjourns the trial in pursuance of sub-section (1) by reason that the accused is not`
  line `represented by a legal practitioner, the court shall direct that a legal practitioner be assigned to watch over`
  line `the interests of the accused at any further proceedings in connection with the offence, and at any such`
  line `further proceedings, in the absence of a legal practitioner either accepted by the accused as representing`
  line `him or instructed as mentioned in the last foregoing sub-section, the legal practitioner assigned in`
  line `pursuance of this sub-section shall, without prejudice to the requirements of clause (ii) of sub-section (1),`
  line `be regarded for the purposes of that sub-section as representing the accused.`
  line
  line `(4) A legal practitioner shall be assigned in pursuance of sub-section (3) in such manner as may be`
  line `provided in the rules made under this Act or, in the absence of provisions in the rules, as the court directs,`
  line `and the legal practitioner so assigned shall be entitled to such fees as may be provided in the rules made`
  line `under this Act.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47415)
  sectionNo (10)
  orderNo 10
  title `Appeals by protected prisoners of war and internees.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47415&sectionno=10&orderno=10&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_10_content:
  string
  line `(1) Where a protected prisoner of war`
  line `or a protected internee has been sentenced by a court to death or to imprisonment for a term of two years`
  line `or more, any time allowed in relation to the institution of an appeal against the conviction or sentence`
  line `shall be deemed to continue to run until the day on which the convicted person receives a notice given,--`
  line
  line `(a) in the case of a protected prisoner of war----by an officer in the Armed Forces; or`
  line
  line `(b) in the case of a protected internee----by or on behalf of the governor or other person in charge`
  line `of the prison or place in which he is confined,`
  line
  line `that the protecting power has been notified of his conviction and sentence, and for such further time as`
  line `would have been within the time allowed if the conviction or sentence had taken place or been`
  line `pronounced on that day.`
  line
  line `(2) Where, after an appeal against the conviction or sentence by a court of a protected prisoner of war`
  line `or a protected internee has been decided, the sentence remains a sentence of death, or remains or has become a sentence of imprisonment for a term of two years or more, any time allowed in relation to a`
  line `further appeal in respect of the conviction or sentence as confirmed or varied upon the previous appeal`
  line `shall be deemed to continue to run until the day on which the convicted person receives a notice given by`
  line `a person referred to in clause (a) or clause (b) of the last preceding sub-section, as the case may require,`
  line `that the protecting power has been notified of the decision of the court upon the previous appeal, and for`
  line `such further time as would have been within the time allowed if that decision had been pronounced on`
  line `that day.`
  line
  line `(3) Where sub-section (1) applies in relation to a convicted person, then, unless the court otherwise`
  line `orders, an order of the court relating to the restitution of property or the payment of compensation to an`
  line `aggrieved person shall not take effect, and a provision of any law relating to the revesting of property on`
  line `conviction shall not take effect in relation to the conviction, while an appeal by the convicted person`
  line `against his conviction or sentence is possible without an extension of time other than the extension`
  line `provided by the last preceding sub-section.`
  line
  line `(4) Sub-sections (1), (2) and (3) shall not apply in relation to an appeal against a conviction or`
  line `sentence, or against the decision of a court upon a previous appeal, if, at the time of the conviction or`
  line `sentence, or of the decision of the court upon the previous appeal, as the case may be, there is no`
  line `protecting power.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (47416)
  sectionNo (11)
  orderNo 11
  title `Reduction of sentence and custody of protected prisoners of war and internees.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47416&sectionno=11&orderno=11&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_11_content:
  string
  line `(1) When a`
  line `protected prisoner of war or a protected internee is convicted of an offence, the court shall,--`
  line
  line `(a) in fixing a term of imprisonment in respect of the offence, deduct from the term which it`
  line `would otherwise have fixed any period during which the convicted person has been in custody in`
  line `connection with that offence before the trial; and`
  line
  line `(b) in fixing any penalty other than imprisonment in respect of the offence, take that period of`
  line `custody into account.`
  line
  line `(2) Where the Central Government is satisfied that a protected prisoner of war accused of an offence`
  line `has been in custody in connection with that offence, while awaiting trial, in a place other than a camp or`
  line `place in which protected prisoners of war are detained, for an aggregate period of not less than three`
  line `months, the Central Government may direct that the prisoner shall be transferred from that custody to the`
  line `custody of an officer of the Armed Forces of the Union and thereafter remain in military custody at a`
  line `camp or place in which protected prisoners of war are detained, and be brought before the court at the`
  line `time appointed for his trial.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (47417)
  sectionNo (12)
  orderNo 12
  title `Prohibition of use of Red Cross and other emblems.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47417&sectionno=12&orderno=12&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_12_content:
  string
  line `No person shall, without the approval of`
  line `the Central Government, use for any purpose whatsoever--`
  line
  line `(a) the emblem of a red cross with vertical and horizontal arms of the same length on, and`
  line `completely surrounded by, a white ground, or the designation "Red Cross" or "Geneva Cross";`
  line
  line `(b) the emblem of a red crescent moon on , and completely surrounded by, a white ground, or the`
  line `designation "Red Crescent";`
  line
  line `(c) the following emblem in red on, and completely surrounded by, a white ground, that is to say,`
  line `a lion passing from right to left of, and with its face turned towards, the observer, holding erect in its`
  line `raised right forepaw a scimitar, with, appearing above the lions back, the upper half of the sun`
  line `shooting forth rays, or the designation "Red Lion and Sun";`
  line
  line `(d) the emblem of a white or silver cross with vertical and horizontal arms of the same length on,`
  line `and completely surrounded by, a red ground, being the heraldic emblem of the Swiss`
  line `Confederation; or`
  line
  line `(e) any design or wording so nearly resembling any of the emblems or designations specified in`
  line `the preceding clauses of this section as to be capable of being mistaken for, or, as the case may be,`
  line `understood as referring to, one of those emblems.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (47418)
  sectionNo (13)
  orderNo 13
  title Penalty.
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47418&sectionno=13&orderno=13&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_13_content:
  string
  line `If any person contravenes any of the provisions of section 12, he shall be punishable`
  line `with fine which may extend to five hundred rupees, and be liable to forfeit any goods upon or in`
  line `connection with which the emblem, designation, design or wording was used by that person.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (47419)
  sectionNo (14)
  orderNo 14
  title `Offences by companies.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47419&sectionno=14&orderno=14&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_14_content:
  string
  line `(1) If the person committing an offence under this Chapter is a`
  line `company, the company as well as every person in charge of, and responsible to, the company for the`
  line `conduct of its business at the time of the commission of the offence shall be deemed to be guilty of the`
  line `offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that, nothing contained in this sub-section shall render any such person liable to any`
  line `punishment if he proves that the offence was committed without his knowledge or that he exercised all`
  line `due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Chapter has`
  line `been committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or that the commission of the offence is attributable to any neglect on the part of, any`
  line `director, manager, secretary or other officer of the company, such director, manager, secretary or other`
  line `officer shall also be deemed to be guilty of that offence and shall be liable to be proceeded against and`
  line `punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of`
  line `individuals, and`
  line
  line `(b) "director" in relation to a firm means a partner in the firm`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (47420)
  sectionNo (15)
  orderNo 15
  title Saving.
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47420&sectionno=15&orderno=15&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_15_content:
  string
  line `In the case of a trade mark registered before the coming into force of this Act, the`
  line `foregoing provisions of this Chapter shall not apply by reason only of its consisting of or containing a`
  line `design or wording which reproduces or resembles an emblem or designation specified in clause (b) or`
  line `clause (c) of section 12; and where a person is charged with using such a design or wording for any`
  line `purpose and it is proved that he used it otherwise than as, or as part of, a trade mark so registered, it shall`
  line `be a defence for him to prove--`
  line
  line `(a) that he lawfully used that design or wording for that purpose before the coming into force of`
  line `this Act; or`
  line
  line `(b) in a case where he is charged with using the design or wording upon goods, that the design or`
  line `wording had been applied to the goods before he acquired them by some other person who had`
  line `manufactured or dealt with the goods in the course of trade and who lawfully used the design or`
  line `wording upon similar goods before the coming into force of this Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (47421)
  sectionNo (16)
  orderNo 16
  title `Use of „Red Cross‟ and other emblems on Indian ship or aircraft.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47421&sectionno=16&orderno=16&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_16_content:
  string
  line `The provisions of this`
  line `Chapter extend to the use in or outside India of any emblem, designation, design or wording as is referred`
  line `to in section 12 on any Indian ship or aircraft.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (47422)
  sectionNo (17)
  orderNo 17
  title `Cognizance of offences.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47422&sectionno=17&orderno=17&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_17_content:
  string
  line `No court shall take cognizance of any offence under this Act except on`
  line `complaint by the Government or of such officer of the Government as the Central Government may, by`
  line `notification in the Official Gazette, specify.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (47423)
  sectionNo (18)
  orderNo 18
  title `Power to make rules.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47423&sectionno=18&orderno=18&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_18_content:
  string
  line `The Central Government may, by notification in the Official Gazette,`
  line `make rules for the purpose of carrying into effect the provisions of this Act.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (47424)
  sectionNo (19)
  orderNo 19
  title `Rules to be laid before Parliament.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47424&sectionno=19&orderno=19&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_19_content:
  string
  line `Every rule made by the Central Government under this`
  line `Act shall be laid as soon as may be after it is made or issued before each House of Parliament while it is`
  line `in session for a total period of thirty days which may be comprised in one session or in two successive`
  line `sessions, and if before the expiry of the session in which it is so laid or the session immediately following,`
  line `both Houses agree in making any modification in the rule or both Houses agree that the rule should not be`
  line `made, the rule shall thereafter have effect only in such modified form or be of no effect, as the case may`
  line `be, so however that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that rule.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (47425)
  sectionNo (20)
  orderNo 20
  title Repeal.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00004_196006_1517807318923&sectionId=47425&sectionno=20&orderno=20&orgactid=AC_CEN_10_10_00004_196006_1517807318923
obj_root_law_sections_20_content:
  string
  line `(1) The Geneva Convention Implementing Act, 1936 (14 of 1936), is hereby repealed.`
  line
  line `(2) The Geneva Convention Act, 1911 (1 and 2 Geo. 5, C. 20), shall cease to have effect as part of the`
  line `law of India.`
obj_root_law_sections_20_footnotes:
  string
  line
