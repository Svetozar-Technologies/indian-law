obj_root_law_sections_1:
  sectionId (4616)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4616&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Public Debt ^1***`
  line `Act, 1944.`
  line
  line `^2* * * * *`
  line
  line `(3) It shall come into force on such date^3`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint in this behalf.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The brackets and words "(Central Government)" omitted by Act 6 of 1949, s. 3 (w.e.f. 1-4-1949).`
  line
  line `2. Sub-section (2) omitted by Act 57 of 1956, s. 3 (w.e.f. 15-10-1956).`
  line
  line `3. 1st May, 1946, see Gazette of India, 1946, Pt. I. p. 575.`
obj_root_law_sections_1_a:
  sectionId (4617)
  sectionNo 1A
  orderNo 2
  title `Securities to which this Act applies.`
  content obj_root_law_sections_1_a_content
  footnotes obj_root_law_sections_1_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4617&sectionno=1A&orderno=2&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_1_a_content:
  string
  line `^1[1A. Securities to which this Act applies.--This Act applies to Government securities`
  line `created and issued whether before or after the commencement of this Act by the Central`
  line `Government or a State Government ^2***.]`
obj_root_law_sections_1_a_footnotes:
  string
  line `1. Ins. by Act 57 of 1956, s. 4 (w.e.f. 15-10-1956).`
  line
  line `2. The words "other than the Government of Jammu and Kashmir" omitted by Act 44 of 1972, s. 2 (w.e.f. 1-9-1972).`
obj_root_law_sections_2:
  sectionId (4618)
  sectionNo (2)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4618&sectionno=2&orderno=3&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context,--`
  line
  line `(1) "the Bank" means the Reserve Bank of India;`
  line
  line `^1[(1A) "the Government", in relation to any Government security, means the Central or State`
  line `Government issuing the security;]`
  line
  line `(2) "Government security" means--`
  line
  line `(a) a security, created and issued, ^2[by the Government] for the purpose of raising a public`
  line `loan, and having one of the following forms, namely :--`
  line
  line `(i) stock transferable by registration in the books of the Bank; or`
  line
  line `(ii) a promissory note payable to order; or`
  line
  line `(iii) a bearer bond payable to bearer; or`
  line
  line `(iv) a form prescribed in this behalf;`
  line
  line `(b) any other security created and issued by ^3[the Government] in such form and`
  line `for such of the purposes of this Act as may be prescribed;`
  line
  line `(3) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(4) "promissory note" includes a treasury bill.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Ins. by Act 6 of 1949, s. 4 (w.e.f. 1-4-1949).`
  line
  line `2. Subs. by Act 57 of 1956, s. 5, for certain words (w.e.f. 15-10-1956).`
  line
  line `3. Subs. by Act 57 of 1956, s. 5, for certain words (w.e.f. 15-10-1956)`
obj_root_law_sections_3:
  sectionId (4619)
  sectionNo (3)
  orderNo 4
  title `Transfer of Government securities.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4619&sectionno=3&orderno=4&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_3_content:
  string
  line `(1)`
  line `^1[Subject to the provisions of section 5, a`
  line `transfer of a Government security shall be made only in the manner prescribed for the making`
  line `of transfers of securities of the class to which it belongs, and no transfer of a Government`
  line `security which--`
  line
  line `(i) is made after the 30th April, 1946, in the case of a security issued by the Central Government,`
  line
  line `(ii) is made after the 31st March, 1949, in the case of a security issued by the`
  line `Government of a Part A State,`
  line
  line `(iii) is made after the 14th October, 1956, in the case of a security issued by the`
  line `Government of a Part B State other than Jammu and Kashmir, ^2***`
  line
  line `(iv) is made on or after the 1st day of November, 1956, in the case of a security issued`
  line `on or after that day by the Government of any State other than Jammu and Kashmir*,`
  line ^3[and]
  line
  line `^4[(v) is made on or after the 1st day of September, 1972, in the case of a securit y`
  line `issued on or after that day by the Government of the State of Jammu and Kashmir,]`
  line
  line `shall be valid if--]`
  line
  line `(a) it does not purport to convey the full title to the security, or`
  line
  line `(b) it is of such a nature as to affect the manner in which the security was expressed by ^5[the`
  line `Government] to be held.`
  line
  line `(2) Nothing in this section shall affect any order made by the Bank under this Act, or any order made`
  line `by a Court upon the Bank.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for the opening paragraph.`
  line
  line `2. The word "and" omitted by Act 44 of 1972, s. 3 (w.e.f. 1-9-1972).`
  line
  line `3. Added by s. 3, ibid. (w.e.f. 1-9-1972).`
  line
  line `4. Ins. by s. 3, ibid. (w.e.f. 1-9-1972).`
  line
  line `5. Subs. by Act 6 of 1949, s. 6, for "the Central Government" (w.e.f. 1-4-1949).`
  line
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory`
  line `of Jammu and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_4:
  sectionId (4620)
  sectionNo (4)
  orderNo 5
  title `Transfer or of Government securities not liable for amount thereof.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4620&sectionno=4&orderno=5&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_4_content:
  string
  line Notwithstanding
  line `anything contained in the Negotiable Instruments Act, 1881 (26 of 1881), a person shall not, by`
  line `reason only of his having transferred a Government security, be liable to pay any money due`
  line `either as principal or as interest thereunder.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (4621)
  sectionNo (5)
  orderNo 6
  title `Holding of Government securities by holders of public offices.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by Act 6 of 1949, s. 6, for "the Central Government" (w.e.f. 1-4-1949).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4621&sectionno=5&orderno=6&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_5_content:
  string
  line `(1) In the case of any`
  line `public office to which ^1[the Government] may, by notification in the Official Gazette, declare`
  line `this sub-section to apply, a Government security in the form of stock or of a promissory note`
  line `may be held in the name of the office.`
  line
  line `(2) When a Government security is so held, it shall be deemed to be transferred without`
  line `any or further endorsement or transfer deed from each holder of the office to the succeeding`
  line `holder of the office on and from the date on which the latter takes charge of the office.`
  line
  line `(3) When the holder of the office transfers to a party not being his successor in office`
  line `a Government security so held, the transfer shall be made by the signature of the holder of the`
  line `office and the name of the office in the manner and subject to the conditions laid down in section 3.`
  line
  line `(4) This section applies as well to an office of which there are two or more joint holders as to an`
  line `office of which there is a single holder.`
obj_root_law_sections_6:
  sectionId (4622)
  sectionNo (6)
  orderNo 7
  title `Notice of trust not receivable.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by Act 6 of 1949, s. 6, for "the Central Government" (w.e.f. 1-4-1949).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4622&sectionno=6&orderno=7&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_6_content:
  string
  line `(1) No notice of any trust in respect of any Government security`
  line `shall be receivable by ^1[the Government], nor shall ^1[the Government], be bound by any such notice even`
  line `though expressly given, nor shall ^1[the Government], be regarded as a trustee in respect of any`
  line `Government security.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Bank may, as an act of grace`
  line `and without any liability to the Bank or to ^1[the Government], record in its books such`
  line `directions by the holder of stock for the payment of interest on, or of the maturity value of, or`
  line `the transfer of, or such other matters relating to, the stock as the Bank thinks fit.`
obj_root_law_sections_7:
  sectionId (4623)
  sectionNo (7)
  orderNo 8
  title `Persons whose title to a Government security of a deceased sole holder may be recognised by the Bank.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4623&sectionno=7&orderno=8&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_7_content:
  string
  line `Subject to the provisions of section 9 the executors or administrators of a deceased`
  line `sole holder of a Government security and the holder of a succession certificate issued under Part X of`
  line `the Indian Succession Act, 1925 (39 of 1925) shall be the only persons who may be recognised by the`
  line `Bank as having any title to the Government security:`
  line
  line `Provided that nothing in this section shall bar the recognition by the Bank of the manager or`
  line `the sole surviving male member of a Hindu undivided family governed by the Mitakshara Law as`
  line `having a title to a Government security, when the security appears to the Bank to stand in the name`
  line `of a deceased member of the family and an application is made by such manager or sole surviving`
  line `member for recognition of his title and is supported by a certificate signed by such authority and`
  line `after such inquiry as may be prescribed to the effect that the deceased belonged to a Hindu`
  line `undivided family governed by the Mitakshara Law, that the Government security formed part of`
  line `the joint property of the family, and that the applicant is the managing or sole surviving male`
  line `member of the family.`
  line
  line `Explanation. --The expression "Hindu undivided family governed by the Mitakshara Law" shall, for`
  line `the purposes of this section, be deemed to include a Malabar tarwad.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (4624)
  sectionNo (8)
  orderNo 9
  title `Right of survivors of joint holders or several payees.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4624&sectionno=8&orderno=9&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_8_content:
  string
  line `Notwithstanding anything contained in`
  line `section 45 of the Indian Contract Act, 1872 (9 of 1872),--`
  line
  line `(a) when a Government security is held by two or more persons jointly and either or any`
  line `of them dies, the title to the security shall vest in the survivor or survivors of those persons,`
  line and
  line
  line `(b) when a Government security is payable to two or more persons severally and either or`
  line `any of them dies, the security shall be payable to the survivor or survivors of those persons or`
  line `to the representative of the deceased or to any of them:`
  line
  line `Provided that nothing contained in this section shall effect any claim which any representative of a`
  line `deceased person may have against the survivor or survivors under or in respect of any security to which`
  line `this section applies.`
  line
  line `Explanation.-- For the purposes of this section ^1[a body incorporated or deemed to be`
  line `incorporated under the Companies Act, 1956 (1 of 1956)], or the Co-operative Societies Act, 1912`
  line `(2 of 1912), or any other enactment for the time being in force whether within or without ^2[India],`
  line `relating to the incorporation of associations of individuals, shall be deemed to die when it is`
  line dissolved.
obj_root_law_sections_8_footnotes:
  string
  line `1. Subs. by Act 57 of 1956, s. 7, for "a body incorporated under the Indian Companies Act, 1913 (7 of 1913)" (w.e.f. 15-10-1956).`
  line
  line `2. Subs. by the A.O. 1950, for "the Provinces".`
obj_root_law_sections_9:
  sectionId (4625)
  sectionNo (9)
  orderNo 10
  title `Summary procedure on death of holder of Government securities not exceeding five thousand rupees face value.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4625&sectionno=9&orderno=10&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_9_content:
  string
  line `Notwithstanding anything contained in section 7, if within six`
  line `months of the death of a person who was the holder of a Government security or securities the face value of which does not in the aggregate exceed five thousand rupees, probate of his will or letters`
  line `of administration of his estate or a succession certificate issued under Part X of the Indian`
  line `Succession Act, 1925 (39 of 1925), is not produced to the Bank, or proof to the satisfaction of the`
  line `Bank that proceedings have been instituted to obtain one of these is not furnished, the Bank may`
  line `determine who is the person entitled to the security or securities, or to administer the estate of the`
  line `deceased and may make an order vesting the security or securities in the person so determined.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_9_a:
  sectionId (4626)
  sectionNo 9A
  orderNo 11
  title `Application of sections 9B, 9C, etc.`
  content obj_root_law_sections_9_a_content
  footnotes `1. Ins. by Act 44 of 1959, s. 2 (w.e.f. 1-8-1960).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4626&sectionno=9A&orderno=11&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_9_a_content:
  string
  line `^1[9A. Application of sections 9B, 9C, etc.--Notwithstanding anything contained in section 1A,`
  line `the provisions of sections 9B and 9C and the power to make rules in relation to any of the matters`
  line `referred to in sections 9B and 9C shall apply only to such classes of Government securities created`
  line `and issued by the Central Government, whether before or after the commencement of the Public Debt`
  line `(Amendment) Act, 1959 (44 of 1959), as that Government may, by notification in the Official`
  line `Gazette, specify, and in relation to such classes of securities the provisions of sections 7 and 9 shall`
  line `have effect subject to the provisions contained in sections 9B and 9C.]`
obj_root_law_sections_9_b:
  sectionId (4627)
  sectionNo 9B
  orderNo 12
  title `Nominations by holders of Government securities.`
  content obj_root_law_sections_9_b_content
  footnotes `1. Ins. by Act 44 of 1959, s. 2 (w.e.f. 1-8-1960).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4627&sectionno=9B&orderno=12&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_9_b_content:
  string
  line `^1[9B. Nominations by holders of Government securities.--(1) Notwithstanding anything`
  line `contained in any law for the time being in force or any disposition, whether testamentary or`
  line `otherwise, in respect of a Government security, where a nomination made in the prescribed`
  line `manner purports to confer on any person the right to receive payment of the amount for the time`
  line `being due on the security on the death of the holder thereof, the nominee shall, on the death of the`
  line `holder of the security, become entitled to the security and to payment thereon to the exclusion of`
  line `all other persons, unless the nomination is varied or cancelled in the prescribed manner.`
  line
  line `(2) Any nomination referred to in sub-section (1) shall become void if the nominee`
  line `predeceases, or where there are two or more nominees all the nominees predecease, the holder`
  line `of the security making the nomination.`
  line
  line `(3) A transfer of a Government security made in the prescribed manner shall automatically cancel a`
  line `nomination previously made :`
  line
  line `Provided that where a Government security is held by or on behalf of any person as a`
  line `pledgee or by way of security for any purpose, such holding shall not have the effect of`
  line `cancelling a nomination, but the right of the nominee shall be subject to the right of the person`
  line `so holding it.`
  line
  line `(4) Where the nominee is a minor it shall be lawful for the holder of a security to appoint in`
  line `the prescribed manner any person to receive the amount for the time being due on the security in`
  line `the event of his death during the minority of the nominee, and, where any such appointment has`
  line `been made, the Government security shall, after the death of the holder and during the minority`
  line `of the nominee, be deemed to be vested in that person as representing the minor.]`
obj_root_law_sections_9_c:
  sectionId (4628)
  sectionNo 9C
  orderNo 13
  title `Payment on death of holder.`
  content obj_root_law_sections_9_c_content
  footnotes `1. Ins. by Act 44 of 1959, s. 2 (w.e.f. 1-8-1960).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4628&sectionno=9C&orderno=13&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_9_c_content:
  string
  line `^1[9C. Payment on death of holder.--(1) If a person dies and he is at the time of his death the`
  line `holder of a Government security and there is in force at the time of his death a nomination in favour of`
  line `any person, the amount for the time being due on the security shall be paid to the nominee.`
  line
  line `(2) Where the nominee is a minor, the amount for the time being due on the Government security`
  line `shall be paid--`
  line
  line `(a) in any case where a person has been appointed to receive it under sub-section (4) of`
  line `section 9B, to that person; and`
  line
  line `(b) where there is no such person, to the guardian of the minor for the use of the minor.`
  line
  line `(3) Where the amount due for the time being on a Government security is payable to two or`
  line `more nominees and either or any of them is dead, the title to the security shall vest in the survivor`
  line `or survivors of those nominees and the amount for the time being due thereon shall be paid`
  line accordingly.
  line
  line `(4) Nothing contained in this section shall be deemed to require any person to accept`
  line `payment of the amount due on a Government security before it has reached maturity or otherwise`
  line `than in accordance with the terms of the security.`
  line
  line `(5) Any payment made in accordance with the provisions of this section of the amount due for the`
  line `time being on a Government security shall be a full discharge in respect of the security:`
  line
  line `Provided that nothing contained in this section or in section 9B shall affect any right or`
  line `claim which any person may have against the person to whom any payment is made under`
  line `this section.]`
obj_root_law_sections_10:
  sectionId (4629)
  sectionNo (10)
  orderNo 14
  title `Government securities not exceeding five thousand rupees face value belonging to minor or insane person.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4629&sectionno=10&orderno=14&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_10_content:
  string
  line `When a Government security or securities belong to a minor or a`
  line `person who is insane and incapable of managing his affairs and the face value of the security`
  line `or securities does not in the aggregate exceed five thousand rupees, the Bank may make such`
  line `order as it thinks fit for the vesting of such security or securities in such person as it considers`
  line `represents the minor or insane person.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (4630)
  sectionNo (11)
  orderNo 15
  title `Issue of duplicate securities and of new securities on conversion, consolidation, sub-division or renewal.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 6 of 1949, s. 6, for "the Central Government" (w.e.f. 1-4-1949).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4630&sectionno=11&orderno=15&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_11_content:
  string
  line `(1) If the person entitled to a Government security applies to the`
  line `Bank alleging that the security has been lost, stolen or destroyed, or has been defaced or`
  line `mutilated, the Bank may, on proof to its satisfaction of the loss, theft, destruction, defacement or`
  line `mutilation of the security, subject to such conditions and on payment of such fees as may be`
  line `prescribed, order the issue of a duplicate security payable to the applicant.`
  line
  line `(2) If the person entitled to a Government security applies to the Bank to have the security`
  line `converted into a security of another form, or into a security issued in connection with another`
  line `loan or to have it consolidated with other like securities, or to have it sub -divided, or to have it`
  line `renewed, the Bank may, subject to such conditions and on payment of such fees as may be`
  line `prescribed, cancel the security and order the issue of a new security or securities.`
  line
  line `(3) The person to whom a duplicate security or a new security is issued under this section`
  line `shall be deemed for the purposes of section 19 to have been recognised by the Bank as the`
  line `holder of the security; and a duplicate security or new security so issued to any person shall be`
  line `deemed to constitute a new contract between ^1[the Government] and such person and all`
  line `persons deriving title thereafter through him.`
obj_root_law_sections_12:
  sectionId (4631)
  sectionNo (12)
  orderNo 16
  title `Summary determination by the Bank of title to Government security in case of dispute.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4631&sectionno=12&orderno=16&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_12_content:
  string
  line `(1) If the Bank is of opinion that a doubt exists as to the title to a Government security,`
  line `it may proceed to determine the person who shall for the purposes of the Bank be deemed to be`
  line `the person entitled thereto.`
  line
  line `(2) The Bank shall give notice in writing to each claimant of whom it has knowledge, stating`
  line `the names of all other claimants and the time when and the officer of the Bank by whom the`
  line `determination of the Bank will be made.`
  line
  line `(3) The Bank shall give notice in writing to each claimant of the result of the determination`
  line `so made.`
  line
  line `(4) On the expiry of six months from the issue of the notices referred to in sub -section (3),`
  line `the Bank may make an order vesting in the person, found by the Bank to be entitled to the`
  line `security, the security and any unpaid interest thereon.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (4632)
  sectionNo (13)
  orderNo 17
  title `Law applicable in regard to Government securities.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4632&sectionno=13&orderno=17&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_13_content:
  string
  line `Notwithstanding that as a matter of`
  line `convenience ^1[the Government] may have arranged for payments on a Government security to be made`
  line `elsewhere than in ^2[India], the rights of all persons in relation to Government securities shall be`
  line `determined in connection with all such questions as are dealt with by this Act by the law and in the Courts`
  line `of ^3[India].`
obj_root_law_sections_13_footnotes:
  string
  line `1. Subs. by Act 6 of 1949, s. 6, for "the Central Government" (w.e.f. 1-4-1949).`
  line
  line `2. Subs. by Act 57 of 1956, s. 8, for "Part a States and Part C States" (w.e.f. 15-10-1956).`
  line
  line `3. Subs. s. 8, ibid., for "those States" (w.e.f. 15-10-1956).`
obj_root_law_sections_14:
  sectionId (4633)
  sectionNo (14)
  orderNo 18
  title `Recording of evidence.`
  content obj_root_law_sections_14_content
  footnotes `1. The words and letter "or in a Part B State the Political Agent" omitted by s. 9, ibid. (w.e.f. 15-10-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4633&sectionno=14&orderno=18&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_14_content:
  string
  line `(1) For the purpose of making any order which it is`
  line `empowered to make under this Act, the Bank may request a District Magistrate ^1*** to`
  line `record or to have recorded the whole or any part of such evidence as any person whose evidence the Bank requires may produce. A District Magistrate so requested may himself record, or`
  line `may direct any Magistrate of the first class subordinate to him or any Magistrate of the second`
  line `class subordinate to him and empowered in this behalf by gereral or special order of the State`
  line `Government to record the evidence, and shall forward a copy thereof to the Bank.`
  line
  line `(2) For the purpose of making a vesting order under this Act the Bank may direct one of its officers to`
  line `record the evidence of any person whose evidence the Bank requires or may receive evidence upon`
  line affidavit.
  line
  line `(3) A Magistrate or an officer of the Bank acting in pursuance of this section may administer an oath`
  line `to any witness examined by him.`
obj_root_law_sections_15:
  sectionId (4634)
  sectionNo (15)
  orderNo 19
  title `Postponement of payments and registration of transfers pending the making of a vesting order.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4634&sectionno=15&orderno=19&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_15_content:
  string
  line `Where the Bank contemplates making an order under this Act to vest a`
  line `Government security in any person, the Bank may suspend payment of interest on or the maturity`
  line `value of the security or postpone the making of any order under section 11 or the registration of`
  line `any transfer of the security until the vesting order has been made.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (4635)
  sectionNo (16)
  orderNo 20
  title `Power of Bank to require bonds.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4635&sectionno=16&orderno=20&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_16_content:
  string
  line `(1) Before making any order which it is empowered`
  line `to make under this Act, the Bank may require the person in whose favour the order is to be made`
  line `to execute a bond with one or more sureties in such form as may be prescribed or to furnish`
  line `security not exceeding twice the value of the subject-matter of the order, to be held at the`
  line `disposal of the Bank, to pay to the Bank or any person to whom the Bank may assign the bond or`
  line `security in furtherance of sub-section (2) the amount thereof.`
  line
  line `(2) A Court before which a claim in respect of the subject-matter of any such order is`
  line `established may order the bond or security to be assigned to the successful claimant who shall`
  line `thereupon be entitled to enforce the bond or realise the security to the extent of such claim.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (4636)
  sectionNo (17)
  orderNo 21
  title `Publication of notices in Official Gazette.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by Act 6 of 1949, s. 7, for "the Official Gazette" (w.e.f. 1-4-1949).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4636&sectionno=17&orderno=21&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_17_content:
  string
  line `Any notice required to be given by the`
  line `Bank under this Act may be served by post, but every such notice shall also be published by the`
  line `Bank in ^1[the Gazette of India or the Official Gazette of the State, according as the notice relates`
  line `to a security, issued by the Central Government or a State Government], and on such publication`
  line `shall be deemed to have been delivered to all persons for whom it is intended.`
obj_root_law_sections_18:
  sectionId (4637)
  sectionNo (18)
  orderNo 22
  title `Scope of vesting order.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4637&sectionno=18&orderno=22&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_18_content:
  string
  line `An order made by the Bank under this Act may confer the full`
  line `title to a Government security or may confer a title only to the accrued and accruing interest on`
  line `the security pending a further order vesting the full title.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (4638)
  sectionNo (19)
  orderNo 23
  title `Legal effect of orders made by the Bank.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by s. 6, ibid., for "the Central Government" (w.e.f. 1-4-1949)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4638&sectionno=19&orderno=23&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_19_content:
  string
  line `No recognition by the Bank of a person`
  line `as the holder of a Government security, and no order made by the Bank under this Act shall be`
  line `called in question by any Court so far as such recognition or order affects the relations of`
  line `^1[the Government] or the Bank with the person recognised by the Bank as the holder of a`
  line `Government security or with any person claiming an interest in such security, and any such`
  line `recognition by the Bank of any person or any order by the Bank vesting a Government`
  line `security in any person shall operate to confer on tha t person a title to the security subject only`
  line `to a personal liability to the rightful owner of the security for money had and received on his`
  line account.
obj_root_law_sections_20:
  sectionId (4639)
  sectionNo (20)
  orderNo 24
  title `Stay of proceedings on order of Court.`
  content obj_root_law_sections_20_content
  footnotes `1. Subs. by Act 57 of 1956, s. 10, for "a Part A State or a Part C State" (w.e.f. 15-10-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4639&sectionno=20&orderno=24&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_20_content:
  string
  line `Where the Bank contemplates making with`
  line `reference to any Government security any order which it is empowered to make under this Act, and`
  line `before the order is made the Bank receives from a Court in ^1[India] an order to stay the making of such`
  line `order, the Bank shall either--`
  line
  line `(a) hold the security together with any interest unpaid or accruing thereon until the further orders`
  line `of the Court are received, or`
  line
  line `(b) apply to the Court to have the security transferred to the Official Trustees`
  line `appointed for the State in which such Court is situated, pending the dispo sal of the`
  line `proceedings before the Court.`
obj_root_law_sections_21:
  sectionId (4640)
  sectionNo (21)
  orderNo 25
  title `Cancellation by the Bank of vesting proceedings.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4640&sectionno=21&orderno=25&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_21_content:
  string
  line `Where the Bank contemplates making`
  line `an order under this Act vesting a Government security in any person the Bank may, at any time`
  line `before the order is made, cancel any proceedings already taken for that purpose and may, on such`
  line `cancellation, proceed anew to the making of such order.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (4641)
  sectionNo (22)
  orderNo 26
  title `Discharge in respect of interest on Government securities.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4641&sectionno=22&orderno=26&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_22_content:
  string
  line `Save as otherwise expressly`
  line `provided in the terms of a Government security, no person shall be entitled to claim interest on`
  line `such security in respect of any period which has elapsed after the earliest date on which demand`
  line `could have been made for the payment of the amount due on such security.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (4642)
  sectionNo (23)
  orderNo 27
  title `Discharge in respect of bearer bonds.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4642&sectionno=23&orderno=27&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_23_content:
  string
  line `^1[The Government] shall be discharged from`
  line `all liability on a bearer bond or on any interest coupon of such a bond on payment to the holder`
  line `of such bond or coupon on presentation on or after the date when it becomes due of the amount`
  line `expressed therein, unless before such payment an order of a Court in ^2[India] has been served on`
  line `^1[the Government] restraining it from making payment.`
obj_root_law_sections_23_footnotes:
  string
  line `1. Subs. by Act 6 of 1949, s. 6, for "The Central Government" (w.e.f. 1-4-1949).`
  line
  line `2. Subs. by Act 57 of 1956, s. 11, for "the States" (w.e.f. 15-10-1956).`
obj_root_law_sections_24:
  sectionId (4643)
  sectionNo (24)
  orderNo 28
  title `Period of limitation of Government’s liability in respect of interest.`
  content obj_root_law_sections_24_content
  footnotes `1. Subs. by Act 6 of 1949, s. 6, for "The Central Government" (w.e.f. 1-4-1949).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4643&sectionno=24&orderno=28&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_24_content:
  string
  line `Where no`
  line `shorter period of limitation is fixed by any law for the time being in force, the liability of`
  line `^1[the Government] in respect of any interest payment due on a Government security shall`
  line `terminate on the expiry of six years from the date on which the amount due by way of interest`
  line `became payable.`
obj_root_law_sections_25:
  sectionId (4644)
  sectionNo (25)
  orderNo 29
  title `Inspection of documents.`
  content obj_root_law_sections_25_content
  footnotes `1. Subs. by Act 6 of 1949, s. 6, for "The Central Government" (w.e.f. 1-4-1949).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4644&sectionno=25&orderno=29&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_25_content:
  string
  line `No person shall be entitled to inspect, or to receive`
  line `information derived from any Government security in the possession or custody of ^1[the`
  line `Government] or from any book, register, or other document kept or maintained by or on behalf`
  line `of ^1[the Government] in relation to Government securities or any Government security, save in`
  line `such circumstances and manner and subject to such conditions as may be prescribed.`
obj_root_law_sections_26:
  sectionId (4645)
  sectionNo (26)
  orderNo 30
  title `The Bank and its officers to be deemed public officers.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4645&sectionno=26&orderno=30&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_26_content:
  string
  line `For the purposes of section`
  line `124 of the Indian Evidence Act, 1872 (1 of 1872), the provisions of Part IV of the Code of Civil`
  line `Procedure, 1908 (5 of 1908), relating to suits by or against public officers in their official`
  line `capacity, and the provisions of rule 27 of Order V, and rule 52 of Order XXI of the said Code,`
  line `the Bank and any officer of the Bank acting in his capacity as such shall be deemed to be a`
  line `public officer.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (4646)
  sectionNo (27)
  orderNo 31
  title Penalty.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4646&sectionno=27&orderno=31&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_27_content:
  string
  line `[Penalty.] Omitted. by the Jan Vishwas (Amendment of Provisions) Act, 2023(18 of 2023), s. 2`
  line `and the Schedule (w.e.f. 31-7-2024).`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (4647)
  sectionNo (28)
  orderNo 32
  title `Power to make rules.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4647&sectionno=28&orderno=32&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_28_content:
  string
  line `(1) The Central Government may, subject to the condition of`
  line `previous publication, by notification in the Official Gazette, make rules to carry out the`
  line `purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power such rules may`
  line `provide for all or any of the following matters, namely : --`
  line
  line `(a) the forms in which Government securities may be issued;`
  line
  line `(b) the form of the obligations referred to in clause (iv) of sub-clause (a) of clause (2) of`
  line `section 2;`
  line
  line `(c) the conditions subject to which Government securities may be issued to the ^1[Rulers of former`
  line `Indian States];`
  line
  line `(d) the manner in which different forms of Government securities may be transferred;`
  line
  line `(e) the holding of Government securities in the form of stock by the holders of offices other`
  line `than public offices, and the manner in which and the conditions subject to which Government`
  line `securities so held may be transferred;`
  line
  line `(f) the manner in which payment of interest in respect of Government securities is to be made and`
  line acknowledged;
  line
  line `(g) the conditions governing the grant of duplicate, renewed, converted, consolidated and`
  line `sub-divided Government securities;`
  line
  line `(h) the fees to be paid in respect of the issue of duplicate Government securities and of the`
  line `renewal, conversion, consolidation and sub-division of Government securities;`
  line
  line `(i) the form in which receipt of a Government security delivered for discharge, renewal,`
  line `conversion, consolidation or sub-division is to be acknowledged;`
  line
  line `(j) the manner of attestation of documents relating to Government securities in the form of stock;`
  line
  line `(k) the manner in which any document relating to a Government security or any endorsement on a`
  line `promissory note issued by ^2[the Government] may, on the demand of a person who from any cause is`
  line `unable to write, be executed on his behalf;`
  line
  line `(l) the form of the bonds referred to in sub-section (1) of section 16;`
  line
  line `(m) the circumstance and the manner in which and the conditions subject to which inspection of`
  line `Government securities, books, registers and other documents may be allowed or information`
  line `therefrom may be given under section 25;`
  line
  line `(n) the procedure to be followed in making vesting orders;`
  line
  line `(o) the authority by whom the certificate referred to in the proviso to section 7 is to be granted`
  line `and the manner of making the inquiry therein mentioned;`
  line
  line `^3[(p) the form in which and the persons in whose favour nominations may be made under`
  line `section 9B, the manner in which and the conditions and restrictions subject to which such`
  line `nominations may be made, the registration, variation or cancellation of such nominations and`
  line `the fees that may be levied for such registration, variation or cancellation;`
  line
  line `(q) the manner in which any person may be appointed for the purposes of sub-section (4) of`
  line `section 9B.]`
  line
  line `^4[(3) Every rule made under this section shall be laid, as soon as may be after it is made,`
  line `before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the`
  line `expiry of the session immediately following the session or the successive sessions aforesaid, both Houses agree in making any modification in the rule or both Houses agree that the rule should not`
  line `be made, the rule shall thereafter have effect only in such modified form or be of no effect, as the`
  line `case may be; so, however, that any such modification or annulment shall be without prejudice to`
  line `the validity of anything previously done under that rule.]`
obj_root_law_sections_28_footnotes:
  string
  line `1. Subs. by Act 57 of 1956, s. 12, for "rules of Part B States" (w.e.f. 15-10-1956).`
  line
  line `2. Subs. by Act 6 of 1949, s. 6, for "the Central Government" (w.e.f. 1-4-1949).`
  line
  line `3. Ins. by Act 44 of 1959, s. 3 (w.e.f. 1-8-1960).`
  line
  line `4. Subs. by Act 44 of 1972, s. 4, for sub-section (3) (w.e.f. 1-9-1972).`
obj_root_law_sections_29:
  sectionId (4648)
  sectionNo (29)
  orderNo 33
  title `Certain laws not to apply to Government securities.`
  content obj_root_law_sections_29_content
  footnotes `1. Subs. by Act 57 of 1956, s. 12, for the original s. 29 (w.e.f. 15-10-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4648&sectionno=29&orderno=33&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_29_content:
  string
  line `^1[29. Certain laws not to apply to Government securities.--The Indian Securities Act, 1920`
  line `(10 of 1920), and any law corresponding to that law in force in any Part B State immediately before the`
  line `commencement of the Public Debt (Amendment) Act, 1956 (57 of 1956), shall cease to apply to`
  line `Government securities to which this Act applies and to all matters for which provision is made by this`
  line `Act :`
  line
  line `Provided that any such corresponding law shall continue to apply to or in relation to any`
  line `securities created and issued by the Government of Hyderabad, Saurashtra or Travancore -Cochin`
  line `on or before the 31st day of March, 1953, for such period not exceeding one year from the`
  line `commencement of the Public Debt (Amendment) Act, 1956 (57 of 1956), as the Cenral`
  line `Government may, by notification in the Official Gazette, specify.]`
obj_root_law_sections_30:
  sectionId (4649)
  sectionNo (30)
  orderNo 34
  title `Construction of reference to laws not in force before 1st April, 1951 in Part B States.`
  content obj_root_law_sections_30_content
  footnotes `1. Ins. by s. 14, ibid. (w.e.f. 15-10-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4649&sectionno=30&orderno=34&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_30_content:
  string
  line `^1[30. Construction of reference to laws not in force before 1st April, 1951 in Part B States.--Any`
  line `reference in this Act to any law which did not extend to any Part B State or any part of such State before`
  line `the commencement of the Part B States (Laws) Act, 1951 (3 of 1951), shall wherever necessary, be`
  line `construed as including a reference to the corresponding law, if any, in force in that State, or, as the case`
  line `may be, any part thereof, before the said date.]`
obj_root_law_sections_31:
  sectionId (4650)
  sectionNo (31)
  orderNo 35
  title `Construction of references to laws not in force in Jammu and Kashmir.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_194418_1523354333018&sectionId=4650&sectionno=31&orderno=35&orgactid=AC_CEN_2_11_00030_194418_1523354333018
obj_root_law_sections_31_content:
  string
  line `[Construction of references to laws not in force in *Jammu and Kashmir.] Omitted by the Jammu`
  line `and Kashmir Reorganization (Adaptation of Central Laws) Order, 2020, vide notification No. S.O. 1123(E)`
  line `dated (18-3-2020) and vide Union Territory of Ladakh Reorganisation (Adaptation of Central Laws)`
  line `Order, 2020, notification No. S.O. 3774(E), dated (23-10-2020).]`
obj_root_law_sections_31_footnotes:
  string
  line `1. Ins. by Act 44 of 1972, s. 4 (w.e.f. 1-9-1972).`
  line
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory`
  line `of Jammu and Kashmir and the Union territory of Ladakh.`
