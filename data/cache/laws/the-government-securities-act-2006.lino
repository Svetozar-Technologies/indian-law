obj_root_law_sections_34:
  sectionId (18934)
  sectionNo (34)
  orderNo 35
  title `Power to remove difficulties.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00005_200638_1517807318273&sectionId=18934&sectionno=34&orderno=35&orgactid=AC_CEN_2_11_00005_200638_1517807318273
obj_root_law_sections_34_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, not inconsistent with the provisions of this Act, remove`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of two years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (18935)
  sectionNo (35)
  orderNo 36
  title `Repeal and saving.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00005_200638_1517807318273&sectionId=18935&sectionno=35&orderno=36&orgactid=AC_CEN_2_11_00005_200638_1517807318273
obj_root_law_sections_35_content:
  string
  line `(1) The Indian Securities Act, 1920 (10 of 1920) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal anything done or any action taken in the exercise of any power`
  line `conferred by or under the Act shall be deemed to have been done or taken in the exercise of the powers`
  line `conferred by or under this Act as if this Act was in force on the day on which such thing was done or`
  line `action was taken.`
obj_root_law_sections_35_footnotes:
  string
  line
