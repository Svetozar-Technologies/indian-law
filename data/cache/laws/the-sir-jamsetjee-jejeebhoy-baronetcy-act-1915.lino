obj_root_law:
  slug the-sir-jamsetjee-jejeebhoy-baronetcy-act-1915
  handle (2355)
  collectionHandle 123456789/1362
  title `The Sir Jamsetjee Jejeebhoy Baronetcy Act, 1915`
  actNumber (10)
  enactmentDate 1915-09-08
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2355`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (1915)
  ministry `Ministry of Home Affairs`
  department `Department of Home`
  longTitle `An Act for repealing Act No. XX of 1860 entitled "An Act for settling Promissory Notes of the Government of India, producing an annual income of one lakh of rupees and a Mansion House and and hereditaments called Mazagon Castle, in the Island of Bombay, late the property of Sir Jamsetjee Jejeebhoy, Baronet, deceased, so as to accompany and support the title and dignity of a Baronet, lately conferred on him and the heirs male of his body, by Her present Majesty Queen Victoria, and for other purposes connected therewith," and for resettling the said Promissory Notes, Mansion House and hereditaments and for other purposes connected therewith.`
  enforcementDate 08-09-1915
  notification undefined
