obj_root_law_sections_1:
  sectionId (16617)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16617&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Depositories Act, 1996.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall be deemed to have come into force on the 20th day of September, 1995.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (16618)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Ins. by Act 32 of 1999, s. 13 (w.e.f. 16-12-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16618&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "beneficial owner" means a person whose name is recorded as such with a depository;`
  line
  line `(b) "Board" means the Securities and Exchange Board of India established under section 3 of the`
  line `Securities and Exchange Board of India Act, 1992 (15 of 1992);`
  line
  line `(c) "bye-laws" means bye-laws made by a depository under section 26;`
  line
  line `(d) "Company Law Board" means the Board of Company Law Administration constituted under`
  line `section 10E of the Companies Act, 1956 (1 of 1956);`
  line
  line `(e) "depository" means a company formed and registered under the Companies Act,`
  line `1956 (1 of 1956) and which has been granted a certificate of registration under sub-section (1A) of`
  line `section 12 of the Securities and Exchange Board of India Act, 1992 (15 of 1992);`
  line
  line `(f) "issuer" means any person making an issue of securities;`
  line
  line `(g) "participant" means a person registered as such under sub-section (1A) of section 12 of the`
  line `Securities and Exchange Board of India Act, 1992 (15 of 1992);`
  line
  line `(h) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(i) "record" includes the records maintained in the form of books or stored in a computer or in`
  line `such other form as may be determined by regulations;`
  line
  line `(j) "registered owner" means a depository whose name is entered as such in the register of the`
  line issuer;
  line
  line `(k) "regulations" means the regulations made by the Board;`
  line
  line ^1
  line `[(ka) "Securities Appellate Tribunal" means a Securities Appellate Tribunal established under`
  line `sub-section (1) of section 15K of the Securities and Exchange Board of India Act, 1992 (15 of 1992);]`
  line
  line `(l) "security" means such security as may be specified by the Board;`
  line
  line `(m) "service" means any service connected with recording of allotment of securities or transfer of`
  line `ownership of securities in the record of a depository.`
  line
  line `(2) Words and expressions used herein and not defined but defined in the Companies Act,`
  line `1956 (1 of 1956) or the Securities Contracts (Regulation) Act, 1956 (42 of 1956) or the Securities and`
  line `Exchange Board of India Act, 1992 (15 of 1992), shall have the meanings respectively assigned to them`
  line `in those Acts.`
obj_root_law_sections_3:
  sectionId (16619)
  sectionNo (3)
  orderNo 3
  title `Certificate of commencement of business by depositories.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16619&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_3_content:
  string
  line `(1) No depository shall act as a`
  line `depository unless it obtains a certificate of commencement of business from the Board.`
  line
  line `(2) A certificate granted under sub-section (1) shall be in such form as may be specified by the`
  line regulations.
  line
  line `(3) The Board shall not grant it certificate under sub-section (1) unless it is satisfied that the`
  line `depository has adequate systems and safeguards to prevent manipulation of records and transactions:`
  line
  line `Provided that no certificate shall be refused under this section unless the depository concerned has`
  line `been given a reasonable opportunity of being heard.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (16620)
  sectionNo (4)
  orderNo 4
  title `Agreement between depository and participant.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16620&sectionno=4&orderno=4&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_4_content:
  string
  line `(1) A depository shall enter into an agreement`
  line `with one or more participants as its agent.`
  line
  line `(2) Every agreement under sub-section (1) shall be in such form as may be specified by the bye-laws.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (16621)
  sectionNo (5)
  orderNo 5
  title `Services of depository.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16621&sectionno=5&orderno=5&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_5_content:
  string
  line `Any person, through a participant, may enter into an agreement, in such`
  line `form as may be specified by the bye-laws, with any depository for availing its services.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (16622)
  sectionNo (6)
  orderNo 6
  title `Surrender of certificate of security.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16622&sectionno=6&orderno=6&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_6_content:
  string
  line `(1) Any person who has entered into an agreement under`
  line `section 5 shall surrender the certificate of security, for which he seeks to avail the services of a`
  line `depository, to the issuer in such manner as may be specified by the regulations.`
  line
  line `(2) The issuer, on receipt of certificate of security under sub-section (1), shall cancel the certificate of`
  line `security and substitute in its records the name of the depository as a registered owner in respect of that`
  line `security and inform the depository accordingly.`
  line
  line `(3) A depository shall, on receipt of information under sub-section (2), enter the name of the person`
  line `referred to in sub-section (1) in its records, as the beneficial owner.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (16623)
  sectionNo (7)
  orderNo 7
  title `Registration of transfer of securities with depository.`
  content obj_root_law_sections_7_content
  footnotes `1. Ins. by Act 44 of 2016, s. 44 and the Second Schedule (w.e.f. 1-9-2016)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16623&sectionno=7&orderno=7&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_7_content:
  string
  line `(1) Every depository shall, on receipt of`
  line `intimation from a participant, register the transfer of security in the name of the transferee.`
  line
  line ^1
  line `[(1A) Every depository on receipt of intimation from a participant register any transfer of security in`
  line `favour of an asset reconstruction company as defined in clause (ba) of sub-section (1) of section 2 of the`
  line `Securitisation and Reconstruction of Financial Assets and Enforcement of Security Interest Act, 2002`
  line `(54 of 2002) along with or consequent upon transfer or assignment of financial asset of any bank or`
  line `financial institution under sub-section (1) of section 5 of that Act.`
  line
  line `(1B) Every depository, on receipt of intimation from a participant, register any issue of new shares in`
  line `favour of any bank or financial institution or asset reconstruction company or any other assignee of such`
  line `bank or financial institution or asset reconstruction company, as the case may be, by conversion of part of`
  line `their debt into shares pursuant to reconstruction of debts of the company agreed between the company and`
  line `the bank or financial institution or asset reconstruction company.`
  line
  line `Explanation.--For the purpose of this section, the expressions "asset reconstruction company",`
  line `"bank", and "financial institution" shall have the meanings assigned to them respectively under`
  line `clauses (ba), (c) and (m) of sub-section (1) of section 2 of the Securitisation and Reconstruction of`
  line `Financial Assets and Enforcement of Security Interest Act, 2002 (54 of 2002).]`
  line
  line `(2) If a beneficial owner or a transferee of any security seeks to have custody of such security, the`
  line `depository shall inform the issuer accordingly.`
obj_root_law_sections_8:
  sectionId (16624)
  sectionNo (8)
  orderNo 8
  title `Options to receive security certificate or hold securities with depository.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16624&sectionno=8&orderno=8&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_8_content:
  string
  line `(1) Every person`
  line `subscribing to securities offered by an issuer shall have the option either to receive the security`
  line `certificates or hold securities with a depository.`
  line
  line `(2) Where a person opts to hold a security with a depository, the issuer shall intimate such depository`
  line `the details of allotment of the security, and on receipt of such information the depository shall enter in its`
  line `records the name of the allottee as the beneficial owner of that security.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (16625)
  sectionNo (9)
  orderNo 9
  title `Securities in depositories to be in fungible form.`
  content obj_root_law_sections_9_content
  footnotes `1. Subs. by Act 8 of 1997, s. 22, for sub-section (2) (w.e.f. 15-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16625&sectionno=9&orderno=9&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_9_content:
  string
  line `(1) All securities held by a depository shall be`
  line `dematerialised and shall be in a fungible form.`
  line
  line ^1
  line `[(2) Nothing contained in sections 153, 153A, 153B, 187B, 187C and 372 of the Companies Act,`
  line `1956 (1 of 1956) shall apply to a depository in respect of securities held by it on behalf of the beneficial`
  line owners.]
obj_root_law_sections_10:
  sectionId (16626)
  sectionNo (10)
  orderNo 10
  title `Rights of depositories and beneficial owner.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16626&sectionno=10&orderno=10&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_10_content:
  string
  line `(1) Notwithstanding anything contained in any`
  line `other law for the time being in force, a depository shall be deemed to be the registered owner for the`
  line `purposes of effecting transfer of ownership of security on behalf of a beneficial owner.`
  line
  line `(2) Save as otherwise provided in sub-section (1), the depository as a registered owner shall not have`
  line `any voting rights or any other rights in respect of securities held by it.`
  line
  line `(3) The beneficial owner shall be entitled to all the rights and benefits and be subjected to all the`
  line `liabilities in respect of his securities held by a depository.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (16627)
  sectionNo (11)
  orderNo 11
  title `Register of beneficial owner.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16627&sectionno=11&orderno=11&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_11_content:
  string
  line `Every depository shall maintain a register and an index of`
  line `beneficial owners in the manner provided in sections 150, 151 and 152 of the Companies Act,`
  line `1956 (1 of 1956).`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (16628)
  sectionNo (12)
  orderNo 12
  title `Pledge or hypothecation of securities held in a depository.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16628&sectionno=12&orderno=12&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_12_content:
  string
  line `(1) Subject to such regulations`
  line `and bye-laws, as may be made in this behalf, a beneficial owner may with the previous approval of the`
  line `depository create a pledge or hypothecation in respect of a security owned by him through a depository.`
  line
  line `(2) Every beneficial owner shall give intimation of such pledge or hypothecation to the depository`
  line `and such depository shall thereupon make entries in its records accordingly.`
  line
  line `(3) Any entry in the records of a depository under sub-section (2) shall be evidence of a pledge or`
  line hypothecation.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (16629)
  sectionNo (13)
  orderNo 13
  title `Furnishing of information and records by depository and issuer.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16629&sectionno=13&orderno=13&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_13_content:
  string
  line `(1) Every depository shall`
  line `furnish to the issuer information about the transfer of securities in the name of beneficial owners at such`
  line `intervals and in such manner as may be specified by the bye-laws.`
  line
  line `(2) Every issuer shall make available to the depository copies of the relevant records in respect of`
  line `securities held by such depository.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (16630)
  sectionNo (14)
  orderNo 14
  title `Option to opt out in respect of any security.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16630&sectionno=14&orderno=14&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_14_content:
  string
  line `(1) If a beneficial owner seeks to opt out of a`
  line `depository in respect of any security he shall inform the depository accordingly.`
  line
  line `(2) The depository shall on receipt of intimation under sub-section (1) make appropriate entries in its`
  line `records and shall inform the issuer.`
  line
  line `(3) Every issuer shall, within thirty days of the receipt of intimation from the depository and on`
  line `fulfilment of such conditions and on payment of such fees as may be specified by the regulations, issue`
  line `the certificate of securities to the beneficial owner or the transferee, as the case may be.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (16631)
  sectionNo (15)
  orderNo 15
  title `Act 18 of 1891 to apply to depositories.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16631&sectionno=15&orderno=15&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_15_content:
  string
  line `The Bankers' Books Evidence Act, 1891 shall apply`
  line `in relation to a depository as if it were a bank as defined in section 2 of that Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (16632)
  sectionNo (16)
  orderNo 16
  title `Depositories to indemnify loss in certain cases.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16632&sectionno=16&orderno=16&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_16_content:
  string
  line `(1) Without prejudice to the provisions of any`
  line `other law for the time being in force, any loss caused to the beneficial owner due to the negligence of the`
  line `depository or the participant, the depository shall indemnify such beneficial owner.`
  line
  line `(2) Where the loss due to the negligence of the participant under sub-section (1) is indemnified by the`
  line `depository, the depository shall have the right to recover the same from such participant.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (16633)
  sectionNo (17)
  orderNo 17
  title `Rights and obligations of depositories, etc.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16633&sectionno=17&orderno=17&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_17_content:
  string
  line `(1) Subject to the provisions of this Act, the rights`
  line `and obligations of the depositories, participants and the issuers whose securities are dealt with by a`
  line `depository shall be specified by the regulations.`
  line
  line `(2) The eligibility criteria for admission of securities into the depository shall be specified by the`
  line regulations.
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (16634)
  sectionNo (18)
  orderNo 18
  title `Power of Board to call for information and enquiry.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16634&sectionno=18&orderno=18&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_18_content:
  string
  line `(1) The Board, on being satisfied that it`
  line `is necessary in the public interest or in the interest of investors so to do, may, by order in writing,--`
  line
  line `(a) call upon any issuer, depository, participant or beneficial owner to furnish in writing such`
  line `information relating to the securities held in a depository as it may require; or`
  line
  line `(b) authorise any person to make an enquiry or inspection in relation to the affairs of the issuer,`
  line `beneficial owner, depository or participant, who shall submit a report of such enquiry or inspection to`
  line `it within such period as may be specified in the order.`
  line
  line `(2) Every director, manager, partner, secretary, officer or employee of the depository or issuer or the`
  line `participant or beneficial owner shall on demand produce before the person making the enquiry or`
  line `inspection all information or such records and other documents in his custody having a bearing on the`
  line `subject matter of such enquiry or inspection.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (16635)
  sectionNo (19)
  orderNo 19
  title `Power of Board to give directions in certain cases.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16635&sectionno=19&orderno=19&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_content:
  string
  line ^1
  line `[1] Save as provided in this Act, if after`
  line `making or causing to be made an enquiry or inspection, the Board is satisfied that it is necessary--`
  line
  line `(i) in the interest of investors, or orderly development of securities market; or`
  line
  line `(ii) to prevent the affairs of any depository or participant being conducted in the manner`
  line `detrimental to the interests of investors or securities market,`
  line
  line `it may issue such directions--`
  line
  line `(a) to any depository or participant or any person associated with the securities market; or`
  line
  line `(b) to any issuer,`
  line
  line `as may be appropriate in the interest of investors or the securities market.`
  line
  line ^2
  line `[Explanation.--For the removal of doubts, it is hereby declared that power to issue directions under`
  line `this section shall include and always be deemed to have been included the power to direct any person,`
  line `who made profit or averted loss by indulging in any transaction or activity in contravention of the`
  line `provisions of this Act or regulations made thereunder, to disgorge an amount equivalent to the wrongful`
  line `gain made or loss averted by such contravention.]`
  line
  line ^3
  line `[(2) Without prejudice to the provisions contained in sub-section (1) and section 19H, the Board`
  line `may, by order, for reason to be recorded in writing, levy penalty under sections 19A, 19B, 19D, 19E, 19F,`
  line `19FA and 19G after holding an inquiry in the prescribed manner.]`
obj_root_law_sections_19_footnotes:
  string
  line `1. Section 19 numbered as sub-section (1) thereof by Act 13 of 2018, s. 192 (w.e.f. 8-3-2019).`
  line
  line `2. Ins. by Act 27 of 2014, s. 41 (w.e.f. 8-9-2014).`
  line
  line `3. Ins. by Act 13 of 2018, s. 192 (w.e.f. 8-3-2019)`
obj_root_law_sections_19_a:
  sectionId (16636)
  sectionNo 19A
  orderNo 20
  title `Penalty for failure to furnish information, return, etc.`
  content obj_root_law_sections_19_a_content
  footnotes obj_root_law_sections_19_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16636&sectionno=19A&orderno=20&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_a_content:
  string
  line ^2
  line `[19A. Penalty for failure to furnish information, return, etc.--Any person, who is required under`
  line `this Act or any rules or regulations or bye-laws made thereunder,--`
  line
  line `(a) to furnish any information, document, books, returns or report to the Board, fails to furnish the same`
  line `within the time specified therefor ^3`
  line `[or who furnishes or files false, incorrect or incomplete information,`
  line `return, report, books or other documents], he shall be liable to a penalty ^4`
  line `[which shall not be less than`
  line `one lakh rupees but which may extend to one lakh rupees for each day during which such failure`
  line `continues subject to a maximum of one crore rupees] for each such failure;`
  line
  line `(b) to file any return or furnish any information, books or other documents within the time`
  line `specified therefor in the regulations or bye-laws, fails to file return or furnish the same within the time`
  line `specified therefor, he ^3`
  line `[or who furnishes or files false, incorrect or incomplete information, return,`
  line `report, books or other documents] shall be liable to a penalty ^1`
  line `[which shall not be less than one lakh`
  line `rupees but which may extend to one lakh rupees for each day during which such failure continues`
  line `subject to a maximum of one crore rupees];`
  line
  line `(c) to maintain books of account or records, fails to maintain the same, he shall be liable to a`
  line `penalty ^1`
  line `[which shall not be less than one lakh rupees but which may extend to one lakh rupees for`
  line `each day during which such failure continues subject to a maximum of one crore rupees].`
obj_root_law_sections_19_a_footnotes:
  string
  line `1. Ins. by Act 13 of 2018, s. 192 (w.e.f. 8-3-2019).`
  line
  line `2. Ins. by Act 1 of 2005, s. 17 (w.e.f. 12-10-2004).`
  line
  line `3. Ins. by Act 13 of 2018, s. 193 (w.e.f. 8-3-2019).`
  line
  line `4. Subs. by Act 27 of 2014, s. 42, for certain words (w.e.f. 8-9-2014).`
obj_root_law_sections_19_b:
  sectionId (16637)
  sectionNo 19B
  orderNo 21
  title `Penalty for failure to enter into an agreement.`
  content obj_root_law_sections_19_b_content
  footnotes `1. Subs. by s. 43, ibid., for certain words (w.e.f. 8-9-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16637&sectionno=19B&orderno=21&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_b_content:
  string
  line `If a depository or participant or any issuer or`
  line `its agent or any person, who is registered as an intermediary under the provisions of section 12 of the`
  line `Securities and Exchange Board of India Act, 1992 (15 of 1992), and is required under this Act or any`
  line `rules or regulations, made thereunder, to enter into an agreement, fails to enter into such agreement, such`
  line `depository or participant or issuer or its agent or intermediary shall be liable to a penalty ^1`
  line `[which shall not`
  line `be less than one lakh rupees but which may extend to one lakh rupees for each day during which such`
  line `failure continues subject to a maximum of one crore rupees] for every such failure.`
obj_root_law_sections_19_c:
  sectionId (16638)
  sectionNo 19C
  orderNo 22
  title `Penalty for failure to redress investors‟ grievances.`
  content obj_root_law_sections_19_c_content
  footnotes `1. Subs. by s. 44, ibid., for certain words (w.e.f. 8-9-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16638&sectionno=19C&orderno=22&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_c_content:
  string
  line `If any depository or participant or any`
  line `issuer or its agent or any person, who is registered as an intermediary under the provisions of section 12`
  line `of the Securities and Exchange Board of India Act, 1992 (15 of 1992), after having been called upon by`
  line `the Board in writing, to redress the grievances of the investors, fails to redress such grievances within the`
  line `time specified by the Board, such depository or participant or issuer or its agents or intermediary shall be`
  line `liable to a penalty ^1`
  line `[which shall not be less than one lakh rupees but which may extend to one lakh rupees`
  line `for each day during which such failure continues subject to a maximum of one crore rupees].`
obj_root_law_sections_19_d:
  sectionId (16639)
  sectionNo 19D
  orderNo 23
  title `Penalty for delay in dematerialisation or issue of certificate of securities.`
  content obj_root_law_sections_19_d_content
  footnotes `1. Subs. by s. 45, ibid., for certain words (w.e.f. 8-9-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16639&sectionno=19D&orderno=23&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_d_content:
  string
  line `If any issuer or`
  line `its agent or any person, who is registered as an intermediary under the provisions of section 12 of the`
  line `Securities and Exchange Board of India Act, 1992 (15 of 1992), fails to dematerialise or issue the`
  line `certificate of securities on opting out of a depository by the investors, within the time specified under this`
  line `Act or regulations or bye-laws made thereunder or abets in delaying the process of dematerialisation or`
  line `issue the certificate of securities on opting out of a depository of securities, such issuer or its agent or`
  line `intermediary shall be liable to a penalty ^1`
  line `[which shall not be less than one lakh rupees but which may`
  line `extend to one lakh rupees for each day during which such failure continues subject to a maximum of one`
  line `crore rupees].`
obj_root_law_sections_19_e:
  sectionId (16640)
  sectionNo 19E
  orderNo 24
  title `Penalty for failure to reconcile records.`
  content obj_root_law_sections_19_e_content
  footnotes `1. Subs. by s. 46, ibid., for certain words (w.e.f. 8-9-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16640&sectionno=19E&orderno=24&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_e_content:
  string
  line `If a depository or participant or any issuer or its`
  line `agent or any person, who is registered as an intermediary under the provisions of section 12 of the`
  line `Securities and Exchange Board of India Act, 1992 (15 of 1992), fails to reconcile the records of`
  line `dematerialised securities with all the securities issued by the issuer as specified in the regulations, such`
  line `depository or participant or issuer or its agent or intermediary shall be liable to a penalty ^1`
  line `[which shall not`
  line `be less than one lakh rupees but which may extend to one lakh rupees for each day during which such`
  line `failure continues subject to a maximum of one crore rupees].`
obj_root_law_sections_19_f:
  sectionId (16641)
  sectionNo 19F
  orderNo 25
  title `Penalty for failure to comply with directions issued by Board under section 19 of the Act.`
  content obj_root_law_sections_19_f_content
  footnotes `1. Subs. by s. 47, ibid., for certain words (w.e.f. 8-9-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16641&sectionno=19F&orderno=25&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_f_content:
  string
  line `If any person fails to comply with the directions issued by the Board under section 19, within the`
  line `time specified by it, he shall be liable to a penalty ^1`
  line `[which shall not be less than one lakh rupees but which`
  line `may extend to one lakh rupees for each day during which such failure continues subject to a maximum of`
  line `one crore rupees].`
obj_root_law_sections_19_fa:
  sectionId (48893)
  sectionNo 19FA
  orderNo 26
  title `Penalty for conduct business in a fair manner.`
  content obj_root_law_sections_19_fa_content
  footnotes `1. Ins. by Act 13 of 2018, s. 194 (w.e.f. 8-3-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=48893&sectionno=19FA&orderno=26&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_fa_content:
  string
  line ^1
  line `[19FA. Penalty for failure to conduct business in a fair manner.--Where a depository fails to`
  line `conduct its business with its participants or any issuer or its agent or any person associated with the`
  line `securities markets in a fair manner in accordance with the rules, regulations made by the Board or`
  line `directions issued by the Board under this Act, it shall be liable to penalty which shall not be less than five`
  line `crore rupees but which may extend to twenty-five crore rupees or three times the amount of gains made`
  line `out of such failure, whichever is higher.]`
obj_root_law_sections_19_g:
  sectionId (16642)
  sectionNo 19G
  orderNo 27
  title `Penalty for contravention where no separate penalty has been provided.`
  content obj_root_law_sections_19_g_content
  footnotes `1. Subs. by Act 27 of 2014, s. 48, for certain words (w.e.f. 28-3-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16642&sectionno=19G&orderno=27&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_g_content:
  string
  line `Whoever fails to`
  line `comply with any provision of this Act, the rules or the regulations or bye-laws made or directions issued`
  line `by the Board thereunder for which no separate penalty has been provided, shall be ^1`
  line `[liable to a penalty`
  line `which shall not be less than one lakh rupees but which may extend to one crore rupees].`
obj_root_law_sections_19_h:
  sectionId (16643)
  sectionNo 19H
  orderNo 28
  title `Power to adjudicate.`
  content obj_root_law_sections_19_h_content
  footnotes obj_root_law_sections_19_h_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16643&sectionno=19H&orderno=28&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_h_content:
  string
  line `(1) For the purpose of adjudging under sections 19A, 19B, 19C, 19D,`
  line `19E, ^1`
  line `[19F, 19FA and 19G, the Board may appoint any officer not below the rank of a Division Chief of`
  line `the Securities and Exchange Board of India to be an adjudicating officer for holding an inquiry in the`
  line `prescribed manner after giving any person concerned a reasonable opportunity of being heard for the`
  line `purpose of imposing any penalty.`
  line
  line `(2) While holding an inquiry, the adjudicating officer shall have power to summon and enforce the`
  line `attendance of any person acquainted with the facts and circumstances of the case to give evidence or to`
  line `produce any document, which in the opinion of the adjudicating officer, may be useful for or relevant to`
  line `the subject-matter of the inquiry and if, on such inquiry, he is satisfied that the person has failed to`
  line `comply with the provisions of any of the sections specified in sub-section (1), he may impose such`
  line `penalty as he thinks fit in accordance with the provisions of any of those sections.`
  line
  line ^2
  line `[(3) The Board may call for and examine the record of any proceedings under this section and if it`
  line `considers that the order passed by the adjudicating officer is erroneous to the extent it is not in the`
  line `interests of the securities market, it may, after making or causing to be made such inquiry as it deems`
  line `necessary, pass an order enhancing the quantum of penalty, if the circumstances of the case so justify:`
  line
  line `Provided that no such order shall be passed unless the person concerned has been given an`
  line `opportunity of being heard in the matter:`
  line
  line `Provided further that nothing contained in this sub-section shall be applicable after an expiry of a`
  line `period of three months from the date of the order passed by the adjudicating officer or disposal of the`
  line `appeal under section 23A, whichever is earlier.]`
obj_root_law_sections_19_h_footnotes:
  string
  line `1. Subs. by Act 13 of 2018, s. 195, for "19F and 19G, the Board shall" (w.e.f. 8-3-2019).`
  line
  line `2. Ins. by Act 27 of 2014, s. 49 (w.e.f. 18-7-2013).`
obj_root_law_sections_19_i:
  sectionId (16671)
  sectionNo 19-I
  orderNo 29
  title `Factors to be taken into account by adjudicating officer.`
  content obj_root_law_sections_19_i_content
  footnotes obj_root_law_sections_19_i_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16671&sectionno=19-I&orderno=29&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_i_content:
  string
  line `19-I. ^1`
  line `[Factors to be taken into account while adjudging quantum of penalty].--While adjudging`
  line `adjudging the quantum of penalty under ^2`
  line `[section 19 or section 19H, the Board or the adjudicating`
  line `officer] shall have due regard to the following factors, namely:--`
  line
  line `(a) the amount of disproportionate gain or unfair advantage, wherever quantifiable, made as a`
  line `result of the default;`
  line
  line `(b) the amount of loss caused to an investor or group of investors as a result of the default;`
  line
  line `(c) the repetitive nature of the default.`
  line
  line ^3
  line `[Explanation.--For the removal of doubts, it is clarified that the power of ^4`
  line `*** to adjudge the`
  line `quantum of penalty under sections 19A to 19F shall be and shall always be deemed to have been`
  line `exercised under the provisions of this section.]`
obj_root_law_sections_19_i_footnotes:
  string
  line `1. Subs. by Act 13 of 2018, s. 196, for "Factors to be taken into account by adjudicating officer" (w.e.f. 8-3-2019).`
  line
  line `2. Subs. by s. 196, ibid., for "section 19H, the adjudicating officer" (w.e.f. 8-3-2019).`
  line
  line `3. Ins. by Act 7 of 2017, s. 149 (31-3-2017).`
  line
  line `4 The words "of an adjudicating officer" omitted by Act 13 of 2018, s. 196 (w.e.f. 8-3-2019).`
obj_root_law_sections_19_ia:
  sectionId (16672)
  sectionNo 19-IA
  orderNo 30
  title `Settlement of Administrative and Civil Proceedings`
  content obj_root_law_sections_19_ia_content
  footnotes obj_root_law_sections_19_ia_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16672&sectionno=19-IA&orderno=30&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_ia_content:
  string
  line `^1[19-IA. Settlement of Administrative and Civil Proceedings.--(1) Notwithstanding anything`
  line `contained in any other law for the time being in force, any person, against whom any proceedings have`
  line `been initiated or may be initiated under section 19 or section 19H, as the case may be, may file an`
  line `application in writing to the Board proposing for settlement of the proceedings initiated or to be initiated`
  line `for the alleged defaults.`
  line
  line `(2) The Board may, after taking into consideration the nature, gravity and impact of defaults, agree to`
  line `the proposal for settlement, on payment of such sum by the defaulter or on such other terms as may be`
  line `determined by the Board in accordance with the regulations made under the Securities and Exchange`
  line `Board of India Act, 1992 (15 of 1992).`
  line
  line `(3) For the purpose of settlement under this section, the procedure as specified by the Board under the`
  line `Securities and Exchange Board of India Act, 1992 (15 of 1992) shall apply.`
  line
  line `(4) No appeal shall lie under section 23A against any order passed by the Board or the adjudicating`
  line `officer under this section.]`
  line
  line `^2[(5) All settlement amounts, excluding the disgorgement amount and legal costs, realised under this`
  line `Act shall be credited to the Consolidated Fund of India.]`
obj_root_law_sections_19_ia_footnotes:
  string
  line `1. Ins. by Act 27 of 2014, s. 50 (w.e.f. 20-4-2007).`
  line
  line `2. Ins. by Act 13 of 2018, s. 197 (w.e.f. 8-3-2019).`
obj_root_law_sections_19_ib:
  sectionId (16673)
  sectionNo 19-IB
  orderNo 31
  title `Recovery of amounts.`
  content obj_root_law_sections_19_ib_content
  footnotes obj_root_law_sections_19_ib_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16673&sectionno=19-IB&orderno=31&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_ib_content:
  string
  line ^1
  line `[19-IB. Recovery of amounts.--(1) If a person fails to pay the penalty imposed ^2`
  line `[under this Act] or`
  line `or fails to comply with a direction of disgorgement order issued under section 19 or fails to pay any fees`
  line `due to the Board, the Recovery Officer may draw up under his signature a statement in the specified form`
  line `specifying the amount due from the person (such statement being hereafter in this Chapter referred to as`
  line `certificate) and shall proceed to recover from such person the amount specified in the certificate by one or`
  line `more of the following modes, namely:`
  line
  line `(a) attachment and sale of the person's movable property;`
  line
  line `(b) attachment of the person's bank accounts;`
  line
  line `(c) attachment and sale of the person's immovable property;`
  line
  line `(d) arrest of the person and his detention in prison;`
  line
  line `(e) appointing a receiver for the management of the person's movable and immovable properties,`
  line
  line `and for this purpose, the provisions of sections 220 to 227, 228A, 229, 232, the Second and Third`
  line `Schedules to the Income-tax Act, 1961 (43 of 1961), and the Income-tax (Certificate Proceedings) Rules,`
  line `1962 as in force from time to time, in so far as may be, apply with necessary modifications as if the said`
  line `provisions and the rules thereunder were the provisions of this Act and referred to the amount due under`
  line `this Act instead of to income-tax under the Income-tax Act, 1961.`
  line
  line `Explanation 1.--For the purposes of this sub-section, the person's movable or immovable property or`
  line `monies held in bank accounts shall include any property or monies held in bank accounts which has been`
  line `transferred, directly or indirectly on or after the date when the amount specified in certificate had become`
  line `due, by the person to his spouse or minor child or son's wife or son's minor child, otherwise than for`
  line `adequate consideration, and which is held by, or stands in the name of, any of the persons aforesaid; and`
  line `so far as the movable or immovable property or monies held in bank accounts so transferred to his minor`
  line `child or his son's minor child is concerned, it shall, even after the date of attainment of majority by such`
  line `minor child or son's minor child, as the case may be, continue to be included in the person's movable or`
  line `immovable property or monies held in bank accounts for recovering any amount due from the person`
  line `under this Act.`
  line
  line `Explanation 2.--Any reference under the provisions of the Second and Third Schedules to the`
  line `Income-tax Act, 1961 (43 of 1961) and the Income-tax (Certificate Proceedings) Rules, 1962 to the`
  line `assessee shall be construed as a reference to the person specified in the certificate.`
  line
  line `Explanation 3.--Any reference to appeal in Chapter XVIID and the Second Schedule to the`
  line `Income-tax Act, 1961 (43 of 1961), shall be construed as a reference to appeal before the Securities`
  line `Appellate Tribunal under section 23A of this Act.`
  line
  line `(2) The Recovery Officer shall be empowered to seek the assistance of the local district`
  line `administration while exercising the powers under sub-section (1).`
  line
  line `(3) Notwithstanding anything contained in any other law for the time being in force, the recovery of`
  line `amounts by a Recovery Officer under sub-section (1), pursuant to non-compliance with any direction`
  line `issued by the Board under section 19, shall have precedence over any other claim against such person.`
  line
  line `(4) For the purposes of sub-sections (1), (2) and (3), the expression ''Recovery Officer'' means any`
  line `officer of the Board who may be authorised, by general or special order in writing, to exercise the powers`
  line `of a Recovery Officer.]`
obj_root_law_sections_19_ib_footnotes:
  string
  line `1. Ins. by Act 27 of 2014, s. 51 (w.e.f. 18-7-2013).`
  line
  line `2. Subs. by Act 13 of 2018, s. 198, for "by the adjudicating officer" (w.e.f. 8-3-2019).`
obj_root_law_sections_19_ic:
  sectionId (48894)
  sectionNo 19-IC
  orderNo 32
  title `Continuance of proceedings.`
  content obj_root_law_sections_19_ic_content
  footnotes `1. Ins. by Act 13 of 2018, s. 199 (w.e.f. 8-3-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=48894&sectionno=19-IC&orderno=32&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_ic_content:
  string
  line ^1
  line `[19-IC. Continuance of proceedings.--(1) Where a person dies, his legal representative shall be`
  line `liable to pay any sum which the deceased would have been liable to pay if he had not died, in the like`
  line `manner and to the same extent as the deceased:`
  line
  line `Provided that, in case of any penalty payable under this Act, a legal representative shall be liable only`
  line `in case the penalty has been imposed before the death of the deceased person.`
  line
  line `(2) For the purposes of sub-section (1),--`
  line
  line `(a) any proceeding for disgorgement, refund or an action for recovery before the Recovery`
  line `Officer under this Act, except a proceeding for levy of penalty, initiated against the deceased before`
  line `his death shall be deemed to have been initiated against the legal representative, and may be`
  line `continued against the legal representative from the stage at which it stood on the date of the death of`
  line `the deceased and all the provisions of this Act shall apply accordingly;`
  line
  line `(b) any proceeding for disgorgement, refund or an action for recovery before the Recovery`
  line `Officer under this Act, except a proceeding for levy of penalty, which could have been initiated`
  line `against the deceased if he had survived, may be initiated against the legal representative and all the`
  line `provisions of this Act shall apply accordingly.`
  line
  line `(3) Every legal representative shall be personally liable for any sum payable by him in his capacity as`
  line `legal representative if, while his liability for such sum remains undischarged, he creates a charge on or`
  line `disposes of or parts with any assets of the estate of the deceased, which are in, or may come into, his`
  line `possession, but such liability shall be limited to the value of the asset so charged, disposed of or parted`
  line with.
  line
  line `(4) The liability of a legal representative under this section shall be limited to the extent to which the`
  line `estate of the deceased is capable of meeting the liability.`
  line
  line `Explanation.--For the purposes of this section "legal representative" means a person who in law`
  line `represents the estate of a deceased person, and includes any person who intermeddles with the estate of`
  line `the deceased and where a party sues or is sued in a representative character, the person on whom the`
  line `estate devolves on the death of the party so suing or sued.`
obj_root_law_sections_19_j:
  sectionId (16674)
  sectionNo 19J
  orderNo 33
  title `Crediting sums realised by way of penalties to Consolidated Fund of India.`
  content obj_root_law_sections_19_j_content
  footnotes obj_root_law_sections_19_j_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16674&sectionno=19J&orderno=33&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_19_j_content:
  string
  line `All sums`
  line `realised by way of penalties under this Act shall be credited to the Consolidated Fund of India.]`
obj_root_law_sections_19_j_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (16675)
  sectionNo (20)
  orderNo 34
  title Offences
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16675&sectionno=20&orderno=34&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_20_content:
  string
  line ^1[^2
  line `[20. Offences.--(1) Without prejudice to any award of penalty by the adjudicating officer ^3`
  line `[or the`
  line `Board] under this Act, if any person contravenes or attempts to contravene or abets the contravention of`
  line `the provisions of this Act or of any rules or regulations or bye-laws made thereunder, he shall be`
  line `punishable with imprisonment for a term which may extend to ten years, or with fine, which may extend`
  line `to twenty-five crore rupees, or with both.`
  line
  line `(2) If any person fails to pay the penalty imposed by the ^4`
  line `[adjudicating officer or the Board or fails to`
  line `comply with any] directions or orders, he shall be punishable with imprisonment for a term which shall`
  line `not be less than one month but which may extend to ten years, or with fine, which may extend to twentyfive crore rupees, or with both.]`
obj_root_law_sections_20_footnotes:
  string
  line `1. Subs. by s. 200, ibid.., for "PENALTY" (w.e.f. 8-3-2019).`
  line
  line `2. Subs. by Act 1 of 2005, s. 18, for section 20 (w.e.f. 12-10-2004).`
  line
  line `3. Ins. by Act 13 of 2018, s. 201 (w.e.f. 8-3-2019).`
  line
  line `4. Subs. by s. 201, ibid., for "adjudicating officer or fails to comply with any of his" (w.e.f. 8-3-2019).`
obj_root_law_sections_21:
  sectionId (16676)
  sectionNo (21)
  orderNo 35
  title `Offences by companies.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16676&sectionno=21&orderno=35&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_21_content:
  string
  line `21. ^1`
  line `[Contravention by companies].--(1) Where ^2`
  line `[a contravention of any of the provisions of this`
  line `Act or any rule, regulation, direction or order made thereunder] has been committed by a company, every`
  line `person who at the time the ^3`
  line `[contravention] was committed was in charge of, and was responsible to, the`
  line `company for the conduct of the business of the company, as well as the company, shall be deemed to be`
  line `guilty of the ^3`
  line `[contravention] and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act, if he proves that the offence was committed without his knowledge or`
  line `that he had exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where ^2`
  line `[a contravention of any of the`
  line `provisions of this Act or any rule, regulation, direction or order made thereunder] this Act has been`
  line `committed by a company and it is proved that the ^3`
  line `[contravention] has been committed with the consent`
  line `or connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of the ^3`
  line `[contravention] and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) 'company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_21_footnotes:
  string
  line `1.Subs. by Act 13 of 2018, s. 202, for "Offences by companies" (w.e.f. 8-3-2019).`
  line
  line `2. Subs. by s. 202, ibid., for "an offence under this Act" (w.e.f. 8-3-2019).`
  line
  line `3. Subs. by s. 202, ibid., for "offence" (w.e.f. 8-3-2019).`
obj_root_law_sections_22:
  sectionId (16677)
  sectionNo (22)
  orderNo 36
  title `Cognizance of offences by courts`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16677&sectionno=22&orderno=36&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_content:
  string
  line ^1
  line `[22. Cognizance of offences by courts.--(1) No court shall take cognizance of any offence`
  line `punishable under this Act or any rules or regulations or bye-laws made thereunder, save on a complaint`
  line `made by the Central Government or State Government or the Securities and Exchange Board of India or`
  line `by any person.`
  line
  line ^2
  line `* * * * *]`
obj_root_law_sections_22_footnotes:
  string
  line `1. Subs. by Act 1 of 2005, s. 19, for section 22 (w.e.f. 12-10-2004).`
  line
  line `2. Sub-section (2) omitted by Act 27 of 2014, s. 52 (w.e.f. 18-7-2013).`
obj_root_law_sections_22_a:
  sectionId (16678)
  sectionNo 22A
  orderNo 37
  title `Composition of certain offences.`
  content obj_root_law_sections_22_a_content
  footnotes obj_root_law_sections_22_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16678&sectionno=22A&orderno=37&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_a_content:
  string
  line `[22A. Composition of certain offences.--Notwithstanding anything contained in the Code of`
  line `Criminal Procedure, 1973 (2 of 1974), any offence punishable under this Act, not being an offence`
  line `punishable with imprisonment only, or with imprisonment and also with fine, may either before or after`
  line `the institution of any proceeding, be compounded by a Securities Appellate Tribunal or a court before`
  line `which such proceedings are pending.]`
obj_root_law_sections_22_a_footnotes:
  string
  line
obj_root_law_sections_22_b:
  sectionId (16679)
  sectionNo 22B
  orderNo 38
  title `Power to grant immunity.`
  content obj_root_law_sections_22_b_content
  footnotes obj_root_law_sections_22_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16679&sectionno=22B&orderno=38&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_b_content:
  string
  line `[22B. Power to grant immunity.--(1) The Central Government may, on recommendation by the`
  line `Board, if the Central Government is satisfied, that any person, who is alleged to have violated any of the`
  line `provisions of this Act or the rules or the regulations made thereunder, has made a full and true disclosure`
  line `in respect of alleged violation, grant to such person, subject to such conditions as it may think fit to`
  line `impose, immunity from prosecution for any offence under this Act, or the rules or the regulations made`
  line `thereunder or also from the imposition of any penalty under this Act with respect to the alleged violation:`
  line
  line `Provided that no such immunity shall be granted by the Central Government in cases where the`
  line `proceedings for the prosecution for any such offence have been instituted before the date of receipt of`
  line `application for grant of such immunity:`
  line
  line `Provided further that recommendation of the Board under this sub-section shall not be binding upon`
  line `the Central Government.`
  line
  line `(2) An immunity granted to a person under sub-section (1) may, at any time, be withdrawn by the`
  line `Central Government, if it is satisfied that such person had, in the course of the proceedings, not complied`
  line `with the condition on which the immunity was granted or had given false evidence, and thereupon such`
  line `person may be tried for the offence with respect to which the immunity was granted or for any other`
  line `offence of which he appears to have been guilty in connection with the contravention and shall also`
  line `become liable to the imposition of any penalty under this Act to which such person would have been`
  line `liable, had not such immunity been granted.]`
obj_root_law_sections_22_b_footnotes:
  string
  line
obj_root_law_sections_22_c:
  sectionId (16680)
  sectionNo 22C
  orderNo 39
  title `Establishment of Special Courts`
  content obj_root_law_sections_22_c_content
  footnotes `1. Ins. by Act 27 of 2014, s. 53 (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16680&sectionno=22C&orderno=39&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_c_content:
  string
  line ^1
  line `[22C. Establishment of Special Courts.--(1) The Central Government may, for the purpose of`
  line `providing speedy trial of offences under this Act, by notification, establish or designate as many Special`
  line `Courts as may be necessary.`
  line
  line `(2) A Special Court shall consist of a single judge who shall be appointed by the Central Government`
  line `with the concurrence of the Chief Justice of the High Court within whose jurisdiction the judge to be`
  line `appointed is working.`
  line
  line `(3) A person shall not be qualified for appointment as a judge of a Special Court unless he is,`
  line `immediately before such appointment, holding the office of a Sessions Judge or an Additional Sessions`
  line `Judge, as the case may be.]`
obj_root_law_sections_22_d:
  sectionId (16681)
  sectionNo 22D
  orderNo 40
  title `Offences triable by Special Courts`
  content obj_root_law_sections_22_d_content
  footnotes `1. Ins. by Act 27 of 2014, s. 53 (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16681&sectionno=22D&orderno=40&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_d_content:
  string
  line `^1[22D. Offences triable by Special Courts.--Notwithstanding anything contained in the Code of`
  line `Criminal Procedure, 1973 (2 of 1974), all offences under this Act committed prior to the date of`
  line `commencement of the Securities Laws (Amendment) Act, 2014 (27 of 2014) or on or after the date of`
  line `such commencement, shall be taken cognizance of and tried by the Special Court established for the area`
  line `in which the offence is committed or where there are more Special Courts than one for such area, by such`
  line `one of them as may be specified in this behalf by the High Court concerned.]`
obj_root_law_sections_22_e:
  sectionId (16682)
  sectionNo 22E
  orderNo 41
  title `Appeal and revision`
  content obj_root_law_sections_22_e_content
  footnotes `1. Ins. by Act 27 of 2014, s. 53 (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16682&sectionno=22E&orderno=41&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_e_content:
  string
  line `^1[22E. Appeal and revision.--The High Court may exercise, so far as may be applicable, all the`
  line `powers conferred by Chapters XXIX and XXX of the Code of Criminal Procedure, 1973 (2 of 1974) on a`
  line `High Court, as if a Special Court within the local limits of the jurisdiction of the High Court were a Court`
  line `of Session trying cases within the local limits of the jurisdiction of the High Court.]`
obj_root_law_sections_22_f:
  sectionId (16683)
  sectionNo 22F
  orderNo 42
  title `Application of Code to proceedings before Special Court`
  content obj_root_law_sections_22_f_content
  footnotes `1. Ins. by Act 27 of 2014, s. 53 (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16683&sectionno=22F&orderno=42&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_f_content:
  string
  line `^1[22F. Application of Code to proceedings before Special Court.--(1) Save as otherwise provided in`
  line `this Act, the provisions of the Code of Criminal Procedure, 1973 (2 of 1974) shall apply to the`
  line `proceedings before a Special Court and for the purposes of the said provisions, the Special Court shall be`
  line `deemed to be a Court of Session and the person conducting prosecution before a Special Court shall be`
  line `deemed to be a Public Prosecutor within the meaning of clause (u) of section 2 of the Code of Criminal`
  line `Procedure, 1973.`
  line
  line `(2) The person conducting prosecution referred to in sub-section (1) should have been in practice as`
  line `an advocate for not less than seven years or should have held a post, for a period of not less than seven`
  line `years, under the Union or a State, requiring special knowledge of law.]`
obj_root_law_sections_22_g:
  sectionId (16684)
  sectionNo 22G
  orderNo 43
  title `Transitional provisions.`
  content obj_root_law_sections_22_g_content
  footnotes `1. Ins. by Act 27 of 2014, s. 53 (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16684&sectionno=22G&orderno=43&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_22_g_content:
  string
  line `^1[22G. Transitional provisions.--Any offence committed under this Act, which is triable by a Special`
  line `Court shall, until a Special Court is established, be taken cognizance of and tried by a Court of Session`
  line `exercising jurisdiction over the area, notwithstanding anything contained in the Code of Criminal`
  line `Procedure, 1973 (2 of 1974):`
  line
  line `Provided that nothing contained in this section shall affect the powers of the High Court under section`
  line `407 of the Code to transfer any case or class of cases taken cognizance by a Court of Session under this`
  line section.]
obj_root_law_sections_23:
  sectionId (16685)
  sectionNo (23)
  orderNo 44
  title Appeals.
  content obj_root_law_sections_23_content
  footnotes `1. Subs. by Act 32 of 1999, s. 14, for 'an order of the Board made" (w.e.f.16-12-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16685&sectionno=23&orderno=44&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_content:
  string
  line `(1) Any person aggrieved by 2`
  line `[an order of the Board made before the commencement`
  line `of the Securities Laws (Second Amendment) Act, 1999 (32 of 1999)] under this Act, or the regulations`
  line `made thereunder may prefer an appeal to the Central Government within such time as may be prescribed.`
  line
  line `(2) No appeal shall be admitted if it is preferred after the expiry of the period prescribed therefor:`
  line
  line `Provided that an appeal may be admitted after the expiry of the period prescribed therefor if the`
  line `appellant satisfies the Central Government that he had sufficient cause for not preferring the appeal within`
  line `the prescribed period.`
  line
  line `(3) Every appeal made under this section shall be made in such form and shall be accompanied by a`
  line `copy of the order appealed against and by such fees as may be prescribed.`
  line
  line `(4) The procedure for disposing of an appeal shall be such as may be prescribed:`
  line
  line `Provided that before disposing of an appeal, the appellant shall be given a reasonable opportunity of`
  line `being heard.`
obj_root_law_sections_23_a:
  sectionId (16686)
  sectionNo 23A
  orderNo 45
  title `Appeal to Securities Appellate Tribunal.`
  content obj_root_law_sections_23_a_content
  footnotes obj_root_law_sections_23_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16686&sectionno=23A&orderno=45&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_a_content:
  string
  line ^1
  line `[23A. Appeal to Securities Appellate Tribunal.--(1) Save as provided in sub-section (2), any`
  line `person aggrieved by an order of the Board made, on and after the commencement of the Securities Laws`
  line `(Second Amendment) Act, 1999 (32 of 1999), under this Act, or the regulations made thereunder,`
  line ^2
  line `[or by an order made by an adjudicating officer under this Act] may prefer an appeal to a Securities`
  line `Appellate Tribunal having jurisdiction in the matter.`
  line
  line ^3
  line `* * * * *`
  line
  line `(3) Every appeal under sub-section (1) shall be filed within a period of forty-five days from the date`
  line `on which a copy of the order made by the Board is received by the person referred to in sub-section (1)`
  line `and it shall be in such form and be accompanied by such fees as may be prescribed:`
  line
  line `Provided that the Securities Appellate Tribunal may entertain an appeal after the expiry of the said`
  line `period of forty-five days if it is satisfied that there was sufficient cause for not filing it within that period.`
  line
  line `(4) On receipt of an appeal under sub-section (1), the Securities Appellate Tribunal may, after giving`
  line `the parties to the appeal an opportunity of being heard, pass such orders thereon as it thinks fit,`
  line `confirming, modifying or setting aside the order appealed against.`
  line
  line `(5) The Securities Appellate Tribunal shall send a copy of every order made by it to the Board and`
  line `parties to the appeal.`
  line
  line `(6) The appeal filed before the Securities Appellate Tribunal under sub-section (1) shall be dealt with`
  line `by it as expeditiously as possible and endeavour shall be made by it to dispose of the appeal finally within`
  line `six months from the date of receipt of the appeal.]`
obj_root_law_sections_23_a_footnotes:
  string
  line `1. Ins. by Act 32 of 1999, s. 15 (w.e.f. 16-12-1999).`
  line
  line `2. Ins. by Act 1 of 2005, s. 20 (w.e.f. 12-10-2004).`
  line
  line `3. Omitted by Act 27 of 2014, s. 54 (w.e.f 18-7-2013).`
obj_root_law_sections_23_b:
  sectionId (16687)
  sectionNo 23B
  orderNo 46
  title `Procedure and powers of Securities Appellate Tribunal.`
  content obj_root_law_sections_23_b_content
  footnotes `1. Ins. by Act 32 of 1999, s. 15 (w.e.f. 16-12-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16687&sectionno=23B&orderno=46&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_b_content:
  string
  line `^1[23B. Procedure and powers of Securities Appellate Tribunal.--(1) The Securities Appellate`
  line `Tribunal shall not be bound by the procedure laid down by the Code of Civil Procedure, 1908 (5 of 1908),`
  line `but shall be guided by the principles of natural justice and, subject to the other provisions of this Act and`
  line `of any rules, the Securities Appellate Tribunal shall have powers to regulate their own procedure`
  line `including the places at which they shall have their sittings.`
  line
  line `(2) The Securities Appellate Tribunal shall have, for the purpose of discharging their functions under`
  line `this Act, the same powers as are vested in a civil court under the Code of Civil Procedure,`
  line `1908 (5 of 1908), while trying a suit in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) receiving evidence on affidavits;`
  line
  line `(d) issuing commissions for the examination of witnesses or documents;`
  line
  line `(e) reviewing its decisions;`
  line
  line `(f) dismissing an application for default or deciding it ex parte;`
  line
  line `(g) setting aside any order of dismissal of any application for default or any order passed by it`
  line `ex parte; and`
  line
  line `(h) any other matter which may be prescribed.`
  line
  line `(3) Every proceeding before the Securities Appellate Tribunal shall be deemed to be a judicial`
  line `proceeding within the meaning of sections 193 and 228, and for the purposes of section 196 of the Indian`
  line `Penal Code (45 of 1860) and the Securities Appellate Tribunal shall be deemed to be a civil court for all`
  line `the purposes of section 195 and Chapter XXVI of the Code of Criminal Procedure, 1973 (2 of 1974).]`
obj_root_law_sections_23_c:
  sectionId (16688)
  sectionNo 23C
  orderNo 47
  title `Right to legal representation.`
  content obj_root_law_sections_23_c_content
  footnotes `1. Ins. by Act 32 of 1999, s. 15 (w.e.f. 16-12-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16688&sectionno=23C&orderno=47&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_c_content:
  string
  line `^1[23C. Right to legal representation.--The appellant may either appear in person or authorise one or`
  line `more chartered accountants or company secretaries or cost accountants or legal practitioners or any of its`
  line `officers to present his or its case before the Securities Appellate Tribunal.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "chartered accountant" means a chartered accountant as defined in clause (b) of`
  line `sub-section (1) of section 2 of Chartered Accountants Act, 1949 (38 of 1949) and who has obtained a`
  line `certificate of practice under sub-section (1) of section 6 of that Act;`
  line
  line `(b) "company secretary" means a company secretary as defined in clause (c) of sub-section (1) of`
  line `section 2 of the Company Secretaries Act, 1980 (56 of 1980) and who has obtained a certificate of`
  line `practice under sub-section (1) of section 6 of that Act;`
  line
  line `(c) "cost accountant" means a cost accountant as defined in clause (b) of sub-section (1) of`
  line `section 2 of Cost and Works Accountants Act, 1959 (23 of 1959) and who has obtained a certificate`
  line `of practice under sub-section (1) of section 6 of that Act;`
  line
  line `(d) "legal practitioner" means an advocate, vakil or an attorney of any High Court, and includes a`
  line `pleader in practice.]`
obj_root_law_sections_23_d:
  sectionId (16689)
  sectionNo 23D
  orderNo 48
  title Limitations.
  content obj_root_law_sections_23_d_content
  footnotes `1. Ins. by Act 32 of 1999, s. 15 (w.e.f. 16-12-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16689&sectionno=23D&orderno=48&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_d_content:
  string
  line `^1[23D. Limitation.--The provisions of the Limitation Act, 1963 (36 of 1963) shall, as far as may be,`
  line `apply to an appeal made to a Securities Appellate Tribunal.]`
obj_root_law_sections_23_e:
  sectionId (16690)
  sectionNo 23E
  orderNo 49
  title `Civil Court not to have jurisdiction`
  content obj_root_law_sections_23_e_content
  footnotes `1. Ins. by Act 32 of 1999, s. 15 (w.e.f. 16-12-1999).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16690&sectionno=23E&orderno=49&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_e_content:
  string
  line `^1[23E. Civil court not to have jurisdiction.--No civil court shall have jurisdiction to entertain any`
  line `suit or proceeding in respect of any matter which a Securities Appellate Tribunal is empowered by or`
  line `under this Act to determine and no injunction shall be granted by any court or other authority in respect of`
  line `any action taken or to be taken in pursuance of any power conferred by or under this Act.]`
obj_root_law_sections_23_f:
  sectionId (16691)
  sectionNo 23F
  orderNo 50
  title `Appeal to Supreme Court`
  content obj_root_law_sections_23_f_content
  footnotes obj_root_law_sections_23_f_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16691&sectionno=23F&orderno=50&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_f_content:
  string
  line ^1[^1
  line `[23F. Appeal to Supreme Court.--Any person aggrieved by any decision or order of the Securities`
  line `Appellate Tribunal may file an appeal to the Supreme Court within sixty days from the date of`
  line `communication of the decision or order of the Securities Appellate Tribunal to him on any question of`
  line `law arising out of such order:`
  line
  line `Provided that the Supreme Court may, if it is satisfied that the appellant was prevented by sufficient`
  line `cause from filing the appeal within the said period, allow it to be filed within a further period not`
  line `exceeding sixty days.]]`
obj_root_law_sections_23_f_footnotes:
  string
  line `1. Ins. by Act 32 of 1999, s. 15 (w.e.f. 16-12-1999).`
  line
  line `2. Subs. by Act 1 of 2005, s. 21, for section 23F (w.e.f. 12-10-2004).`
obj_root_law_sections_23_g:
  sectionId (50603)
  sectionNo 23G
  orderNo 51
  title `Powers of Board not to apply to International Financial Services Centre.`
  content obj_root_law_sections_23_g_content
  footnotes `1. Ins. by Act 50 of 2019, s. 33 and the second Schedule (w.e.f. 1-10-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=50603&sectionno=23G&orderno=51&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_23_g_content:
  string
  line `^1[23G. Powers of Board not to apply to International Financial Services Centre.--`
  line `Notwithstanding anything contained in any other law for the time being in force, the powers exercisable`
  line `by the Board under this Act,--`
  line
  line `(a) shall not extend to an International Financial Services Centre set up under sub-section (1) of`
  line `section 18 of the Special Economic Zones Act, 2005 (28 of 2005);`
  line
  line `(b) shall be exercisable by the International Financial Services Centres Authority established`
  line `under sub-section (1) of section 4 of the International Financial Services Centres Authority Act, 2019,`
  line
  line `in so far as regulation of financial products, financial services and financial institutions that are permitted`
  line `in the International Financial Services Centres are concerned.]`
obj_root_law_sections_24:
  sectionId (16692)
  sectionNo (24)
  orderNo 52
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16692&sectionno=24&orderno=52&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_24_content:
  string
  line `(1) The Central Government may, by`
  line `notification in the Official Gazette, make rules for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line ^1
  line `[(a) the manner of inquiry under sub-section (1) of section 19H;`
  line
  line `(aa) the time within which an appeal may be preferred under sub-section (1) of section 23;]`
  line
  line `(b) the form in which an appeal may be preferred under sub-section (3) of section 23 and the fees`
  line `payable in respect of such appeal;`
  line
  line `(c) the procedure for disposing of an appeal under sub-section (4) of section 23;`
  line
  line ^2
  line `[(d) the form in which an appeal may be filed before the Securities Appellate Tribunal under`
  line `section 23A and the fees payable in respect of such appeal.]`
obj_root_law_sections_24_footnotes:
  string
  line `1. Subs. by s. 22, ibid., for clause (a) (w.e.f. 12-10-2004).`
  line
  line `2. Ins. by Act 32 of 1999, s. 16 (w.e.f. 16-12-1999).`
obj_root_law_sections_25:
  sectionId (16693)
  sectionNo (25)
  orderNo 53
  title `Power of Board to make regulations.`
  content obj_root_law_sections_25_content
  footnotes `1. Ins. by Act 27 of 2014, s. 55 (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16693&sectionno=25&orderno=53&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_25_content:
  string
  line `(1) Without prejudice to the provisions contained in`
  line `section 30 of the Securities and Exchange Board of India Act, 1992 (15 of 1992), the Board may, by`
  line `notification in the Official Gazette, make regulations consistent with the provisions of this Act and the`
  line `rules made thereunder to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for--`
  line
  line `(a) the form in which record is to be maintained under clause (i) of sub-section (1) of section 2;`
  line
  line `(b) the form in which the certificate of commencement of business shall be issued under`
  line `sub-section (2) of section 3;`
  line
  line `(c) the manner in which the certificate of security shall be surrendered under sub-section (1) of`
  line `section 6;`
  line
  line `(d) the manner of creating a pledge or hypothecation in respect of security owned by a beneficial`
  line `owner under sub-section (1) of section 12;`
  line
  line `(e) the conditions and the fees payable with respect to the issue of certificate of securities under`
  line `sub-section (3) of section 14;`
  line
  line `(f) the rights and obligations of the depositories, participants and the issuers under sub-section (1)`
  line `of section 17;`
  line
  line `(g) the eligibility criteria for admission of securities into the depository under sub-section (2) of`
  line `section 17;`
  line
  line ^1
  line `[(h) the terms determined by the Board for settlement of proceedings under sub-section (2) of`
  line `section 19-IA;`
  line
  line `(i) any other matter which is required to be, or may be, specified by regulations or in respect of`
  line `which provision to be made by regulations.]`
obj_root_law_sections_26:
  sectionId (16694)
  sectionNo (26)
  orderNo 54
  title `Power of depositories to make bye-laws.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16694&sectionno=26&orderno=54&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_26_content:
  string
  line `(1) A depository shall, with the previous approval of`
  line `the Board, make bye-laws consistent with the provisions of this Act and the regulations.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such bye-laws shall`
  line `provide for--`
  line
  line `(a) the eligibility criteria for admission and removal of securities in the depository;`
  line
  line `(b) the conditions subject to which the securities shall be dealt with;`
  line
  line `(c) the eligibility criteria for admission of any person as a participant;`
  line
  line `(d) the manner and procedure for dematerialisation of securities;`
  line
  line `(e) the procedure for transactions within the depository;`
  line
  line `(f) the manner in which securities shall be dealt with or withdrawn from a depository;`
  line
  line `(g) the procedure for ensuring safeguards to protect the interests of participants and beneficial`
  line owners;
  line
  line `(h) the conditions of admission into and withdrawal from a participant by a beneficial owner;`
  line
  line `(i) the procedure for conveying information to the participants and beneficial owners on dividend`
  line `declaration, shareholder meetings and other matters of interest to the beneficial owners;`
  line
  line `(j) the manner of distribution of dividends, interest and monetary benefits received from the`
  line `company among beneficial owners;`
  line
  line `(k) the manner of creating pledge or hypothecation in respect of securities held with a depository;`
  line
  line `(l) inter se rights and obligations among the depository, issuer, participants and beneficial`
  line owners;
  line
  line `(m) the manner and the periodicity of furnishing information to the Board, issuer and other`
  line persons;
  line
  line `(n) the procedure for resolving disputes involving depository, issuer, company or a beneficial`
  line owner;
  line
  line `(o) the procedure for proceeding against the participant committing breach of the regulations and`
  line `provisions for suspension and expulsion of participants from the depository and cancellation of`
  line `agreements entered with the depository;`
  line
  line `(p) the internal control standards including procedure for auditing, reviewing and monitoring.`
  line
  line `(3) Where the Board considers it expedient so to do, it may, by order in writing, direct a depository to`
  line `make any bye-laws or to amend or revoke any bye-laws already made within such period as it may`
  line `specify in this behalf.`
  line
  line `(4) If the depository fails or neglects to comply with such order within the specified period, the Board`
  line `may make the bye-laws or amend or revoke the bye-laws made either in the form specified in the order or`
  line `with such modifications thereof as the Board thinks fit`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (16695)
  sectionNo (27)
  orderNo 55
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16695&sectionno=27&orderno=55&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_27_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (16696)
  sectionNo (28)
  orderNo 56
  title `Application of other laws not barred.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16696&sectionno=28&orderno=56&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_28_content:
  string
  line `The provisions of this Act shall be in addition to, and`
  line `not in derogation of, any other law for the time being in force relating to the holding and transfer of`
  line securities.
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (16697)
  sectionNo (29)
  orderNo 57
  title `Removal of difficulties`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16697&sectionno=29&orderno=57&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_29_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of this Act,`
  line `the Central Government may, by order published in the Official Gazette, make such provisions not`
  line `inconsistent with the provisions of this Act as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of a period of two years from`
  line `the commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (16698)
  sectionNo (30)
  orderNo 58
  title Repealed..
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16698&sectionno=30&orderno=58&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_30_content:
  string
  line `[Amendments to certain enactments.] Rep. by the Repealing and Amending Act, 2001`
  line `(30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_30_footnotes:
