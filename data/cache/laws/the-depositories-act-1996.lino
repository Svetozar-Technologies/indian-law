obj_root_law_sections_30_a:
  sectionId (16699)
  sectionNo 30A
  orderNo 59
  title `Validation of certain acts.`
  content obj_root_law_sections_30_a_content
  footnotes `1. Ins. by Act 27 of 2014, s. 56 (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16699&sectionno=30A&orderno=59&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_30_a_content:
  string
  line ^1
  line `[30A. Validation of certain acts.-- Any act or thing done or purporting to have been done under the`
  line `principal Act, in respect of settlement of administrative and civil proceedings, shall, for all purposes, be`
  line `deemed to be valid and effective as if the amendments made to the principal Act had been in force at all`
  line `material times.]`
obj_root_law_sections_31:
  sectionId (16700)
  sectionNo (31)
  orderNo 60
  title `Repeal and saving.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00013_199622_1517807323191&sectionId=16700&sectionno=31&orderno=60&orgactid=AC_CEN_5_24_00013_199622_1517807323191
obj_root_law_sections_31_content:
  string
  line `(1) The Depositories (Third) Ordinance, 1996 (Ord. 28 of 1996) is hereby`
  line repealed.
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_31_footnotes:
  string
  line
