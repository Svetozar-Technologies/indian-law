obj_root_law_sections_1:
  sectionId (42411)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00020_198559_1517807326718&sectionId=42411&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00020_198559_1517807326718
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Judges (Protection) Act, 1985.`
  line
  line `(2) It extends to the whole of India ^1***.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule (w.e.f. 31-10-`
  line `2019).`
obj_root_law_sections_2:
  sectionId (42412)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00020_198559_1517807326718&sectionId=42412&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00020_198559_1517807326718
obj_root_law_sections_2_content:
  string
  line `In this Act, "Judge" means not only every person who is officially designated as a`
  line `Judge, but also every person—`
  line
  line `(a) who is empowered by law to give in any legal proceeding a definitive judgment, or a`
  line `judgment which, if not appealed against, would be definitive, or a judgment which, if confirmed by`
  line `some other authority, would be definitive; or`
  line
  line `(b) who is one of a body of persons which body of persons is empowered by law to give such a`
  line `judgment as is referred to in clause (a).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (42413)
  sectionNo (3)
  orderNo 3
  title `Additional protection to Judges.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00020_198559_1517807326718&sectionId=42413&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00020_198559_1517807326718
obj_root_law_sections_3_content:
  string
  line `(1) Notwithstanding anything contained in any other law for`
  line `the time being in force and subject to the provisions of sub-section (2), no court shall entertain or continue`
  line `any civil or criminal proceeding against any person who is or was a Judge for any act, thing or word`
  line `committed, done or spoken by him when, or in the course of, acting or purporting to act in the discharge`
  line `of his official or judicial duty or function.`
  line
  line `(2) Nothing in sub-section (1) shall debar or affect in any manner the power of the Central`
  line `Government or the State Government or the Supreme Court of India or any High Court or any other`
  line `authority under any law for the time being in force to take such action (whether by way of civil, criminal,`
  line `or departmental proceedings or otherwise) against any person who is or was a Judge.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (42414)
  sectionNo (4)
  orderNo 4
  title Saving.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00020_198559_1517807326718&sectionId=42414&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00020_198559_1517807326718
obj_root_law_sections_4_content:
  string
  line `The provisions of this Act shall be in addition to, and not in derogation of, the provisions`
  line `of any other law for the time being in force providing for protection of Judges.`
obj_root_law_sections_4_footnotes:
  string
  line
