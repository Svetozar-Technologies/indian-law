obj_root_law_sections_1:
  sectionId (42925)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42925&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Births, Deaths and Marriages`
  line `Registration Act, 1886; and`
  line
  line `(2) It shall come into force on such day^1as the Central Government, by notification in the Official Gazette, directs.`
  line
  line `^2* * * * *`
obj_root_law_sections_1_footnotes:
  string
  line `1. The 1st October, 1888, see Gazette of India, 1888, Part I, p. 336.`
  line
  line `2. Sub-section (3) rep. by Act 12 of 1891, s. 2 and the First Schedule.`
obj_root_law_sections_2:
  sectionId (42926)
  sectionNo (2)
  orderNo 2
  title Extent.
  content `^1[2. Extent.--This Act extends^2 to the whole of India except ^3[the territories which, immediately before the 1st November, 1956, were comprised in Part B States].]`
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42926&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for section 2.`
  line
  line `2. It has been declared in force in the Sonthal Parganas by s. 3 of the Sonthal Parganas Settlement Regulation, 1872 (3 of 1872).`
  line `It has also been partially extended to Berar by the Berar Laws Act, 1941 (4 of 1941).`
  line
  line `3. Subs. by the Adaptation of Laws (No. 2), Order 1956, for "Part B States".`
obj_root_law_sections_3:
  sectionId (42927)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes `1. The words "by the G.G. in C." rep. by the A.O. 1937.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42927&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_3_content:
  string
  line `In this Act, unless there is something repugnant in the subject or`
  line `context,--"sign" includes mark, when the person making the mark is unable to write his name;`
  line
  line `"prescribed" means prescribed by a rule made ^1`
  line `*** under this Act; and`
  line
  line `"Registrar of Births and Deaths" means a Registrar of Births and Deaths appointed under this`
  line Act.
obj_root_law_sections_4:
  sectionId (42928)
  sectionNo (4)
  orderNo 4
  title `Saving of local laws.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42928&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_4_content:
  string
  line `Nothing in this Act, or in any rule made under this Act, shall affect any law`
  line `heretofore or hereafter passed providing for the registration of births and deaths within particular local`
  line areas.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (42962)
  sectionNo (5)
  orderNo 5
  title `Powers exercisable from time to time`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42962&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_5_content:
  string
  line `All powers conferred by this Act may be exercised from`
  line `time to time as occasion requires.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (42963)
  sectionNo (6)
  orderNo 6
  title `Establishment of general registry offices and appointment of Registrars General.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42963&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_6_content:
  string
  line `(1) Each`
  line `State Government--`
  line
  line `(a) shall establish a general registry office for keeping such certified copies of registers of births and deaths registered under this Act, or marriages registered under Act 3 of 1872^1`
  line `( to provide a form of marriage in certain cases) or the Indian Christian Marriage Act, 1872 ( 15 of 1872), or, beyond the local limits of the ordinary original civil jurisdiction of the High Court of Judicature at Bombay, under the Parsi Marriage and Divorce Act, 1865^2`
  line `(15 of 1865), as may be sent to it under this Act, or under any of the three last-mentioned Acts, as amended by this Act; and`
  line
  line `(b) may appoint to the charge of that office an officer, to be called the Registrar General of Births,`
  line `Deaths and Marriages, for the territories under its administration:`
  line
  line ^3
  line `** * * *`
obj_root_law_sections_6_footnotes:
  string
  line `1. See now the Special Marriage Act, 1954 (43 of 1954).`
  line
  line `2. See now the Parsi Marriage and Divorce Act, 1936 (3 of 1936).`
  line
  line `3. Sub-section (2) rep. by the A.O. 1937.`
obj_root_law_sections_7:
  sectionId (42930)
  sectionNo (7)
  orderNo 7
  title `Indexes to be kept at general registry office.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42930&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_7_content:
  string
  line `Each Registrar General of Births, Deaths and`
  line `Marriages shall cause indexes of all the certified copies of registers sent to his office under this Act, or`
  line `under Act 3 of 1872^1`
  line `the Indian Christian Marriage Act, 1872 (15 of 1872), or the Parsi Marriage and`
  line `Divorce Act, 1865^2`
  line `(15 of 1865), as amended by this Act, to be made and kept in his office in the`
  line `prescribed form.`
obj_root_law_sections_7_footnotes:
  string
  line `1. See now the Special Marriage Act, 1954 (43 of 1954).`
  line
  line `2. See now the Parsi Marriage and Divorce Act, 1936 (3 of 1936).`
obj_root_law_sections_8:
  sectionId (42931)
  sectionNo (8)
  orderNo 8
  title `Indexes to be open to inspection.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42931&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_8_content:
  string
  line `Subject to the payment of the prescribed fees the indexes so`
  line `made shall be at all reasonable time open to inspection by any person applying to inspect them, and`
  line `copies of entries in the certified copies of the registers to which the indexes relate shall be given to all`
  line `persons applying for them.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (42932)
  sectionNo (9)
  orderNo 9
  title `Copies of entries to be admissible in evidence.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42932&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_9_content:
  string
  line `A copy of an entry given under the last`
  line `foregoing section shall be certified by the Registrar General of Births, Deaths and Marriages, or by an`
  line `officer authorised in this behalf by the State Government and shall be admissible in evidence for the`
  line `purpose of proving the birth, death or marriage to which the entry relates.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (42933)
  sectionNo (10)
  orderNo 10
  title `Superintendence of Registrars by Registrar General.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42933&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_10_content:
  string
  line `Each Registrar General of Births,`
  line `Deaths and Marriages shall exercise a general superintendence over the Registrars of Births and Deaths in`
  line `the territories for which he is appointed.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (42964)
  sectionNo (11)
  orderNo 11
  title `Persons whose births and deaths are registrable.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42964&sectionno=11&orderno=11&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_11_content:
  string
  line `(1) The persons whose births and deaths`
  line `shall, in the first instance, be registrable under this Chapter are the following, namely:--`
  line
  line `(a) in ^1`
  line `[the territories to which this Act extends] the members of every race, sect or tribe to which`
  line `the Indian Succession Act, 1865^2`
  line `(10 of 1865) applies, and in respect of which an order under section`
  line `332 of that Act is not for the time being in force, and all persons professing the Christian religion;`
  line
  line ^3
  line `* * * * *`
  line
  line `(2) But the State Government by notification in the Official Gazette, may ^4`
  line `*** extend the operation of`
  line `this Chapter to any other class of persons either generally or in any local area.`
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by the Adaptation of Laws (No. 2), Order 1956, for "a Part A State or a Part C State".`
  line
  line `2. See now the Indian Succession Act, 1925 (39 of 1925), s. 3.`
  line
  line `3. Clause (@i/i@) omitted by the A.O. 1950.`
  line
  line `4. The words with the previous approval of the G. G. in C., omitted by the Act 38 of 1920, s. 2 and the First Schedule.`
obj_root_law_sections_12:
  sectionId (42965)
  sectionNo (12)
  orderNo 12
  title `Power for State Government to appoint Registrars for its territories.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42965&sectionno=12&orderno=12&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_12_content:
  string
  line `The State Government`
  line `may appoint, either by name or by virtue of their office, so many persons as it thinks necessary to be`
  line `Registrars of Births and Deaths for such local areas within the territories under its administration as it`
  line `may define and, if it sees fit, for any class of persons within any part of those territories.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (42936)
  sectionNo (13)
  orderNo 13
  title [Omitted.].
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42936&sectionno=13&orderno=13&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_13_content:
  string
  line `[Power for Central Government to appoint Registrars for Indian States]. Omitted. by the A.O.`
  line 1950.
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (42937)
  sectionNo (14)
  orderNo 14
  title `Registrar to be deemed a public servant.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42937&sectionno=14&orderno=14&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_14_content:
  string
  line `Every Registrar of Births and Deaths shall be`
  line `deemed to be a public servant within the meaning of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (42938)
  sectionNo (15)
  orderNo 15
  title [Repealed.].
  content `[Power to remove Registrars.]—Rep. by the A.O. 1937.`
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42938&sectionno=15&orderno=15&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (42939)
  sectionNo (16)
  orderNo 16
  title `Office and attendance of Registrar.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42939&sectionno=16&orderno=16&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_16_content:
  string
  line `(1) Every Registrar of Births and Deaths shall have an`
  line `office in the local area, or within the part of the territories or dominions for which he is appointed.`
  line `(2) Every Registrar of Births and Deaths to whom the State Government may direct this sub-section`
  line `to apply shall attend at his office for the purpose of registering births and deaths on such days and at such`
  line `hours as the Registrar General of Births, Deaths and Marriages may direct, and shall cause to be placed in`
  line `some conspicuous place on or near the outer door of his office his name, with the addition of Registrar of`
  line `Births and Deaths for the local area or class for which he is appointed, and the days and hours of his`
  line attendance.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (42940)
  sectionNo (17)
  orderNo 17
  title `Absence of Registrar or vacancy in his office.`
  content obj_root_law_sections_17_content
  footnotes `1. The section has been declared by the Government of Madras to apply to all Registrars appointed by that Government under section 12, see Mad. R. and O.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42940&sectionno=17&orderno=17&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_17_content:
  string
  line `(1) When any Registrar of Births and Deaths to`
  line `whom the State Government may direct this section to apply^1`
  line `, not being a Registrar of Births and Deaths`
  line `for a local area in the town of Calcutta, Madras or Bombay is absent, or when his office is temporarily`
  line `vacant, any person whom the Registrar General of Births, Deaths and Marriages appoints in this behalf,`
  line `or, in default of such appointment the Judge of the District Court within the local limits of whose`
  line `jurisdiction the Registrars office is situate, or such other officer as the State Government appoints in this`
  line `behalf, shall be the Registrar of Births and Deaths during such absence or until the State Government fills`
  line `the vacancy.`
  line `(2) When any such Registrar of Births and Deaths for a local area in the town of Calcutta, Madras or`
  line `Bombay is absent, or when his office is temporarily vacant, any person whom the Registrar General of`
  line `Births, Deaths and Marriages appoints in this behalf shall be the Registrar of Births and Deaths during`
  line `such absence or until the State Government fills the vacancy.`
  line `(3) The Registrar General of Births, Deaths and Marriages shall report to the State Government all`
  line `appointments made by him under this section.`
obj_root_law_sections_18:
  sectionId (42941)
  sectionNo (18)
  orderNo 18
  title `Register books to be supplied and preservation of records to be provided for.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42941&sectionno=18&orderno=18&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_18_content:
  string
  line `The State`
  line `Government shall every Registrar of Births and Deaths with a sufficient number of register books of`
  line `births and of register books of deaths, and shall make suitable provision for the preservation of the`
  line `records connected with the registration of births and deaths.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (42966)
  sectionNo (19)
  orderNo 19
  title `Duty of Registrar to register births and deaths of which notice is given`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42966&sectionno=19&orderno=19&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_19_content:
  string
  line `Every Registrar of Births and Deaths of notice of a birth or death within the local area or among the class for which he is appointed, shall, if the notice is given within the prescribed time and in the prescribed mode by a person authorized by this Act to give the notice, forthwith make an entry of the birth or death in the proper register book:`
  line
  line `Provided that—`
  line
  line `(a) if he has reason to believe the notice to be in any respect false, he may refuse to register`
  line `the birth or death until he receives an order from the Judge of the District Court directing him to make`
  line `the entry and prescribing the manner in which the entry is to be made; and`
  line
  line `(b) he shall not enter in the register the name of any person as father of an illegitimate child,`
  line `unless at the request of the mother and of the person acknowledging himself to be the father of the`
  line child.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (42943)
  sectionNo (20)
  orderNo 20
  title `Persons authorised to give notice of birth.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42943&sectionno=20&orderno=20&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_20_content:
  string
  line `Any of the following persons may give notice of a`
  line `birth, namely:—`
  line
  line `(a) the father or mother of the child;`
  line
  line `(b) any person present at the birth;`
  line
  line `(c) any person occupying, at the time of the birth, any part of the house wherein the child was`
  line `born and having knowledge of the child having been born in the house;`
  line
  line `(d) any medical practitioner in attendance after the birth and having personal knowledge of birth occurred;`
  line
  line `(e) any person having charge of the child.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (42944)
  sectionNo (21)
  orderNo 21
  title `Persons authorised to give notice of death.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42944&sectionno=21&orderno=21&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_21_content:
  string
  line `Any of the following persons may give notice of a`
  line `death, namely:—`
  line
  line `(a) any relative of the deceased having knowledge of any of the particulars required to be`
  line `registered concerning the death;`
  line
  line `(b) any person present at the death;`
  line
  line `(c) any person occupying, at the time of the death, any part of the house wherein the death`
  line `occurred and having knowledge of the deceased having died in the house;`
  line
  line `(d) any person in attendance during the last illness of the deceased:`
  line
  line `(e) any person who has seen the body of the deceased after death.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (42945)
  sectionNo (22)
  orderNo 22
  title `Entry of birth or death to be signed by person giving notice.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42945&sectionno=22&orderno=22&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_22_content:
  string
  line `(1) When an entry of a birth or death has been made by the Registrar of Births and Deaths under section 19, the person giving notice of the birth or death must sign the entry in the register in the presence of the Registrar:`
  line
  line `^1[Provided that it shall not be necessary for the person giving notice to attend before the Registrar or to sign the entry in the register if he has given such notice in writing and has furnished to the satisfaction of the Registrar such evidence of his identity as may be required by any rules made by the State Government in this behalf.]`
  line
  line `(2) Until the entry has been so signed, ^2[or the conditions specified in the proviso to sub-section (1) have been complied with] the birth or death shall not be deemed to be registered under this Act.`
  line
  line `(3) When the birth of an illegitimate child is registered, and the mother and the person acknowledging`
  line `himself to be the father of the child jointly request that person may be registered as the father, the mother`
  line `and that person must both sign the entry in the register in the presence of the Registrar.`
obj_root_law_sections_22_footnotes:
  string
  line `1. Ins. by Act 9 of 1911, s. 2.`
  line `2. Ins. by Act 9 of 1911, s. 2`
obj_root_law_sections_23:
  sectionId (42946)
  sectionNo (23)
  orderNo 23
  title `Grant of certificate of registration of birth or death.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42946&sectionno=23&orderno=23&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_23_content:
  string
  line `The Registrar of Births and Deaths`
  line `shall, on application made at the time of registering any birth or death by the person giving notice of the`
  line `birth or death, and on payment by him of the prescribed fee, give to the applicant a certificate in the`
  line `prescribed form signed by the Registrar, of having registered the birth or death.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (42947)
  sectionNo (24)
  orderNo 24
  title `Duty of Registrars as to sending certified copies of entries in register books to Registrar General.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42947&sectionno=24&orderno=24&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_24_content:
  string
  line `(1) Every Registrar of Birth and Deaths in ^1`
  line `[the territories to which this Act extends] shall send to the Registrar General of Birth, Deaths and Marriages for the territories within which the local area or class for which he is appointed is situate or resides, at the prescribed intervals, a true copy certified by`
  line `him, in the prescribed form, of all the entries of births and deaths in the register book kept by him since the last of those intervals:`
  line
  line `Provided that in the case Registrars of Births and Deaths who are clergymen of the Churches of England, Rome and Scotland the Registrar may, if so directed by his ecclesiastical superior, send the certified copies in the first instance to that superior, who shall send them to the proper Registrar General of Births, Deaths and Marriages.`
  line
  line `In this sub-section "Church of England" and "Church of Scotland" means the Church of England and the Church of Scotland as by law established respectively; and "Church of Rome" means the Church which regards the Pope of Rome as its spiritual head.`
  line
  line `^2* * * * *`
  line
  line `^3 * * * * *`
obj_root_law_sections_24_footnotes:
  string
  line `1. Subs. by the Adaptation of Laws (No. 2), Order 1956, for "Part A States or Part C States".`
  line
  line `2 Sub-section (2) omitted by the A.O. 1950.`
  line
  line `3. The proviso rep. by the A.O. 1937.`
obj_root_law_sections_25:
  sectionId (42948)
  sectionNo (25)
  orderNo 25
  title `Searches and copies of entries in register books.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42948&sectionno=25&orderno=25&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_25_content:
  string
  line `(1) Every Registrar of Births and Deaths`
  line `shall, on payment of the prescribed fees, at all reasonable times, allow searches to be made in the register`
  line `books kept by him, and give a copy of any entry in the same.`
  line
  line `(2) Every copy of an entry in a register book given under this section shall be certified by the`
  line `Registrar of Births and Deaths, and shall be admissible in evidence for the purpose of proving the birth or`
  line `death to which the entry relates.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (42949)
  sectionNo (26)
  orderNo 26
  title `Exceptional provision for registration of certain births and deaths.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42949&sectionno=26&orderno=26&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_26_content:
  string
  line Notwithstanding
  line `anything in section 19, the ^1`
  line `[State Government] may make rules^2`
  line `authorising Registrars of Births and`
  line `Deaths, on conditions and in circumstances to be specified in the rules, to register births and deaths`
  line `occurring outside the local areas or classes for which they are appointed.`
obj_root_law_sections_26_footnotes:
  string
  line `1. Subs. by Act 9 of 1911, s. 3 for "G.G. in C.".`
  line
  line `2. For rules made under section 26 conjointly with sections 28 and 36, see Gazette of India, 1888, Part. I, p. 336, and different`
  line `local Rules and Orders. All rules made by the G.G. in C. under this Act, before 1911, shall be deemed to have been made by`
  line `the State Governments, see section 6 of Act 9 of 1911.`
obj_root_law_sections_27:
  sectionId (42967)
  sectionNo (27)
  orderNo 27
  title `Penalty for willfully giving false information`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42967&sectionno=27&orderno=27&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_27_content:
  string
  line `If any person willfully makes, or causes to be`
  line `made, for the purpose of being inserted in any register of births or deaths, any false statement in`
  line `connection with any notice of a birth or death under this Act, he shall be punished with imprisonment for`
  line `a term which may extend to three years, or with fine, or with both.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (42968)
  sectionNo (28)
  orderNo 28
  title `Correction of entry in register of births or deaths.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42968&sectionno=28&orderno=28&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_28_content:
  string
  line `(1) If it is proved to the satisfaction of a`
  line `Registrar of Births and Deaths that any entry of a birth or death in any register kept by him under this Act is erroneous in form or substance, he may, subject to such rules^1`
  line `as may be made by the ^2[State Government] with respect to the conditions and circumstances on and in which errors may be corrected,`
  line `correct the error by entry in the margin, without any alteration of the original entry, and shall sign the marginal entry and add thereto the date of the correction.`
  line
  line `(2) If a certified copy of the entry has already been sent to the Registrar General of Births, Deaths and Marriages, the Registrar of Births and Deaths shall make and send a separate certified copy of the original erroneous entry and of the marginal correction therein made.`
obj_root_law_sections_28_footnotes:
  string
  line `1. For rules made under section 26 conjointly with sections 28 and 36, see Gazette of India, 1888, Part. I, p. 336 and different local Rules and orders. All rules made by the G.G. in C. under this Act, before 1911, shall be deemed to have been made by`
  line `the State Government, see section 6 of Act 9 of 1911.`
  line `2. Subs. by Act 9 of 1911, s. 3 for "G.G. in C.".`
obj_root_law_sections_29:
  sectionId (42952)
  sectionNo (29)
  orderNo 29
  title [Repealed.].
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42952&sectionno=29&orderno=29&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_29_content:
  string
  line `[Addition of new section after section 13, Act 3`
  line `of 1872]. Rep. by the Repealing Act, 1938 (1 of`
  line `1938), s. 2 and the Schedule.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (42953)
  sectionNo (30)
  orderNo 30
  title [Repealed.].
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42953&sectionno=30&orderno=30&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_30_content:
  string
  line `[Amendment of the Indian Christian Marriage Act, 1872].`
  line `Rep. by s. 2 and the Schedule, ibid.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (42954)
  sectionNo (31)
  orderNo 31
  title [Repealed.].
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42954&sectionno=31&orderno=31&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_31_content:
  string
  line `[Addition of new section after section 8 of the Parsi Marriage and Divorce Act, 1865]. Rep. by`
  line `s. 2 and the Schedule, ibid.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (42969)
  sectionNo (32)
  orderNo 32
  title `Permission to persons having custody of certain records to send them within one year to Registrar General.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42969&sectionno=32&orderno=32&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_32_content:
  string
  line `If any person in ^1[the territories to which this Act extends] has for the time being`
  line `the custody of any register or record of birth, baptism, naming, dedication, death or burial of any persons of the classes referred to in section 11, subsection (1), or, of any register or record of marriage of any persons of the classes to which Act III of 1872 or the Indian Christian Marriage Act, 1872 (15 of 1872) or the Parsi Marriage and Divorce Act, 1865 (15 of 1865) applies, and if such register or record has been made otherwise than in performance of a duly specially enjoined by the law of the country in which the register or record was kept, he may, ^2[ at any time before the first day April, 1891,] send the register or`
  line `record to the office of the Registrar General or Births, Deaths and Marriages for the territories within which he resides, ^3 ***.`
obj_root_law_sections_32_footnotes:
  string
  line `1. Subs. by the Adaptation of Laws (No. 2), Order 1956, for "a Part A State or a Part C State".`
  line
  line `2. Subs. by Act 16 of 1890, s. 1, for "within one year from the date on which this Act comes into force".`
  line
  line `3. Certain words including the proviso which was inserted by Act 38 of 1920, s. 2 and the Schedule, omitted by the A.O. 1950.`
obj_root_law_sections_33:
  sectionId (42956)
  sectionNo (33)
  orderNo 33
  title `Appointment of Commissioners to examine registers.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42956&sectionno=33&orderno=33&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_33_content:
  string
  line `^1 [(1) Any State Government in the case of registers or records sent under section 32 to the Registrar General for the territories under its administration, ^2 *** may appoint so many persons as it ^3 *** thinks fit to be Commissioner for examining such registers or records.]`
  line
  line `(2) The Commissioners so appointed shall hold office for such period as the ^4 [authority appointing them], by the order of appointment, or any subsequent order, directs.`
obj_root_law_sections_33_footnotes:
  string
  line `1. Subs. by Act 38 of 1920, s. 2 and the First Schedule, for sub-section (1).`
  line `2. Certain words omitted by the A.O. 1950.`
  line `3. The words "or he, as the case may be," rep. by the A.O. 1937.`
  line `4. Subs. by Act 38 of 1920, s. 2 and Sch. 1, for "G.G. in C".`
obj_root_law_sections_34:
  sectionId (42957)
  sectionNo (34)
  orderNo 34
  title `Duties of Commissioners.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42957&sectionno=34&orderno=34&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_34_content:
  string
  line `(1) The Commissioners appointed under the last foregoing section`
  line `shall enquire into the state, custody and authenticity of every such register or record as may be sent to the`
  line `Registrar General of Births, Deaths and Marriages under section 32;`
  line
  line `and shall deliver to the Registrar General a descriptive list or descriptive lists of all such registers or records, or portions of registers or records, as they find to be accurate and faithful.`
  line
  line `(2) The list or lists shall contain the prescribed particulars and refer to the registers or records, or to`
  line `the portions of the registers or records, in me prescribed manner.`
  line
  line `(3) The Commissioners, shall also certify in writing, upon some part of every separate book or volume containing any such register or record, or portion of a register or record, as is referred to in any list or lists made by the Commissioners, that it is one of the registers or records, or portions of registers or`
  line `records, referred to in the said list or lists.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (42958)
  sectionNo (35)
  orderNo 35
  title `Searches of lists prepared by Commissioners and grant of certified copies of entries.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42958&sectionno=35&orderno=35&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_35_content:
  string
  line `(1) Subject to the payment of the prescribed fees, the descriptive list or lists of registers or records, or portions of registers or records, delivered by the Commissioners to the Registrar General of Births, Deaths and Marriages shall be, at all reasonable times, open to inspection by any person applying to inspect it or them, and copies of entries in those registers or records shall be given to all persons applying for them.`
  line
  line `(2) A copy of an entry given under this section shall be certified by the Registrar General of Births,Deaths and Marriages, or by an officer or person authorised in this behalf by the State Government and shall be admissible in evidence for the purpose of proving the birth, baptism, naming, dedication, death, burial or marriage to which the entry relates.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_35_a:
  sectionId (42959)
  sectionNo 35A
  orderNo 36
  title `Constitution of additional Commissions for purposes of this Chapter.`
  content obj_root_law_sections_35_a_content
  footnotes obj_root_law_sections_35_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42959&sectionno=35A&orderno=36&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_35_a_content:
  string
  line `^1 [ 35A. Constitution of additional Commissions for purposes of this Chapter.--(1) ^2 *** The State Government ^3 [may by notification in the Official Gazette] appoint more Commissions^4 than one for the purposes of section 33, each such Commission consisting of so many and such members, and having its functions restricted to the disposal, under this Act and the rules there under, of such registers and records sent under section 32 to the Registrar General, as may be specified in the notification.`
  line
  line `(2) If more Commissions than one are appointed in exercise of the power conferred by sub-section (1), then references in this Act to the Commissioners shall be construed as references to the members constituting a Commission so appointed.]`
obj_root_law_sections_35_a_footnotes:
  string
  line `1. Section 35A was added by the Births, Death and Marriages Registration Act, (1886) Amendment Act, 1890 (16 of 1890), s. 2,`
  line `which was repealed by the Devolution Act, 1920 (38 of 1920), s. 3 and the Second Schedule. The present sub-section (1) was`
  line `subs. for the original sub-section by the Devolution Act, 1920 (38 of 1920), s. 2 and the First Schedule, and sub-section (2),`
  line `was inserted by the Repealing and Amending Act, 1934 (24 of 1934), s. 2 and the First Schedule.`
  line
  line `2. The words "The Central Government or" omitted by the A.O. 1950.`
  line
  line `3. Subs. by the A.O. 1937, for "if he or it thinks fit, may by notification in the Gazette of India or the local Official Gazette, as the`
  line `case may be".`
  line
  line `4. For Commissioners appointed under this section, see Gazette of India, 1890, Pt. I, p. 744.`
obj_root_law_sections_36:
  sectionId (42960)
  sectionNo (36)
  orderNo 37
  title Rules.
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42960&sectionno=36&orderno=37&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_36_content:
  string
  line `^1[36. Rules.—^2[(1) The State Government, for each State ^3`
  line `*** may make rules to carry out the purpose of this Act.]`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may.—`
  line
  line `(a) fix the fees payable under this Act;`
  line
  line `(b) prescribe the forms required for the purposes of this Act;`
  line
  line `(c) prescribe the time within which, and the mode in which, persons authorised under this Act to give notice of a birth or death to a Registrar of Births and Deaths must give the notice;`
  line
  line `(d) prescribe the evidence of identity to be furnished to a Registrar of Birth and Deaths by persons giving notice of a birth or death in cases where personal attendance before such Registrar is dispensed with;`
  line
  line `(e) prescribe the registers to be kept and the form and manner in which Registrars of Births and Deaths are to register births and deaths under this Act, and the intervals at which they are to send to the Registrar General of Births, Deaths and Marriages true copies of the entries of births and deaths in the registers kept by them;`
  line
  line `(f) prescribe the conditions and circumstances on and in which Registers of Births and Deaths may correct entries of births and deaths in registers kept by them;`
  line
  line `(g) prescribe the particulars which the descriptive list or lists to be prepared by the Commissioner appointed under Chapter V are to contain, and the manner in which they are to refer to the registers or records, or portions of registers or records, to which they relates; and`
  line
  line `(h) prescribe the custody in which those registers or records are to kept.`
  line
  line `(3) Every power to make rules conferred by this Act is subject to the condition of the rules being made after previous publication.`
  line
  line `(4) All rules made under this Act shall be published in the Official Gazette and on such publication shall have effect as if enacted in this Act.`
obj_root_law_sections_36_footnotes:
  string
  line `1. Subs. by Act 9 of 1911, s. 4, for section 36.`
  line `2. Subs. by the A.O. 1937, for sub-section (1).`
  line `3. The words and "the Central Government for British subjects in Indian States" omitted by the A.O. 1950.`
obj_root_law_sections_37:
  sectionId (42961)
  sectionNo (37)
  orderNo 38
  title [Repealed.].
  content `[Procedure for making and publication of rules]. Rep. by the Births, Deaths and Marriages Registration (Amendment) Act, 1911 (9 of 1911) s. 5.`
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00045_188606_1523273337975&sectionId=42961&sectionno=37&orderno=38&orgactid=AC_CEN_3_20_00045_188606_1523273337975
obj_root_law_sections_37_footnotes:
  string
  line
