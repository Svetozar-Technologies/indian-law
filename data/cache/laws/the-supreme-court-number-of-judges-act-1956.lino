  sectionId (43691)
  sectionNo (2)
  orderNo 2
  title `Maximum number of Supreme Court Judges other than Chief Justice.`
  content obj_root_law_sections_2_content
  footnotes `1. Subs. by Act 37 of 2019, s. 2, for "thirty" (w.e.f. 09-08-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00012_195655_1517807322161&sectionId=43691&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00012_195655_1517807322161
obj_root_law_sections_2_content:
  string
  line `The maximum`
  line `number of Judges of the Supreme Court, excluding the Chief Justice of India, shall be`
  line ^1[thirty-three].
