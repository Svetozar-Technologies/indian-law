obj_root_law_sections_2:
  object
  (str sectionId) (str 43691)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Maximum number of Supreme Court Judges other than Chief Justice.`)
  (str content) (str `The maximum
number of Judges of the Supreme Court, excluding the Chief Justice of India, shall be
^1[thirty-three].`)
  (str footnotes) (str `1. Subs. by Act 37 of 2019, s. 2, for "thirty" (w.e.f. 09-08-2019).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00012_195655_1517807322161&sectionId=43691&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00012_195655_1517807322161)
