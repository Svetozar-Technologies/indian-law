obj_root_law_translations_hi_sections_18:
  kind page
  sectionId pdf-page-18
  sectionNo (18)
  orderNo 18
  title `Page 18`
  content obj_root_law_translations_hi_sections_18_content
  footnotes obj_root_law_translations_hi_sections_18_footnotes
  sourcePage 18
obj_root_law_translations_hi_sections_18_content:
  string
  line 18
  line `ऊपररिावमत क.ि. और ग.घ. द्व ारा हमारी उपवस्‍टथ वत में हस्‍टता िर ककए गए। िहां तक हम िािते हैं इस वििाह में कोई`
  line `विविपूणष बािा िहीं है।`
  line `( हस्‍टता िर ) छ.ि`
  line `( हस्‍टता िर ) झ. ञ तीि सािी`
  line `( हस्‍टता िर ) ि. ठ प्र`
  line `वतहस्‍टता िररत ङ. च.`
  line `वििाह अविकारी`
  line `तारीि 19……………… के ……………… मास का ……………………… कदि`
  line `चतुथष अिुसूची`
  line `( िारा 13 देविए )`
  line `वििाह का प्र माण पत्र`
  line `मैं, ङ. च, एतद् द्व ारा प्र मावणत करता हं कक 200 0..............................के..........................मास के..................कदि`
  line `क.ि. और ग.घ . मेरे समि हाविर हु ए और उिमें से प्रत् ये क िे मेरी उपवस्‍टथ वत में और उि तीि सावियों की उपवस्‍टथ वत में, विन्हों िे इसमें`
  line `िीचे हस्‍टता िर ककए हैं, िारा 11 द्व ारा अपेवित घोषणाएं कीं और उिका परस्‍टप र वििाह इस अविवियम के अिीि मेरी उपवस्‍टथ वत में`
  line `अिुष्ठा वपत ककया गया।`
  line `( हस्‍टता िर ) ङ. च.`
  line `..........का वििाह अविकारी`
  line `( हस्‍टता िर ) क. ि.`
  line िर
  line `( हस्‍टता िर ) ग. घ.`
  line ििु
  line `( हस्‍टता िर ) छ. ि.`
  line `( हस्‍टता िर ) झ. ञ. तीि सािी`
  line `( हस्‍टता िर ) ि. ठ.`
  line `तारीि 19……………… के ……………… मास का ……………………… कदि।`
  line ` यहां पिकारों की विवशवष्ि यां दीविए।`
obj_root_law_translations_hi_sections_18_footnotes:
  string
  line
