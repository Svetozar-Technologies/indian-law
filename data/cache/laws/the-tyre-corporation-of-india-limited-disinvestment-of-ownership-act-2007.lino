obj_root_law_sections_1:
  object
  (str sectionId) (str 36021)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Tyre Corporation of India Limited (Disinvestment of
Ownership) Act, 2007.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36021&sectionno=1&orderno=1&orgactid=AC_CEN_14_15_00006_200750_1517807323337)
obj_root_law_sections_2:
  object
  (str sectionId) (str 36022)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Disinvestment in the company.`)
  (str content) (str `Where the Central Government, on the recommendations of the
Board for Reconstruction of Public Sector Enterprises, is of the opinion that disinvestment is to be made
in the Tyre Corporation of India Limited (hereinafter referred to as the company), it may pass an order
providing for transfer, exchange or relinquishment of shares in the company to any person on such terms
and conditions as may be agreed upon.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36022&sectionno=2&orderno=2&orgactid=AC_CEN_14_15_00006_200750_1517807323337)
obj_root_law_sections_3:
  object
  (str sectionId) (str 36023)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Payment of consideration for disinvestment in the company.`)
  (str content) (str `(1) For the transfer to, and
vesting in, any person, the shares of the company, there shall be given to the Central Government by such
person or in case such person is a company, by such company, such consideration, having regard to the
optimum valuation of land, assets and liabilities of the company in accordance with a valuation method as
specified by the Central Government.

(2) The manner of payment of consideration for transfer of shares of the company to the transferee
shall be such as may be agreed upon between the transferor, the company and the transferee, the person or
the company, as the case may be.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36023&sectionno=3&orderno=3&orgactid=AC_CEN_14_15_00006_200750_1517807323337)
obj_root_law_sections_4:
  object
  (str sectionId) (str 36024)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Manner of disinvestment.`)
  (str content) (str `The Central Government may, in its order made under section 2,
specify that disinvestment of shares shall be effected by one or more of the following methods as may be
specified in such order, namely:--

(a) by making a public offer or preferential allotment or private placement in accordance with
such procedure as applicable in case of any other Government company;

(b) by directing the company to make further issue of equity capital to the members of the public
or preferential allotment or private placement, as the case may be, in accordance with such procedure
as applicable in case of the Government company.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36024&sectionno=4&orderno=4&orgactid=AC_CEN_14_15_00006_200750_1517807323337)
obj_root_law_sections_5:
  object
  (str sectionId) (str 36025)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Provision in respect of officers and other employees of the company.`)
  (str content) (str `(1) Every officer or
other employee of the company, except the Chairman and Directors, serving in its employment
immediately before the disinvestment of the company under this Act, shall continue in office or service
after such disinvestment, on same terms and conditions as would have been admissible to him if there had been no such disinvestment and shall continue to do so until the expiry of the period of three years from
the date of disinvestments.

(2) Where an officer or other employee of the company opts under sub-section (1) not to be in the
employment or service of the company, such officer or other employee shall be deemed to have resigned.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36025&sectionno=5&orderno=5&orgactid=AC_CEN_14_15_00006_200750_1517807323337)
obj_root_law_sections_6:
  object
  (str sectionId) (str 36026)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Act to have overriding effect.`)
  (str content) (str `The provisions of this Act shall have effect notwithstanding
anything inconsistent therewith contained in the Inchek Tyres Limited and National Rubber
Manufactures, Limited (Nationalisation) Act, 1984 (17 of 1984) or any other law for the time being in
force.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36026&sectionno=6&orderno=6&orgactid=AC_CEN_14_15_00006_200750_1517807323337)
