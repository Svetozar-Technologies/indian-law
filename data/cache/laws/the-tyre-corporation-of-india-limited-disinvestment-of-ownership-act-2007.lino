obj_root_law_sections_1:
  sectionId (36021)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36021&sectionno=1&orderno=1&orgactid=AC_CEN_14_15_00006_200750_1517807323337
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Tyre Corporation of India Limited (Disinvestment of`
  line `Ownership) Act, 2007.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (36022)
  sectionNo (2)
  orderNo 2
  title `Disinvestment in the company.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36022&sectionno=2&orderno=2&orgactid=AC_CEN_14_15_00006_200750_1517807323337
obj_root_law_sections_2_content:
  string
  line `Where the Central Government, on the recommendations of the`
  line `Board for Reconstruction of Public Sector Enterprises, is of the opinion that disinvestment is to be made`
  line `in the Tyre Corporation of India Limited (hereinafter referred to as the company), it may pass an order`
  line `providing for transfer, exchange or relinquishment of shares in the company to any person on such terms`
  line `and conditions as may be agreed upon.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (36023)
  sectionNo (3)
  orderNo 3
  title `Payment of consideration for disinvestment in the company.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36023&sectionno=3&orderno=3&orgactid=AC_CEN_14_15_00006_200750_1517807323337
obj_root_law_sections_3_content:
  string
  line `(1) For the transfer to, and`
  line `vesting in, any person, the shares of the company, there shall be given to the Central Government by such`
  line `person or in case such person is a company, by such company, such consideration, having regard to the`
  line `optimum valuation of land, assets and liabilities of the company in accordance with a valuation method as`
  line `specified by the Central Government.`
  line
  line `(2) The manner of payment of consideration for transfer of shares of the company to the transferee`
  line `shall be such as may be agreed upon between the transferor, the company and the transferee, the person or`
  line `the company, as the case may be.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36024)
  sectionNo (4)
  orderNo 4
  title `Manner of disinvestment.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36024&sectionno=4&orderno=4&orgactid=AC_CEN_14_15_00006_200750_1517807323337
obj_root_law_sections_4_content:
  string
  line `The Central Government may, in its order made under section 2,`
  line `specify that disinvestment of shares shall be effected by one or more of the following methods as may be`
  line `specified in such order, namely:--`
  line
  line `(a) by making a public offer or preferential allotment or private placement in accordance with`
  line `such procedure as applicable in case of any other Government company;`
  line
  line `(b) by directing the company to make further issue of equity capital to the members of the public`
  line `or preferential allotment or private placement, as the case may be, in accordance with such procedure`
  line `as applicable in case of the Government company.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (36025)
  sectionNo (5)
  orderNo 5
  title `Provision in respect of officers and other employees of the company.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36025&sectionno=5&orderno=5&orgactid=AC_CEN_14_15_00006_200750_1517807323337
obj_root_law_sections_5_content:
  string
  line `(1) Every officer or`
  line `other employee of the company, except the Chairman and Directors, serving in its employment`
  line `immediately before the disinvestment of the company under this Act, shall continue in office or service`
  line `after such disinvestment, on same terms and conditions as would have been admissible to him if there had been no such disinvestment and shall continue to do so until the expiry of the period of three years from`
  line `the date of disinvestments.`
  line
  line `(2) Where an officer or other employee of the company opts under sub-section (1) not to be in the`
  line `employment or service of the company, such officer or other employee shall be deemed to have resigned.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36026)
  sectionNo (6)
  orderNo 6
  title `Act to have overriding effect.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_14_15_00006_200750_1517807323337&sectionId=36026&sectionno=6&orderno=6&orgactid=AC_CEN_14_15_00006_200750_1517807323337
obj_root_law_sections_6_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in the Inchek Tyres Limited and National Rubber`
  line `Manufactures, Limited (Nationalisation) Act, 1984 (17 of 1984) or any other law for the time being in`
  line force.
obj_root_law_sections_6_footnotes:
  string
  line
