obj_root_law_sections_1:
  sectionId (6755)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00006_196918_1517807324141&sectionId=6755&sectionno=1&orderno=1&orgactid=AC_CEN_5_40_00006_196918_1517807324141
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Registration of Births`
  line `and Deaths Act, 1969.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force in a State on such date ^1`
  line `as the Central Government may, by notification in`
  line `the Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different parts of a State.`
obj_root_law_sections_1_footnotes:
  string
  line `11st October, 1970, vide notification No. G.S.R. 1718, dated 22nd, November, Gazette of India, Extraordinary, Part II, sec. 3(i) in the following areas of the State of Jammu and Kashmir:—`
  line
  line `the area comprised within the jurisdiction of the Police Station of Ramnagar in Udhampur district.`
  line
  line `the area comprised within the jurisdiction of the Police Station of Kupwara in Baramulla district.`
  line
  line `the area comprised within the limits of the Municipalities of Jammu and Srinagar.`
  line
  line `the area comprised within the limits of Town Area Committees of Anantnag, Kathua and Leh.`
  line
  line `1st May, 1974 vide notification No. G.S.R. 379, dated 22-3-1974 in the Union territory of Mizoram.`
  line
  line `1st January, 1971 vide notification No G.S.R. 1927, dated 21-11-1970, see Gazette of India, Extraordinary, Part II, sec. 3(i) in the Union territory of Goa, Daman and Diu.`
  line
  line `1st January, 1971 vide notification No. G.S.R. 2027, dated 24-11-1970, see Gazette of India, Part II, sec. 3(i) in the Union territory of Manipur.`
  line
  line `1st April, 1974, vide notification No. G.S.R. 106, dated 16-1-1971, see Gazette of India, Part II, sec. 3(i) in the Union territory of Andaman and Nicobar Islands.`
  line
  line `1st October, 1971, in the whole of the State of Nagaland vide notification No. G.S.R. 1324, dated 30-8-1971, see Gazette of India, Part II, sec. 3(i), dated 11-9-1971.`
  line
  line `1st July, 1972, in the Union territory of Arunachal Pradesh vide notification No. G.S.R. 552, dated 11-4-1972, see Gazette of India, Part II, sec. 3(i).`
  line
  line `1st April, 1972, in the whole of State of Tripura vide notification No. G.S.R. 202(E), dated 17-3-1972, see Gazette of India, Extraordinary, Part II, sec. 3(i).`
  line
  line `1st December, 1972 vide Notification No. G.S.R. 463(E), dated 21-11-1972, see Gazette of India, Extraordinary, Part II, sec. 3(i) also in the area comprised within the limits of cantonments of Barrackpore, Labong and Jalapahar in the State of West Bengal`
  line
  line `1st July, 1970, vide notification No. G.S.R. 973, dated 26th June, 1972, extended to the Union territory of Delhi.`
  line
  line `1st April, 1970, vide notification No. G.S.R. 514, dated 21st March, 1970, Gazette of India, sec. 3(i), in the areas of the State of Assam except:—`
  line
  line `(i) the district of United Khasi & Jaintia Hills excluding the areas comprised within the limits of:`
  line
  line `(a) Municipality of Shillong`
  line
  line `(b) Contonment of Shillong`
  line
  line `(ii) the entire district of Garo Hills`
  line
  line `(iii) the entire district of United Mikir and North Cachar Hills`
  line
  line `(iv) the entire district of Mizo Hills.`
  line
  line `In the State of West Bengal except:`
  line
  line `(i) The area comprised within the limits of Corporation of Calcutta;`
  line
  line `(ii) the area comprised within the limits of Howrah Municipality;`
  line
  line `(iii) Fort Villiam; and`
  line
  line `(iv) the area comprised, within the limits of cantonments of Barrackpore, Labong and Jalapahar.`
  line
  line `1st April, 1970, vide notification No. G.S.R. 461, dated 7th March, 1970, see Gazette of India, sec. 3(i), in the States and the Union territories:`
  line
  line STATES
  line
  line `1. Andhra Pradesh 8. Mysore`
  line
  line `2. Bihar 9. Orissa`
  line
  line `3. Gujrat 10. Punjab`
  line
  line `4. Haryana 11. Rajasthan`
  line
  line `5. Kerala 12. Tamil Nadu`
  line
  line `6. Madhya Pradesh 13. Uttar Pradesh.`
  line
  line `7. Maharashtra`
