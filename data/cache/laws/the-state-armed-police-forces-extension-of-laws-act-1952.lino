obj_root_law_sections_1:
  sectionId (72651)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes `1. Omitted by Act 62 of 1952, s. 2 and the Schedule, for "except the State of Jammu and Kashmir" (w.e.f. 1-11-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00044_195263_1673588820692&sectionId=72651&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00044_195263_1673588820692
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the State Armed Police Forces (Extension of`
  line `Laws) Act, 1952.`
  line
  line `(2) It extends to the whole of India ^1***.`
obj_root_law_sections_2:
  sectionId (72652)
  sectionNo (2)
  orderNo 2
  title Definition.
  content `In this Act, "armed police force" means any police force constituted by any of the enactments specified in the Schedule for the time being in force.`
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00044_195263_1673588820692&sectionId=72652&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00044_195263_1673588820692
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (72653)
  sectionNo (3)
  orderNo 3
  title `Extension of disciplinary laws of any State to members of the armed police force of that State when serving outside that State.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00044_195263_1673588820692&sectionId=72653&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00044_195263_1673588820692
obj_root_law_sections_3_content:
  string
  line `Where any detachment of an armed police force of a State is serving`
  line `in any part of any other State, whether independently or by being attached to the police force of that other`
  line `State, then, notwithstanding anything contained in section 3 of the Police Act, 1888 (III of 1888), every`
  line `member of the said detachment, while discharging the functions of a police officer in that other State, shall`
  line `continue to be subject to the same laws in respect of discipline and liabilities as would have been applicable`
  line `to him, if he had been discharging those functions within the State to which the said force belongs.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (72654)
  sectionNo (4)
  orderNo 4
  title `Power to add to, or omit from, the Schedule.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00044_195263_1673588820692&sectionId=72654&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00044_195263_1673588820692
obj_root_law_sections_4_content:
  string
  line `The Central Government may, by notification in`
  line `the Official Gazette, add to, or omit from, the Schedule any enactment and on the publication of such a`
  line `notification, the Schedule shall be deemed to be amended accordingly.`
obj_root_law_sections_4_footnotes:
  string
  line
