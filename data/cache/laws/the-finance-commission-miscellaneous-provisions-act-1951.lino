  object
  (str title) (str `वित्त आयोग (प्रकीर्ण उपबंध) अधिनियम, 1951`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1941/2/hH1951-33.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:32:38.832Z`)
