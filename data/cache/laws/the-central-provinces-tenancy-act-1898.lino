  (str title) (str `Right heritable and transferable after notice to landlord, who may claim to purchase.`)
  (str content) (str )
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00119_189811_1675234739417&sectionId=72728&sectionno=41&orderno=41&orgactid=AC_CEN_5_5_00119_189811_1675234739417)
obj_root_law_sections_42:
  object
  (str sectionId) (str 72729)
  (str sectionNo) (str 42)
  (str orderNo) (int 42)
  (str title) (str `Absolute occupancy-tenant not liable to ejectement.`)
  (str content) (str `Notwithstanding any contract to the
contrary, or any provision of a record-of-rights, an absolute occupancy-tenant shall not be ejected from
his holding by his landlord as such for any cause.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00119_189811_1675234739417&sectionId=72729&sectionno=42&orderno=42&orgactid=AC_CEN_5_5_00119_189811_1675234739417)
