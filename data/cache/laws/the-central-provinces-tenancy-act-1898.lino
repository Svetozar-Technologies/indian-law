obj_root_law_sections_42:
  sectionId (72729)
  sectionNo (42)
  orderNo 42
  title `Absolute occupancy-tenant not liable to ejectement.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00119_189811_1675234739417&sectionId=72729&sectionno=42&orderno=42&orgactid=AC_CEN_5_5_00119_189811_1675234739417
obj_root_law_sections_42_content:
  string
  line `Notwithstanding any contract to the`
  line `contrary, or any provision of a record-of-rights, an absolute occupancy-tenant shall not be ejected from`
  line `his holding by his landlord as such for any cause.`
obj_root_law_sections_42_footnotes:
  string
  line
