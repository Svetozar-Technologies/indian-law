  orderNo 45
  title `Accrual of occupancy-tenant-right in sir-land on transfer of right to occupy as proprietor.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00119_189811_1675234739417&sectionId=72732&sectionno=45&orderno=45&orgactid=AC_CEN_5_5_00119_189811_1675234739417
obj_root_law_sections_45_content:
