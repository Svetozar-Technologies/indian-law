obj_root_law_sections_21:
  sectionId (72706)
  sectionNo (21)
  orderNo 21
  title `Remedy for error in division.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00119_189811_1675234739417&sectionId=72706&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00119_189811_1675234739417
obj_root_law_sections_21_content:
  string
  line `(1) If in any division under the foregoing provisions either party`
  line `receives less than the share to which he is entitled, he may, within three months from the date on which`
  line `the division is completed, institute a suit against the other party to recover the value of the additional`
  line `portion of the crop due to him at the price which prevailed on that date.`
  line
  line `(2) If no such suit is instituted within the said period of three months, the division shall for all`
  line `purposes be deemed as between the parties thereto to have been rightly made.`
obj_root_law_sections_21_footnotes:
  string
  line
