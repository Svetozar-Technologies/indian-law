obj_root_law_sections_1:
  sectionId (34801)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34801&sectionno=1&orderno=1&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Asiatic Society Act, 1984.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 25th June, 1984, vide notification No. G.S.R. 470(E), dated 25th June, 1984, see Gazette of India, Extraordinary, Part II,`
  line `sec. (i).`
obj_root_law_sections_2:
  sectionId (34802)
  sectionNo (2)
  orderNo 2
  title `Declaration of Asiatic Society as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34802&sectionno=2&orderno=2&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_2_content:
  string
  line `Whereas the late`
  line `William Jones founded on the 15th day of January, 1784, an institution in Calcutta which is now known`
  line `as the Asiatic Society and the objects of which are such as to make the institution one of national`
  line `importance, it is hereby declared that the said Asiatic Society is an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (34803)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34803&sectionno=3&orderno=3&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "memorandum" means the memorandum of association of the Society;`
  line
  line `(b) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(c) "regulations" includes any rule or regulation (by whatever name called) which the Society is`
  line `competent to make in the exercise of the powers conferred on it under the West Bengal Societies`
  line `Registration Act, 1961 (West Bengal Act XXVI,1961), but shall not include any bye-laws or standing`
  line `orders made under the regulations for the conduct of its day-to-day administration ;`
  line
  line `(d) "Society" means the Asiatic Society being a society within the meaning of the West Bengal`
  line `Societies Registration Act, 1961(West Bengal Act XXVI, 1961), and having its registered office in`
  line Calcutta.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (34804)
  sectionNo (4)
  orderNo 4
  title `Grants, loans, etc., by Central Government to Society.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34804&sectionno=4&orderno=4&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_4_content:
  string
  line `For the purpose of enabling the`
  line `Society to discharge efficiently its functions, including in particular those relating to research, literary,`
  line `library, scientific and museological activities, collection of manuscripts, coins and art objects, and the`
  line `publication of periodicals, books and other literature, the Central Government may, after due`
  line `appropriation made by Parliament by law in this behalf, pay to the Society in each financial year such`
  line `sums of money as that Government considers necessary by way of grants, loans or otherwise.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (34805)
  sectionNo (5)
  orderNo 5
  title `Audit of accounts of Society.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34805&sectionno=5&orderno=5&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_5_content:
  string
  line `(1) The Society shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts including the balance sheet in such form as may be`
  line `approved by the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Society shall be audited by the Comptroller and Auditor-General of India and`
  line `any expenditure incurred by him in connection with such audit shall be payable by the Society to the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Society shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts, and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the office of the`
  line Society.
  line
  line `(4) The accounts of the Society as certified by the Comptroller and Auditor-General of India or any`
  line `person appointed by him in this behalf together with the audit report thereof shall be forwarded annually`
  line `to the Central Government and that Government shall cause the same to be laid before each House of`
  line Parliament.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (34806)
  sectionNo (6)
  orderNo 6
  title `Annual report.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34806&sectionno=6&orderno=6&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_6_content:
  string
  line `The Society shall furnish to the Central Government, at such time each year as`
  line `may be directed, its annual report giving full account of its activities, policies and programmes during the`
  line `previous year and that Government shall cause the same to be laid before each House of Parliament.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (34807)
  sectionNo (7)
  orderNo 7
  title `Prior approval of Central Government necessary for certain action by Society.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34807&sectionno=7&orderno=7&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_7_content:
  string
  line `The Society`
  line `shall not, except with the previous approval of the Central Government,--`
  line
  line `(a) alter, extend or abridge any of the purposes for which it has been established or for which it is`
  line `being used immediately before the commencement of this Act, or amalgamate itself either wholly or`
  line `partially with any other institution or society; or`
  line
  line `(b) alter or amend in any manner the memorandum or regulations; or`
  line
  line `(c) sell or otherwise dispose of any property acquired by the Society with money specifically`
  line `provided for such acquisition by the Central Government:`
  line
  line `Provided that no such approval shall be necessary in the case of any such movable property or`
  line `class of movable property as may be specified by the Central Government in this behalf by general or`
  line `special order; or`
  line
  line `(d) be dissolved.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (34808)
  sectionNo (8)
  orderNo 8
  title `Planning Board.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34808&sectionno=8&orderno=8&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_8_content:
  string
  line `(1) For the purpose of advising it with respect to the planning and`
  line `implementation of the developmental programmes of the Society and other matters concerning the`
  line `Society, the Central Government may, by notification in the Official Gazette, establish a board to be`
  line `called the Planning Board (Asiatic Society).`
  line
  line `(2) The Board shall consist of a Chairman and such other members as may be appointed by the`
  line `Central Government.`
  line
  line `(3) Subject to any rules which the Central Government may make in this behalf, the Board shall have`
  line `the power to regulate its own procedure.`
  line
  line `(4) The term of office of, the procedure to be followed in the discharge of their functions by, the`
  line `manner of filling casual vacancies among, the allowances, if any, payable to, and other matters`
  line `concerning, the members of the Board shall be such as may be prescribed.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (34809)
  sectionNo (9)
  orderNo 9
  title Committees.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34809&sectionno=9&orderno=9&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government may, by notifications in the Official Gazette,`
  line `constitute as many committees, as and when it considers it necessary, consisting of such number of`
  line `persons as it thinks fit to appoint thereto and assign to each such committee all or any of the following`
  line `duties, namely:--`
  line
  line `(a) the preparation and submission to the Central Government, as far as possible before the`
  line `commencement of each financial year, of statements showing programmes of work agreed to be`
  line `undertaken by the Society during that year for which the Central Government may provide funds as`
  line `well as general financial estimates in respect of such work;`
  line
  line `(b) the settlement on broad line of the programmes of such work.`
  line
  line `(2) A committee constituted under sub-section (1) shall, in discharging its duties with respect to any`
  line `matter under this section, have due regard to the advice, if any, tendered in respect of such matter under`
  line `section 8 by the Board to the Central Government.`
  line
  line `(3) Where the Society does not agree to undertake any work suggested by any committee referred to`
  line `in sub-section (1), it shall give to the Central Government its reasons for not so agreeing.`
  line
  line `(4) The procedure to be followed by a committee constituted under sub-section (1) in the discharge of`
  line `its functions, the allowances, if any, payable to the members of such committee and other matters relating`
  line `to such committee shall be such as may be prescribed.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (34810)
  sectionNo (10)
  orderNo 10
  title `Review of work done, inspection of assets, etc.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34810&sectionno=10&orderno=10&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_10_content:
  string
  line `(1) the Central Government may, by`
  line `notification in the Official Gazette, constitute a Committee consisting of such number of persons as it`
  line `thinks fit to appoint thereto for the purpose of--`
  line
  line `(a) reviewing the work done by the Society and the progress made by it;`
  line
  line `(b) inspecting its buildings, equipment and other assets;`
  line
  line `(c) evaluating the work done by the Society; and`
  line
  line `(d) advising Government generally on any matter which in the`
  line
  line `opinion of the Central Government is of importance in connection with the work of the Society;`
  line
  line `and the Committee shall submit its report thereon in such manner as the Central Government may direct.`
  line
  line `(2) The procedure to be followed by, the allowances, if any, payable to, the members of the`
  line `Committee and other matters concerning the Committee shall be such as may be prescribed.`
  line
  line `(3) The Committee shall, subject to the provisions of sub-section (4) and of any rules which the`
  line `Central Government may make in this behalf, have power to regulate its own procedure.`
  line
  line `(4) Notice shall be given in every case to the Society of the intention to cause a review, inspection or`
  line `evaluation to be made, and the Society shall be entitled to appoint a representative who shall have the`
  line `right to be present and be heard at such review, inspection or evaluation.`
  line
  line `(5) The Central Government may address the President of the Society with reference to the result of`
  line `such review, inspection or evaluation as disclosed in any report of the Committee referred to in subsection (1), and the President shall communicate to the Central Government the action, if any, taken`
  line thereon.
  line
  line `(6) When the Central Government has in pursuance of sub-section (5), addressed the President of the`
  line `Society in connection with any matter, and the President does not within a reasonable time take action to`
  line `the satisfaction of the Central Government in respect thereof, the Central Government may, after`
  line `considering any explanations furnished or representations made on behalf of the Society, issue such`
  line `directions as it considers necessary in respect of any of the matters dealt with in the report.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (34811)
  sectionNo (11)
  orderNo 11
  title `Society to afford facilities to Committees.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34811&sectionno=11&orderno=11&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_11_content:
  string
  line `The Society shall be bound to afford all necessary`
  line `facilities to the Board constituted under section 8 and to every committee constituted under section 9 or`
  line `section 10 for the purpose of enabling them to carry out their duties.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (34812)
  sectionNo (12)
  orderNo 12
  title `Power to issue directions to Society.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34812&sectionno=12&orderno=12&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_12_content:
  string
  line `(1) The Central Government may, if it is satisfied that it`
  line `is necessary so to do in the public interest issue, for reasons to be recorded and communicated to the`
  line `Society, such directions as it thinks to the Society, and such directions may include directions requiring`
  line `the Society--`
  line
  line `(a) to amend the memorandum or to make or amend any regulation within such period as may be`
  line `specified in the directions;`
  line
  line `(b) to give priorities to the work undertaken or to be undertaken by the Society in such manner as`
  line `the Central Government may think fit to specify in this behalf.`
  line
  line `(2) Any directions issued under this section shall have effect, notwithstanding anything contained in`
  line `any law for the time being in force or in the memorandum or regulations of the Society.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (34813)
  sectionNo (13)
  orderNo 13
  title `Power of Central Government to assume functions of control.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34813&sectionno=13&orderno=13&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_13_content:
  string
  line `(1) If, in the opinion of the`
  line `Central Government,--`
  line
  line `(i) the Society without just or reasonable cause has made default in giving effect to any direction`
  line `issued under sub-section (6) of section 10 or section 12; or`
  line
  line `(ii) the Council of the Society has exceeded or abused the powers in relation to the Society or any`
  line `part thereof;`
  line
  line `the Central Government may, by written order, direct the Society within a period to be specified in the`
  line `order to show cause to the satisfaction of the Central Government against the making of any appointment`
  line `referred to in sub-section (2).`
  line
  line `(2) If, within the period fixed by any order issued under sub-section (1), cause is not shown to the`
  line `satisfaction of the Central Government, the Central Government may, by order published in the Official`
  line `Gazette and stating the reasons therefor, appoint one or more persons to take over the management of the`
  line `Society or of any of the activities of the Society for such period not exceeding two years as may be`
  line `specified in the order.`
  line
  line `(3) During the period specified in the order issued under sub-section (2),--`
  line
  line `(a) where the order provides for any person or persons taking over the management of the`
  line Society--
  line
  line `(i) all persons holding office as Members of the Council, including the President, shall be`
  line `deemed to have vacated their offices as such;`
  line
  line `(ii) the person or persons appointed under sub-section (2) to take over the management of the`
  line `Society shall exercise all the powers and perform all the duties of the President or Council of the`
  line `Society, whether at a meeting or otherwise, in respect of the Society;`
  line
  line `(b) where the order provides for any person or persons taking over the management of any`
  line `activities of the Society, the person or persons so appointed shall alone be entitled to exercise all the`
  line `powers and perform all the duties of the President or Council in relation to those activities.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (34814)
  sectionNo (14)
  orderNo 14
  title `Act to have overriding effect.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34814&sectionno=14&orderno=14&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_14_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in the memorandum or regulations or the West Bengal`
  line `Societies Registration Act, 1961 (West Bengal Act XXVI, 1961) or any other law for the time being in`
  line force.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (34815)
  sectionNo (15)
  orderNo 15
  title `Power to make rules.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00012_198405_1517807326040&sectionId=34815&sectionno=15&orderno=15&orgactid=AC_CEN_27_37_00012_198405_1517807326040
obj_root_law_sections_15_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(i) matters with respect to the procedure to be followed by the Board under sub-section (3) of`
  line `section 8;`
  line
  line `(ii) the term of office of, the procedure to be followed in the discharge of their functions by, the`
  line `manner of filling casual vacancies among, the allowances, if any, payable to, and other matters`
  line `concerning, the members of the Board under sub-section (4) of section 8;`
  line
  line `(iii) the procedure to be followed by a committee in the discharge of its functions, the allowances,`
  line `if any, payable to the members of the committee and other matters relating to the committee under`
  line `sub-section (4) of section 9;`
  line
  line `(iv) the procedure to be followed by, the allowances, if any, payable to, the members of the`
  line `Committee and other matters concerning the Committee under sub-section (2) of section 10;`
  line
  line `(v) any other matter which is required to be or in respect of which rules may be made under this`
  line Act.
  line
  line `(3) Every rule made by the Central Government under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.`
obj_root_law_sections_15_footnotes:
  string
  line
