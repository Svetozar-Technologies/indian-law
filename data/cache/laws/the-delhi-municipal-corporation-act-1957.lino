  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27114&sectionno=3A&orderno=4&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Division of the area of ^2[^3[the Corporation]] into zones and wards.(1) The area of`
  line `^2[^3[the Corporation]] shall be divided into a number of zones and each zone and into a number of wards as`
  line `specified in the Fourteenth Schedule.`
  line `(2) The ^4[^5[Central Government]] may, by notification in the official Gazette, after the number or the`
  line `name, and increase or diminish the area of any zone or ward specified in the Fourteenth Schedule.]`
obj_root_law_sections_3_a_footnotes:
  string
