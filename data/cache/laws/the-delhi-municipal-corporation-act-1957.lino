obj_root_law_sections_90_a:
  sectionId (67067)
  sectionNo 90A
  orderNo 110
  title `Officers of erstwhile Corporations to become officers of Corporation.`
  content obj_root_law_sections_90_a_content
  footnotes obj_root_law_sections_90_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=67067&sectionno=90A&orderno=110&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_90_a_content:
  string
  line `^1[^2[90A. Officers of erstwhile Corporations to become officers of Corporation.`
  line `---(1) On the date`
  line `of establishment of the Corporation under sub-section (1) of section 3, the officers and employees of the`
  line `erstwhile North Delhi Municipal Corporation, South Delhi Municipal Corporation and East Delhi`
  line `Municipal Corporation shall, with immediate effect, become the officers and employees of the Corporation.`
  line
  line `(2) For the purposes of sub-section (1), the Government may make such rules as may be required.]]`
obj_root_law_sections_90_a_footnotes:
  string
  line `1. Ins. by Delhi Act 12 of 2011, s. 12 (w.e.f. 13-1-2012).`
  line
  line `2. Subs. by Act 10 of 2022, s. 7, for section 90A (w.e.f. 22-5-2022).`
obj_root_law_sections_91:
  sectionId (27217)
  sectionNo (91)
  orderNo 111
  title `Restriction on employment of permanent officers and other employees.`
  content obj_root_law_sections_91_content
  footnotes obj_root_law_sections_91_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27217&sectionno=91&orderno=111&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_91_content:
  string
  line `No permanent`
  line `officer or other employee shall be entertained in any department of the municipal administration unless he`
  line `has been appointed under sub-section (1) of section 89 or his office and emoluments are included in one`
  line `of the schedules for the time being in force prepared and sanctioned under section 90.`
obj_root_law_sections_91_footnotes:
  string
  line
obj_root_law_sections_92:
  sectionId (27218)
  sectionNo (92)
  orderNo 112
  title `Power to make appointments.`
  content obj_root_law_sections_92_content
  footnotes `1. Subs. by Act 67 of 1993, s. 68, for sub-section (1) (w.e.f. 1-10-1993).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27218&sectionno=92&orderno=112&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_92_content:
  string
  line ^1[
  line `(1) Subject to the provisions of section 89, the power of the`
  line `appointing municipal officers and other municipal employees whether temporary or permanent shall vest`
  line `in the Commissioner:`
  line
  line `Provided that the power of appointing officers and other employees immediately subordinate to the`
  line `Municipal Secretary or the Municipal Chief Auditor to category B posts of category C posts shall vest in`
  line `the Standing Committee:`
  line
  line `Provided further that the Standing Committee may delegate to the Municipal Secretary or the`
  line `Municipal Chief Auditor the power of appointing officers and other employees immediately subordinate`
  line `to the said Secretary or Auditor, to category C posts.]`
  line
  line `(2) The claims of the members of the Scheduled Castes shall be taken into consideration, consistently`
  line `with the maintenance of efficiency of administration, in the making of appointments of municipal officers`
  line `and other municipal employees.`
obj_root_law_sections_92_a:
  sectionId (27219)
  sectionNo 92A
  orderNo 113
  title `Recruitment to category B and category C posts.`
  content obj_root_law_sections_92_a_content
