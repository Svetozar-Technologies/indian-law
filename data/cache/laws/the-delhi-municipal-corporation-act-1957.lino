  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27116&sectionno=5&orderno=6&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_5_content:
  string
  line `^1[5. Delimitation of wards.^2[(1) For the purposes of election of councillors, ^3[the area of ^4[^5[the Corporation]] shall be divided into single-Member wards in such manner that the population of each of the`
  line `wards shall, so for as practicable, be the same throughout ^3the area of ^4[^5[the Corporation]].]`
  line
  line `(2) The ^6[^7[Central Government]] shall, by order in the Official Gazette, determine,--`
  line
  line `(a) the number of wards;`
  line
  line `(b) the extent of each ward; ^8***`
  line
  line `(c) the wards in which seats shall be reserved for the Scheduled Castes;]`
  line
  line `^9[(d) The wards in which seats shall be reserved for women; and`
  line
  line `(e) The manner in which seats shall be rotated under sub-sections (6) and (8) of section 3.]`
