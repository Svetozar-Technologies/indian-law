  sectionId (27115)
  sectionNo (4)
  orderNo 5
  title `Duration of the Corporation.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27115&sectionno=4&orderno=5&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_4_content:
  string
  line `^1[4. Duration of ^2[^3[the Corporation]].---(1) ^4[^5[The Corporation]], unless sooner dissolved under section 490,`
  line `shall continue for five years from the date appointed for its first meeting and no longer:`
  line
  line `(2) An election to constitute ^2[^3[the Corporation]] shall be completed--`
  line
  line `(i) before the expiry of its duration specified in sub-section (1);`
  line
  line `(ii) before the expiration of a period of six months from the date of its dissolution :`
  line
  line `Provided that where the remainder of the period for which the dissolved Corporation would have`
  line `continued is less than six months, it shall not be necessary to hold any election under this sub-section for`
  line `constituting ^2[^3[the Corporation]] for such period.]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 67 of 1993, s. 5, for section 4 (w.e.f. 1-10-1993).`
  line
  line `2. Subs. by Delhi Act 12 of 2011, s. 2, for "the Corporation" (w.e.f. 13-1-2012).`
  line
  line `3. Subs. by Act 10 of 2022, s. 2, for "a Corporation" (w.e.f. 22-5-2022).`
  line
  line `4. Subs. by Delhi Act 12 of 2011, s. 2, for "The Corporation" (w.e.f. 13-1-2012).`
  line
  line `5. Subs. by Act 10 of 2022, s. 2, for "A Corporation" (w.e.f. 22-5-2022).`
