obj_root_law_sections_7:
  sectionId (27119)
  sectionNo (7)
  orderNo 9
  title `Elections to the Corporation.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27119&sectionno=7&orderno=9&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_7_content:
  string
  line `^1[^2[7. Elections to ^3[^4[the Corporation]].---(1) The superintendence, direction and control of the`
  line `preparation of electoral rolls for, and the conduct of, all elections to ^3[^4[the Corporation]] shall be vested in the`
  line `Election Commission of the National Capital Territory of Delhi consisting of an Election Commissioner`
  line `to be appointed by the Administrator.`
  line
  line `(2) Subject to the provisions of any law made by the Legislative Assembly of the National Capital`
  line `Territory of Delhi, the conditions of service and tenure of office of the Election Commissioner shall be`
  line `such as the Administrator may by rules determine:`
  line
  line `Provided that the Election Commissioner shall not be removed from office except in a like manner`
  line `and on the like grounds as a Judge of a High Court and the conditions of service of the Election`
  line `Commissioner shall not be varied to his disadvantage after his appointment.`
  line
  line `(3) The Administrator shall, when so requested by the Election Commission make available to that`
  line `Commission such staff which the Administrator considers necessary for discharge of the functions`
  line `conferred on the Election Commission by sub-section (1).]`
obj_root_law_sections_7_footnotes:
  string
  line `1. Subs. by Act 55 of 1974, s. 5, for section 7 (w.e.f. 10-1-1975).`
  line
  line `2. Subs. by Act 67 of 1993, s. 8, for section 7 (w.e.f. 1-10-1993)`
  line
  line `3. Subs. by Delhi Act 12 of 2011, s. 2, for “the Corporation” (w.e.f. 13-1-2012).`
  line
  line `4. Subs. by Act 10 of 2022, s. 2, for “a Corporation” (w.e.f. 22-5-2022).`
obj_root_law_sections_7_a:
  sectionId (27120)
  sectionNo 7A
  orderNo 10
  title `Electoral roll for every ward.`
  content obj_root_law_sections_7_a_content
  footnotes obj_root_law_sections_7_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27120&sectionno=7A&orderno=10&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_7_a_content:
  string
  line `For every ward there shall be an electoral roll which shall be`
  line `prepared in accordance with the provisions of this Act and the rules made thereunder.]`
obj_root_law_sections_7_a_footnotes:
  string
  line
obj_root_law_sections_7_b:
  sectionId (27121)
  sectionNo 7B
  orderNo 11
  title `Electoral registration officers.`
  content obj_root_law_sections_7_b_content
  footnotes obj_root_law_sections_7_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27121&sectionno=7B&orderno=11&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_7_b_content:
  string
  line `(1) The electoral roll for each ward shall be prepared and`
  line `revised by an electoral registration officer who shall be such officer of Government or ^1[^2[the Corporation]] as ^3[the Election Commission may, in consultation with the Government,] designate or nominate in this`
  line behalf.
  line
  line `(2) To assist the electoral registration officer in the discharge of his functions under sub-section (1)`
  line `the ^4[Election Commission may employ such persons as it thinks fit].`
obj_root_law_sections_7_b_footnotes:
  string
  line `1. Subs. by Delhi Act 12 of 2011, s. 2, for the Corporation (w.e.f. 13-1-2012).`
  line
  line `2. Subs. by Act 10 of 2022, s. 2, for a Corporation (w.e.f. 22-5-2022).`
  line
  line `3. Subs. by Act 67 of 1993, s. 9, for Central Government may (w.e.f. 1-10-1993).`
  line
  line `4. Subs. by s. 9, ibid, for "Director of Municipal Elections may employ such persons as he thinks fit" (w.e.f. 1-10-1993).`
obj_root_law_sections_7_c:
  sectionId (27122)
  sectionNo 7C
  orderNo 12
  title `Assistant electoral registration officers.`
  content obj_root_law_sections_7_c_content
  footnotes `1. Subs. by s. 10, ibid. for "The Central Government" (w.e.f. 1-10-1993)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00028_195766_1517807321857&sectionId=27122&sectionno=7C&orderno=12&orgactid=AC_CEN_5_5_00028_195766_1517807321857
obj_root_law_sections_7_c_content:
  string
  line `(1)`
  line `^1[The Election Commission] may appoint one or`
  line `more persons as assistant electoral registration officers to assist any electoral registration officer in the`
  line `performance of his functions.`
  line
  line `(2) Every assistant electoral registration officer shall, subject to the control of the electoral`
  line `registration officer, be competent to perform all or any of the functions of the electoral registration`
  line officer.
obj_root_law_sections_7_d:
  sectionId (27123)
  sectionNo 7D
  orderNo 13
  title `Registration of Electors.`
  content obj_root_law_sections_7_d_content
