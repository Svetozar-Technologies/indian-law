obj_root_law:
  slug the-national-sports-governance-act-2025
  handle (22045)
  collectionHandle 123456789/1362
  title `The National Sports Governance Act, 2025`
  actNumber (25)
  enactmentDate 2025-08-18
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/22045`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (2025)
  ministry `Ministry of Youth Affairs and Sports`
  department `Department of Sports`
  longTitle `An Act to provide for the development and promotion of sports, welfare measures for sportspersons, ethical practices based on basic universal principles of good governance, ethics and fair play of the Olympic and sports movement, the Olympic Charter, the Paralympic Charter, international best practices and established legal standards and to provide for the resolution of sports grievances and sports disputes in a unified, equitable and effective manner and for matters connected therewith or incidental thereto.`
  enforcementDate 1-1-2026
  notification undefined
  fetchedAt `2026-05-10T14:25:29.370Z`
