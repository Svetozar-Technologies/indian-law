obj_root_law:
  object
  (str slug) (str the-national-sports-governance-act-2025)
  (str handle) (str 22045)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Sports Governance Act, 2025`)
  (str actNumber) (str 25)
  (str enactmentDate) (str 2025-08-18)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/22045`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (undefined)
  (str actYear) (str 2025)
  (str ministry) (str `Ministry of Youth Affairs and Sports`)
  (str department) (str `Department of Sports`)
  (str longTitle) (str `An Act to provide for the development and promotion of sports, welfare measures for sportspersons, ethical practices based on basic universal principles of good governance, ethics and fair play of the Olympic and sports movement, the Olympic Charter, the Paralympic Charter, international best practices and established legal standards and to provide for the resolution of sports grievances and sports disputes in a unified, equitable and effective manner and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 1-1-2026)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T14:25:29.370Z`)
