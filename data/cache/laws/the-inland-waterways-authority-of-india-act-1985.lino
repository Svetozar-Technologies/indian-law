obj_root_law_sections_1:
  sectionId (19615)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19615&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Inland Waterways Authority of`
  line `India Act, 1985.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 27th October, 1986, vide notification No. S.O. 763(E), dated 27th October, 1986, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (19616)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19616&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appurtenant land" means all lands appurtenant to a national waterway, whether demarcated`
  line `or not;`
  line
  line `(b) "Authority" means the Inland Waterways Authority of India constituted under section 3;`
  line
  line `(c) "channel" means any waterway, whether natural or artificial;`
  line
  line `(d) "conservancy" includes dredging, training, closure, diversion or abandoning channels;`
  line
  line `(e) "conservancy measures" means measures for purposes of conservancy, but does not include`
  line `measures for protection of banks against floods or for restricting banks which have become eroded`
  line `mainly on account of reasons not connected with shipping and navigation;`
  line
  line `(f) "infrastructure" includes structures such as docks, wharves, jetties, landing stages, locks,`
  line `buoys, inland ports, cargo handling equipment, road and rail access and cargo storage spaces, and the`
  line `expression infrastructural facilities shall be construed accordingly;`
  line
  line `(g) "member" means a member of the Authority appointed under sub-section (3) of section 3;`
  line
  line `(h) "national waterway" means the inland waterway declared by section 2 of the National`
  line `Waterway (Allahabad-Haldia Stretch of the Ganga-Bhagirathi-Hooghly River) Act,`
  line `1982 (49 of 1982), to be a national waterway.`
  line
  line `Explanation.--If Parliament declares by law any other waterway to be a national waterway, then`
  line `from the date on which such declaration takes effect, such other waterway--`
  line
  line `(i) shall be deemed also to be a national waterway within the meaning of this clause; and`
  line
  line `(ii) the provisions of this Act shall, with necessary modifications (including modification for`
  line `construing any reference to the commencement of this Act as a reference to the date aforesaid),`
  line `apply to such national waterway;`
  line
  line `(i) "navigable channel" means a channel navigable during the whole or a part of the year;`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(k) "regulations" means regulations made by the Authority under this Act; and`
  line
  line `(l) "rules" means rules made by the Central Government under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (19617)
  sectionNo (3)
  orderNo 3
  title `Constitution and incorporation of the Inland Waterways Authority of India.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 40 of 2001, s. 2, for sub-section (3) (w.e.f. 1-7-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19617&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_3_content:
  string
  line `(1) With effect`
  line `from such date as the Central Government may, by notification in the Official Gazette, appoint in this`
  line `behalf, there shall be constituted for the purposes of this Act an Authority, to be called the Inland`
  line `Waterways Authority of India.`
  line
  line `(2) The Authority shall be a body corporate by the name aforesaid, having perpetual succession and a`
  line `common seal with power, subject to the provisions of this Act, to acquire, hold and dispose of property,`
  line `both movable and immovable, and to contract and shall by the said name sue and be sued.`
  line
  line `^1[(3) The Authority shall consist of the following members, namely:--`
  line
  line `(a) a Chairman;`
  line
  line `(b) a Vice-Chairman;`
  line
  line `(c) not more than three full-time members; and`
  line
  line `(d) not more than three part-time members,`
  line
  line `to be appointed by the Central Government by notification in the Official Gazette.]`
  line
  line `(4) The Authority may associate with itself, in such manner and for such purposes as may be`
  line `determined by regulations, any person whose assistance or advice it may desire in complying with any of`
  line `the provisions of this Act and a person so associated shall have the right to take part in the discussions of`
  line `the Authority relevant to the purpose for which he has been associated, but shall not be entitled to vote.`
obj_root_law_sections_4:
  sectionId (19618)
  sectionNo (4)
  orderNo 4
  title `Conditions of service of members.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19618&sectionno=4&orderno=4&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_4_content:
  string
  line `The term of office and other conditions of service of the`
  line `members shall be such as may be prescribed.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_4_a:
  sectionId (19619)
  sectionNo 4A
  orderNo 5
  title `Disqualifications for appointment as member.`
  content obj_root_law_sections_4_a_content
  footnotes `1. Ins. by s. 3, ibid. (w.e.f. 1-7-2003)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19619&sectionno=4A&orderno=5&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_4_a_content:
  string
  line `^1[4A. Disqualifications for appointment as member.-- A person shall be disqualified for being`
  line `appointed as a member, if he--`
  line
  line `(a) has been convicted and sentenced to imprisonment for an offence which, in the opinion of the`
  line `Central Government, involves moral turpitude; or`
  line
  line `(b) is an undischarged insolvent; or`
  line
  line `(c) is of unsound mind and stands so declared by a competent court; or`
  line
  line `(d) has been removed or dismissed from the service of the Government or a company owned or`
  line `controlled by the Government; or`
  line
  line `(e) has, in the opinion of the Central Government, such financial or other interest in the Authority`
  line `as is likely to affect prejudicially the discharge by him of his functions as a member.]`
obj_root_law_sections_5:
  sectionId (19620)
  sectionNo (5)
  orderNo 6
  title `Powers of Chairman and Vice-Chairman.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19620&sectionno=5&orderno=6&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_5_content:
  string
  line `(1) The Chairman of the Authority shall, in addition`
  line `to presiding over the meetings of the Authority, exercise and discharge such powers and duties of the`
  line `Authority as may be delegated to him by the Authority and such other powers and duties as may be`
  line prescribed.
  line
  line `(2) The Vice-Chairman of the Authority shall exercise and discharge such of the powers and duties of`
  line `the Chairman as may be prescribed or as may be delegated to him by the Authority.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_5_a:
  sectionId (19621)
  sectionNo 5A
  orderNo 7
  title Meetings.
  content obj_root_law_sections_5_a_content
  footnotes `1. Ins. by Act 40 of 2001, s. 4 (w.e.f. 1-7-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19621&sectionno=5A&orderno=7&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_5_a_content:
  string
  line `^1[5A. Meetings.--(1) The Authority shall meet at such times and places and shall observe such rules`
  line `of procedure in regard to the transaction of business at its meetings, including the quorum thereat, as may`
  line `be provided by regulations.`
  line
  line `(2) The Chairman or in his absence, the Vice-Chairman, or in the absence of both, such other member`
  line `as is chosen by the members present at the meeting of the Authority shall preside at the meeting.`
  line
  line `(3) All questions which come up before any meeting of the Authority shall be decided by a majority`
  line `of votes of the members present and voting, and in the event of an equality of votes, the Chairman or in`
  line `his absence, the Vice-Chairman, or in the absence of both, the person presiding, shall have and exercise a`
  line `second or casting vote.]`
obj_root_law_sections_6:
  sectionId (19622)
  sectionNo (6)
  orderNo 8
  title `Removal, etc., of members.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19622&sectionno=6&orderno=8&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_6_content:
  string
  line `(1) The Central Government may remove from the Authority any`
  line `member who, in its opinion,--`
  line
  line `(a) refuses to act,`
  line
  line `(b) has become incapable to act,`
  line
  line `(c) has so abused his office as to render his continuance in office detrimental to the public`
  line `interest, or`
  line
  line `(d) is otherwise unsuitable to continue as a member.`
  line
  line `(2) The Central Government may suspend any member pending an inquiry against him.`
  line
  line `(3) No order of removal under this section shall be made unless the member concerned has been`
  line `given an opportunity to submit his explanation to the Central Government and when such order is passed,`
  line `the seat of the member removed shall be declared vacant.`
  line
  line `(4) A member who has been removed under this section shall not be eligible for re-appointment as a`
  line `member or in any capacity under the Authority.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (19623)
  sectionNo (7)
  orderNo 9
  title `Vacancy, etc., not to invalidate proceedings of the Authority.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19623&sectionno=7&orderno=9&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_7_content:
  string
  line `No act or proceeding of the`
  line `Authority shall be invalidated merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Authority; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Authority; or`
  line
  line `(c) any irregularity in the procedure of the Authority not affecting the merits of the case.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (19624)
  sectionNo (8)
  orderNo 10
  title `Secretary and other officers.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19624&sectionno=8&orderno=10&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_8_content:
  string
  line `(1) The Authority may appoint the Secretary and such other`
  line `officers and employees as it considers necessary for the efficient discharge of its functions under this Act.`
  line
  line `(2) The terms and conditions of service of the Secretary and other officers and employees of the`
  line `Authority shall be such as may be determined by regulations.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (19625)
  sectionNo (9)
  orderNo 11
  title `Advisory Committees.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19625&sectionno=9&orderno=11&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_9_content:
  string
  line `(1) Subject to any rules made in this behalf, the Authority may from time`
  line `to time constitute such Advisory Committees as may be necessary for the efficient discharge of its`
  line functions.
  line
  line `(2) Every Advisory Committee shall consist of such number of persons connected with shipping and`
  line `navigation and allied aspects as the Authority may deem fit.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (19626)
  sectionNo (10)
  orderNo 12
  title `Authority to act on business principles.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19626&sectionno=10&orderno=12&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_10_content:
  string
  line `In the discharge of its functions under this Act, the`
  line `Authority shall act, so far as may be, on business principles.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (19627)
  sectionNo (11)
  orderNo 13
  title `Transfer of assets and liabilities of the Central Government to the Authority.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19627&sectionno=11&orderno=13&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_11_content:
  string
  line `(1) As from`
  line `such day as the Central Government may, appoint by notification in the Official Gazette,--`
  line
  line `(a) all properties and other assets vested in the Central Government for the purposes of Inland`
  line `Water Transport Directorate, and administered by the Chief Engineer-cum-Administrator, Inland`
  line `Water Transport Directorate, immediately before such day shall vest in the Authority;`
  line
  line `(b) all debts, obligations and liabilities incurred, all contracts entered into and all matters and`
  line `things engaged to be done by, with, or for the Central Government immediately before such day for`
  line `or in connection with the purposes of Inland Water Transport Directorate shall be deemed to have`
  line `been incurred; entered into and engaged to be done by, with, or for the Authority;`
  line
  line `(c) all non-recurring expenditure incurred by the Central Government for or in connection with`
  line `the purposes of Inland Water Transport Directorate up to such day and declared to be capital`
  line `expenditure by the Central Government shall, subject to such terms and conditions as may be`
  line `determined by the Central Government, be treated as capital provided by the Central Government to`
  line `the Authority;`
  line
  line `(d) all sums of money due to the Central Government in relation to Inland Water Transport`
  line `Directorate immediately before such day shall be deemed to be due to the Authority;`
  line
  line `(e) all suits and other legal proceedings with respect to any matter in relation to Inland Water`
  line `Transport Directorate which having been instituted by or against the Central Government are`
  line `pending, or which could have been so instituted, immediately before such date shall on and after such`
  line `date be continued or instituted by or against the Authority; and`
  line
  line `(f) every employee holding any office under the Central Government immediately before such`
  line `day solely or mainly for or in connection with such affairs of Inland Water Transport Directorate as`
  line `are relevant to the functions of the Authority under this Act shall be treated as on deputation with the`
  line `Authority but shall hold his office in the Authority by the same tenure and upon the same terms and`
  line `conditions of service as respects remuneration, leave, provident fund, retirement or other terminal`
  line `benefits as he would have held such office, if the Authority had not been constituted and shall`
  line `continue to do so until the Central Government, either on its own motion or at the request of the`
  line `Authority, recalls such employee to its service or until the Authority, with the concurrence of the`
  line `Central Government, duly absorbs such employee in its regular service, whichever is earlier:`
  line
  line `Provided that during the period of deputation of any such employee with the Authority, the`
  line `Authority shall pay to the Central Government in respect of every such employee, such contribution`
  line `towards his leave salary, pension and gratuity as the Central Government may, by order, determine:`
  line
  line `Provided further that any such employee, who has, in respect of the proposal of the Authority to`
  line `absorb him in its regular service, intimated within such time as may be specified in this behalf by the`
  line `Authority his intention of not becoming a regular employee of the Authority, shall not be absorbed by`
  line `the Authority in its regular service.`
  line
  line `(2) If any dispute or doubt arises as to which of the properties, rights or liabilities of the Central`
  line `Government have been transferred to the Authority or as to which of the employees serving under the`
  line `Central Government are to be treated as on deputation with the Authority, under this section, such dispute`
  line `or doubt shall be decided by the Central Government in consultation with the Authority and the decision`
  line `of the Central Government thereon shall be final.`
  line
  line `(3) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947) or in any`
  line `other law for the time being in force, the absorption of any employee by the Authority in its regular`
  line `service under this section shall not entitle such employee to any compensation under that Act or other law`
  line `and no such claim shall be entertained by any court, tribunal or other authority.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (19628)
  sectionNo (12)
  orderNo 14
  title `Contracts by the Authority.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19628&sectionno=12&orderno=14&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_12_content:
  string
  line `Subject to the provisions of section 13, the Authority shall be`
  line `competent to enter into and perform any contract necessary for the discharge of its functions under this`
  line Act.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (19629)
  sectionNo (13)
  orderNo 15
  title `Mode of executing contracts on behalf of the Authority.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19629&sectionno=13&orderno=15&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_13_content:
  string
  line `(1) Every contract shall, on behalf of`
  line `the Authority, be made by the Chairman or such other member or such officer of the Authority as may be`
  line `generally or specially empowered in this behalf by the Authority and such contracts or class of contracts`
  line `as may be specified in the regulations shall be sealed with the common seal of the Authority:`
  line
  line `Provided that no contract exceeding such value or amount as the Central Government may, from time`
  line `to time, by order, fix in this behalf shall be made unless it has been previously approved by the Authority:`
  line
  line `Provided further that no contract for the acquisition or sale of immovable property or for the lease of`
  line `any such property for a term exceeding thirty years and no other contract exceeding such value or amount`
  line `as the Central Government may, from time to time, by order, fix in this behalf shall be made unless it has`
  line `been previously approved by the Central Government.`
  line
  line `(2) Subject to the provisions of sub-section (1), the form and manner in which any contract shall be`
  line `made under this Act shall be such as may be prescribed by regulations.`
  line
  line `(3) No contract which is not in accordance with the provisions of this Act and the regulations shall be`
  line `binding on the Authority.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (19630)
  sectionNo (14)
  orderNo 16
  title `Functions of the Authority.`
  content obj_root_law_sections_14_content
  footnotes `1 Ins. by Act 40 of 2001, s. 5 (w.e.f. 1-7-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19630&sectionno=14&orderno=16&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_14_content:
  string
  line `(1) The Authority may`
  line
  line `(a) carry out surveys and investigations for the development, maintenance and better utilisation of`
  line `the national waterways and the appurtenant land for shipping and navigation and prepare schemes in`
  line `this behalf;`
  line
  line `(b) provide or permit setting up of infrastructural facilities for national waterways;`
  line
  line `(c) carry out conservancy measures and training works and do all other acts necessary for the`
  line `safety and convenience of shipping and navigation and improvement of the national waterways;`
  line
  line `(d) control activities such as throwing rubbish, dumping or removal of material, in or from the`
  line `bed of the national waterways and appurtenant land, in so far as they may affect safe and efficient,`
  line `shipping and navigation, maintenance of navigable channels, river training and conservancy`
  line measures;
  line
  line `(e) remove or alter any obstruction or impediment in the national waterways and the appurtenant`
  line `land which may impede the safe navigation or endanger safety of infrastructural facilities or`
  line `conservancy measures where such obstruction or impediment has been lawfully made or has become`
  line `lawful by reason of long continuance of such obstruction or impediment or otherwise, after making`
  line `compensation to person suffering damage by such removal or alteration;`
  line
  line `(f) provide for the regulation of navigation and traffic (including the rule of the road) on national`
  line waterways;
  line
  line `(g) regulate the construction or alteration of structures on, across or under the national waterways;`
  line
  line `(h) disseminate navigational meteorological information about national waterways;`
  line
  line `(i) ensure co-ordination of inland water transport on national waterways with other modes of`
  line `transport; and`
  line
  line `(j) establish and maintain pilotage on national waterways;`
  line
  line `^1[(k) enter into joint ventures concerning inland shipping by way of equity participation.]`
  line
  line `(2) The Authority may also`
  line
  line `(a) advise the Central Government on matters relating to inland water transport;`
  line
  line `(b) study the transport requirement with a view to co-ordinating inland water transport with other`
  line `modes of transport;`
  line
  line `(c) carry out hydrographic surveys and publish river charts;`
  line
  line `(d) assist, on such terms and conditions as may be mutually agreed upon, any State Government`
  line `in formulation and implementation of scheme for inland water transport development;`
  line
  line `(e) develop consultancy services and provide such services, on such terms and conditions as may`
  line `be mutually agreed upon, in India and abroad in relation to planning and development of waterways`
  line `for shipping and navigation or any facility thereat;`
  line
  line `(f) conduct research in matters relating to inland water transport including development of craft`
  line `design, mechanisation of country crafts, technique of towage, landing and terminal facilities, port`
  line `installations and survey techniques;`
  line
  line `(g) lay down standards for classification of inland waterways;`
  line
  line `(h) arrange programme of technical training for inland water transport personnel within and`
  line `outside the country; and`
  line
  line `(i) perform such other functions as may be necessary to carry out the provisions of this Act.`
  line
  line `(3) Any dispute arising out of or concerning the compensation referred to in clause (e) of`
  line `sub-section (1) shall be determined according to the law relating to like disputes in the case of land`
  line `required for public purposes.`
  line
  line `(4) Every scheme, prepared by the Authority to carry out functions under sub-sections (1) and (2),`
  line `involving capital expenditure exceeding the amount as may be prescribed, shall be submitted to the`
  line `Central Government for approval.`
  line
  line `(5) The Central Government may either approve the scheme submitted to it under sub-section (4)`
  line `without modification or with such modifications as it may consider necessary or reject the scheme with`
  line `directions to the Authority to prepare a fresh scheme according to such directions.`
obj_root_law_sections_15:
  sectionId (19631)
  sectionNo (15)
  orderNo 17
  title `Amendment of schemes.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19631&sectionno=15&orderno=17&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_15_content:
  string
  line `The Authority shall not make any material change in the scheme`
  line `approved under sub-section (5) of section 14 without the prior approval of the Central Government.`
  line
  line `Explanation.--For the purposes of this section, "material change" means an increase in the cost of the`
  line `scheme by more than twenty per cent. of its cost or a change in the benefit and cost ratio which either`
  line `makes the cost component in the ratio exceeds the benefit or reduces the benefit component by more than`
  line `twenty per cent.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (19632)
  sectionNo (16)
  orderNo 18
  title [Omitted.].
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19632&sectionno=16&orderno=18&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_16_content:
  string
  line `[Power to fix maximum and minimum rates for passenger fares and freight for`
  line `goods.]--Omitted by the Inland Waterways Authority of India (Amendment) Act, 1993 (8 of 1994), s. 2`
  line `(w.e.f. 7-1-1994).`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (19633)
  sectionNo (17)
  orderNo 19
  title `Levy and collection of fees and charges.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19633&sectionno=17&orderno=19&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_17_content:
  string
  line `(1) The Authority may, with the previous approval of`
  line `the Central Government, levy fees and charges at such rates as may be laid down by regulations made in`
  line `this behalf for services or benefits rendered in relation to the use of the national waterways for the`
  line `purposes of shipping, navigation, infrastructural facilities, including facilities for passengers and facilities`
  line `relating to the berthing of vessels, handling of cargoes and storage of cargoes.`
  line
  line `(2) The fees and charges levied under sub-section (1) shall be collected in such manner as may be`
  line `determined by regulations.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (19634)
  sectionNo (18)
  orderNo 20
  title `Grants and loans by the Central Government.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19634&sectionno=18&orderno=20&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_18_content:
  string
  line `The Central Government may, after due`
  line `appropriation made by Parliament by law in this behalf, make to the Authority grants and loans of such`
  line `sums of money as that Government may consider necessary.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_18_a:
  sectionId (19635)
  sectionNo 18A
  orderNo 21
  title `Borrowing powers of the Authority.`
  content obj_root_law_sections_18_a_content
  footnotes `1. Ins. by Act 40 of 2001, s. 6 (w.e.f. 1-7-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19635&sectionno=18A&orderno=21&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_18_a_content:
  string
  line `^1[18A. Borrowing powers of the Authority.--The Authority may, in such manner and subject to`
  line `such terms and conditions as may be determined by regulations, borrow money from any source by the`
  line `issue of bonds, debentures or other instruments as it may think fit for discharge of all or any of its`
  line `functions under the Act.]`
obj_root_law_sections_19:
  sectionId (19636)
  sectionNo (19)
  orderNo 22
  title `Constitution of the Fund.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19636&sectionno=19&orderno=22&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_19_content:
  string
  line `(1) There shall be constituted a Fund to be called the Inland`
  line `Waterways Authority of India Fund and there shall be credited thereto--`
  line
  line `(a) any grants and loans made to the Authority by the Central Government under section 18;`
  line
  line `(b) all fees and charges received by the Authority under this Act; and`
  line
  line `(c) all sums received by the Authority from such other sources as may be decided upon by the`
  line `Central Government.`
  line
  line `(2) The Fund shall be applied for meeting--`
  line
  line `(a) salary, allowances and other remuneration of the members, officers and other employees of`
  line `the Authority;`
  line
  line `(b) expenses of the Authority in the discharge of its functions under section 14; and`
  line
  line `(c) expenses on objects and for purposes authorised by this Act.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (19637)
  sectionNo (20)
  orderNo 23
  title Budget.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19637&sectionno=20&orderno=23&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_20_content:
  string
  line `The Authority shall prepare, in such form and at such time each financial year as may`
  line `be prescribed, its budget for the next financial year, showing the estimated receipts and expenditure of the`
  line `Authority and forward the same to the Central Government.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (19638)
  sectionNo (21)
  orderNo 24
  title `Investment of funds.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19638&sectionno=21&orderno=24&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_21_content:
  string
  line `The Authority may invest its funds (including any reserve fund) in the`
  line `securities of the Central Government or in such other manner as may be prescribed.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (19639)
  sectionNo (22)
  orderNo 25
  title `Annual report.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19639&sectionno=22&orderno=25&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_22_content:
  string
  line `The Authority shall prepare, in such form and at such time each financial year`
  line `as may be prescribed, its annual report, giving a full account of its activities during the previous financial`
  line `year, and submit a copy thereof to the Central Government.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (19640)
  sectionNo (23)
  orderNo 26
  title `Accounts and audit.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19640&sectionno=23&orderno=26&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_23_content:
  string
  line `The accounts of the Authority shall be maintained and audited in such`
  line `manner as may, in consultation with the Comptroller and Auditor-General of India, be prescribed and the`
  line `Authority shall furnish, to the Central Government, before such date as may be prescribed, its audited`
  line `copy of accounts together with the auditors report thereon.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (19641)
  sectionNo (24)
  orderNo 27
  title `Annual report and auditors’ report to be laid before Parliament.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19641&sectionno=24&orderno=27&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_24_content:
  string
  line `The Central Government`
  line `shall cause the annual report and auditors report to be laid, as soon as may be after they are received,`
  line `before each House of Parliament.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (19642)
  sectionNo (25)
  orderNo 28
  title `Power of Central Government to issue directions.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19642&sectionno=25&orderno=28&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_25_content:
  string
  line `(1) Without prejudice to the foregoing`
  line `provisions of this Act, the Authority shall, in the discharge of its functions and duties under this Act, be`
  line `bound by such directions on questions of policy as the Central Government may give in writing to it from`
  line `time to time:`
  line
  line `Provided that the Authority shall, as far as practicable, be given opportunity to express its views`
  line `before any direction is given under this sub-section.`
  line
  line `(2) The decision of the Central Government whether a question is one of policy or not shall be final.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (19643)
  sectionNo (26)
  orderNo 29
  title `Compulsory acquisition of land for the Authority.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19643&sectionno=26&orderno=29&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_26_content:
  string
  line `Any land required by the Authority for`
  line `discharging its functions under this Act shall be deemed to be needed for a public purpose and such land may be acquired for the Authority under the provisions of the Land Acquisition Act, 1894 (1 of 1894) or`
  line `of any other corresponding law for the time being in force.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (19644)
  sectionNo (27)
  orderNo 30
  title `Application, etc., of certain laws.`
  content obj_root_law_sections_27_content
  footnotes `1. Certain words omitted by Act 8 of 1994, s. 3 (w.e.f. 7-1-1994).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19644&sectionno=27&orderno=30&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_27_content:
  string
  line `(1) The provisions of this Act shall be in addition to the`
  line `provisions of the Indian Ports Act, 1908 (15 of 1908) and the Major Port Trusts Act, 1963 (38 of 1963)`
  line `and in particular nothing in this Act shall affect any jurisdiction, functions, powers or duties required to`
  line `be exercised, performed or discharged by--`
  line
  line `(a) the conservator of any port or by any officer or authority under the Indian Ports`
  line `Act, 1908 (15 of 1908), or`
  line
  line `(b) the Board of Trustees for any major port or by any officer or authority under the Major Port`
  line `Trusts Act, 1963 (38 of 1963),`
  line
  line `in or in relation to any portion of an inland waterway (including the national waterway) falling within the`
  line `limits of such port or major port.`
  line
  line `(2) Nothing in this Act shall affect the operation of the Inland Vessels Act, 1917 (1 of 1917) or any`
  line `other Central Act (other than the Indian Ports Act, 1908 (15 of 1908) and the Major Port Trusts`
  line `Act, 1963 [38 of 1963]) or any State or provincial Act in force immediately before the commencement of`
  line `this Act with respect to shipping and navigation on any national waterway ^1***.`
obj_root_law_sections_28:
  sectionId (19645)
  sectionNo (28)
  orderNo 31
  title `Power to enter.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19645&sectionno=28&orderno=31&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_28_content:
  string
  line `Subject to any rules made in this behalf, any person, generally or specially`
  line `authorised by the Authority in this behalf, may, whenever it in necessary so to do for any of the purposes`
  line `of this Act, at all reasonable times, enter upon any land or premises and--`
  line
  line `(a) make any inspection, survey, measurement, valuation or inquiry;`
  line
  line `(b) take levels;`
  line
  line `(c) dig or bore into sub-soil;`
  line
  line `(d) set out boundaries and intended lines of work;`
  line
  line `(e) mark such level boundaries and lines by placing marks and cutting trenches; or`
  line
  line `(f) do such other acts or things as may be prescribed:`
  line
  line `Provided that no such person shall enter any building or any enclosed court or garden attached to a`
  line `dwelling-house (unless with the consent of the occupier thereof) without previously giving such occupier`
  line `at least twenty-four hours' notice in writing of his intention to do so.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (19646)
  sectionNo (29)
  orderNo 32
  title Delegation.
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19646&sectionno=29&orderno=32&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_29_content:
  string
  line `The Authority may, by general or special order in writing, delegate to the Chairman`
  line `or any other member or to any officer of the Authority, subject to such conditions and limitations, if any,`
  line `as may be specified in the order such of its powers and functions under this Act (except the powers under`
  line `section 35) as it may deem necessary.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (19647)
  sectionNo (30)
  orderNo 33
  title `Authentication of orders and other instruments of the Authority.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19647&sectionno=30&orderno=33&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_30_content:
  string
  line `All orders and decisions`
  line `of the Authority shall be authenticated by the signature of the Chairman or any other member authorised`
  line `by the Authority in this behalf and all other instruments executed by the Authority shall be authenticated`
  line `by the signature of an officer of the Authority authorised by the Authority in this behalf.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (19648)
  sectionNo (31)
  orderNo 34
  title `Members, officers and employees of the Authority to be public servants.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19648&sectionno=31&orderno=34&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_31_content:
  string
  line `All members,`
  line `officers and other employees of the Authority shall be deemed, when acting or purporting to act in`
  line `pursuance of any of the provisions of this Act, to be public servants within the meaning of section 21 of`
  line `the Indian Penal Code (45 of 1860).`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (19649)
  sectionNo (32)
  orderNo 35
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19649&sectionno=32&orderno=35&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_32_content:
  string
  line `(1) No suit, prosecution or other legal proceedings`
  line `shall lie against the Government or any officer of the Government or any member, officer or employee of the Authority for anything which is in good faith done or intended to be done under this Act or the rules`
  line `or regulations made thereunder.`
  line
  line `(2) No suit or other legal proceedings shall lie against the Authority for any damage caused or likely`
  line `to be caused by anything in good faith done or purported to be done under this Act or the rules or`
  line `regulations, and in particular, it shall not be the responsibility of the Authority to provide for relief`
  line `measures necessitated by floods or by breaches and failures of works.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (19650)
  sectionNo (33)
  orderNo 36
  title `Power of Central Government to supersede the Authority.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19650&sectionno=33&orderno=36&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_33_content:
  string
  line `(1) If, at any time, the Central`
  line `Government is of opinion--`
  line
  line `(a) that on account of a grave emergency, the Authority is unable to discharge the functions and`
  line `duties imposed on it by or under the provisions of this Act; or`
  line
  line `(b) that the Authority has persistently made default in complying with any direction issued by the`
  line `Central Government under this Act or in the discharge of the functions and duties imposed on it by or`
  line `under the provisions of this Act and as a result of which default the financial position of the Authority`
  line `or the administration of any national waterway has deteriorated; or`
  line
  line `(c) that circumstances exist which render it necessary in the public interest so to do,`
  line
  line `the Central Government may, by notification in the Official Gazette, supersede the Authority for such`
  line `period, not exceeding six months, as may be specified in the notification:`
  line
  line `Provided that before issuing a notification under this sub-section for the reasons mentioned in`
  line `clause (b), the Central Government shall give a reasonable opportunity to the Authority to show cause`
  line `why it should not be superseded and shall consider the explanations and objection, if any, of the`
  line Authority.
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the Authority,`
  line
  line `(a) all the members shall, as from the date of supersession, vacate their offices as such;`
  line
  line `(b) all the powers, functions and duties which may, by or under the provisions of this Act, be`
  line `exercised or discharged by or on behalf of the Authority, shall, until the Authority is reconstituted`
  line `under sub-section (3), be exercised and discharged by such person or persons as the Central`
  line `Government may direct;`
  line
  line `(c) all property owned or controlled by the Authority shall, until the Authority is reconstituted`
  line `under sub-section (3), vest in the Central Government.`
  line
  line `(3) On the expiration of the period of supersession specified in the notification issued under`
  line `sub-section (1), the Central Government may`
  line
  line `(a) extend the period of supersession for such further term, not exceeding six months, as it may`
  line `consider necessary; or`
  line
  line `(b) reconstitute the Authority by fresh appointment and in such case any persons who vacated`
  line `their offices under clause (a) of sub-section (2) shall not be deemed disqualified for appointment:`
  line
  line `Provided that the Central Government may, at any time before the expiration of the period of`
  line `supersession, whether as originally specified under sub-section (1) or as extended under this sub-section,`
  line `take action under clause (b) of this sub-section.`
  line
  line `(4) The Central Government shall cause a notification issued under sub-section (1) and a full report of`
  line `any action taken under this section and the circumstances leading to such action to be laid before such`
  line `House of Parliament at the earliest opportunity.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (19651)
  sectionNo (34)
  orderNo 37
  title `Power to make rules.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19651&sectionno=34&orderno=37&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_34_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the purposes of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may provide for all or any`
  line `of the following matters, namely:--`
  line
  line `(a) the term of office and other conditions of service of the members of the Authority under`
  line `section 4;`
  line
  line `(b) the powers and duties of the Chairman and Vice-Chairman under section 5;`
  line
  line `(c) the matters with respect to the Advisory Committee referred to in sub-section (1) of section 9;`
  line
  line `(d) the amount required to be prescribed under sub-section (4) of section 14;`
  line
  line `(e) the form in which, and the time at which, the Authority shall prepare its budget under`
  line `section 20 and its annual report under section 22;`
  line
  line `(f) the manner in which the Authority may invest its funds under section 21;`
  line
  line `(g) the manner in which the accounts of the Authority shall be maintained and audited under`
  line `section 23;`
  line
  line `(h) the conditions and restrictions with respect to exercise of the power to enter under section 28`
  line `and the matters referred to in clause (f) of that section; and`
  line
  line `(i) any other matter which is to be, or may be, prescribed or in respect of which provision is to be,`
  line `or may be, made by rules.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (19652)
  sectionNo (35)
  orderNo 38
  title `Power to make regulations.`
  content obj_root_law_sections_35_content
  footnotes `1 Ins. by Act 40 0f 2001, s. 7 (w.e.f. 1-7-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19652&sectionno=35&orderno=38&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_35_content:
  string
  line `(1) The Authority may, with the previous approval of the Central`
  line `Government, by notification in the Official Gazette, make regulations consistent with this Act and the`
  line `rules generally to carry out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:`
  line
  line `(a) the manner in which and the purposes for which, the Authority may associate with itself any`
  line `person under sub-section (4) of section 3;`
  line
  line `(b) the terms and conditions of service of the Secretary and other officers and employees of the`
  line `Authority under sub-section (2) of section 8;`
  line
  line `(c) the contracts or class of contracts which are to be sealed with the common seal of the`
  line `Authority and the form and manner in which a contract may be made by the Authority;`
  line
  line `(d) the manner in which, and the conditions subject to which, any functions in relation to the`
  line `matters referred to in sub-sections (1) and (2) of section 14 may be performed;`
  line
  line `(e) the rule of the road on a national waterway;`
  line
  line `(f) the safe, efficient and convenient use, management and control of the infrastructures and`
  line `infrastructural facilities;`
  line
  line `(g) the reception, porterage, storage and removal of goods brought on a national waterway, and`
  line `the procedure to be followed for taking charge of goods which may have been damaged before`
  line `landing, or may be alleged to have been so damaged;`
  line
  line `(h) regulating, declaring and defining the docks, wharfs, jetties, landing stages on which goods`
  line `shall be landed from vessels and shipped on board vessels;`
  line
  line `(i) regulating the manner in which and the conditions under which the loading and unloading of`
  line `vessels on a national waterway shall be carried out; and`
  line
  line `(j) the exclusion from a national waterway of disorderly or other undesirable persons and of`
  line trespassers;
  line
  line `^1[(k) the terms and conditions for issue of bonds, debentures or other instruments;`
  line
  line `(l) the time, place and the rules of procedure with regard to the transaction of business at its`
  line `meetings including the quorum under sub-section (1) of section 5A.]`
  line
  line `(3) Any regulation made under any of the clauses (c) to (j) of sub-section (2) may provide that a`
  line `contravention thereof shall be punishable with fine which may extend to five hundred rupees and in the case of a continuing contravention with an additional fine which may extend to twenty rupees for every`
  line `day during which such contravention continues after conviction for the first such contravention.`
obj_root_law_sections_36:
  sectionId (19653)
  sectionNo (36)
  orderNo 39
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19653&sectionno=36&orderno=39&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_36_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (19654)
  sectionNo (37)
  orderNo 40
  title `Power to remove difficulties.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19654&sectionno=37&orderno=40&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_37_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of five years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (19655)
  sectionNo (38)
  orderNo 41
  title `Amendment of Act 49 of 1982.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00036_198582_1517807326680&sectionId=19655&sectionno=38&orderno=41&orgactid=AC_CEN_2_2_00036_198582_1517807326680
obj_root_law_sections_38_content:
  string
  line `In the National Waterway (Allahabad-Haldia Stretch of the`
  line `Ganga-Bhagirathi-Hooghly River) Act, 1982,--`
  line
  line `(a) in section 3, for the words "Central Government", the word "Union" shall be substituted, and`
  line `for the words "to the extent hereinafter provided", the words and figures "to the extent provided in the`
  line `Inland Waterways Authority of India Act, 1985" shall be substituted;`
  line
  line `(b) sections 4 to 15 shall be omitted.`
obj_root_law_sections_38_footnotes:
  string
  line
