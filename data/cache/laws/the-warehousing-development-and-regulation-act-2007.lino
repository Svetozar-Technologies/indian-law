  handle (2020)
  collectionHandle 123456789/1362
  title `The Warehousing (Development and Regulation) Act, 2007`
  actNumber (37)
  enactmentDate 2007-09-19
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2020`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भाण्‍डागारण (विकास और विनियमन) अधिनियम, 2007`
  actYear (2007)
  ministry `Ministry of Consumer Affairs, Food and Public Distribution`
  department `Department of Food and Public Distribution`
  longTitle `An Act to make provisions for the development and regulation of warehouses, negotiability of warehouse receipts, establishment of a Warehousing Development and Regulatory Authority and for matters connected therewith or incidental thereto.`
