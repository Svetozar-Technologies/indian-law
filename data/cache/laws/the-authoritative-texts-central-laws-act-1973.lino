  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00020_197350_1517807322031&sectionId=33953&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00020_197350_1517807322031
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the ^1`
  line `[Authoritative Texts] (Central`
  line `Laws) Act, 1973.`
  line
  line `(2) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for "Authorised Translations" (w.e.f. 31-3-1988).`
  line
  line `2. 1st July, 1981, vide notification No. S.O. 482(E), dated 15th June, 1981, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (33954)
  sectionNo (2)
  orderNo 2
  title `Authoritative texts of Central laws in certain languages.`
  content obj_root_law_sections_2_content
  footnotes `1. Subs. by Act 18 of 1988, s. 4, for "authorised translation" (w.e.f. 31-3-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00020_197350_1517807322031&sectionId=33954&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00020_197350_1517807322031
obj_root_law_sections_2_content:
  string
  line `^1[Authoritative texts] of Central laws in certain languages.--A translation in any language`
  line `(other than Hindi) specified in the Eighth Schedule to the Constitution, published under the authority of`
  line `the President in the Official Gazette,--`
  line
  line `(a) of any Central Act or of any Ordinance promulgated by the President, or`
  line
  line `(b) of any order, rule, regulation or bye-law issued under the Constitution or under any Central`
  line Act,
  line
  line `shall be deemed to be the ^1[authoritative text] thereof in such language.`
obj_root_law_sections_3:
  sectionId (33955)
  sectionNo (3)
  orderNo 3
  title `Power to make rules.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00020_197350_1517807322031&sectionId=33955&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00020_197350_1517807322031
obj_root_law_sections_3_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_3_footnotes:
  string
  line
