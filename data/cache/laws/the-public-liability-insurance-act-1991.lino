  (str slug) (str the-public-liability-insurance-act-1991)
  (str handle) (str 1960)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Public Liability Insurance Act, 1991`)
  (str actNumber) (str 6)
  (str enactmentDate) (str 1991-01-22)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1960`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `लोक दायित्‍व बीमा अधिनियम, 1991`)
  (str actYear) (str 1991)
  (str ministry) (str `Ministry of Environment, Forest and Climate Change`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for public liability insurance for the purpose of providing immediate relief to the persons affected by accident occurring while handling any hazardous substance and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-04-1991)
  (str notification) (str `1st April, 1991, vide notification No. G.S.R 253 dated 27th March, 1991, see Gazette of India Ordinary, Part II sec.3(i).`)
