obj_root_law:
  slug the-pre-conception-and-pre-natal-diagnostic-techniques-prohibition-of-sex-selection-act-1994
  handle (1937)
  collectionHandle 123456789/1362
  title `The Pre-conception and Pre-natal Diagnostic Techniques (Prohibition of Sex Selection) Act, 1994`
  actNumber (57)
  enactmentDate 1994-09-20
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1937`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `गर्भधारण पूर्व और प्रसवपूर्व निदान-तकनीक(लिंग चयन प्रतिषेध) अधिनियम, 1994`
  actYear (1994)
  ministry `Ministry of Health and Family Welfare`
  department `Department of Health and Family Welfare`
  longTitle `An Act to provide for the prohibition of sex selection, before or after conception, and for regulation of pre-natal diagnostic techniques for the purposes of detecting genetic abnormalities or metabolic disorders or chromosomal abnormalities or certain congenital malformations or sex-linked disorders and for the prevention of their misuse for sex determination leading to female foeticide and for matters connected therewith or incidental thereto.`
  enforcementDate 01-01-1996
  notification `1st January, 1996, vide notification No. S.O. 990, dated 21st December, 1995, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T21:35:37.850Z`
  translations obj_root_law_translations
