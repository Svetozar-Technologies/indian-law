  object
  (str hi) obj_root_law_translations_hi
obj_root_law_translations_hi:
  object
  (str title) (str `तेल उद्योग (विकास ) अधिनियम, 1974`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1617/3/H1974-47.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T13:08:11.711Z`)
