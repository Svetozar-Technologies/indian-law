  (str title) (str `The National Institutes of Food Technology, Entrepreneurship and Management Act, 2021.`)
  (str actNumber) (str 19)
  (str enactmentDate) (str 2021-07-30)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/16941`)
