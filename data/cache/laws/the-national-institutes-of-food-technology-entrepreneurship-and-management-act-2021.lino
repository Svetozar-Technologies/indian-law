obj_root_law:
  slug the-national-institutes-of-food-technology-entrepreneurship-and-management-act-2021
  handle (16941)
  collectionHandle 123456789/1362
  title `The National Institutes of Food Technology, Entrepreneurship and Management Act, 2021.`
  actNumber (19)
  enactmentDate 2021-07-30
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/16941`
  sources obj_root_law_sources
  sections obj_root_law_sections
