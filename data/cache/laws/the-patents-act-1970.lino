obj_root_law_sections_117_e:
  sectionId (15991)
  sectionNo 117E
  orderNo 127
  title `Appearance of Controller in legal proceedings.`
  content obj_root_law_sections_117_e_content
  footnotes `1. Subs. by Act 33 of 2021, s. 13, for “Appellate Board” (w.e.f. 4-4-2021).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00002_197039_1517807321764&sectionId=15991&sectionno=117E&orderno=127&orgactid=AC_CEN_11_61_00002_197039_1517807321764
obj_root_law_sections_117_e_content:
  string
  line `(1) The Controller shall have the right to`
  line `appear and be heard--`
  line
  line `(a) in any legal proceedings before the ^1[High Court] in which the relief sought includes`
  line `alteration or rectification of the register or in which any question relating to the practice of the patent`
  line `office is raised;`
  line
  line `(b) in any appeal to the ^1[High Court] from an order of the Controller on an application for`
  line `grant of a patent--`
  line
  line `(i) which is not opposed, and the application is either refused by the Controller or is accepted`
  line `by him subject to any amendments, modifications, conditions or limitations, or`
  line
  line `(ii) which has been opposed and the Controller considers that his appearance is necessary in`
  line `the public interest,`
  line
  line `and the Controller shall appear in any case if so directed by the ^1[High Court].`
  line
  line `(2) Unless the ^1[High Court] otherwise directs, the Controller may, in lieu of appearing, submit a`
  line `statement in writing signed by him, giving such particulars as he thinks proper of the proceedings before`
  line `him relating to the matter in issue or of the grounds of any decision given by him or of the practice of the`
  line `patent office in like cases, or of other matters relevant to the issues and within his knowledge as the`
  line `Controller may deem it necessary, and such statement shall be evidence in the proceeding.`
obj_root_law_sections_117_f:
  sectionId (15992)
  sectionNo 117F
  orderNo 128
  title `Costs of Controller in proceedings before Appellate Board.`
  content `117F. Costs of Controller in proceedings before Appellate Board.@/i2 Omitted by the Tribunal Reforms Act, 2021 (33 of 201), s. 13 (w.e.f. 4-4-2021).`
