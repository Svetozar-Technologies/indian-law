  sectionId (15894)
  sectionNo (24)
  orderNo 26
  title [Omitted.].
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00002_197039_1517807321764&sectionId=15894&sectionno=24&orderno=26&orgactid=AC_CEN_11_61_00002_197039_1517807321764
