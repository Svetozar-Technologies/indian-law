obj_root_law_sections_162:
  sectionId (16040)
  sectionNo (162)
  orderNo 178
  title `Repeal of Act 2 of 1911 in so far as it relates to patents and savings.`
  content obj_root_law_sections_162_content
  footnotes `1. Sub-sections (2) and (3) omitted by s. 66, ibid. (w.e.f. 20-5-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00002_197039_1517807321764&sectionId=16040&sectionno=162&orderno=178&orgactid=AC_CEN_11_61_00002_197039_1517807321764
obj_root_law_sections_162_content:
  string
  line `(1) The Indian Patents`
  line `and Designs Act, 1911, in so far as it relates to patents, is hereby repealed, that is to say, the said Act shall`
  line `be amended in the manner specified in the Schedule.`
  line
  line `^1* * * * *`
  line
  line `(4) The mention of particular matters in this section shall not prejudice the general application of the`
  line `General Clauses Act, 1897 (10 of 1987), with respect to repeals.`
  line
  line `(5) Notwithstanding anything contained in this Act, any suit for infringement of a patent or any`
  line `proceeding for revocation of a patent, pending in any court at the commencement of this Act, may be`
  line `continued and disposed of, as if this Act had not been passed.`
