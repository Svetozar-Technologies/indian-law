obj_root_law_sections_117_a:
  sectionId (15987)
  sectionNo 117A
  orderNo 123
  title `Appeals to Appellate Board.`
  content obj_root_law_sections_117_a_content
  footnotes obj_root_law_sections_117_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00002_197039_1517807321764&sectionId=15987&sectionno=117A&orderno=123&orgactid=AC_CEN_11_61_00002_197039_1517807321764
obj_root_law_sections_117_a_content:
  string
  line `(1) Save as otherwise expressly provided in sub-section (2),`
  line `no appeal shall lie from any decision, order or direction made or issued under this Act by the Central`
  line `Government, or from any act or order of the Controller for the purpose of giving effect to any such`
  line `decision, order or direction.`
  line
  line `(2) An appeal shall lie to the ^1*** from any decision, order or direction of the Controller`
  line `of Central Government under section 15, section 16, section 17, section 18, section 19,^2[section 20,`
  line `sub-section (4) of section 25, section 28], section 51, section 54, section 57, section 60, section 61,`
  line `section 63, section 66, sub-section (3) of section 69, section 78, sub-sections (1) to (5) of section 84,`
  line `section 85, section 88, section 91, section 92 and section 94.`
  line
  line `(3) Every appeal under this section shall be in the prescribed form and shall be verified in such`
  line `manner as may be prescribed and shall be accompanied by a copy of the decision, order or direction`
  line `appealed against and by such fees as may be prescribed.`
  line
  line `(4) Every appeal shall be made within three months from the date of the decision, order or direction,`
  line `as the case may be, of the Controller or the Central Government or within such further time as the`
  line `Appellate Board may, in accordance with the rules made by it, allow.`
obj_root_law_sections_117_a_footnotes:
  string
  line `1. Subs. by s. 13, ibid., for “Appellate Board” (w.e.f. 4-4-2021).`
  line `1. Subs. by s. 61, ibid., for section 20, section 25, section 27, section 28 (w.e.f. 2-4-2007).`
