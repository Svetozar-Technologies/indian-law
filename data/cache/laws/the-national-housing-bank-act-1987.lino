obj_root_law:
  slug the-national-housing-bank-act-1987
  handle (1881)
  collectionHandle 123456789/1362
  title `The National Housing Bank Act, 1987`
  actNumber (53)
  enactmentDate 1987-12-23
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1881`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्ट्रीय आवास बैंक अधिनियम, 1987`
  actYear (1987)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to establish a bank to be known as the National Housing Bank to operate as a principal agency to promote housing finance institutions both at local and regional levels and to provide financial and other support to such institutions and for matters connected therewith or incidental thereto.`
  enforcementDate 09-07-1988
  notification `9th July, 1988, vide notification No. S.O. 684(E), dated 9th July, 1988, see Gazette of India, Extraordinary, Part II, sec. 3(ii) except Chapter V and sub-section (3) of section 49. 1st June, 1989, vide notification No. S.O. 394(E), dated 1st June, 1989, see Gazette of India, Extraordinary, Part II, sec. 3(ii) in respect of Chapter V and sub-section (3) of section 49.`
  fetchedAt `2026-05-09T10:32:00.821Z`
  translations obj_root_law_translations
