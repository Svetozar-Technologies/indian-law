obj_root_law_sections_57:
  sectionId (35032)
  sectionNo (57)
  orderNo 101
  title `Power to remove difficulties.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00053_198753_1517807327356&sectionId=35032&sectionno=57&orderno=101&orgactid=AC_CEN_2_11_00053_198753_1517807327356
obj_root_law_sections_57_content:
  string
  line `If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, not inconsistent with the provisions of this Act,`
  line `remove the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of three years from the`
  line `commencement of this Act.`
obj_root_law_sections_57_footnotes:
  string
  line
