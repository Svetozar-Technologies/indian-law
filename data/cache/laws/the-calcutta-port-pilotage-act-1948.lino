obj_root_law_sections_1:
  object
  (str sectionId) (str 20788)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Calcutta Port (Pilotage)
Act, 1948.

(2) It shall come into force on such date^1
as the Central Government may, by notification in the
Official Gazette, appoint in this behalf.`)
  (str footnotes) (str `1. 16th May, 1948, vide notificaiton No. 27-M (iii)/47, dated 19th May, 1948, see Gazette of India, 1948, Part I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20788&sectionno=1&orderno=1&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_2:
  object
  (str sectionId) (str 20789)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act, unless there is anything repugnant in the subject or context, --

(a) "Appointed day" means the date on which this Act comes into force;

(b) "Commissioners'' means the Commissioners for the Part of Calcutta incorporated under the
Calcutta Port Act, 1890 (Ben, Act 3 of 1890);

(c) "Hooghly area" means the part, of the Hooghly River extending from the Port of Calcutta to
the sea to which section 31 of the Indian Ports Act, 1908 ( 15 of 1908), has been extended.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20789&sectionno=2&orderno=2&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_3:
  object
  (str sectionId) (str 20790)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Commissioners’ duty to maintain pilots.`)
  (str content) (str `As from the appointed day it shall be the duty of the
Commissioners to maintain pilots for the safe navigation of vessels in the Hooghly area and the
Commissioners shall be bound to maintain a sufficient number of pilots for the purpose as may be
prescribed by the Central Government from time to time.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20790&sectionno=3&orderno=3&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_4:
  object
  (str sectionId) (str 20791)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Appointment of pilots.`)
  (str content) (str `No person shall be appointed to be a pilot by the Commissioners who is
not for the time being authorised by the Central Government under the provisions of' the Indian Ports
Act, 1908 (15 of 1908), to pilot vessels.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20791&sectionno=4&orderno=4&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_5:
  object
  (str sectionId) (str 20792)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Rules regulating Pilots.`)
  (str content) (str `(1) The Commissioners may from time to time make rules--

(a) For fixing and regulating the salaries, wages and allowances for pilot age to be received by
the Pilots, and

(b) For regulating the behaviour and conduct of pilots,

and may enforce the observance of such rules by the imposition of pecuniary penalties not exceeding two
hundred rupees for every breach thereof or by suspension or deprivation of appointment or otherwise, as
to them may appear expedient:

Provided that any such order made by the Commissioners shall, as respects any officer whose salary
amounts to or exceeds one thousand rupees, be subject to the previous sanction of the Central
Government.

(2) No such rules shall take effect until they are approved by the Central Government and published
in the Official Gazette.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20792&sectionno=5&orderno=5&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_6:
  object
  (str sectionId) (str 20793)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Levy of pilotage fees.`)
  (str content) (str `As from the appointed day the Commissioners shall be entitled to levy
fees for the pilot age of vessels in the Hooghly area at rates fixed under the Indian Ports
Act, 1908 (15 of 1908).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20793&sectionno=6&orderno=6&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_7:
  object
  (str sectionId) (str 20794)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Pilot age fees and fines and penalties levied under the Act.`)
  (str content) (str `^1[7. Pilot age fees and fines and penalties levied under the Act.--All fees for pilotage and all fines
and penalties levied under this Act from pilot or other persons employed in the pilot service, except fines
and penalties imposed by a Court, shall be accounted for and expended by the Commissioners in
accordance with the provisions of section 36 of the Indian Ports Act, 1908 (15 of 1908).]`)
  (str footnotes) (str `1. Subs. by Act 35 of 1951, s. 193, for section 7, (w.e.f. 16-7-1951).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20794&sectionno=7&orderno=7&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_8:
  object
  (str sectionId) (str 20795)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str Repealed.)
  (str content) (str `[Expenditure in pilotage account.]-- Repealed by the Port Trust and Ports (Amendment) Act,
1951 (35 of 1951), s. 194 (w.e.f. 16-7-1951).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20795&sectionno=8&orderno=8&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_9:
  object
  (str sectionId) (str 20797)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str `Power to transfer moneys from the general account to pilot age account and vice versa.`)
  (str content) (str `The
Commissioners shall have the power, with the previous sanction of the Central Government, to apply
^1[any sum out of] the moneys credited to the general account towards meeting deficits, if any, in the
pilotage account ^2[maintained under section 36 of the Indian Ports Act, 1908 (15 of 1908)] and to transfer
the whole or ^2[part of the surplus funds, if any, in such pilot age account] to the general account.`)
  (str footnotes) (str `1. Ins. by s. 195, ibid.

2. Subs. by s. 195, ibid., for "part of the surplus funds in the pilotage account".`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20797&sectionno=9&orderno=9&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_10:
  object
  (str sectionId) (str 20798)
  (str sectionNo) (str 10)
  (str orderNo) (int 10)
  (str title) (str `Application of certain provisions of Bengal Act 3 of 1890.`)
  (str content) (str `^1[10. Application of certain provisions of Bengal Act 3 of 1890.--Section 18, 19, 24B, 29 to 34
(both inclusive), 47 to 54 (both inclusive), 55, 57, 58 and 69 to 80A (both inclusive) of the Calcutta Port
Act, 1890 are hereby incorporated in this Act subject to the following modifications, namely:--

(a) That the references in the said sections to the Calcutta Port Act, 1890 (Ben. Act 3 of 1890)
shall be taken as references to this Act;

(b) That in clause (b) of section 19, for the words "the tolls, dues, rates, rents and charges", the
words “the pilotage fees” shall be substituted;

(c) That the proviso to sub-section (2) of section 30 shall be omitted;

(d) That in sub-section (1) of section 34, the words "the Deputy Chairman or to" shall be omitted.

(e) That sub-section (2) of section 34 shall be omitted.]`)
  (str footnotes) (str `1. Subs. by s. 196, ibid., for section 10.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20798&sectionno=10&orderno=10&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
obj_root_law_sections_11:
  object
  (str sectionId) (str 20799)
  (str sectionNo) (str 11)
  (str orderNo) (int 11)
  (str title) (str Repealed.)
  (str content) (str `[Amendment of the Calcutta Pilots Act 12 of 1859] Rep. by the Repealing and Amending
Act, 1950 (Act 35 of 1950), s. 2 and the First Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20799&sectionno=11&orderno=11&orgactid=AC_CEN_7_7_00007_194833_1517807326076)
