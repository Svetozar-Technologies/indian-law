  object
  (str title) (str `कलकत्ता पत्तन (यान मार्गदर्शन)अधिनियम,1948`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1852/3/H1948-33.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T10:07:15.294Z`)
  (str pageCount) (int 2)
  (str sections) obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
