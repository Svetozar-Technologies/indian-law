obj_root_law_sections_1:
  sectionId (20788)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 16th May, 1948, vide notificaiton No. 27-M (iii)/47, dated 19th May, 1948, see Gazette of India, 1948, Part I.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20788&sectionno=1&orderno=1&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Calcutta Port (Pilotage)`
  line `Act, 1948.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint in this behalf.`
obj_root_law_sections_2:
  sectionId (20789)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20789&sectionno=2&orderno=2&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context, --`
  line
  line `(a) "Appointed day" means the date on which this Act comes into force;`
  line
  line `(b) "Commissioners'' means the Commissioners for the Part of Calcutta incorporated under the`
  line `Calcutta Port Act, 1890 (Ben, Act 3 of 1890);`
  line
  line `(c) "Hooghly area" means the part, of the Hooghly River extending from the Port of Calcutta to`
  line `the sea to which section 31 of the Indian Ports Act, 1908 ( 15 of 1908), has been extended.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (20790)
  sectionNo (3)
  orderNo 3
  title `Commissioners’ duty to maintain pilots.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20790&sectionno=3&orderno=3&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_3_content:
  string
  line `As from the appointed day it shall be the duty of the`
  line `Commissioners to maintain pilots for the safe navigation of vessels in the Hooghly area and the`
  line `Commissioners shall be bound to maintain a sufficient number of pilots for the purpose as may be`
  line `prescribed by the Central Government from time to time.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (20791)
  sectionNo (4)
  orderNo 4
  title `Appointment of pilots.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20791&sectionno=4&orderno=4&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_4_content:
  string
  line `No person shall be appointed to be a pilot by the Commissioners who is`
  line `not for the time being authorised by the Central Government under the provisions of' the Indian Ports`
  line `Act, 1908 (15 of 1908), to pilot vessels.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (20792)
  sectionNo (5)
  orderNo 5
  title `Rules regulating Pilots.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20792&sectionno=5&orderno=5&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_5_content:
  string
  line `(1) The Commissioners may from time to time make rules--`
  line
  line `(a) For fixing and regulating the salaries, wages and allowances for pilot age to be received by`
  line `the Pilots, and`
  line
  line `(b) For regulating the behaviour and conduct of pilots,`
  line
  line `and may enforce the observance of such rules by the imposition of pecuniary penalties not exceeding two`
  line `hundred rupees for every breach thereof or by suspension or deprivation of appointment or otherwise, as`
  line `to them may appear expedient:`
  line
  line `Provided that any such order made by the Commissioners shall, as respects any officer whose salary`
  line `amounts to or exceeds one thousand rupees, be subject to the previous sanction of the Central`
  line Government.
  line
  line `(2) No such rules shall take effect until they are approved by the Central Government and published`
  line `in the Official Gazette.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (20793)
  sectionNo (6)
  orderNo 6
  title `Levy of pilotage fees.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20793&sectionno=6&orderno=6&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_6_content:
  string
  line `As from the appointed day the Commissioners shall be entitled to levy`
  line `fees for the pilot age of vessels in the Hooghly area at rates fixed under the Indian Ports`
  line `Act, 1908 (15 of 1908).`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (20794)
  sectionNo (7)
  orderNo 7
  title `Pilot age fees and fines and penalties levied under the Act.`
  content obj_root_law_sections_7_content
  footnotes `1. Subs. by Act 35 of 1951, s. 193, for section 7, (w.e.f. 16-7-1951).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20794&sectionno=7&orderno=7&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_7_content:
  string
  line `^1[7. Pilot age fees and fines and penalties levied under the Act.--All fees for pilotage and all fines`
  line `and penalties levied under this Act from pilot or other persons employed in the pilot service, except fines`
  line `and penalties imposed by a Court, shall be accounted for and expended by the Commissioners in`
  line `accordance with the provisions of section 36 of the Indian Ports Act, 1908 (15 of 1908).]`
obj_root_law_sections_8:
  sectionId (20795)
  sectionNo (8)
  orderNo 8
  title Repealed.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20795&sectionno=8&orderno=8&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_8_content:
  string
  line `[Expenditure in pilotage account.]-- Repealed by the Port Trust and Ports (Amendment) Act,`
  line `1951 (35 of 1951), s. 194 (w.e.f. 16-7-1951).`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (20797)
  sectionNo (9)
  orderNo 9
  title `Power to transfer moneys from the general account to pilot age account and vice versa.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20797&sectionno=9&orderno=9&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_9_content:
  string
  line The
  line `Commissioners shall have the power, with the previous sanction of the Central Government, to apply`
  line `^1[any sum out of] the moneys credited to the general account towards meeting deficits, if any, in the`
  line `pilotage account ^2[maintained under section 36 of the Indian Ports Act, 1908 (15 of 1908)] and to transfer`
  line `the whole or ^2[part of the surplus funds, if any, in such pilot age account] to the general account.`
obj_root_law_sections_9_footnotes:
  string
  line `1. Ins. by s. 195, ibid.`
  line
  line `2. Subs. by s. 195, ibid., for "part of the surplus funds in the pilotage account".`
obj_root_law_sections_10:
  sectionId (20798)
  sectionNo (10)
  orderNo 10
  title `Application of certain provisions of Bengal Act 3 of 1890.`
  content obj_root_law_sections_10_content
  footnotes `1. Subs. by s. 196, ibid., for section 10.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20798&sectionno=10&orderno=10&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_10_content:
  string
  line `^1[10. Application of certain provisions of Bengal Act 3 of 1890.--Section 18, 19, 24B, 29 to 34`
  line `(both inclusive), 47 to 54 (both inclusive), 55, 57, 58 and 69 to 80A (both inclusive) of the Calcutta Port`
  line `Act, 1890 are hereby incorporated in this Act subject to the following modifications, namely:--`
  line
  line `(a) That the references in the said sections to the Calcutta Port Act, 1890 (Ben. Act 3 of 1890)`
  line `shall be taken as references to this Act;`
  line
  line `(b) That in clause (b) of section 19, for the words "the tolls, dues, rates, rents and charges", the`
  line `words “the pilotage fees” shall be substituted;`
  line
  line `(c) That the proviso to sub-section (2) of section 30 shall be omitted;`
  line
  line `(d) That in sub-section (1) of section 34, the words "the Deputy Chairman or to" shall be omitted.`
  line
  line `(e) That sub-section (2) of section 34 shall be omitted.]`
obj_root_law_sections_11:
  sectionId (20799)
  sectionNo (11)
  orderNo 11
  title Repealed.
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00007_194833_1517807326076&sectionId=20799&sectionno=11&orderno=11&orgactid=AC_CEN_7_7_00007_194833_1517807326076
obj_root_law_sections_11_content:
  string
  line `[Amendment of the Calcutta Pilots Act 12 of 1859] Rep. by the Repealing and Amending`
  line `Act, 1950 (Act 35 of 1950), s. 2 and the First Schedule.`
obj_root_law_sections_11_footnotes:
  string
  line
