  object
  (str title) (str `प्रतिकरात्मक वनरोपण निधि अधिनियम, 2016`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2151/3/H2016-38.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:42:01.080Z`)
