obj_root_law_sections_1:
  sectionId (39785)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00049_198332_1517807325645&sectionId=39785&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00049_198332_1517807325645
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called The Punjab Disturbed Areas`
  line `Act, 1983.`
  line
  line `(2) It extends to the whole of the State of Punjab.`
  line
  line `(3) It shall be deemed to have come into force on the 7th day of October, 1983.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39786)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00049_198332_1517807325645&sectionId=39786&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00049_198332_1517807325645
obj_root_law_sections_2_content:
  string
  line `In this Act, "disturbed area" means an area which is for the time being declared by`
  line `notification under section 3 to be a disturbed area.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39787)
  sectionNo (3)
  orderNo 3
  title `Powers to declare areas to be disturbed areas.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00049_198332_1517807325645&sectionId=39787&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00049_198332_1517807325645
obj_root_law_sections_3_content:
  string
  line `The State Government may, by notification in`
  line `the Official Gazette, declare that the whole or any part of any district of Punjab as may be specified in the`
  line `notification, is a disturbed area.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39788)
  sectionNo (4)
  orderNo 4
  title `Power to fire upon persons contravening certain orders.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00049_198332_1517807325645&sectionId=39788&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00049_198332_1517807325645
obj_root_law_sections_4_content:
  string
  line `Any Magistrate or Police Officer not`
  line `below the rank of Sub-Inspector or Havildar in case of the Armed Branch of the Police may, if he is of`
  line `opinion that it is necessary so to do for the maintenance of public order, after giving such due warning, as`
  line `he may consider necessary, fire upon, or otherwise use force, even to the causing of death, against any`
  line `person who is acting in contravention of any law or order for the time being in force in the disturbed area,`
  line `prohibiting the assembly of five or more persons or the carrying of weapons or of things capable of being`
  line `used as weapons or of fire-arms, ammunition or explosive substances.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39789)
  sectionNo (5)
  orderNo 5
  title `Powers to destroy arms dump, fortified positions, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00049_198332_1517807325645&sectionId=39789&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00049_198332_1517807325645
obj_root_law_sections_5_content:
  string
  line `Any Magistrate or Police Officer not`
  line `below the rank of a Sub-Inspector may, if he is of the opinion that it is necessary so to do, destroy any`
  line `arms dump, prepared or fortified position or shelter from which armed attacks arc made or are likely to be`
  line `made or are attempted to be made or any structure used as training camp for armed volunteers or utilized`
  line `as a hide-out by armed gangs or absconders wanted for any offence.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39790)
  sectionNo (6)
  orderNo 6
  title `Protection of persons acting under sections 4 and 5.`
  content obj_root_law_sections_6_content
  footnotes `1 Subs. by President Act 2 of 1989, s. 2, for "State Government" (w.e.f. 3-4-1989).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00049_198332_1517807325645&sectionId=39790&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00049_198332_1517807325645
obj_root_law_sections_6_content:
  string
  line `No suit, prosecution or other legal`
  line `proceedings shall be instituted except with the previous sanction of the^1`
  line `[Central Government] against any`
  line `person in respect of anything done or purporting to be done in exercise of the powers conferred by`
  line `sections 4 and 5.`
obj_root_law_sections_7:
  sectionId (39791)
  sectionNo (7)
  orderNo 7
  title `Repeal and saving.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00049_198332_1517807325645&sectionId=39791&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00049_198332_1517807325645
obj_root_law_sections_7_content:
  string
  line `(1) The Punjab Disturbed Areas Ordinance, 1983 (5 of 1983), is hereby`
  line repealed.
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_7_footnotes:
  string
  line
