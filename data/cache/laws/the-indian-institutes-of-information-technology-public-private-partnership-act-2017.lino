obj_root_law_sections_1:
  sectionId (40894)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40894&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Indian Institutes of Information`
  line `Technology (Public-private Partnership) Act, 2017.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 6th September, 2017 vide notification No. S.O. 2928(E) dated the 6 September, 2017, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (40895)
  sectionNo (2)
  orderNo 2
  title `Declaration of certain institutions as institutions of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40895&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of`
  line `the Institutes mentioned in the Schedule are such as to make them institutions of national importance, it is`
  line `hereby declared that each such Institute is an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (40896)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40896&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,---`
  line
  line `(a) "appointed day" means the date of establishment of the Institutes established under`
  line `sub-section (2) of section 4;`
  line
  line `(b) "Board" , in relation to any Institute, means the Board of Governors referred to in`
  line `sub-section (1) of section 14;`
  line
  line `(c) "Chairperson" means the Chairperson of the Board appointed under sub-section (2) of`
  line `section 14;`
  line
  line `(d) "Co-ordination Forum" means the Co-ordination Forum established under sub-section (1) of`
  line `section 38;`
  line
  line `(e) "Director" means the Director of the Institute;`
  line
  line `(f) "existing Institute" means the Institute mentioned in column (3) of the Schedule;`
  line
  line `(g) "industry partner" means an individual, or a trust established under the Indian Trusts Act, 1882,`
  line `(2 of 1882) or a company established under the Companies Act, 2013 (18 of 2013) or society formed`
  line `and registered under the Societies Registration Act, 1860 (21 of 1860) or a financial institution or a`
  line `combination of one or more of such industry partners;`
  line
  line `(h) "Institute" means any of the institutions mentioned in column (5) of the Schedule and such`
  line `other Institutes established under section 11;`
  line
  line `(i) "notification" means a notification published in the Official Gazette and the expression`
  line `"notify" shall be construed accordingly;`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(k) "public-private partnership" means such partnership under a scheme of the Central`
  line `Government which provides for establishment of Institute involving collaboration between the`
  line `Central Government, the State Government and industry partners;`
  line
  line `(l) "Schedule" means the Schedule to this Act;`
  line
  line `(m) "Senate", in relation to any Institute, means the Senate thereof;`
  line
  line `(n) "Statutes" and "Ordinances", in relation to any Institute, mean the Statutes and Ordinances of`
  line `the Institute made under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (40897)
  sectionNo (4)
  orderNo 4
  title `Incorporation of Institutes.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40897&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_4_content:
  string
  line `(1) On and from the commencement of this Act, every existing`
  line `Institute, shall be a body corporate by the same name as mentioned in column (5) of the Schedule.`
  line
  line `(2) On and from the appointed day, any other Institute of Information Technology as may be`
  line `established under section 11 shall be a body corporate by such name as the Central Government may, by`
  line `notification, specify.`
  line
  line `(3) Every existing Institute or any Institute established under sub-section (2) shall have perpetual`
  line `succession and a common seal, with power, subject to the provisions of this Act, to acquire, hold and`
  line `dispose of property, both movable and immovable, and to contract, and shall, by its name, sue or be sued.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (40898)
  sectionNo (5)
  orderNo 5
  title `Effect of incorporation of Institutes.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40898&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_5_content:
  string
  line `On and from the date of commencement of this Act,---`
  line
  line `(a) any reference to any existing Institute in any contract or other instrument shall be deemed to be`
  line `reference to the corresponding Institute mentioned in column (5) of the Schedule;`
  line
  line `(b) all properties, movable and immovable, belonging to every existing Institute shall vest in the`
  line `corresponding Institute mentioned in column (5) of the Schedule;`
  line
  line `(c) all rights, debts and other liabilities of every existing Institute shall be transferred to, and be the`
  line `rights and liabilities of, the corresponding Institute mentioned in column (5) of the Schedule;`
  line
  line `(d) every person employed by any existing Institute, immediately before such commencement, shall hold`
  line `his office or service in the corresponding Institute mentioned in column (5) of the Schedule, with the same`
  line `tenure, at the same remuneration and upon the same terms and conditions and with the same rights and`
  line `privileges as to pension, leave, gratuity, provident fund and other matters as he would have held the same if`
  line `this Act had not been enacted and shall continue to do so unless and until his employment is terminated or`
  line `until such tenure, remuneration and the terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may be`
  line `terminated by the Institute in accordance with the terms of the contract with the employee or, if no`
  line `provision is made therein in this behalf, on payment to him by the Institute of compensation equivalent`
  line `to three months' remuneration in the case of permanent employees and one month's remuneration in`
  line `case of other employees:`
  line
  line `Provided further that any reference, by whatever form of words, to the Director, Registrar and other`
  line `officers of any existing Institute, in any law for the time being in force, or in any instrument or other`
  line `document, shall be deemed to be reference to the Director, Registrar and other officers of the`
  line `corresponding Institute mentioned in column (5) of the Schedule;`
  line
  line `(e) every person pursuing, before the commencement of this Act, any academic or research course in`
  line `any existing Institute, shall be deemed to have migrated and registered with the corresponding Institute`
  line `mentioned in column (5) of the Schedule, on such commencement at the same level of course in the`
  line `Institute from which such person migrated;`
  line
  line `(f) all suits and other legal proceedings instituted or which could have been instituted by or against an`
  line `existing Institute, immediately before the commencement of this Act, shall be continued or instituted by`
  line `or against the corresponding Institute mentioned in column (5) of the Schedule.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (40899)
  sectionNo (6)
  orderNo 6
  title `Objects of Institute.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40899&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_6_content:
  string
  line `Every Institute shall have the following objectives, namely:—`
  line
  line `(a) to emerge amongst the foremost institutions in information technology and allied fields of`
  line `knowledge in the global context;`
  line
  line `(b) to advance new knowledge and innovation in information technology and allied fields to`
  line `empower the nation to the forefront in the global context;`
  line
  line `(c) to develop competent and capable youth imbued with the spirit of innovation and`
  line `entrepreneurship with the social and environmental orientation to meet the knowledge needs of the`
  line `country and provide global leadership in information technology and allied fields;`
  line
  line `(d) to promote and provide transparency of highest order in matters of admission, appointment to`
  line `various positions, academic evaluation, administration and finance.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (40900)
  sectionNo (7)
  orderNo 7
  title `Powers and functions of Institute.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40900&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of this Act, every Institute shall`
  line `exercise the following powers and perform the following functions, namely:—`
  line
  line `(a) to provide instructions in such fields of knowledge relating to information technology and`
  line `allied areas as the Institute may deem fit, for the advancement of learning and dissemination of`
  line knowledge;
  line
  line `(b) to lead, organise and conduct research and innovation in information technology and allied`
  line `fields of knowledge in such manner as the Institute may deem fit, including in collaboration or in`
  line `association with any other Institute, educational institution, research organisation, body corporate or`
  line `financial organisations at national or global level;`
  line
  line `(c) to hold examinations and grant degrees, diplomas and other academic distinctions or titles and`
  line `to confer honorary degrees;`
  line
  line `(d) to create academic, administrative, technical, ministerial and other posts under the Institute`
  line `other than the post of Director of the Institute and to make appointments thereto;`
  line
  line `(e) to appoint persons working in any other Institute or educational institution or involved in`
  line `research of significance in any industry as adjunct, guest or visiting faculty of the Institute on such`
  line `terms and for such duration as the Institute may decide;`
  line
  line `(f) to create administrative and other posts and to make appointments thereto on the basis of`
  line `criteria as may be decided by the Board;`
  line
  line `(g) to make provision for dissemination of knowledge emerging from research and for that purpose`
  line `to enter into such arrangements, including consultancy and advisory services, with other institutions,`
  line `industry, civil society or other organisations, as the Institute may deem necessary;`
  line
  line `(h) to create a website, highlight all information not restricted to those related to students,`
  line `admission, fee, administrative structure, policies including recruitment rules, faculty and non-faculty`
  line `posts, annual reports and financial details including statement of account of the Institute;`
  line
  line `(i) to determine, specify and receive payment of fees and other charges, as the Institute may deem`
  line `fit, from students and any other person, institution or body corporate for instructions and other`
  line `services, including training, consultancy and advisory services, provided by the Institute;`
  line
  line `(j) to deal with any property belonging to, or vested in, the Institute in such manner as the Institute`
  line `may deem fit for advancement of the objectives of the Institute:`
  line
  line `Provided that no land or other immovable property shall be disposed of by the Institute without`
  line `the prior approval of the concerned State Government and the Central Government;`
  line
  line `(k) to receive gifts, grants, donations or benefactions from the Government and to receive`
  line `bequests, donations and transfer of movable or immovable properties from testators, donors or`
  line `transferors, as the case may be;`
  line
  line `(l) to co-operate with educational or other institutions in any part of the world having objects`
  line `wholly or partly similar to those of the Institute by exchange of teachers and scholars and generally in`
  line `such manner as may be conducive to their common objects;`
  line
  line `(m) to establish and maintain such infrastructure as may be necessary, incidental or conducive to`
  line `the attainment of the objectives of the Institute;`
  line
  line `(n) to institute and award fellowships, scholarships, exhibitions, prizes and medals; and`
  line
  line `(o) to do all such things as may be necessary, incidental or conducive to the attainment of all or`
  line `any of the objectives of the Institute.`
  line
  line `(2) Subject to the provisions of this Act, every Institute may take up the following works, namely:—`
  line
  line `(a) supporting and collaborating with educational Institutes imparting technical or information`
  line `technology courses located in the zone or region;`
  line
  line `(b) advising the State Governments and Union territory Administrations included in its zone in`
  line `matters of information technology and other technological issues referred by them to the Institute for`
  line advice.
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (40901)
  sectionNo (8)
  orderNo 8
  title `Institutes to be open to all races, creeds and classes.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40901&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_8_content:
  string
  line `(1) Every Institute shall be open to all`
  line `citizens irrespective of gender, caste, creed, disability, domicile, ethnicity, social or economic`
  line background.
  line
  line `(2) No bequest, donation or transfer of any property shall be accepted by any Institute which in the`
  line `opinion of the Co-ordination Forum involves conditions or obligations opposed to the spirit and object of`
  line `this section.`
  line
  line `(3) Admissions to every programme of study in each Institute shall be based on merit assessed`
  line `through transparent and reasonable criteria disclosed through its prospectus, prior to the commencement`
  line `of the process of admission by such Institute:`
  line
  line `Provided that every such Institute shall be a Central Educational Institution for the purposes of the`
  line `Central Educational Institutions (Reservation in Admission) Act, 2006 (5 of 2007).`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (40902)
  sectionNo (9)
  orderNo 9
  title `Teaching at Institute.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40902&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_9_content:
  string
  line `All teaching at each of the Institute shall be conducted by or in the name`
  line `of the Institute in accordance with the Statutes and Ordinances made in this behalf.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (40903)
  sectionNo (10)
  orderNo 10
  title `Institute to be a distinct legal entity not-for-profit.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40903&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_10_content:
  string
  line `(1) Every Institute shall be a not-for-profit`
  line `legal entity and no part of the surplus, if any, in revenue of such Institute, after meeting all expenditure in`
  line `regard to its operations under this Act, shall be invested for any purpose other than for the growth and`
  line `development of such Institute or for conducting research therein.`
  line
  line `(2) Every Institute shall strive to raise funds for creation of a corpus for self-sufficiency, sustainability`
  line `and future development of the Institute.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (40904)
  sectionNo (11)
  orderNo 11
  title `Establishment of Institute by Central Government, State Government and industry partners.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40904&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_11_content:
  string
  line `(1) The State Government shall identify at least one industry partner, and preferably three industry`
  line `partners, for collaboration and submit a proposal to the Central Government.`
  line
  line `(2) The Central Government shall examine the proposal on the basis of such criteria, as may be`
  line `prescribed, which shall include the following, namely:—`
  line
  line `(a) the investment of capital required for establishing the proposed Institute to be borne by the`
  line `Central Government, the concerned State Government and industry partners in the ratio 50:35:15 and`
  line `recurring expenditure, as may be considered necessary during the first five years of operation, to be`
  line `made available by the Central Government:`
  line
  line `Provided that the ratio of investment of capital required for establishing the proposed Institute in`
  line `North Eastern States shall be 57.5:35:7.5;`
  line
  line `(b) the expertise and standing of the industry partners proposed in sub-section (1) in the field of`
  line `information technology;`
  line
  line `(c) the assessment of the capability, financial and other resources of industry partners to support`
  line `the Institute;`
  line
  line `(d) the suitability of adequate land, to the extent of fifty to hundred acres, to be provided by the`
  line `State Government free of cost;`
  line
  line `(e) the availability of, or the commitment of the State Government to make available, adequate`
  line `physical infrastructure namely, water, electricity, road connectivity and security, at the proposed site.`
  line
  line `(3) The Central Government may, with the concurrence of the concerned State Government, suggest`
  line `modifications, if any, to the proposal submitted to it under sub-section (1).`
  line
  line `(4) Where a proposal submitted by the State Government under sub-section (1) is not acceptable to the`
  line `Central Government, the Central Government shall communicate its decision to that State Government,`
  line `specifying the reasons for such decision.`
  line
  line `(5) The Central Government shall, on acceptance of the proposal with modifications, if any, under`
  line `sub-section (3) , enter into a memorandum of understanding or an agreement with the concerned State`
  line `Government and the industry partners for the establishment of the proposed Institute.`
  line
  line `(6) The industry partner shall—`
  line
  line `(a) actively participate in the governance of the Institute within the overall framework;`
  line
  line `(b) support and facilitate joint research projects with the Indian Institutes of Information Technology`
  line `either through funding, collaboration or in any other manner;`
  line
  line `(c) depute experienced individuals as adjunct faculty;`
  line
  line `(d) encourage, enable, support and mentor students to do research project as a part of their course`
  line `curriculum, within their enterprise;`
  line
  line `(e) accept faculty members of the Indian Institutes of Information Technology on a sabbatical to`
  line `work for short period with the industry;`
  line
  line `(f) co-create programs as per the requirements of the industry with the Institution;`
  line
  line `(g) provide internship to students of the Indian Institutes of Information Technology;`
  line
  line `(h) facilitate for placement of students from the Indian Institutes of Information Technology;`
  line
  line `(i) sponsor their eligible employees for doctorate studies in the Indian Institutes of Information`
  line `Technology; and`
  line
  line `(j) fund and mentor the startups in the Institution.`
  line
  line `(7) Every memorandum of understanding or agreement referred to in sub-section (5) shall contain—`
  line
  line `(a) the investment proposal of capital in establishment of the Institute and the respective shares as`
  line `may be prescribed;`
  line
  line `(b) the first Statutes of the Institute;`
  line
  line `(c) the commitment of the Central Government, the concerned State Government, and the`
  line `industry partner in ensuring autonomy to the proposed Institute; and`
  line
  line `(d) the conditions, if the industry partners pulls out.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (40905)
  sectionNo (12)
  orderNo 12
  title Visitor.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40905&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_12_content:
  string
  line `(1) The President of India shall be the Visitor of every Institute.`
  line
  line `(2) The Visitor may appoint one or more persons to review the work and progress of any Institute and`
  line `to hold inquiries into the affairs thereof and to report thereon in such manner as the Visitor may direct.`
  line
  line `(3) Upon receipt of any such report, the Visitor may take such action and issue such directions as`
  line `he considers necessary in respect of any of the matters dealt within the report and the Institute shall be`
  line `bound to comply with such directions within a reasonable time.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (40906)
  sectionNo (13)
  orderNo 13
  title `Authorities of Institute.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40906&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_13_content:
  string
  line `The following shall be the authorities of an Institute, namely:—`
  line
  line `(a) Visitor;`
  line
  line `(b) Board of Governors;`
  line
  line `(c) Senate;`
  line
  line `(d) Finance Committee;`
  line
  line `(e) such other authorities or posts as may be declared by the Statutes to be the authorities of the`
  line Institute.
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (40907)
  sectionNo (14)
  orderNo 14
  title `Board of Governors.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40907&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_14_content:
  string
  line `(1) The Board of Governors of each Institute shall be the principal policy`
  line `making and executive body of the Institute.`
  line
  line `(2) The Board shall consist of the following members, namely:—`
  line
  line `(a) Chairperson, an eminent technologist or industrialist or educationist to be nominated by the`
  line `Visitor on the recommendation of the Central Government;`
  line
  line `(b) one nominee each of the Central Government and the concerned State Government;`
  line
  line `(c) three eminent persons, of which at least one shall be a woman, appointed by the Board out of`
  line `industry, research laboratories, and civil society, one from each category;`
  line
  line `(d) two eminent academicians appointed by the Board;`
  line
  line `(e) one nominee representing each of the industry partners:`
  line
  line `Provided that if there are more than two industry partners then the number of representatives of`
  line `industry partners at any time would be limited to two, chosen amongst themselves by rotation every`
  line `two years;`
  line
  line `(f) Director of an Indian Institute of Technology or a National Institute of Technology located in`
  line `the region, to be nominated by the Board;`
  line
  line `(g) two members from the faculty of the Institute, preferably one Professor and one`
  line `Associate/Assistant Professor, to be nominated by the Senate;`
  line
  line `(h) one person from the Scheduled Castes or the Scheduled Tribes distinguished in the field of`
  line `education or industry or social service or public service, to be nominated by the Board, in case any of the`
  line `above do not belong to the Scheduled Castes or the Scheduled Tribes; and`
  line
  line `(i) Director of the Institute, ex officio.`
  line
  line `(3) Registrar of the concerned Institute shall be the ex officio non-member Secretary of the Board.`
  line
  line `(4) The First Board of Governors shall be notified by the Central Government by obtaining nominations`
  line `under sub-section (2), other than the members referred to in clauses (c), (d), (f) and (h), which shall be`
  line `decided in the first meeting of the Board of Governors.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (40908)
  sectionNo (15)
  orderNo 15
  title `Term of office of, vacancies among and allowances payable to, members of Board.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40908&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_15_content:
  string
  line `(1) Save`
  line `as otherwise provided in this section, the term of office of the Chairperson or any other member of the`
  line `Board, other than an ex officio member, shall be for a period of three years from the date of nomination.`
  line
  line `(2) The term of office of an ex officio member shall continue so long as the member holds the office`
  line `by virtue of which he is a member.`
  line
  line `(3) A member of the Board, other than an ex officio member, who fails to attend three consecutive`
  line `meetings of the Board without the leave of absence, shall cease to be a member of the Board.`
  line
  line `(4) One-third of the members of the Board shall form a quorum of the Board, provided at least three`
  line `members are from members referred to in clauses other than clauses (e), (g) and (i) of sub-section (2) of`
  line `section 14.`
  line
  line `(5) The members of the Board shall be entitled to such allowances, as may be laid down in Statutes, for`
  line `attending meetings of the Board or as may be convened by the Institute.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (40909)
  sectionNo (16)
  orderNo 16
  title `Resignation of Chairperson.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40909&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_16_content:
  string
  line `(1) The Chairperson may, by writing under his hand addressed to`
  line `the Visitor, resign his office.`
  line
  line `(2) Any member of the Board, except ex officio members, may, by writing under his hand addressed`
  line `to the Chairperson, resign his office.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (40910)
  sectionNo (17)
  orderNo 17
  title `Powers and functions of Board.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40910&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_17_content:
  string
  line
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (40911)
  sectionNo (18)
  orderNo 18
  title Senate.
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40911&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_18_content:
  string
  line `(1) The Senate of every Institute shall consist of the following persons, namely:—`
  line
  line `(a) the Director of the Institute who shall be the ex officio Chairperson of the Senate;`
  line
  line `(b) all Deans, ex officio;`
  line
  line `(c) heads of all departments, faculties or schools, ex officio, as the case may be, of the Institute;`
  line
  line `(d) all full-time professors other than the Deans or heads of the Departments;`
  line
  line `(e) three persons from amongst educationists of repute or persons from another field related to the`
  line `activities of the Institute who are not in service of the Institute, nominated by the Board;`
  line
  line `(f) three persons who are not members of teaching staff co-opted by the Senate for their`
  line `specialised knowledge; and`
  line
  line `(g) Registrar of the Institute, ex officio Secretary.`
  line
  line `(2) The term of office of members nominated under clauses (e) and (f) shall be for a period of two`
  line `years from the date of nomination.`
  line
  line `(3) The term of office of an ex officio member shall continue so long as the member holds the office`
  line `by virtue of which he is a member.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (40912)
  sectionNo (19)
  orderNo 19
  title `Powers and functions of Senate.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40912&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_19_content:
  string
  line `(1) Subject to the provisions of this Act, the Statutes and the`
  line `Ordinances, the Senate shall be the principal academic body of the Institute and shall have the power to`
  line `enact, amend or modify the Ordinances governing academic matters and the affairs and well-being of`
  line students.
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Senate shall have the following powers,`
  line `namely:—`
  line
  line `(a) to specify the criteria and procedure for admission to courses or programmes of study offered`
  line `by the Institute;`
  line
  line `(b) to recommend to the Board creation of teaching and other academic posts, determination of`
  line `the number and emoluments of such posts and defining the duties and conditions of service of`
  line `teachers and other academic posts;`
  line
  line `(c) to recommend to the Board about starting of new programmes or courses of study;`
  line
  line `(d) to specify the broad academic content of programmes and courses of study and undertake`
  line `modifications therein;`
  line
  line `(e) to specify the academic calendar and approve grant of degrees, diplomas and other academic`
  line `distinctions or titles;`
  line
  line `(f) to appoint examiners, moderators, tabulators and such other personnel for different`
  line examinations;
  line
  line `(g) to recognise diplomas and degrees of Universities and other Institutes and to determine`
  line `equivalence with the diplomas and degrees of the Institute;`
  line
  line `(h) to suggest measures for departmental co-ordination;`
  line
  line `(i) to make major recommendations to the Board of Governors on—`
  line
  line `(A) measures for improvement of standard of teaching, training and research;`
  line
  line `(B) institution of chairs, fellowships, scholarships, studentships, freeships, medals and prizes`
  line `and other related matters;`
  line
  line `(C) establishment or abolition of departments or centres; and`
  line
  line `(D) academic functioning of the Institute, discipline, residence, admissions, examinations,`
  line `award of fellowships and studentships, freeships, concessions, attendance and other related`
  line matters;
  line
  line `(j) to appoint sub-committees to advise on such specific matters as may be referred to by the Board`
  line `or by itself;`
  line
  line `(k) to consider the recommendations of the sub-committees and to take such action including`
  line `making of recommendations to the Board as may be required;`
  line
  line `(l) to take periodical review of the activities of the departments or centres and to take appropriate`
  line `action including making of recommendations to the Board with a view to maintain and improve the`
  line `standards of instructions, in the institutions; and`
  line
  line `(m) to exercise such other powers and discharge such other functions as may be assigned to it, by`
  line `Statutes or otherwise, by the Board.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (40913)
  sectionNo (20)
  orderNo 20
  title `Finance Committee.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40913&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_20_content:
  string
  line `(1) The Finance Committee of each Institute shall consist of the following`
  line `persons, namely:—`
  line
  line `(a) the Chairperson of the Board shall be the ex officio Chairperson of the Committee;`
  line
  line `(b) one representative of the Government of India, Ministry of Human Resource Development,`
  line `Department of Higher Education handling the matters relating to finance, ex officio;`
  line
  line `(c) one representative of the State Government in which the Institute is located, ex officio;`
  line
  line `(d) one representative of the industry partners chosen from amongst themselves;`
  line
  line `(e) the Director, ex officio; and`
  line
  line `(f) the officer in-charge of finance and accounts of the Institute, ex officio Secretary.`
  line
  line `(2) The members of the Finance Committee other than ex officio members shall hold office for a term`
  line `of three years.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (40914)
  sectionNo (21)
  orderNo 21
  title `Powers and functions of Finance Committee.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00033_201723_1517807328002&sectionId=40914&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_00033_201723_1517807328002
obj_root_law_sections_21_content:
  string
  line `The Finance Committee shall examine the accounts,`
  line `scrutinise proposals for expenditure and financial estimates of the Institute and thereafter submit it to the`
  line `Board together with its comments for approval.`
obj_root_law_sections_21_footnotes:
  string
  line
