  object
  (str title) (str `विनिर्दिष्टि बैंक नोट (दायित्वोंन की समाप्तिि) अधिनियम,2017`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2244/4/H2017-2.pdf`)
  (str sourceKind) (str pdf)
