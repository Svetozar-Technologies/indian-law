obj_root_law_sections_1:
  sectionId (4728)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4728&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Specified Bank Notes`
  line `(Cessation of Liabilities) Act, 2017.`
  line
  line `(2) It shall be deemed to have come into force on the 31st day of December, 2016.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (4729)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4729&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,—`
  line
  line `(a) "appointed day" means the 31st day of December, 2016;`
  line
  line `(b) "grace period" means the period to be specified by the Central Government, by notification,`
  line `during which the specified bank notes can be deposited in accordance with this Act;`
  line
  line `(c) "notification" means a notification published in the Official Gazette;`
  line
  line `(d) "Reserve Bank" means the Reserve Bank of India constituted by the Central Government`
  line `under section 3 of the Reserve Bank of India Act, 1934 (2 of 1934);`
  line
  line `(e) "specified bank note" means a bank note of the denominational value of five hundred rupees`
  line `or one thousand rupees of the series existing on or before the 8th day of November, 2016.`
  line
  line `(2) The words and expressions used and not defined in this Act but defined in the Reserve Bank of`
  line `India Act, 1934 (2 of 1934) or the Banking Regulation Act, 1949 (10 of 1949) shall have the meanings`
  line `respectively assigned to them in those Acts.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (4730)
  sectionNo (3)
  orderNo 3
  title `Specified bank notes to cease to be liability of Reserve Bank or Central Government.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4730&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_3_content:
  string
  line On
  line `and from the appointed day, notwithstanding anything contained in the Reserve Bank of India Act, 1934`
  line `(2 of 1934) or any other law for the time being in force, the specified bank notes which have ceased to be`
  line `legal tender, in view of the notification of the Government of India in the Ministry of Finance, number S.O.`
  line `3407(E), dated the 8th November, 2016, issued under sub-section (2) of section 26 of the Reserve Bank of`
  line `India Act, 1934, shall cease to be liabilities of the Reserve Bank under section 34 and shall cease to have the`
  line `guarantee of the Central Government under sub-section (1) of section 26 of the said Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (4731)
  sectionNo (4)
  orderNo 4
  title `Exchange of specified bank notes.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4731&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_4_content:
  string
  line `(1) Notwithstanding anything contained in section 3, the`
  line `following persons holding specified bank notes on or before the 8th day of November, 2016 shall be entitled`
  line `to tender within the grace period with such declarations or statements, at such offices of the Reserve Bank or`
  line `in such other manner as may be specified by it, namely:—`
  line
  line `(i) a citizen of India who makes a declaration that he was outside India between the 9th November,`
  line `2016 to 30th December, 2016, subject to such conditions as may be specified, by notification, by the`
  line `Central Government; or`
  line
  line `(ii) such class of persons and for such reasons as may be specified by notification, by the`
  line `Central Government.`
  line
  line `(2) The Reserve Bank may, if satisfied, after making such verifications as it may consider necessary that the`
  line `reasons for failure to deposit the notes within the period specified in the notification referred to in section 3, are`
  line `genuine, credit the value of the notes in his Know Your Customer compliant bank account in such manner as`
  line `may be specified by it.`
  line
  line `(3) Any person, aggrieved by the refusal of the Reserve Bank to credit the value of the notes under`
  line `sub-section (2), may make a representation to the Central Board of the Reserve Bank within fourteen`
  line `days of the communication of such refusal to him.`
  line
  line `Explanation.—For the purposes of this section, the expression "Know Your Customer compliant bank`
  line `account" means the account which complies with the conditions specified in the regulations made by the`
  line `Reserve Bank under the Banking Regulation Act, 1949 (10 of 1949).`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (4732)
  sectionNo (5)
  orderNo 5
  title `Prohibition on holding transferring or receiving specified bank notes.`
  content obj_root_law_sections_5_content
  footnotes `1. Ins. by Notification No. S.O. 4149(E) dated 24th August 2018 (w.e.f. 24-8-2018)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4732&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_5_content:
  string
  line `On and from the`
  line `appointed day, no person shall, knowingly or voluntarily, hold, transfer or receive any specified bank`
  line `note:`
  line
  line `Provided that nothing contained in this section shall prohibit the holding of specified bank notes—`
  line
  line `(a) by any person—`
  line
  line `(i) up to the expiry of the grace period; or`
  line
  line `(ii) after the expiry of the grace period,—`
  line
  line `(A) not more than ten notes in total, irrespective of the denomination; or`
  line
  line `(B) not more than twenty-five notes for the purposes of study, research or numismatics;`
  line
  line `(b) by the Reserve Bank or its agencies, or any other person authorised by the Reserve Bank;`
  line
  line `(c) by any person on the direction of a court in relation to any case pending in the court.`
  line
  line `^1[(d) by the law enforcement agencies, such as the Central Board of Direct Taxes, Central`
  line `Board of Indirect Taxes and Enforcement Directorate on production of the documents authorising`
  line `such seizure or confiscation, as the case may be.]`
obj_root_law_sections_6:
  sectionId (4733)
  sectionNo (6)
  orderNo 6
  title `Penalty for contravention of section 4.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4733&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_6_content:
  string
  line `Whoever knowingly and wilfully makes any`
  line `declaration or statement specified under sub-section (1) of section 4, which is false in material`
  line `particulars, or omits to make a material statement, or makes a statement which he does not believe to be`
  line `true, shall be punishable with fine which may extend to fifty thousand rupees or five times the amount`
  line `of the face value of the specified bank notes tendered, whichever is higher.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (4734)
  sectionNo (7)
  orderNo 7
  title `Penalty for contravention of section 5.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4734&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_7_content:
  string
  line `Whoever contravenes the provisions of section 5 shall`
  line `be punishable with fine which may extend to ten thousand rupees or five times the amount of the face`
  line `value of the specified bank notes involved in the contravention, whichever is higher.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (4735)
  sectionNo (8)
  orderNo 8
  title `Offences by companies.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4735&sectionno=8&orderno=8&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_8_content:
  string
  line `(1) Where a person committing a contravention or default referred to in`
  line `section 6 or section 7 is a company, every person who, at the time the contravention or default was`
  line `committed, was in charge of, and was responsible to, the company for the conduct of the business of the`
  line `company, as well as the company, shall be deemed to be guilty of the contravention or default and shall be`
  line `liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to punishment if`
  line `he proves that the contravention or default was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the contravention or default.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the same was committed with the consent or connivance`
  line `of, or is attributable to any neglect on the part of, any director, manager, secretary, or other officer or`
  line `employee of the company, such director, manager, secretary, other officer or employee shall also be`
  line `deemed to be guilty of the offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.—For the purpose of this section,—`
  line
  line `(a) “a company” means any body corporate and includes a firm, a trust, a co-operative society`
  line `and other association of individuals;`
  line
  line `(b) “director”, in relation to a firm or trust, means a partner in the firm or a beneficiary in the`
  line trust.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (4736)
  sectionNo (9)
  orderNo 9
  title `Special provisions relating to offences.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4736&sectionno=9&orderno=9&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_9_content:
  string
  line `Notwithstanding anything contained in section 29`
  line `of the Code of Criminal Procedure, 1973 (2 of 1974), the court of a Magistrate of the First Class or`
  line `the court of a Metropolitan Magistrate may impose a fine, for contravention of the provisions of this`
  line Act.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (4737)
  sectionNo (10)
  orderNo 10
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4737&sectionno=10&orderno=10&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_10_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Government, the Reserve Bank or any of their officers for anything done or intended to`
  line `be done in good faith under this Act.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (4738)
  sectionNo (11)
  orderNo 11
  title `Power to make rules.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4738&sectionno=11&orderno=11&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_11_content:
  string
  line `(1) The Central Government may, by notification, make rules for`
  line `carrying out the provisions of this Act.`
  line
  line `(2) Every rule made under this Act shall be laid, as soon as may be after it is made, before each House`
  line `of Parliament while it is in session for a total period of thirty days which may be comprised in one session`
  line `or in two or more successive sessions, and if, before the expiry of the session immediately following the`
  line `session or the successive sessions aforesaid, both Houses agree in making any modification in the rule or`
  line `both Houses agree that the rule should not be made, the rule shall thereafter have effect only in such`
  line `modified form or be of no effect, as the case may be; so, however, that any such modification or annulment`
  line `shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (4739)
  sectionNo (12)
  orderNo 12
  title `Power to remove difficulties.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4739&sectionno=12&orderno=12&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_12_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act, as may appear to it to be necessary or expedient for`
  line `removing the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of a period of two years`
  line `from the date of commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (4740)
  sectionNo (13)
  orderNo 13
  title `Repeal and savings.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00054_201702_1517807327901&sectionId=4740&sectionno=13&orderno=13&orgactid=AC_CEN_2_11_00054_201702_1517807327901
obj_root_law_sections_13_content:
  string
  line `(1) The Specified Bank Notes (Cessation of Liabilities) Ordinance, 2016`
  line `(Ord. 10 of 2016) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall`
  line `be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
