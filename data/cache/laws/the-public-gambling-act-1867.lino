obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `सार्वजनिक द्यु त अनिनियम, 1867`
  line _________
  line `िाराओं का क्र म`
  line _________
  line `ि ााराएं`
  line उद्देनिका।
  line `1. निर्वचि खण्ड।`
  line `2. अनिनियम का नर्स्ता र करिे की िनत।`
  line `3. जुआ घर का स् र् ा मी होिे या उसे चलािे या उसका भारसािक होिे के नलए िानस्त।`
  line `4. जुआ घर में पाए जािे के नलए िानस्त।`
  line `5. प्रर्े ि करिे और पुनलस को प्रर्े ि और तलािी के नलए प्र ानिकृत करिे की िनत।`
  line `6. संदिग्ि घरों में तािों आदि के पाए जािे का इस बात का साक्ष्य होिा दक ऐसे घर सामान्य जुआ घर हैं।`
  line `7. निरफ्तार दकए िए लोिों पर नमथ्या िाम और पते िेिे के नलए िानस्त।`
  line `8. जु आ घर चलािे के नलए िोषनसनि पर जुए के उपकरणों का िष्ट दकया जािा।`
  line `9. िार्े के नलए खेलिे का सबूत अिार्श्य क।`
  line `10. मनजस्रे ट का दकसी पकडे िए व् य नत से िपथ लेिे और साक्ष्य िेिे की अपेक्षा कर सकिा।`
  line `11. सानक्षयों का पररत्राण।`
  line `12. अनिनियम का कनतपय खेलों को लािू ि होिा।`
  line `13. सार्वजनिक मािों में जुआ खेलिा और पनक्षयों और पिुओं को लडिे के नलए छोडिा।`
  line `14. अपरािों का नजिके द्व ारा नर्चारणी य होिा।`
  line `15. पश्चा त्र् ती अपराि के नलए िानस्त।`
  line `16. जुमाविे के एक भाि का इनिला िेिे र् ाले को संिि दकया जा सकिा।`
  line `17. जुमाविों की र् सूली और उपयोजि।`
  line `18. इस इस अनिनियम के अिीि अपराि िण्ड संनहता के अथव के भीतर “ अपराि ” होंिे।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
