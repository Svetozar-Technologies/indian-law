obj_root_law_sections_1:
  sectionId (26798)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26798&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Pondicherry (Alteration of`
  line `Name) Act, 2006.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st October, 2006, vide notification No. S.O. 1627(E), dated, 28th September, 2006, see Gazette of India, Extraordinary, Part`
  line `II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (26799)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26799&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "appointed day" means the date appointed under sub-section (2) of section 1 for the coming`
  line `into force of this Act;`
  line
  line `(b) "appropriate Government" means the Central Government, and as respects a law relating to a`
  line `matter enumerated in the State List or the Concurrent List in the Seventh Schedule to the Constitution`
  line `in so far as any such matter is applicable in relation to the Union territory of Puducherry, also the`
  line `administrator of the Union territory of Puducherry;`
  line
  line `(c) "law" includes any enactment, Ordinance, regulation, order, bye-law, rule, scheme,`
  line `notification or other instrument having the force of law in the whole or any part of the Union territory`
  line `of Pondicherry.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (26800)
  sectionNo (3)
  orderNo 3
  title `Alteration of name of the Union territory of Pondicherry.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26800&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_3_content:
  string
  line `As from the appointed day, the`
  line `Union territory of Pondicherry shall be known as the Union territory of Puducherry.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (26801)
  sectionNo (4)
  orderNo 4
  title `Amendment of Part VIII of the Constitution.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26801&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_4_content:
  string
  line `In Part VIII of the Constitution, for the word`
  line `“Pondicherry”, wherever it occurs, the word “Puducherry” shall be substituted.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (26802)
  sectionNo (5)
  orderNo 5
  title `Amendment of First Schedule to the Constitution.`
  content `In the First Schedule to the Constitution, under the heading “II. THE UNION TERRITORIES”, in entry 6, under the column “Name”, for the word “Pondicherry”, the word “Puducherry” shall be substituted.`
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26802&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (26803)
  sectionNo (6)
  orderNo 6
  title `Amendment of Fourth Schedule to the Constitution.`
  content `In the Fourth Schedule to the Constitution, under the heading “TABLE”, in entry 30, in the second column, for the word “Pondicherry” the word “Puducherry” shall be substituted.`
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26803&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (26804)
  sectionNo (7)
  orderNo 7
  title `Amendment of section 2 of Act 20 of 1963.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26804&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_7_content:
  string
  line `In the Government of Union Territories Act, 1963,`
  line `in section 2, in sub-section (1), in clause (h), for the word “Pondicherry”, the word “Puducherry” shall be substituted.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (26805)
  sectionNo (8)
  orderNo 8
  title `Power to adapt laws.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26805&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_8_content:
  string
  line `(1) For the purpose of giving effect to the alteration of the name of the`
  line `Union territory of Pondicherry by section 3, the appropriate Government may, before the expiration of`
  line `one year from the appointed day, by order, make such adaptations and modifications of any law made`
  line `before the appointed day, whether by way of repeal or amendment, as may be necessary or expedient, and`
  line `thereupon every such law shall have effect subject to the adaptations and modifications so made.`
  line
  line `(2) Nothing in sub-section (1) shall be deemed to prevent Parliament or Legislative Assembly of the`
  line `Union territory of Puducherry or other competent authority from repealing or amending any law adapted`
  line `or modified by the appropriate Government under the said sub-section.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (26806)
  sectionNo (9)
  orderNo 9
  title `Power to construe laws.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26806&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_9_content:
  string
  line `Notwithstanding that no provision or insufficient provision has been`
  line `made under section 8 for the adaptation of a law made before the appointed day, any court, tribunal or`
  line `authority, required or empowered to enforce such law, may construe the law in such manner, without affecting the substance, as may be necessary or proper in regard to the matter before the court, tribunal or`
  line authority.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (26807)
  sectionNo (10)
  orderNo 10
  title `Legal proceedings.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00038_200644_1517807323490&sectionId=26807&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00038_200644_1517807323490
obj_root_law_sections_10_content:
  string
  line `Where immediately before the appointed day any legal proceedings are`
  line `pending to which the administrator of the Union territory of Pondicherry is a party, or the Union of India`
  line `represented by the said administrator is a party, then, for the purposes of those proceedings, any reference`
  line `to the administrator of the Union territory of Pondicherry shall be construed as a reference to the`
  line `administrator of the Union territory of Puducherry.`
obj_root_law_sections_10_footnotes:
  string
  line
