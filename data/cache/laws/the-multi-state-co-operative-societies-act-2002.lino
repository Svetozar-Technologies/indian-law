obj_root_law_sections_1:
  sectionId (1564)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1564&sectionno=1&orderno=1&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Multi-State Co-operative`
  line `Societies Act, 2002.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act and any`
  line `reference in any such provision to the commencement of this Act shall be construed as a reference to the`
  line `coming into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1 19th August, 2002, vide notification No. G.S.R. 571(E), dated 16th August, 2002, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (1565)
  sectionNo (2)
  orderNo 2
  title Application.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1565&sectionno=2&orderno=2&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_2_content:
  string
  line `This Act shall apply to--`
  line
  line `(a) all co-operative societies, with objects not confined to one State which were incorporated`
  line `before the commencement of this Act,--`
  line
  line `(i) under the Co-operative Societies Act, 1912 (2 of 1912), or`
  line
  line `(ii) under any other law relating to co-operative societies in force in any State or in pursuance`
  line `of the Multi-unit Co-operative Societies Act, 1942 (6 of 1942) or the Multi-State Co-operative`
  line `Societies Act, 1984 (51 of 1984),`
  line
  line `and the registration of which has not been cancelled before such commencement; and`
  line
  line `(b) all multi-State co-operative societies.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (1566)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1566&sectionno=3&orderno=3&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "area of operation" means the area from which the persons are admitted as members;`
  line
  line `(b) "board" means the board of directors or the governing body of a multi-State co-operative`
  line `society, by whatever name called, to which the direction and control of the management of the affairs`
  line `of the society is entrusted;`
  line
  line `(c) "bye-laws" means the bye-laws for the time being in force which have been duly registered or`
  line `deemed to have been registered under this Act and includes amendments thereto which have been`
  line `duly registered or deemed to have been registered under this Act;`
  line
  line `(d) "Central Registrar" means the Central Registrar of Co-operative Societies appointed under`
  line `sub-section (1) of section 4 and includes any officer empowered to exercise the powers of the Central`
  line `Registrar under sub-section (2) of that section;`
  line
  line `(e) "Chief Executive" means a Chief Executive of a multi-State co-operative society appointed`
  line `under section 51;`
  line
  line `(f) "co-operative bank" means a multi-State co-operative society which undertakes banking`
  line business;
  line
  line `(g) "co-operative principles" means the co-operative principles specified in the First Schedule;`
  line
  line `(h) "co-operative society" means a society registered or deemed to be registered under any law`
  line `relating to co-operative societies for the time being in force in any State;`
  line
  line `(i) "co-operative year", in relation to any multi-State co-operative society or class of such`
  line `societies, means the year ending on the 31st day of March of the year and where the accounts of such`
  line `society or class of such societies are, with the previous sanction of the Central Registrar, balanced on`
  line `any other day, the year ending on such day;`
  line
  line `(j) "Deposit Insurance Corporation" means the Deposit Insurance and Credit Guarantee`
  line `Corporation established under section 3 of the Deposit Insurance Corporation Act, 1961 (47 of 1961);`
  line
  line `(k) "federal co-operative" means a federation of co-operative societies registered under this Act`
  line `and whose membership is available only to a co-operative society or a multi-State co-operative`
  line society;
  line
  line `(l) "general body", in relation to a multi-State co-operative society, means all the members of`
  line `that society and in relation to a national co-operative society or a federal co-operative means all the`
  line `delegates of member co-operative societies or delegates of multistate co-operative societies and`
  line `includes a body constituted under the first proviso to sub-section (1) of section 38;`
  line
  line `(m) "general meeting" means a meeting of the general body of a multistate co-operative societies`
  line `and includes special general meeting;`
  line
  line `(n) "member" means a person joining in the application for the registration of a multi-State cooperative`
  line `society and includes a person admitted to membership after such registration in accordance`
  line `with the provisions of this Act, the rules and the byelaws;`
  line
  line `(o) "member co-operative" means a co-operative society or a multistate co-operative society`
  line `which is member of a federal co-operative ;`
  line
  line `(p) "multi-State co-operative society" means a society registered or deemed to be registered under`
  line `this Act and includes a national co-operative society and a Federal co-operative ;`
  line
  line `(q) "multi-State co-operative society with limited liability" means a society having the liability of`
  line `its members limited by its bye-laws to the amount, if any, unpaid on the shares, respectively, held by`
  line `them or to such amount as they may, respectively, thereby undertake to contribute to the assets of the`
  line `society, in the event of its being wound up;`
  line
  line `(r) "national co-operative society" means a multi-State co-operative society specified in the`
  line `Second Schedule;`
  line
  line `(s) "notification" means a notification published in the Official Gazette;`
  line
  line `(t) "officer" means a president, vice-president, chairperson, vice-chairperson, managing director,`
  line `secretary, manager, member of a board, treasurer, liquidator, an administrator appointed under section`
  line `123 and includes any other person empowered under this Act or the rules or the bye-laws to give`
  line `directions in regard to the business of a multi-State co-operative society;`
  line
  line `(u) "prescribed" means prescribed by rules;`
  line
  line `(v) "Reserve Bank" means the Reserve Bank of India constituted under the Reserve Bank of India`
  line `Act, 1934 (2 of 1934);`
  line
  line `(w) "rules" means the rules made under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (1567)
  sectionNo (4)
  orderNo 4
  title `Central Registrar.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1567&sectionno=4&orderno=4&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_4_content:
  string
  line `(1) The Central Government may appoint a person to be the Central Registrar`
  line `of Co-operative Societies and may appoint such other persons as it may think fit to assist the Central`
  line Registrar.
  line
  line `(2) The Central Government may, by notification, direct that any power exercisable by the Central`
  line `Registrar under this Act (other than the power of registration of a multi-State co-operative society) shall,`
  line `in relation to such society, and such matters as may be specified in the notification, be exercisable also by`
  line `any other officer of the Central Government or of a State Government as may be authorised by the`
  line `Central Government subject to such conditions as may be specified therein:`
  line
  line `Provided that no officer of a state government shall be empowered to exercise such power in relation`
  line `to a national co-operative society.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (1568)
  sectionNo (5)
  orderNo 5
  title `Multi-State co-operative societies which may be registered.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1568&sectionno=5&orderno=5&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_5_content:
  string
  line `(1) No multi-State co-operative`
  line `society shall be registered under this Act, unless,--`
  line
  line `(a) its main objects are to serve the interests of members in more than one state; and`
  line
  line `(b) its bye-laws provide for social and economic betterment of its members through self-help and`
  line `mutual aid in accordance with the co-operative principles.`
  line
  line `(2) The word "limited" or its equivalent in any Indian language shall be suffixed to the name of every`
  line `multi-State co-operative society registered under this Act with limited liability.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (1569)
  sectionNo (6)
  orderNo 6
  title `Application for registration.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1569&sectionno=6&orderno=6&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_6_content:
  string
  line `(1) For the purposes of registration of a multi-State co-operative`
  line `society under this Act, an application shall be made to the Central Registrar in such form and with such`
  line `particulars as may be prescribed.`
  line
  line `(2) The application shall be signed,--`
  line
  line `(a) in the case of a multi-State co-operative society of which all the members are individuals, by`
  line `at least fifty persons from each of the state concerned;`
  line
  line `(b) in the case of a multi-State co-operative society of which the members are co-operative`
  line `societies, by duly authorised representatives on behalf of at least five such societies as are not`
  line `registered in the same state; and`
  line
  line `(c) in the case of a multi-State co-operative society of which another multi-State co-operative`
  line `society and other co-operative societies are members, by duly authorised representatives of each of`
  line `such societies:`
  line
  line `Provided that not less than two of the co-operative societies referred to in this clause, shall be`
  line `such as are not registered in the same state;`
  line
  line `(d) in the case of a multi-State co-operative society of which the members are co-operative`
  line `societies or multi-State co-operative societies and individuals, by at least--`
  line
  line `(i) fifty persons, being individuals, from each of the two states or more; and`
  line
  line `(ii) one co-operative society each from two states or more or one multi-State co-operative`
  line society.
  line
  line `(3) The application shall be accompanied by four copies of the proposed bye-laws of the multi-State`
  line `co-operative society and the persons by whom or on whose behalf such application is made shall furnish`
  line `such information in regard to the society as the Central Registrar may require.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (1570)
  sectionNo (7)
  orderNo 7
  title Registration.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1570&sectionno=7&orderno=7&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_7_content:
  string
  line `(1) If the Central Registrar is satisfied--`
  line
  line `(a) that the application complies with the provisions of this Act and the rules;`
  line
  line `(b) that the proposed multi-State co-operative society satisfies the basic criterion that its objects`
  line `are to serve the interests of members in more than one state;`
  line
  line `(c) that its bye-laws provide for social and economic betterment of its members through self-help`
  line `and mutual aid in accordance with the co-operative principles;`
  line
  line `(d) that the proposed bye-laws are not contrary to the provision of this Act and the rules,`
  line
  line `he may register the multi-State co-operative society and its bye-laws.`
  line
  line `(2) The application for registration shall be disposed of by the Central Registrar within a period of`
  line `four months from the date of receipt thereof by him.`
  line
  line `(3) Where the Central Registrar refuses to register a multi-State co-operative society, he shall`
  line `communicate, within a period of four months from the date of receipt of the application for registration, the order of refusal together with the reasons therefor to the applicant or applicants, as the case may be:`
  line
  line `Provided that no order or refusal shall be made unless the applicants have been given a reasonable`
  line `opportunity of being heard:`
  line
  line `Provided further that if the application for registration is not disposed of within a period of four`
  line `months specified in sub-section (2) or the Central Registrar fails to communicate the order of refusal`
  line `within that period, the application shall be deemed to have been accepted for registration and the Central`
  line `Registrar shall issue the registration certificate in accordance with the provisions of this Act and the rules`
  line `made thereunder.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (1571)
  sectionNo (8)
  orderNo 8
  title `Registration certificate.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1571&sectionno=8&orderno=8&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_8_content:
  string
  line `Where a multi-State co-operative society is registered under this Act,`
  line `the Central Registrar shall issue a certificate of registration signed by him, which shall be conclusive`
  line `evidence that the society therein mentioned is duly registered under this Act, unless it is proved that the`
  line `registration of the society has been cancelled.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (1572)
  sectionNo (9)
  orderNo 9
  title `Multi-State co-operative society to be body corporate.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1572&sectionno=9&orderno=9&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_9_content:
  string
  line `(1) The registration of a multi-State cooperative`
  line `society shall render it a body corporate by the name under which it is registered having`
  line `perpetual succession and a common seal, and with power to acquire, hold and dispose of property, both`
  line `movable and immovable, enter into contract, institute and defend suits and other legal proceedings and to`
  line `do all things necessary for the purpose for which it is constituted, and shall, by the said name, sue or be`
  line sued.
  line
  line `(2) All transactions entered into in good faith prior to the registration of a multi-State co-operative`
  line `society shall be deemed to be its transactions after registration for furtherance of the objects of its`
  line registration.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (1573)
  sectionNo (10)
  orderNo 10
  title `Bye-laws of multi-State co-operative societies.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1573&sectionno=10&orderno=10&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_10_content:
  string
  line `(1) Every multi-State co-operative society may`
  line `make its bye-laws consistent with the provisions of this Act and the rules made thereunder.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such bye-laws may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the name, address and area of operation of the society;`
  line
  line `(b) the objects of the society;`
  line
  line `(c) the services to be provided to its members;`
  line
  line `(d) the eligibility for obtaining membership;`
  line
  line `(e) the procedure for obtaining membership;`
  line
  line `(f) the conditions for continuing as member;`
  line
  line `(g) the procedure for withdrawal of membership;`
  line
  line `(h) the transfer of membership;`
  line
  line `(i) the procedure for expulsion from membership;`
  line
  line `(j) the rights and duties of the members;`
  line
  line `(k) the nature and amount of capital of the society;`
  line
  line `(l) the manner in which the maximum capital to which a single member can subscribe;`
  line
  line `(m) the sources from which the funds may be raised by the multistate co-operative society;`
  line
  line `(n) the purpose for which the funds may be applied;`
  line
  line `(o) the manner of allocation or disbursement of net profits of the multi-State co-operative society;`
  line
  line `(p) the constitution of various reserves;`
  line
  line `(q) the manner of convening general meetings and quorum thereof other than those provided`
  line `under this Act;`
  line
  line `(r) the procedure for notice and manner of voting, in general and other meetings;`
  line
  line `(s) the procedure for amending the bye-laws;`
  line
  line `(t) the number of members of the board not exceeding twenty-one;`
  line
  line `(u) the tenure, of directors, chairperson and other office bearers of the society, not exceeding five`
  line years;
  line
  line `(v) the procedure for removal of members of the board and for filling up of vacancies;`
  line
  line `(w) the manner of convening board meetings, its quorum, number of meetings in a year and venue`
  line `of such meetings;`
  line
  line `(x) the frequency of board meetings;`
  line
  line `(y) the powers and functions of the Chief Executive in addition to those provided under section`
  line 52;
  line
  line `(z) the manner of imposing the penalty;`
  line
  line `(za) the appointment, rights and duties of auditors and procedure for conduct of audit;`
  line
  line `(zb) the authorisation of officers to sign documents and to institute and defend suits and other`
  line `legal proceedings on behalf of the society;`
  line
  line `(zc) the terms on which a multi-State co-operative society may deal with persons other than`
  line members;
  line
  line `(zd) the terms on which a multi-State co-operative society may associate with other co-operative`
  line societies;
  line
  line `(ze) the terms on which a multi-State co-operative society may deal with organisation other than`
  line `co-operative societies;`
  line
  line `(zf) the rights, if any, which the multi-State co-operative society may confer on any other multiState`
  line `co-operative society or federal co-operative and the circumstances under which such rights may`
  line `be exercised by the federal co-operative;`
  line
  line `(zg) the procedure and manner for transfer of shares and interest in the name of a nominee in case`
  line `of death of a member;`
  line
  line `(zh) the educational and training programmes to be conducted by the multi-State co-operative`
  line society;
  line
  line `(zi) the principal place and other places of business of multi-State co-operative society;`
  line
  line `(zj) the minimum level of services, to be used by its members;`
  line
  line `(zk) any other matter which may be prescribed.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (1574)
  sectionNo (11)
  orderNo 11
  title `Amendment of bye-laws of a multi-State co-operative society.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1574&sectionno=11&orderno=11&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_11_content:
  string
  line `(1) No amendment of any`
  line `bye-law of a multi-State co-operative society shall be valid, unless such amendment has been registered`
  line `under this Act.`
  line
  line `(2) The amendment to the bye-laws of a multi-State co-operative society shall be made by a`
  line `resolution passed by a two-third majority of the members present and voting at general meeting of the`
  line society.
  line
  line `(3) No such resolution shall be valid unless fifteen clear days' notice of the proposed amendment has`
  line `been given to the members.`
  line
  line `(4) In every case in which a multi-State co-operative society proposes to amend its bye-laws, an`
  line `application to register such amendments shall be made to the Central Registrar together with--`
  line
  line `(a) a copy of the resolution referred to in sub-section (2);`
  line
  line `(b) a statement containing the particulars indicating--`
  line
  line `(i) the date of the general meeting at which the amendments to the bye-laws were made;`
  line
  line `(ii) the number of days notice given to convene the general meeting;`
  line
  line `(iii) the total number of members of the multi-State co-operative society;`
  line
  line `(iv) the quorum required for such meeting;`
  line
  line `(v) the number of members present at the meeting;`
  line
  line `(vi) the number of members who voted in such meeting;`
  line
  line `(vii) the number of members who voted in favour of such amendments to bye-laws;`
  line
  line `(c) a copy of the relevant bye-laws in force with the amendment proposed to be made together`
  line `with reasons justifying such amendments;`
  line
  line `(d) four copies of the text of the bye-laws incorporating therein the proposed amendments signed`
  line `by the officer duly authorised in this behalf by the general body;`
  line
  line `(e) a copy of the notice given to the members and the proposal to amend the bye-laws;`
  line
  line `(f) a certificate signed by the person who presided at the general meeting certifying that the`
  line `procedure specified in sub-sections (2) and (3) and the bye-laws had been followed;`
  line
  line `(g) any other particular which may be required by the Central Registrar in this behalf.`
  line
  line `(5) Every such application shall be made within sixty days from the date of the general meeting at`
  line `which such amendment to the byelaws was passed.`
  line
  line `(6) The procedure given in sub-sections (2) to (5) of this section shall apply to the amendment of the`
  line `bye-laws of a co-operative society desiring to convert itself into a multi-State co-operative society as per`
  line `the provisions of section 22.`
  line
  line `(7) If, on receipt of application under sub-section (5), the Central Registrar is satisfied that the`
  line `proposed amendment--`
  line
  line `(a) is not contrary to the provisions of this Act or of the rules;`
  line
  line `(b) does not conflict with co-operative principles; and`
  line
  line `(c) will promote the economic interests of the members of the multistate co-operative society,`
  line
  line `he may register the amendment within a period of three months from the date of receipt thereof by him.`
  line
  line `(8) The Central Registrar shall forward to the multi-State co-operative society a copy of the registered`
  line `amendment together with a certificate signed by him within a period of one month from the date of`
  line `registration thereof and such certificate shall be conclusive evidence that the amendment has been duly`
  line registered.
  line
  line `(9) Where the Central Registrar refuses to register an amendment of the bye-laws of a multi-State cooperative`
  line `society, he shall communicate the order of refusal together with the reasons therefor to the`
  line `Chief Executive of the society in the manner prescribed within fifteen days from the date of such refusal:`
  line
  line `Provided that if the application for registration is not disposed of within a period of three months`
  line `specified in sub-section (7) or the Central Registrar fails to communicate the order of refusal within that`
  line `period, the application shall be deemed to have been accepted for registration and the Central Registrar`
  line `shall issue registration certificate in accordance with the provisions of this Act.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (1575)
  sectionNo (12)
  orderNo 12
  title `When amendment of bye-laws comes into force.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1575&sectionno=12&orderno=12&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_12_content:
  string
  line `An amendment of the bye-laws of a multiState`
  line `co-operative society shall, unless it is expressed to come into operation on a particular day, come`
  line `into force on the day on which it is registered.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (1576)
  sectionNo (13)
  orderNo 13
  title `Change of name.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1576&sectionno=13&orderno=13&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_13_content:
  string
  line `(1) A multi-State co-operative society may, by an amendment of its byelaws,`
  line `change its name but such change shall not affect any right or obligation of the multi-State co-operative`
  line `society or of any of its members or past members, and any legal proceedings which might have been`
  line `continued or commenced by or against the multi-State co-operative society by its former name, may be`
  line `continued or commence by or against its new name.`
  line
  line `(2) Where a multi-State co-operative society changes its name, the Central Registrar shall enter the`
  line `new name on the register of multistate co-operative society in place of former name and shall amend the`
  line `certificate of registration accordingly.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (1577)
  sectionNo (14)
  orderNo 14
  title Address.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1577&sectionno=14&orderno=14&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_14_content:
  string
  line `^1[Address].--Every multi-State co-operative society shall have principal place of business and an`
  line `^2[address, including e-mail address registered in the manner prescribed to which all notices and`
  line `communications may be sent.`
obj_root_law_sections_14_footnotes:
  string
  line `1. Subs. by Act 11 of 2023, s. 5, for "Change of address" (w.e.f. 3-8-2023).`
  line
  line `2. Subs. by s. 5, ibid., for "address" (w.e.f. 3-8-2023).`
obj_root_law_sections_15:
  sectionId (1578)
  sectionNo (15)
  orderNo 15
  title `Publication of name by multi-State co-operative society.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1578&sectionno=15&orderno=15&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_15_content:
  string
  line `Every multi-State co-operative`
  line society--
  line
  line `(a) shall paint or affix its name and the address of its registered office and keep the same painted`
  line `or affixed, on the outside of every office or place in which its business is carried on, in conspicuous`
  line `position, in letters easily legible; and if the characters employed therefor are not those of the`
  line `language, or of one of the languages in general use in that locality, also in the characters of that`
  line `language or of one of those languages;`
  line
  line `(b) shall have its name engraven in legible characters on its seal; and`
  line
  line `(c) shall have its name and the address of its registered office mentioned in legible characters in`
  line `all its business letters, in all its bill heads and letter paper, and in all its notices and other official`
  line `publications; and also have its name so mentioned in all bills of exchange, hundies, promissory notes,`
  line `endorsements, cheques and orders for money or goods purporting to be signed by or on behalf of the`
  line `multi-State co-operative society, and in all bills of parcels, invoices, receipts and letters of credit of`
  line `the multi-State co-operative society.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (1579)
  sectionNo (16)
  orderNo 16
  title Liability.
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1579&sectionno=16&orderno=16&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_16_content:
  string
  line `(1) No multi-State co-operative society with unlimited liability shall be registered`
  line `after the commencement of this Act:`
  line
  line `Provided that where a multi-State co-operative society with unlimited liability was functioning before`
  line `the commencement of this Act, such a society shall exercise the option within a period of one year from`
  line `such commencement either to continue to function as such or to convert itself into a multi-State cooperative`
  line `society with limited liability by following the procedure specified in sub-sections (2) to (4).`
  line
  line `(2) Subject to the provisions of this Act and the rules, a multi-State co-operative society may, by an`
  line `amendment of its bye-laws, change the extent of its liability.`
  line
  line `(3) When a multi-State co-operative society has passed a resolution to change the extent of its`
  line `liability, it shall give notice thereof in writing to all its members and creditors, and, notwithstanding`
  line `anything contained in the bye-laws or contract to the contrary, any member or creditor shall, during the`
  line `period of one month from the date of service of the notice upon him, have the option of withdrawing his`
  line `shares, deposits or loans, as the case may be.`
  line
  line `(4) Any member or creditor who does not exercise his option within the period specified in subsection`
  line `(3) shall be deemed to have assented to the change.`
  line
  line `(5) An amendment of a bye-law of a multi-State co-operative society changing the extent of its`
  line `liability shall not be registered or shall not take effect until either--`
  line
  line `(a) the assent thereto of all members and creditors has been obtained; or`
  line
  line `(b) all claims of members and creditors who exercise the option referred to in sub-section (3)`
  line `within the period specified therein have been met in full or otherwise satisfied.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (1580)
  sectionNo (17)
  orderNo 17
  title `Amalgamation or transfer of assets and liabilities, or division of multi-State co-operative societies.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1580&sectionno=17&orderno=17&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_17_content:
  string
  line `(1) A multi-State co-operative society may, by a resolution passed by a majority of not less`
  line `than two-thirds of the members, present and voting at a general meeting of the society held for the`
  line purpose,--
  line
  line `(a) transfer its assets and liabilities in whole or in part to any other multi-State co-operative`
  line `society or co-operative society;`
  line
  line `(b) divide itself into two or more multi-State co-operative societies;`
  line
  line `(c) divide itself into two or more co-operative societies.`
  line
  line `(2) Any two or more multi-State co-operative societies may, by a resolution passed by a majority of`
  line `not less than two-thirds of the members present and voting at a general meeting of each such society,`
  line `amalgamate themselves and form a new multi-State co-operative society.`
  line
  line `(3) The resolution of a multi-State co-operative society under sub-section (1) or sub-section (2) shall`
  line `contain all particulars of the transfer or division or amalgamation, as the case may be.`
  line
  line `(4) When a multi-State co-operative society has passed a resolution under sub-section (1) or subsection`
  line `(2), it shall give notice thereof in writing to all the members and creditors, and, notwithstanding anything contained in the bye-laws or contract to the contrary, any member or creditor shall, during the`
  line `period of one month of the date of service of the notice upon him, have the option of withdrawing his`
  line `share, deposits or loans, as the case may be.`
  line
  line `(5) Any member or creditor who does not exercise his option within the period specified in subsection`
  line `(4) shall be deemed to have assented to the proposals contained in the resolution.`
  line
  line `(6) (a) A resolution passed by a multi-State co-operative society under this section shall not take`
  line `effect until the assent thereto of all the members and creditors has been obtained.`
  line
  line `(b) The multi-State co-operative society shall make arrangements for meeting in full or otherwise`
  line `satisfying all claims of the members and creditors who exercise the option within the period specified in`
  line `sub-section (4).`
  line
  line `(7) On receipt of an application for the registration of new societies formed by division in accordance`
  line `with the resolution passed under sub-section (1) or of a new society formed by amalgamation in`
  line `accordance with the resolution passed under sub-section (2), the Central Registrar, on being satisfied that`
  line `the resolution has become effective under sub-section (6) shall, unless for reasons to be recorded in`
  line `writing he thinks fit to refuse so to do, Register the new society or societies, as the case may be, and the`
  line `bye-laws thereof.`
  line
  line `(8) On the issue of an order under sub-section (7), the provisions of section 21 shall, so far as may be,`
  line `apply to the multi-State co-operative society so divided or the multi-State co-operative societies so`
  line amalgamated.
  line
  line `(9) Where a resolution passed by a multi-State co-operative society under this section involves the`
  line `transfer of any assets and liabilities, the resolution shall, notwithstanding anything contained in any other`
  line `law for the time being in force, be a sufficient conveyance to vest the assets and liabilities in the`
  line `transferee without any further assurance.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (1581)
  sectionNo (18)
  orderNo 18
  title `Central Registrar to prepare scheme of amalgamation or reorganisation of a co-operative bank in certain cases.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1581&sectionno=18&orderno=18&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_18_content:
  string
  line `When an order of moratorium has been made by the Central Government under`
  line `sub-section (2) of section 45 of the Banking Regulation Act, 1949 (10 of 1949) in respect of a cooperative`
  line `bank, the Central Registrar, with the previous approval of the Reserve Bank in writing, may,`
  line `during the period of moratorium prepare a scheme--`
  line
  line `(a) for the amalgamation of the co-operative bank with any other co-operative bank; or`
  line
  line `(b) for the reorganisation of the co-operative bank.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (1582)
  sectionNo (19)
  orderNo 19
  title `Promotion of subsidiary institution.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1582&sectionno=19&orderno=19&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_19_content:
  string
  line `(1) Any multi-State co-operative society may, by a`
  line `resolution passed at general meeting by a majority of members present and voting, promote one or more`
  line `subsidiary institutions, which may be registered under any law for the time being in force, for the`
  line `furtherance of its stated objects.`
  line
  line `(2) Any subsidiary institution promoted under sub-section (1) shall exist only as long as general body`
  line `of the multi-State co-operative society deems its existence necessary:`
  line
  line `Provided that a multi-State co-operative society while promoting such a subsidiary institution, shall`
  line `not transfer or assign its substantive part of business or activities undertaken in furtherance of its stated`
  line objects.
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) an institution shall be deemed to be a subsidiary institution if the multi-State co-operative`
  line society--
  line
  line `(i) controls the management or board of directors or members of governing body of such`
  line `institution; or`
  line
  line `(ii) holds more than half in nominal value of equity shares of such institutions; or`
  line
  line `(iii) if one or more members of such multi-State co-operative society, hold whether by`
  line `themselves or together with subsidiary institution or their relatives, as the case may be, the`
  line `majority of equity shares in that institution;`
  line
  line `(b) a subsidiary institution shall not include a partnership firm.`
  line
  line `(3) The annual reports and accounts of any such subsidiary institution shall be placed each year`
  line `before general meeting of the promoting multi-State co-operative society.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (1583)
  sectionNo (20)
  orderNo 20
  title `Liability of a co-operative bank to Deposit Insurance and Credit Guarantee Corporation.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1583&sectionno=20&orderno=20&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_20_content:
  string
  line `Notwithstanding anything contained in section 17 or any other provision of this Act, where a co-operative`
  line `bank, being an insured bank within the meaning of the Deposit Insurance and Credit Guarantee`
  line `Corporation Act, 1961 (47 of 1961), is amalgamated or reorganised and the Deposit Insurance`
  line `Corporation has become liable to pay to the depositors of the insured bank under sub-section (2) of`
  line `section 16 of that Act, the bank with which such insured bank is amalgamated or the new co-operative`
  line `bank formed after such amalgamation, or, as the case may be, the insured bank or transferee bank shall be`
  line `under an obligation to repay to the Deposit Insurance Corporation in the circumstances, to the extent and`
  line `in the manner referred to in section 21 of the Deposit Insurance and Credit Guarantee Corporation Act,`
  line 1961.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (1584)
  sectionNo (21)
  orderNo 21
  title `Cancellation of registration certificate of multi-State co-operative societies in certain cases.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1584&sectionno=21&orderno=21&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_21_content:
  string
  line `(1) Where the whole of the assets and liabilities of a multi-State co-operative society are`
  line `transferred to another multi-State co-operative society or to a co-operative society in accordance with the`
  line `provisions of section 17, the registration of the first mentioned multi-State co-operative society shall stand`
  line `cancelled and the society shall be deemed to have been dissolved and shall cease to exist as a corporate`
  line body.
  line
  line `(2) Where two or more multi-State co-operative societies are amalgamated into a new multi-State cooperative`
  line `society in accordance with the provisions of section 17, the registration of each of the`
  line `amalgamating societies shall stand cancelled on the registration of the new society, and each of the`
  line `amalgamating societies shall be deemed to have been dissolved and shall cease to exist as a corporate`
  line body.
  line
  line `(3) Where a multi-State co-operative society divides itself into two or more multi-State co-operative`
  line `societies or two or more co-operative societies in accordance with the provisions of section 17, the`
  line `registration of that society shall stand cancelled on the registration of the new societies and that society`
  line `shall be deemed to have been dissolved and shall cease to exist as a corporate body.`
  line
  line `(4) The amalgamation or division of multi-State co-operative societies shall not in any manner`
  line `whatsoever affect any right or obligation of the resulting multi-State co-operative society or societies or`
  line `render defective any legal proceedings by or against the multi-State co-operative society or societies, and`
  line `any legal proceedings that might have been continued or commenced by or against the multistate cooperative`
  line `society or societies, as the case may be, before the amalgamation or division, may be continued`
  line `or commenced by or against the resulting multi-State co-operative society or societies.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (1585)
  sectionNo (22)
  orderNo 22
  title `Conversion of a co-operative society into a multi-State co-operative society.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1585&sectionno=22&orderno=22&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_22_content:
  string
  line `(1) A cooperative`
  line `society may, by an amendment of its bye-laws, extend its jurisdiction and convert itself into a`
  line `multi-State co-operative society:`
  line
  line `Provided that no such amendment of bye-laws of a co-operative society shall be valid unless it has`
  line `been registered by the Central Registrar.`
  line
  line `(2) (a) Every proposal for such amendment of bye-laws shall be forwarded to the Central Registrar in`
  line `accordance with the provisions contained in sub-section (4) of section 11.`
  line
  line `(b) If the Central Registrar, after consulting the Registrars of Co-operative Societies of the States`
  line `concerned, has satisfied himself that such amendment--`
  line
  line `(i) fulfils the requirements of the members being from more than one state;`
  line
  line `(ii) is in accordance with the provisions contained in sub-section (4) of section 11,`
  line
  line `he may register the amendment within a period of six months from the date of receipt thereof by him:`
  line
  line `Provided that no co-operative society shall be deemed to have been converted into a multi-State cooperative`
  line `society on any ground whatsoever unless such society is registered as a multi-State co-operative`
  line society.
  line
  line `(3) The Central Registrar shall forward to the co-operative society a copy of the registered`
  line `amendment together with a certificate signed by him and such certificate shall be conclusive evidence that`
  line `the amendment has been registered.`
  line
  line `(4) Where the Central Registrar refuses to register an amendment of the bye-laws or a co-operative`
  line `society, he shall communicate the order of refusal together with the reasons therefor to the society in the`
  line `manner prescribed within seven days from the date of refusal.`
  line
  line `(5)(a) Once the amendment of bye-laws has been registered by the Central Registrar, the co-operative`
  line `society shall, as from the date of registration of amendment, become a multi-State co-operative society.`
  line
  line `(b) The Central Registrar shall forward to the co-operative society a certificate signed by him to the`
  line `effect that such society has been registered as a multi-State co-operative society under this Act and also`
  line `forward a copy of the same to the Registrar of Co-operative Societies of the State concerned.`
  line
  line `(c) The Registrar of Co-operative Societies referred to in clause (b) shall thereupon make an order`
  line `directing that the society had, as from the date of registration by the Central Registrar, ceased to be a`
  line `society under the law relating to co-operative societies in force in that state.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (1586)
  sectionNo (23)
  orderNo 23
  title `Registration of federal co-operative.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1586&sectionno=23&orderno=23&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_23_content:
  string
  line `(1) Every federal co-operative shall obtain registration`
  line `certification in accordance with the provisions of this Act.`
  line
  line `(2) Every federal co-operative shall in its general meeting be represented by its member co-operative.`
  line
  line `(3) The classification of federal co-operative and other terms and conditions applicable to it shall be`
  line `such as may be prescribed.`
  line
  line `(4) All provisions of this Act, applicable to a multi-State co-operative society shall, as far as may be,`
  line `apply to a federal co-operative.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (1587)
  sectionNo (24)
  orderNo 24
  title `Functions of federal co-operative.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1587&sectionno=24&orderno=24&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_24_content:
  string
  line `(1) Subject to the provisions of this Act and any other law`
  line `for the time being in force, a federal co-operative may discharge the functions to facilitate the voluntary`
  line `formation and democratic functioning of co-operative societies as federal co-operative or multi-State cooperatives`
  line `based on self-help and mutual aid.`
  line
  line `(2) Without prejudice to the generality of the provisions contained in sub-section (1), the federal cooperative`
  line may--
  line
  line `(a) ensure compliance of the co-operative principles;`
  line
  line `(b) make model bye-laws and policies for consideration of its member co-operative;`
  line
  line `(c) provide specialised training, education and data-base information;`
  line
  line `(d) undertake research, evaluation and assist in preparation of perspective development plans for`
  line `its member co-operative;`
  line
  line `(e) promote harmonious relations amongst member co-operative;`
  line
  line `(f) help member co-operative to settle disputes among themselves;`
  line
  line `(g) undertake business services on behalf of its member co-operative, if specifically required by`
  line `or under the resolution of the general body or the board, or bye-laws of a member of co-operative;`
  line
  line `(h) provide management development services to a member co-operative;`
  line
  line `(i) evolve code of conduct for observance by a member co-operative;`
  line
  line `(j) evolve viability norms for a member co-operative;`
  line
  line `(k) provide legal aid and advice to a member co-operative;`
  line
  line `(l) assist member co-operative in organising self-help;`
  line
  line `(m) develop market information system logo brand promotion, quality control and technology`
  line upgradation.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (1588)
  sectionNo (25)
  orderNo 25
  title `Persons who may become members.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1588&sectionno=25&orderno=25&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_25_content:
  string
  line `(1) No person shall be admitted as a member of a multiState`
  line `co-operative society except the following, namely:--`
  line
  line `(a) an individual, competent to contract under section 11 of the Indian Contract Act, 1872 (9 of`
  line `1872);`
  line
  line `(b) any multi-State co-operative society or any co-operative society;`
  line
  line `(c) the Central Government;`
  line
  line `(d) a State Government;`
  line
  line `(e) the National Co-operative Development Corporation established under the National Cooperative`
  line `Development Corporation Act, 1962 (26 of 1962);`
  line
  line `(f) any other corporation owned or controlled by the Government;`
  line
  line `(g) any Government company as defined in section 617 of the Companies Act, 1956 (1 of 1956);`
  line
  line `(h) such class or classes or persons or association of persons as may be permitted by the Central`
  line `Registrar having regard to the nature and activities of a multi-State co-operative society.`
  line
  line `(2) No individual person shall be eligible for admission as a member of a national co-operative`
  line `society or a federal co-operative.`
  line
  line `(3) Any person eligible for membership of a multi-State co-operative society may, on his application,`
  line `be admitted as a member by such society.`
  line
  line `(4) Every application for admission as a member of a multi-State co-operative society shall be`
  line `disposed of by such society within a period of four months from the date of receipt of the application, and`
  line `the decision of such society on the application shall be communicated to the applicant within fifteen days`
  line `from the date of such decision:`
  line
  line `Provided that if the application is not disposed of within the period aforesaid, or the decision is not`
  line `communicated within a period of fifteen days of the expiry of the aforesaid period of four months, the`
  line `multi-State co-operative society shall be deemed to have made a decision, on the date of expiry of such`
  line `period, refusing admission to the applicant.`
  line
  line `(5) It shall be the duty of every member of a multi-State co-operative society to promote and protect`
  line `the interests and objects of such society.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (1589)
  sectionNo (26)
  orderNo 26
  title `Nominal or associate member of society.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1589&sectionno=26&orderno=26&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_26_content:
  string
  line `A multi-State co-operative society may, if provided`
  line `in its bye-laws, admit a person as nominal or associate member:`
  line
  line `Provided that no such nominal or associate member shall be entitled to subscribe the shares of such`
  line `society or have any interest in the management thereof including right to vote, elect as a director of the`
  line `board or participate in the general body meetings.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (1590)
  sectionNo (27)
  orderNo 27
  title `Educational course for members.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1590&sectionno=27&orderno=27&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_27_content:
  string
  line `(1) Every multi-State co-operative society shall organise cooperative`
  line `education programmes for its members, directors and employees.`
  line
  line `(2) Every multi-State co-operative society may provide funds for such co-operative education`
  line programmes.
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (1591)
  sectionNo (28)
  orderNo 28
  title `Members not to exercise rights till due payment made.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1591&sectionno=28&orderno=28&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_28_content:
  string
  line `No member of a multi-State cooperative`
  line `society shall exercise the rights of a member, unless he has made the payment to the society in`
  line `respect of membership, or has acquired such interest in the society, as may be specified in the bye-laws.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (1592)
  sectionNo (29)
  orderNo 29
  title `Disqualification for member of a multi-State co-operative society.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1592&sectionno=29&orderno=29&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_29_content:
  string
  line `No person shall be`
  line `eligible for being a member of a multi-State co-operative society if--`
  line
  line `(a) his business is in conflict or competitive with the business of such multi-State co-operative`
  line `society; or`
  line
  line `(b) he used for two consecutive years the services below the minimum level specified in the byelaws;`
  line or
  line
  line `(c) he has not attended three consecutive general meetings of the multi-State co-operative society`
  line `and such absence has not been condoned by the members in the general meeting; or`
  line
  line `(d) he has made any default in payment of any amount to be paid to the multi-State co-operative`
  line `society under the bye-laws of such society.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (1593)
  sectionNo (30)
  orderNo 30
  title `Expulsion of members.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1593&sectionno=30&orderno=30&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_30_content:
  string
  line `(1) A multi-State co-operative society may, by resolution passed by a`
  line `majority of not less than two-thirds of the members present and voting at a general meeting of members`
  line `held for the purpose, expel a member for acts which are detrimental to the proper working of the society:`
  line
  line `Provided that the member concerned shall not be expelled unless he has been given a reasonable`
  line `opportunity of making representation in the matter.`
  line
  line `(2) No member of the multi-State co-operative society, who has been expelled under sub-section (1),`
  line `shall be eligible for re-admission as a member of that society, for a period of one year from the date of`
  line `such expulsion.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (1594)
  sectionNo (31)
  orderNo 31
  title `Vote of members.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1594&sectionno=31&orderno=31&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_31_content:
  string
  line `Every member of a multi-State co-operative society, including a member`
  line `who is an employee of such society, shall have one vote in the affairs of the society:`
  line
  line `Provided that--`
  line
  line `(a) a member who is an employee of such society shall not be entitled to vote--`
  line
  line `(i) at the election of a member of the board of such society;`
  line
  line `(ii) in any general meeting convened for framing the bye-laws of such society or any`
  line `amendments thereto;`
  line
  line `(b) in the case of an equality of votes, the chairperson shall have a casting vote;`
  line
  line `(c) where any of the authorities, multi-State co-operative society or a co-operative society`
  line `referred to in clauses (b) to (g) of sub-section (1) of section 25 is a member of a multi-State cooperative`
  line `society, each person nominated by such authority or society, on the board in accordance`
  line `with the provisions contained in this Act and the rules, shall, have one vote;`
  line
  line `(d) a multi-State co-operative society, the membership of which include co-operative societies or`
  line `other multi-State co-operative society, may provide in its bye-laws for an equitable system of voting`
  line `having regard to the membership of, and the extent of business carried on by such co-operative`
  line `societies or multi-State co-operative societies.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (1595)
  sectionNo (32)
  orderNo 32
  title `Manner of exercising vote.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1595&sectionno=32&orderno=32&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_32_content:
  string
  line `Every member of a multi-State co-operative society shall exercise`
  line `his vote in person and no member shall be permitted to vote by proxy:`
  line
  line `Provided that a multi-State co-operative society or a co-operative society or any other institution`
  line `which is a member of any other multi-State co-operative society may, subject to the provisions of subsection`
  line `(3) of section 38 and the rules, appoint its representative to vote on its behalf in the affairs of such`
  line `multi-State co-operative society.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (1596)
  sectionNo (33)
  orderNo 33
  title `Restriction on holding of shares.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1596&sectionno=33&orderno=33&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_33_content:
  string
  line `No member, other than the authorities referred to in clauses`
  line `(c) to (g) of sub-section (1) of section 25 or a multi-State co-operative society or a co-operative society,`
  line `shall hold more than such portion of the total share capital of the society (in no case exceeding one-fifth`
  line `thereof) as may be prescribed in the rules or bye-laws of such multi-State co-operative society.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (1597)
  sectionNo (34)
  orderNo 34
  title `Restriction on transfer of shares or interest.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1597&sectionno=34&orderno=34&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_34_content:
  string
  line `The transfer of share or interest of a member in`
  line `the capital of a multi-State co-operative society shall be subject to such conditions as to maximum`
  line `holding as specified in section 33.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (1598)
  sectionNo (35)
  orderNo 35
  title `Redemption of shares.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1598&sectionno=35&orderno=35&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_35_content:
  string
  line `(1) Shares held in a multi-State co-operative society by any of the`
  line `authorities referred to in clauses (c) to (g) of sub-section (1) of section 25 shall be redeemable in`
  line `accordance with the bye-laws of such multi-State co-operative society and in a case where the byelaws do`
  line `not contain any provision in this regard, in such manner as may be agreed upon between the multi-State`
  line `co-operative society and such authority.`
  line
  line `(2) The redemption of shares referred to in sub-section (1) shall be on the face value of the shares.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (1599)
  sectionNo (36)
  orderNo 36
  title `Transfer of interest on death of members.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1599&sectionno=36&orderno=36&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_36_content:
  string
  line `(1) On the death of a member, a multi-State cooperative`
  line `society may transfer the share or interest of the deceased member to the person nominated in accordance with the bye-law made in this behalf or, if there is no person nominated, to such person as`
  line `may appear to the board to be the heir or legal representative of the deceased member, or pay to such`
  line `nominee, heir or legal representative, as the case may be, a sum representing the value of such member's`
  line `share or interest as ascertained in accordance with the rules:`
  line
  line `Provided that no such transfer or payment shall be made except with the consent of the nominee, heir`
  line `or legal representative, as the case may be.`
  line
  line `(2) A multi-State co-operative society shall, unless within six months of the death of the member`
  line `prevented by an order of a competent court, pay to such nominee, heir or legal representative, as the case`
  line `may be, all other moneys due to the deceased member from the society.`
  line
  line `(3) All transfers and payments made by a multi-State co-operative society in accordance with the`
  line `provisions of this section shall be valid and effectual against any demand made upon the society by any`
  line `other person.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (1600)
  sectionNo (37)
  orderNo 37
  title `Liabilities of past member and estate of deceased member.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1600&sectionno=37&orderno=37&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_37_content:
  string
  line `(1) Subject to the provisions of`
  line `sub-section (2), the liability of a past member or of the estate of a deceased member of a multi-State cooperative`
  line `society for the debts of the society as they existed,--`
  line
  line `(a) in the case of a past member, on the date on which he ceased to be a member;`
  line
  line `(b) in the case of a deceased member, on the date of his death,`
  line
  line `shall continue for a period of two years from such date.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where a multi-State co-operative society is`
  line `ordered to be wound up under section 86, the liability of a past member who ceased to be a member or of`
  line `the estate of a deceased member who died within two years immediately preceding the date of the order`
  line `of winding up, shall continue until the entire liquidation proceedings are completed, but such liability`
  line `shall extend only to the debts of the society as they existed on the date of cessation of membership or`
  line `death, as the case may be.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (1601)
  sectionNo (38)
  orderNo 38
  title `Constitution, powers and functions of general body.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1601&sectionno=38&orderno=38&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_38_content:
  string
  line `(1) The general body of a multi-State`
  line `co-operative society shall consist of all the members of such society:`
  line
  line `Provided that where the bye-laws of a multi-State co-operative society provide for the constitution of`
  line `a smaller body consisting of delegates of members of the society elected or selected in accordance with`
  line `such bye-laws, that smaller body shall exercise such powers of the general body as may be prescribed or`
  line `as may be specified in the bye-laws of the society.`
  line
  line `(2) Subject to the provisions of this Act, the rules and the bye-laws, the ultimate authority of a multiState`
  line `co-operative society shall vest in the general body of its members:`
  line
  line `Provided that nothing contained in this sub-section shall affect the exercise by the board or any`
  line `officer of a multi-State co-operative society of any power conferred on such board or such officer by this`
  line `Act or the rules or the bye-laws.`
  line
  line `(3) Where in any meeting of the general body or the board of a multistate co-operative society, a cooperative`
  line `society or another multi-State co-operative society is to be represented, such co-operative`
  line `society or other multi-State co-operative society shall be represented in such meeting only through the`
  line `Chairperson or the president or the Chief Executive or a member of the board of such co-operative society`
  line `or other multi-State co-operative society, as the case may be, if such member is so authorised by the board`
  line `and where there is no board of such co-operative society or other multi-State co-operative society, for`
  line `whatever reasons, through the administrator, by whatever name called, of such co-operative society or`
  line `other multistate co-operative society:`
  line
  line `Provided that where the bye-laws of a multi-State co-operative society provide for representation of`
  line `other institutions in any meeting of general body or the board of such multi-State co-operative society,`
  line `such institutions shall be represented through its nominee.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (1602)
  sectionNo (39)
  orderNo 39
  title `Annual general meeting of general body.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1602&sectionno=39&orderno=39&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_39_content:
  string
  line `(1) The board of every multi-State co-operative`
  line `society shall, within such period as may be prescribed, and not later than six months after the close of the`
  line `corresponding year, call the annual general meeting in the manner prescribed for the purpose of--`
  line
  line `(a) consideration of the audited statement of accounts;`
  line
  line `(b) consideration of the audit report and annual report;`
  line
  line `(c) consideration of audit compliance report;`
  line
  line `(d) disposal of net profits;`
  line
  line `(e) review of operational deficit, if any;`
  line
  line `(f) creation of specific reserves and other funds;`
  line
  line `(g) approval of the annual budget;`
  line
  line `(h) review of actual utilisation of reserve and other funds;`
  line
  line `(i) approval of the long-term perspective plan and the annual operational plan;`
  line
  line `(j) review of annual report and accounts of subsidiary institution, if any;`
  line
  line `(k) expulsion of members;`
  line
  line `(l) list of employees who are relatives of members of the board or of the Chief Executive;`
  line
  line `(m) amendment of bye-laws, if any;`
  line
  line `(n) formulation of code of conduct for the members of the board and officers;`
  line
  line `(o) election of members of the board, if any.`
  line
  line `(2) Where the board of a multi-State co-operative society fails to convene the annual general meeting`
  line `within the period specified in sub-section (1), the Central Registrar or the person authorised by him in this`
  line `behalf shall be competent to convene such annual general meeting within a period of ninety days from the`
  line `date of expiry of the period mentioned in that sub-section and the expenditure incurred on such meeting`
  line `shall be borne by the society.`
  line
  line `(3) At every annual general meeting of a multi-State co-operative society, the board shall lay before`
  line `the society a statement showing the details of the loans or goods on credit, if any, given to any of the`
  line `members of the board or to the spouse or a son or daughter of a member of the board during the preceding`
  line `year or outstanding against him or against such spouse or son or daughter of the member of the board.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (1603)
  sectionNo (40)
  orderNo 40
  title `Special general meeting of general body.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1603&sectionno=40&orderno=40&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_40_content:
  string
  line `(1) The Chief Executive may, at any time, on the`
  line `direction of the board, call a special general meeting of the society and shall call such meeting within one`
  line `month after the receipt of a requisition in writing from the Central Registrar or from such member or`
  line `members or a proportion of the total number of members, as may be provided in the bye-laws.`
  line
  line `(2) If a special general meeting of a multi-State co-operative society is not called in accordance with`
  line `the requisition referred to in subsection (1), the Central Registrar or any person authorised by him in this`
  line `behalf shall have the power to call such meeting and that meeting shall be deemed to be a meeting called`
  line `by the Chief Executive in accordance with the provisions of that sub-section and the Central Registrar`
  line `may order that the expenditure incurred in calling such meeting shall be paid out of the funds of the`
  line `society or by such person or persons who, in the opinion of the Central Registrar, was or were responsible`
  line `for the refusal or failure to convene the special general meeting.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (1604)
  sectionNo (41)
  orderNo 41
  title `Board of directors.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1604&sectionno=41&orderno=41&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_41_content:
  string
  line `(1) Subject to the provisions of this Act and rules, there shall be a board of`
  line `directors for every multi-State co-operative society consisting of such number of members as specified in`
  line `sub-section (3).`
  line
  line `(2) The members of a multi-State co-operative society, by a resolution in a general meeting, shall`
  line `elect directors who shall be members of board.`
  line
  line `(3) The board shall consist of such number of directors as may be specified in the bye-laws:`
  line
  line `Provided that the maximum number of directors in no case shall exceed twenty-one:`
  line
  line `Provided further that the board may co-opt two directors in addition to twenty-one directors specified`
  line `in the first proviso:`
  line
  line `Provided also that the functional directors in the national co-operative societies shall also be the`
  line `members of the board and such members shall be excluded for the purpose of counting the total number`
  line `of directors specified in the first proviso.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (1605)
  sectionNo (42)
  orderNo 42
  title `Association of employees in management decision making process.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1605&sectionno=42&orderno=42&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_42_content:
  string
  line `Every multi-State cooperative`
  line `society shall devise such procedure, as may be specified in the bye-laws or in the administrative`
  line `instructions of such society, for the association of the representatives of employees of such multi-State cooperative`
  line `societies at such level or bodies as may be specified in the bye-laws or the instructions issued in`
  line `this regard, in the management decision making process.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (1606)
  sectionNo (43)
  orderNo 43
  title `Disqualifications for being a member of board.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1606&sectionno=43&orderno=43&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_43_content:
  string
  line `(1) No member of any multi-State cooperative`
  line `society or nominee of a member, society or a national co-operative society shall be eligible for`
  line `being chosen as, or for being, a member of the board of such multi-State co-operative society or a national`
  line `co-operative society, or of any other co-operative society to which the multi-State co-operatives society is`
  line `affiliated, if such member--`
  line
  line `(a) has been adjudged by a competent court to be insolvent or of unsound mind;`
  line
  line `(b) is concerned or participates in the profits of any contract with the society;`
  line
  line `(c) has been convicted for an offence involving moral turpitude;`
  line
  line `(d) holds any office or place of profit under the society:`
  line
  line `Provided that the Chief Executive or such full time employee of the society as may be notified by the`
  line `Central Government from time to time or a person elected by the employees of such society to represent`
  line `them on the board of such society shall be eligible for being chosen as, or for being, a member of such`
  line board;
  line
  line `(e) has been a member of the society for less than twelve months immediately preceding the date`
  line `of such election or appointment;`
  line
  line `(f) has interest in any business of the kind carried on by the society of which he is a member;`
  line
  line `(g) has taken loan or goods on credit from the society of which he is a member, or is otherwise`
  line `indebted to such society and after the receipt of a notice of default issued to him by such society, has`
  line defaulted--
  line
  line `(i) in repayment of such loan or debt or in payment of the price of the goods taken on credit,`
  line `as the case may be, within the date fixed for such repayment or payment or where such date is`
  line `extended, which in no case shall exceed six months, within the date so extended, or`
  line
  line `(ii) when such loan or debt or the price of goods taken on credit is to be paid in instalments,`
  line `in payment of any instalment, and the amount in default or any part thereof has remained unpaid`
  line `on the expiry of six months from the date of such default:`
  line
  line `Provided that a member of the board who has ceased to hold office as such under this clause shall not`
  line `be eligible, for a period of one year, from the date on which he ceased to hold office, for re-election as a`
  line `member of the board of the multi-State co-operative society of which he was a member or for the election`
  line `to the board of any other multi-State co-operative society;`
  line
  line `(h) is a person against whom any amount due under a decree, decision or order is pending`
  line `recovery under this Act;`
  line
  line `(i) is retained or employed as a legal practitioner on behalf of or against the multi-State cooperative`
  line `society, or on behalf of or against any other multi-State co-operative society which is a`
  line `member of the former society.`
  line
  line `Explanation.--For the purposes of this clause, "legal practitioner" has the same meaning as in clause`
  line `(i) of sub-section (1) of section 2 of the Advocates Act, 1961 (25 of 1961);`
  line
  line `(j) has been convicted for any offence under this Act;`
  line
  line `(k) is disqualified for being a member under section 29;`
  line
  line `(l) has been expelled as a member under section 30;`
  line
  line `(m) absents himself from three consecutive board meetings and such absence has not been`
  line `condoned to by the board;`
  line
  line `(n) absents himself from three consecutive general body meetings and such absence has not been`
  line `condoned by the members in the general body.`
  line
  line `(2) A person shall not be eligible for being elected as member of board of a multi-State co-operative`
  line `society for a period of five years if the board of such multi-State co-operative society fails--`
  line
  line `(a) to conduct elections of the board under section 45; or`
  line
  line `(b) to call the annual general meeting under section 39; or`
  line
  line `(c) to prepare the financial statement and present the same in the annual general meeting.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (1607)
  sectionNo (44)
  orderNo 44
  title `Prohibition to hold office of chairperson or president or vice-chairperson or vice-president in certain cases.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1607&sectionno=44&orderno=44&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_44_content:
  string
  line `(1) No member of a board shall be eligible to be elected as the chairperson or`
  line `president or vice-chairperson or vice-president of a multi-State co-operative society if such member is a`
  line `Minister in the Central Government or a State Government.`
  line
  line `(2) No member of a board shall be eligible to be elected as the chairperson or president of a multiState`
  line `co-operative society, after he has held the office as such during two consecutive terms, whether full`
  line `or part:`
  line
  line `Provided that a member who has ceased to hold the office of the chairperson or president`
  line `continuously for one full term shall again be eligible for election to the office as such.`
  line
  line `Explanation.--where any member holding the office of the chairperson or president at the`
  line `commencement of this Act is again elected to that office after such commencement, he shall for the`
  line `purpose of this section, be deemed to have held office for one term before such election.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (1608)
  sectionNo (45)
  orderNo 45
  title `Establishment of Co-operative Election Authority.`
  content obj_root_law_sections_45_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1608&sectionno=45&orderno=45&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_content:
  string
  line `^1[45. Establishment of Cooperative Election Authority.--(1) The Central Government shall, by`
  line `notification, establish an Authority to be known as the Co-operative Election Authority which shall`
  line `consist of a Chairperson, a Vice-Chairperson and Members not exceeding three to be appointed by the`
  line `Central Government on the recommendation of the Selection Committee consisting of such persons as`
  line `may be prescribed.`
  line
  line `(2) The head office of the Authority shall be at such place as may be notified by the Central`
  line Government.
  line
  line `(3) The election of the members of the board shall be held in the general meeting of the members of`
  line `the multi-State co-operative society.`
  line
  line `(i) Chairperson of the Authority unless he held the post of Additional Secretary to the`
  line `Government of India or equivalent rank;`
  line
  line `(ii) Vice-Chairperson of the Authority unless he held the post of Joint Secretary to the`
  line `Government of India or equivalent rank; and`
  line
  line `(iii) Member unless he fulfils such qualification and experience as may be prescribed`
  line
  line `(4) The Chairperson, Vice-Chairperson or Member of the Authority shall hold office for a period of`
  line `three years from the date on which they enter upon their office or until they attain the age of sixty-five`
  line `years, whichever is earlier and they shall be eligible for re-appointment:`
  line
  line `Provided that in case of appointment of a Government servant as a Chairperson, Vice-Chairperson or`
  line `a Member, he shall be treated as an ex officio Member and he shall continue so long as he holds the office`
  line `by virtue of which he is a Chairperson, Vice-Chairperson or Member.`
  line
  line `(5) The salaries and allowances payable to, and the other terms and conditions of service of the`
  line `Chairperson, Vice-Chairperson and Members of the Authority, other than the ex officio Member, shall be`
  line `such as may be prescribed.]`
obj_root_law_sections_45_a:
  sectionId (76468)
  sectionNo 45A
  orderNo 46
  title `Power of Chairperson.`
  content obj_root_law_sections_45_a_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76468&sectionno=45A&orderno=46&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_a_content:
  string
  line `^1[45A. Power of Chairperson.--The Chairperson of the Authority shall have powers of general`
  line `superintendence and directions in the conduct of the affairs of the Authority and he shall, in addition to`
  line `presiding over the meetings of the Authority, exercise and discharge such other powers and functions as`
  line `may be prescribed.]`
obj_root_law_sections_45_b:
  sectionId (76469)
  sectionNo 45B
  orderNo 47
  title `Removal and suspension of Chairperson, Vice Chairperson and Members.`
  content obj_root_law_sections_45_b_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76469&sectionno=45B&orderno=47&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_b_content:
  string
  line `^1[45B. Removal and suspension of Chairperson, Vice Chairperson and Members.--(1) The`
  line `Central Government may, by order, remove from office the Chairperson, Vice-Chairperson or Member of`
  line `the Authority, other than ex officio Member, if the Chairperson, Vice-Chairperson or Member of the`
  line `Authority, as the case may be,--`
  line
  line `(a) has been adjudged as an insolvent;`
  line
  line `(b) has been convicted of an offence which, in the opinion of the Central Government involves`
  line `moral turpitude;`
  line
  line `(c) has been physically or mentally incapable of acting as a Chairperson, Vice-Chairperson or`
  line `Member of the Authority;`
  line
  line `(d) has acquired such financial or other interests, as is likely to affect prejudicially his function as`
  line `a Chairperson, Vice-Chairperson or Member of the Authority;`
  line
  line `(e) has so abused his position, as to render his continuance in office prejudicial to the public`
  line `interest; orbr`
  line
  line `(f) has engaged at any time during his term of office in any other employment.`
  line
  line `(2) The Chairperson, Vice-Chairperson or Member of the Authority shall not be removed from his`
  line `office except by an order of the Central Government on the ground of his proved misbehaviour or`
  line `incapacity after the Central Government has, on an inquiry, held in accordance with the procedure`
  line `prescribed in this behalf by it, come to the conclusion that the Chairperson, Vice-Chairperson or Member`
  line `of the Authority ought on any such ground to be removed.`
  line
  line `(3) The Central Government may suspend the Chairperson, Vice-Chairperson or Member of the`
  line `Authority in respect of whom an inquiry under sub-section (2) is being initiated or pending until the`
  line `Central Government has passed an order on receipt of the report of the inquiry.]`
obj_root_law_sections_45_c:
  sectionId (76470)
  sectionNo 45C
  orderNo 48
  title `Disclosure and declaration of interest.`
  content obj_root_law_sections_45_c_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76470&sectionno=45C&orderno=48&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_c_content:
  string
  line `^1[45C. Disclosure and declaration of interest. --(1) Before appointing any person as Chairperson,`
  line `Vice-Chairperson or Member, the Central Government shall satisfy itself that the person does not have`
  line `any such financial or other interest as is likely to affect prejudicially his functions as such Chairperson,`
  line `Vice-Chairperson or Member.`
  line
  line `(2) The Chairperson, Vice-Chairperson or Members shall immediately after entering office and every`
  line `year thereafter, make a declaration as to the extent of their interest, whether direct or indirect and whether`
  line `financial or otherwise, in any co-operative society.`
  line
  line `(3) The declaration so made under sub-section (2) shall be placed in the public domain by the`
  line Authority.]
obj_root_law_sections_45_d:
  sectionId (76471)
  sectionNo 45D
  orderNo 49
  title `Resignation of Members.`
  content obj_root_law_sections_45_d_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76471&sectionno=45D&orderno=49&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_d_content:
  string
  line `^1[45D. Resignation of Members.-- The Chairperson, Vice-Chairperson or Members, other than ex`
  line `officio Members, may, by notice in writing of not less than thirty days under their hand addressed to the`
  line `Central Government, resign their office and on such resignation being accepted by that Government, shall`
  line `be deemed to have vacated their office:`
  line
  line `Provided that the Chairperson, Vice-Chairperson or Member shall, unless he is permitted by the`
  line `Central Government to relinquish his office sooner, continue to hold office until the expiry of three`
  line `months from the date of receipt of such notice or until a person duly appointed as his successor enters`
  line `upon his office or until the expiry of his term of office, whichever is the earliest.]`
obj_root_law_sections_45_e:
  sectionId (76472)
  sectionNo 45E
  orderNo 50
  title `Filling of casual vacancy.`
  content obj_root_law_sections_45_e_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76472&sectionno=45E&orderno=50&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_e_content:
  string
  line `^1[45E. Filling of casual vacancy.--- If a casual vacancy occurs in the office of the Chairperson, Vice Chairperson or Member of the Authority, whether by reason of his death, resignation or otherwise, such`
  line `vacancy shall be filled within a period of ninety days by making a fresh appointment in accordance with`
  line `the provisions of section 45 and the person so appointed shall hold office for the remainder of the term of`
  line `office for which the Chairperson, Vice-Chairperson or Member of the Authority, as the case may be, in`
  line `whose place he is so appointed.]`
obj_root_law_sections_45_f:
  sectionId (76473)
  sectionNo 45F
  orderNo 51
  title `Restriction of reemployment.`
  content obj_root_law_sections_45_f_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76473&sectionno=45F&orderno=51&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_f_content:
  string
  line `^1[45F. Restriction of reemployment.--The Chairperson, Vice-Chairperson and Member of the`
  line `Authority, on ceasing to hold office shall not, for a period of two years, accept any employment`
  line `(including as consultant or otherwise) in any co-operative society:`
  line
  line `Provided that nothing contained in this section shall apply to any employment under the Central`
  line `Government or in any State Government or any Corporation established by or under any Central or State`
  line `Act or a Government Company as defined under clause (45) of section 2 of the Companies Act, 2013 (18`
  line `of 2013).]`
obj_root_law_sections_45_g:
  sectionId (76474)
  sectionNo 45G
  orderNo 52
  title `Vacancies, etc., not to invalidate proceedings of Authority.`
  content obj_root_law_sections_45_g_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76474&sectionno=45G&orderno=52&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_g_content:
  string
  line `^1[45G. Vacancies, etc., not to invalidate proceedings of Authority.--No act or proceeding of the`
  line `Authority shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of the Authority;`
  line
  line `(b) any defect in the appointment of a person as Chairperson or Member of the Authority; or`
  line
  line `(c) any irregularity in the procedure of the Authority not affecting the merits of the case.]`
obj_root_law_sections_45_h:
  sectionId (76475)
  sectionNo 45H
  orderNo 53
  title `Meetings of Authority.`
  content obj_root_law_sections_45_h_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76475&sectionno=45H&orderno=53&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_h_content:
  string
  line `^1[45H. Meetings of Authority.-- (1) The Authority shall meet at such places and times and shall`
  line `observe such rules of procedure in regard to the transaction of business at its meetings (including the`
  line `quorum at its meetings), as may be prescribed.`
  line
  line `(2) The Chairperson of the Authority shall preside at the meeting of the Authority and if for any`
  line `reason the Chairperson of the Authority is unable to attend a meeting of the Authority, the Vice Chairperson of the Authority shall preside at the meeting.`
  line
  line `(3) All questions which come up before any meeting of the Authority shall be decided by a majority`
  line `of votes of the members present and voting and, in the event of an equality of votes, the Chairperson or`
  line `the Vice-Chairperson of the Authority presiding shall have the right to exercise a second or casting vote.`
  line
  line `(4) Save as otherwise provided in sub-section (1), every Member shall have one vote.]`
obj_root_law_sections_45_i:
  sectionId (76476)
  sectionNo 45-I
  orderNo 54
  title `Functions of Authority.`
  content obj_root_law_sections_45_i_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76476&sectionno=45-I&orderno=54&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_i_content:
  string
  line `^1[45-I. Functions of Authority.--- The Authority shall discharge the following functions, namely:–--`
  line
  line `(i) conduct the elections of the multi-State co-operative society;`
  line
  line `(ii) supervise, direct and control the matters relating to preparation of electoral rolls; and`
  line
  line `(iii) such other functions as may be prescribed.]`
obj_root_law_sections_45_j:
  sectionId (76477)
  sectionNo 45J
  orderNo 55
  title `Elections of members of board.`
  content obj_root_law_sections_45_j_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76477&sectionno=45J&orderno=55&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_j_content:
  string
  line `^1[45J. Elections of members of board.-- (1) No person shall be eligible to be elected as a member of`
  line `the board or office bearer of a multi-State co-operative society, unless he is an active member of the`
  line `general body of that society.`
  line
  line `Explanation.--For the purposes of this sub-section, the term "active member" means any member--`
  line
  line `(i) availing minimum level of products or services of the society; or`
  line
  line `(ii) attending not less than three consecutive general meetings,`
  line
  line `as specified in section 29.`
  line
  line `(2) A member of the board or office bearer of a multi-State co-operative society shall cease to be such`
  line `member or office bearer, if he ceases to be a member of general body of that society.`
  line
  line `(3) The election of members of board shall be held by secret ballot in such manner as may be`
  line prescribed.
  line
  line `(4) The election of the members of the board shall be held in the general meeting of the members of`
  line `the multi-State co-operative society and the elected members of the board shall, if the bye-laws of such`
  line `society permit, be eligible for re-election.`
  line
  line `(5) The term of office of elected members of the board and its office bearers shall be five years from`
  line `the date of election and the term of office bearers shall be co-terminus with the term of the board:`
  line
  line `Provided that the board may fill casual vacancies up to one-third of number of elected directors on the`
  line `board by nomination out of the same class of members in respect of which the casual vacancy has arisen,`
  line `if the term of office of the board is less than half of its original term:`
  line
  line `Provided further that in case the number of such casual vacancies in the same term of the board`
  line `exceeds one-third of number of elected directors, such vacancies shall be filled by elections.`
  line
  line `(6) The expenses for holding elections by the Authority shall be borne by the multi-State co-operative`
  line `society in such manner as may be prescribed.`
  line
  line `(7) The Central Government may make rules to provide for the powers and the procedure to be`
  line `followed by the Authority for conduct of election of members of the board.`
  line
  line `(8) The Chairperson and the Chief Executive of the multi-State co-operative society shall inform the`
  line `Authority, six months before the expiry of the term of the existing board, to conduct the elections within`
  line time.
  line
  line `(9) The multi-State co-operative society in respect of which the election is being held shall provide`
  line `such infrastructure, personnel, information, documents or other assistance to the Authority as it may`
  line require.]
obj_root_law_sections_45_k:
  sectionId (76478)
  sectionNo 45K
  orderNo 56
  title `Appointment of Returning Officer and other officers.`
  content obj_root_law_sections_45_k_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76478&sectionno=45K&orderno=56&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_k_content:
  string
  line `^1[45L. 45K. Appointment of Returning Officer and other officers.-- (1) The Authority may appoint a`
  line `Returning Officer to conduct the election of the multi-State co-operative societies and discharge such`
  line `functions, as directed by the Authority, in such manner as may be prescribed.`
  line
  line `(2) The Central Government shall provide such staff and officers to the Authority as may be`
  line `necessary for the efficient discharge of functions by the Authority under the Act.`
  line `(3) The Authority may appoint,--`
  line
  line `(a) such observers as it may consider necessary to supervise the elections and discharge such`
  line `other functions as may be prescribed; and`
  line
  line `(b) such number of Assistant Returning Officers as it may consider necessary to assist the`
  line `Returning Officer.`
obj_root_law_sections_45_l:
  sectionId (76479)
  sectionNo 45L
  orderNo 57
  title `Power to issue directions.`
  content obj_root_law_sections_45_l_content
  footnotes `1. Subs. by s. 17, ibid., for section 45 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76479&sectionno=45L&orderno=57&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_45_l_content:
  string
  line `^1[45L. Power to issue directions.-- The Authority may, by general or special order, issue such`
  line `directions to the board, its members, Chief Executive and other staff of the multi-State co-operative`
  line `society as may be necessary for the conduct of free and fair elections and the board, its members, Chief`
  line `Executive and staff of the society shall comply with such directions.]`
obj_root_law_sections_46:
  sectionId (1609)
  sectionNo (46)
  orderNo 58
  title `Holding of office in co-operative society.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1609&sectionno=46&orderno=58&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_46_content:
  string
  line `Notwithstanding anything contained in this Act, no`
  line `person shall be eligible to hold, at the same time, office of a president or chairperson or vice-president or`
  line `vice-chairperson on the board of more than two multistate co-operative societies.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (1610)
  sectionNo (47)
  orderNo 59
  title `Removal of elected members by general body.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1610&sectionno=47&orderno=59&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_47_content:
  string
  line `An elected member of a board, who has acted`
  line `adversely to the interests of multi-State co-operative society, may on the basis of a report of the Central Registrar or otherwise be removed from the board upon a resolution of the general body passed at its`
  line `meeting by a majority of not less than two-third of the members present and voting at the meeting:`
  line
  line `Provided that the member concerned shall not be removed unless he has been given a reasonable`
  line `opportunity of making a representation in the matter.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (1611)
  sectionNo (48)
  orderNo 60
  title `Nominee of Central Government or State Government on board.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1611&sectionno=48&orderno=60&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_48_content:
  string
  line `(1) Where the Central`
  line `Government or a State Government has subscribed to the share capital of a multi-State co-operative`
  line `society, the Central Government or the State Government, as the case may be, or any person authorised`
  line `by the Central Government or the State Government shall have right to nominate on the board such`
  line `number of persons as its members on the following basis, namely:--`
  line
  line `(a) where the total amount of issued equity share capital held by the Central Government or the`
  line `State Government is less than twenty six per cent. of the total issued equity share capital, one member`
  line `of the board;`
  line
  line `(b) where the total amount of issued equity share capital held by the Central Government or the`
  line `State Government is twenty-six per cent. or more but less than fifty-one per cent. of the total issued`
  line `equity share capital, two members of the board;`
  line
  line `(c) where the total amount of issued equity share capital held by the Central Government or the`
  line `State Government is fifty-one per cent. or more of the total issued share capital, three members of the`
  line `board:`
  line
  line `Provided that the number of such nominated persons shall not exceed one third of the total number of`
  line `members of the board:`
  line
  line `Provided further that where the Central Government or a State Government has guaranteed the`
  line `repayment of principal and payment of interest on debentures issued by a multi-State co-operative society`
  line `or has guaranteed the repayment of principal and payment of interest on loans and advances to a multiState`
  line `co-operative society or has given any assistance by way of grants or otherwise to a multi-State cooperative`
  line `society, the Central Government or the State Government in this behalf, as the case may be, or`
  line `any person authorised by the Central Government, shall have the right to nominate person on the board of`
  line `such a society in the manner as may be prescribed.`
  line
  line `(2) A person nominated under this section shall hold office during the pleasure of the Government by`
  line `which he has been so nominated.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (1612)
  sectionNo (49)
  orderNo 61
  title `Powers and functions of board.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1612&sectionno=49&orderno=61&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_49_content:
  string
  line `(1) The board may exercise all such powers as may be`
  line `necessary or expedient for the purpose of carrying out its functions under this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing powers, such powers shall include the`
  line power--
  line
  line `(a) to admit members;`
  line
  line `(b) to interpret the organisational objectives and set up specific goals to be achieved towards`
  line `these objectives;`
  line
  line `(c) to make periodic appraisal of operations;`
  line
  line `(d) to appoint and remove a Chief Executive and such other employees of the society as are not`
  line `required to be appointed by the Chief Executive;`
  line
  line `(e) to make provisions for regulating the appointment of employees of the multi-State cooperative`
  line `society and the scales of pay, allowances and other conditions of service of, including`
  line `disciplinary action against such employees;`
  line
  line `(f) to place the annual report, annual financial statements, annual plan and budget for the approval`
  line `of the general body;`
  line
  line `(g) to consider audit and compliance report and place the same before the general body;`
  line
  line `(h) to acquire or dispose of immovable property;`
  line
  line `(i) to review membership in other co-operatives;`
  line
  line `(j) to approve annual and supplementary budget;`
  line
  line `(k) to raise funds;`
  line
  line `(l) to sanction loans to the members; and`
  line
  line `(m) to take such other measures or to do such other acts as may be prescribed or required under`
  line `this Act or the bye-laws or as may be delegated by the general body.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (1613)
  sectionNo (50)
  orderNo 62
  title `Meeting of board.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1613&sectionno=50&orderno=62&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_50_content:
  string
  line `(1) The Chief Executive shall convene the meetings of the board at the`
  line `instance of the chairperson or president of the multi-State co-operative society.`
  line
  line `(2) The total number of meetings of the board in a year and the venue of meetings as may be specified`
  line `in the bye-laws:`
  line
  line `Provided that the board shall meet at least once in every quarter:`
  line
  line `Provided further that not more than two persons may be invited by the board in its meetings.`
  line
  line `(3) The Chairperson, or if for any reason, he is unable to attend a meeting of the board, any other`
  line `member of the board chosen by the members of the board present from amongst themselves at the`
  line `meeting, shall preside at the meeting.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (1614)
  sectionNo (51)
  orderNo 63
  title `Chief Executive.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1614&sectionno=51&orderno=63&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_51_content:
  string
  line `(1) There shall be a Chief Executive, by whatever designation called, of every`
  line `multi-State co-operative society to be appointed by the board and he shall be a full-time employee of such`
  line `multi-State co-operative society.`
  line
  line `(2) The Chief Executive shall be a member of the board and of the Executive Committee and such`
  line `other committees or subcommittees as may be constituted under sub-section (1) of section 53.`
  line
  line `(3) Where the Central Government or the State Government holds fifty-one per cent. or more of the`
  line `equity share capital or of total shares of the multi-State co-operative society, the salary and allowances`
  line `payable to and other terms and conditions of service including pension, gratuity and other retirement`
  line `benefits of the Chief Executive shall be such as may be prescribed.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (1615)
  sectionNo (52)
  orderNo 64
  title `Powers and functions of Chief Executive.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1615&sectionno=52&orderno=64&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_52_content:
  string
  line `The Chief Executive shall under the general`
  line `superintendence, direction and control of the board, exercise the powers and discharge the functions`
  line `specified below, namely:--`
  line
  line `(a) day-to-day management of the business of the multi-State co-operative society;`
  line
  line `(b) operating the account of the multi-State co-operative society and be responsible for making`
  line `arrangements for safe custody of cash;`
  line
  line `(c) signing on the documents for and on behalf of the multi-State co-operative society;`
  line
  line `(d) making arrangements for the proper maintenance of various books and records of the multiState`
  line `co-operative society and for the correct preparation, timely submission of periodical statements`
  line `and returns in accordance with the provisions of this Act, the rules and the bye-laws;`
  line
  line `(e) convening meetings of the general body of the multi-State co-operative society, the board and`
  line `the Executive Committee and other committees or sub-committees constituted under sub-section (1)`
  line `of section 53 and maintaining proper records for such meetings;`
  line
  line `(f) making appointments to the posts in the multi-State co-operative society in accordance with`
  line `the bye-laws;`
  line
  line `(g) assisting the board in the formulation of policies, objectives and planning;`
  line
  line `(h) furnishing to the board periodical information necessary for appraising the operations and`
  line `functions of the multi-State co-operative society;`
  line
  line `(i) appoint the person to sue or be sued on behalf of the multi-State co-operative society;`
  line
  line `(j) present the draft annual report and financial statement for the approval of the board within`
  line `thirty days of closure of the financial year;`
  line
  line `(k) performing such other duties, and exercising such other powers, as may be specified in the`
  line `bye-laws of the multi-State co-operative society.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (1616)
  sectionNo (53)
  orderNo 65
  title `Committees of board.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1616&sectionno=53&orderno=65&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_53_content:
  string
  line `(1) The board may, subject to such conditions as may be prescribed,`
  line `constitute an Executive Committee and other committees or subcommittees as may be considered`
  line `necessary:`
  line
  line `Provided that other committees or sub-committees, other than the Executive Committee shall not`
  line `exceed three.`
  line
  line `(2) The Executive Committee or other committee or sub-committee referred to in sub-section (1) shall`
  line `perform such functions as are assigned to it in accordance with the bye-laws of the multi-State cooperative`
  line society.
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (1617)
  sectionNo (54)
  orderNo 66
  title `Securing possession of records, etc.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1617&sectionno=54&orderno=66&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_54_content:
  string
  line `(1) If--`
  line
  line `(a) the records, including registers and books of account of a multi-State co-operative society are`
  line `likely to be tampered with or destroyed or the funds or other property of such society are likely to be`
  line `mis-appropriated; or`
  line
  line `(b) the board of a multi-State co-operative society is reconstituted at a general meeting of the`
  line `society; or`
  line
  line `(c) a multi-State co-operative society is ordered to be wound up under section 86 and the`
  line `outgoing members of the board refuse to handover charge of the records and property of the society to`
  line `those having or entitled to receive such charge,`
  line
  line `the Chief Executive may apply to the magistrate within whose jurisdiction the multi-State co-operative`
  line `society functions for securing the records and property of the society.`
  line
  line `(2) On receipt of an application under sub-section (1), the magistrate may, by a warrant, authorise any`
  line `police officer not below the rank of a sub-inspector to enter and search any place where such records and`
  line `property are kept or are believed to be kept and to seize such records and property; and the records and`
  line `property so seized shall be handed over to the new board or the liquidator, as the case may be.`
  line
  line `(3) Every such search and seizure shall be made in accordance with the provisions of the Code of`
  line `Criminal Procedure, 1973 (2 of 1974).`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (1618)
  sectionNo (55)
  orderNo 67
  title `Charge and set-off in respect of share or contribution or interest of members.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1618&sectionno=55&orderno=67&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_55_content:
  string
  line `A multi-State`
  line `co-operative society shall have a charge on the share or contribution or interest in the capital and on the`
  line `deposits of a member or past or deceased member and on any dividend, bonus or profits payable to a`
  line `member or past member or the estate of a deceased member in respect of any debt due from such member`
  line `or past member or the estate of such deceased member to the society and may set-off any sum credited or`
  line `payable to a member or past member or the estate of deceased member in or towards payment of any such`
  line debt.
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (1619)
  sectionNo (56)
  orderNo 68
  title `Share or contribution or interest not liable to attachment.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1619&sectionno=56&orderno=68&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_56_content:
  string
  line `(1) Subject to the provisions of`
  line `section 55, the share or contribution or interest of a member or past or deceased member in the capital of`
  line `a multi-State co-operative society shall not be liable to attachment or sale under any decree or order of`
  line `any court in respect of any debt or liability incurred by such member, and an official assignee or a`
  line `receiver under any law relating to insolvency shall not be entitled to, or have any claim on, such share or`
  line `contribution or interest.`
  line
  line `(2) The reserve fund, or the bad debt reserves, or the provident fund of the employees, of a multiState`
  line `co-operative society invested by such society in accordance with the provision of this Act and the`
  line `bye-laws shall not be liable to attachment under any decree or order of a court in respect of any debt or`
  line `liability incurred by the society.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (1620)
  sectionNo (57)
  orderNo 69
  title `Register of members.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1620&sectionno=57&orderno=69&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_57_content:
  string
  line `Any register or list of members or shares kept by any multi-State cooperative`
  line `society shall be prima facie evidence of any of the following particulars entered therein,`
  line `namely:--`
  line
  line `(a) the date on which any person entered in such register or list became a member; or`
  line
  line `(b) the date on which any such person ceased to be a member.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (1621)
  sectionNo (58)
  orderNo 70
  title `Admissibility of copy of entry as evidence.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1621&sectionno=58&orderno=70&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_58_content:
  string
  line `(1) A copy of any entry in a book of a multi-State`
  line `co-operative society regularly kept in the course of its business shall, if certified in such manner as may`
  line `be prescribed, be received in any suit or legal proceedings as prima facie evidence of the existence of`
  line `such entry and shall be admitted as evidence of the matters, transactions and accounts therein recorded in`
  line `every case where, and to the same extent, as the original entry itself if admissible.`
  line
  line `(2) No officer of a multi-State co-operative society and no officer in whose office the books of a`
  line `multi-State co-operative society are deposited after liquidation shall, in any legal proceedings to which`
  line `the society or the liquidator is not a party, be compelled to produce any of the society's books or`
  line `documents the contents of which can be proved under this section, or to appear as a witness to prove the`
  line `matters, transactions and accounts therein recorded, except under an order of a court or an arbitrator made`
  line `for a special cause.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (1622)
  sectionNo (59)
  orderNo 71
  title `Exemption from compulsory registration of instruments.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1622&sectionno=59&orderno=71&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_59_content:
  string
  line `Nothing in clauses (b) and (c) of`
  line `sub-section (1) of section 17 of the Registration Act, 1908 (16 of 1908) shall apply to--`
  line
  line `(a) any instrument relating to shares in a multi-State co-operative society notwithstanding that the`
  line `assets of the society consist in whole or in part of immovable property; or`
  line
  line `(b) any debenture issued by any such society and not creating, declaring, assigning, limiting or`
  line `extinguishing any right, title or interest to or in immovable property, except in so far as it entitles the`
  line `holder thereof to the security afforded by a registered instrument whereby the society has mortgaged,`
  line `conveyed or otherwise transferred the whole or part of its immovable property or any interest therein`
  line `to trustees upon trust for the benefit of the holders of such debentures; or`
  line
  line `(c) an endorsement upon transfer of any debenture issued by any such society.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (1623)
  sectionNo (60)
  orderNo 72
  title `Deduction from salary to meet multi-State co-operative society’s claim in certain cases.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1623&sectionno=60&orderno=72&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_60_content:
  string
  line `(1)`
  line `Notwithstanding anything contained in any law for the time being in force, a member of a multi-State cooperative`
  line `society may execute an agreement in favour of that society providing that his employer`
  line `disbursing his salary or wages shall be competent to deduct every month from the salary or wages payable`
  line `to him, such amount as may be specified in the agreement and to pay the amount so deducted to the`
  line `society in satisfaction of any debt or other demand the member owes to the society.`
  line
  line `(2) On the execution of such agreement, the employer disbursing the salary or wages of the members`
  line `shall, if so required by the multi-State co-operative society, by a requisition in writing and so long as the`
  line `society does not intimate that the whole of such debt or other demand has been paid, make the deduction`
  line `in accordance with the agreement and pay the amount so deducted to the society within a period of`
  line `fourteen days of the date on which deduction has been made, as if it were a part of the salary or wages`
  line `payable on the day as required under the Payment of Wages Act, 1936 (4 of 1936), and such payment`
  line `shall be valid discharge of the employer for his liability to pay the amount deducted.`
  line
  line `(3) If after the receipt of a requisition made under sub-section (2), the employer disbursing the salary`
  line `or wages of the member at any time fails to deduct the amount specified in the requisition from the salary`
  line `or wages payable to the member concerned or makes default in remitting the amount deducted to the`
  line `multi-State co-operative society, the society shall be entitled to recover any such amount from such`
  line `employer as arrears of land revenue and the amount so due from such employer shall rank in priority in`
  line `respect of the liability of such employer equal to that of the salary or wages in arrears.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (1624)
  sectionNo (61)
  orderNo 73
  title `Government aid to multi-State co-operative societies.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1624&sectionno=61&orderno=73&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_61_content:
  string
  line `Notwithstanding anything contained in`
  line `any law for the time being in force, the Central Government or a State Government, on receipt of request`
  line `from a multi-State co-operative society and with a view to promoting co-operative movement, may,--`
  line
  line `(a) subscribe to the share capital of a multi-State co-operative society;`
  line
  line `(b) give loans or make advances to a multi-State co-operative society;`
  line
  line `(c) guarantee the repayment of principal and payment of interest on debentures issued by a multiState`
  line `co-operative society;`
  line
  line `(d) guarantee the repayment of share capital of a multi-State co-operative society and dividends`
  line `thereon at such rates as may be specified by the Central Government or the State Government;`
  line
  line `(e) guarantee the repayment of principal and payment of interest on loans and advances to a`
  line `multi-State co-operative society;`
  line
  line `(f) give financial assistance in any other form, including subsidies, to any multi-State co-operative`
  line `society; and`
  line
  line `(g) provide aid to any other multi-State co-operative society on such terms and conditions as may`
  line `be prescribed.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (1625)
  sectionNo (62)
  orderNo 74
  title `Funds not to be divided by way of profit.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1625&sectionno=62&orderno=74&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_62_content:
  string
  line `(1) No part of the funds, other than net profits, of a`
  line `multi-State co-operative society shall be divided by way of bonus or dividend or otherwise distributed`
  line `among its members.`
  line
  line `(2) The net profits of a multi-State co-operative society referred to in sub-section (1) in respect of a`
  line `society earning profits shall be calculated by deducting from the gross profit for the year, all interest`
  line `accrued and accruing in relation to amounts which are overdue, establishment charges, interest payable on`
  line `loans and deposits, audit fees, working expenses including repairs, rent, taxes and depreciation, bonus`
  line `payable to employees under the law relating to payment of bonus for the time being in force, and`
  line `equalisation fund for such bonus, provision for payment of income-tax and making approved donations`
  line `under the Income-tax Act, 1961 (43 of 1961), development rebate, provision for development fund, bad`
  line `debt fund, price fluctuation fund, dividend equalisation fund, share capital redemption fund, investment`
  line `fluctuation fund, provision for retirement benefits to employees, and after providing for or writing off bad`
  line `debts and losses not adjusted against any fund created out of profit:`
  line
  line `Provided that such society may add to the net profits for the year interest accrued in the preceding`
  line `years, but actually recovered during the year:`
  line
  line `Provided further that in the case of such multi-State co-operative societies as do not have share`
  line `capital, the surplus of income over expenditure shall not be treated as net profits and such surplus shall be`
  line `dealt with in accordance with the bye-laws.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (1626)
  sectionNo (63)
  orderNo 75
  title `Disposal of net profits.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1626&sectionno=63&orderno=75&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_63_content:
  string
  line `(1) A multi-State co-operative society shall, out of its net profits in any`
  line year,--
  line
  line `(a) transfer an amount not less than twenty-five per cent. to the reserve fund;`
  line
  line `(b) credit one per cent. to co-operative education fund maintained, by the National Co-operative`
  line `Union of India Limited, New Delhi, in the manner as may be prescribed;`
  line
  line `(c) transfer an amount not less than ten per cent. to a reserve fund for meeting unforeseen losses.`
  line
  line `(2) Subject to such conditions as may be prescribed, the balance of the net profits may be utilised for`
  line `all or any of the following purposes, namely:--`
  line
  line `(a) payment of dividend to the members on their paid-up share capital at a rate not exceeding the`
  line `prescribed limit;`
  line
  line `(b) constitution of, or contribution to, such special funds including education funds, as may be`
  line `specified in the bye-laws;`
  line
  line `(c) donation of amounts not exceeding five per cent. of the net profits for any purpose connected`
  line `with the development of co-operative movement or charitable purpose as defined in section 2 of the`
  line `Charitable Endowments Act, 1890 (6 of 1890);`
  line
  line `(d) payment of ex gratia amount to employees of the multi-State co-operative society to the`
  line `extent and in the manner specified in the bye-laws.`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_63_a:
  sectionId (76480)
  sectionNo 63A
  orderNo 76
  title `Establishment of Co-operative Rehabilitation, Reconstruction and Development Fund.`
  content obj_root_law_sections_63_a_content
  footnotes `1. Ins. by s. 24, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76480&sectionno=63A&orderno=76&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_63_a_content:
  string
  line `^1[63A. Establishment of Co-operative Rehabilitation, Reconstruction and Development`
  line `Fund. -- (1) The Central Government shall establish a Fund, to be called the Co-operative Rehabilitation,`
  line `Reconstruction and Development Fund for revival of sick multi-State co-operative societies as referred to`
  line `in section 63B and for development purposes in such manner as may be determined by it and there shall`
  line `be credited to such Fund annually by multi-State co-operative societies which are in profit for the`
  line `preceding three financial years one crore rupees or one per cent. of the net profits of such multi-State cooperative society, whichever is less.`
  line
  line `(2) The Central Government shall, by notification, constitute a Committee, consisting of such`
  line `members as it may deem fit, to administer the Fund, and maintain separate accounts and other relevant`
  line `records in relation to the Fund in such form as may be specified by the Central Government in`
  line `consultation with the Comptroller and Auditor-General of India.`
  line
  line `(3) The Committee shall spend the money out of the Fund for carrying out the objects for which such`
  line `Fund has been established.]`
obj_root_law_sections_63_b:
  sectionId (76481)
  sectionNo 63B
  orderNo 77
  title `Rehabilitation and reconstruction of sick societies.`
  content obj_root_law_sections_63_b_content
  footnotes `1. Ins. by s. 24, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76481&sectionno=63B&orderno=77&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_63_b_content:
  string
  line `^1[63B. Rehabilitation and reconstruction of sick societies.-- (1) If, at any time, the Central`
  line `Registrar, is of the opinion that a multi-State co-operative society has become sick, he may, by an order,`
  line `declare such society as sick co-operative society.`
  line
  line `(2) Where a multi-State co-operative society is declared as a sick co-operative society under`
  line `sub-section (1), the Central Government or any person or agency authorised by it, may prepare a scheme`
  line `for rehabilitation and reconstruction of the society and hand it over to the society for approval of the`
  line `general body.`
  line
  line `(3) The Central Government may, on the recommendation of the general body and to give effect to`
  line `the scheme for rehabilitation and reconstruction referred to in sub-section (2), re-organise the board of`
  line `such society with such persons, having experience in the field of co-operation, management, finance,`
  line `accountancy and any other area relating to such societies as may be recommended by the general body:`
  line
  line `Provided that in respect of a sick multi-State co-operative bank, any scheme for rehabilitation or`
  line `reconstruction shall be done with the prior approval of the Reserve Bank.`
  line
  line `Explanation.-- For the purposes of this section, the expression "sick co-operative society" means a`
  line `multi-State co-operative society being a society registered under the provisions of this Act which has at`
  line `the end of any financial year accumulated losses equal to or exceeding total of its paid-up capital, free reserves and surpluses and has also suffered cash losses in such financial year and the financial year`
  line `immediately preceding such financial year.]`
obj_root_law_sections_63_c:
  sectionId (76482)
  sectionNo 63C
  orderNo 78
  title `Financial assistance to multi-State co-operative societies for development.`
  content obj_root_law_sections_63_c_content
  footnotes `1. Ins. by s. 24, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76482&sectionno=63C&orderno=78&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_63_c_content:
  string
  line `^1[63C. Financial assistance to multi-State co-operative societies for development.--(1) The Central`
  line `Government may, on an application made by a multi-State co-operative society which has contributed to`
  line `the Fund for continuous five preceding financial years, grant such financial assistance as it may consider`
  line `appropriate to the society out of the Fund for infrastructural requirement:`
  line
  line `Provided that at least fifty per cent. of the total requirement shall be borne by the multi-State`
  line `co-operative society and the financial assistance from the Fund shall not exceed more than the fifty per`
  line `cent. of such requirement.`
  line
  line `(2) The Committee constituted under sub-section (2) of section 63A shall examine and recommend to`
  line `the Central Government for providing the financial assistance to the multi-State co-operative society to`
  line `such extent and on such terms and conditions as it may consider necessary.]`
obj_root_law_sections_64:
  sectionId (1627)
  sectionNo (64)
  orderNo 79
  title `Investment of funds.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1627&sectionno=64&orderno=79&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_64_content:
  string
  line `A multi-State co-operative society may invest or deposit its funds--`
  line
  line `(a) in a co-operative bank, state co-operative bank, co-operative land development bank or central`
  line `co-operative bank; or`
  line
  line `(b) in any of the securities specified in section 20 of the Indian Trust Act, 1882 (2 of 1882); or`
  line
  line `(c) in the shares or securities of any other multi-State co-operative society or any co-operative`
  line `society; or`
  line
  line `(d) in the shares, securities or assets of a subsidiary institution or any other institution; or`
  line
  line `(e) with any other bank; or`
  line
  line `(f) in such other mode as may be provided in the bye-laws.`
  line
  line `Explanation.--For the purposes of clause (e), "bank" means any banking company as defined in`
  line `clause (c) of section 5 of the Banking Regulation Act, 1949 (10 of 1949), and includes--`
  line
  line `(i) the State Bank of India constituted under the State Bank of India Act, 1955 (23 of 1955);`
  line
  line `(ii) a subsidiary bank as defined in clause (k) of section 2 of the State Bank of India (Subsidiary`
  line `Banks) Act, 1959 (38 of 1959);`
  line
  line `(iii) a corresponding new bank constituted under section 3 of the Banking Companies`
  line `(Acquisition and Transfer of Undertakings) Act, 1970 (5 of 1970) or a corresponding new bank`
  line `constituted under section 3 of the Banking Companies (Acquisition and Transfer of Undertakings)`
  line `Act, 1980 (40 of 1980).`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (1628)
  sectionNo (65)
  orderNo 80
  title `Restriction on contribution.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1628&sectionno=65&orderno=80&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_65_content:
  string
  line `No multi-State co-operative society shall make a contribution,`
  line `either in money or in kind, whether directly or indirectly, to an institution which has an object of`
  line `furtherance of the interest of a political party.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (1629)
  sectionNo (66)
  orderNo 81
  title `Restriction on loans.`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1629&sectionno=66&orderno=81&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_66_content:
  string
  line `(1) A multi-State co-operative society, other than a co-operative bank,`
  line `shall not make a loan to a member on the security of his share or on the security of a non-member.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), a multi-State co-operative society may`
  line `make a loan to a depositor on the security of his deposit.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (1630)
  sectionNo (67)
  orderNo 82
  title `Restrictions on borrowings.`
  content obj_root_law_sections_67_content
  footnotes `1. Ins. by Act 21 of 2019, s. 42 the Second Schedule (w.e.f. 21-2-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1630&sectionno=67&orderno=82&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_67_content:
  string
  line `(1) A multi-State co-operative society may receive deposits, raise`
  line `loans and receive grants from external sources to such extent and under such conditions as may be`
  line `specified in the bye-laws:`
  line
  line `Provided that the total amount of deposits and loans received during any financial year shall not`
  line `exceed ten times of the sum of subscribed share capital and accumulated reserves:`
  line
  line `Provided further that while calculating the total sum of subscribed share capital and accumulated`
  line `reserves, the accumulated losses shall be deducted.`
  line
  line `^1Explanation. -- For the removal of doubts, it is hereby clarified that a multi-State co-operative`
  line `society shall not be entitled to receive deposits from persons other than voting members.`
  line
  line `(2) Subject to the provisions of sub-section (1), a multi-State co-operative society may accept funds`
  line `or borrow funds for the fulfilment of its objects on such terms and conditions as are mutually contracted`
  line upon.
  line
  line `(3) A multi-State co-operative society may issue non-convertible debentures or other instruments`
  line `subject to the provisions of any law for the time being in force to raise resources for the fulfilment of its`
  line `objects to the extent of twenty-five per cent. of its paid-up share capital.`
obj_root_law_sections_68:
  sectionId (1631)
  sectionNo (68)
  orderNo 83
  title `Restriction on other transactions with non-members.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1631&sectionno=68&orderno=83&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_68_content:
  string
  line `Save as provided in sections 66 and`
  line `67, the transaction of a multi-State co-operative society with any person other than a member, shall be`
  line `subject to such prohibitions and restrictions, if any, as may be specified in the bye-laws.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (1632)
  sectionNo (69)
  orderNo 84
  title `Contributory provident fund.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1632&sectionno=69&orderno=84&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_69_content:
  string
  line `(1) Subject to the provisions of the Employees' Provident Fund`
  line `and Miscellaneous Provisions Act, 1952 (19 of 1952), a multi-State co-operative society having such`
  line `number or class of employees as may be prescribed, may establish a contributory provident fund for the`
  line `benefit of its employees to which shall be credited all contributions made by the employees and the`
  line `society in accordance with the bye-laws of the society.`
  line
  line `(2) Monies standing to the credit of any contributory provident fund established by a multi-State cooperative`
  line `society under sub-section (1) shall not--`
  line
  line `(a) be used in the business of the society;`
  line
  line `(b) form part of the assets of the society;`
  line
  line `(c) be liable to attachment or be subject to any other process of any court or other authority.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (1633)
  sectionNo (70)
  orderNo 85
  title `Appointment and remuneration of auditors.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1633&sectionno=70&orderno=85&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_70_content:
  string
  line `(1) Every multi-State co-operative society shall`
  line `cause to be audited by an auditor referred to in sub-section (2), its accounts at least once in each year.`
  line
  line `(2) Every multi-State co-operative society shall, at each annual general meeting, appoint an auditor`
  line `or auditors to hold office from the conclusion of that meeting until the conclusion of the next annual`
  line `general meeting and shall, within seven days of the appointment, give intimation thereof to every auditor`
  line `so appointed:`
  line
  line `Provided that such auditor or auditors may be appointed from a panel of auditors approved by the`
  line `Central Registrar or from a panel of auditors, if any, prepared by the multi-State co-operative society.`
  line
  line `(3) Every auditor appointed under sub-section (1) shall, within thirty days of the receipt from the`
  line `multi-State co-operative society of the intimation of his appointment, inform the Central Registrar in`
  line `writing that he has accepted, or refused to accept, the appointment.`
  line
  line `(4) A retiring auditor shall be re-appointed unless--`
  line
  line `(a) he is not qualified for re-appointment;`
  line
  line `(b) he has given the multi-State co-operative society a notice in writing of his unwillingness to`
  line `be re-appointed;`
  line
  line `(c) a resolution has been passed at the general meeting of members appointing some body instead`
  line `of him or providing expressly that he shall not be re-appointed; or`
  line
  line `(d) where notice has been given of an intended resolution to appoint some person or persons in`
  line `the place of a retiring auditor, and by reason of the death, incapacity or disqualification of that person`
  line `or all those persons, as the case may be, the resolution cannot be proceeded with.`
  line
  line `(5) Where at an annual general meeting no auditors are appointed or re-appointed, the Central`
  line `Registrar may appoint a person to fill the vacancy.`
  line
  line `(6) First auditor or auditors of a multi-State co-operative society shall be appointed by the board`
  line `within one month of the date of registration of such society and the auditor or auditors so appointed shall`
  line `hold office until the conclusion of the first annual general meeting:`
  line
  line `Provided that--`
  line
  line `(a) the multi-State co-operative society may, at a general meeting, remove any such auditor or all`
  line `or any of such auditors and appoint in his or their places any other person or persons who have been`
  line `nominated for appointment by any member of the multi-State co-operative society and of whose`
  line `nomination notice has been given to the members of the multi-State co-operative society not less than`
  line `fourteen days before the date of the meeting; and`
  line
  line `(b) if the board fails to exercise its powers under this sub-section, the multi-State co-operative`
  line `society in the general meeting may appoint the first auditor or auditors.`
  line
  line `(7) (a) The multi-State co-operative society may fill any causal vacancy in the office of an auditor;`
  line `but while any such vacancy continues, the remaining auditor or auditors, if any, may act:`
  line
  line `Provided that where such vacancy is caused by the resignation of an auditor, the vacancy shall only`
  line `be filled by the multi-State co-operative society in general meeting.`
  line
  line `(b) Any auditor appointed in a causal vacancy shall hold office until the conclusion of the next annual`
  line `general meeting.`
  line
  line `(8) Any auditor appointed under this section may be removed from office before the expiry of his`
  line `term by the multi-State co-operative society in general meeting.`
  line
  line `(9) The remuneration of the auditors of a multi-State co-operative society--`
  line
  line `(a) in the case of an auditor appointed by the board or the Central Registrar may be fixed by the`
  line `board or the Central Registrar, as the case may be; and`
  line
  line `(b) subject to clause (a), shall be fixed by the multi-State co-operative society in general meeting`
  line `or in such manner as the multi-State co-operative society in general meeting may determine.`
  line
  line `Explanation.--For the purposes of this sub-section, any sums paid by the multi-State co-operative`
  line `society in respect of the auditors' expenses shall be deemed to be included in the expression`
  line remuneration.
obj_root_law_sections_70_footnotes:
  string
  line
obj_root_law_sections_70_a:
  sectionId (76483)
  sectionNo 70A
  orderNo 86
  title `Concurrent Audit.`
  content obj_root_law_sections_70_a_content
  footnotes `1. Ins. by s. 28, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76483&sectionno=70A&orderno=86&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_70_a_content:
  string
  line `^1[70A. Concurrent Audit.-- In case of multi-State co-operative societies,–-`
  line
  line `(i) having an annual turnover more than the amount as determined by the Central Government; or`
  line
  line `(ii) having deposit of more than the amount as determined by the Central Government,`
  line `the concurrent audit shall be carried out by an auditor appointed from a panel of auditors approved by`
  line `the Central Registrar.]`
obj_root_law_sections_71:
  sectionId (1634)
  sectionNo (71)
  orderNo 87
  title `Provision as to resolutions for appointing or removing auditors.`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1634&sectionno=71&orderno=87&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_71_content:
  string
  line `(1) A special notice shall be`
  line `required for a resolution at an annual general meeting appointing as auditor a person other than a retiring`
  line `auditor, or providing expressly that a retiring auditor shall not be reappointed.`
  line
  line `(2) On receipt of notice of such a resolution, the multi-State co-operative society shall forthwith send`
  line `a copy thereof to the retiring auditor.`
  line
  line `(3) Where notice is given of such a resolution and the retiring auditor makes with respect thereto`
  line `representations in writing to the multistate co-operative society (not exceeding a reasonable length) and`
  line `requests their notification to members of the multi-State co-operative society, the multi-State co-operative`
  line `shall, unless the representations are received by it too late for it to do so,--`
  line
  line `(a) in any notice of the resolution given to members of the multi-State co-operative society, state`
  line `the fact of the representations having been made; and`
  line
  line `(b) send a copy of the representation to every member of the multi-State co-operative society to`
  line `whom notice of the meeting is sent, whether before or after the receipt of the representations by the`
  line `multi-State co-operative society,`
  line
  line `and if a copy of the representations is not sent as aforesaid because they were received too late or because`
  line `of the multi-State co-operative societys default, the auditor may (without prejudice to his right to be`
  line `heard orally) require that the representations shall be read out at the meeting.`
obj_root_law_sections_71_footnotes:
  string
  line
obj_root_law_sections_72:
  sectionId (1635)
  sectionNo (72)
  orderNo 88
  title `Qualifications disqualifications of auditors.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1635&sectionno=72&orderno=88&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_72_content:
  string
  line `(1) A person shall not be qualified for`
  line `appointment as an auditor of a multi-State co-operative society unless he is a chartered accountant within`
  line `the meaning of the Chartered Accountants Act, 1949 (38 of 1949).`
  line
  line `(2) None of the following persons shall be qualified for appointment as auditor of a multi-State cooperative`
  line society--
  line
  line `(a) a body corporate;`
  line
  line `(b) an officer or employee of the multi-State co-operative society;`
  line
  line `(c) a person who is a member, or who is in the employment, of an officer or employee or the`
  line `multi-State co-operative society;`
  line
  line `(d) a person who is indebted to the multi-State co-operative society or who has given any`
  line `guarantee or provided any security in connection with the indebtedness of any third person to the`
  line `multi-State co-operative society for an amount exceeding one thousand rupees.`
  line
  line `(3) A person shall also not be qualified for appointment as an auditor of a multi-State co-operative`
  line `society if he is, by virtue of sub-section (2), disqualified for appointment as an auditor of any other body`
  line `corporate or multi-State co-operative society or co-operative society.`
  line
  line `(4) If an auditor becomes subject, after his appointment, to any of the disqualifications specified in`
  line `sub-sections (2) and (3), he shall be deemed to have vacated his office as such.`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (1636)
  sectionNo (73)
  orderNo 89
  title `Powers and duties of auditors.`
  content obj_root_law_sections_73_content
  footnotes obj_root_law_sections_73_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1636&sectionno=73&orderno=89&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_73_content:
  string
  line `(1) Every auditor of a multi-State co-operative society shall`
  line `have a right of access at all times to the books, accounts and vouchers of the multi-State co-operative`
  line `society, whether kept at the head office of the multi-State co-operative society or elsewhere, and shall be`
  line `entitled to require from the officers or other employees of the multi-State co-operative society such`
  line `information and explanations as the auditor may think necessary for the performance of his duties as an`
  line auditor.
  line
  line `(2) Without prejudice to provisions of sub-section (1), the auditor shall inquire,--`
  line
  line `(a) whether loans and advances made by the multi-State co-operative society on the basis of`
  line `security have been properly secured and whether the terms on which they have been made are not`
  line `prejudicial to the interests of the multi-State co-operative society or its members;`
  line
  line `(b) whether transactions of the multi-State co-operative society which are represented merely by`
  line `book entries are not prejudicial to the interests of the multi-State co-operative society;`
  line
  line `(c) whether personal expenses have been charged to revenue account; and`
  line
  line `(d) where it is stated in the books and papers of the multi-State co-operative society that any`
  line `shares have been allotted for cash, whether case has actually been received in respect of such`
  line `allotment, and if no cash has actually been so received, whether the position as stated in the account`
  line `books and the balance-sheet is correct, regular and not misleading.`
  line
  line `(3) The auditor shall make a report to the members of the multi-State co-operative society on the`
  line `accounts examined by him and on every balance-sheet and profit and loss account and on every other`
  line `document required to be part or annexed to the balance-sheet or profit and loss account, which are laid`
  line `before the multi-State co-operative society in general meeting during his tenure of office, and the report`
  line `shall state whether, in his opinion and to the best of his information and according to the explanations`
  line `given to him, the said accounts give the information required by this Act in the manner so required and`
  line `give a true and fair view,--`
  line
  line `(a) in the case of the balance-sheet, of the state of the multi-State co-operative society's affairs as`
  line `at the end of its financial year; and`
  line
  line `(b) in the case of the profit and loss account, of the profit or loss for its financial year.`
  line
  line `(4) The auditors report shall also state--`
  line
  line `(a) whether he has obtained all the information and explanations which to the best of his`
  line `knowledge and belief were necessary for the purposes of his audit;`
  line
  line `(b) whether, in his opinion, proper books of account have been kept by the multi-State cooperative`
  line `society so far as appears from his examination of those books, and proper returns adequate`
  line `for the purposes of his audit have been received from branches or offices of the multi-State cooperative`
  line `society not visited by him;`
  line
  line `(c) whether the report on the accounts of any branch office audited by a person other than the`
  line `multi-State co-operative society's auditor has been forwarded to him and how he has dealt with the`
  line `same in preparing the auditors report;`
  line
  line `(d) whether the multi-State co-operative society's balance-sheet and profit and loss account dealt`
  line `with by the report are in agreement with the books of account and returns.`
  line
  line `(5) Where any of the matters referred to in clauses (a) and (b) of sub-section (3) or in clauses (a), (b),`
  line `(c) and (d) of sub-section (4) is answered in the negative or with a qualification, the auditor's report shall`
  line `state the reason for the answer.`
obj_root_law_sections_73_footnotes:
  string
  line
obj_root_law_sections_74:
  sectionId (1637)
  sectionNo (74)
  orderNo 90
  title `Signature of audit report, etc.`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1637&sectionno=74&orderno=90&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_74_content:
  string
  line `Only the person appointed as an auditor of the multi-State cooperative`
  line `society shall sign the auditor's report, or sign or authenticate any other document of the multiState`
  line `co-operative society required by law to be signed or authenticated by the auditor.`
obj_root_law_sections_74_footnotes:
  string
  line
obj_root_law_sections_75:
  sectionId (1638)
  sectionNo (75)
  orderNo 91
  title `Reading and inspection of auditor’s report.`
  content obj_root_law_sections_75_content
  footnotes obj_root_law_sections_75_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1638&sectionno=75&orderno=91&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_75_content:
  string
  line `The auditor's report shall be read before the`
  line `multi-State co-operative society in the general meeting and shall be open to inspection by any member`
  line `of the multi-State co-operative society.`
obj_root_law_sections_75_footnotes:
  string
  line
obj_root_law_sections_76:
  sectionId (1639)
  sectionNo (76)
  orderNo 92
  title `Right of auditor to attend general meeting.`
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1639&sectionno=76&orderno=92&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_76_content:
  string
  line `All notices of, and other communications relating`
  line `to, any general meeting of a multi-State co-operative society, which any member of the multi-State cooperative`
  line `society is entitled to have sent to him, shall also be forwarded to the auditor of the multi-State`
  line `co-operative society; and the auditor shall be entitled to attend any general meeting and to be heard at any`
  line `general meeting which he attends on any part of the business which concerns him as auditor.`
obj_root_law_sections_76_footnotes:
  string
  line
obj_root_law_sections_77:
  sectionId (1640)
  sectionNo (77)
  orderNo 93
  title `Power of Central Government to direct special audit in certain cases.`
  content obj_root_law_sections_77_content
  footnotes obj_root_law_sections_77_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1640&sectionno=77&orderno=93&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_77_content:
  string
  line `(1) Where the Central`
  line `Government is of the opinion--`
  line
  line `(a) that the affairs of any multi-State co-operative society are not being managed in accordance`
  line `with self-help and mutual aid and co-operative principles or prudent commercial practices; or with`
  line `sound business principles; or`
  line
  line `(b) that any multi-State co-operative society is being managed in a manner likely to cause serious`
  line `injury or damage to the interest of the trade, industry or business to which it pertains; or`
  line
  line `(c) that the financial position of any multi-State co-operative society is such as to endanger its`
  line solvency,
  line
  line `the Central Government may at any time by order direct that a special audit of the multi-State cooperative`
  line `society's accounts for such period or periods as may be specified in the order, shall be`
  line `conducted and may by the same or a different order appoint either a chartered accountant as defined in`
  line `clause (b) of sub-section (1) of section 2 of the Chartered Accountants Act, 1949 (38 of 1949) or the`
  line `multi-State co-operative societys auditor himself to conduct with special audit:`
  line
  line `Provided that the Central Government shall not order for special audit of a multi-State co-operative`
  line `society's accounts if that Government or the State Government either by itself or both hold less than fiftyone`
  line `per cent. of the paid up share capital or of the shares in such multi-State co-operative society.`
  line
  line `(2) The chartered accountant or the multi-State co-operative society's auditor appointed under subsection`
  line `(1) to conduct a special audit as aforesaid is hereafter in this section referred to as the special`
  line auditor.
  line
  line `(3) The special auditor shall have the same powers and duties in relation to the special audit as an`
  line `auditor of a multi-State co-operative society has under section 73:`
  line
  line `Provided that the special auditor shall, instead of making his report to the members of the multi-State`
  line `co-operative society, make the same to the Central Government.`
  line
  line `(4) The report of the special auditor shall, as far as may be, include all the matters required to be`
  line `included in the auditors report under section 73 and, if the Central Government so directs, shall also`
  line `include a statement on any other matter which may be referred to him by that Government.`
  line
  line `(5) The Central Government may by order direct any person specified in the order to furnish to the`
  line `special auditor within such time as may be specified therein such information or additional information as`
  line `may be required by the special auditor in connection with the special audit.`
  line
  line `(6) On receipt of the report of the special auditor, the Central Government may take such action on`
  line `the report as it considers necessary in accordance with the provisions of this Act or any other law for the`
  line `time being in force:`
  line
  line `Provided that if the Central Government does not take any action on the report within four months`
  line `from the date of its receipt, that Government shall send to the multi-State co-operative society either a`
  line `copy of, or relevant extract from, the report with its comments thereon and require the multi-State cooperative`
  line `society either to circulate that copy or those extracts to the members or to have such copy or`
  line `extracts read before the multi-State co-operative society at its next general meeting.`
  line
  line `(7) The expenses of, and incidental to, any special audit under this section (including the`
  line `remuneration of the special auditor) shall be determined by the Central Government which determination`
  line `shall be final and paid by the multi-State co-operative society and in default of such payment, shall be`
  line `recoverable from the multi-State co-operative society as an arrear of land revenue.`
obj_root_law_sections_77_footnotes:
  string
  line
obj_root_law_sections_78:
  sectionId (1641)
  sectionNo (78)
  orderNo 94
  title `Inquiry by Central Registrar.`
  content obj_root_law_sections_78_content
  footnotes obj_root_law_sections_78_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1641&sectionno=78&orderno=94&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_78_content:
  string
  line `(1) The Central Registrar may, on a request from a federal cooperative`
  line `to which a multi-State co-operative society is affiliated or a creditor or not less than one-third of`
  line `the members of the board or not less than one-fifth of the total number of members of a multi-State cooperative`
  line `society hold an inquiry or direct some person authorised by him by order in writing in this`
  line `behalf to hold an inquiry into the constitution, working and financial condition of a multi-State cooperative`
  line `society:`
  line
  line `Provided that no inquiry under this sub-section shall be held unless a notice of not less than fifteen`
  line `days has been given to the multi-State co-operative society.`
  line
  line `(2) The Central Registrar or the person authorised by him under sub-section (1) shall have the`
  line `following powers, namely:--`
  line
  line `(a) he shall at all reasonable times have free access to the books, accounts, documents, securities,`
  line `cash and other properties belonging to or in the custody of the multi-State co-operative society and`
  line `may summon any person in possession or responsible for the custody of any such books, accounts,`
  line `documents, securities, cash or other properties to produce the same, at any place specified by him;`
  line
  line `(b) he may, notwithstanding any bye-law specifying the period of notice for a general meeting of`
  line `the multi-State co-operative society, require the officers of the society to call a general meeting of the society by giving notice of not less than seven days at such time and place at the headquarters of the`
  line `society to consider such matters, as may be directed by him; and where the officers of the society`
  line `refuse or fail to call such a meeting, he shall have power to call it himself;`
  line
  line `(c) he may summon any person who is reasonably believed by him to have any knowledge of the`
  line `affairs of the multi-State co-operative society to appear before him at any place at the headquarters of`
  line `the society or any branch thereof and may examine such person on oath.`
  line
  line `(3) Any meeting called under clause (b) of sub-section (2) shall have all the powers of a general`
  line `meeting of the society called under the byelaws of the society and its proceedings shall be regulated by`
  line `such bye-laws.`
  line
  line `(4) The Central Registrar shall, within a period of three months of the date of receipt of the report,`
  line `communicate the report of inquiry to the multi-State co-operative society, the financial institutions, if any,`
  line `to which the society is affiliated, and to the person or authority, if any, at whose instance the inquiry is`
  line made.
obj_root_law_sections_78_footnotes:
  string
  line
obj_root_law_sections_79:
  sectionId (1642)
  sectionNo (79)
  orderNo 95
  title `Inspection of multi-State co-operative societies.`
  content obj_root_law_sections_79_content
  footnotes obj_root_law_sections_79_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1642&sectionno=79&orderno=95&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_79_content:
  string
  line `(1) The Central Registrar may, on a request`
  line `from a federal co-operative to which a multi-State co-operative society is affiliated or a creditor or not`
  line `less than one-third of the members of the board or not less than one-fifth of the total number of members`
  line `of a multi-State co-operative society by general or special order in writing in this behalf, inspect or direct`
  line `any person authorised by him by order in writing in this behalf to make an inspection into the`
  line `constitution, working and financial condition of a multi-State co-operative society:`
  line
  line `Provided that no inspection under this sub-section shall be made unless a notice of not less than`
  line `fifteen days has been given to the multi-State co-operative society.`
  line
  line `(2) (a) For the purpose of inspection under sub-section (1), the Central Registrar or the person`
  line `authorised by him under that subsection shall at all times have access to all books, accounts, papers,`
  line `vouchers, securities, stock and other property of that society and may, in the event of serious irregularities`
  line `discovered during inspection, take them into custody and shall have power to verify the cash balance of`
  line `the society and subject to the general or special order of the Central Registrar to call a meeting of the`
  line `board and also a general meeting of the society where such general meeting is, in his opinion, necessary.`
  line
  line `(b) Every officer or member of a multi-State co-operative society shall furnish such information with`
  line `regard to the working of the society as the Central Registrar or the person making such inspection may`
  line require.
  line
  line `(3) A copy of the report of inspection under this section shall be communicated to the multi-State cooperative`
  line `society within a period of three months from the date of completion of such inspection.`
obj_root_law_sections_79_footnotes:
  string
  line
obj_root_law_sections_80:
  sectionId (1643)
  sectionNo (80)
  orderNo 96
  title `Inspection of books of indebted multi-State co-operative societies.`
  content obj_root_law_sections_80_content
  footnotes obj_root_law_sections_80_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1643&sectionno=80&orderno=96&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_80_content:
  string
  line `(1) The Central Registrar`
  line `shall, on the application of a creditor of a multi-State co-operative society, inspect, or direct some person`
  line `authorised by him by order in writing in this behalf to inspect, the books of the society:`
  line
  line `Provided that no such inspection shall be made unless the applicant--`
  line
  line `(a) satisfies the Central Registrar that the debt is a sum then due, and that he has demanded`
  line `payment thereof and has not received satisfaction within a reasonable time;`
  line
  line `(b) deposits with the Central Registrar such sum as security for the costs of the proposed`
  line `inspection as the Central Registrar may require.`
  line
  line `(2) The Central Registrar shall communicate the result of any such inspection to the creditor.`
obj_root_law_sections_80_footnotes:
  string
  line
obj_root_law_sections_81:
  sectionId (1644)
  sectionNo (81)
  orderNo 97
  title `Costs of inquiry and inspection.`
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1644&sectionno=81&orderno=97&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_81_content:
  string
  line `Where an inquiry is held under section 78 or an inspection is`
  line `made under section 79, the Central Registrar may apportion the costs, or such part of the costs, as he may`
  line `think fit, between the multi-State co-operative society, the members or creditors demanding an inquiry or`
  line `inspection, and the officers or former officers and the members or past members of that society:`
  line
  line `Provided that--`
  line
  line `(a) no order of apportionment of the costs shall be made under this section unless the society or`
  line `the person liable to pay the costs thereunder has had a reasonable opportunity of being heard;`
  line
  line `(b) the Central Registrar shall state in writing under his own hand the grounds on which the costs`
  line `are apportioned.`
obj_root_law_sections_81_footnotes:
  string
  line
obj_root_law_sections_82:
  sectionId (1645)
  sectionNo (82)
  orderNo 98
  title `Recovery of costs.`
  content obj_root_law_sections_82_content
  footnotes obj_root_law_sections_82_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1645&sectionno=82&orderno=98&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_82_content:
  string
  line `Any sum awarded by way of costs under section 81 may be recovered, on`
  line `application to a magistrate having jurisdiction in the place where the person, from whom the money is`
  line `claimable, actually and voluntarily resides or carries on business, and such magistrate shall recover the`
  line `same as if it were a fine imposed by himself.`
obj_root_law_sections_82_footnotes:
  string
  line
obj_root_law_sections_83:
  sectionId (1646)
  sectionNo (83)
  orderNo 99
  title `Repayment, etc.`
  content obj_root_law_sections_83_content
  footnotes obj_root_law_sections_83_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1646&sectionno=83&orderno=99&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_83_content:
  string
  line `(1) If in the course of an audit, inquiry, inspection or the winding up of a`
  line `multi-State co-operative society, it is found that any person, who is or was entrusted with the organisation`
  line `or management of such society or who is or has at any time been an officer or an employee of the society,`
  line `has made any payment contrary to this Act, or the bye-laws or has caused any deficiency in the assets of`
  line `the society by breach of trust or wilful negligence or has misappropriated or fraudulently retained any`
  line `money or other property belonging to such society, the Central Registrar may, of his own motion or on`
  line `the application of the board, liquidator or any creditor inquire himself or direct any person authorised by`
  line `him, by an order in writing in this behalf, to inquire into the conduct of such person within a period of two`
  line `years from the date of the report of the audit, inspection or inquiry or the date of the order of winding up,`
  line `as the case may be:`
  line
  line `Provided that where the Central Registrar is satisfied that such inquiry could not be commenced`
  line `during the period of two years aforesaid on account of fraud or concealment of facts, he may make or`
  line `direct the inquiry to be made within such period not exceeding six years from the date of the report of the`
  line `audit, inspection or inquiry or the date of the order of winding up, as he thinks fit.`
  line
  line `(2) Where an inquiry is made under sub-section (1), the Central Registrar may, after giving the person`
  line `concerned a reasonable opportunity of being heard, make an order requiring him to repay or restore the`
  line `money or property or any part thereof, with interest at such rate, or to pay contribution and costs or`
  line `compensation to such extent, as the Central Registrar may consider just and equitable.`
obj_root_law_sections_83_footnotes:
  string
  line
obj_root_law_sections_84:
  sectionId (1647)
  sectionNo (84)
  orderNo 100
  title `Reference of disputes.`
  content obj_root_law_sections_84_content
  footnotes obj_root_law_sections_84_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1647&sectionno=84&orderno=100&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_84_content:
  string
  line `(1) Notwithstanding anything contained in any other law for the time`
  line `being in force, if any dispute [other than a dispute regarding disciplinary action taken by a multi-State cooperative`
  line `society against its paid employee or an industrial dispute as defined in clause (k) of section 2 of`
  line `the Industrial Disputes Act, 1947 (14 of 1947)] touching the constitution, management or business of a`
  line `multi-State co-operative society arises--`
  line
  line `(a) among members, past members and persons claiming through members, past members and`
  line `deceased members, or`
  line
  line `(b) between a member, past members and persons claiming through a member, past member or`
  line `deceased member and the multi-State co-operative society, its board or any officer, agent or employee`
  line `of the multi-State co-operative society or liquidator, past or present, or`
  line
  line `(c) between the multi-State co-operative society or its board and any past board, any officer,`
  line `agent or employee, or any past officer, past agent or past employee, heirs or legal representatives of`
  line `any deceased officer, deceased agent or deceased employee of the multi-State co-operative society, or`
  line
  line `(d) between the multi-State co-operative society and any other multi-State co-operative society,`
  line `between a multi-State co-operative society and liquidator of another multi-State co-operative society`
  line `or between the liquidator of one multi-State co-operative society and the liquidator of another multiState`
  line `co-operative society,`
  line
  line `such dispute shall be referred to arbitration.`
  line
  line `(2) For the purposes of sub-section (1), the following shall be deemed to be disputes touching the`
  line `constitution, management or business of a multi-State co-operative society, namely:--`
  line
  line `(a) a claim by the multi-State co-operative society for any debt or demand due to it from a`
  line `member or the nominee, heirs or legal representatives of a deceased member, whether such debt or`
  line `demand be admitted or not;`
  line
  line `(b) a claim by a surety against the principal debtor where the multi-State co-operative society has`
  line `recovered from the surety any amount in respect of any debt or demand due to it from the principal`
  line `debtor as a result of the default of the principal debtor, whether such debt or demand is admitted or`
  line not;
  line
  line `(c) any dispute arising in connection with the election of any officer of a multi-State co-operative`
  line society.
  line
  line `(3) If any question arises whether a dispute referred to arbitration under this section is or is not a`
  line `dispute touching the constitution, management or business of a multi-State co-operative society, the`
  line `decision thereon of the arbitrator shall be final and shall not be called in question in any court.`
  line
  line `(4) Where a dispute has been referred to arbitration under sub-section (1), the same shall be settled or`
  line `decided by the arbitrator to be appointed by the Central Registrar.`
  line
  line `(5) Save as otherwise provided under this Act, the provisions of the Arbitration and Conciliation Act,`
  line `1996 (26 of 1996) shall apply to all arbitration under this Act as if the proceedings for arbitration were`
  line `referred for settlement or decision under the provisions of the Arbitration and Conciliation Act, 1996.`
obj_root_law_sections_84_footnotes:
  string
  line
obj_root_law_sections_85:
  sectionId (1648)
  sectionNo (85)
  orderNo 101
  title Limitation.
  content obj_root_law_sections_85_content
  footnotes obj_root_law_sections_85_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1648&sectionno=85&orderno=101&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_85_content:
  string
  line `(1) Notwithstanding anything contained in the Limitation Act, 1963 (36 of 1963),`
  line `but subject to the specific provisions made in this Act, the period of limitation in the case of a dispute`
  line `referred to arbitration shall,--`
  line
  line `(a) when the dispute relates to the recovery of any sum including interest thereon due to a multiState`
  line `co-operative society by a member thereof, be computed from the date on which such member`
  line `dies or ceases to be a member of the society;`
  line
  line `(b) save as otherwise provided in clause (c), when the dispute relates to any act or omission on`
  line `the part of any of the parties referred to in clause (b) or clause (c) or clause (d) of subsection (1) of`
  line `section 84, be six years from the date on which the act or omission, with reference to which the`
  line `dispute arose, took place;`
  line
  line `(c) when the dispute is in respect of an election of an officer of a multi-State co-operative society,`
  line `be one month from the date of the declaration of the result of the election.`
  line
  line `(2) The period of limitation in the case of any dispute, except those mentioned in sub-section (1),`
  line `which are required to be referred to arbitration shall be regulated by the provisions of the Limitation Act,`
  line `1963 (36 of 1963), as if the dispute were a suit and the arbitrator a civil court.`
  line
  line `(3) Notwithstanding anything contained in sub-sections (1) and (2), the arbitrator may admit a dispute`
  line `after the expiry of the period of limitation, if the applicant satisfies the arbitrator that he had sufficient`
  line `cause for not referring the dispute within such period.`
obj_root_law_sections_85_footnotes:
  string
  line
obj_root_law_sections_85_a:
  sectionId (76484)
  sectionNo 85A
  orderNo 102
  title `Co-operative Ombudsman.`
  content obj_root_law_sections_85_a_content
  footnotes `1. Ins. by s. 31, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76484&sectionno=85A&orderno=102&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_85_a_content:
  string
  line `^1[85A. Co-operative Ombudsman.-- (1) The Central Government shall appoint, one or more Cooperative Ombudsman with territorial jurisdiction for inquiring into the complaints made by any member`
  line `of the multi-State co-operative societies regarding their deposits, equitable benefits of society’s`
  line `functioning or any other issue affecting the individual rights of the concerned member, in such manner, as`
  line `may be prescribed.`
  line
  line `(2) The Co-operative Ombudsman shall, on receipt of a complaint, complete the process of inquiry`
  line `and adjudicate within a period of three months from the date of receipt of the complaint and may issue`
  line `necessary directions to the society during the course of inquiry and the society shall be bound to comply`
  line `with the same within a period of one month from the date of issuance of such directions.`
  line
  line `(3) The multi-State co-operative society aggrieved by any directions of the Ombudsman may file an`
  line `appeal in such manner as may be prescribed, within a period of one month before the Central Registrar`
  line `who shall decide the appeal within a period of forty-five days and the decision of the Central Registrar`
  line `shall be final and binding:`
  line
  line `Provided that the Central Registrar may entertain the appeal after the expiry of said period of one`
  line `month, if he is satisfied that the society was prevented by sufficient cause from preferring the appeal in`
  line time.
  line
  line `(4) The Ombudsman shall submit periodic reports to the Central Registrar of Co-operative Societies.`
  line
  line `(5) The Co-operative Ombudsman while conducting the inquiry under sub-section (1), shall exercise`
  line `the same powers as are vested in a civil court under the Code of Civil Procedure, 1908, (5 of 1908)---`
  line
  line `(a) for summoning and enforcing the attendance of persons;`
  line
  line `(b) examining them on oath;`
  line
  line `(c) discovery and production of books of account and other documents; and`
  line
  line `(d) any other matter which may be prescribed.]`
obj_root_law_sections_86:
  sectionId (1649)
  sectionNo (86)
  orderNo 103
  title `Winding up of multi-State co-operative societies.`
  content obj_root_law_sections_86_content
  footnotes obj_root_law_sections_86_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1649&sectionno=86&orderno=103&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_86_content:
  string
  line `(1) If the Central Registrar, after audit has`
  line `been conducted under section 70 or special audit has been conducted under section 77 or an inquiry has`
  line `been held under section 78 or an inspection has been made under section 79, is of opinion that the society`
  line `ought to be wound up, he may, after giving the society a reasonable opportunity of making its`
  line `representations by order, direct it to be wound up.`
  line
  line `(2) The Central Registrar may, of his own motion and after giving the multi-State co-operative`
  line `society a reasonable opportunity of making its representation, make an order directing the winding up of`
  line `the multi-State co-operative society,--`
  line
  line `(a) where it is a condition of the registration of the society that the society shall consist of at least`
  line `fifty members and the number of members has been reduced to less than fifty; or`
  line
  line `(b) where the multi-State co-operative society has not commenced working within a period of six`
  line `months of the date of its registration or such extended period as the Central Registrar may allow in`
  line `this behalf or has ceased to function in accordance with co-operative principles.`
  line
  line `(3) The Central Registrar may cancel an order for the winding up of a multi-State co-operative`
  line `society, at any time, in any case where, in his opinion, the society should continue to exist.`
  line
  line `(4) A copy of such order shall be communicated by registered post to the multi-State co-operative`
  line `society and to the financial institutions, if any, of which the society is a member.`
  line
  line `(5) Notwithstanding anything contained in this section, no co-operative bank shall be wound up`
  line `except with the previous sanction, in writing of the Reserve Bank.`
  line
  line `(6) Notwithstanding anything contained in this section, the Central Registrar shall make an order for`
  line `the winding up of a multi-State co-operative society, if the society, by a resolution passed by two-third`
  line `majority of members present and voting in a general meeting decides for winding up of that society.`
obj_root_law_sections_86_footnotes:
  string
  line
obj_root_law_sections_87:
  sectionId (1650)
  sectionNo (87)
  orderNo 104
  title `Winding up of co-operative bank at the direction of Reserve Bank.`
  content obj_root_law_sections_87_content
  footnotes obj_root_law_sections_87_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1650&sectionno=87&orderno=104&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_87_content:
  string
  line Notwithstanding
  line `anything to the contrary contained elsewhere in this Act, the Central Registrar shall make an order for the`
  line `winding up of a co-operative bank, if so required by the Reserve Bank in the circumstances mentioned in`
  line `section 13D of the Deposit Insurance and Credit Guarantee Corporation Act, 1961 (47 of 1961).`
obj_root_law_sections_87_footnotes:
  string
  line
obj_root_law_sections_88:
  sectionId (1651)
  sectionNo (88)
  orderNo 105
  title `Reimbursement to the Deposit Insurance Corporation by liquidator.`
  content obj_root_law_sections_88_content
  footnotes obj_root_law_sections_88_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1651&sectionno=88&orderno=105&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_88_content:
  string
  line `Where a co-operative`
  line `bank, being an insured bank within the meaning of the Deposit Insurance and Credit Guarantee`
  line `Corporation Act, 1961, is wound up and the Deposit Insurance Corporation has become liable to the`
  line `depositors of the insured bank under sub-section (1) of section 16 of that Act, the Deposit Insurance`
  line `Corporation shall be reimbursed by the liquidator or such other person in the circumstances, to the extent`
  line `and in the manner provided in section 21 of that Act.`
obj_root_law_sections_88_footnotes:
  string
  line
obj_root_law_sections_89:
  sectionId (1652)
  sectionNo (89)
  orderNo 106
  title Liquidator.
  content obj_root_law_sections_89_content
  footnotes obj_root_law_sections_89_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1652&sectionno=89&orderno=106&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_89_content:
  string
  line `(1) Where the Central Registrar has made an order under section 86 for the winding`
  line `up of multi-State co-operative society, the Central Registrar may appoint a liquidator for the purpose and`
  line `fix his remuneration.`
  line
  line `(2) A liquidator shall, on appointment, take into his custody or under his control all the property,`
  line `effects and actionable claims to which the multi-State co-operative society is or appears to be entitled and`
  line `shall take such steps as he may deem necessary or expedient to prevent loss or deterioration of, or damage`
  line `to, such property, effects and claims and he may carry on the business of the multi-State co-operative`
  line `society so far as may be necessary with the previous approval of the Central Registrar.`
  line
  line `(3) Where an appeal is preferred under clause (f) of sub-section (1) of section 99, an order for the`
  line `winding up of a multi-State co-operative society made under section 86 shall not operate thereafter until`
  line `the order is confirmed in appeal:`
  line
  line `Provided that the liquidator shall continue to have custody or control of the property, effects and`
  line `actionable claims mentioned in subsection (2) and have authority to take the steps referred to in that subsection.`
  line
  line `(4) Where an order for the winding up of a multi-State co-operative society is set aside in appeal, the`
  line `property, effects and actionable claims of the society shall re-vest in the society.`
obj_root_law_sections_89_footnotes:
  string
  line
obj_root_law_sections_90:
  sectionId (1653)
  sectionNo (90)
  orderNo 107
  title `Powers of liquidator.`
  content obj_root_law_sections_90_content
  footnotes obj_root_law_sections_90_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1653&sectionno=90&orderno=107&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_90_content:
  string
  line `(1) Subject to any rules made in this behalf, the whole of the assets of a`
  line `multi-State co-operative society in respect of which an order for winding up has been made, shall vest in`
  line `the liquidator appointed under section 89 from the date on which the order takes effect and the liquidator`
  line `shall have power to realise such assets by sale or otherwise.`
  line
  line `(2) Such liquidator shall also have power, subject to the control of the Central Registrar--`
  line
  line `(a) to institute and defend suits and other legal proceedings on behalf of the multi-State cooperative`
  line `society by the name of his office;`
  line
  line `(b) to determine from time to time the contribution (including debts due and costs of liquidation)`
  line `to be made or remaining to be made by the members or past members or by the estates or nominees,`
  line `heirs or legal representatives of the deceased members or by any officers or former officers, to the`
  line `assets of the multi-State co-operative society;`
  line
  line `(c) to investigate all claims against the multi-State co-operative society and subject to the`
  line `provisions of this Act, to decide questions of priority arising between claimants;`
  line
  line `(d) to pay claims against the multi-State co-operative society, including interest up to the date of`
  line `winding up according to their respective priorities, if any, in full or rateably, as the assets of the`
  line `society may permit; and the surplus, if any, remaining after payment of the claims being applied in`
  line `payment of interest from the date of such order or winding up at a rate fixed by him but not exceeding`
  line `the contract rate in any case;`
  line
  line `(e) to determine by what persons and in what proportions the costs of the liquidation are to be`
  line borne;
  line
  line `(f) to determine whether any person is a member, past member or nominee of a deceased`
  line member;
  line
  line `(g) to give such directions in regard to the collection and distribution of the assets of the multiState`
  line `co-operative society as may appear to him to be necessary for winding up the affairs of that`
  line society;
  line
  line `(h) to carry on the business of the multi-State co-operative society so far as may be necessary for`
  line `the beneficial winding up of the same;`
  line
  line `(i) to make any compromise or arrangement with creditors or persons claiming to be creditors or`
  line `having or alleging to have any claim, present or future, whereby the multi-State co-operative society`
  line `may be rendered liable;`
  line
  line `(j) to make any compromise or arrangement with any person between whom and the multi-State`
  line `co-operative society there exists any dispute and to refer any such dispute for decision;`
  line
  line `(k) after consulting the members of the multi-State co-operative society, to dispose of the surplus,`
  line `if any, remaining after paying the claims against the society, in such manner as may be prescribed;`
  line
  line `(l) to compromise all calls or liabilities to calls and debts and liabilities capable of resulting in`
  line `debts, and all claims, present or future, certain or contingent, subsisting or alleged to be subsisting`
  line `between the multi-State co-operative society and a contributory or other debtor or person`
  line `apprehending liability to the multi-State co-operative society and all questions in any way relating to`
  line `or affecting the assets or the winding up of the society on such terms as may be agreed and take any`
  line `security for the discharge of any such call, liability, debt or claim and give a complete discharge in`
  line `respect thereof.`
  line
  line `(3) When the affairs of a multi-State co-operative society have been wound up, the liquidator shall`
  line `make a report to the Central Registrar and deposit the records of the society in such place as the Central`
  line `Registrar may direct.`
obj_root_law_sections_90_footnotes:
  string
  line
obj_root_law_sections_91:
  sectionId (1654)
  sectionNo (91)
  orderNo 108
  title `Disposal of surplus assets.`
  content obj_root_law_sections_91_content
  footnotes obj_root_law_sections_91_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1654&sectionno=91&orderno=108&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_91_content:
  string
  line `The surplus assets, as shown in the report of a liquidator of a multiState`
  line `co-operative society which is wound up,--`
  line
  line `(a) may, if the bye-laws of the multi-State co-operative society specify the purpose for which`
  line `surplus shall be utilised, be utilised by the Central Registrar for the said purpose, and`
  line
  line `(b) if the bye-laws aforesaid do not specify the purpose, be divided by the Central Registrar with`
  line `the previous sanction of the Central Government, amongst the members of such multi-State cooperative`
  line `society in such manner as may be prescribed.`
obj_root_law_sections_91_footnotes:
  string
  line
obj_root_law_sections_92:
  sectionId (1655)
  sectionNo (92)
  orderNo 109
  title `Priority of contributions assessed by liquidator.`
  content obj_root_law_sections_92_content
  footnotes obj_root_law_sections_92_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1655&sectionno=92&orderno=109&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_92_content:
  string
  line `Notwithstanding anything contained in any`
  line `law relating to insolvency, the contribution assessed by a liquidator shall rank next to debts due to the`
  line `Central Government or a State Government or a local authority in accordance with the order of priority in`
  line `insolvency proceedings.`
obj_root_law_sections_92_footnotes:
  string
  line
obj_root_law_sections_93:
  sectionId (1656)
  sectionNo (93)
  orderNo 110
  title `Power of Central Registrar to cancel registration of a multi-State co-operative society.`
  content obj_root_law_sections_93_content
  footnotes obj_root_law_sections_93_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1656&sectionno=93&orderno=110&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_93_content:
  string
  line `(1)`
  line `The Central Registrar may, after considering the report of the liquidator made to him under sub-section`
  line `(3) of section 90, order the registration of the multi-State co-operative society to be cancelled and on such`
  line `cancellation, that society shall stand dissolved.`
  line
  line `(2) An order passed under sub-section (1) shall be communicated by registered post to the president`
  line `or the chairperson as the case may be, of the multi-State co-operative society and to the financial`
  line `institutions, if any, of which the society was a member.`
obj_root_law_sections_93_footnotes:
  string
  line
obj_root_law_sections_94:
  sectionId (1657)
  sectionNo (94)
  orderNo 111
  title `Execution of decisions, etc.`
  content obj_root_law_sections_94_content
  footnotes obj_root_law_sections_94_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1657&sectionno=94&orderno=111&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_94_content:
  string
  line `Every decision or order made under section 39 or section 40 or`
  line `section 83 or section 99 or section 101 shall, if not carried out,--`
  line
  line `(a) on a certificate signed by the Central Registrar or any person authorised by him in writing in`
  line `this behalf, be deemed to be a decree of a civil court and shall be executed in the same manner as if it`
  line `were a decree of such court and such decree shall be executed by the Central Registrar or any person`
  line `authorised by him or it in writing in this behalf, by attachment and sale or sale without attachment of`
  line `any property of the person or a multi-State co-operative society against whom the decision or order`
  line `has been made; or`
  line
  line `(b) where the decision or order provides for the recovery of money, by executed according to law`
  line `for the time being in force for the recovery of arrears of land revenue:`
  line
  line `Provided that any application for the recovery of any sum shall be made in such manner--`
  line
  line `(i) to the Collector and shall be accompanied by a certificate signed by the Central Registrar`
  line `or by any person authorised by him in writing in this behalf;`
  line
  line `(ii) within twelve years from the date fixed in the decision or order and if no such date is`
  line `fixed, from the date of decision or order, as the case may be; or`
  line
  line `(c) be executed by the Central Registrar or any person authorised by him in writing in this behalf,`
  line `by attachment and sale or sale without attachment of any property of the person or a multi-State cooperative`
  line `society against whom the decision or order has been made.`
obj_root_law_sections_94_footnotes:
  string
  line
obj_root_law_sections_95:
  sectionId (1658)
  sectionNo (95)
  orderNo 112
  title `Execution of orders of liquidators.`
  content obj_root_law_sections_95_content
  footnotes obj_root_law_sections_95_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1658&sectionno=95&orderno=112&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_95_content:
  string
  line `Every order made by the liquidator under section 90 shall`
  line `be executed according to the law for the time being in force for the recovery of arrears of land revenue.`
obj_root_law_sections_95_footnotes:
  string
  line
obj_root_law_sections_96:
  sectionId (1659)
  sectionNo (96)
  orderNo 113
  title `Attachment before award.`
  content obj_root_law_sections_96_content
  footnotes obj_root_law_sections_96_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1659&sectionno=96&orderno=113&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_96_content:
  string
  line `(1) Where the arbitrator is satisfied that a party to any reference`
  line `made to him under section 84 with intent to defeat or delay the execution of any decision that may be`
  line `passed thereon is about to--`
  line
  line `(a) dispose of the whole or any part of the property; or`
  line
  line `(b) remove the whole or any part of the property from its existing precincts,`
  line
  line `the arbitrator may, unless adequate security is furnished, direct conditional attachment of the said property`
  line `or such part thereof as he deems necessary.`
  line
  line `(2) The attachment under sub-section (1) shall be executed by a civil court having jurisdiction in the`
  line `same way as an attachment order passed by itself and shall have the same effect as such order.`
obj_root_law_sections_96_footnotes:
  string
  line
obj_root_law_sections_97:
  sectionId (1660)
  sectionNo (97)
  orderNo 114
  title `Central Registrar or arbitrator or person authorised to be civil court for certain purposes.`
  content obj_root_law_sections_97_content
  footnotes obj_root_law_sections_97_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1660&sectionno=97&orderno=114&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_97_content:
  string
  line `The Central Registrar or the arbitrator or any person authorised by him in writing in this`
  line `behalf shall be deemed, when exercising any powers under this Act for the recovery of any amount by the`
  line `attachment and sale or by sale without attachment of any property, or when passing any orders on any`
  line `application made to him for such recovery or for taking a step-in-aid of such recovery, to be a civil court`
  line `for the purposes of article 136 of the Schedule to the Limitation Act, 1963 (36 of 1963).`
obj_root_law_sections_97_footnotes:
  string
  line
obj_root_law_sections_98:
  sectionId (1661)
  sectionNo (98)
  orderNo 115
  title `Recovery of sums due to Government.`
  content obj_root_law_sections_98_content
  footnotes obj_root_law_sections_98_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1661&sectionno=98&orderno=115&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_98_content:
  string
  line `(1) All sums due from a multi-State co-operative`
  line `society, or from an officer or member or past member of a multi-State co-operative society, to the Central`
  line `Government or a State Government, including any cost awarded to the Central Government or the State`
  line `Government, as the case may be, under any provision of this Act, may, on a certificate issued by the`
  line `Central Registrar in this behalf, be recovered in the same manner as arrears of land revenue as first charge`
  line `on the assets of such society or officer or member, as the case may be.`
  line
  line `(2) Sums due from a multi-State co-operative society to the Central Government or a State`
  line `Government and recoverable under sub-section (1) may be recovered firstly from the property of the`
  line `society and secondly from the members, past members or the estates of deceased members, subject to the`
  line `limit of their liability:`
  line
  line `Provided that the liability of past members and the estate of deceased members shall in all cases be`
  line `subject to the provisions of section 37.`
obj_root_law_sections_98_footnotes:
  string
  line
obj_root_law_sections_98_a:
  sectionId (76485)
  sectionNo 98A
  orderNo 116
  title `Review of decision.`
  content obj_root_law_sections_98_a_content
  footnotes `1. Ins. by s. 34, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76485&sectionno=98A&orderno=116&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_98_a_content:
  string
  line `^1[98A. Review of decision.-- The Central Registrar may, on an application received from any party,`
  line `review his decision under clause (a) or clause (b) or clause (c) of sub-section (1) of section 94:`
  line
  line `Provided that no application for review shall be entertained against the recovery certificate issued by`
  line `the Central Registrar or by any person authorised by him in writing in this behalf, unless the applicant`
  line `deposits with the concerned society, fifty per cent. of the amount of the recoverable dues:`
  line
  line `Provided further that no application for review shall be entertained, if made after sixty days of the`
  line `date of receipt of the decision or order:`
  line
  line `Provided also that the Central Registrar may entertain any such application made after such period, if`
  line `the applicant satisfies that he had sufficient cause for not making the application within such period.]`
obj_root_law_sections_99:
  sectionId (49367)
  sectionNo (99)
  orderNo 117
  title Appeals.
  content obj_root_law_sections_99_content
  footnotes obj_root_law_sections_99_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=49367&sectionno=99&orderno=117&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_99_content:
  string
  line `(1) Subject to the provisions of section 100, an appeal shall lie under this section`
  line against--
  line
  line `(a) an order made by the Central Registrar under sub-section (3) of section 7 refusing to register a`
  line `multi-State co-operative society;`
  line
  line `(b) an order made by the Central Registrar under sub-section (9) of section 11 refusing to register`
  line `an amendment of the bye-laws of a multi-State co-operative society;`
  line
  line `(c) a decision of a multi-State co-operative society refusing or deemed to be refusing under subsection`
  line `(4) of section 25 to admit any person as a member of the society who is otherwise duly`
  line `qualified for membership under the bye-laws of the society;`
  line
  line `(d) an order made by the Central Registrar under section 81 apportioning the costs of an inquiry`
  line `held under section 78 or an inspection made under section 80;`
  line
  line `(e) an order made by the Central Registrar under sub-section (2) of section 83;`
  line
  line `(f) an order made by the Central Registrar under section 86 directing the winding up of a multiState`
  line `co-operative society;`
  line
  line `(g) an order made by the liquidator of a multi-State co-operative society under section 90.`
  line
  line `(2) An appeal against any decision or order under sub-section (1) shall be made within sixty days`
  line `from the date of such decision or order to the prescribed appellate authority.`
  line
  line `(3) The appellate authority may, if satisfied that the appellant was prevented by sufficient cause from`
  line `preferring the appeal within the period of sixty days, admit the appeal within such further period as that`
  line `authority may deem fit.`
  line
  line `(4) In disposing of an appeal under this section, the appellate authority may, after giving the parties a`
  line `reasonable opportunity of making their representation, pass such order thereon as that authority may deem`
  line fit.
  line
  line `(5) The decision or order of the appellate authority on appeal shall be final.`
obj_root_law_sections_99_footnotes:
  string
  line
obj_root_law_sections_100:
  sectionId (1663)
  sectionNo (100)
  orderNo 118
  title `No appeal in certain cases.`
  content obj_root_law_sections_100_content
  footnotes obj_root_law_sections_100_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1663&sectionno=100&orderno=118&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_100_content:
  string
  line `Notwithstanding anything contained in this Act, where, with the`
  line `previous sanction in writing of, or on requisition by, the Reserve Bank, a co-operative bank--`
  line
  line `(a) is being wound up; or`
  line
  line `(b) in respect of which a scheme of amalgamation or reorganisation is given effect to,`
  line
  line `no appeal there against shall lie or be permissible, and the sanction or requisition of the Reserve Bank`
  line `shall not be liable to be called in question.`
obj_root_law_sections_100_footnotes:
  string
  line
obj_root_law_sections_101:
  sectionId (1664)
  sectionNo (101)
  orderNo 119
  title Review.
  content obj_root_law_sections_101_content
  footnotes obj_root_law_sections_101_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1664&sectionno=101&orderno=119&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_101_content:
  string
  line `(1) The appellate authority referred to in section 99, may, on the application of any`
  line `party, review its own order in any case and pass in reference thereto such orders as it thinks fit:`
  line
  line `Provided that no such application shall be entertained unless the appellate authority is satisfied that`
  line `there has been a discovery of new and important matter or evidence which after exercise of due diligence`
  line `was not within the knowledge of the applicant or could not be produced by him at the time when the order`
  line `was made or that there has been some mistake or error apparent on the face of the record or for any other`
  line `sufficient reason:`
  line
  line `Provided further that no such order shall be made under this sub-section unless notice has been given`
  line `to all interested parties and they have been afforded a reasonable opportunity of being heard.`
  line
  line `(2) An application for review under sub-section (1) by any party shall be made within thirty days`
  line `from the date of communication of the order of the appellate authority sought to be reviewed.`
obj_root_law_sections_101_footnotes:
  string
  line
obj_root_law_sections_102:
  sectionId (1665)
  sectionNo (102)
  orderNo 120
  title `Interlocutory orders.`
  content obj_root_law_sections_102_content
  footnotes obj_root_law_sections_102_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1665&sectionno=102&orderno=120&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_102_content:
  string
  line `Where an appeal is made under section 99, the appellate authority may`
  line `in order to prevent the ends of justice being defeated, make such interlocutory orders, including an order`
  line `of stay pending the decision of the appeal as such authority may deem fit.`
obj_root_law_sections_102_footnotes:
  string
  line
obj_root_law_sections_103:
  sectionId (1666)
  sectionNo (103)
  orderNo 121
  title `Co-operative societies functioning immediately before reorganisation of States.`
  content obj_root_law_sections_103_content
  footnotes obj_root_law_sections_103_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1666&sectionno=103&orderno=121&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_103_content:
  string
  line `(1) Where,`
  line `by virtue of the provisions of Part II of the State Reorganisation Act, 1956 (37 of 1956) or any other`
  line `enactment relating to reorganisation of states, any co-operative society which immediately before the day`
  line `on which the reorganisation takes place, had its objects confined to one state becomes, as from that day, a`
  line `multi-State co-operative society, it shall be deemed to be a multi-State co-operative society registered`
  line `under the corresponding provisions of this Act and the bye-laws of such society shall, in so far as they are`
  line `not inconsistent with the provisions of this Act, continue to be in force until altered or rescinded.`
  line
  line `(2) If it appears to the Central Registrar or any officer authorised in this behalf by the Central`
  line `Government (hereafter in this section referred to as the authorised officer) that it is necessary or expedient`
  line `to reconstitute or reorganise any society referred to in sub-section (1), the Central Registrar or the`
  line `authorised officer, as the case may be, may, with the previous approval of the Central Government, places`
  line `before a meeting of the general body of that society, held in such manner as may be prescribed, a scheme`
  line `for the reconstitution or reorganisation, including proposals regarding--`
  line
  line `(a) the formation of new multi-State co-operative societies and the transfer thereto in whole or in`
  line `part, of the assets and liabilities of that society; or`
  line
  line `(b) the transfer, in whole or in part, of the assets and liabilities of that society to any other multiState`
  line `co-operative society in existence immediately before the date of that meeting of the general`
  line `body (hereafter in this section referred to as the existing multi-State co-operative society).`
  line
  line `(3) If the scheme is sanctioned by a resolution passed by a majority of the members present at the said`
  line `meeting, either without modifications or with modifications to which the Central Registrar or the`
  line `authorised officer agrees, he shall certify the scheme and upon such certification, the scheme shall,`
  line `notwithstanding anything to the contrary contained in any law, regulation or bye-laws for the time being`
  line `in force, be binding on all the societies affected by the scheme, as well as the shareholders and creditors`
  line `of all such societies.`
  line
  line `(4) If the scheme is not sanctioned under sub-section (3), the Central Registrar or the authorised`
  line `officer may refer the scheme to such judge of the appropriate High Court, as may be nominated in this`
  line `behalf by the Chief Justice thereof, and the decision of that judge in regard to the scheme shall be final`
  line `and shall be binding on all the societies affected by the scheme as well as the shareholders and creditors`
  line `of all such societies.`
  line
  line `Explanation.--For the purposes of this sub-section, "appropriate High Court" means the High Court`
  line `within the local limits of whose jurisdiction the principal place of business of the multi-State co-operative`
  line `society is situated.`
  line
  line `(5) Notwithstanding anything contained in this section, where a scheme under sub-section (2)`
  line `includes any proposal regarding the transfer of the assets and liabilities of any multi-State co-operative`
  line `society referred to in clause (b) thereof, the scheme shall not be binding on such multi-State co-operative`
  line `society or the shareholders and creditors thereof, unless the proposal regarding such transfer is accepted`
  line `by that multi-State co-operative society by a resolution passed by a majority of the members present at a`
  line `meeting of its general body.`
obj_root_law_sections_103_footnotes:
  string
  line
obj_root_law_sections_104:
  sectionId (1667)
  sectionNo (104)
  orderNo 122
  title `Offences and penalties.`
  content obj_root_law_sections_104_content
  footnotes obj_root_law_sections_104_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1667&sectionno=104&orderno=122&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_104_content:
  string
  line `(1) A multi-State co-operative society or an officer or member thereof`
  line `wilfully making a false return or furnishing false information, or any person wilfully or without any`
  line `reasonable excuse disobeying any summons, requisition or lawful written order issued under the`
  line `provisions of this Act, or wilfully not furnishing any information required from him by a person`
  line `authorised in this behalf under the provisions of this Act, shall be punishable with fine which shall not be`
  line `less than two thousand rupees and which may extend to ten thousand rupees.`
  line
  line `(2) Any employer who, without sufficient cause, fails to pay to a multi-State co-operative society the`
  line `amount deducted by him under section 60 within a period of fourteen days from the date on which such`
  line `deduction is made shall, without prejudice to any action that may be taken against him under any other`
  line `law for the time being in force, be punishable with fine which may extend to five thousand rupees.`
  line
  line `(3) Any officer or custodian who wilfully fails to hand over custody of books, accounts, documents,`
  line `records, cash, security and other property belonging to a multi-State co-operative society of which he is`
  line `an officer or custodian, to a person entitled under section 54, or section 70, or section 78, or section 79, or`
  line `section 89 shall be punishable with fine which may extend to two thousand rupees and in the case of a`
  line `continuing breach, with a further fine which may extend to five thousand rupees for every day during`
  line `which the breach is continued after conviction for the first such breach.`
  line
  line `(4) Whoever, before, during or after the election of delegates under the proviso to sub-section (1) of`
  line `section 38 or election of members of the board,--`
  line
  line `(a) fraudulently defaces or fraudulently destroys any nomination paper; or`
  line
  line `(b) fraudulently defaces, destroys or removes any list, notice or other document affixed by or`
  line `under the authority of a returning officer; or`
  line
  line `(c) fraudulently defaces or fraudulently destroys any ballot paper or the official mark on any`
  line `ballot paper or any declaration of identity; or`
  line
  line `(d) without due authority supplies any ballot paper to any person or received any ballot paper`
  line `from any person or is in possession of any ballot papers; or`
  line
  line `(e) fraudulently puts into any ballot box anything other than the ballot paper which he is`
  line `authorised by law to put in; or`
  line
  line `(f) without due authority destroys, takes, opens or otherwise interferes, with any ballot box or`
  line `ballot papers then in use for the purposes of the election; or`
  line
  line `(g) fraudulently or without due authority, as the case may be, attempts to do any of the foregoing`
  line `acts or wilfully aids or abets the doing of any such acts;`
  line
  line `(h) offers any gift or promises to offer any gratification to any person with the object, directly or`
  line `indirectly, of including--`
  line
  line `(i) a person to stand or not to stand as, or to withdraw or not to withdraw from, being a`
  line `candidate at an election; or`
  line
  line `(ii) a member to vote or refrain from voting at an election, or as a reward to a person for`
  line `having so stood or not stood or for having withdrawn or not having withdrawn his candidature; or`
  line
  line `(iii) a member for having voted or refrained from voting,`
  line
  line `shall be punishable with imprisonment for a term which may extend to six months or with fine or with`
  line both.
obj_root_law_sections_104_footnotes:
  string
  line
obj_root_law_sections_105:
  sectionId (1668)
  sectionNo (105)
  orderNo 123
  title `Cognizance of offences.`
  content obj_root_law_sections_105_content
  footnotes obj_root_law_sections_105_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1668&sectionno=105&orderno=123&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_105_content:
  string
  line `(1) No court inferior to that of a Metropolitan Magistrate or a Judicial`
  line `Magistrate of the first class shall try any offence under this Act.`
  line
  line `(2) No prosecution for offences under section 104 shall be instituted except on a complaint filed in`
  line `writing by a member of a multi-State co-operative society or by the Central Registrar in the competent`
  line court.
obj_root_law_sections_105_footnotes:
  string
  line
obj_root_law_sections_105_a:
  sectionId (76486)
  sectionNo 105A
  orderNo 124
  title `Provisions of this Act not in derogation of any other law.`
  content obj_root_law_sections_105_a_content
  footnotes `1. Ins. by Act 11 of 2023, s. 38 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76486&sectionno=105A&orderno=124&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_105_a_content:
  string
  line `^1[105A. Provisions of this Act not in derogation of any other law.-- The provisions of this Act`
  line `shall be in addition to, and not in derogation of, any other law for the time being in force.]`
obj_root_law_sections_106:
  sectionId (1669)
  sectionNo (106)
  orderNo 125
  title `Appointment of Co-operative Information Officer.`
  content obj_root_law_sections_106_content
  footnotes `1. Subs. by s. 39, ibid., for section 106 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1669&sectionno=106&orderno=125&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_106_content:
  string
  line `^1[106. Appointment of Co-operative Information Officer.-- (1) Every multi-State co-operative`
  line `society shall appoint a Co-operative Information Officer to provide the information relating to affairs and`
  line `management of the society to the members of the society and such information shall be confined to the`
  line `information falling under the disclosure norms specified by the society in its bye-laws.`
  line
  line `(2) Any member of multi-State co-operative society shall make an application, accompanying such`
  line `fee as may be prescribed, to get information specified in sub-section (1).`
  line
  line `(3) The Co-operative Information Officer shall, within thirty days from the date of receipt of`
  line `application, either provide the information or reject the application specifying the reason to do so.`
  line
  line `(4) Any member of the multi-State co-operative society whose application has been rejected may`
  line `prefer an appeal to the Co-operative Ombudsman within a period of one month from the date of such`
  line `rejection and his decision shall be final and binding.]`
obj_root_law_sections_106_a:
  sectionId (76487)
  sectionNo 106A
  orderNo 126
  title `Copy of rules and bye-laws, etc., for inspection.`
  content obj_root_law_sections_106_a_content
  footnotes `1. Subs. by s. 39, ibid., for section 106 (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76487&sectionno=106A&orderno=126&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_106_a_content:
  string
  line `[106A. Copy of rules and bye-laws, etc., for inspection.--Every Chief Executive of multi-State`
  line `co-operative society shall keep a copy of the rules and its bye-laws and also a list of its members, open to`
  line `inspection free of charge at all reasonable times, at the registered address of the multi-State co-operative`
  line society.]
obj_root_law_sections_107:
  sectionId (1670)
  sectionNo (107)
  orderNo 127
  title `Place of keeping and inspection of, registers and returns.`
  content obj_root_law_sections_107_content
  footnotes obj_root_law_sections_107_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1670&sectionno=107&orderno=127&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_107_content:
  string
  line `(1) The register of members`
  line `commencing from the date of the registration of multi-State co-operative society, the index of members,`
  line `the register of debenture holders, and copies of all annual returns prepared together with the copies of`
  line `certificates and documents, shall be kept at the registered office of the multi-State co-operative society.`
  line
  line `(2) The registers, indexes, returns and copies of certificates and other documents referred to in subsection`
  line `(1) shall be open during business hours (subject to such reasonable restrictions, as the multi-State`
  line `co-operative society may impose, so that not less than two hours in each day are allowed for inspection)`
  line `to the inspection--`
  line
  line `(a) of any member or debenture holder, without fee; and`
  line
  line `(b) of any other person, on payment of such sum as may be prescribed for each inspection.`
obj_root_law_sections_107_footnotes:
  string
  line
obj_root_law_sections_108:
  sectionId (1671)
  sectionNo (108)
  orderNo 128
  title `Inspection of books of account, etc., of multi-State co-operative society.`
  content obj_root_law_sections_108_content
  footnotes obj_root_law_sections_108_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1671&sectionno=108&orderno=128&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_108_content:
  string
  line `(1) The books of`
  line `account and other books and papers of every multi-State co-operative society shall be open to inspection`
  line `during business hours--`
  line
  line `(i) by the Central Registrar, or`
  line
  line `(ii) by such officer of the Government as may be authorised by the Central Government in this`
  line `behalf:`
  line
  line `Provided that such inspection may be made without giving any previous notice to that society or`
  line `any officer thereof;`
  line
  line `(iii) by the members of the multi-State co-operative society.`
  line
  line `(2) It shall be the duty of every director, other officer or employee of the multi-State co-operative`
  line `society to produce to the person making inspection under sub-section (1), all such books of account and`
  line `other books and papers of the multi-State co-operative society in his custody or control and to furnish him`
  line `with any statement, information or explanation relating to the affairs of such society as the said person`
  line `may require of him within such time and at such place as he may specify.`
  line
  line `(3) It shall also be the duty of every director, other officer or employee of the multi-State co-operative`
  line `society to give to the person making inspection under this section all assistance in connection with the`
  line `inspection which the multi-State co-operative society may be reasonably expected to give.`
  line
  line `(4) The person making the inspection under this section may, during the course of inspection,--`
  line
  line `(i) make or cause to be made copies of books of account and other books and papers, or`
  line
  line `(ii) place or cause to be placed any marks or identification thereon in token of the inspection`
  line `having been made.`
  line
  line `(5) Notwithstanding anything contained in any other law for the time being in force or any contract to`
  line `the contrary, the Central Registrar or an officer authorised under clause (ii) of sub-section (1), making an`
  line `inspection under this section shall have the same powers as are vested in a civil court under the Code of`
  line `Civil Procedure, 1908 (5 of 1908) while trying a suit, in respect of the following matters, namely:--`
  line
  line `(i) the discovery and production of books of account and other documents, at such place and such`
  line `time as may be specified by such person;`
  line
  line `(ii) summoning and enforcing the attendance of persons and examining them on oath;`
  line
  line `(iii) inspection of any books, register and other documents of the multi-State co-operative society`
  line `at any place.`
  line
  line `(6) Where an inspection of the books of account and other books and papers of the multi-State cooperative`
  line `society has been made under this section, the Central Registrar or an officer authorised under`
  line `clause (ii) of sub-section (1), making the inspection shall make a report to the Central Government.`
obj_root_law_sections_108_footnotes:
  string
  line
obj_root_law_sections_109:
  sectionId (1672)
  sectionNo (109)
  orderNo 129
  title `Annual accounts and balance-sheet.`
  content obj_root_law_sections_109_content
  footnotes obj_root_law_sections_109_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1672&sectionno=109&orderno=129&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_109_content:
  string
  line `At every annual general meeting of a multi-State cooperative`
  line `society, the board shall lay before the multi-State co-operative society--`
  line
  line `(a) a balance-sheet as at the end of every co-operative year; and`
  line
  line `(b) a profit and loss account for that year.`
obj_root_law_sections_109_footnotes:
  string
  line
obj_root_law_sections_110:
  sectionId (1673)
  sectionNo (110)
  orderNo 130
  title `Minutes of proceedings of general meetings and of board and other meetings.`
  content obj_root_law_sections_110_content
  footnotes obj_root_law_sections_110_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1673&sectionno=110&orderno=130&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_110_content:
  string
  line `(1) Every`
  line `multi-State co-operative society shall cause minutes of all proceedings of every general meeting and of all`
  line `proceedings of every meeting of its board or of every committee of the board, to be kept by making`
  line `within thirty days of the conclusion of every such meeting concerned, entries thereof in books kept for`
  line `that purpose with their pages consecutively numbered.`
  line
  line `(2) Each page of every such book shall be initialed or signed and the last page of the record of`
  line `proceedings of each meeting in such books shall be dated and signed--`
  line
  line `(a) in the case of minutes of proceedings of a meeting of the board or of a committee thereof, by`
  line `the chairperson of the said meeting or the chairperson of the next succeeding meeting;`
  line
  line `(b) in the case of minutes of proceedings of a general meeting, by the chairperson of the same`
  line `meeting within the aforesaid period of thirty days or in the event of the death or inability of that`
  line `chairperson within that period, by a member of the board duly authorised by the board for the`
  line purpose.
  line
  line `(3) In no case the minutes of proceedings of a meeting shall be attached to any such books as`
  line `aforesaid by pasting or otherwise.`
  line
  line `(4) The minutes of each meeting shall contain a fair and correct summary of the proceedings thereat.`
  line
  line `(5) All appointments of officers made at any of the meetings aforesaid shall be included in the`
  line `minutes of the meeting.`
  line
  line `(6) In the case of a meeting of the board or of a committee of the board, the minutes shall also`
  line contain--
  line
  line `(a) the names of the members of the board present at the meeting; and`
  line
  line `(b) in the case of each resolution passed at the meeting, the names of the members of the board, if`
  line `any, dissenting from, or not concurring in, the resolution.`
  line
  line `(7) Nothing contained in sub-section (1) to (6) shall be deemed to require the inclusion in any such`
  line `minutes of any matter which, in the opinion of the chairperson of the meeting--`
  line
  line `(a) is, or could reasonably be regarded as, defamatory of any person;`
  line
  line `(b) is irrelevant or immaterial to the proceedings; or`
  line
  line `(c) is detrimental to the interests of the multi-State co-operative society.`
  line
  line `Explanation.--The chairperson shall exercise an absolute discretion in regard to the inclusion or noninclusion`
  line `of any matter in the minutes on the grounds specified in this sub-section.`
obj_root_law_sections_110_footnotes:
  string
  line
obj_root_law_sections_111:
  sectionId (1674)
  sectionNo (111)
  orderNo 131
  title `Minutes to be evidence.`
  content obj_root_law_sections_111_content
  footnotes obj_root_law_sections_111_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1674&sectionno=111&orderno=131&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_111_content:
  string
  line `Minutes of meetings kept in accordance with the provision of section`
  line `110 shall be evidence of the proceedings recorded therein.`
obj_root_law_sections_111_footnotes:
  string
  line
obj_root_law_sections_112:
  sectionId (1675)
  sectionNo (112)
  orderNo 132
  title `Presumptions to be drawn where minutes duly drawn and signed.`
  content obj_root_law_sections_112_content
  footnotes obj_root_law_sections_112_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1675&sectionno=112&orderno=132&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_112_content:
  string
  line `Where minutes of the`
  line `proceedings of any general meeting of the multi-State co-operative society or of any meeting of its board`
  line `or a committee of the board have been kept in accordance with the provisions of section 110, then, until`
  line `the contrary is proved, the meeting shall be deemed to have been duly called and held, and all proceedings`
  line `thereat to have duly taken place, and in particular, all appointments of directors or liquidators made at the`
  line `meeting shall be deemed to be valid.`
obj_root_law_sections_112_footnotes:
  string
  line
obj_root_law_sections_113:
  sectionId (1676)
  sectionNo (113)
  orderNo 133
  title `Inspection of minutes book of general meetings.`
  content obj_root_law_sections_113_content
  footnotes obj_root_law_sections_113_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1676&sectionno=113&orderno=133&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_113_content:
  string
  line `The books containing the minutes of the`
  line `proceedings of any general meeting of a multi-State co-operative society shall--`
  line
  line `(a) be kept at the registered office of that society, and`
  line
  line `(b) be open, during business hours, to the inspection of any member of that society.`
obj_root_law_sections_113_footnotes:
  string
  line
obj_root_law_sections_114:
  sectionId (1677)
  sectionNo (114)
  orderNo 134
  title `Liquidator to be public servant.`
  content obj_root_law_sections_114_content
  footnotes obj_root_law_sections_114_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1677&sectionno=114&orderno=134&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_114_content:
  string
  line `Any person appointed as liquidator under the provisions of`
  line `this Act shall be deemed to be a public servant within the meaning of section 21 of the Indian Penal Code`
  line `(45 of 1860).`
obj_root_law_sections_114_footnotes:
  string
  line
obj_root_law_sections_115:
  sectionId (1678)
  sectionNo (115)
  orderNo 135
  title `Notice necessary in suits.`
  content obj_root_law_sections_115_content
  footnotes obj_root_law_sections_115_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1678&sectionno=115&orderno=135&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_115_content:
  string
  line `No suit shall be instituted against a multi-State co-operative society`
  line `or any of its officers in respect of any act touching the constitution, management or the business of the`
  line `society until the expiration of ninety days next after notice in writing has been delivered to the Central`
  line `Registrar or left at his office, stating the cause of action, the name, description and place of residence of`
  line `the plaintiff and the relief which he claims, and the plaint shall contain a statement that such notice has`
  line `been so delivered or left.`
obj_root_law_sections_115_footnotes:
  string
  line
obj_root_law_sections_116:
  sectionId (1679)
  sectionNo (116)
  orderNo 136
  title `Power to amend Schedule.`
  content obj_root_law_sections_116_content
  footnotes obj_root_law_sections_116_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1679&sectionno=116&orderno=136&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_116_content:
  string
  line `^1[Power to amend Schedules.]--(1) If the Central Government is satisfied that any`
  line `multi-State co-operative society should be designated as a national co-operative society or any national`
  line `co-operative society specified in the Second Schedule should be omitted from the said Schedule, it may,`
  line `by notification, amend the said Schedule so at to include therein such multi-State co-operative society or`
  line `exclude therefrom such national co-operative society, and thereupon the said Schedule shall be deemed to`
  line `have been amended accordingly.`
  line
  line `^2[(1A) If the Central Government is satisfied that it is necessary or expedient so to do, it may, by`
  line `notification, amend the First Schedule and the Third Schedule and thereupon such Schedules shall be`
  line `deemed to have been amended accordingly:`
  line
  line `Provided that in case of the First Schedule, such notification shall be used only for adding to the`
  line `co-operative principles in the list.]`
obj_root_law_sections_116_footnotes:
  string
  line `1. Subs. by Act 11 of 2023, s. 42 for marginal heading (w.e.f. 3-8-2023).`
  line
  line `2. Ins. by s. 42 ibid. (w.e.f. 3-8-2023).`
obj_root_law_sections_117:
  sectionId (1680)
  sectionNo (117)
  orderNo 137
  title `Bar of jurisdiction of courts.`
  content obj_root_law_sections_117_content
  footnotes obj_root_law_sections_117_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1680&sectionno=117&orderno=137&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_117_content:
  string
  line `(1) Save as otherwise provided in this Act, no court shall have`
  line `jurisdiction in respect of--`
  line
  line `(a) the registration of a multi-State co-operative society or its byelaws or of an amendment of the`
  line bye-laws;
  line
  line `(b) any matter concerning the winding up and the dissolution of a multi-State co-operative`
  line society.
  line
  line `(2) While a multi-State co-operative society is being wound up, no suit or other legal proceedings`
  line `relating to the business of such society shall be proceeded with or instituted against the liquidator or`
  line `against the society or any member thereof, except by leave of the Central Registrar and subject to such`
  line `terms and conditions as he may impose.`
  line
  line `(3) Save as otherwise provided in this Act, no decision or order made under this Act shall be`
  line `questioned in any court.`
obj_root_law_sections_117_footnotes:
  string
  line
obj_root_law_sections_118:
  sectionId (1681)
  sectionNo (118)
  orderNo 138
  title Indemnity.
  content obj_root_law_sections_118_content
  footnotes obj_root_law_sections_118_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1681&sectionno=118&orderno=138&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_118_content:
  string
  line `No suit, prosecution or other legal proceedings shall lie against the Central`
  line `Registrar or, any person subordinate to him or acting on his authority or against any other person, in`
  line `respect of anything in good faith done or purporting to have been done under this Act.`
obj_root_law_sections_118_footnotes:
  string
  line
obj_root_law_sections_119:
  sectionId (1682)
  sectionNo (119)
  orderNo 139
  title `Opening of branches.`
  content obj_root_law_sections_119_content
  footnotes obj_root_law_sections_119_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1682&sectionno=119&orderno=139&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_119_content:
  string
  line `Notwithstanding anything contained to the contrary in any law relating`
  line `to co-operative societies in force in a state, a multi-State co-operative society, not being a co-operative`
  line `bank, may open branches or places of business in any place in India.`
obj_root_law_sections_119_footnotes:
  string
  line
obj_root_law_sections_120:
  sectionId (1683)
  sectionNo (120)
  orderNo 140
  title `Filing of returns.`
  content obj_root_law_sections_120_content
  footnotes obj_root_law_sections_120_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1683&sectionno=120&orderno=140&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_120_content:
  string
  line `Every year within six months of the closure of the accounting year every`
  line `multi-State co-operative society shall file the following returns with the Central Registrar, namely:--`
  line
  line `(a) annual report of the activities;`
  line
  line `(b) audited statements of accounts;`
  line
  line `(c) plan for surplus disposal as approved by the general body;`
  line
  line `(d) list of amendments to the bye-laws of the multi-State co-operative society;`
  line
  line `(e) declaration regarding date of holding of general body meeting and conduct of elections where`
  line due;
  line
  line `(f) any other information required by the Central Registrar in pursuance of any of the provisions`
  line `of this Act.`
obj_root_law_sections_120_footnotes:
  string
  line
obj_root_law_sections_120_a:
  sectionId (76488)
  sectionNo 120A
  orderNo 141
  title `Filing of applications, documents, inspections, etc., in electronic form.`
  content obj_root_law_sections_120_a_content
  footnotes `1. Ins. by s. 44, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76488&sectionno=120A&orderno=141&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_120_a_content:
  string
  line `^1[120A. Filing of applications, documents, inspections, etc., in electronic form.--(1)`
  line `Notwithstanding anything to the contrary contained in this Act, and without prejudice to the provisions of`
  line `the Information Technology Act, 2000 (21 of 2000), the Central Government may, from such date as may`
  line `be notified, require that--`
  line
  line `(a) such applications, returns, reports, statement of accounts, or any other particulars or document`
  line `as may be required to be filed or delivered under this Act or the rules made thereunder, shall be filed`
  line `in the electronic form and authenticated;`
  line
  line `(b) such document, notice, any communication or intimation, as may be required to be served or`
  line `delivered under this Act, shall be served or delivered in the electronic form and authenticated;`
  line
  line `(c) such applications, returns, reports, statement of accounts, registers, bye-laws or any other`
  line `particulars or documents and returns filed under this Act or the rules made thereunder shall be maintained by the Central Registrar in the electronic form and registered or authenticated, as the case`
  line `may be;`
  line
  line `(c) such applications, returns, reports, statement of accounts, registers, bye-laws or any other`
  line `particulars or documents and returns filed under this Act or the rules made thereunder shall be`
  line `maintained by the Central Registrar in the electronic form and registered or authenticated, as the case`
  line `may be;`
  line
  line `(e) such fees, charges or other sums payable under this Act or the rules made thereunder shall be`
  line `paid through the electronic form,`
  line `in such manner as may be prescribed.`
  line
  line `(2) The Central Registrar shall--`
  line
  line `(a) issue certificate of registration;`
  line
  line `(b) register the amendment of bye-laws;`
  line
  line `(c) register change of registered office;`
  line
  line `(d) register any document;`
  line
  line `(e) issue any certificate;`
  line
  line `(f) issue notice; and`
  line
  line `(g) receive such communication as may be required to be registered or issued or recorded or`
  line `received, as the case may be,`
  line
  line `under this Act or the rules made thereunder or perform duties or discharge functions or exercise powers`
  line `under this Act or the rules made thereunder or do any act which is by this Act directed to be performed or`
  line `discharged or exercised or done by the Central Registrar, in the electronic form in such manner as may be`
  line prescribed.]
obj_root_law_sections_120_b:
  sectionId (76489)
  sectionNo 120B
  orderNo 142
  title `Application of Banking Regulation Act, 1949.`
  content obj_root_law_sections_120_b_content
  footnotes `1. Ins. by s. 44, ibid. (w.e.f. 3-8-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=76489&sectionno=120B&orderno=142&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_120_b_content:
  string
  line `^1[120B. Application of Banking Regulation Act, 1949.--The provisions of this Act shall apply to a`
  line `multi-State co-operative society in respect of matters relating to incorporation, regulation and winding up:`
  line
  line `Provided that in case of a multi-State co-operative society carrying on the business of banking, the`
  line `provisions of the Banking Regulation Act, 1949 (10 of 1949) shall also apply.]`
obj_root_law_sections_121:
  sectionId (1684)
  sectionNo (121)
  orderNo 143
  title `Certain Acts not to apply.`
  content obj_root_law_sections_121_content
  footnotes obj_root_law_sections_121_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1684&sectionno=121&orderno=143&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_121_content:
  string
  line `(1) The provisions of the Companies Act, 1956 (1 of 1956) and the`
  line `Monopolies and Restrictive Trade Practices Act, 1969 (54 of 1969) shall not apply to the multi-State cooperative`
  line societies.
  line
  line `(2) The multi-State Co-operative societies registered or deemed to be registered under the provisions`
  line `of this Act shall not indulge in monopolistic and restrictive trade practices as defined in the Monopolies`
  line `and Restrictive Trade Practices Act, 1969 (54 of 1969).`
obj_root_law_sections_121_footnotes:
  string
  line
obj_root_law_sections_122:
  sectionId (1685)
  sectionNo (122)
  orderNo 144
  title `Central Government’s power to give directions to specified multi-State co-operative societies in public interest.`
  content obj_root_law_sections_122_content
  footnotes obj_root_law_sections_122_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1685&sectionno=122&orderno=144&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_122_content:
  string
  line `If the Central Government is satisfied that in the public interest or for the`
  line `purposes of securing proper implementation of co-operative production and other developmental`
  line `programmes approved or undertaken by the Central Government or to secure proper management of the`
  line `business of the specified multi-State co-operative societies generally or for preventing the affairs of such`
  line `society being conducted in a manner detrimental to the interests of the members, any depositors or`
  line `creditors thereof, it is necessary to issue directions to any class of specified multi-State co-operative`
  line `societies generally or to any specified multi-State co-operative society or societies in particular, the`
  line `Central Government may issue directions to it or to them, from time to time, and all such specified multiState`
  line `co-operative society or the societies concerned, as the case may be, shall be bound to comply with`
  line `such directions.`
obj_root_law_sections_122_footnotes:
  string
  line
obj_root_law_sections_123:
  sectionId (1686)
  sectionNo (123)
  orderNo 145
  title `Supersession of board of specified multi-State co-operative society.`
  content obj_root_law_sections_123_content
  footnotes obj_root_law_sections_123_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1686&sectionno=123&orderno=145&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_123_content:
  string
  line `(1) If in the opinion of`
  line `the Central Government, the board of any specified multi-State co-operative society is persistently`
  line `making default or is negligent in the performance of the duties imposed on it by this Act or the rules or`
  line `the bye-laws or has committed any act which is prejudicial to the interests of the society or its members,`
  line `or has omitted or failed to comply with any directions given to it under section 122 or that there is a`
  line `stalemate in the constitution or functions of the board, the Central Government may, after giving the`
  line `board an opportunity to state its objections, if any, and considering the objections, if received, by order in`
  line `writing, remove the board and appoint one or more administrators, who need not be members of the`
  line `society, to manage the affairs of the society for such period not exceeding six months, as may be specified in the order which period may, at the discretion of the Central Government, be extended from`
  line `time to time; so, however, that the aggregate period does not exceed one year:`
  line
  line `Provided that in the case of a co-operative bank, the provisions of this sub-section shall have effect as`
  line `if for the words "one year", the words "two years" had been substituted.`
  line
  line `(2) The Central Government may fix such remuneration for the administrators, as it may think fit and`
  line `the remuneration shall be paid out of the funds of the specified multi-State co-operative society.`
  line
  line `(3) The administrator shall, subject to the control of the Central Government and to such instructions`
  line `as it may from time to time give, have power to exercise all or any of the functions of the board or of any`
  line `officer of the specified multi-State co-operative society and take all such actions as may be required in the`
  line `interests of the society.`
  line
  line `(4) Save as otherwise provided in sub-section (5), the administrator shall, before the expiry of his`
  line `term of office, arrange for the constitution of a new board in accordance with the bye-laws of the`
  line `specified multi-State co-operative society.`
  line
  line `(5) If, at any time during the period the administrator is in office, the Central Government considers it`
  line `necessary or expedient so to do, it may, by order in writing giving reasons therefor, direct the`
  line `administrator to arrange for the constitution of a new board for such specified multi-State co-operative`
  line `society in accordance with the bye-laws of such society and immediately on the constitution of such`
  line `board, the administrator shall hand over the management of such society to such newly constituted board`
  line `and cease to function.`
  line
  line `(6) Where a specified multi-State co-operative society is indebted to any financial institution, the`
  line `Central Government shall, before taking any action, under sub-section (1) in respect of that society,`
  line `consult the financial institution.`
  line
  line `Explanation.--For the purposes of sections 122 and 123, "specified multi-State co-operative society"`
  line `means any multi-State co-operative society in which not less than fifty-one per cent. of the paid-up share`
  line `capital or, of total shares, is held by the Central Government.`
obj_root_law_sections_123_footnotes:
  string
  line
obj_root_law_sections_124:
  sectionId (1687)
  sectionNo (124)
  orderNo 146
  title `Power to make rules.`
  content obj_root_law_sections_124_content
  footnotes obj_root_law_sections_124_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1687&sectionno=124&orderno=146&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_124_content:
  string
  line `(1) The Central Government may, by notification, make rules to carry`
  line `out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the form to be used, the particulars to be given and the conditions to be complied with in the`
  line `making of applications under section 6 for the registration of a multi-State co-operative society and`
  line `the procedure in the matter of such applications;`
  line
  line `(b) the matters in respect of which a multi-State co-operative society may make bye-laws under`
  line `sub-section (2) of section 10;`
  line
  line `(c) the manner in which the order of refusal to register any amendment of the bye-laws shall be`
  line `communicated under sub-section (9) of section 11;`
  line
  line `(d) the manner in which a multi-State co-operative society shall have a principal place of business`
  line `and registered address under section 14;`
  line
  line `(e) the procedure and conditions for change in the extent of the liability of a multi-State cooperative`
  line `society under section 16;`
  line
  line `(f) the manner in which order of refusal to register an amendment of bye-laws shall be`
  line `communicated under sub-section (4) of section 22;`
  line
  line `(g) the classification of federal co-operative and other terms and conditions applicable to in under`
  line `sub-section (3) of section 23;`
  line
  line `(h) the restriction on holding the share capital of the society other than a member referred to in`
  line `section 33;`
  line
  line `(i) the constitution and powers of smaller body representing the general body under the proviso to`
  line `sub-section (1) of section 38;`
  line
  line `(j) the period within which annual general meeting be called and the procedure at such meetings`
  line `and the powers to be exercised by such meeting under section 39;`
  line
  line `(k) the election of members of the board under sub-section (2) of section 45 through secret ballot;`
  line
  line `(l) the nomination of members under the second proviso to sub-section (1) of section 48;`
  line
  line `(m) the additional measures and acts which may be taken or, as the case may be, done by the`
  line `board under section 49;`
  line
  line `(n) the salary and allowances payable to and other terms and conditions of the Chief Executive`
  line `under sub-section (3) of section 51;`
  line
  line `(o) the conditions subject to which the board may constitute an Executive Committee and other`
  line `committees or sub-committees under sub-section (1) of section 53;`
  line
  line `(p) the persons by whom and the form in which copies of entries in books of multi-State cooperative`
  line `societies may be certified under section 58 and the charges to be levied for the supply of`
  line `such copies;`
  line
  line `(q) providing aid to multi-State co-operative societies on certain terms and conditions under`
  line `clause (g) of section 61;`
  line
  line `(r) the conditions under which profits may be distributed to the members of a multi-State cooperative`
  line `society and the maximum rate of dividend which may be paid by the multi-State cooperative`
  line `societies under section 63;`
  line
  line `(s) establishment of contributory provident fund under sub-section (1) of section 69;`
  line
  line `(t) the manner of disposing of the surplus under clause (k) of sub-section (2) of section 90;`
  line
  line `(u) the manner in which surplus assets be divided by the Central Registrar with the previous`
  line `sanction of the Central Government under clause (b) of section 91;`
  line
  line `(v) the appellate authority to be specified under sub-section (2) of section 99;`
  line
  line `(w) the procedure under section 103 for reconstitution and reorganisation of societies which`
  line `became the multi-State co-operative societies consequent on reorganisation of states;`
  line
  line `(x) the inspection of records of the society on payment of fees under clause (b) of sub-section (2)`
  line `of section 107;`
  line
  line `(y) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree that the rule should not be`
  line `made, the rule shall thereafter have effect only in such modified form or be of no effect, as the case may`
  line `be; so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that rule.`
obj_root_law_sections_124_footnotes:
  string
  line
obj_root_law_sections_125:
  sectionId (1688)
  sectionNo (125)
  orderNo 147
  title `Power to remove difficulties.`
  content obj_root_law_sections_125_content
  footnotes obj_root_law_sections_125_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1688&sectionno=125&orderno=147&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_125_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_125_footnotes:
  string
  line
obj_root_law_sections_126:
  sectionId (1689)
  sectionNo (126)
  orderNo 148
  title `Repeal and saving.`
  content obj_root_law_sections_126_content
  footnotes obj_root_law_sections_126_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00003_200239_1517807323108&sectionId=1689&sectionno=126&orderno=148&orgactid=AC_CEN_23_31_00003_200239_1517807323108
obj_root_law_sections_126_content:
  string
  line `(1) The Multi-State Co-operative Societies Act, 1984 (51 of 1984) is`
  line `hereby repealed.`
  line
  line `(2) Without prejudice to the provisions contained in the General Clauses Act, 1897 (10 of 1897) with`
  line `respect to repeals, any notifications, rule, order, requirement, registration, certificate, notice, decision,`
  line `direction, approval, authorisation, consent, application, request or thing made, issued given or done under`
  line `the Multi-State Co-operative Societies Act, 1984 (51 of 1984) shall, if in force at the commencement of this Act, continue to be in force and have effect as if made, issued given or done under the corresponding`
  line `provisions of this Act.`
  line
  line `(3) Every multi-State co-operative society existing immediately before the commencement of this Act`
  line `which has been registered under the Co-operative Societies Act, 1912 (2 of 1912) or under any other Act`
  line `relating to co-operative societies in force, in any State or in pursuance of the provisions of the Multi-unit`
  line `Co-operative Societies Act, 1942 (6 of 1942), or the Multi-State Co-operative Societies Act, 1984 (51 of`
  line `1984) shall be deemed to be registered under the corresponding provisions of this Act, and the bye-laws`
  line `of such society shall, in so far as they are not inconsistent with the provisions of this Act, or the rules,`
  line `continue to be in force until altered or rescinded.`
  line
  line `(4) All appointments, rules and orders made, all notifications and notices issued and all suits and`
  line `other proceedings instituted under any of the Acts referred to in sub-section (1) shall, in so far as they are`
  line `not inconsistent with the provisions of this Act, be deemed to have been respectively made, issued and`
  line `instituted under this Act, save that an order made cancelling the registration of a multi-State co-operative`
  line `society shall be deemed, unless the society has already been finally liquidated, to be an order made under`
  line `section 86 for its being wound up.`
  line
  line `(5) The provisions of this Act shall apply to--`
  line
  line `(a) any application for registration of a multi-State co-operative society;`
  line
  line `(b) any application for registration of amendment of bye-laws of a multi-State co-operative`
  line `society, pending at the commencement of this Act and to the proceedings consequent thereon and to`
  line `any registration granted in pursuance thereof.`
  line
  line `(6) Save as otherwise provided in this Act, any legal proceeding pending in any court or before the`
  line `Central Registrar or any other authority at the commencement of this Act shall be continued to be in that`
  line `court or before the Central Registrar or that authority as if this Act had not been passed.`
obj_root_law_sections_126_footnotes:
  string
  line
