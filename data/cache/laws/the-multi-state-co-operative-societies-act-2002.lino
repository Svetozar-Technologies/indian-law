obj_root_law:
  object
  (str slug) (str the-multi-state-co-operative-societies-act-2002)
  (str handle) (str 1914)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Multi-State Co-operative Societies Act, 2002`)
  (str actNumber) (str 39)
  (str enactmentDate) (str 2002-07-03)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1914`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बहुराज्यय सहकारी सोसाइटी अधिनियम, 2002`)
  (str actYear) (str 2002)
  (str ministry) (str `Ministry of Cooperation`)
  (str department) (undefined)
  (str longTitle) (str `An Act to consolidate and amend the law relating to co-operative societies, with objects not confined to one State and serving the interests of members in more than one State, to facilitate the voluntary formation and democratic functioning of co-operative s as peoples institutions based on self-help and mutual aid and to enable them to promote their economic and social betterment and to provide functional autonomy and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 19-08-2002)
  (str notification) (str `19th August, 2002, vide notification No. G.S.R. 571(E), dated 16th August, 2002, see Gazette of India, Extraordinary, Part II, sec. 3(i).`)
  (str fetchedAt) (str `2026-05-09T21:47:55.025Z`)
  (str translations) obj_root_law_translations
