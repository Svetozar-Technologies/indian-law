obj_root_law:
  slug the-multi-state-co-operative-societies-act-2002
  handle (1914)
  collectionHandle 123456789/1362
  title `The Multi-State Co-operative Societies Act, 2002`
  actNumber (39)
  enactmentDate 2002-07-03
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1914`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `बहुराज्यय सहकारी सोसाइटी अधिनियम, 2002`
  actYear (2002)
  ministry `Ministry of Cooperation`
  department undefined
  longTitle `An Act to consolidate and amend the law relating to co-operative societies, with objects not confined to one State and serving the interests of members in more than one State, to facilitate the voluntary formation and democratic functioning of co-operative s as peoples institutions based on self-help and mutual aid and to enable them to promote their economic and social betterment and to provide functional autonomy and for matters connected therewith or incidental thereto.`
  enforcementDate 19-08-2002
  notification `19th August, 2002, vide notification No. G.S.R. 571(E), dated 16th August, 2002, see Gazette of India, Extraordinary, Part II, sec. 3(i).`
  fetchedAt `2026-05-09T21:47:55.025Z`
  translations obj_root_law_translations
