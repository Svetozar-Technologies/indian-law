obj_root_law_translations_hi_sections_7:
  kind page
  sectionId pdf-page-7
  sectionNo (7)
  orderNo 7
  title `Page 7`
  content obj_root_law_translations_hi_sections_7_content
  footnotes obj_root_law_translations_hi_sections_7_footnotes
  sourcePage 7
obj_root_law_translations_hi_sections_7_content:
  string
  line 7
  line `भाग 2`
  line `उक्त समझौता अजी के सा ि उपाबद्ध “ बी ” धचधनित सूची में सधम्म धलत सम्पू णष पु त कालय धजसके अन्त गषत सभी भािाओं की`
  line `पुत कें, कतें और पांर्ुधलधपयां हैं चाहे कागज पर या अन्य सामग्री पर मुकरत हों या हत धलधित हों।`
  line `भाग 3`
  line `उक्त समझौता अजी के साि उपाबद्ध “ सी ” धचधनित रेिाधच त्र में वर्णषत और अंककत लगभग 28,390 वगष गज माप`
  line `वाली भू धम।`
  line _______
obj_root_law_translations_hi_sections_7_footnotes:
  string
  line
