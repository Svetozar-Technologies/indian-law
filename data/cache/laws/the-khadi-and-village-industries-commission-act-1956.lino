obj_root_law_sections_1:
  sectionId (9738)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9738&sectionno=1&orderno=1&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called The Khadi and Village Industries Commission`
  line `Act, 1956.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
obj_root_law_sections_1_footnotes:
  string
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (9739)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9739&sectionno=2&orderno=2&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_2_content:
  string
  line `n this Act, unless the context otherwise requires,--`
  line
  line `(a) "the Board" means the Board constituted under ^1`
  line `[section 10];`
  line
  line `(b) "chairman" means the chairman of the Commission;`
  line
  line `(c) "Commission" means the Khadi and Village Industries Commission established under`
  line `section 4;`
  line
  line ^2
  line `[(cc) "fixed capital investment" includes investment in plant and machinery and land and`
  line `building of an industry;]`
  line
  line `(d) "khadi" means any cloth woven on handlooms in India from cotton, silk or woolen yarn`
  line `handspun in India or from a mixture of any two or all of such yarns;`
  line
  line `(e) "member" means a member of the Commission ^3`
  line `[and includes the chairman ^4`
  line ***];
  line
  line `(f) "prescribed" means prescribed by rules made under this Act;`
  line
  line ^5
  line `[(ff) "rural area" means the area comprised in any village, and includes the area comprised in any`
  line `town, the population of which does not exceed ^6`
  line `[twenty thousand] or such other figure as the Central`
  line `Government may specify from time to time;]`
  line
  line ^7
  line `* * * * *`
  line
  line ^8
  line `* * * * *`
  line
  line ^9
  line `[(h) "village industry" means,--`
  line
  line `(i) any industry located in a rural area which produces any goods or renders any service with`
  line `or without the use of power and in which the fixed capital investment per head of an artisan or a`
  line `worker does not exceed ^10[one lakh rupees] or such other sum as may, by notification in the`
  line `Official Gazette, be specified from time to time by the Central Government:`
  line
  line `Provided that any industry specified in the schedule and located in an area other than a rural`
  line `area and recognised as a village industry at any time before the commencement of the Khadi and`
  line `Village Industries Commission (Amendment) Act, 1987 (12 of 1987), shall, notwithstanding`
  line `anything contained in this sub-clause, continue to be a village industry under this Act:`
  line
  line ^11
  line `[Provided further that in the case of any industry located in a hilly area, the provisions of this`
  line `this sub-clause shall have effect as if for the words "one lakh rupees", the words "one lakh and`
  line `fifty thousand rupees" steal.]`
  line
  line `(ii) any other non-manufacturing unit established for the sole purpose of promoting,`
  line `maintaining, assisting, servicing (including mother units) or managing any village industry;]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 36 of 1957, s. 3 and the Second Schedule, for "section 9" (w.e.f. 17-9-1957).`
  line
  line `2. Ins. by Act 12 of 1987, s. 2 (w.e.f. 24-7-1987).`
  line
  line `3. Subs. by Act 32 of 1961, s. 2, for "and includes the chairman" (w.e.f. 28-8-1961).`
  line
  line `4. The words "and the vice-chairman" omitted by Act 12 of 1987, s. 2 (w.e.f. 24-7-1987).`
  line
  line `5. Ins. by s. 2, ibid. (w.e.f. 24-7-1987).`
  line
  line `6. Subs. by Act 10 of 2006, s. 2, for "ten thousand" (w.e.f. 15-5-2006).`
  line
  line `7. Omitted by Act 12 of 1987, s. 2 (w.e.f. 24-7-1987).`
  line
  line `8. Omitted by s. 2, ibid. (w.e.f. 24-7-1987).`
  line
  line `9. Subs. by s. 2, ibid., for clause (h) (w.e.f. 24-7-1987).`
  line
  line `10. Subs. by Act 10 of 2006, s. 2, for "fifteen thousand rupees" (w.e.f. 15-5-2006).`
  line
  line `11. The proviso ins. by Act 10 of 2006, s. 2 (w.e.f. 15-5-2006).`
obj_root_law_sections_3:
  sectionId (9740)
  sectionNo (3)
  orderNo 3
  title `Power to add to the Schedule.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9740&sectionno=3&orderno=3&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_3_content:
  string
  line `[Power to add to the Schedule.] Omitted by Khadi and Village Industries Commission`
  line `(Amendment) Act 1987 (12 of 1987), s. 3 (w.e.f. 24-7-1987).`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (9741)
  sectionNo (4)
  orderNo 4
  title `Establishment and constitution of the Commission.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9741&sectionno=4&orderno=4&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_4_content:
  string
  line `(1) With effect from such date as the`
  line `Central Government may, by notification in the Official Gazette, fix in this behalf, there shall be`
  line `established a Commission to be called the Khadi and Village Industries Commission which shall be a`
  line `body corporate having perpetual succession and a common seal, with power to acquire, hold and dispose`
  line `of property and to contract, and may by the said name sue and be sued.`
  line
  line ^1
  line `[(1A) Save as otherwise provided under this Act and the rules made thereunder, the exercise of all`
  line `powers and discharge of all functions under this Act, including general superintendence, direction and`
  line `management of day-to-day affairs of the Commission, shall vest in the Commission.]`
  line
  line ^2
  line `[(2) The Commission shall consist of the following members appointed by the Central Government,`
  line `namely:--`
  line
  line `(a) six non-official members ^3`
  line `[having specialised knowledge and not less than ten years of`
  line `experience of khadi or village industries] and representing such six geographical zones of the country,`
  line `as may be prescribed;`
  line
  line ^4
  line `[(b) four non-official members of whom each member shall be from the following disciplines,`
  line `namely:--`
  line
  line `(i) one member having expert knowledge and experience in Science and Technology;`
  line
  line `(ii) one member having expert knowledge and experience in Marketing;`
  line
  line `(iii) one member having expert knowledge and experience in Rural Development; and`
  line
  line `(iv) one member having expert knowledge and experience in Technical Education and`
  line Training.]
  line
  line ^5
  line `[(ba) the Chairman of the State Bank of India constituted under sub-section (1) of section 3 of`
  line `the State Bank of India Act, 1955 (23 of 1955) or an officer not below the rank of the Deputy`
  line `Managing Director as may be nominated by the Chairman of the State Bank of India--ex officio;];`
  line
  line ^6
  line `[(c) a Chief Executive Officer, ex officio; and`
  line
  line `(d) a Financial Adviser, who shall also be the Chief Accounts Officer of the Commission,`
  line `ex officio.]`
  line
  line ^7
  line `* * * * *`
  line
  line `(3) The Central Government may appoint one of the members appointed under clause (a) of`
  line `sub-section (2) to be the chairman who shall be a full-time member.]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Ins. by s. 3, ibid. (w.e.f. 15-5-2006).`
  line
  line `2. Subs. by Act 12 of 1987, s. 4, for sub-sections (2) and (3) (w.e.f. 24-7-1987).`
  line
  line `3. Subs. by Act 10 of 2006, s. 3, for "having specialised knowledge and experience of khadi and village industries"`
  line `(w.e.f. 15-5-2006).`
  line
  line `4. Subs. by s. 3, ibid., for clause (b) (w.e.f. 15-5-2006).`
  line
  line `5. Ins. by s. 3, ibid. (w.e.f. 15-5-2006).`
  line
  line `6. Subs. by s. 3, ibid., for clauses (c) and (d) (w.e.f. 15-5-2006).`
  line
  line `7. The proviso omitted by Act 10 of 2006, s. 3 (w.e.f. 15-5-2006).`
obj_root_law_sections_5:
  sectionId (9742)
  sectionNo (5)
  orderNo 5
  title `Powers and functions of the Chief Executive Officer.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9742&sectionno=5&orderno=5&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_5_content:
  string
  line `^1[5. Powers and functions of the Chief Executive Officer.--^2[(1) Subject to the provisions`
  line `contained in sub-section (1A) of section 4, the Chief Executive Officer, appointed under clause (c) of`
  line `sub-section (2) of section 4, shall exercise such powers and discharge such functions in respect of general`
  line `superintendence over the affairs of the Commission and its day-to-day management, as may be`
  line prescribed.
  line
  line `(1A) Without prejudice to the powers and functions referred to in sub-section (1), the Chief Executive`
  line `Officer shall exercise such powers and discharge such functions under the general superintendence,`
  line `direction and management of the Commission.]`
  line
  line `(2) The Chief Executive Officer ^3[shall, in addition to exercise of the powers and discharge of the`
  line `functions referred to in sub-section (1), be responsible] for the furnishing of all returns, reports and`
  line `statements required to be furnished to the Central Government under section 24.`
  line
  line `(3) It shall be the duty of the Chief Executive Officer to place before the Commission for its`
  line `consideration and decision any matter of financial import if the Financial Adviser suggests to him in`
  line `writing that such matter be placed before the Commission.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 12 of 1987, s. 5, for sections 5 and 6 (w.e.f. 24-7-1987).`
  line
  line `2. Subs. by Act 10 of 2006, s. 4, for sub-section (1) (w.e.f. 15-5-2006).`
  line
  line `3. Subs. by s. 4, ibid., for "shall be responsible" (w.e.f. 15-5-2006).`
obj_root_law_sections_5_a:
  sectionId (9743)
  sectionNo 5A
  orderNo 6
  title `Powers and functions of the Financial Adviser.`
  content obj_root_law_sections_5_a_content
  footnotes obj_root_law_sections_5_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9743&sectionno=5A&orderno=6&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_5_a_content:
  string
  line `^1[5A. Powers and functions of the Financial Adviser.--The Financial Adviser ^2[appointed under`
  line `clause (d) of sub-section (2) of section 4 shall be in charge of such financial matters of the Commission`
  line `including its budget, accounts and audit, as may be prescribed] and it shall be the duty of the Financial`
  line `Adviser to bring to the notice of the Commission through the Chief Executive Officer any matter of`
  line `financial import, which, in his opinion, requires consideration and decision by the Commission.]`
obj_root_law_sections_5_a_footnotes:
  string
  line `1. Ins. by s. 5, ibid. (w.e.f. 15-5-2006).`
  line
  line `2. Subs. by s. 5, ibid., for certain words (w.e.f. 15-5-2006).`
obj_root_law_sections_6:
  sectionId (9744)
  sectionNo (6)
  orderNo 7
  title `Disqualifications for membership of the Commission.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9744&sectionno=6&orderno=7&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_6_content:
  string
  line `A person shall be disqualified for being`
  line `appointed as, and for being, a member of the Commission--`
  line
  line `(a) if he is, or is found to be a lunatic or a person of unsound mind; or`
  line
  line `(b) if he has been adjudged insolvent; or`
  line
  line `(c) if he has been convicted of an offence involving moral turpitude; or`
  line
  line `(d) if he has any financial interest in any subsisting contract made with or in any work being done`
  line `by the Commission, except as a shareholder (other than a Director), in a company as defined in`
  line `section 3 of the Companies Act, 1956 (1 of 1956):`
  line
  line `Provided that where he is a shareholder, he shall disclose to the Central Government, the nature`
  line `and extent of shares held by him in such a company; or`
  line
  line `(e) if he has any financial interest in any business undertaking dealing with or any other village`
  line `industry specified or deemed to be specified in the Schedule to the Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_6_a:
  sectionId (9745)
  sectionNo 6A
  orderNo 8
  title `Removal of Chairman, Member, etc., from the Commission.`
  content obj_root_law_sections_6_a_content
  footnotes `1. Ins. by Act 12 of 1987, s. 6 (w.e.f. 24-7-1987).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9745&sectionno=6A&orderno=8&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_6_a_content:
  string
  line `^1[6A. Removal of Chairman, Member, etc., from the Commission.-- The Central Government`
  line `may, by notification in the Official Gazette, remove from office any member of the Commission who--`
  line
  line `(a) is or becomes subject to any of the disqualifications mentioned in section 6; or`
  line
  line `(b) in the opinion of the Central Government has failed or is unable to carry out his duties; or`
  line
  line `(c) absents himself from three consecutive meetings of the Commission without the leave of the`
  line `Commission:`
  line
  line `Provided that before issuing any such notification, the Central Government shall give an opportunity`
  line `to the member concerned to show cause against such removal.]`
obj_root_law_sections_7:
  sectionId (9746)
  sectionNo (7)
  orderNo 9
  title `Resignation of office by member.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9746&sectionno=7&orderno=9&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_7_content:
  string
  line `Any member may resign his office by giving notice in writing`
  line `to the Central Government and, on such resignation being notified in the Official Gazette by that`
  line `Government, shall be deemed to have vacated his office`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (9747)
  sectionNo (8)
  orderNo 10
  title `Vacancies, etc., not to invalidate acts and proceedings of the Commission.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9747&sectionno=8&orderno=10&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_8_content:
  string
  line `No act or`
  line `proceeding of the Commission shall be invalid by reason only of the existence of any vacancy amongst its`
  line `members or any defect in the constitution thereof.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (9748)
  sectionNo (9)
  orderNo 11
  title `Temporary association of persons with the Commission for particular purposes.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9748&sectionno=9&orderno=11&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_9_content:
  string
  line `(1) The`
  line `Commission may associate with itself in such manner and for such purposes as may be determined by`
  line `regulations made under this Act any persons whose assistance or advice it may desire in complying with`
  line `any of the provisions of this Act.`
  line
  line `(2) A person associated with it by the Commission under sub-section (1) for any purpose shall have`
  line `the right to take part in the discussions of the Commission relevant to that purpose, but shall not have the`
  line `right to vote, and shall not be a member for any other purpose.`
  line
  line `(3) The Central Government may, by notification in the Official Gazette, depute one or more officers`
  line `of the Government to attend any meetings of the Commission and to take part in the discussions of the`
  line `Commission, but such officer or officers shall not have the right to vote.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (9749)
  sectionNo (10)
  orderNo 12
  title `Constitution of the Board.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9749&sectionno=10&orderno=12&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_10_content:
  string
  line `^1[(1)] For the purpose of assisting the Commission in the discharge`
  line `of its functions under this Act, the Central Government may, by notification in the Official Gazette,`
  line `constitute a Board to be called the Khadi and Village Industries Board and such number of other members`
  line `as the Central Government may think fit, chosen from among persons who, in the opinion of the Central`
  line `Government, are qualified as having had experience, and shown capacity, in matters relating to the`
  line `development of ^2[National Khadi and Village Industries Board.]`
  line
  line `^3[(2) The Board shall, subject to the provisions of sub-section (3), meet at such times and places and`
  line `observe such rules of procedure in regard to the transaction of business at its meetings including the`
  line `quorum at meetings as may be prescribed;`
  line
  line `(3) The Board shall meet at least twice in a year.].`
obj_root_law_sections_10_footnotes:
  string
  line `1. Section 10 renumbered as sub-section (1) thereof, by Act 10 of 2006, s. 6 (w.e.f. 1-10-1984).`
  line
  line `2. Subs. by s. 6, ibid., for "Khadi and Village Industries Board" (w.e.f. 15-5-2006).`
  line
  line `3. Ins. by s. 6, ibid. (w.e.f. 15-5-2006).`
obj_root_law_sections_11:
  sectionId (9750)
  sectionNo (11)
  orderNo 13
  title `Commission to consult the Board.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9750&sectionno=11&orderno=13&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_11_content:
  string
  line `The Commission shall ordinarily consult the Board with`
  line `respect to the discharge of its functions under this Act.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (9751)
  sectionNo (12)
  orderNo 14
  title `Meetings of the Commission.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9751&sectionno=12&orderno=14&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_12_content:
  string
  line `(1) The Commission shall meet at such times and places and`
  line `shall, subject to the provisions of sub-sections (2) and (3), observe such rules of procedure in regard to`
  line `transaction of business at its meetings (including the quorum at meetings) as may be provided by`
  line `regulations made by the Commission under this Act:`
  line
  line `Provided that the Commission shall meet at least once in every month.`
  line
  line `^1[(2) The chairman or, in his absence, any member (other than an ex officio member) chosen by the`
  line `members present from among themselves, shall preside at a meeting of the Commission.]`
  line
  line `(3) All questions at a meeting of the Commission shall be decided by a majority of the ^2[votes of the`
  line `members (including ex officio members) present] and voting and in the case of an equality of votes, the`
  line `chairman or, in his absence the person presiding shall have a second or casting vote.`
obj_root_law_sections_12_footnotes:
  string
  line `1. Subs. by Act 12 of 1987, s. 6, for sub-section 2 (w.e.f. 24-7-1987).`
  line
  line `2. Subs. by Act 10 of 2006, s. 7, for "votes of the members present" (w.e.f. 15-5-2006).`
obj_root_law_sections_12_a:
  sectionId (9752)
  sectionNo 12A
  orderNo 15
  title `Zonal Committee.`
  content obj_root_law_sections_12_a_content
  footnotes `1. Ins. by s. 8, ibid. (w.e.f. 15-5-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9752&sectionno=12A&orderno=15&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_12_a_content:
  string
  line `^1[12A. Zonal Committee.-- (1) The Commission shall constitute for each of the six geographical`
  line `zones, referred to in clause (a) of sub-section (2) of section 4, a Zonal Committee, which shall consist of`
  line `the following, namely:--`
  line
  line `(a) the non-official member representing the zone, referred to in clause (a) of sub-section (2) of`
  line `section 4, who shall be the Chairman of the Zonal Committee constituted for respective zones;`
  line
  line `(b) one representative of each of the State Khadi and Village Industries Boards of the States or, as case may be, the Government of each State in the zone, to be notified by the Central Government`
  line `in consultation with the State Government concerned--member;`
  line
  line `(c) the Zonal Deputy Chief Executive Officer of the Commission, who shall be the convener of`
  line `the Zonal Committee--member;`
  line
  line `(d) the State Directors in charge of the Commissions Directorates for the States in the`
  line zone--member;
  line
  line `(e) a Zonal or Regional manager of one of the lead banks operating in the zone-member; and`
  line
  line `(f) one representative of an institution of repute, working for at least ten years in the khadi or`
  line `village industries sector and having a good record of performance, from each State in the zone, to be`
  line `notified by the Central Government--member.`
  line
  line `(2) The Zonal Committee shall meet at such times and places and shall, subject to the provisions of`
  line `sub-section (3), observe such rules of procedure in regard to the transaction of business at its meetings`
  line `(including the quorum at the meetings) as may be provided by regulations made by the Commission`
  line `under this Act:`
  line
  line `Provided that the Committee shall meet at least once in every three months.`
  line
  line `(3) The Chairman of the Zonal Committee or, in his absence, any member chosen by the members`
  line `present from among themselves, shall preside at a meeting of the Committee.`
  line
  line `(4) The Zonal Committee shall generally function as a forum for consultation and, accordingly,`
  line `inter alia,--`
  line
  line `(a) act as a conduit for the dissemination of information relating to the programmes and schemes`
  line `of the Commission for the development of khadi and village industries in the zone;`
  line
  line `(b) monitor, from time to time, the implementation of the programmes and schemes referred to in`
  line `clause (a);`
  line
  line `(c) provide feedback to the Commission on the problems and difficulties envisaged and`
  line `suggestions made by banks, voluntary agencies, artisans and others engaged in the operation of`
  line `programmes and schemes referred to in clause (a).]`
obj_root_law_sections_13:
  sectionId (9753)
  sectionNo (13)
  orderNo 16
  title `Term of office and conditions of service of the chairman and other members.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9753&sectionno=13&orderno=16&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_13_content:
  string
  line `^1[13. Term of office and conditions of service of the chairman and other members.--(1) Every`
  line `member of the Commission, other than an ex officio member, shall hold office ^2`
  line `[at the pleasure of the`
  line `Central Government which shall not exceed continuous period of five years]:`
  line
  line `Provided that the chairman shall, notwithstanding the expiration of his term, continue to hold office`
  line `until his successor enters upon his office.`
  line
  line `(2) The terms and conditions of service of the chairman, Chief Executive Officer, Financial Adviser`
  line `and other members shall be such as may be prescribed.]`
obj_root_law_sections_13_footnotes:
  string
  line `1. Subs. by Act 12 of 1987, s. 7, for section 13 (w.e.f. 24-7-1987).`
  line
  line `2. Subs. by Act 10 of 2006, s. 9, for "for a term of five years" (w.e.f. 15-5-2006).`
obj_root_law_sections_14:
  sectionId (9754)
  sectionNo (14)
  orderNo 17
  title `Officers and servants of the Commission.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9754&sectionno=14&orderno=17&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_14_content:
  string
  line `^1* * * * *`
  line
  line `^2*** Subject to such rules as may be made by the Central Government in this behalf, the Commission`
  line `Commission may appoint such other officers and servants as it considers necessary for the efficient`
  line `performance of its functions:`
  line
  line `^2* * * * *`
obj_root_law_sections_14_footnotes:
  string
  line `1. Sub-section (1), omitted by Act 12 of 1987, s. 8 (w.e.f. 24-7-1987).`
  line
  line `2. The proviso and brackets and figure "(2)" omitted by s. 8, ibid. (w.e.f. 24-7-1987).`
obj_root_law_sections_15:
  sectionId (9755)
  sectionNo (15)
  orderNo 18
  title `Functions of the Commission.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9755&sectionno=15&orderno=18&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_15_content:
  string
  line `^1[15. Functions of the Commission.--(1) Subject to the provisions of this Act, the functions of the`
  line `Commission shall generally be to ^2[plan, promote, facilitate, organise] and assist in the establishment and`
  line `development of khadi and village industries in the rural area in coordination with other agencies engaged`
  line `in rural development wherever necessary.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, the Commission may`
  line `take such steps as it may think fit,--`
  line
  line `(a) to ^3[plan and organise, directly or through specified agencies] training of persons employed or`
  line `desirous of seeking employment in khadi and village industries;`
  line
  line `(b) to ^4[build up, directly or through specified agencies] reserves of raw materials and implements`
  line `and ^5[supply them or arrange supply of the raw materials and implements] to persons engaged or`
  line `likely to be engaged in production of handspun yarn or khadi or village industries at such rates as the`
  line `Commission may decide;`
  line
  line `(c) to encourage and assist in the creation of common service facilities for the processing of raw`
  line `materials or semi-finished goods and for otherwise facilitating production and marketing of khadi or`
  line `products of village industries;`
  line
  line `(d) to promote the sale and marketing of khadi or products of village industries or handicrafts and`
  line `for this purpose forge links with established marketing agencies wherever necessary and feasible;`
  line
  line `(e) to encourage and promote research in the technology used in khadi and village industries,`
  line `including the use of non-conventional energy and electric power with a view to increasing`
  line `productivity, eliminating drudgery and otherwise enhancing their competitive capacity and to arrange`
  line `for dissemination of salient results obtained from such research;`
  line
  line `(f) to undertake directly or through other agencies studies of the problems of khadi or village`
  line industries;
  line
  line `(g) to ^6[provide financial assistance, directly or through specified agencies,] to institutions or`
  line `persons engaged in the development and operation of khadi or village industries and guide them`
  line `through supply of designs, prototypes and other technical information for the purpose of producing`
  line `goods and services for which there is effective demand in the opinion of the Commission;`
  line
  line `(h) to ^7[undertake, directly or through specified agencies, experiments,] or pilot projects which in`
  line `the opinion of the Commission are necessary for the development of khadi and village industries;`
  line
  line `(i) to establish and maintain separate organisations for the purpose of carrying out any or all of`
  line `the above matters;`
  line
  line `(j) to promote and encourage co-operative efforts among the manufacturers of khadi or persons`
  line `engaged in village industries;`
  line
  line `(k) to ensure genuineness and to set up standards of quality and ensure that products of khadi and`
  line `village industries do conform to the said standards, including issue of certificates or letters of`
  line `recognition to the concerned persons; and`
  line
  line `(l) to carry out any other matters incidental to the above.]`
  line
  line `^8[Explanation.--For the purposes of clauses (a), (b), (g) and (h) of sub-section (2), the expression`
  line `"specified agencies" means the agencies which the Central Government may, by notification in the`
  line `Official Gazette, specify in this behalf.]`
obj_root_law_sections_15_footnotes:
  string
  line `1 Subs. by Act 12 of 1987, s. 9, for section 15 (w.e.f. 24-7-1987).`
  line
  line `2 Subs. by Act 10 of 2006, s. 10, for "plan, promote, organise" (w.e.f. 15-5-2006).`
  line
  line `3 Subs. by s. 10, ibid., for "plan and organise" (w.e.f. 15-5-2006).`
  line
  line `4 Subs. by s. 10, ibid., for "build up" (w.e.f. 15-5-2006).`
  line
  line `5 Subs. by s. 10, ibid., for "supply them" (w.e.f. 15-5-2006).`
  line
  line `6 Subs. by s. 10, ibid., for "provide financial assistance" (w.e.f. 15-5-2006).`
  line
  line `7 Subs. by s. 10, ibid., for "undertake experiments" (w.e.f. 15-5-2006).`
  line
  line `8 The Explanation ins. by Act 10 of 2006, s. 10 (w.e.f. 15-5-2006).`
obj_root_law_sections_16:
  sectionId (9756)
  sectionNo (16)
  orderNo 19
  title `Power of Central Government to give directions.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9756&sectionno=16&orderno=19&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_16_content:
  string
  line `In the discharge of its functions under this`
  line `Act, the Commission shall be bound by such directions as the Central Government may give to it.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (9757)
  sectionNo (17)
  orderNo 20
  title `Payment to the Commission.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9757&sectionno=17&orderno=20&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_17_content:
  string
  line `The Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the Commission in each financial year such sums as may be`
  line `considered necessary for the performance of the functions of the Commission under this Act.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_17_a:
  sectionId (9758)
  sectionNo 17A
  orderNo 21
  title `Commission to receive gifts, grants, etc.`
  content obj_root_law_sections_17_a_content
  footnotes obj_root_law_sections_17_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9758&sectionno=17A&orderno=21&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_17_a_content:
  string
  line `^1[17A. Commission to receive gifts, grants, etc.--The Commission may, for the purpose of`
  line `development of Khadi, ^2[the development of village industries or the development of Khadi and village`
  line `industries], receive gifts, grants, donations or benefactions from the Government or any other person.]`
obj_root_law_sections_17_a_footnotes:
  string
  line `1. Ins. by Act 32 of 1961, s. 9 (w.e.f. 28-8-1961).`
  line
  line `2. Subs. by Act 12 of 1987, s. 10, for "or the development of village industries" (w.e.f. 24-7-1987)`
obj_root_law_sections_18:
  sectionId (9759)
  sectionNo (18)
  orderNo 22
  title `Funds of the Commission.`
  content obj_root_law_sections_18_content
  footnotes `1. Subs. by s. 11, ibid., for sub-sections (1), (1A) and (1B) (w.e.f. 1-4-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9759&sectionno=18&orderno=22&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_18_content:
  string
  line `^1[(1) The Commission shall have stet separate funds to be called the`
  line `the khadi fund, the village industries fund and the general and miscellaneous fund.`
  line
  line `(1A) There shall be credited,--`
  line
  line `(a) to the khadi fund, all sums received by the Commission for the purposes relating to khadi.`
  line
  line `(b) to the village industries fund, all sums received by the Commission for the purposes relating`
  line `to village industries and products of handicrafts;`
  line
  line `(c) to the general and miscellaneous fund, all other sums received by the Commission:`
  line
  line `Provided that if the amount available in any of the said funds is in excess 6f the requirements of that`
  line `fund and the amount available in any other of the said funds is insufficient to meet the requirements of`
  line `that fund, the Commission may, with the previous approval of the Central Government, transfer from the`
  line `first mentioned fund the excess amount or such part thereof as may be necessary to the other fund.`
  line
  line `Explanation.--For the purpose of computing the amount in any of the said funds, the amount`
  line `received under section 17A shall not be taken into account.`
  line
  line `(1B) The sums credited under sub-section (1),--`
  line
  line `(a) to the khadi fund, shall be applied for the purposes relating to khadi;`
  line
  line `(b) to the village industries fund, shall be stet for the purposes relating to village industries and`
  line `products of handicrafts;`
  line
  line `(c) to the general and miscellaneous fund, shall be stet for the purposes relating to khadi and`
  line `village industries and for meeting the salary, allowances and other remuneration of the members,`
  line `officers and other employees of the Commission and other administrative expenses of the`
  line Commission.]
  line
  line `(2) Except as otherwise directed by the Central Government, all moneys belonging to such funds shall`
  line `be deposited in the Reserve Bank of India or with the agents of the Reserve Bank of India, or, where there`
  line `is neither an office of the Reserve Bank of India nor an agent of the Reserve Bank of India, in a`
  line `Government Treasury, or be invested in such securities as may be approved by the Central Government.`
obj_root_law_sections_19:
  sectionId (9760)
  sectionNo (19)
  orderNo 23
  title `Power of the Commission to spend.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9760&sectionno=19&orderno=23&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_19_content:
  string
  line `Subject to the provisions of section 20 the Commission`
  line `shall have power to spend such sums as it thinks fit on purposes authorised by this Act:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the Commission from spending, with`
  line `the previous approval of the Central Government, such moneys, as it thinks fit on any such purpose`
  line `outside the territories to which this Act extends.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_19_a:
  sectionId (9761)
  sectionNo 19A
  orderNo 24
  title `Standing Finance Committees.`
  content obj_root_law_sections_19_a_content
  footnotes obj_root_law_sections_19_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9761&sectionno=19A&orderno=24&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_19_a_content:
  string
  line `^1[19A. Standing Finance Committees.--(1) There shall be constituted from among the members`
  line `of the Commission in the prescribed manner, a Standing Finance Committee in respect of each of the`
  line `^2[three funds] referred to in section 18.`
  line
  line `^3[Provided that the Chief Executive Officer and Financial Adviser shall be ex officio members of the`
  line `Standing Finance Committee in respect of each of the three separate funds referred to in sub-section (1) of`
  line `section 18,].`
  line
  line `(2) The Standing Finance Committee shall exercise such of the powers of the Commission under`
  line `section 19 as are delegated to it by the Commission.]`
obj_root_law_sections_19_a_footnotes:
  string
  line `1. Ins. by Act 32 of 1961, s. 11 (w.e.f. 28-8-1961).`
  line
  line `2. Subs. by Act 12 of 1987, s. 12, for "two funds" (w.e.f. 1-4-1988).`
  line
  line `3. The proviso ins. by Act 10 of 2006, s. 11 (w.e.f. 15-5-2006).`
obj_root_law_sections_19_b:
  sectionId (9762)
  sectionNo 19B
  orderNo 25
  title `Recovery of monies due to the Commission as arrears of land-revenue.`
  content obj_root_law_sections_19_b_content
  footnotes `1. Ins. by Act 32 of 1961, s. 11 (w.e.f. 28-8-1961).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9762&sectionno=19B&orderno=25&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_19_b_content:
  string
  line `^1[19B. Recovery of monies due to the Commission as arrears of land-revenue.--(1) Any sum`
  line `payable to the Commission under any agreement, express or implied, or otherwise howsoever, may be`
  line `recovered in the same manner as an arrear of land revenue.`
  line
  line `(2) If any question arises whether a sum is payable to the Commission within the meaning of`
  line `sub-section (1), it shall be referred to a Tribunal constituted by the Central Government for the purpose`
  line `which shall, after making such inquiry as it may deem fit and after giving to the person by whom the sum`
  line `is alleged to be payable an opportunity of being heard, decide the question; and the decision of the`
  line `Tribunal shall be final and shall not be called in question by any court or other authority.`
  line
  line `(3) The Tribunal shall consist of one person who is not connected with the Commission or with the`
  line `person by whom the sum is alleged to be payable.`
  line
  line `(4) The expenses of the Tribunal shall be borne by the Commission.]`
obj_root_law_sections_20:
  sectionId (9763)
  sectionNo (20)
  orderNo 26
  title Budget.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9763&sectionno=20&orderno=26&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_20_content:
  string
  line `(1) The Commission shall, by such date in each year as may be prescribed, prepare and`
  line `submit to the Central Government for approval ^1[three separate budgets] in the prescribed form for the`
  line `next financial year, to be called the khadi budget ^2[, the village industries budget and the general and`
  line `miscellaneous budget], showing the estimated receipts and expenditure in respect to khadi ^3[, village`
  line `industries and products of handicrafts and khadi and village industries respectively] during that financial`
  line year.
  line
  line `(2) Subject to the provisions of sub-sections (3) and (4), no sum shall be expended by or on behalf of`
  line `the Commission unless the expenditure is covered by a specific provision in the budget approved by the`
  line `Central Government.`
  line
  line `^4[(3) The Commission may within the respective limits of the khadi budget, the village industries`
  line `budget and the general and miscellaneous budget, sanction any reappropriation from one head of`
  line `expenditure to another or from a provision made for one scheme to that in respect of another, but subject`
  line `to the proviso to sub-section (1) of section 18, in no case shall a reappropriation of fund be made from`
  line `one budget to any of the other two budgets:`
  line
  line `Provided that no reappropriation from the head "Loan" to any other head of expenditure and`
  line `vice versa in any of the budgets shall be sanctioned by the Commission, except with the previous`
  line `approval of the Central Government.].`
  line
  line `(4) The Commission may, within such limits and subject to such conditions as may be prescribed,`
  line `incur expenditure in excess of the limit provided in the budget approved by the Central Government`
  line `under any head of expenditure or in connection with any particular scheme, so long as the aggregate`
  line `amount in ^5[the budget] approved by the Central Government is not exceeded.`
obj_root_law_sections_20_footnotes:
  string
  line `1. Subs. by Act 12 of 1987, s. 13, for "two separate budgets (w.e.f. 1-4-1988).`
  line
  line `2. Subs. by s. 13, ibid., for "and the village industries budget" (w.e.f. 1-4-1988).`
  line
  line `3. Subs. by s. 13, ibid., for and "village industries respectively" (w.e.f. 1-4-1988).`
  line
  line `4. Subs. by s. 13, ibid., for sub-section (3) (w.e.f. 1-4-1988).`
  line
  line `5. Subs. by s. 13, ibid., for "either budget" (w.e.f. 1-4-1988).`
obj_root_law_sections_21:
  sectionId (9764)
  sectionNo (21)
  orderNo 27
  title `Borrowing of money.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9764&sectionno=21&orderno=27&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_21_content:
  string
  line `Subject to such rules as may be made in this behalf, the Commission`
  line `shall have power to borrow on the security of the khadi fund or the village industries fund or any other`
  line `asset for any purposes for which such funds may be applied.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (9765)
  sectionNo (22)
  orderNo 28
  title `Transfer of liabilities and obligations to the Commission.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9765&sectionno=22&orderno=28&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_22_content:
  string
  line `All liabilities incurred, by all`
  line `contracts entered into with, and all matters and things engaged to be done by, or for, the Central`
  line `Government in connection with the development of khadi or village industries at any time after the 14th`
  line `day of January, 1953, and before the commencement of this Act, shall, after such commencement, be`
  line `deemed to have been incurred by, entered into with, or engaged to be done by, or for, the Commission.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (9766)
  sectionNo (23)
  orderNo 29
  title `Accounts and audit.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9766&sectionno=23&orderno=29&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_23_content:
  string
  line `(1) The Commission shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts including the profit and loss account and the balance`
  line `sheet in such form as may be prescribed by the Central Government in consultation with the Comptroller`
  line `and Auditor-General of India.`
  line
  line `(2) The accounts of the Commission shall be audited by the Comptroller and Auditor-General of India`
  line `at such intervals as may be prescribed by him.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Commission shall have the same rights and privileges and authority`
  line `in connection with such audit as the Comptroller and Auditor-General has in connection with the audit of`
  line `Government accounts and, in particular, shall have the right to demand the production of books, accounts,`
  line `connected vouchers and other documents and papers and to inspect any of the offices of the Commission.`
  line
  line `(4) The accounts of the Commission as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (9767)
  sectionNo (24)
  orderNo 30
  title `Returns and reports.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9767&sectionno=24&orderno=30&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_24_content:
  string
  line `(1) The Commission shall furnish to the Central Government, at such`
  line `time and in such form and manner as may be prescribed or as the Central Government may direct, such`
  line `returns and statements and such particulars in regard to any proposed or existing programme for the`
  line `promotion and development of khadi and village industries, as the Central Government may, from time to`
  line `time, require.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Commission shall, as soon as possible`
  line `after the end of each financial year submit to the Central Government a report, in such form and before`
  line `such date as may be prescribed, giving a true and full account of its activities, policy and programme`
  line `during the previous financial year.`
  line
  line `(3) A copy of the report received under sub-section (2) shall be laid before each House of Parliament`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_24_a:
  sectionId (9768)
  sectionNo 24A
  orderNo 31
  title `Exemption from liability to pay income-tax.`
  content obj_root_law_sections_24_a_content
  footnotes `1 Ins. by Act 29 of 1977, s. 34 (w.e.f. 1-4-1962).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9768&sectionno=24A&orderno=31&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_24_a_content:
  string
  line `^1[24A. Exemption from liability to pay income-tax.-- Notwithstanding anything contained in the`
  line `Income-tax Act, 1961 (43 of 1961), the Commission shall not be liable to pay any income-tax on its`
  line `income, profits or gains.]`
obj_root_law_sections_25:
  sectionId (9769)
  sectionNo (25)
  orderNo 32
  title `Dissolution of the Commission.`
  content obj_root_law_sections_25_content
  footnotes `1. Ins. by Act 10 of 2006, s. 12 (w.e.f. 15-5-2006)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9769&sectionno=25&orderno=32&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_25_content:
  string
  line `(1) The Central Government may, by notification in the`
  line `Official Gazette, direct that the Commission shall be dissolved from such date as may be specified in the`
  line `notification and thereupon the Commission shall be deemed to be dissolved accordingly.`
  line
  line `(2) On and from the said date--`
  line
  line `(a) all properties and funds which, immediately before the said date, were in the possession of the`
  line `Commission for the purposes of this Act shall vest in the Central Government; and`
  line
  line `(b) all members shall vacate their office as members of the Commission.`
  line
  line `^1[(3) Any time after the issue of the notification under sub-section (1), the Central Government may`
  line `re-establish the Commission in accordance with the provisions of section 4 and on and from the date of`
  line `the re-establishment of the Commission, the properties and funds which had previously vested in the`
  line `Central Government under clause (a) of sub-section (2) shall stand vested in the Commission so`
  line re-established.]
obj_root_law_sections_26:
  sectionId (9770)
  sectionNo (26)
  orderNo 33
  title `Power to make rules.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9770&sectionno=26&orderno=33&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_26_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to give effect to the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `^1[(a) the manner of filling casual vacancies among the members of the Commission and the terms`
  line `and conditions of service of the Chairman, the Chief Executive Officer, the Financial Adviser and`
  line `other members of the Commission including the salary and allowances to be paid to them and the`
  line `travelling and daily allowances to be drawn by them when they are on tour;]`
  line
  line `^2[(aa) the powers to be exercised and functions to be discharged by the Chief Executive Officer`
  line `under sub-section (1) of section 5;`
  line
  line `(ab) the financial matters in respect of which the Financial Adviser shall be in charge under`
  line `section 5A;`
  line
  line `(ac) the transaction of business at the meetings of the Board under sub-section (2) of section 10;];`
  line
  line `(b)`
  line `^3***the procedure to be followed in removing a member who is or becomes subject to any`
  line disqualification;
  line
  line `(c) the term of office and other conditions of service of, the procedure to be followed in the`
  line `discharge of functions by, and the manner of filling casual vacancies among members of the Board;`
  line
  line `^4* * * * *`
  line
  line `^5[(dd) the constitution of the Standing Finance Committees under sub-section (1) of section 19 A;`
  line
  line `(ddd) the procedure to be followed by the Tribunal in deciding questions referred to it under`
  line `sub-section (2) of section 19B;]`
  line
  line `(e) the date by which, and the form in which, the budget shall be prepared and submitted in each`
  line `year under sub-section (1) of section 20;`
  line
  line `(f) the procedure to be followed for placing the Commission in possession of funds;`
  line
  line `(g) the procedure to be followed and the conditions to be observed in borrowing moneys or in`
  line `granting loans;`
  line
  line `(h) the conditions subject to which, and the mode in which, contracts may be entered into by or`
  line `on behalf of the Commission;`
  line
  line `(i) the form and manner in which the accounts of the Commission shall be maintained under`
  line `sub-section (1) of section 23;`
  line
  line `(j) the form and manner in which the returns, reports or statements shall be submitted under`
  line `section 23; and`
  line
  line `(k) any other matter which has to be, or may be, prescribed.`
  line
  line `^6* * * * *`
obj_root_law_sections_26_footnotes:
  string
  line `1. Subs. by Act 12 of 1987, s. 14, for clause (a) (w.e.f. 24-7-1987).`
  line
  line `2. Ins. by Act 10 of 2006, s. 13 (w.e.f. 15-5-2006).`
  line
  line `3. The words "the disqualifications for membership of the Commission and" omitted by Act 12 of 1987, s. 14 (w.e.f. 24-7-1987).`
  line
  line `4. Omitted by s. 14, ibid. (w.e.f. 24-7-1987).`
  line
  line `5. Ins. by Act 32 of 1961, s. 13 (w.e.f. 28-8-1961).`
  line
  line `6. Omitted by Act 12 of 1987, s. 14 (w.e.f. 24-7-1987).`
obj_root_law_sections_27:
  sectionId (9771)
  sectionNo (27)
  orderNo 34
  title `Power to make regulations.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9771&sectionno=27&orderno=34&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_27_content:
  string
  line `(1) The Commission may, with the previous sanction of the`
  line `Central Government, by notification in the Official Gazette, make regulations not inconsistent with this`
  line `Act and the rules made thereunder, for enabling it to discharge its functions under this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the terms and conditions of appointment and service and the scales of pay of officers and`
  line `servants of the Commission, other than ^1`
  line `[the Chief Executive Officer] and the Financial Adviser to`
  line `the Commission, including payment of travelling and daily allowances in respect of journeys`
  line `undertaken by such officers and servants for the purpose of this Act;`
  line
  line `(b) the time and place of meetings of the Commission, the procedure to be followed in regard to`
  line `transaction of business at such meetings and the quorum necessary for the transaction of such`
  line `business at a meeting;`
  line
  line ^2
  line `[(ba) the transaction of business at the meetings of the Zonal Committee under sub-section (2) of`
  line `section 12A;];`
  line
  line ^3
  line `[(bb) the summoning and holding of meetings, and the conduct of business of a Standing Finance`
  line `Finance Committee];`
  line
  line `(c) the delegation of powers and duties to ^4`
  line `*** or any employee of the Commission;`
  line
  line `(d) the maintenance of minutes of meetings of the Commission and of the Board and the`
  line `transmission of copies thereof to the Central Government;`
  line
  line `(e) the persons by whom, and the manner in which, payments deposits and investments may be`
  line `made on behalf of the Commission;`
  line
  line `(f) the custody of moneys required for the current expenditure of the Commission and investment`
  line `of moneys not so required;`
  line
  line `(g) the maintenance of accounts; and`
  line
  line `(h) the form in which certificates of genuineness of khadi and products of village industries may`
  line `be granted by the Commission ^5`
  line `[and the fees chargeable in respect thereof.]`
  line
  line ^6
  line `[(2A) The power to make regulations under this section with respect to the terms and conditions of`
  line `service and the scales of pay and pension to be paid to the employees of the Commission shall include the`
  line `power to give retrospective effect from a date not earlier than the commencement of this Act, to such`
  line `regulations or any of them but no retrospective effect shall be given to any such regulation so as to`
  line `prejudicially affect the interest of any person to whom such regulation may be applicable.]`
  line
  line `(3) The Central Government may, by notification in the Official Gazette, rescind any regulation`
  line `which it has sanctioned and thereupon the regulation shall cease to have effect.`
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by Act 12 of 1987, s. 15, for clause (a) for "the secretary" (w.e.f. 24-7-1987).`
  line
  line `2. Ins. by Act 10 of 2006, s. 14 (w.e.f. 15-5-2006).`
  line
  line `3. Ins. by Act 32 of 1961, s. 14 (w.e.f. 28-8-1961).`
  line
  line `4. The words "the Chief Executive Officer or" omitted by Act 10 of 2006, s. 14 (w.e.f. 15-5-2006).`
  line
  line `5. Added by Act 32 of 1961, s. 14 (w.e.f. 28-8-1961).`
  line
  line `6. Ins. by Act 12 of 1987, s. 15 (w.e.f. 24-7-1987).`
obj_root_law_sections_28:
  sectionId (9772)
  sectionNo (28)
  orderNo 35
  title `Rules and Regulations to be laid before Parliament.`
  content obj_root_law_sections_28_content
  footnotes `1. Ins. by s. 16, ibid. (w.e.f. 24-7-1987).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_46_77_00001_195661_1517807324225&sectionId=9772&sectionno=28&orderno=35&orgactid=AC_CEN_46_77_00001_195661_1517807324225
obj_root_law_sections_28_content:
  string
  line `^1[28. Rules and Regulations to be laid before Parliament.--Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.]`
