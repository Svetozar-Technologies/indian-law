obj_root_law_sections_2_content:
  string
  line `The Farmers (Empowerment and`
  line `Protection) Agreement on Price Assurance and Farm Services Act, 2020, the Farmers' Produce Trade and`
  line `Commerce (Promotion and Facilitation) Act, 2020 and the Essential Commodities (Amendment) Act, 2020`
  line `are hereby repealed.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (59023)
  sectionNo (3)
  orderNo 3
  title `Amendment of Act 10 of 1955`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00012_202140_1638437177885&sectionId=59023&sectionno=3&orderno=3&orgactid=AC_CEN_23_31_00012_202140_1638437177885
obj_root_law_sections_3_content:
  string
  line `In section 3 of the Essential Commodities Act, 1955,`
  line `sub-section (1A) shall be omitted.`
obj_root_law_sections_3_footnotes:
  string
  line
