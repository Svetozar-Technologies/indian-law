obj_root_law_sections_7_o:
  sectionId (41855)
  sectionNo 7-O
  orderNo 33
  title `Deposit of amount due, on filing appeal.`
  content obj_root_law_sections_7_o_content
  footnotes `1. Subs. by Act 7 of 2017, s. 159, for section 7D (w.e.f. 26-5-2017).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41855&sectionno=7-O&orderno=33&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_7_o_content:
  string
  line `^1[7-O. Deposit of amount due, on filing appeal.--No appeal by the employer shall be entertained by a Tribunal unless he has deposited with it seventy-five per cent. of the amount due from him as determined by an officer referred to in section 7A:`
  line
  line `Provided that the Tribunal may, for reasons to be recorded in writing, waive or reduce the amount to be deposited under this section.]`
obj_root_law_sections_7_p:
  sectionId (41441)
  sectionNo 7P
  orderNo 34
  title `Transfer of certain applications to Tribunals.`
  content `^1[7P. Transfer of certain applications to Tribunals.--All applications which are pending before the Central Government under section 19A before its repeal, shall stand transferred to a Tribunal exercising jurisdiction in respect of establishments in relation to which such applications had been made as if such applications were appeals preferred to the Tribunal.]`
  footnotes `1. Subs. by Act 7 of 2017, s. 159, for section 7D (w.e.f. 26-5-2017).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41441&sectionno=7P&orderno=34&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_7_q:
  sectionId (41442)
  sectionNo 7Q
  orderNo 35
  title `Interest payable by the employer.`
  content obj_root_law_sections_7_q_content
  footnotes `1. Subs. by Act 7 of 2017, s. 159, for section 7D (w.e.f. 26-5-2017).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41442&sectionno=7Q&orderno=35&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_7_q_content:
  string
  line `^1[7Q. Interest payable by the employer.--The employer shall be liable to pay simple interest at the rate of twelve per cent. per annum or at such higher rate as may be specified in the Scheme on any amount due from him under this Act from the date on which the amount has become so due till the date of its actual payment:`
  line
  line `Provided that higher rate of interest specified in the Scheme shall not exceed the lending rate of interest charged by any scheduled bank.]`
obj_root_law_sections_8:
  sectionId (41443)
  sectionNo (8)
  orderNo 36
  title `Mode of recovery of moneys due from employers.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41443&sectionno=8&orderno=36&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_content:
  string
  line `^1[8. Mode of recovery of moneys due from employers.-- Any amount due--`
  line
  line `(a) from the employer in relation to ^2[an establishment] to which any ^3[Scheme or the Insurance`
  line `Scheme] applies in respect of any contribution payable to ^4[the Fund or, as the case may be, the`
  line `Insurance Fund], damages recoverable under section 14B, accumulations required to be transferred`
  line `under sub-section (2) of section 15 ^5[or under sub-section (5) of section 17] or any charges payable by`
  line `him under any other provision of this Act or of any provision of the ^3[Scheme or the Insurance`
  line `Scheme]; or`
  line
  line `(b) from the employer in relation to an exempted ^6[establishment] in respect of any damages`
  line `recoverable under section 14B or any charges payable by him to the appropriate Government under`
  line `any provision of this Act or under any of the conditions specified ^7[under section 17 or in respect of`
  line `the contribution payable by him towards the ^8[Pension] Scheme under the said section 17],`
  line
  line `may, if the amount is in arrear, ^9[be recovered ^10[in the manner specified in sections 8B to 8G].]`
obj_root_law_sections_8_footnotes:
  string
  line `1. Subs. by Act 37 of 1953, s. 6, for section 8.`
  line
  line `2. Subs. by Act 94 of 1956, s. 3, for "a factory".`
  line
  line `3. Subs. by Act 99 of 1976, s. 24, for "Scheme" (w.e.f. 1-8-1976).`
  line
  line `4. Subs. by s. 24, ibid., for "the Fund" (w.e.f. 1-8-1976).`
  line
  line `5. Ins. by Act 28 of 1963, s. 7 (w.e.f. 30-11-1963).`
  line
  line `6. Subs. by Act 94 of 1956, s. 3, for "factory".`
  line
  line `7. Subs. by Act 16 of 1971, s. 21, for "under section 17" (w.e.f. 23-4-1971).`
  line
  line `8. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `9. Subs. by Act 40 of 1973, s. 2, for certain words (w.e.f. 1-11-1973).`
  line
  line `10. Subs. by Act 33 of 1988, s. 12, for certain words (w.e.f. 1-7-1990).`
obj_root_law_sections_8_a:
  sectionId (41444)
  sectionNo 8A
  orderNo 37
  title `Recovery of moneys by employers and contractors.`
  content obj_root_law_sections_8_a_content
  footnotes obj_root_law_sections_8_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41444&sectionno=8A&orderno=37&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_a_content:
  string
  line `^1[8A. Recovery of moneys by employers and contractors.-- (1) ^2[The amount of contribution`
  line `(that is to say the employer's contribution as well as the employee's contribution in pursuance of any`
  line `Scheme and the employer's contribution in pursuance of the Insurance Scheme)], and any charges ^3*** for meeting the cost of administering the Fund paid or payable by an employer in respect of an employee`
  line `employed by or through a contractor may be recovered by such employer from the contractor, either by`
  line `deduction from any amount payable to the contractor, under any contract or as a debt payable by the`
  line contractor.
  line
  line `(2) A contractor from whom the amounts mentioned in sub-section (1) may be recovered in respect of`
  line `any employee employed by or through him, may recover from such employee the employee's`
  line `contribution ^4[under any Scheme] by deduction from the basic wages, dearness allowance and retaining`
  line `allowance (if any) payable to such employee.`
  line
  line `(3) Notwithstanding any contract to the contrary, no contractor shall be entitled to deduct the`
  line `employer's contribution or the charges referred to in sub-section (1) from the basic wages, dearness`
  line `allowance, and retaining allowance (if any) payable to an employee employed by or through him or`
  line `otherwise to recover such contribution or charges from such employee.`
  line
  line `Explanation.-- In this section, the expressions, "dearness allowance" and "retaining allowance" shall`
  line `have the same meanings as in section 6.]`
obj_root_law_sections_8_a_footnotes:
  string
  line `1. Ins. by Act 28 of 1963, s. 8 (w.e.f. 30-11-1963).`
  line
  line `2. Subs. by Act 99 of 1976, s. 25, for certain words (w.e.f. 1-8-1976).`
  line
  line `3. The words "on the basis of such contribution" omitted by Act 33 of 1988, s. 13. (w.e.f. 1-8-1988).`
  line
  line `4. Ins. by Act 99 of 1976, s. 25 (w.e.f. 1-8-1976).`
obj_root_law_sections_8_b:
  sectionId (41445)
  sectionNo 8B
  orderNo 38
  title `Issue of certificate to the Recovery Officer.`
  content obj_root_law_sections_8_b_content
  footnotes `1. Ins. by Act 33 of 1988, s. 14 (w.e.f. 1-7-1990).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41445&sectionno=8B&orderno=38&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_b_content:
  string
  line `^1[8B. Issue of certificate to the Recovery Officer.-- (1) Where any amount is in arrear under section`
  line `section 8, the authorised officer may issue, to the Recovery Officer, a certificate under his signature`
  line `specifying the amount of arrears and the Recovery Officer, on receipt of such certificate, shall proceed to`
  line `recover the amount specified therein from the establishment or, as the case may be, the employer by one`
  line `or more of the modes mentioned below:--`
  line
  line `(a) attachment and sale of the movable or immovable property of the establishment or, as the case`
  line `may be, the employer;`
  line
  line `(b) arrest of the employer and his detention in prison;`
  line
  line `(c) appointing a receiver for the management of the movable or immovable properties of the`
  line `establishment or, as the case may be, the employer:`
  line
  line `Provided that the attachment and sale of any property under this section shall first be effected against`
  line `the properties of the establishment and where such attachment and sale is insufficient for recovering the`
  line `whole of the amount of arrears specified in the certificate, the Recovery Officer may take such`
  line `proceedings against the property of the employer for recovery of the whole or any part of such arrears.`
  line
  line `(2) The authorised officer may issue a certificate under sub-section (1), notwithstanding that`
  line `proceedings for recovery of the arrears by any other mode have been taken.]`
obj_root_law_sections_8_c:
  sectionId (41446)
  sectionNo 8C
  orderNo 39
  title `Recovery Officer to whom certificate is to be forwarded.`
  content obj_root_law_sections_8_c_content
  footnotes `2. Ins. by Act 33 of 1988, s. 14 (w.e.f. 1-7-1990).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41446&sectionno=8C&orderno=39&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_c_content:
  string
  line `8C. Recovery Officer to whom certificate is to be forwarded.-- (1) The authorised officer may`
  line `forward the certificate referred to in section 8B to the Recovery Officer within whose jurisdiction the`
  line employer--
  line
  line `(a) carries on his business or profession or within whose jurisdiction the principal place of his`
  line `establishment is situate; or`
  line
  line `(b) resides or any movable or immovable property of the establishment or the employer is situate.`
  line
  line `(2) Where an establishment or the employer has property within the jurisdiction of more than one`
  line `Recovery Officers and the Recovery Officer to whom a certificate is sent by the authorised officer--`
  line
  line `(a) is not able to recover the entire amount by the sale of the property, movable or immovable,`
  line `within his jurisdiction; or`
  line
  line `(b) is of the opinion that, for the purpose of expediting or securing the recovery of the whole or`
  line `any part of the amount, it is necessary so to do,`
  line
  line `he may send the certificate or, where only a part of the amount is to be recovered, a copy of the certificate`
  line `certified in the prescribed manner and specifying the amount to be recovered to the Recovery Officer`
  line `within whose jurisdiction the establishment or the employer has property or the employer resides, and`
  line `thereupon that Recovery Officer shall also proceed to recover the amount due under this section as if the`
  line `certificate or the copy thereof had been the certificate sent to him by the authorised officer.]`
obj_root_law_sections_8_d:
  sectionId (41447)
  sectionNo 8D
  orderNo 40
  title `Validity of certificate and amendment thereof.`
  content obj_root_law_sections_8_d_content
  footnotes `1. Ins. by Act 33 of 1988, s. 14 (w.e.f. 1-7-1990).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41447&sectionno=8D&orderno=40&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_d_content:
  string
  line `^1[8D. Validity of certificate and amendment thereof.-- (1) When the authorised officer issues a`
  line `certificate to a Recovery Officer under section 8B, it shall not be open to the employer to dispute before`
  line `the Recovery Officer the correctness of the amount, and no objection to the certificate on any other`
  line `ground shall also be entertained by the Recovery Officer.`
  line
  line `(2) Notwithstanding the issue of a certificate to a Recovery Officer, the authorised officer shall have`
  line `power to withdraw the certificate or correct any clerical or arithmetical mistake in the certificate by`
  line `sending an intimation to the Recovery Officer.`
  line
  line `(3) The authorised officer shall intimate to the Recovery Officer any order withdrawing or cancelling`
  line `a certificate or any correction made by him under sub-section (2) or any amendment made under`
  line `sub-section (4) of section 8E.]`
obj_root_law_sections_8_e:
  sectionId (41448)
  sectionNo 8E
  orderNo 41
  title `Stay of proceedings under certificate and amendment or withdrawal thereof.`
  content obj_root_law_sections_8_e_content
  footnotes `1. Ins. by Act 33 of 1988, s. 14 (w.e.f. 1-7-1990).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41448&sectionno=8E&orderno=41&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_e_content:
  string
  line `^1[8E. Stay of proceedings under certificate and amendment or withdrawal thereof.-- (1) Notwithstanding that a certificate has been issued to the Recovery Officer for the recovery of any amount,`
  line `the authorised officer may grant time for the payment of the amount, and thereupon the Recovery Officer`
  line `shall stay the proceedings until the expiry of the time so granted.`
  line
  line `(2) Where a certificate for the recovery of amount has been issued, the authorised officer shall keep`
  line `the Recovery Officer informed of any amount paid or time granted for payment, subsequent to the issue`
  line `of such certificate.`
  line
  line `(3) Where the order giving rise to a demand of amount for which a certificate for recovery has been`
  line `issued has been modified in appeal or other proceeding under this Act, and, as a consequence thereof, the`
  line `demand is reduced but the order is the subject-matter of a further proceeding under this Act, the`
  line `authorised officer shall stay the recovery of such part of the amount of the certificate as pertains to the`
  line `said reduction for the period for which the appeal or other proceeding remains pending.`
  line
  line `(4) Where a certificate for the recovery of amount has been issued and subsequently the amount of the`
  line `outstanding demand is reduced as a result of an appeal or other proceeding under this Act, the authorised`
  line `officer shall, when the order which was the subject-matter of such appeal or other proceeding has become`
  line `final and conclusive, amend the certificate or withdraw it, as the case may be.]`
obj_root_law_sections_8_f:
  sectionId (41449)
  sectionNo 8F
  orderNo 42
  title `Other modes of recovery.`
  content obj_root_law_sections_8_f_content
  footnotes `1. Ins. by Act 33 of 1988, s. 14 (w.e.f. 1-7-1990).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41449&sectionno=8F&orderno=42&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_f_content:
  string
  line `^1[8F. Other modes of recovery.-- (1) Notwithstanding the issue of a certificate to the Recovery`
  line `Officer under section 8B, the Central Provident Fund Commissioner or any other officer authorised by the`
  line `Central Board may recover the amount by any one or more of the modes provided in this section.`
  line
  line `(2) If any amount is due from any person to any employer who is in arrears, the Central Provident`
  line `Fund Commissioner or any other officer authorised by the Central Board in this behalf may require such`
  line `person to deduct from the said amount the arrears due from such employer under this Act and such person`
  line `shall comply with any such requisition and shall pay the sum so deducted to the credit of the Central`
  line `Provident Fund Commissioner or the officer so authorised, as the case may be:`
  line
  line `Provided that nothing in this sub-section shall apply to any part of the amount exempt from`
  line `attachment in execution of a decree of a civil court under section 60 of the Code of Civil Procedure, 1908`
  line `(5 of 1908).`
  line
  line `(3) (i) The Central Provident Fund Commissioner or any other officer authorised by the Central Board`
  line `in this behalf may, at any time or from time to time, by notice in writing, require any person from whom`
  line `money is due or may become due to the employer or, as the case may be, the establishment or any person`
  line `who holds or may subsequently hold money for or on account of the employer or as the case may be, the`
  line `establishment, to pay to the Central Provident Fund Commissioner either forthwith upon the money`
  line `becoming due or being held or at or within the time specified in the notice (not being before the money`
  line `becomes due or is held) so much of the money as is sufficient to pay the amount due from the employer in`
  line `respect of arrears or the whole of the money when it is equal to or less than that amount.`
  line
  line `(ii) A notice under this sub-section may be issued to any person who holds or may subsequently hold`
  line `any money for or an account of the employer jointly with any other person and for the purposes of this`
  line `sub-section, the shares of the joint-holders in such account shall be presumed, until the contrary is proved,`
  line `to be equal.`
  line
  line `(iii) A copy of the notice shall be forwarded to the employer at his last address known to the Central`
  line `Provident Fund Commissioner or, as the case may be, the officer so authorised and in the case of a joint`
  line `account to all the joint-holders at their last addresses known to the Central Provident Fund Commissioner`
  line `or the officer so authorised.`
  line
  line `(iv) Save as otherwise provided in this sub-section, every person to whom a notice is issued under this`
  line `sub-section shall be bound to comply with such notice, and, in particular, where any such notice is issued`
  line `to a post office, bank or an insurer, it shall not be necessary for any pass book, deposit receipt, policy or`
  line `any other document to be produced for the purpose of any entry, endorsement or the like being made`
  line `before payment is made notwithstanding any rule, practice or requirement to the contrary.`
  line
  line `(v) Any claim respecting any property in relation to which a notice under this sub-section has been`
  line `issued arising after the date of the notice shall be void as against any demand contained in the notice.`
  line
  line `(vi) Where a person to whom a notice under this sub-section is sent objects to it by a statement on`
  line `oath that the sum demanded or any part thereof is not due to the employer or that he does not hold any`
  line `money for or on account of the employer, then, nothing contained in this sub-section shall be deemed to`
  line `require such person to pay any such sum or part thereof, as the case may be, but if it is discovered that`
  line `such statement was false in any material particular, such person shall be personally liable to the Central`
  line `Provident Fund Commissioner or the officer so authorised to the extent of his own liability to the`
  line `employer on the date of the notice, or to the extent of the employers liability for any sum due under this`
  line `Act, whichever is less.`
  line
  line `(vii) The Central Provident Fund Commissioner or the officer so authorised may, at any time or from`
  line `time to time, amend or revoke any notice issued under this sub-section or extend the time for making any`
  line `payment in pursuance of such notice.`
  line
  line `(viii) The Central Provident Fund Commissioner or the officer so authorised shall grant a receipt for`
  line `any amount paid in compliance with a notice issued under this sub-section, and the person so paying shall`
  line `be fully discharged from his liability to the employer to the extent of the amount so paid.`
  line
  line `(ix) Any person discharging any liability to the employer after the receipt of a notice under this`
  line `sub-section shall be personally liable to the Central Provident Fund Commissioner or the officer so`
  line `authorised to the extent of his own liability to the employer so discharged or to the extent of the`
  line `employer's liability for any sum due under this Act, whichever is less.`
  line
  line `(x) If the person to whom a notice under this sub-section is sent fails to make payment in pursuance`
  line `thereof to the Central Provident Fund Commissioner or the officer so authorised he shall be deemed to be`
  line `an employer in default in respect of the amount specified in the notice and further proceedings may be`
  line `taken against him for the realisation of the amount as if it were an arrear due from him, in the manner provided in sections 8B to 8E and the notice shall have the same effect as an attachment of a debt by the`
  line `Recovery Officer in exercise of his powers under section 8B.`
  line
  line `(4) The Central Provident Fund Commissioner or the officer authorised by the Central Board in this`
  line `behalf may apply to the court in whose custody there is money belonging to the employer for payment to`
  line `him of the entire amount of such money, or if it is more than the amount due, an amount sufficient to`
  line `discharge the amount due.`
  line
  line `(5) The Central Provident Fund Commissioner or any officer not below the rank of Assistant`
  line `Provident Fund Commissioner may, if so authorised by the Central Government by general or special`
  line `order, recover any arrears of amount due from an employer or, as the case may be, from the establishment`
  line `by distraint and sale of his or its movable property in the manner laid down in the Third Schedule to the`
  line `Income- tax Act, 1961 (43 of 1961).]`
obj_root_law_sections_8_g:
  sectionId (41450)
  sectionNo 8G
  orderNo 43
  title `Application of certain provisions of Income-tax Act.`
  content obj_root_law_sections_8_g_content
  footnotes `1. Ins. by Act 33 of 1988, s. 14 (w.e.f. 1-7-1990).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41450&sectionno=8G&orderno=43&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_8_g_content:
  string
  line `^1[8G. Application of certain provisions of Income-tax Act.-- The provisions of the Second and Third`
  line `Schedules to the Income-tax Act, 1961 (43 of 1961) and the Income-tax (Certificate Proceedings) Rules,`
  line `1962, as in force from time to time, shall apply with necessary modifications as if the said provisions and`
  line `the rules referred to the arrears of the amount mentioned in section 8 of this Act instead of to the`
  line `income-tax:`
  line
  line `Provided that any reference in the said provisions and the rules to the assessee shall be construed as`
  line `a reference to an employer as defined in this Act.]`
obj_root_law_sections_9:
  sectionId (41451)
  sectionNo (9)
  orderNo 44
  title `Fund to be recognised under Act 11 of 1922.`
  content obj_root_law_sections_9_content
  footnotes `1. Ins. by Act 37 of 1953, s. 7.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41451&sectionno=9&orderno=44&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_9_content:
  string
  line `For the purposes of the Indian Income-tax Act,`
  line `1922, the Fund shall be deemed to be a recognised provident fund within the meaning of Chapter IXA of`
  line `that Act:`
  line
  line `^1[Provided that nothing contained in the said Chapter shall operate to render ineffective any provision`
  line `of the Scheme (under which the Fund is established) which is repugnant to any of the provisions of that`
  line `Chapter or of the rules made thereunder.]`
obj_root_law_sections_10:
  sectionId (41452)
  sectionNo (10)
  orderNo 45
  title `Protection against attachment.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41452&sectionno=10&orderno=45&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_10_content:
  string
  line `(1) The amount standing to the credit of any member in the`
  line `Fund ^1[or of any exempted employee in a provident fund] shall not in any way be capable of being`
  line `assigned or charged and shall not be liable to attachment under any decree or order of any court in respect`
  line `of any debt or liability incurred by the member ^1[or the exempted employee], and neither the official`
  line `assignee appointed under the Presidency-towns Insolvency Act, 1909 (3 of 1909), nor any receiver`
  line `appointed under the Provincial Insolvency Act, 1920 (5 of 1920), shall be entitled to, or have any claim`
  line `on, any such amount.`
  line
  line `^2[(2) Any amount standing to the credit of a member in the Fund or of an exempted employee in a`
  line `provident fund at the time of his death and payable to his nominee under the Scheme or the rules of the`
  line `provident fund shall, subject to any deduction authorised by the said Scheme or rules, vest in the nominee`
  line `and shall be free from any debt or other liability incurred by the deceased or the nominee before the death`
  line `of the member of the exempted employee ^3[and shall also not be liable to attachment under any decree or`
  line `order of any court].`
  line
  line `^4[(3) The provisions of sub-section (1) and sub-section (2) shall, so far as may be, apply in relation to`
  line `the family pension or any other amount payable under the ^5[Pension] Scheme ^6[and also in relation to any amount payable under the Insurance Scheme] as they apply in relation to any amount payable out of the`
  line Fund.]
obj_root_law_sections_10_footnotes:
  string
  line `1. Ins. by s. 8, ibid.`
  line
  line `2. Subs. by s. 8, ibid., for sub-section (2).`
  line
  line `3. Ins. by Act 33 of 1988, s. 15 (w.e.f. 1-8-1988).`
  line
  line `4. Ins. by Act 16 of 1971, s. 22 (w.e.f. 23-4-1971).`
  line
  line `5. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f.16-11-1995).`
  line
  line `6. Ins. by Act 99 of 1976, s. 26 (w.e.f. 1-8-1976).`
obj_root_law_sections_11:
  sectionId (41453)
  sectionNo (11)
  orderNo 46
  title `Priority of payment of contributions over other debts.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41453&sectionno=11&orderno=46&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_11_content:
  string
  line `^1[(1)] ^2[Where any employer is`
  line `adjudicated insolvent or, being a company, an order for winding up is made, the amount due--`
  line
  line `(a) from the employer in relation to ^3[an establishment] to which any ^4[Scheme or the Insurance`
  line `Scheme] applies in respect of any contribution payable to the Fund ^5[or, as the case may be, the`
  line `Insurance Fund], damages recoverable under section 14B, accumulations required to be transferred`
  line `under sub-section (2) of section 15 or any charges payable by him under any other provision of this`
  line `Act or of any provision of the ^6[Scheme or the Insurance Scheme]; or`
  line
  line `(b) from the employer in relation to an exempted ^7[establishment] in respect of any contribution`
  line `to ^8[the Provident Fund or any Insurance Fund] (in so far it relates to exempted employees), under the`
  line `the rules of ^8[the Provident Fund or any Insurance Fund], ^9[any contribution payable by him towards`
  line `the Family Pension Fund under sub-section (6) of section 17], damages recoverable under section`
  line `14B or any charges payable by him to the appropriate Government under any provision of this Act or`
  line `under any of the conditions specified under section 17,`
  line
  line `shall, where the liability thereof has accrued before the order of adjudication or winding up is made, be`
  line `deemed to be included among the debts which under section 49 of the Presidency-towns Insolvency Act,`
  line `1909 (3 of 1909), or under section 61 of the Provincial Insolvency Act, 1920 (5 of 1920), or under`
  line `^10[section 530 of the Companies Act, 1956 (1 of 1956)], are to be paid in priority to all other debts in the`
  line `distribution of the property of the insolvent or the assets of the company being wound up, as the case may`
  line be.
  line
  line `^11[Explanation.--In this sub-section and in section 17, "insurance fund" means any fund established`
  line `by an employer under any scheme for providing benefits in the nature of life insurance to employees,`
  line `whether linked to their deposits in provident fund or not, without payment by the employees of any`
  line `separate contribution or premium in that behalf.`
  line
  line `^12[(2) Without prejudice to the provisions of sub-section (1), if any amount is due from an employer`
  line `^13[whether in respect of the employees contribution (deducted from the wages of the employee) or the`
  line `employer's contribution], the amount so due shall be deemed to be the first charge on the assets of the`
  line `establishment, and shall, notwithstanding anything contained in any other law for the time being in force,`
  line `be paid in priority to all other debts.]`
obj_root_law_sections_11_footnotes:
  string
  line `1. Section 11 re-numbered as sub-section (1) of that section by Act 40 of 1973, s. 3 (w.e.f. 1-11-1973).`
  line `2. Subs. by Act 37 of 1953, s. 9, for certain words.`
  line `3. Subs. by Act 94 of 1956, s. 3, for "a factory".`
  line `4. Subs. by Act 99 of 1976, s. 27, for "Scheme" (w.e.f. 1-8-1976).`
  line `5. Ins. by s. 27, ibid. (w.e.f. 1-8-1976).`
  line `6. Subs. by Act 99 of 1976, s. 27, for "Scheme" (w.e.f. 1-8-1976).`
  line `7 Subs. by Act 94 of 1956, s. 3, for "Factory".`
  line `8. Subs. by Act 99 of 1976, s. 27, for "the provident fund" (w.e.f. 1-8-1976).`
  line `9. Ins. by Act 16 of 1971, s. 23 (w.e.f. 23-4-1971).`
  line `10. Subs. by Act 40 of 1973, s. 3, for certain words (w.e.f. 1-11-1973).`
  line `11. Ins. by Act 99 of 1976, s. 27 (w.e.f. 1-8-1976).`
  line `12. Ins. by Act 40 of 1973, s. 3 (w.e.f. 1-11-1973).`
  line `13. Subs. by Act 33 of 1988, s. 16, for certain words (w.e.f. 1-8-1988).`
obj_root_law_sections_12:
  sectionId (41454)
  sectionNo (12)
  orderNo 47
  title `Employer not to reduce wages, etc.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41454&sectionno=12&orderno=47&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_12_content:
  string
  line `^1[12. Employer not to reduce wages, etc. -- No employer in relation to ^2[an establishment] to which`
  line `any ^3[Scheme or the Insurance Scheme] applies shall, by reason only of his liability for the payment of any contribution to ^4[the Fund or the Insurance Fund] or any charges under this Act or the ^5[Scheme or the`
  line `the Insurance Scheme], reduce, whether directly or indirectly, the wages of any employee to whom the`
  line `^5[Scheme or the Insurance Scheme] applies or the total quantum of benefits in the nature of old age`
  line `pension, gratuity ^6[Provident Fund or Life Insurance] to which the employee is entitled under the terms of`
  line `of his employment, express or implied.]`
obj_root_law_sections_12_footnotes:
  string
  line `1. Subs. by Act 37 of 1953, s. 10, for section 12.`
  line
  line `2. Subs. by Act 94 of 1956, s. 3, for "a factory".`
  line
  line `3. Subs. by Act 99 of 1976, s. 28, for "Scheme" (w.e.f. 1-8-1976).`
  line
  line `4. Subs. by Act 99 of 1976, s. 28, for "the Fund" (w.e.f. 1-8-1976).`
  line
  line `5. Subs. by s. 28, ibid., for "Scheme" (w.e.f. 1-8-1976).`
  line
  line `6. Subs. by s. 28, ibid., "or provident Fund" (w.e.f. 1-8-1976)`
obj_root_law_sections_13:
  sectionId (41455)
  sectionNo (13)
  orderNo 48
  title Inspectors.
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41455&sectionno=13&orderno=48&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_13_content:
  string
  line `(1) The appropriate Government may, by notification in the Official Gazette,`
  line `appoint such persons as it thinks fit to be Inspectors for the purposes of this Act ^1[, the Scheme] ^2[, the ^3[Pension] Scheme or the Insurance Scheme], and may define their jurisdiction.`
  line
  line `(2) Any Inspector appointed under sub-section (1) may, for the purpose of inquiring into the`
  line `correctness of any information furnished in connection with this Act or with any ^4`
  line `Scheme or the`
  line `Insurance Scheme or for the purpose of ascertaining whether any of the provisions of this Act or of any`
  line `^4[Scheme or the Insurance Scheme] have been complied with ^5[in respect of ^6[`
  line `an establishment] to which`
  line `which any ^4[Scheme or the Insurance Scheme] applies or for the purpose of ascertaining whether the`
  line `provisions of this Act or any`
  line `Scheme or the Insurance Scheme are applicable to any ^7[establishment]`
  line `to which the ^4[Scheme or the Insurance Scheme] has not been applied or for the purpose of determining`
  line `whether the conditions subject to which exemption was granted under section 17 are being complied with`
  line `by the employer in relation to an exempted ^7[establishment]]--`
  line
  line `(a) require an employer ^8or any contractor from whom any amount is recoverable under section`
  line `8A to furnish such information as he may consider necessary ^9***;`
  line
  line `(b) at any reasonable time ^10[and with such assistance, if any, as he may think fit, enter and`
  line `search] any`
  line `^7[establishment] or any premises connected therewith and require any one found in`
  line `charge thereof to produce before him for examination any accounts, books, registers and other`
  line `documents relating to the employment of persons or the payment of wages in the ^7[establishment];`
  line
  line `(c) examine, with respect to any matter relevant to any of the purposes aforesaid, the employer`
  line `^8[or any contractor from whom any amount is recoverable under section 8A], his agent or servant or`
  line `any other person found in charge of the ^7[establishment] of any premises connected therewith or`
  line `whom the Inspector has reasonable cause to believe to be or to have been, an employee in the`
  line ^7[establishment];
  line
  line `^11(d) make copies of, or take extracts from, any book, register or other document maintained in`
  line `relation to the establishment and, where he has reason to believe that any offence under this Act has`
  line `been committed by an employer, seize with such assistance as he may think fit, such book, register or`
  line `other document or portions thereof as he may consider relevant in respect of that offence;`
  line
  line `(e) exercise such other powers as the ^4[Scheme or the Insurance Scheme] may provide.`
  line
  line `^12[(2A) Any Inspector appointed under sub-section (1) may, for the purpose of inquiring into the`
  line `correctness of any information furnished in connection with the ^13[Pension] Scheme or for the purpose of`
  line `ascertaining whether any of the provisions of this Act or of the ^13[Pension] Scheme have been complied`
  line `with in respect of an establishment to which the ^13[Pension] Scheme applies, exercise all or any of the`
  line `powers conferred, on him under clause (a), clause (b), clause (c) or clause (d) of sub-section (2).`
  line
  line `^14[ ^15[(2B)] The provisions of the Code of Criminal Procedure, 1898 (5 of 1898) shall, so far as may be,`
  line `be, apply to any search or seizure under sub-section (2), ^16[or under sub-section (2A), as the case may be],`
  line `as they apply to any search or seizure made under the authority of a warrant issued under section 98 of the`
  line `said Code.`
  line
  line `^17* * * * *`
obj_root_law_sections_13_footnotes:
  string
  line `1. Subs. by Act 16 of 1971, s. 24, for "or of any Scheme" (w.e.f. 23-4-1971).`
  line
  line `2. Subs. by Act 99 of 1976, s. 29, for or "the Family Pension Scheme" (w.e.f. 1-8-1976).`
  line
  line `3. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `4. Subs. by Act 99 of 1976, s. 29, for "Scheme" (w.e.f. 1-8-1976).`
  line
  line `5. Ins. by Act 37 of 1953, s. 11.`
  line
  line `6. Subs. by Act 94 of 1956, s. 3, for a "factory".`
  line
  line `7. Subs. by s. 3, ibid., for "factory".`
  line
  line `8. Ins. by Act 28 of 1963, s. 9 (w.e.f. 30-11-1963).`
  line
  line `9. The words in relation to the Scheme omitted by Act 37 of 1953, s. 11.`
  line
  line `10. Subs. by Act 28 of 1963, s. 9, for enter (w.e.f. 30-11-1963).`
  line
  line `11. Subs. by s. 9,ibid., for clause (d) (w.e.f. 30-11-1963).`
  line
  line `12. Ins. by Act 16 of 1971, s. 24.`
  line
  line `13. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `14. Ins. by Act 28 of 1963, s. 9 (w.e.f. 30-11-1963).`
  line
  line `15. Sub-section (2A) re-numbered as sub-section (2B) by Act 16 of 1971, s. 24 (w.e.f. 23-4-1971).`
  line
  line `16. Ins. by s. 24, ibid. (w.e.f. 23-4-1971).`
  line
  line `17. Sub-section (3) omitted by Act 33 of 1988, s. 17 (w.e.f. 1-8-1988).`
obj_root_law_sections_14:
  sectionId (41456)
  sectionNo (14)
  orderNo 49
  title Penalties.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41456&sectionno=14&orderno=49&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_14_content:
  string
  line `(1) Whoever, for the purpose of avoiding any payment to be made by himself under`
  line `this Act ^1[, the Scheme ^2[, the ^3[Pension] Scheme or the Insurance Scheme]] or of enabling any other`
  line `person to avoid such payment, knowingly makes or causes to be made any false statement or false`
  line `representation shall be punishable with imprisonment for a term which may extend to ^4[one year, or with`
  line `fine of five thousand rupees, or with both.]`
  line
  line `^5[(1A) An employer who contravenes, or makes default in complying with, the provisions of section`
  line `6 or clause (a) of sub-section (3) of section 17 in so far as it relates to the payment of inspection charges,`
  line `or paragraph 38 of the Scheme in so far as it relates to the payment of administrative charges, shall be`
  line `punishable with imprisonment for a term which may extend to ^6[three years] but--`
  line
  line `(a) which shall not be less than^7[one year and a fine of ten thousand rupees] in case of default in`
  line `payment of the employees' contribution which has been deducted by the employer from the`
  line `employees' wages;`
  line
  line `^8[(b) which shall not be less than six months and a fine of five thousand rupees, in any other`
  line case;]
  line
  line `^9* * * * *`
  line
  line `Provided that the court may, for any adequate and special reasons to be recorded in the judgment,`
  line `impose a sentence of imprisonment for a lesser term ^10***.]`
  line
  line `^11[(1B) An employer who contravenes, or makes default in complying with, the provisions of section`
  line `6C, or clause (a) of sub-section (3A) of section 17 in so far as it relates to the payment of inspection`
  line `charges, shall be punishable with imprisonment for a term which may extend to ^12[one year] but which shall not be less than ^13[six months] and shall also be liable to fine which may extend to ^14[five thousand`
  line `rupees]:`
  line
  line `Provided that the court may, for any adequate and special reasons to be recorded in the judgment,`
  line `impose a sentence of imprisonment for a lesser term ^15***.`
  line
  line `(2) ^16[Subject to the provisions of this Act, the Scheme] ^17[, the ^18[Pension Scheme or the Insurance`
  line `Scheme] may provide that any person who contravenes, or makes default in complying with, any of the`
  line `provisions thereof shall be punishable with imprisonment for a term which may extend ^19[one year, or with`
  line `with fine which may extend to four thousand rupees, or with both].`
  line
  line `^20[(2A) Whoever contravenes or makes default in complying with any provision of this Act or of any`
  line `condition subject to which exemption was granted under section 17 shall, if no other penalty is elsewhere`
  line `provided by or under this Act for such contravention or non-compliance, be punishable with`
  line `imprisonment which may extend to ^19[six months, but which shall not be less than one month, and shall`
  line `also be liable to fine which may extend to five thousand rupees.]`
  line
  line `^21* * * * *`
obj_root_law_sections_14_footnotes:
  string
  line `1. Subs. by Act 16 of 1971, s. 25, for "or under any Scheme".`
  line
  line `2. Subs. by Act 99 of 1976, s. 30, for "or the Family Pension Scheme" (w.e.f. 7-9-1976).`
  line
  line `3. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `4. Subs. by Act 33 of 1988, s. 18, for "six months, or with fine which may extend to one thousand rupees, or with both"`
  line `(w.e.f. 1-8-1988).`
  line
  line `5. Ins. by Act 40 of 1973, s. 4 (w.e.f. 1-11-1973).`
  line
  line `6. Subs. by Act 33 of 1988, s. 18, for "six months" (w.e.f. 1-8-1988).`
  line
  line `7. Subs. by s. 18, ibid., for "three months" (w.e.f. 1-8-1988).`
  line
  line `8. Subs. by Act 33 of 1988, s. 18 (w.e.f. 1-8-1988).`
  line
  line `9. The words "and shall also be liable to fine which may extend to two thousand rupees" omitted by s. 18,ibid.`
  line `(w.e.f. 1-8-1988).`
  line
  line `10. The words "or of fine only in lieu of imprisonment" omitted by s. 18, ibid. (w.e.f. 1-8-1988).`
  line
  line `11. Ins. by Act 99 of 1976, s. 30 (w.e.f. 7-9-1976).`
  line
  line `12. Subs. by Act 33 of 1988, s. 18, for "six months" (w.e.f. 1-8-1988).`
  line
  line `13. Subs. by Act 33 of 1988, s. 18, for "one month" (w.e.f. 1-8-1988).`
  line
  line `14. Subs. by s. 18, ibid., for "two thousand rupees" (w.e.f. 1-8-1988).`
  line
  line `15. The words "or of fine only in lieu of imprisonment" omitted by s. 18, ibid. (w.e.f. 1-8-1988).`
  line
  line `16. Subs. by Act 40 of 1973, s. 4, for "the scheme" (w.e.f. 1-11-1973).`
  line
  line `17. Subs. by Act 99 of 1976, s. 30, "or the family pension" (w.e.f. 7-9-1976).`
  line
  line `18. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `19. Subs. by Act 33 of 1988, s. 18, for "six months, or with fine which may extend to one thousand rupees, or with both"`
  line `(w.e.f. 1-8-1988).`
  line
  line `20. Ins. by Act 37 of 1953, s. 12.`
  line
  line `21. Omitted by Act 40 of 1973, s. 4 (w.e.f. 1-11-1973).`
obj_root_law_sections_14_a:
  sectionId (41457)
  sectionNo 14A
  orderNo 50
  title `Offences by companies.`
  content obj_root_law_sections_14_a_content
  footnotes obj_root_law_sections_14_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41457&sectionno=14A&orderno=50&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_14_a_content:
  string
  line `^1[14A. Offences by companies.-- (1) If the person committing an offence under this Act ^2[, the`
  line `Scheme or ^3[the ^4[Pension] Scheme or the Insurance Scheme]] is a company, every person, who at the`
  line `time the offence was committed was in charge of, and was responsible to, the company for the conduct of`
  line `the business of the company, as well as the company, shall be deemed to be guilty of the offence and shall`
  line `be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he exercised all`
  line `due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act ^2[, the`
  line `Scheme or ^3[the ^4[Pension] Scheme or the Insurance Scheme has been committed by a company and it is`
  line `proved that the offence has been committed with the consent or connivance of, or is attributable to, any`
  line `neglect on the part of, any director or manager, secretary or other officer of the company, such director,`
  line `manager, secretary or other officer shall be deemed to be guilty of that offence and shall be liable to be`
  line `proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm and other association of`
  line `individuals; and`
  line
  line `(b) "director" in relation to a firm, means a partner in the firm.]`
obj_root_law_sections_14_a_footnotes:
  string
  line `1. Ins. by Act 37 of 1953, s. 13.`
  line
  line `2. Subs. by Act 16 of 1971, s. 26, for "or the scheme made thereunder".`
  line
  line `3. Subs. by Act 99 of 1976, s. 31, for "the family pension scheme" (w.e.f. 7-9-1976).`
  line
  line `4. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
obj_root_law_sections_14_aa:
  sectionId (41458)
  sectionNo 14AA
  orderNo 51
  title `Enhanced punishment in certain cases after previous conviction.`
  content obj_root_law_sections_14_aa_content
  footnotes obj_root_law_sections_14_aa_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41458&sectionno=14AA&orderno=51&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_14_aa_content:
  string
  line `^3[14AA. Enhanced punishment in certain cases after previous conviction.-- Whoever, having`
  line `been convicted by a Court of an offence punishable under this Act, the Scheme or ^1[the ^2[Pension]`
  line `Scheme or the Insurance Scheme, commits the same offence shall be subject for every such subsequent`
  line `offence to imprisonment for a term which may extend to ^4[five years, but which shall not be less than two`
  line `two years, and shall also be liable to a fine of twenty-five thousand rupees.]`
obj_root_law_sections_14_aa_footnotes:
  string
  line `1. Subs. by Act 99 of 1976, s. 31, for "the family pension scheme" (w.e.f. 7-9-1976).`
  line
  line `2. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `3. Ins. by Act 40 of 1973, s. 5.`
  line
  line `4. Subs. by Act 33 of 1988, s. 19, for "one year but which shall not be less than three months and shall also be liable to fine`
  line `which may extend to four thousand rupees" (w.e.f. 1-8-1988).`
obj_root_law_sections_14_ab:
  sectionId (41459)
  sectionNo 14AB
  orderNo 52
  title `Certain offences to be cognizable.`
  content obj_root_law_sections_14_ab_content
  footnotes `1. Ins. by Act 40 of 1973, s. 5.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41459&sectionno=14AB&orderno=52&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_14_ab_content:
  string
  line `^1[14AB. Certain offences to be cognizable.-- Notwithstanding anything contained in the Code of`
  line `Criminal Procedure, 1898 (5 of 1898.) an offence relating to default in payment of contribution by the`
  line `employer punishable under this Act shall be cognizable.]`
obj_root_law_sections_14_ac:
  sectionId (41460)
  sectionNo 14AC
  orderNo 53
  title `Cognizance and trial of offences.`
  content obj_root_law_sections_14_ac_content
  footnotes obj_root_law_sections_14_ac_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41460&sectionno=14AC&orderno=53&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_14_ac_content:
  string
  line `^1[14AC. Cognizance and trial of offences.-- (1) No court shall take cognizance of any offence`
  line `punishable under this Act, the Scheme or ^2[the ^3[Pension] Scheme or the Insurance Scheme except on a`
  line `report in writing of the facts constituting such offence made with the previous sanction of the Central`
  line `Provident Fund Commissioner or such other officer as may be authorised by the Central Government, by`
  line `notification in the Official Gazette, in this behalf, by an Inspector appointed under section 13.`
  line
  line `(2) No court inferior to that of a Presidency Magistrate or a Magistrate of the first class shall try any`
  line `offence under this Act or the Scheme or ^4[the ^5[Pension] Scheme or the Insurance Scheme.]`
obj_root_law_sections_14_ac_footnotes:
  string
  line `1. Ins. by Act 40 of 1973, s. 5.`
  line
  line `2. Subs. by Act 99 of 1976, s. 31, for "the family pension scheme" (w.e.f. 7-9-1976).`
  line
  line `3. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `4. Subs. by Act 99 of 1976, s. 31, for "the family pension scheme" (w.e.f. 7-9-1976).`
  line
  line `5. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
obj_root_law_sections_14_b:
  sectionId (41461)
  sectionNo 14B
  orderNo 54
  title `Power to recover damages.`
  content obj_root_law_sections_14_b_content
  footnotes obj_root_law_sections_14_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41461&sectionno=14B&orderno=54&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_14_b_content:
  string
  line `^1[14B. Power to recover damages.-- Where an employer makes default in the payment of any`
  line `contribution to the Fund ^3[, the ^2[Pension] Fund or the Insurance Fund] or in the transfer of accumulations`
  line `accumulations required to be transferred by him under sub-section (2) of section 15 ^3[or sub-section (5) of`
  line `of section 17] or in the payment of any charges payable under any other provision of this Act or of ^5[any`
  line `Scheme or Insurance Scheme] or under any of the conditions specified under section 17, ^6[the Central`
  line `Provident Fund Commissioner or such other officer as may be authorised by the Central Government, by`
  line `notification in the Official Gazette, in this behalf] may recover ^7[from the employer by way of penalty`
  line `such damages, not exceeding the amount of arrears, as may be specified in the Scheme:]`
  line
  line `^8[Provided that before levying and recovering such damages, the employer shall be given a reasonable`
  line `reasonable opportunity of being heard]:`
  line
  line `^9[Provided further that the Central Board may reduce or waive the damages levied under this section`
  line `in relation to an establishment which is a sick industrial company and in respect of which a scheme for`
  line `rehabilitation has been sanctioned by the Board for Industrial and Financial Reconstruction established`
  line `under section 4 of the Sick Industrial Companies (Special Provisions) Act, 1985, subject to such terms`
  line `and conditions as may be specified in the Scheme.]]`
obj_root_law_sections_14_b_footnotes:
  string
  line `1. Ins. by Act 37 of 1953, s. 13.`
  line
  line `2. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `3. Subs. by Act 99 of 1976, s. 32, for "or the family pension fund" (w.e.f. 1-8-1976).`
  line
  line `4. Ins. by Act 28 of 1963, s. 10 (w.e.f. 30-11-1963).`
  line
  line `5. Subs. by Act 99 of 1976, s. 32, for "any scheme" (w.e.f. 1-8-1976).`
  line
  line `6. Subs. by Act 40 of 1973, s. 6, for "the appropriate Government" (w.e.f. 1-11-1973).`
  line
  line `7. Subs. by Act 33 of 1988, s. 20, for "from the employer such damages, not exceeding the amount of arrears as it may think fit to`
  line `impose" (w.e.f. 1-9-1991).`
  line
  line `8. Ins. by Act 40 of 1973, s. 6 (w.e.f. 1-11-1973).`
  line
  line `9. Ins. by Act 33 of 1988, s. 20 (to be notified).`
obj_root_law_sections_14_c:
  sectionId (41462)
  sectionNo 14C
  orderNo 55
  title `Power of court to make orders.`
  content obj_root_law_sections_14_c_content
  footnotes obj_root_law_sections_14_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41462&sectionno=14C&orderno=55&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_14_c_content:
  string
  line `^1[14C. Power of court to make orders.--(1) Where an employer is convicted of an offence of`
  line `making default in the payment of any contribution to the Fund ^2[, the ^3[Pension] Fund or the Insurance`
  line `Fund or in the transfer of accumulations required to be transferred by him under sub-section (2) of`
  line `section 15 or sub-section (5) of section 17, the court may, in addition to awarding any punishment, by`
  line `order in writing require him within a period specified in the order (which the court may, if it thinks fit and`
  line `on application in that behalf, from time to time, extend), to pay the amount of contribution or transfer the`
  line `accumulations, as the case may be, in respect of which the offence was committed.`
  line
  line `(2) Where an order is made under sub-section (1), the employer shall not be liable under this Act in`
  line `respect of the continuation of the offence during the period or extended period, if any, allowed by the`
  line `court, but if, on the expiry of such period or extended period, as the case may be, the order of the court`
  line `has not been fully complied with, the employer shall be deemed to have committed a further offence and`
  line `shall be punished with imprisonment in respect thereof under section 14 and shall also be liable to pay`
  line `fine which may extend to one hundred rupees for every day after such expiry on which the order has not`
  line `been complied with.]`
obj_root_law_sections_14_c_footnotes:
  string
  line `1. Ins. by Act 40 of 1973, s. 7 (w.e.f. 1-11-1973).`
  line
  line `2. Subs. by Act 99 of 1976, s. 33, for "or the Family Pension Fund" (w.e.f. 1-8-1976).`
  line
  line `3. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
obj_root_law_sections_15:
  sectionId (41463)
  sectionNo (15)
  orderNo 56
  title `Special provisions relating to existing provident funds.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41463&sectionno=15&orderno=56&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_15_content:
  string
  line `(1) ^1[Subject to the provisions of`
  line `section 17, every employee who is a subscriber to any provident fund of ^2[an establishment] to which this act applies shall, pending the application of a Scheme to the ^3[establishment] in which he is employed,`
  line `continue to be entitled to the benefits accruing to him under the provident fund, and the provident fund`
  line `shall continue to be maintained in the same manner and subject to the same conditions as it would have`
  line `been if this Act had not been passed.`
  line
  line `(2) ^4[On the application of any Scheme to ^5[an establishment], the accumulations in any provident`
  line `fund of the^3[establishment] standing to the credit of the employees who become members of the Fund`
  line `established under the Scheme] shall, notwithstanding anything to the contrary contained in any law for the`
  line `time being in force or in any deed or other instrument establishing the provident fund but subject to the`
  line `provisions, if any, contained in the Scheme, be transferred to the Fund established under the Scheme, and`
  line `shall be credited to the accounts of the employees entitled thereto in the Fund.`
obj_root_law_sections_15_footnotes:
  string
  line `1. Subs. by Act 37 of 1953, s. 14, for certain words.`
  line
  line `2. Subs. by Act 94 of 1956, s. 3, for "a factory".`
  line
  line `3. Subs. by Act 94 of 1956, s. 3, for "factory".`
  line
  line `4. Subs. by Act 37 of 1953, s. 14, for certain words.`
  line
  line `5. Subs. by Act 94 of 1956, s. 3, for "a factory".`
obj_root_law_sections_16:
  sectionId (41464)
  sectionNo (16)
  orderNo 57
  title `Act not to apply to certain establishments.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41464&sectionno=16&orderno=57&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_16_content:
  string
  line `^1[(1) This Act shall not apply--`
  line
  line `(a) to any establishment registered under the Co-operative Societies Act, 1912 (2 of 1912), or`
  line `under any other law for the time being in force in any State relating to co-operative societies,`
  line `employing less than fifty persons and working without the aid of power; or`
  line
  line `^2[(b) to any other establishment belonging to or under the control of the Central Government or a`
  line `State Government and whose employees are entitled to the benefit of contributory provident fund or`
  line `old age pension in accordance with any scheme or rule framed by the Central Government or the`
  line `State Government governing such benefits; or`
  line
  line `(c) to any other establishment set up under any Central, Provincial or State Act and whose`
  line `employees are entitled to the benefits of contributory provident fund or old age pension in accordance`
  line `with any scheme or rule framed under that Act governing such benefits; ^3***`
  line
  line `^4* * * * *`
  line
  line `^5[(2) If the Central Government is of opinion that having regard to the financial position of any class`
  line `of ^6[establishments] or other circumstances of the case, it is necessary or expedient so to do, it may, by`
  line `notification in the Official Gazette, and subject to such conditions as may be specified in the notification,`
  line `exempt ^7[whether prospectively or retrospectively] that class of ^6[establishments] from the operation of`
  line `this Act for such period as may be specified in the notification.]`
obj_root_law_sections_16_footnotes:
  string
  line `1. Subs. by Act 46 of 1960, s. 5, for sub-section (1) (w.e.f. 31-12-1960).`
  line
  line `2. Subs. by Act 33 of 1988, s. 21, for clause (b) (w.e.f. 1-8-1988).`
  line
  line `3. The word "or" omitted by Act 10 of 1998, s. 5 (w.e.f. 22-9-1997).`
  line
  line `4. Omitted by s. 5, ibid. (w.e.f. 22-9-1997).`
  line
  line `5. Ins. by Act 37 of 1953, s. 15.`
  line
  line `6. Subs. by Act 94 of 1956, s. 3, for "factories".`
  line
  line `7. Ins. by Act 33 of 1988, s. 21 (w.e.f. 1-8-1988)`
obj_root_law_sections_16_a:
  sectionId (41465)
  sectionNo 16A
  orderNo 58
  title `Authorising certain employers to maintain provident fund accounts.`
  content obj_root_law_sections_16_a_content
  footnotes `1. Section 16 A shall stand ins (date to be notified) by s. 22, ibid.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41465&sectionno=16A&orderno=58&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_16_a_content:
  string
  line `^1[16A. Authorising certain employers to maintain provident fund accounts.-- (1) The Central`
  line `Government may, on an application made to it in this behalf by the employer and the majority of`
  line `employees in relation to an establishment employing one hundred or more persons, authorise the`
  line `employer, by an order in writing, to maintain a provident fund account in relation to the establishment,`
  line `subject to such terms and conditions as may be specified in the Scheme:`
  line
  line `Provided that no authorisation shall be made under this sub-section if the employer of such`
  line `establishment had committed any default in the payment of provident fund contribution or had committed`
  line `any other offence under this Act during the three years immediately preceding the date of such`
  line authorisation.
  line
  line `(2) Where an establishment is authorised to maintain a provident fund account under sub-section (1),`
  line `the employer in relation to such establishment shall maintain such account, submit such return, deposit`
  line `the contribution in such manner, provide for such facilities for inspection, pay such administrative`
  line `charges, and abide by such other terms and conditions, as may be specified in the Scheme.`
  line
  line `(3) Any authorisation made under this section may be cancelled by the Central Government by order`
  line `in writing if the employer fails to comply with any of the terms and conditions of the authorisation or`
  line `where he commits any offence under any provision of this Act:`
  line
  line `Provided that before cancelling the authorisation, the Central Government shall give the employer a`
  line `reasonable opportunity of being heard.]`
obj_root_law_sections_17:
  sectionId (41466)
  sectionNo (17)
  orderNo 59
  title `Power to exempt.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41466&sectionno=17&orderno=59&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_17_content:
  string
  line `^1[17. Power to exempt.--(1) The appropriate Government may, by notification in the Official`
  line `Gazette and subject to such conditions as may be specified in the notification, ^2[exempt, whether`
  line `prospectively or retrospectively, from the operation] of all or any of the provisions of any Scheme`
  line
  line `(a) any ^3[establishment] to which this Act applies if, in the opinion of the appropriate`
  line `Government, the rules of its provident fund with respect to the rates of contribution are not less`
  line `favourable than those specified in section 6 and the employees are also in enjoyment of other`
  line `provident fund benefits which on the whole are not less favourable to the employees than the benefits`
  line `provided under this Act or any Scheme in relation to the employees in any other ^3`
  line `establishment of a`
  line `similar character; or`
  line
  line `(b) and ^3[establishment] if the employees of such ^3[establishment] are in enjoyment of benefits in`
  line `the nature of provident fund, pension or gratuity and the appropriate Government is of opinion that`
  line `such benefits, separately or jointly, are on the whole not less favourable to such employees than the`
  line `benefits provided under this Act or any Scheme in relation to employees in any other ^3`
  line establishment
  line `of a similar character:`
  line
  line `^4[Provided that no such exemption shall be made except after consultation with the Central Board`
  line `which on such consultation shall forward its views on exemption to the appropriate Government within`
  line `such time limit as may be specified in the Scheme.]`
  line
  line `^5* * * * *`
  line
  line `^6[(1A) Where an exemption has been granted to an establishment under clause (a) of sub-section`
  line `(1),--`
  line
  line `(a) the provisions of sections 6, 7A, 8 and 14B shall, so far as may be, apply to the employer of`
  line `the exempted establishment in addition to such other conditions as may be specified in the`
  line `notification granting such exemption, and where such employer contravenes, or makes default in`
  line `complying with any of the said provisions or conditions or any other provisions of this Act, he shall`
  line `be punishable under section 14 as if the said establishment had not been exempted under the said`
  line `clause (a);`
  line
  line `(b) the employer shall establish a Board of Trustees for the administration of the provident fund`
  line `consisting of such number of members as may be specified in the Scheme;`
  line
  line `(c) the terms and conditions of service of members of the Board of Trustees shall be such as may`
  line `be specified in the Scheme;`
  line
  line `(d) the Board of Trustees constituted under clause (b) shall`
  line
  line `(i) maintain detailed accounts to show the contributions credited, withdrawals made and`
  line `interest accrued in respect of each employee;`
  line
  line `(ii) submit such returns to the Regional Provident Fund Commissioner or any other officer as`
  line `the Central Government may direct from time to time;`
  line
  line `(iii) invest the provident fund monies in accordance with the directions issued by the Central`
  line `Government from time to time;`
  line
  line `(iv) transfer, where necessary, the provident fund account of any employee; and`
  line
  line `(v) perform such other duties as may be specified in the Scheme.`
  line
  line `(1B) Where the Board of Trustees established under clause (b) of sub-section (1A) contravenes, or`
  line `makes default in complying with, any provisions of clause (d) of that sub-section, the Trustees of the said`
  line `Board shall be deemed to have committed an offence under sub-section (2A) of section 14 and shall be`
  line `punishable with the penalties provided in that sub-section.`
  line
  line `^7[(1C)The appropriate Government may, by notification in the Official Gazette, and subject to the`
  line `condition on the pattern of investment of pension fund and such other conditions as may be specified`
  line `therein, exempt any establishment or class of establishments from the operation of the Pension Scheme if`
  line `the employees of such establishment or class of establishments are either members of any other pension`
  line `scheme or propose to be members of such pension scheme, where the pensionary benefits are at par or`
  line `more favourable than the Pension Scheme under this Act.]]`
  line
  line `(2) Any Scheme may make provision for exemption of any person or class of persons employed in`
  line `any ^8[establishment] to which the Scheme applies from the operation of all or any of the provisions of the`
  line `Scheme, if such person or class of persons is entitled to benefits in the nature of provident fund, gratuity`
  line `or old age pension and such benefits, separately or jointly, are on the whole not less favourable than the`
  line `benefits provided under this Act or the Scheme:`
  line
  line `Provided that no such exemption shall be granted in respect of a class of persons unless the`
  line `appropriate Government is of opinion that the majority of persons constituting such class desire to`
  line `continue to be entitled to such benefits.`
  line
  line `^9[(2A) ^10The Central Provident Fund Commissioner may, if requested so to do by the employer, by`
  line `notification in the Official Gazette, and subject to such conditions as may be specified in the notification,`
  line `exempt, whether prospectively or retrospectively, any establishment from the operation of all or any of`
  line `the provisions of the Insurance Scheme, if he is satisfied] that the employees of such establishment are,`
  line `without making any separate contribution or payment of premium, in enjoyment of benefits in the nature`
  line `of life insurance, whether linked to their deposits in provident fund or not, and such benefits are more`
  line `favourable to such employees than the benefits admissible under the Insurance Scheme.`
  line
  line `(2B) Without prejudice to the provisions of sub-section (2A), the Insurance Scheme may provide for`
  line `the exemption of any person or class of persons employed in any establishment and covered by that`
  line `Scheme from the operation of all or any of the provisions thereof, if the benefits in the nature of life`
  line `insurance admissible to such person or class of persons are more favourable than the benefits provided`
  line `under the Insurance Scheme.]`
  line
  line `^11[(3) Where in respect of any person or class of persons employed in an establishment an exemption`
  line `is granted under this section from the operation of all or any of the provisions of any Scheme (whether`
  line `such exemption has been granted to the establishment wherein such person or class of persons is`
  line `employed or to the person or class of persons as such), the employer in relation to such establishment--`
  line
  line `(a) shall, in relation to the provident fund, pension and gratuity to which any such person or class`
  line `of persons is entitled, maintain such accounts, submit such returns, make such investment, provide for`
  line `such facilities for inspection and pay such inspection charges, as the Central Government may direct;`
  line
  line `(b) shall not, at any time after the exemption, without the leave of the Central Government,`
  line `reduce the total quantum of benefits in the nature of pension, gratuity or provident fund to which any`
  line `such person or class of persons was entitled at the time of the exemption; and`
  line
  line `(c) shall, where any such person leaves his employment and obtains re-employment in another`
  line `establishment to which this Act applies, transfer within such time as may be specified in this behalf`
  line `by the Central Government, the amount of accumulations to the credit of that person in the provident`
  line `fund of the establishment left by him to the credit of that persons account in the provident fund of the`
  line `establishment in which he is re-employed or, as the case may be, in the Fund established under the`
  line `Scheme applicable to the establishment.`
  line
  line `^12[(3A) Where, in respect of any person or class of persons employed in any establishment, an`
  line `exemption is granted under sub-section (2A) or sub-section (2B) from the operation of all or any of the`
  line `provisions of the Insurance Scheme (whether such exemption is granted to the establishment wherein`
  line `such person or class of persons is employed or to the person or class of persons as such), the employer in`
  line `relation to such establishment--`
  line
  line `(a) shall, in relation to the benefits in the nature of life insurance, to which any such person or`
  line `class of persons is entitled, or any insurance fund, maintain such accounts, submit such returns, make`
  line `such investments, provide for such facilities for inspection and pay such inspection charges, as the`
  line `Central Government may direct;`
  line
  line `(b) shall not, at any time after the exemption without the leave of the Central Government, reduce`
  line `the total quantum of benefits in the nature of life insurance to which any such person or class of`
  line `persons was entitled immediately before the date of the exemption; ^13***`
  line
  line `^14* * * * *`
  line
  line `(4) Any exemption granted under this section may be cancelled by the authority which granted it, by`
  line `order in writing, if an employer fails to comply,--`
  line
  line `(a) in the case of an exemption granted under sub-section (1), with any of the conditions imposed`
  line `under that sub-section ^15`
  line `or sub-section (1A) or with any of the provisions of sub-section (3); ^16***`
  line
  line `^17[(aa) in the case of an exemption granted under sub-section ^18`
  line `(IC), with any of the conditions`
  line `imposed under that sub-section; and]`
  line
  line `(b) in the case of an exemption granted under sub-section (2), with any of the provisions of`
  line `sub-section (3);`
  line
  line `^19[(c) in the case of an exemption granted under sub-section (2A), with any of the conditions`
  line `imposed under that sub-section or with any of the provisions of sub-section (3A);`
  line
  line `(d) in the case of an exemption granted under sub-section (2B), with any of the provisions of`
  line `sub-section (3A).]`
  line
  line `^20[(5) Where any exemption granted under sub-section (1), sub-section ^21[(IC) ^22[, sub-section (2),`
  line `sub-section (2A) or sub-section (2B)] is cancelled, the amount of accumulations to the credit of every`
  line `employee to whom such exemption applied, in the provident fund ^22[the ^23[pension] fund or the insurance`
  line `fund of the establishment in which he is employed ^24[together with any amount forfeited from the`
  line `employer's share of contribution to the credit of the employee who leaves the employment before the`
  line `completion of the full period of service shall be transferred within such time and in such manner as may`
  line `be specified in the Scheme or the ^23[Pension] Scheme ^22[or the Insurance Scheme] to the credit of his`
  line `account in the Fund or the ^23[Pension] Fund ^22[or the Insurance Fund], as the case may be.`
  line
  line `(6) Subject to the provisions of sub-section ^21[(IC) the employer of an exempted establishment or of`
  line `an exempted employee of an establishment to which the provisions of the ^23[Pension] Scheme apply, shall,`
  line `notwithstanding any exemption granted under sub-section (1) or sub-section (2), pay to the ^23[Pension]`
  line `Fund such portion of the employers contribution ^25*** to its provident fund within such time and in such`
  line `manner as may be specified in the ^23[Pension] Scheme.]]]`
obj_root_law_sections_17_footnotes:
  string
  line `1. Subs. by Act 37 of 1953, s. 16, for section 17.`
  line
  line `2. Subs. by Act 33 of 1988, s. 23, for certain words (w.e.f. 1-10-1988).`
  line
  line `3. Subs. by Act 94 of 1956, s. 3, for "factory".`
  line
  line `4. Added by Act 33 of 1988, s. 23 (w.e.f. 1-10-1988).`
  line
  line `5. The Explanation omitted by Act 28 of 1963, s. 11 (w.e.f. 30-11-1963).`
  line `6. Subs. by Act 33 of 1988, s. 23, for sub-section (IA) (w.e.f. 1-10-1988).`
  line
  line `7. Subs. by Act 25 of 1996, s. 7, for sub-section (IC) (w.e.f. 16-11-1996).`
  line
  line `8. Subs. by Act 94 of 1956, s. 3, for "factory".`
  line
  line `9. Ins. by Act 99 of 1976, s. 34 (w.e.f. 1-8-1976).`
  line
  line `10. Subs. by Act 33 of 1988, s. 23, for certain words (w.e.f. 1-10-1988).`
  line
  line `11. Subs. by Act 28 of 1963, s. 11, for sub-section (3) (w.e.f. 30-11-1963).`
  line
  line `12. Ins. by Act 99 of 1976, s. 34 (w.e.f. 1-8-1976).`
  line
  line `13. The word "and" omitted by Act 33 of 1988, s. 23 (w.e.f. 1-10-1988).`
  line
  line `14. Omitted by s. 23, ibid. (w.e.f. 1-10-1988).`
  line
  line `15. Ins. by Act 33 of 1988, s. 23 (w.e.f. 1-10-1988).`
  line
  line `16. The word "and" omitted by Act 16 of 1971, s. 27 (w.e.f. 23-4-1971).`
  line
  line `17. Ins. by s. 27, ibid. (w.e.f. 23-4-1971).`
  line
  line `18. Subs. by Act 33 of 1988, s. 23, for "(IA)" (w.e.f. 1-10-1985).`
  line
  line `19. Ins. by Act 99 of 1976, s. 34 (w.e.f. 1-8-1976).`
  line
  line `20. Subs. by Act 16 of 1971, s. 27, for sub-section (5) (w.e.f. 23-4-1971).`
  line
  line `21. Subs. by Act 33 of 1988, s. 23, for "(IA)" (w.e.f. 1-10-1985).`
  line
  line `22. Subs. by Act 99 of 1976, s. 27, for certain words (w.e.f. 1-8-1976).`
  line
  line `23. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line
  line `24. Ins. by Act 33 of 1988, s. 23 (w.e.f. 1-10-1988).`
  line
  line `25. The words "as well as the employees' Contribution" omitted by Act 25 of 1996, s. 7 (w.e.f. 16-11-1995).`
obj_root_law_sections_17_a:
  sectionId (41467)
  sectionNo 17A
  orderNo 60
  title `Transfer of accounts.`
  content obj_root_law_sections_17_a_content
  footnotes `1. Ins. by Act 28 of 1963, s. 12 (w.e.f. 30-11-1963).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41467&sectionno=17A&orderno=60&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_17_a_content:
  string
  line `^1[17A. Transfer of accounts.-- (1) Where an employee employed in an establishment to which this`
  line `Act applies leaves his employment and obtains re-employment in another establishment to which this Act`
  line `does not apply, the amount of accumulations to the credit of such employee in the Fund, or as the case`
  line `may be, in the provident fund of the establishment left by him shall be transferred, within such time as`
  line `may be specified by the Central Government in this behalf, to the credit of his account in the provident`
  line `fund of the establishment in which he is re-employed, if the employee so desires and the rules in relation`
  line `to that provident fund permit such transfer.`
  line
  line `(2) Where an employee employed in an establishment to which this Act does not apply leaves his`
  line `employment and obtains re-employment in another establishment to which this Act applies, the amount of`
  line `accumulations to the credit of such employee in the provident fund of the establishment left by him may,`
  line `if the employee so desires and the rules in relation to such provident fund permit, be transferred to the`
  line `credit of his account in the Fund or as the case may be, in the provident fund of the establishment in`
  line `which he is re-employed.]`
obj_root_law_sections_17_aa:
  sectionId (41468)
  sectionNo 17AA
  orderNo 61
  title `Act to have effect notwithstanding anything contained in Act 31 of 1956.`
  content obj_root_law_sections_17_aa_content
  footnotes `1. Ins. by Act 99 of 1976, s. 35 (w.e.f. 1-8-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41468&sectionno=17AA&orderno=61&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_17_aa_content:
  string
  line `^1[17AA. Act to have effect notwithstanding anything contained in Act 31 of 1956.-- The`
  line `provisions of this Act shall have effect notwithstanding anything inconsistent therewith contained in the`
  line `Life Insurance Corporation Act, 1956.]`
obj_root_law_sections_17_b:
  sectionId (41469)
  sectionNo 17B
  orderNo 62
  title `Liability in case of transfer of establishment.`
  content obj_root_law_sections_17_b_content
  footnotes obj_root_law_sections_17_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41469&sectionno=17B&orderno=62&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_17_b_content:
  string
  line `^1[17B. Liability in case of transfer of establishment.--Where an employer, in relation to an`
  line `establishment, transfers that establishment in whole or in part, by sale, gift, lease or licence or in any other`
  line `manner whatsoever, the employer and the person to whom the establishment is so transferred shall jointly`
  line `and severally be liable to pay the contribution and other sums due from the employer under any provision Of this Act or the Scheme or ^2[the ^3[Pension] Scheme or the Insurance Scheme, as the case may be, in`
  line `respect of the period up to the date of such transfer:`
  line
  line `Provided that the liability of the transferee shall be limited to the value of the assets obtained by him`
  line `by such transfer].]`
obj_root_law_sections_17_b_footnotes:
  string
  line `1. Ins. by Act 40 of 1973, s. 8 (w.e.f. 1-11-1973).`
  line
  line `2. Subs. by Act 99 of 1976, s. 31, for "the Family Pension Scheme" (w.e.f. 7-9-1976).`
  line
  line `3. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
obj_root_law_sections_18:
  sectionId (41470)
  sectionNo (18)
  orderNo 63
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41470&sectionno=18&orderno=63&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_18_content:
  string
  line `^1[18. Protection of action taken in good faith.-- No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government, a State Government, the Presiding Officer of a Tribunal, any`
  line `authority referred to in section 7A, an Inspector or any other person for anything which is in good faith`
  line `done or intended to be done in pursuance of this Act, the Scheme, the ^2[Pension] Scheme or the Insurance`
  line Scheme.]
obj_root_law_sections_18_footnotes:
  string
  line `1. Subs. by Act 33 of 1988, s. 24, for section 18 (w.e.f. 1-8-1988).`
  line
  line `2. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
obj_root_law_sections_18_a:
  sectionId (41471)
  sectionNo 18A
  orderNo 64
  title `Presiding Officer and other officers to be public servants.`
  content `^1[18A. Authorities and inspector to be public servant.--The authorities referred to in section 7A and every inspector shall be deemed to be a public servant within the meaning of section 21 of the Indian Penal Code.]]`
  footnotes `1. Subs. by Act 7 of 2017, s. 159, for section 18A (w.e.f. 26-5-2017).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41471&sectionno=18A&orderno=64&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_19:
  sectionId (41472)
  sectionNo (19)
  orderNo 65
  title `Delegation of powers.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41472&sectionno=19&orderno=65&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_19_content:
  string
  line `^2[19. Delegation of powers-- The appropriate Government may direct that any power or authority or`
  line `or jurisdiction exercisable by it under this Act ^3[, the Scheme ^4[, the ^1Pension] Scheme or the Insurance`
  line `Scheme]] shall, in relation to such matters and subject to such conditions, if any, as may be specified in`
  line `the direction, be exercisable also--`
  line
  line `(a) where the appropriate Government is the Central Government, by such officer or authority`
  line `subordinate to the Central Government or by the State Government or by such officer or authority`
  line `subordinate to the State Government, as may be specified in the notification; and`
  line
  line `(b) where the appropriate Government is a State Government, by such officer or authority`
  line `subordinate to the State Government as may be specified in the notification.]`
obj_root_law_sections_19_footnotes:
  string
  line `1. Subs. by Act 25 of 1996, s. 4, for "Family Pension" (w.e.f. 16-11-1995).`
  line `2. Subs. by Act 37 of 1953, s. 17, for section 19.`
  line `3. Subs. by Act 16 of 1971, s. 29, for "or any scheme".`
  line `4. Subs. by Act 99 of 1976, s. 37, for "or the family scheme".`
obj_root_law_sections_20:
  sectionId (41473)
  sectionNo (20)
  orderNo 66
  title `Power of Central Government to give directions.`
  content obj_root_law_sections_20_content
  footnotes `1. Subs. by Act 33 of 1988, s. 25, for section 19A (w.e.f. 1-7-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41473&sectionno=20&orderno=66&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_20_content:
  string
  line `^1[20. Power of Central Government to give directions.-- The Central Government may, from time`
  line `to time, give such directions to the Central Board as it may think fit for the efficient administration of this`
  line `Act and when any such direction is given, the Central Board shall comply with such direction.]`
obj_root_law_sections_21:
  sectionId (41474)
  sectionNo (21)
  orderNo 67
  title `Power to make rules.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41474&sectionno=21&orderno=67&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_21_content:
  string
  line `^1[21. Power to make rules.-- (1) The Central Government may, by notification in the Official Gazette, make rules to carry out the provisions of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may provide for all or any of the following matters, namely:--`
  line
  line `^1[* * * * *`
  line
  line ];
  line
  line `(b) the form and the manner in which, and the time within which, an appeal shall be filed before a Tribunal and the fees payable for filing such appeal;`
  line
  line `(c) the manner of certifying the copy of the certificate, to be forwarded to the Recovery Officer under sub-section (2) of section 8C; and`
  line
  line `(d) any other matter, which has to be, or may be, prescribed by rules under this Act.`
  line
  line `(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it is in session, for a total period of thirty days which may be comprised in one session or in two or more successive sessions, and if, before the expiry of the session immediately following the session or the successive sessions aforesaid, both Houses agree in making any modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that any such modification or annulment shall be without prejudice to the validity of anything previously done under that rule.]`
obj_root_law_sections_21_footnotes:
  string
  line `1. Subs. by Act 33 of 1988, s. 25, for section 19A (w.e.f. 1-7-1997).`
  line
  line `2. Clause (a) omitted by Act 7 of 2017, s. 159 (w.e.f. 26-5-2017).`
obj_root_law_sections_22:
  sectionId (41475)
  sectionNo (22)
  orderNo 68
  title `Power to remove difficulties.`
  content obj_root_law_sections_22_content
  footnotes `1. Subs. by Act 33 of 1988, s. 25, for section 19A (w.e.f. 1-7-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00038_195219_1517807328217&sectionId=41475&sectionno=22&orderno=68&orgactid=AC_CEN_6_6_00038_195219_1517807328217
obj_root_law_sections_22_content:
  string
  line `^1[22. Power to remove difficulties.-- (1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, as amended by the Employees Provident Funds and Miscellaneous Provisions (Amendment)`
  line `Act, 1988 (33 of 1988), the Central Government may, by order published in the Official Gazette, make`
  line `such provisions, not inconsistent with the provisions of this Act as appear to it to be necessary or`
  line `expedient for the removal of the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of three years from the date on`
  line `which the said amendment Act receives the assent of the President.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.]]]`
