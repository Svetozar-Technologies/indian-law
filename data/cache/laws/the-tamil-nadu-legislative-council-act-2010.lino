obj_root_law_sections_1:
  sectionId (30260)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Tamil Nadu Legislative Council Act, 2010.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_201016_1517807325032&sectionId=30260&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00032_201016_1517807325032
