obj_root_law_sections_1:
  sectionId (67702)
  sectionNo (1)
  orderNo 1
  title Repealed.
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67702&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_1_content:
  string
  line `Regulation XIV of 1807 of`
  line `the Government of the presidency of Fort William in Bengal, Section 11, clause 5, is hereby repealed so`
  line `far as it applies to public Saráís in the territories to which this Act may from time to time apply.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (67703)
  sectionNo (2)
  orderNo 2
  title `Interpretation clause.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67703&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there be something repugnant in the subject or`
  line context,--
  line
  line `"Sarai." --- "Sarai" means any building used for the shelter and accommodation of travellers, and`
  line `includes, in any case in which only part of a building is used as a sarai, the part so used of such`
  line `building. It also includes a purao so far as the provisions of this Act are applicable thereto:`
  line
  line `"Keeper of a Sarai."--- "keeper of a sarai" includes the owner and any person having or acting in`
  line `the care or management thereof :`
  line
  line `"Magistrate of the District."--- "Magistrate of the District" means the chief officer charged with`
  line `the executive administration of a district in criminal matters whatever may be his designation :`
  line
  line `Number.---Words in the singular include the plural, and vice versa ; And in any place in which this`
  line `Act shall operate,`
  line
  line `"Local Government".--- shall mean the person administering Executive Government in such`
  line `place, and shall include a Chief Commissioner and the Commissioner in Sind.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (67704)
  sectionNo (3)
  orderNo 3
  title `Notice of this Act to be given to keepers of Sarai's.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67704&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_3_content:
  string
  line `Within six months after this Act shall come`
  line `into operation, the Magistrate of the District in which any sarai to which this Act shall apply may be`
  line `situate shall, and from time to time thereafter such Magistrate may, give to the keeper of every such sarai`
  line `notice in writing of this Act, by leaving such notice for the keeper at the sarai, and shall by such notice`
  line `require the keeper to register the sarai as by this Act provided. Such notice may be in the form in the`
  line `Schedule to this Act annexed or to the like effect.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (67705)
  sectionNo (4)
  orderNo 4
  title `Registers of Sara'i's to be kept`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67705&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_4_content:
  string
  line `The Magistrate of the District shall keep a register in which shall`
  line `be entered by such magistrate or such other person as he shall appoint in this behalf, the names and`
  line `residences of the keepers of all sarais within his jurisdiction and the situation of every such sarai. No`
  line `charge shall be made for making any such entry`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (67706)
  sectionNo (5)
  orderNo 5
  title `Lodgers, &c., not to be received in Sara'i's until registered.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67706&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_5_content:
  string
  line `After one month after the giving of`
  line `such notice to register as by this Act, Act provided the keeper of any sarai or any other person shall not`
  line `receive any lodge or allow any person cattle, sheep, elephant, camel or other animal or any vehicle to halt`
  line `or be placed in such until the same and the name and residence of the keeper thereof shall have been`
  line `registered as by this Act provided`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (67707)
  sectionNo (6)
  orderNo 6
  title `Magistrate may refuse to refuse to register keeper not producing certificate of character.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67707&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_6_content:
  string
  line The
  line `Magistrate of the District may if he shall think fit refuse to register as the keeper of a saráí person who`
  line `does not produce a certificate of character in such form and signed by such person as the State`
  line `Government shall from time to time direct.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (67708)
  sectionNo (7)
  orderNo 7
  title `Duties of keepers of Sara'i's.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67708&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_7_content:
  string
  line `The keeper of a Saráí shall be bound.--`
  line
  line `(1) when any person in such Sarai is ill of any infectious or contagious disease or dies of such`
  line `disease to give immediate notice thereof to the nearest police-station.`
  line
  line `(2) at all times when requires by any Magistrate or any other person duly authorized by the`
  line `Magistrate of the District in this behalf to give him free access to the Sarai and allow him to inspect`
  line `the same or any part thereof;`
  line
  line `(3) to thoroughly cleanse the rooms and verandahs and drains of the Sarai and the wells, tanks or`
  line `other sources from which water is obtained for the persons or animals using it to the satisfaction of and`
  line `so often as shall be required by the Magistrate of the District, or such person as he shall appoint in this`
  line `behalf :`
  line
  line `(4) to remove all noxious vegetation on or near the Saráí, and all tree and branches of tree capable`
  line `of affording to thieves means of entering or leaving the Sarai:`
  line
  line `(5) to keep the gates, walls, fences, roofs and drains of the Sarai in repair:`
  line
  line `(6) to provide such number of watchmen as may, in the opinion of the Magistrate of the District,`
  line `subject to such rules as the State Government may prescribe in this behalf, be necessary for the safety`
  line `and protection of persons and animals or vehicles in, halting at or placed in the Sarai:`
  line and
  line
  line `(7) to exhibit a list of charges for the Sarai at such place and in such form and languages as the`
  line `Magistrate of the District shall from time to time direct.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (67709)
  sectionNo (8)
  orderNo 8
  title `Power to order reports from keepers of Sara'i's`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67709&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_8_content:
  string
  line `The keeper of a Sarai shall from time to time, if`
  line `required so to do by an order of the Magistrate of the District served upon him, report, either orally or in`
  line `writing as may be directed by the Magistrate, to such Magistrate or to such person as the Magistrate shall`
  line `appoint, every person who resorted to such Sarai during the preceding day or night. If written reports are`
  line `required for any space of time, exceeding a single day or night, schedules shall be furnished by the`
  line `Magistrate of the District to the keeper. The keeper shall from time to time fill up the said schedule with`
  line `information so required, and transmit them to the said Magistrate, in such manner and at such intervals as`
  line `may from time to time be ordered by him.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (67710)
  sectionNo (9)
  orderNo 9
  title `Power to shut up, secure, clear, and clean deserted Sara'i'.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67710&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_9_content:
  string
  line `If any Sarai by reason of`
  line `abandonment or of disputed ownership shall remain untenanted, and thereby become a resort of idle and`
  line `disorderly persons, or become in a filthy or unwholesome state, or be complained of by any two or more`
  line `of the neighbours as a nuisance, the Magistrate of the District, after due enquiry, may cause notice in`
  line `writing to be Vienna to the owner or to the person claiming to be the owner, if he be known and resident`
  line `within the district, and may also cause such notice to be put on some conspicuous part of the Sarai,`
  line `requiring the persons concerned therein, whoever they may be, to secure, enclose, clean or clear the same;`
  line `and if such requisition shall not be complied within eight days, the Magistrate of the District may cause`
  line `the necessary work to be executed, and all expenses thereby incurred shall be paid by the owner of the Sarai and shall be recoverable like penalties under this Act, or, in case of abandonment or disputed`
  line `ownership of the Sarai, by the sale of any material found therein.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (67711)
  sectionNo (10)
  orderNo 10
  title `Taking down or repairing ruinous Sara'i's.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67711&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_10_content:
  string
  line `If a Sarai or any part thereof be deemed by the`
  line `Magistrate of the District to be in a ruinous state, or likely to fall, or in any way dangerous to the persons`
  line `or animals lodging in or halting at the Sarai, he shall give notice in writing to the keeper of the Sarai,`
  line `requiring him forthwith to take down, repair or secure (as the case may be) the Sarai or such part thereof`
  line `as the case may require. If the keeper do not begin to take down, repair or secure the Sarai, or such part as`
  line `aforesaid within three days after such notice, and complete such work with due diligence, the Magistrate`
  line `shall cause all or so much of the Sarai as he shall think necessary to be taken down, repaired or otherwise`
  line `secured. All the expenses so incurred by the Magistrate shall be paid by the keeper of the Sarai, and shall`
  line `be recoverable from him as hereinafter mentioned.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (67712)
  sectionNo (11)
  orderNo 11
  title `Sale of materials of ruinous Sara'i's.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67712&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_11_content:
  string
  line `If any such Sarai or any part thereof be taken down by`
  line `virtue of the powers aforesaid, the Magistrate of the District may sell the materials thereof, or so much of`
  line `the same as shall be taken down under the provisions of the last preceding section, and apply the proceeds`
  line `of such sale in payment of the expenses incurred, and shall restore the overplus (if any) arising from such`
  line `sale to the owner of such sarai on demand, and may recover the deficiency (if any) as if the amount`
  line `thereof were a penalty under this Act.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (67713)
  sectionNo (12)
  orderNo 12
  title `Penalty for permitting Sara'i's to be filthy or overgrown. Proviso`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67713&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_12_content:
  string
  line `Whoever, being the keeper of any`
  line `Sarai, suffers the same to be in a filthy and unwholesome state, or overgrown with vegetation, or after the`
  line `expiration of two days from the time of his receiving notice in writing from the Magistrate of the District`
  line `to cleanse or clear the same, or after he shall have been convicted of suffering the same to be in such state`
  line `or so overgrown as aforesaid, shall allow the same to continue in such state, or so overgrown, shall be`
  line `liable to the penalties provided in section 14 of this Act:`
  line
  line `Proviso. -- Provided that the Magistrate of the District may, in lieu of enforcing such daily penalty,`
  line `enter on and cleanse or clear the said Sarai, and the expense incurred by the Magistrate in respect thereof`
  line `shall be paid to him by the keeper, and shall be recoverable as by this Act provided in the case of`
  line penalties
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (67714)
  sectionNo (13)
  orderNo 13
  title `Power for Local Government to make regulations.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67714&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_13_content:
  string
  line `The Local Government may from time to`
  line `time make regulations for the better attainment of the objects of this Act, provided that such rules be not`
  line `inconsistent with this Act or with any other law for the time being in force, and may from time to time`
  line `repeal, alter and add to the same. All regulations made under this Act and all repeals thereof, and`
  line `alterations and additions thereto, shall be published in the Local official Gazette.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (67715)
  sectionNo (14)
  orderNo 14
  title `Penalty for infringing Act or regulations.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67715&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_14_content:
  string
  line `If the keeper of a sarai offend against any of the`
  line `provisions of this Act or any of the regulations made in pursuance of this Act, he shall for every such`
  line `offence be liable on conviction before any Magistrate to a penalty not exceeding twenty rupees, and to a`
  line `further penalty not exceeding one rupee a day for every day during which the offence continues :`
  line `Provided always that this Act shall not exempt any person from any penalty or other liability to which he`
  line `may be subject, irrespective of this Act. All penalties imposed under this Act may be recovered in the`
  line `same manner as fines may be recovered under Section 61 of the Code of Criminal Procedure.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (67716)
  sectionNo (15)
  orderNo 15
  title `Conviction for third offence to disqualify persons from keeping Sara'i's`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67716&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_15_content:
  string
  line `Where a keeper of a`
  line `sarai is convicted of a third offence under this Act, he shall not afterwards act as keeper of a Saráí without`
  line `the licence in writing of the Magistrate of the District, who may either withhold such licence or grant the`
  line `same on such terms and conditions as he may think fit`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (67717)
  sectionNo (16)
  orderNo 16
  title `Nothing in Act to apply to certain Sarai.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67717&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_16_content:
  string
  line `No part of this Act, except section 8, shall apply to`
  line `any Saráí which may be under the direct management of the Local Government or of any Municipal`
  line Committee.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (67718)
  sectionNo (17)
  orderNo 17
  title `Extent of Act.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67718&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_17_content:
  string
  line `This Act shall in the first instance extend only to the territories under the`
  line `government of the Lieutenant-Governor of the North-West Provinces of the Presidency of Fort William in`
  line Bengal.
  line
  line `Power to Governor General in Council to extend this Act.— But it shall be lawful for the Local`
  line `Government, by notification in the Local Gazette, to extend this Act, mutatis mutandis, to any other part`
  line `of the territories which are or may be vested in Her Majesty or Her Successors by the Statute 21 & 22`
  line `Vic., cap. 106 (An Act for the better Government of India), except the towns of Calcutta, Madras and`
  line `Bombay, and the Settlement of Prince of Wales’ Island, Singapore and Malacca.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (67719)
  sectionNo (18)
  orderNo 18
  title `Short title.`
  content `This Act may be called "The sarais" Act, 1867."`
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00089_186722_1661253567439&sectionId=67719&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00089_186722_1661253567439
obj_root_law_sections_18_footnotes:
  string
  line
