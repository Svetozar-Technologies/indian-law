obj_root_law_sections_1:
  sectionId (30265)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30265&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00007_196549_1517807319766
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Union Territories (Direct Election to the House`
  line `of the People) Act, 1965.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (30266)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30266&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00007_196549_1517807319766
obj_root_law_sections_2_content:
  string
  line `In this Act`
  line
  line `(a) "parliamentary constituency" has the same meaning as in the Representation of the People`
  line `Act, 1950 (43 of 1950);`
  line
  line `(b) "sitting member" means a person who immediately before the commencement of this Act`
  line `is a member of the House of the People;`
  line
  line `(c) "Union territory" means any of the Union territories of the Andaman and Nicobar Islands,`
  line ^1
  line `[Lakshadweep] and Dadra and Nagar Haveli.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by the Laccadive, Minicoy and Aminidivi Islands (Alteration of Name) Adaptation of Laws Order, 1974`
  line `(w.e.f. 1-11-1973).`
obj_root_law_sections_3:
  sectionId (30267)
  sectionNo (3)
  orderNo 3
  title `Direct election to fill the seats in the House of the People allotted to certain Union territories.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30267&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00007_196549_1517807319766
obj_root_law_sections_3_content:
  string
  line `At the next general election to the House of the People and thereafter, the seats allotted`
  line `under section 3 of the Representation of the People Act, 1950 (43 of 1950) to the Union territories in`
  line `the House of the People shall be seats to be filled by persons chosen by direct election and for that`
  line `purpose each Union territory shall form one parliamentary constituency.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (30268)
  sectionNo (4)
  orderNo 4
  title Repealed.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30268&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00007_196549_1517807319766
obj_root_law_sections_4_content:
  string
  line `[Amendment of Act 43 of 1950.] Rep. by the Repealing and Amending Act, 1974 (56 of 1974), s. 2`
  line `and the First Schedule (w.e.f. 20-12-1974).`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (30269)
  sectionNo (5)
  orderNo 5
  title Repealed.
  content `[Amendment of Act 43 of 1951.] Rep. by s. 2 and the First Schedule, ibid. (w.e.f. 20-12-1974).`
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30269&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00007_196549_1517807319766
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (30270)
  sectionNo (6)
  orderNo 6
  title `Provision as to sitting member.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30270&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00007_196549_1517807319766
obj_root_law_sections_6_content:
  string
  line `The sitting member representing each Union territory shall`
  line `continue to represent that Union territory until the dissolution of the present House of the People and`
  line `if before such dissolution the seat allotted to a Union territory in the House of the People becomes`
  line `vacant it shall be filled by a person nominated by the President and that person shall represent the`
  line `Union territory in the present House of the People until its dissolution.`
obj_root_law_sections_6_footnotes:
  string
  line
