obj_root_law_sections_1:
  object
  (str sectionId) (str 30265)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Union Territories (Direct Election to the House
of the People) Act, 1965.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30265&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00007_196549_1517807319766)
obj_root_law_sections_2:
  object
  (str sectionId) (str 30266)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act

(a) "parliamentary constituency" has the same meaning as in the Representation of the People
Act, 1950 (43 of 1950);

(b) "sitting member" means a person who immediately before the commencement of this Act
is a member of the House of the People;

(c) "Union territory" means any of the Union territories of the Andaman and Nicobar Islands,
^1
[Lakshadweep] and Dadra and Nagar Haveli.`)
  (str footnotes) (str `1. Subs. by the Laccadive, Minicoy and Aminidivi Islands (Alteration of Name) Adaptation of Laws Order, 1974
(w.e.f. 1-11-1973).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30266&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00007_196549_1517807319766)
obj_root_law_sections_3:
  object
  (str sectionId) (str 30267)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Direct election to fill the seats in the House of the People allotted to certain Union territories.`)
  (str content) (str `At the next general election to the House of the People and thereafter, the seats allotted
under section 3 of the Representation of the People Act, 1950 (43 of 1950) to the Union territories in
the House of the People shall be seats to be filled by persons chosen by direct election and for that
purpose each Union territory shall form one parliamentary constituency.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30267&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00007_196549_1517807319766)
obj_root_law_sections_4:
  object
  (str sectionId) (str 30268)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str Repealed.)
  (str content) (str `[Amendment of Act 43 of 1950.] Rep. by the Repealing and Amending Act, 1974 (56 of 1974), s. 2
and the First Schedule (w.e.f. 20-12-1974).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30268&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00007_196549_1517807319766)
obj_root_law_sections_5:
  object
  (str sectionId) (str 30269)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str Repealed.)
  (str content) (str `[Amendment of Act 43 of 1951.] Rep. by s. 2 and the First Schedule, ibid. (w.e.f. 20-12-1974).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30269&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00007_196549_1517807319766)
obj_root_law_sections_6:
  object
  (str sectionId) (str 30270)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Provision as to sitting member.`)
  (str content) (str `The sitting member representing each Union territory shall
continue to represent that Union territory until the dissolution of the present House of the People and
if before such dissolution the seat allotted to a Union territory in the House of the People becomes
vacant it shall be filled by a person nominated by the President and that person shall represent the
Union territory in the present House of the People until its dissolution.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00007_196549_1517807319766&sectionId=30270&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00007_196549_1517807319766)
