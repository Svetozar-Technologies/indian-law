obj_root_law_sections_15_content:
  string
  line `The Finance Officer shall be appointed in such manner, and shall exercise such`
  line `powers and perform such duties, as may be prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
