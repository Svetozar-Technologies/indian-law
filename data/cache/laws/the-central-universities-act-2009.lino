  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23154&sectionno=17&orderno=24&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_17_content:
  string
