obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (23155)
  sectionNo (18)
  orderNo 25
  title `Other officers.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23155&sectionno=18&orderno=25&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_18_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (23156)
  sectionNo (19)
  orderNo 26
  title `Authorities of University.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23156&sectionno=19&orderno=26&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_19_content:
  string
  line `The following shall be the authorities of the University, namely:--`
  line
  line `(1) the Court;`
  line
  line `(2) the Executive Council;`
  line
  line `(3) the Academic Council;`
  line
  line `(4) the Board of Studies;`
  line
  line `(5) the Finance Committee; and`
  line
  line `(6) such other authorities as may be declared by the Statutes to be the authorities of the`
  line University.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (23157)
  sectionNo (20)
  orderNo 27
  title `The Court.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23157&sectionno=20&orderno=27&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_20_content:
  string
  line `(1) The constitution of the Court and the term of office of its members shall be`
  line `prescribed by the Statutes:`
  line
  line `Provided that such number of members, as may be prescribed by the Statutes, shall be elected from`
  line `among the teachers, employees and students of the University.`
  line
  line `(2) Subject to the provisions of this Act, the Court shall have the following powers and functions,`
  line `namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University, and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the University`
  line `and the audit report on such accounts;`
  line
  line `(c) to advise the Visitor in respect of any matter which may be referred to it for advise; and`
  line
  line `(d) to perform such other functions as may be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (23158)
  sectionNo (21)
  orderNo 28
  title `Executive Council.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23158&sectionno=21&orderno=28&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_21_content:
  string
  line `(1) The Executive Council shall be the principal executive body of the`
  line University.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes:`
  line
  line `Provided that such number of members as may be prescribed by the Statutes shall be from among the`
  line `elected members of the Court.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (23159)
  sectionNo (22)
  orderNo 29
  title `Academic Council.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23159&sectionno=22&orderno=29&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_22_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and the Ordinances, co-ordinate`
  line `and exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of members and its powers and`
  line `functions shall be prescribed by the Statutes:`
  line
  line `Provided that such number of members as may be prescribed by the Statutes shall be from among the`
  line `elected members of the Court.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (23160)
  sectionNo (23)
  orderNo 30
  title `Boards of Studies.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23160&sectionno=23&orderno=30&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_23_content:
  string
  line `The constitution, powers and function of the Boards of Studies shall be`
  line `prescribed by the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (23161)
  sectionNo (24)
  orderNo 31
  title `Finance Committee.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23161&sectionno=24&orderno=31&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_24_content:
  string
  line `The constitution, powers and functions of the Finance Committee shall be`
  line `prescribed by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (23162)
  sectionNo (25)
  orderNo 32
  title `Other authorities of University.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23162&sectionno=25&orderno=32&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_25_content:
  string
  line `The constitution, powers and functions of other authorities, as`
  line `may be declared by the Statutes to be the authorities of the University, shall be prescribed by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (23163)
  sectionNo (26)
  orderNo 33
  title `Powers to make Statutes.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23163&sectionno=26&orderno=33&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_26_content:
  string
  line `Subject to the provision of this Act, the Statutes may provide for all or`
  line `any of the following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the appointment and continuance in office of the members of the said authorities and bodies,`
  line `the filling up of vacancies of members, and all other matters relating to those authorities and other`
  line `bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers, academic staff and other employees of the University, their`
  line `emoluments and conditions of service;`
  line
  line `(e) the appointment of teachers and academic staff working in any other University or`
  line `organisation for a specific period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provisions for pension, insurance, provident`
  line `fund, the manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing the seniority of service of the employees of the University;`
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University.`
  line
  line `(j) the conferment of autonomous status on a College or an Institution or a Department;`
  line
  line `(k) the establishment and abolition of Schools, Departments, Centres, Halls, Colleges and`
  line Institutions;
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(n) the management of Colleges and Institutions established by the University;`
  line
  line `(o) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(p) the maintenance of discipline among the employees and students; and`
  line
  line `(q) all other matters which by this Act are to be, or may be, provided for by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (23164)
  sectionNo (27)
  orderNo 34
  title `Statutes, how to be made.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23164&sectionno=27&orderno=34&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_27_content:
  string
  line `(1) The first Statutes are those set out in the Second Schedule to this`
  line Act.
  line
  line `(2) The Executive Council may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Executive Council shall not make, amend or repeal any Statutes affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Executive Council.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require`
  line `the assent of the Visitor who may assent thereto or withhold assent or remit to the Executive Council for`
  line re-consideration.
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may make new or`
  line `additional Statutes or amend or repeal the Statutes referred to in sub-section (1) during the period of three`
  line `years immediately after the commencement of this Act:`
  line
  line `Provided that the Visitor may, on the expiry of the said period of three years, make, within one year`
  line `from the date of such expiry, such detailed Statutes as he may consider necessary and such detailed`
  line `Statutes shall be laid before both Houses of Parliament.`
  line
  line `(6) Notwithstanding anything contained in this section, the Visitor may direct the University to make`
  line `provisions in the Statutes in respect of any matter specified by him and if the Executive Council is unable`
  line `to implement such direction within sixty days of its receipt, the Visitor may, after considering the reasons,`
  line `if any, communicated by the Executive Council for its inability to comply with such direction, make or`
  line `amend the Statutes suitably.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (23165)
  sectionNo (28)
  orderNo 35
  title `Power to make Ordinances.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23165&sectionno=28&orderno=35&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_28_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to`
  line `examinations, degrees and diplomas to the University;`
  line
  line `(f) the conditions for award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(g) the conduct of examination, including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence and teaching of women`
  line `students and the prescribing of special courses of studies for them;`
  line
  line `(j) the establishment of Centres of Studies, Boards of Studies, Specialised Laboratories and other`
  line Committees;
  line
  line `(k) the manner of co-operation and collaboration with other Universities, Institutions and other`
  line `agencies including learned bodies or associations;`
  line
  line `(l) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(m) the institution of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(n) the setting up of machinery for redressal of grievances of employees and students; and`
  line
  line `(o) all other matters which by this Act, or, the Statutes, are to be, or may be provided for by the`
  line Ordinances.
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Executive Council and the Ordinances so made may also be amended, repealed or added to at any time by`
  line `the Executive Council in the manner prescribed by the Statutes:`
  line
  line `Provided that in the case of Guru Ghasidas Vishwavidyalaya and Doctor Harisingh Gour`
  line `Vishwavidyalaya, and Hemvati Nandan Bahuguna Garhwal University, till such time as the first`
  line `Ordinances are not so made, in respect of the matters that are to be provided for by the Ordinances under`
  line `this Act and the Statutes, the relevant provisions of the Statutes and the Ordinances made immediately`
  line `before the commencement of this Act under the provisions of the Madhya Pradesh Vishwavidyalaya`
  line `Adhiniyam, 1973 (Madhya Pradesh Act 22 of 1973), and the Utter Pradesh State Universities Act, 1973`
  line `(Presidents Act 10 of 1973), respectively, shall be applicable in so for as they are not inconsistent with`
  line `the provisions of this Act and the Statutes.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (23166)
  sectionNo (29)
  orderNo 36
  title Regulations.
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23166&sectionno=29&orderno=36&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_29_content:
  string
  line `The authorities of the University may make Regulations, consistent with this Act,`
  line `the Statutes and the Ordinances, for the conduct of their own business and that of the Committees, if any,`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances, in the manner`
  line `prescribed by the Statutes.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (23167)
  sectionNo (30)
  orderNo 37
  title `Annual report.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23167&sectionno=30&orderno=37&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_30_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Executive Council, which shall include, among other matters, the steps taken by the University`
  line `towards the fulfilment of its objects and shall be submitted to the Court on or before such date as may be`
  line `prescribed by the Statutes and the Court shall consider the report in its annual meeting.`
  line
  line `(2) The Court shall submit the annual report to the Visitor along with its comments, if any.`
  line
  line `(3) A copy of the annual report, as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (23168)
  sectionNo (31)
  orderNo 38
  title `Annual accounts.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23168&sectionno=31&orderno=38&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_31_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be prepared`
  line `under the direction of the Executive Council and shall, once at least every year and at intervals of not`
  line `more them fifteen months, be audited by the Comptroller and Auditor-General of India or by such persons`
  line `as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts together with the audit report thereon shall be submitted to the`
  line `Court and the Visitor along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Court and the observations of the Court, if any, shall, after being considered by the Executive Council, be`
  line `submitted to the Visitor.`
  line
  line `(4) A copy of the annual accounts together with the audit report, as submitted to the Visitor, shall also`
  line `be submitted to the Central Government, which shall, as soon as may be, cause the same to be laid before`
  line `both Houses of Parliament.`
  line
  line `(5) The audited annual accounts after having been laid before both Houses of Parliament shall be`
  line `published in the Gazette of India.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (23169)
  sectionNo (32)
  orderNo 39
  title `Returns and information.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23169&sectionno=32&orderno=39&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_32_content:
  string
  line `The University shall furnish to the Central Government such returns`
  line `or other information with respect to its property or activities as the Central Government may, from time to`
  line `time, require, within such period as may be specified by the Central Government.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (23170)
  sectionNo (33)
  orderNo 40
  title `Conditions of service of employees, etc.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23170&sectionno=33&orderno=40&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_33_content:
  string
  line `(1) Every employee of the University shall be`
  line `appointed under a written contract, which shall be lodged with the University and a copy of which shall`
  line `be furnished to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Executive Council, one member nominated by the employee concerned and an umpire appointed by`
  line `the Visitor.`
  line
  line `(3) The decision of the Tribunal shall be final and no suit shall lie in any civil court in respect of the`
  line `matters decided by the Tribunal:`
  line
  line `Provided that nothing in this sub-section shall preclude the employee from availing of the judicial`
  line `remedies available under articles 32 and 226 of the Constitution.`
  line
  line `(4) Every request made by the employee under sub-section (2) shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation Act, 1996`
  line `(26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be prescribed by the Statutes.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (23171)
  sectionNo (34)
  orderNo 41
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23171&sectionno=34&orderno=41&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_34_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the case`
  line `may be, and who has been debarred from appearing at the examinations of the University for more than`
  line `one year, may, within ten days of the date of receipt of such orders or copy of such resolution by him,`
  line `appeal to the Executive Council and the Executive Council may confirm, modify or reverse the decision`
  line `of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-sections`
  line `(2), (3), (4) and (5) of section 33 shall, as far as may be, apply to a reference made under this sub-section.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (23172)
  sectionNo (35)
  orderNo 42
  title `Right to appeal.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23172&sectionno=35&orderno=42&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_35_content:
  string
  line `Every employee or student of the University or of a College or Institution`
  line `maintained by the University shall, notwithstanding anything contained in this Act, have a right to appeal`
  line `within such time as may be prescribed by the Statutes, to the Executive Council against the decision of`
  line `any officer or authority of the University, or, the Principal or the management of any College or an`
  line `Institution, as the case may be, and thereupon the Executive Council may confirm, modify or reverse the`
  line `decision appealed against.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (23173)
  sectionNo (36)
  orderNo 43
  title `Provident and pension funds.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23173&sectionno=36&orderno=43&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_36_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such provident or pension fund or provide such insurance schemes as it may deem fit in such`
  line `manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or pension fund has been so constituted, the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund, as if it`
  line `were a Government provident fund.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (23174)
  sectionNo (37)
  orderNo 44
  title `Disputes as to constitution of authorities and bodies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23174&sectionno=37&orderno=44&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_37_content:
  string
  line `If any question arises as to whether any`
  line `person has been duly elected or appointed as, or is entitled to be, a member of any authority or other body`
  line `of the University, the matter shall be referred to the Visitor whose decision thereon shall be final.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (23175)
  sectionNo (38)
  orderNo 45
  title `Filling of casual vacancies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23175&sectionno=38&orderno=45&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_38_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `members) of any authority or other body of the University shall be filled, as soon as may be, by the`
  line `person or body who appoints, elects or co-opts the member whose place has become vacant and the`
  line `person appointed, elected or co-opted to a casual vacancy shall be a member of such authority or body for`
  line `the residue of the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (23176)
  sectionNo (39)
  orderNo 46
  title `Proceedings of authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23176&sectionno=39&orderno=46&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_39_content:
  string
  line `No act or proceedings of`
  line `any authority or other body of the University shall be invalid merely by reason of the existence of a`
  line `vacancy or vacancies among its members.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (23177)
  sectionNo (40)
  orderNo 47
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23177&sectionno=40&orderno=47&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_40_content:
  string
  line `No suit or other legal proceedings shall lie against any`
  line `officer or other employee of the University for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (23178)
  sectionNo (41)
  orderNo 48
  title `Mode of proof of University record.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23178&sectionno=41&orderno=48&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_41_content:
  string
  line `Notwithstanding anything contained in the Indian`
  line `Evidence Act,1872 (1 of 1872) or in any other law for the time being in force, a copy of any receipt,`
  line `application, notice, order, proceeding or resolution of any authority or other body of the University, or`
  line `any other document in possession of the University, or any entry in any register duly maintained by the`
  line `University, if certified by the Registrar, shall be received as prima facie evidence of such receipt,`
  line `application, notice, order, proceeding, resolution or document or the existence of entry in the register and`
  line `shall be admitted as evidence of the matters and transactions therein where the original thereof would, if`
  line `produced, have been admissible in evidence.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (23179)
  sectionNo (42)
  orderNo 49
  title `Power to remove difficulties.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23179&sectionno=42&orderno=49&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_42_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order published in the Official Gazette, make such provisions, not`
  line `inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under sub-section (1) shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the order or both Houses agree that the order should not be made, the order shall thereafter have effect`
  line `only in such modified form or be of no effect, as the case may be; so, however, that any such modification`
  line `or annulment shall be without prejudice to the validity of anything previously done under that order.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (23180)
  sectionNo (43)
  orderNo 50
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23180&sectionno=43&orderno=50&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_43_content:
  string
  line `(1) Every Statute, Ordinances or Regulation made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinances or Regulation made under this Act, shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinances or Regulation or both Houses agree that the Statute,`
  line `Ordinances or Regulation should not be made, the Statute, Ordinances or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinances or Regulation.`
  line
  line `(3) The power to make Statutes, Ordinances or Regulations shall include the power to give`
  line `retrospective effect, from a date not earlier than the date of commencement of this Act, to the Statutes,`
  line `Ordinances or Regulation or any of them but no retrospective effect shall be given to any Statutes,`
  line `Ordinances or Regulations so as to prejudicially affect the interests of any person to whom such Statutes,`
  line `Ordinances or Regulations may be applicable.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (23181)
  sectionNo (44)
  orderNo 51
  title `Transitional provisions.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23181&sectionno=44&orderno=51&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_44_content:
  string
  line `Notwithstanding anything contained on this Act and the Statutes,--`
  line
  line `(a) the first Chancellor and the first Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner and on such conditions as may be deemed fit and each of the said officers shall hold office for`
  line `such term, not exceeding five years, as may be specified by the Visitor;`
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Visitor and each of`
  line `the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Court and the first Executive Council shall consist of not more than thirty-one`
  line `members and eleven members, respectively, who shall be nominated by the Central Government and`
  line `shall hold office for a term of three years; and`
  line
  line `(d) the first Academic Council shall consist of not more than twenty-one members, who shall be`
  line `nominated by the Central Government and shall hold office for a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment by the Visitor or nomination by the Central Government, as the case may be, and the person`
  line `so appointed or nominated shall hold office for so long as the officer or member in whose place he is`
  line `appointed or nominated would have held office, if such vacancy had not occurred.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (23182)
  sectionNo (45)
  orderNo 52
  title `Amendment of Madhya Pradesh Act 22 of 1973.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23182&sectionno=45&orderno=52&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_45_content:
  string
  line `(1) In the Madhya Pradesh Vishwavidyalaya`
  line `Adhiniyam, 1973, in the Second Schedule, the entries relating to Guru Ghasidas Vishwavidyalaya and`
  line `Doctor Harisingh Gour Vishwavidyalaya shall be omitted.`
  line
  line `(2) Notwithstanding such omission,--`
  line
  line `(a) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted, or other things done under the Madhya Pradesh`
  line `Vishwavidyalaya Adhiniyam, 1973 (Madhya Pradesh Act 22 of 1973), shall be deemed to have been`
  line `respectively made, issued, conferred, awarded, granted or done under the corresponding provisions of`
  line `this Act and, except as otherwise provided by this Act or the Statutes, continue in force unless and`
  line `until they are superseded by any order made under this Act or the Statutes; and`
  line
  line `(b) all proceedings of Selection Committees for the appointment or promotion of teachers that`
  line `took place before the commencement of this Act and all actions of the Executive Council in respect of`
  line `the recommendations of such Selection Committees where no orders of appointment on the basis`
  line `thereof were passed before the commencement of this Act shall, notwithstanding that the procedure`
  line `for selection has been modified by this Act, be deemed to have been valid but further proceeding in`
  line `connection with such pending selections shall be taken in accordance with the provisions of this Act`
  line `and be continued from the stage where they stood immediately before such commencement, except if`
  line `the concerned authorities take, with the approval of the Visitor, a decision to the contrary.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (23183)
  sectionNo (46)
  orderNo 53
  title `Amendment of President’s Act 10 of 1973.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23183&sectionno=46&orderno=53&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_46_content:
  string
  line `(1) In the Uttar Pradesh State Universities Act,`
  line 1973,--
  line
  line `(a) in sub-section (1) of section 4, the words, figures and brackets "and a University of Garhwal`
  line `which shall from April 25, 1989 be called the Hemvati Nandan Bahuguna Garhwal University at`
  line `Srinagar (District Garhwal)" shall be omitted;`
  line
  line `(b) in clause (d) of sub-section (1) of section 20, the words "the Hemvati Nandan Bahuguna`
  line `Garhwal University" shall be omitted;`
  line
  line `(c) in sub-section (2) of section 52, for the words "the Universities of Kumaun and Garhwal" the`
  line `words "the University of Kumaun" shall be substituted;`
  line
  line `(d) section 72B shall be omitted;`
  line
  line `(e) in the Schedule, Serial No. 8 and the entries relating thereto shall be omitted.`
  line
  line `(2) Notwithstanding the omission and substitution referred to in sub-section (1),--`
  line
  line `(a) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted, or other things done under the Uttar Pradesh`
  line `State Universities Act, 1973 (Presidents Act 10 of 1973), shall be deemed to have been respectively`
  line `made, issued, conferred, awarded, granted or done under the corresponding provisions of this Act`
  line `and, except as otherwise provided by this Act or the Statutes, continue in force unless and until they`
  line `are superseded by and order made under this Act or the Statutes; and`
  line
  line `(b) all proceedings of Selection Committees for the appointment or promotion of teachers that`
  line `took place before the commencement of this Act and all actions of the Executive Council in respect of`
  line `the recommendations of such Selection Committees where no orders of appointment on the basis`
  line `thereof were passed before the commencement of this Act shall, notwithstanding that the procedure for selection has been modified by this Act, be deemed to have been valid but further proceeding in`
  line `connection with such pending selections shall be taken in accordance with the provisions of this Act`
  line `and be continued from the stage where they stood immediately before such commencement, except if`
  line `the concerned authorities take, with the approval of the Visitor, a decision to the contrary.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (23184)
  sectionNo (47)
  orderNo 54
  title `Repeal and savings.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23184&sectionno=47&orderno=54&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_47_content:
  string
  line `(1) The Central Universities Ordinance, 2009 (Ord. 3 of 2009) is hereby`
  line repealed.
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act, and-`
  line
  line `(a) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted, or other things done under the Central`
  line `Universities Ordinance, 2009 (Ord. 3 of 2009), shall be deemed to have been respectively made,`
  line `issued, conferred, awarded, granted or done under the corresponding provisions of this Act and,`
  line `except as otherwise provided by, or under this Act or the Statutes, continue in force unless and until`
  line `they are superseded by any order made under this Act or the Statutes; and`
  line
  line `(b) all proceedings of Selection Committees for the appointment or promotion of teachers that`
  line `took place before the commencement of this Act and all actions of the Executive Council in respect of`
  line `the recommendations of such Selection Committees where no orders of appointment on the basis`
  line `thereof were passed before the commencement of this Act shall, notwithstanding that the procedure`
  line `for selection has been modified by this Act, be deemed to have been valid but further proceeding in`
  line `connection with such pending selections shall be taken in accordance with the provisions of this Act`
  line `and be continued from the stage where they stood immediately before such commencement, except if`
  line `the concerned authorities take, with the approval of the Visitor, decision to the contrary.`
obj_root_law_sections_47_footnotes:
  string
  line
