obj_root_law_sections_1:
  sectionId (23136)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23136&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Central Universities Act, 2009.`
  line
  line `(2) It shall be deemed to have come into force on the 15th day of January, 2009.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (23137)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23137&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_2_content:
  string
  line `.In this Act, and in all Statutes made hereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "Board of Studies" means the Board of Studies of a Department of the University;`
  line
  line `(d) "College" means a college maintained by the University;`
  line
  line `(e) "Chancellor", "Vice-Chancellor" and "Pro-Vice-Chancellor" mean, respectively, the`
  line `Chancellor, Vice-Chancellor and Pro-Vice-Chancellor of the University;`
  line
  line `(f) "Court" means the Court of the University;`
  line
  line `(g) "Department" means a Department of Studies and includes a Centre of Studies;`
  line
  line `(h) "distance education system" means the system of imparting education through any means of`
  line `communication, such as broadcasting, telecasting, internet, correspondence courses, seminars, contact`
  line `programmes or the combination of any two or more such means;`
  line
  line `(i) "employee" means any person appointed by the University and include teachers and other staff`
  line `of the University;`
  line
  line `(j) "Executive Council" means the Executive Council of the University;`
  line
  line `(k) "Hall" means a unit of residence or of corporate life for the student of the University, or of a`
  line `College or an Institution, maintained by the University;`
  line
  line `(l) "Institution" means an academic institution, not being a College, maintained by the University;`
  line
  line `(m) "Principal" means the Head of a College or an Institution maintained by the University and`
  line `includes, where there is no principal, the person for the time being duly appointed to act as Principal,`
  line `and in the absence of the Principal, or the acting Principal, a Vice- Principal duly appointed as such;`
  line
  line `(n) "Regulations" means the Regulations made by any authority of the University under this Act`
  line `for the time being in force;`
  line
  line `(o) "School" means a School of Studies of the University;`
  line
  line `(p) "Statutes" and "Ordinances" mean, respectively, the Statutes and the Ordinances of the`
  line `University for the time being in force;`
  line
  line `(q) "teachers of the University" means Professors, Associate Professors, Assistant Professors and`
  line `such other persons as may by appointed for imparting instruction or conducting research in the`
  line `University or in any College or Institution maintained by the University and are designated as`
  line `teachers by the Ordinances; and`
  line
  line `(r) "University" means a University established and incorporated as a University under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (23138)
  sectionNo (3)
  orderNo 3
  title `Establishment of Universities.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23138&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_content:
  string
  line `(1)The Guru Ghasidas Vishwavidyalaya in the State of`
  line `Chhattisgarh and Doctor Harisingh Gour Vishwavidyalaya in the State of Madhya Pradesh, established`
  line `under the Madhya Pradesh Vishwavidyalaya Adhiniyam, 1973 (Madhya Pradesh Act 22 of 1973), and`
  line `Hemvati Nandan Bahuguna Garhwal University in the State of Uttarakhand, established under the Uttar`
  line `Pradesh State Universities Act,1973 (Presidents Act 10 of 1973), shall be established as bodies corporate`
  line `under this Act by the same names of "Guru Ghasidas Vishwavidyalaya", "Doctor Harisingh Gour`
  line `Vishwavidyalaya" and "Hemvati Nandan Bahuguna Garhwal University", respectively.`
  line
  line `(2) The headquarters of Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya`
  line `and Hemvati Nandan Bahuguna Garhwal University, shall be at Bilaspur, Sagar and Srinagar,`
  line respectively.
  line
  line `(3) The jurisdiction of Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya`
  line `and Hemvati Nandan Bahuguna Garhwal University shall extend to the Bilaspur, Raigarh and Surguja`
  line `districts of the State of Chhattisgarh, the Sagar, Tikamgarh, Chhatarpur, Panna, Chhindwara and Damoh`
  line `districts of the State of Madhya Pradesh, and the Chamoli, Dehradun, Garhwal, Hardwar, Rudraprayag,`
  line `Tehri Garhwal and Uttarkashi districts of the State of Uttarakhand, respectively.`
  line
  line `(4) There shall be established, the Universities in the various States as bodies corporate, by such`
  line `names and territorial jurisdiction, as specified in the First Schedule to this Act.`
  line
  line `(5) The headquarters of each of the University, referred in sub-section (4), shall be such as may be`
  line `specified by the Central Government by notification in the Official Gazette.`
  line
  line `(6) The first Chancellor, the first Vice-Chancellor and the first members of the Court, the Executive`
  line `Council and the Academic Council of each University, and all persons who may hereafter become such`
  line `officers or members, so long as they continue to hold such office or membership, are hereby constituted a`
  line `body corporate by the name of the University.`
  line
  line `(7) The University shall have perpetual succession and a common seal, and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_3_a:
  sectionId (23139)
  sectionNo 3A
  orderNo 4
  title `Special provision with respect to the union Territory of Jammu and Kashmir.`
  content obj_root_law_sections_3_a_content
  footnotes obj_root_law_sections_3_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23139&sectionno=3A&orderno=4&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Special provision with respect to the ^2[Union Territory of Jammu and Kashmir]*.--(1) The Central`
  line `University of Jammu and Kashmir established under sub-section (4) of section 3 shall be known as the`
  line `Central University of Kashmir and its territorial jurisdiction shall be limited to the Kashmir Division of`
  line `the ^2[Union Territory of Jammu and Kashmir]^*.`
  line
  line `(2) There shall be established a university, which shall be a body corporate, to be known as the`
  line `Central University of Jammu having its territorial jurisdiction extending to the Jammu Division of the`
  line `^2[Union Territory of Jammu and Kashmir]^*.`
  line
  line `(3) All assets and liabilities of the Central University of Jammu and Kashmir in respect of the`
  line `territory of Jammu Division of the ^2[Union Territory of Jammu and Kashmir]^* shall stand transferred to be the assets`
  line `and liabilities of the Central University of Jammu.`
  line
  line `(4) Anything done or any action taken by the University of Jammu and Kashmir in respect of the`
  line `territory of Jammu Division of ^2[Union Territory of Jammu and Kashmir]^* shall be deemed to have been done or`
  line `taken by the Central University of Jammu.`
  line
  line `(5) Any suit or legal proceedings instituted or continued by or against the Central University of`
  line `Jammu and Kashmir in respect of the territory of Jammu Division of the ^2[Union Territory of Jammu and Kashmir]^*`
  line `shall be deemed to have been instituted or continued by or against the Central University of Jammu.]`
obj_root_law_sections_3_a_footnotes:
  string
  line `1. Ins. by Act 38 of 2009, s. 2 (w.e.f. 20-10-2009).`
  line
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`
  line
  line `2. Subs. by Act 27 of 2021, s. 2, for "State of Jammu and Kashmir" (w.e.f. 6-7-2022).`
obj_root_law_sections_3_b:
  sectionId (23140)
  sectionNo 3B
  orderNo 5
  title `Special provision with respect to State of Bihar.`
  content obj_root_law_sections_3_b_content
  footnotes `1. Section 3B shall stand inserted (date to be notified) by Act 35 of 2014, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23140&sectionno=3B&orderno=5&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_b_content:
  string
  line `^1[3B. Special provision with respect to State of Bihar.--(1) The Central University of Bihar`
  line `established under sub-section (4)of section 3 shall be known as the Central University of South Bihar,`
  line `having its territorial jurisdiction extending to the territory in the south of River Ganges in the State of`
  line `Bihar, as specified in the First Schedule to this Act.`
  line
  line `(2) There shall be established a University, which shall be a body corporate, to be known as the Mahatma Gandhi Central University, having its territorial jurisdiction extending to the territory in the`
  line `north of the River Ganges in the State of Bihar, as specified in the First Schedule to this Act].`
obj_root_law_sections_3_c:
  sectionId (49415)
  sectionNo 3C
  orderNo 6
  title `Establishment of Central University of Andhra Pradesh.`
  content obj_root_law_sections_3_c_content
  footnotes `1. Ins. by Act 15 of 2019, s. 2 (w.e.f. 5-8-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=49415&sectionno=3C&orderno=6&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_c_content:
  string
  line `^1[3C. Establishment of Central University of Andhra Pradesh.There shall be established a`
  line `University, which shall be a body corporate, to be known as the Central University of Andhra Pradesh,`
  line `having its territorial jurisdiction extending to the whole of the State of Andhra Pradesh, as specified in the`
  line `First Schedule to this Act]`
obj_root_law_sections_3_d:
  sectionId (49416)
  sectionNo 3D
  orderNo 7
  title `Establishment of Central Tribal University of Andhra Pradesh.`
  content obj_root_law_sections_3_d_content
  footnotes `1. Ins. by Act 15 of 2019, s. 2 (w.e.f. 5-8-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=49416&sectionno=3D&orderno=7&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_d_content:
  string
  line `^1[3D. Establishment of Central Tribal University of Andhra Pradesh.There shall be established a`
  line `Tribal University, which shall be a body corporate, to be known as the Central Tribal University of`
  line `Andhra Pradesh, as specified in the First Schedule to this Act, to provide avenues of higher education and`
  line `research facilities primarily for the tribal population of India.]`
obj_root_law_sections_3_e:
  sectionId (66834)
  sectionNo 3E
  orderNo 8
  title `Establishment of Sindhu Central University.`
  content obj_root_law_sections_3_e_content
  footnotes `1. Ins. by Act 27 of 2021, s. 3 (w.e.f. 6-7-2022).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=66834&sectionno=3E&orderno=8&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_e_content:
  string
  line `^1[3E. Establishment of Sindhu Central University.--`
  line `There shall be established a University,`
  line `which shall be a body corporate, to be known as the Sindhu Central University, having its territorial`
  line `jurisdiction extending to the whole of the Union territory of Ladakh, as specified in the First Schedule to`
  line `this Act].`
obj_root_law_sections_3_f:
  sectionId (71855)
  sectionNo 3F
  orderNo 9
  title `Establishment of Gati Shakti Vishwavidyalaya in Gujarat.`
  content obj_root_law_sections_3_f_content
  footnotes `1. Ins. by Act 17 of 2022, s. 3 (w.e.f. 6-12-2022).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=71855&sectionno=3F&orderno=9&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_f_content:
  string
  line `^1[3F. Establishment of Gati Shakti Vishwavidyalaya in Gujarat.--(1) The National Rail and`
  line `Transportation Institute, Vadodara, Gujarat, declared as a deemed to be University under section 3 of the`
  line `University Grants Commission Act, 1956 (3 of 1956), shall be established as a body corporate under this`
  line `Act by the name Gati Shakti Vishwavidyalaya.`
  line
  line `(2) The territorial jurisdiction of Gati Shakti Vishwavidyalaya shall extend to the whole of India, as`
  line `specified in the First Schedule to this Act.`
  line
  line `(3) The Gati Shakti Vishwavidyalaya shall be sponsored and funded by the Central Government in`
  line `the Ministry of Railways.]`
obj_root_law_sections_3_g:
  sectionId (82833)
  sectionNo 3G
  orderNo 10
  title `Establishment of Sammakka Sarakka Central Tribal University.`
  content obj_root_law_sections_3_g_content
  footnotes `1. Ins. by Act 36 of 2023, s. 2 (w.e.f. 24-1-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=82833&sectionno=3G&orderno=10&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_3_g_content:
  string
  line `^1[3G. Establishment of Sammakka Sarakka Central Tribal University.--There shall be`
  line `established a Tribal University, which shall be a body corporate, to be known as the Sammakka Sarakka`
  line `Central Tribal University, having its territorial jurisdiction extending to the whole of the State of`
  line `Telangana, as specified in the First Schedule to this Act, to provide avenues of higher education and`
  line `research facilities primarily for the tribal population of India.]`
obj_root_law_sections_4:
  sectionId (23141)
  sectionNo (4)
  orderNo 11
  title `Effect of establishment of Universities.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 17 of 2022, s. 4, for "Whichever is earlier; and" (w.e.f. 6-12-2022).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23141&sectionno=4&orderno=11&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_4_content:
  string
  line `On and from the dated of commencement of this Act,--`
  line
  line `(a) any reference to Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya`
  line `or Hemvati Nandan Bahuguna Garhwal University, in any contract or other instrument shall be`
  line `deemed as a reference to Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya,`
  line `and Hemvati Nandan Bahuguna Garhwal University, respectively, established under this Act;`
  line
  line `(b) all properties, movable and immovable, of or belonging to Guru Ghasidas Vishwavidyalaya,`
  line `Doctor Harisingh Gour Vishwavidyalaya and Hemvati Nandan Bahuguna Garhwal University, shall`
  line `vest in Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya or Hemvati`
  line `Nandan Bahuguna Garhwal University, as the case may be, established under this Act;`
  line
  line `(c) all rights and liabilities of Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour`
  line `Vishwavidyalaya and Hemvati Nandan Bahuguna Garhwal University, shall be transferred to, and be`
  line `the rights and liabilities of, Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour`
  line `Vishwavidyalaya and Hemvati Nandan Bahuguna Garhwal University, respectively, established`
  line `under this Act;`
  line
  line `(d) every person employed by Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour`
  line `Vishwavidyalaya and Hemvati Nandan Bahuguna Garhwal University, immediately before the`
  line `commencement of this Act shall hold his office or service in Guru Ghasidas Vishwavidyalaya, Doctor`
  line `Harisingh Gour Vishwavidyalaya and Hemvati Nandan Bahuguna Garhwal University, respectively,`
  line `established under this Act by the same tenure, at the same remuneration and upon the same terms and`
  line `conditions and with the same rights and privileges as to pension, leave, gratuity, provident fund and`
  line `other matters as he would have held the same if this Act had not been enacted and shall continue to do`
  line `so unless and until his employment is terminated or until such tenure, remuneration and terms and`
  line `conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the University in accordance with the terms of the contract with the employee or, if`
  line `no provision is made therein in this behalf, on payment, to him by the University, of compensation`
  line `equivalent to three months' remuneration in case of permanent employees and one month's`
  line `remuneration in the case of other employees:`
  line
  line `Provided further that every person employed before the commencement of this Act, pending the`
  line `execution of a contract under section 33, shall be deemed to have been appointed in accordance with`
  line `the provisions of a contract consistent with the provisions of this Act and the Statutes:`
  line
  line `Provided also that any reference, by whatever form of words, to the Vice-Chancellor and`
  line `Pro-Vice-Chancellor of Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya or`
  line `Hemvati Nandan Bahuguna Garhwal University, in any law for the time being in force, or in any`
  line `instrument or other document, shall be Construed as a reference to the Vice-Chancellor and the`
  line `Pro-Vice-Chancellor of Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya or`
  line `Hemvati Nandan Bahuguna Garhwal University, as the case may be, established under this Act.`
  line
  line `(e) the Vice-Chancellors of Guru Ghasidas Vishwavidyalaya and Doctor Harisingh Gour`
  line `Vishwavidyalaya, appointed under the provisions of the Madhya Pradesh Vishwavidyalaya`
  line `Adhiniyam, 1973 (Madhya Pradesh Act 22 of 1973), and the Vice-Chancellor of Hemvati Nandan`
  line `Bahuguna Garhwal University, appointed under the provisions of the Uttar Pradesh State Universities`
  line `Act, 1973 (Presidents Act 10 of 1973), shall be deemed to have been appointed as the ViceChancellor under this Act and shall hold office for a period of three months or till such time the first`
  line `Vice-Chancellor is appointed under section 44 of the Act ^1[whichever is earlier]`
  line
  line `(f) all colleges, Institutions, Schools or Faculties, and Departments affiliated to, or admitted to the`
  line `privileges of, or maintained by, Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour`
  line `Vishwavidyalaya and Hemvati Nandan Bahuguna Garhwal University shall stand affiliated to or`
  line `admitted to the privileges of, or maintained by, Guru Ghasidas Vishwavidyalaya, Doctor Harisingh Gour Vishwavidyalaya and Hemvati Nandan Bahuguna Garhwal University, respectively, established`
  line `under this Act.`
obj_root_law_sections_5:
  sectionId (23142)
  sectionNo (5)
  orderNo 12
  title `Objects of University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23142&sectionno=5&orderno=12&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_5_content:
  string
  line `The objects of the University shall be to disseminate and advance`
  line `knowledge by providing instructional and research facilities in such branches of learning as it may deem`
  line `fit; to make special provisions for integrated courses in humanities, social sciences, science and`
  line `technology in its educational programmes; to take appropriate measures for promoting innovations in`
  line `teaching-learning process and inter-disciplinary studies and research; to educate and train manpower for`
  line `the development of the country; to establish linkages with industries for the promotion of science and`
  line `technology; and to pay special attention to the improvement of the social and economic conditions and`
  line `welfare of the people, their intellectual, academic and cultural development.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (23143)
  sectionNo (6)
  orderNo 13
  title `Powers of University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23143&sectionno=6&orderno=13&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_6_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instructions in such branches of learning like natural sciences, social sciences,`
  line `humanities, engineering, technology and medicine as the University may, from time to time,`
  line `determine and to make provisions for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on, persons, on the basis of examination,`
  line `evaluation or any other method of testing, and to withdraw any such diplomas, certificates, degrees`
  line `or other academic distinction for good and sufficient cause;`
  line
  line `(iii) to organise and to undertake extramural studies, training and extension services;`
  line
  line `(iv) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(v) to provide facilities through the distance education system to such persons as it may`
  line determine;
  line
  line `(vi) to institute Principalships, Professorships, Associate Professorships, Assistant Professorships`
  line `and other teaching or academic positions, required by the University and to appoint persons such`
  line `Principalships, Professorships, Associate Professorships, Assistant Professorships or other teaching or`
  line `academic positions;`
  line
  line `(vii) to recognise an institution of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(viii) to appoint persons working in any other University or academic institution, including those`
  line `located outside the country, as teachers of the University for a specified period;`
  line
  line `(ix) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(x) to co-operate or collaborate or associate with any other University or authority or institution of`
  line `higher learning, including those located outside the country, in such manner and for such purposes as`
  line `the University may determine;`
  line
  line `(xi) to establish such centers and specialised laboratories or other units for research and`
  line `instruction as are, in the opinion of the University, necessary for the furtherance of its objects;`
  line
  line `(xii) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xiii) to establish and maintain colleges, Institutions and Halls;`
  line
  line `(xiv) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions, industrial or other organisations, as the University may deem`
  line necessary;
  line
  line `(xv) to organise and conduct refresher courses, workshops, seminars and other programmes for`
  line `teachers, evaluators and other academic staff;`
  line
  line `(xvi) to appoint on contract or otherwise visiting Professors, Emeritus Professors, Consultants and`
  line `such other persons who may contribute to the advancement of the objects of the University;`
  line
  line `(xvii) to confer autonomous status on a College or an Institution or a Department, as the case may`
  line `be, in accordance with the Statutes;`
  line
  line `(xviii) to determine standards of admission to the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xix) to demand and receive payment of fees and other charges;`
  line
  line `(xx) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xxi) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xxii) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxiii) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(xxiv) to receive benefactions, donations and gifts and to acquire, hold and manage, and to`
  line `dispose of, with the previous approval of the Central Government, any property, movable or`
  line `immovable, including trust and endowment properties, for the purposes of the University;`
  line
  line `(xxv) to borrow, with the previous approval of the Central Government, on the security of the`
  line `Property of the University, money for the purposes of the University; and`
  line
  line `(xxvi) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
  line
  line `(2) in exercising its powers referred to in sub-section (1), it shall be the endeavour of the University to`
  line `maintain an all-India character and high standards of teaching and research, and the University shall,`
  line `among other measures which may be necessary for the said purpose, take, in particular, the following`
  line `measures, namely:--`
  line
  line `(i) admission of students and recruitment of faculty shall be made on all-India basis;`
  line
  line `(ii) admissions of students shall be made on merit, either through Common Entrance Tests`
  line `conducted individually by the University or in combination with other Universities, or on the basis of`
  line `marks obtained in the qualifying examination in such courses where the intake of students is small;`
  line
  line `(iii) inter-University mobility of faculty, with portable pensions and protection of seniority, shall`
  line `be encouraged;`
  line
  line `(iv) semester system, continuous evaluation and choice-based credit system shall be introduced`
  line `and the University shall enter into agreements with other Universities and academic institutions for`
  line `credit transfer and joint degree programmes;`
  line
  line `(v) innovative courses and programmes of studies shall be introduced with a provision for`
  line `periodic review and restructuring;`
  line
  line `(vi) active participation of students shall be ensured in all academic activities of the University,`
  line `including evaluation of teachers;`
  line
  line `(vii) accreditation shall be obtained from the National Assessment and Accreditation Council or`
  line `any other accrediting agency at the national level; and`
  line
  line `(viii) e-governance shall be introduced with an effective management information system.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (23144)
  sectionNo (7)
  orderNo 14
  title `University open to all castes, creed, race or class.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23144&sectionno=7&orderno=14&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_7_content:
  string
  line `The University shall be open to the persons of`
  line `either sex and of whatever caste, creed, race or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person, any test whatsoever of religious belief or profession in order to entitle him to be`
  line `appointed as a teacher of the University or to hold any other office therein or to be admitted as a student`
  line `in the University or to graduate thereat or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provision for the employment or admission of women, persons with disabilities or of persons belonging to`
  line `the weaker sections of the society and, in particular, of the Scheduled Castes, the Scheduled Tribes and`
  line `the other socially and educationally backward classes of citizens:`
  line
  line `Provide further that no such special provision shall be made on the ground of domicile.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (23145)
  sectionNo (8)
  orderNo 15
  title `Visitor of University.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23145&sectionno=8&orderno=15&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_8_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University, including Colleges and Institutions maintained by it, and to submit a report thereon; and`
  line `upon receipt of that report, the Visitor may, after obtaining the views of the Executive Council thereon`
  line `through the Vice-Chancellor, take such action and issue such directions, as he considers necessary, in`
  line `respect of any of the matters dealt with in the report and the University shall abide by such action and be`
  line `bound to comply with such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection to be made by such person or persons, as he`
  line `may direct, of the University, its buildings, libraries, laboratories and equipment, and of any College or`
  line `Institution maintained by the University; and also of the examinations, teaching and other work conducted`
  line `or done by the University and to cause an inquiry to be made in like manner in respect of any matter`
  line `connected with the administration or finances of the University, College or Institutions.`
  line
  line `(4) The Visitor shall, in every matter referred to in sub-section (3), give notice of his intention to`
  line `cause an inspection or inquiry to be made, to the University, and the University shall have the right to`
  line `make such representations to the Visitor, as it may consider necessary.`
  line
  line `(5) After considering the representations, if any, made by the University, the Visitor may cause to be`
  line `made such inspection or inquiry as is referred to in sub- section (3).`
  line
  line `(6) Where any inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative, who shall have the right to be present and be heard at such`
  line `inspection or inquiry.`
  line
  line `(7) The Visitor may, if the inspection or inquiry is made in respect of the University or any College or`
  line `Institution maintained by it, address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry together with such views and advice with regard to the action to be taken thereon, as the Visitor`
  line `may be pleased to offer, and on receipt of address made by the Visitor, the Vice-Chancellor shall`
  line `communicate, to the Executive Council, the views of the Visitor with such advice as the Visitor may offer`
  line `upon the action to be taken thereon.`
  line
  line `(8) The Executive Council shall communicate through the Vice-Chancellor to the Visitor such action,`
  line `if any, as it proposes to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(9) Where, the Executive Council does not, within a reasonable time, take action to the satisfaction of`
  line `the Visitor, the Visitor may, after considering any explanation furnished or representation made by the`
  line `Executive Council, issue such directions, as he may think fit, and the Executive Council shall comply`
  line `with such directions.`
  line
  line `(10) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annul any proceeding of the University which is not in conformity with this Act, the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the Registrar to show cause why such`
  line `an order should not be made, and, if any cause is shown within a reasonable time, he shall consider the`
  line same.
  line
  line `(11) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (23146)
  sectionNo (9)
  orderNo 16
  title `Officers of University.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23146&sectionno=9&orderno=16&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_9_content:
  string
  line `The following shall be the officers of the University, namely:--`
  line
  line `1. The Chancellor;`
  line
  line `2. The Vice-Chancellor;`
  line
  line `3. The Pro-Vice-Chancellor;`
  line
  line `4. The Deans of Schools;`
  line
  line `5. The Registrar;`
  line
  line `6. The Finance Officer;`
  line
  line `7. The Controller of Examination;`
  line
  line `8. The Librarian; and`
  line
  line `9. Such other officers as may be declared by the Statutes to be the officers of the University`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (23147)
  sectionNo (10)
  orderNo 17
  title Chancellor.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23147&sectionno=10&orderno=17&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_10_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the head of the University and shall, if present,`
  line `preside at the Convocations of the University held for conferring degrees and meetings of the Court.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (23148)
  sectionNo (11)
  orderNo 18
  title Vice-Chancellor.
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23148&sectionno=11&orderno=18&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_11_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such manner as`
  line `may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of the opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority at its next meeting the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of the opinion that such action ought not to have been`
  line `taken, it may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to represent against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated`
  line `to him and thereupon the Executive Council may confirm, modify or reverse the action taken by the`
  line Vice-Chancellor.
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the University is`
  line `beyond the powers of the authority conferred by the provisions of this Act, the Statutes or the Ordinances`
  line `or that any decision taken is not in the interest of the University, may ask the authority concerned to`
  line `review its decision within sixty days of such decision and if the authority refuses to review the decision`
  line `either in whole or in part or no decision is taken by it within the said period of sixty days, the matter shall`
  line `be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (23149)
  sectionNo (12)
  orderNo 19
  title Pro-Vice-Chancellor.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23149&sectionno=12&orderno=19&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_12_content:
  string
  line `The Pro-Vice-Chancellor shall be appointed in such manner and on such`
  line `terms and condition of service, and shall exercise such powers and perform such duties, as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (23150)
  sectionNo (13)
  orderNo 20
  title `Deans of Schools.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23150&sectionno=13&orderno=20&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_13_content:
  string
  line `Every Dean of School shall be appointed in such manner, and shall exercise`
  line `such powers and perform such duties, as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (23151)
  sectionNo (14)
  orderNo 21
  title Registrar.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00014_200925_1517807324115&sectionId=23151&sectionno=14&orderno=21&orgactid=AC_CEN_9_30_00014_200925_1517807324115
obj_root_law_sections_14_content:
  string
  line `(1) The Registrar shall be appointed in such manner, and on such terms and`
  line `conditions of service, as may be prescribed by the Statutes.`
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University, and shall exercise such powers and perform such duties, as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (23152)
