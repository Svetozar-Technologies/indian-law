obj_root_law_sections_1:
  object
  (str sectionId) (str 33963)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Election Laws (Extension to
Sikkim) Act, 1976.

(2) It shall be deemed to have come into force on the 9th day of September, 1975.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00017_197610_1517807321616&sectionId=33963&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00017_197610_1517807321616)
obj_root_law_sections_2:
  object
  (str sectionId) (str 33964)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Extension and amendment of election laws.`)
  (str content) (str `(1) The Acts mentioned in the Schedule are
hereby extended to, and shall be in force in, the State of Sikkim.

(2) With effect from the commencement of this Act, the Acts mentioned in the Schedule shall be
amended as specified therein.

(3) Any reference in the Acts mentioned in the Schedule to a law not in force, or to a functionary
not in existence, in the State of Sikkim shall be construed as a reference to the corresponding law in
force, or to the corresponding functionary in existence, in that State:

Provided that if any question arises as to who such corresponding functionary is, or if there is no
such corresponding functionary, the Central Government shall decide as to who such functionary will
be and the decision of the Central Government shall be final.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00017_197610_1517807321616&sectionId=33964&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00017_197610_1517807321616)
obj_root_law_sections_3:
  object
  (str sectionId) (str 33965)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Repeal and saving.`)
  (str content) (str `(1) The Election Laws (Extension to Sikkim)
Ordinance, 1975 (9 of 1975), is hereby repealed.

(2) Notwithstanding such repeal, anything done or any action taken under or by virtue of the said
Ordinance shall be deemed to have been done or taken under or by virtue of this Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00017_197610_1517807321616&sectionId=33965&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00017_197610_1517807321616)
