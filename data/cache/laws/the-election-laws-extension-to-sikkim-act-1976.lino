obj_root_law_sections_1:
  sectionId (33963)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00017_197610_1517807321616&sectionId=33963&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00017_197610_1517807321616
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Election Laws (Extension to`
  line `Sikkim) Act, 1976.`
  line
  line `(2) It shall be deemed to have come into force on the 9th day of September, 1975.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (33964)
  sectionNo (2)
  orderNo 2
  title `Extension and amendment of election laws.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00017_197610_1517807321616&sectionId=33964&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00017_197610_1517807321616
obj_root_law_sections_2_content:
  string
  line `(1) The Acts mentioned in the Schedule are`
  line `hereby extended to, and shall be in force in, the State of Sikkim.`
  line
  line `(2) With effect from the commencement of this Act, the Acts mentioned in the Schedule shall be`
  line `amended as specified therein.`
  line
  line `(3) Any reference in the Acts mentioned in the Schedule to a law not in force, or to a functionary`
  line `not in existence, in the State of Sikkim shall be construed as a reference to the corresponding law in`
  line `force, or to the corresponding functionary in existence, in that State:`
  line
  line `Provided that if any question arises as to who such corresponding functionary is, or if there is no`
  line `such corresponding functionary, the Central Government shall decide as to who such functionary will`
  line `be and the decision of the Central Government shall be final.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (33965)
  sectionNo (3)
  orderNo 3
  title `Repeal and saving.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00017_197610_1517807321616&sectionId=33965&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00017_197610_1517807321616
obj_root_law_sections_3_content:
  string
  line `(1) The Election Laws (Extension to Sikkim)`
  line `Ordinance, 1975 (9 of 1975), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under or by virtue of the said`
  line `Ordinance shall be deemed to have been done or taken under or by virtue of this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
