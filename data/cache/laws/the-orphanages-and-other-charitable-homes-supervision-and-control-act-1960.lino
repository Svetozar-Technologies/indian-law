obj_root_law_sections_1:
  sectionId (36112)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36112&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Orphanages and`
  line `other Charitable Homes (Supervision and Control) Act, 1960.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
  line
  line `(3) It shall come into force in a State on such date as the State Government may, by notification in`
  line `the Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1. Enforced on 2-10-1963 in the whole of Rajasthan —vide Rajasthan Government Gazette, dated 30-9-1963, Part IV(Ga), Extraordinary, p. 529,`
  line
  line `In Kerala, on 1-7-1962—vvidev Kerala Gazette, dated 3-7-1962, Part I.`
  line
  line `In Andhra Pradesh, w.e.f. 20-2-1992 vide Andhra Gazette, dated 19-2-1992, Part I, Extraordinary, p. 1.`
  line
  line `In Manipur, on 1-8-1983—vvide Manipur Gazette, dated 5-8-1983, Extraordinary, p. 1, No. 172.`
  line
  line `In Goa, w.e.f. 4-8-1994—vide Goa Government Gazette, dated 4-8-1994, p. 339, Sl. No. 1.`
  line
  line `In Karnataka, w.e.f. 1-4-1992—vide Karnataka Gazette, dated 22-11-1992, Part II, 2-C(ii), p. 1.`
  line
  line `In Maharashtra, w.r.e.f. 31-10-1991—vide Maharashtra Government Gazette, dated 2-1-1992, Part 4-A, p. 3.`
  line
  line `In Orissa, w.e.f. 2-10-1991 vide Orissa Gazette, dated 5-10-1991, Extraordinary, p. 1.`
  line
  line `In Punjab w.e.f. 28-11-1991—vide Punjab Government Gazette, dated 28-11-1991.`
  line
  line `In Tripura, w.e.f. 11-10-1991, vide Tripura Gazette, dated 11-10-1991.`
  line
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (36113)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36113&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Board" means the Board of Control established under section 5;`
  line
  line `(b) "certificate" means the certificate of recognition granted under section 15;`
  line
  line `(c) "child" means a boy or girl who has not completed the age of eighteen years;`
  line
  line `(d) "home" means an institution, whether called an orphanage, a home for neglected women`
  line `or children, a widows" home, or by any other name, maintained or intended to be maintained for`
  line `the reception, care, protection and welfare of women or children;`
  line
  line `(e) "manager" means a member of the managing committee appointed as such by the`
  line `committee under section 20;`
  line
  line `(f) "managing committee" means the committee of management referred to in section 20;`
  line
  line `(g) "recognised home" means a home in respect of which a certificate has been granted;`
  line
  line `(h) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(i) "woman" means a female who has completed the age of eighteen years.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (36114)
  sectionNo (3)
  orderNo 3
  title `Act not to apply to certain institutions.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36114&sectionno=3&orderno=3&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_3_content:
  string
  line `Nothing in this Act shall apply to--`
  line
  line `(a) any hostel or boarding house attached to, or controlled or recognised by, an educational`
  line `institution; or`
  line
  line `(b) any protective home established under the Suppression of Immoral Traffic in Women and`
  line `Girls Act, 1956 (104 of 1956); or`
  line
  line `(c) any reformatory, certified or other school, or any home or workhouse, governed by any`
  line `enactment for the time being in force.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36115)
  sectionNo (4)
  orderNo 4
  title `Effect of Act on instruments governing recognised homes.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36115&sectionno=4&orderno=4&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_4_content:
  string
  line `The provisions of this Act shall`
  line `have effect notwithstanding anything inconsistent therewith contained in any instrument governing a`
  line `recognised home.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (36116)
  sectionNo (5)
  orderNo 5
  title `Board of Control, its constitution, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36116&sectionno=5&orderno=5&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_5_content:
  string
  line `(1) The State Government may, by notification in`
  line `the Official Gazette, establish a Board of Control for the supervision and control of homes in the`
  line State.
  line
  line `(2) The Board shall consist of the following members, namely:--`
  line
  line `(a) three members of the State Legislature to be elected by the members thereof; provided that`
  line `where the State Legislature consist of two Houses, two members shall be elected by the members`
  line `of the Legislative Assembly from among themselves and one member shall be elected by the`
  line `members of the Legislative Council from among themselves;`
  line
  line `(b) five members of the managing committees in the State, to be elected by such committees`
  line `from among themselves, each such committee having one vote only for this purpose;`
  line
  line `(c) the officer in charge of social welfare work in the State, to be nominated by the State`
  line Government;
  line
  line `(d) six members to be nominated by the State Government, of whom not more than one shall`
  line `be a member of Parliament from the State and not less than three shall be women.`
  line
  line `(3) If for any reason the officer referred to in clause (c) of sub-section (2) is unable to attend any`
  line `meeting of the Board, he may depute any officer subordinate to him to attend such meeting.`
  line
  line `(4) The Chairman of the Board shall be elected by the members of the Board from among`
  line `themselves:`
  line
  line `Provided that at the time of the first constitution of the Board, one of the members of the Board`
  line `shall be nominated by the State Government to be its Chairman.`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra
  line
  line `Amendment of section 5 of 10 of 1960.--In section 5 of the Orphanages and Other Charitable Homes (Supervision and Control) Act, 1960 (10 of 1960), in its application to the State of Maharashtra (hereinafter referred to as “the Orphanages and Charitable Homes Act”), in sub-section (2), for clause (a), the following clause shall be substituted, namely:--`
  line
  line `“(a) two members of the State Legislative Assembly nominated by the Speaker of the State Legislative Assembly from amongst the members of the State Legislative Assembly and one member of the State Legislative Council nominated by the Chairman of the State Legislative Council from amongst the members of the State Legislative Council;”.`
  line
  line `[Vide Maharashtra Act 4 of 2016, s. 2].`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36117)
  sectionNo (6)
  orderNo 6
  title `Term of office and casual vacancies.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36117&sectionno=6&orderno=6&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_6_content:
  string
  line `(1) Save as otherwise provided in this section, the term`
  line `of office of a member of the Board shall be five years from the date of his election or nomination or`
  line `until his successor has been duly elected or nominated, whichever is longer:`
  line
  line `Provided that the term of office of a member elected under clause (a) or clause (b) of`
  line `sub-section (2) of section 5, or of a member of Parliament nominated under clause (d) of`
  line `sub-section (2) of section 5, shall come to an end as soon as he ceases to be a member of the House of`
  line `the State Legislature which elected him, the managing committee or Parliament, as the case may be.`
  line
  line `(2) A member may at any time resign his office by giving notice in writing to the State`
  line `Government and on such resignation being notified in the Official Gazette by that Government, the`
  line `seat of such member shall become vacant.`
  line
  line `(3) A casual vacancy in the Board shall be filled by fresh election or nomination, as the case may`
  line `be; and the term of office of a member elected or nominated to fill such vacancy shall be the`
  line `remainder of the term of the member in whose place he is elected or nominated.`
  line
  line `(4) Members of the Board shall be eligible for re-election or re-nomination.`
  line
  line `(5) No act done or proceeding taken by the Board shall be questioned on the ground merely of the`
  line `existence of any vacancy in, or defect in the constitution of, the Board.`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra
  line
  line `Amendment of section 6 of 10 of 1960.--In section 6 of the Orphanages and Charitable Homes Act, in sub-section (1), in the proviso, for the words, brackets and letters “elected under clause (a) or clause (b)” the words, brackets and letters “nominated under clause (a) or elected under clause (b)” shall be substituted.`
  line
  line `[Vide Maharashtra Act 4 of 2016, s. 3].`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (36118)
  sectionNo (7)
  orderNo 7
  title `Functions of the Board.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36118&sectionno=7&orderno=7&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_7_content:
  string
  line `(1) It shall be the duty of the Board to supervise and control`
  line `generally all matters relating to the management of homes in accordance with the provisions of this`
  line `Act; and exercise such other powers and perform such other functions as may be prescribed by or`
  line `under this Act.`
  line
  line `(2) In the performance of its functions under this Act, the Board shall be found by such directions`
  line `as the State Government may give to it.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (36119)
  sectionNo (8)
  orderNo 8
  title `Power of the Board to give directions to manager of a recognised home.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36119&sectionno=8&orderno=8&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_8_content:
  string
  line `Subject to the`
  line `directions, if any, given under sub-section (2) of section 7, the Board may, from time to time, give`
  line `such general or special directions to the manager of a recognised home as it thinks fit for the efficient`
  line `management of the home and the manager shall comply with such directions.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (36120)
  sectionNo (9)
  orderNo 9
  title `Power of inspection.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36120&sectionno=9&orderno=9&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_9_content:
  string
  line `Any member of the Board, or any officer of the Board authorised in`
  line `writing by it in this behalf, by general or special order, may enter at all reasonable times any home for`
  line `the purpose of ascertaining whether the provisions of this Act or of any rules, regulations, directions`
  line `or orders thereunder are being complied with and may require the production, for his inspection, of`
  line `any document, book, register or record kept therein and ask for any information relating to the`
  line `working of the home:`
  line
  line `Provided that no such member or officer shall enter any home or part thereof where there are`
  line `females, except in the presence of two respectable women of the locality.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (36121)
  sectionNo (10)
  orderNo 10
  title `Funds of the Board.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36121&sectionno=10&orderno=10&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_10_content:
  string
  line `The funds of the Board shall consist of--`
  line
  line `(a) contributions, subscriptions, donations or bequests made to it by any person; and`
  line
  line `(b) grants made to it by the State Government or any local or other public body.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (36122)
  sectionNo (11)
  orderNo 11
  title `Staff of the Board.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36122&sectionno=11&orderno=11&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_11_content:
  string
  line `Subject to such rules as may be made by the State Government in this`
  line `behalf, the Board may, for the purpose of enabling it to perform efficiently its functions or exercise its`
  line `powers under this Act, appoint such officers or other employees as it may think fit and determine their`
  line `functions and conditions of service.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (36123)
  sectionNo (12)
  orderNo 12
  title `Delegation of powers.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36123&sectionno=12&orderno=12&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_12_content:
  string
  line `Subject to the control of the State Government, the Board may, by`
  line `general or special order in writing and subject to such conditions and limitations, if any, as may be`
  line `specified therein, delegate to the Chairman or any other member or any officer thereof such of its`
  line `powers and functions under this Act, as it may deem necessary, for the efficient carrying on of its`
  line administration.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (36124)
  sectionNo (13)
  orderNo 13
  title `Homes not to be run without certificate.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36124&sectionno=13&orderno=13&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_13_content:
  string
  line `After the commencement of this Act, no person`
  line `shall maintain or conduct any home except under, and in accordance with, the conditions of a`
  line `certificate of recognition granted under this Act.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (36125)
  sectionNo (14)
  orderNo 14
  title `Application for certificate.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36125&sectionno=14&orderno=14&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_14_content:
  string
  line `Every person desiring to maintain or conduct a home shall`
  line `make an application for a certificate of recognition to the Board in such form and containing such`
  line `particulars as may be prescribed:`
  line
  line `Provided that a person maintaining or conducting a home at the commencement of this Act shall`
  line `be allowed a period of three months from such commencement to make an application for such`
  line certificate.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (36126)
  sectionNo (15)
  orderNo 15
  title `Grant or refusal of certificate.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36126&sectionno=15&orderno=15&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_15_content:
  string
  line `(1) On receipt of an application under section 14, the Board`
  line `after making such inquiry as it considers necessary, may, by order in writing, either grant a certificate`
  line `or refuse to grant it.`
  line
  line `(2) No order refusing to grant a certificate shall be made until an opportunity is given to the`
  line `applicant to be heard in the matter and where a certificate is refused, the grounds for such refusal shall`
  line `be communicated to the applicant in the prescribed manner.`
  line
  line `(3) No fee shall be charged for the grant of a certificate.`
  line
  line `(4) A certificate shall not be transferable.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (36127)
  sectionNo (16)
  orderNo 16
  title `Contents of certificate.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36127&sectionno=16&orderno=16&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_16_content:
  string
  line `(1) The certificate shall specify--`
  line
  line `(a) the name and location of the recognised home;`
  line
  line `(b) the name of the manager thereof;`
  line
  line `(c) the nature of the home, whether for women generally or for widows or for children`
  line `generally or for orphans or for one or more of these classes;`
  line
  line `(d) the number of inmates to be taken by the home;`
  line
  line `(e) the minimum standards regarding boarding, lodging, clothing, sanitation, health and`
  line `hygiene which, having regard to the conditions of the locality in which the recognised home is`
  line `situated and its resources, should be complied with in the home;`
  line
  line `(f) the standard of education or training to be provided for the inmates of the home, in case the`
  line `education or training of its inmates is undertaken; and`
  line
  line `(g) such other conditions and particulars as may be prescribed:`
  line
  line `Provided that there shall be deemed to be included in the certificate granted in respect of a home`
  line `for females a condition to the effect that the person incharge thereof, whether called superintendent or`
  line `by any other name, shall ordinarily be a woman.`
  line
  line `(2) The Board shall not, ordinarily, permit any recognised home to admit as inmates, persons of`
  line `different sexes, but may do so for reasons to be recorded and subject to such conditions and`
  line `limitations as may appear to it to be in the public interest.`
  line
  line `(3) Without the previous written consent of the Board, no recognised home shall--`
  line
  line `(a) change its name or location as specified in the certificate in respect of it; or`
  line
  line `(b) alter the purpose of any service specified therein.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (36128)
  sectionNo (17)
  orderNo 17
  title `Revocation of certificate.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36128&sectionno=17&orderno=17&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_17_content:
  string
  line `(1) The Board may, without prejudice to any other penalty to`
  line `which a person to whom a certificate has been granted may be liable under this Act, revoke the`
  line certificate--
  line
  line `(a) if it is satisfied that the home is not being conducted in accordance with the conditions laid`
  line `down in the certificate; or`
  line
  line `(b) the management of the home is being persistently carried on in an unsatisfactory manner`
  line `or is being carried on in a manner highly prejudicial to the moral and physical well-being of the`
  line `inmates; or`
  line
  line `(c) the home has, in the opinion of the Board, otherwise rendered itself unsuitable for that`
  line `purpose:`
  line
  line `Provided that no order of revocation shall be made under this sub-section until an opportunity`
  line `is given to the person to show cause why the certificate should not be revoked;`
  line
  line `and in every case of revocation, the grounds therefor shall be communicated to the person in the`
  line `prescribed manner.`
  line
  line `(2) Where a certificate in respect of a home is revoked under sub-section (1), such home shall`
  line `cease to function--`
  line
  line `(a) where an appeal has not been preferred under section 18 against the order of revocation,`
  line `immediately on the expiration of the period prescribed for such appeal;`
  line
  line `(b) where such appeal has been preferred, but the order of revocation is upheld, from the date`
  line `of the appellate order.`
  line
  line `(3) On any home ceasing to function under sub-section (2), the Board may direct that any woman`
  line `or child who is an inmate of such home shall be--`
  line
  line `(a) restored to the custody of her or his parent, husband or lawful guardian, as the case may`
  line `be, or`
  line
  line `(b) transferred to another recognised home, or`
  line
  line `(c) entrusted to the care of any other fit person:`
  line
  line `Provided that no woman shall be entrusted to the care of any person other than a woman.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (36129)
  sectionNo (18)
  orderNo 18
  title Appeals.
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36129&sectionno=18&orderno=18&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_18_content:
  string
  line `Any person aggrieved by an order of the Board refusing to grant a certificate or`
  line `revoking a certificate may, in such manner and within such period as may be prescribed, prefer an`
  line `appeal to the State Government or to such authority as may be specified by it against such refusal or`
  line `revocation:`
  line
  line `Provided that the State Government or the authority so specified, as the case may be, may admit`
  line `an appeal after the expiry of the period so prescribed, if it is satisfied that the applicant was prevented`
  line `by sufficient cause from preferring the appeal in time.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (36130)
  sectionNo (19)
  orderNo 19
  title `Surrender of certificate and its effect.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36130&sectionno=19&orderno=19&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_19_content:
  string
  line `(1) The manager of a home, if specially authorised`
  line `in this behalf by resolution of the managing committee, may, on giving six months' notice in writing`
  line `to the Board of his intention so to do, apply for the withdrawal of the certificate granted in respect of`
  line `that home and on the expiration of the said period from the date of notice, the certificate shall, unless`
  line `before that time the notice is withdrawn, cease to have effect; and the home shall cease to function.`
  line
  line `(2) No woman or child shall be received into any such home after the date of such notice; but`
  line `nothing in this section shall be construed to affect the obligation of the manager to comply with all`
  line `the requirements of this Act and the rules, regulations, directions and orders thereunder until the`
  line `certificate ceases to take effect under sub-section (1).`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (36131)
  sectionNo (20)
  orderNo 20
  title `Managing committee.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36131&sectionno=20&orderno=20&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_20_content:
  string
  line `(1) There shall be a managing committee in charge of the`
  line `management of every recognised home and the members of the managing committee shall appoint a`
  line `member thereof to be the manager of such home for the purposes of this Act.`
  line
  line `(2) The constitution, powers and functions of the managing committee and the term of office of`
  line `the members thereof shall be such as may be provided in the constitution pertaining to such home.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (36132)
  sectionNo (21)
  orderNo 21
  title `Duty of manager.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36132&sectionno=21&orderno=21&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_21_content:
  string
  line `It shall be the duty of the manager to comply with all the requirements of`
  line `this Act and the rules, regulations, directions and orders thereunder in respect of every woman or`
  line `child admitted into the recognised home until the woman is rehabilitated or the child completes the`
  line `age of eighteen years or until the certificate ceases to have effect.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (36133)
  sectionNo (22)
  orderNo 22
  title `Discharge of inmates of home.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36133&sectionno=22&orderno=22&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_22_content:
  string
  line `(1) Subject to the regulations, if any, made by the Board, if`
  line `the managing committee of a home is satisfied that an inmate of the home has become fit to earn his`
  line `or her livelihood or is otherwise fit to be discharged from the home, the manager may discharge such`
  line inmate.
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no female inmate of a home shall be`
  line `discharged or given in marriage or entrusted to the care of any other person unless such female has`
  line `made a declaration before the Board or an officer specified by it in this behalf that she consents to`
  line `such discharge, marriage or entrustment, as the case may be, and, if the inmate to be given in marriage`
  line `is a minor, unless the Board or officer, as the case may be, has, after recording the reasons in writing,`
  line `given its or his approval thereto.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (36134)
  sectionNo (23)
  orderNo 23
  title `Reports regarding deaths of inmates.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36134&sectionno=23&orderno=23&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_23_content:
  string
  line `The manager shall, immediately after the occurrence`
  line `of any death among the inmates of the home, send a written report thereof to the Board explaining the`
  line `cause of death to the best of his knowledge.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (36135)
  sectionNo (24)
  orderNo 24
  title Penalties.
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36135&sectionno=24&orderno=24&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_24_content:
  string
  line `Any person who fails to comply with any of the provisions of this Act or of any`
  line `rule, regulation, direction or order thereunder or any of the conditions of a certificate shall be`
  line `punishable in the case of a first offence with imprisonment which may extend to three months or with`
  line `fine which may extend to two hundred and fifty rupees or with both, and in the case of a second or`
  line `subsequent offence, with imprisonment which may extend to six months or with fine which may`
  line `extend to one thousand rupees or with both.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (36136)
  sectionNo (25)
  orderNo 25
  title `Sanction for prosecutions.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36136&sectionno=25&orderno=25&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_25_content:
  string
  line `No prosecution under this Act shall be instituted except with the`
  line `previous sanction of the District Magistrate or the Chief Presidency Magistrate, as the case may be.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (36137)
  sectionNo (26)
  orderNo 26
  title `Persons performing functions under Act to be public servants.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36137&sectionno=26&orderno=26&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_26_content:
  string
  line `The members of the`
  line `Board and every person empowered by the Board to exercise any of its powers under this Act shall be`
  line `deemed to be public servants within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (36138)
  sectionNo (27)
  orderNo 27
  title `Protection of acts done in good faith.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36138&sectionno=27&orderno=27&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_27_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against any person who performs any function under this Act for anything done or intended to be`
  line `done in good faith under this Act or any rule, regulation direction or order thereunder.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (36139)
  sectionNo (28)
  orderNo 28
  title `Power of State Government to exempt homes.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36139&sectionno=28&orderno=28&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_28_content:
  string
  line `(1) If, after consultation with the Board,`
  line `the State Government is satisfied that the circumstances in relation to any class of homes or any home`
  line `are such that it is necessary or expedient so to do, it may, by notification in the Official Gazette, and`
  line `for reasons to be specified therein, exempt, subject to such conditions, restrictions or limitations, if`
  line `any, as it may think fit to impose, such class of homes or home, as the case may be, from the`
  line `operation of all or any of the provisions of this Act or of any rule or regulation made thereunder.`
  line
  line `(2) Every notification issued under this section granting an exemption shall be reviewed in`
  line `consultation with the Board at intervals not exceeding two years, but nothing herein contained shall`
  line `affect the power of the State Government to amend, vary or rescind any such notification at any time`
  line `in consultation with the Board.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (36140)
  sectionNo (29)
  orderNo 29
  title `Power of State Government to make rules.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36140&sectionno=29&orderno=29&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_29_content:
  string
  line `(1) The State Government may, by`
  line `notification in the Official Gazette, make rules to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) all matters relating to, or in connection with, elections, to the Board under clause (b) of`
  line `sub-section (2) of section 5 and the election of the Chairman;`
  line
  line `(b) the disqualifications for membership of the Board and the procedure to be followed in`
  line `removing a member who is or becomes subject to any disqualification;`
  line
  line `(c) the funds of the Board;`
  line
  line `(d) the travelling and other allowances to be drawn by members of the Board;`
  line
  line `(e) the appointment of staff for enabling the Board to perform its functions efficiently under`
  line `this Act and their recruitment and conditions of service;`
  line
  line `(f) the calling of returns and other information by the State Government from the Board and`
  line `the managing committees;`
  line
  line `(g) the form in which an application for certificate of recognition may be made, the particulars`
  line `to be contained in such application and the form in which, and the conditions subject to which,`
  line `such certificate may be granted;`
  line
  line `(h) the maintenance of registers and accounts by the Board and the audit of its accounts;`
  line
  line `(i) any other matter which is to be, or may be, prescribed.`
  line
  line `(3) All rules made under this Act shall, as soon as may be after they are made, be laid before the`
  line `State Legislature.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (36141)
  sectionNo (30)
  orderNo 30
  title `Power of the Board to make regulations.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36141&sectionno=30&orderno=30&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_30_content:
  string
  line `(1) The Board may, with the previous approval`
  line `of the State Government, by notification in the Official Gazette, make regulations not inconsistent`
  line `with this Act and the rules made thereunder, for enabling it to perform its functions under this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations`
  line `may provide for all or any of the following matters, namely:--`
  line
  line `(a) the time and place of the meetings of the Board, the procedure to be followed in regard to`
  line `the transaction of business at such meetings and the quorum necessary for the transaction of`
  line `business at such meetings;`
  line
  line `(b) the maintenance of the minutes of meetings of the Board and the transmission of copies`
  line `thereof to the State Government;`
  line
  line `(c) the appointment of sub-committees and local committees and of persons by the Board for`
  line `the purpose of assisting it in performing its functions under this Act;`
  line
  line `(d) the supervision and control of the management of recognised homes;`
  line
  line `(e) the inspection of homes;`
  line
  line `(f) the calling of returns and other information by the Board from managing committees;`
  line
  line `(g) the reception, care, treatment, maintenance, protection, training, welfare, instruction,`
  line `control and discipline of inmates in recognised homes;`
  line
  line `(h) visits to, and communication with, inmates of recognised homes and the grant of`
  line `permission to such inmates to absent themselves for short periods;`
  line
  line `(i) the discharge of inmates from recognised homes, their transfer from one recognised home`
  line `to another and the reports to be sent by managers to the Board;`
  line
  line `(j) any other matter in respect of which provision is, in the opinion of the Board, necessary for`
  line `the efficient supervision and control of homes.`
  line
  line `(3) The State Government may, by notification in the Official Gazette, amend, vary or rescind any`
  line `regulation which it has approved; and thereupon the regulation shall have effect accordingly, but`
  line `without prejudice to the exercise of the powers of the Board under sub-section (1).`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (36142)
  sectionNo (31)
  orderNo 31
  title `Repeals and savings.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00004_196010_1517807318791&sectionId=36142&sectionno=31&orderno=31&orgactid=AC_CEN_12_13_00004_196010_1517807318791
obj_root_law_sections_31_content:
  string
  line `(1) As from the date of the coming into force in any State of this Act,`
  line `the Women's and Children's Institutions (Licensing) Act, 1956 (105 of 1956), or any other Act`
  line `corresponding to this Act in force in that State immediately before such commencement, shall stand`
  line repealed.
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken (including any direction`
  line `given, any register or rule or order made or any restriction imposed) under the said Act shall, in so far`
  line `as such thing or action is not inconsistent with the provisions of this Act, be deemed to have been`
  line `done or taken under the provisions aforesaid, as if they were in force when such thing was done or`
  line `such action was taken, and shall continue in force accordingly until superseded by anything done or`
  line `any action taken under this Act.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `अनाथालय और अन्‍य पूर्त आश्रम (पर्यवेक्षण औरनियंत्रण) अधिनियम, 1960`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/13052/3/H1960-10.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T11:31:01.346Z`
  pageCount 7
  sections obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
  obj_root_law_translations_hi_sections_3
  obj_root_law_translations_hi_sections_4
  obj_root_law_translations_hi_sections_5
  obj_root_law_translations_hi_sections_6
  obj_root_law_translations_hi_sections_7
obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `अनाथालय और अन्य पूर्त आश्रम ( पयतवेक्षण और`
  line `ननयंत्रण ) अनिननयम, 1960`
  line `(1960 का अनिननयम संखयां क 10 )`
  line `[9 अप्रैल, 1960]`
  line `अनाथालयों, उपेनक्षर् न् त्र यों या बालकों के नलए आश्रमों और ऐसी`
  line `ही अन्य सं्था ओं के पयतवेक्षण और ननयंत्रण और उनसे`
  line `सम्ब नन्ि र् नवषयों का उपबन्ि`
  line `करने के नलए`
  line अनिननयम
  line `भारर् गणराज्य के ग् या रहवें वषत में संसद् द्व ारा ननम्न नलनिर् रू प में यह अनिननय नमर् हो: ––`
  line `अध्या य 1 प्र`
  line `ारनम्भ क`
  line `1. संनक्षप् र् नाम, नव् र्ा र और प्र ारम्भ –– (1) इस अनिननयम का संनक्षप् र् नाम अनाथालय और अन्य पूर्त आश्रम ( पयतवे क्ष ण और`
  line `ननयंत्रण ) अनिननयम, 1960 है।`
  line `(2) इसका नव् र्ा र जम् मू - कश्मी र राज्य के नसवाय  सम्पू णत भारर् पर है।`
  line `(3) यह ककसी राज्य में उस र् ारीि को प्र वृत्त होगा नजसे राज्य सरकार, राजपत्र में अनिसूचना द्व ारा, ननयर् करे।`
  line `2. पररभाषाएं –– इस अनिननयम में, जब र् क कक सन्द भत से अन्य था अपेनक्षर् न हो, ––`
  line `( क ) “ बोर्त ” से िारा 5 के अिीन ् था नपर् ननयंत्रण बोर्त अनभप्रेर् है;`
  line `( ि ) “ प्र माणपत्र ” से िारा 15 के अिीन अनुदत्त मान्य र् ा प्र माणपत्र अनभप्रेर् है;`
  line `( ग ) “ बालक ” से ऐसा लड़का या लड़की अनभप्रेर् है नजसने अठारह वषत की आयु पूरी नहीं की है;`
  line `( घ ) “ आश्रम ” से वह सं्था अनभप्रेर् है जो न् त्र यों या बालकों के ग्र हण, देिभाल, संरक्षण और कल्या ण के नलए`
  line `चलाई जार्ी है या इनके नलए नजसका चलाया जाना आशनयर् है, चाहे वह अनाथालय, उपेनक्षर् न् त्र यों या बालकों के नलए`
  line `आश्रम, नविवा आश्रम या ककसी अन्य नाम से ज्ञ ार् हो;`
  line `( ङ ) “ प्र बन्ि क ” से प्र बन्ि सनमनर् का कोई सद्य अनभप्रेर् है जो िारा 20 के अिीन सनमनर् द्व ारा इस रू प में`
  line `ननयुक् र् ककया गया है;`
  line `( च ) “ प्र बन् ध् ाा सनमनर् ” से िारा 20 में ननर्दतष्ट प्र बन्ि सनमनर् अनभप्रेर् है;`
  line `( छ ) “ मान्य र् ाप्रा प् र् आश्रम ” से ऐसा आश्रम अनभप्रेर् है नजसके संबंि में प्र माणपत्र अनुदत्त कर कदया गया है;`
  line `( ज ) “ नवनहर् ” से इस अनिननयम के अिीन बनाए गए ननयमों द्व ारा नवनहर् अनभप्रेर् है;`
  line `( झ ) “ ् त्र ी ” से ऐसी मनहला अनभप्रेर् है नजसने अठारह वषत की आयु पूरी कर ली है।`
  line `3. अनिननय म का कनर्पय सं्था ओं को लागू न होना –– इस अनिननयम की कोई भी बार् ननम्न नलनिर् को लागू`
  line `नहीं होगी: ––`
  line `( क ) ककसी शैक्षनणक सं्था से संबद्ध या उसके द्व ारा ननयनन् त्र र् या मान्य र् ाप्राप् र् छात्रावास या बोर्र्िंग हाऊस; या`
  line `( ि ) ् त्र ी र् था लड़की अनै नर्क व् या पार दमन अनिननयम, 1956 (1956 का 104) के अिीन ् था नपर् संरक्षा गृह; या`
  line `( ग ) र्त् स मय प्र वृत्त ककसी अनिननयनमनर् द्व ारा शानसर् सुिारालय, प्र मानणर् या अन्य ् कू ल या आश्रम या कायतगृह।`
  line `4. अनिननयम का मान्य र् ाप्राप् र् आश्रमों को शानसर् करने वाली नलिर्ों पर प्र भाव –– इस अनिननयम के उपबन् ध् ाा ककसी`
  line `मान्य र् ाप्राप् र् आश्रम को शानसर् करने वाली ककसी भी नलिर् में उससे असंगर् ककसी बार् के होर्े हु ए भी प्र भावी होंगे।`
  line ` इस अनिननयम को जम्मू - कश्मीर संघ राज्यक्षेत्र और लद्दाि संघ राज्यक्षेत्र में अनिसूचना सं. सा. का. 3912 (अ), र् ारीि, 30 अक्टूबर, 2019 से लागू ककया गया।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line 2
  line `अध्या य 2`
  line `ननयंत्रण बोर्त और उसकी शनक् र् यां और कृत्य`
  line `5. ननयंत्रण बोर्त, उसका गठन आकद –– (1) राज्य सरका र, राजपत्र में अनिसूचना द्व ारा, राज्य में आश्रमों के पयतवेक्षण और`
  line `ननयंत्रण के नलए ननयंत्रण बोर्त ् था नपर् कर सकर्ी है।`
  line `(2) बोर्त का गठन ननम्न नलनिर् सद्यों से होगा, अथातर््: ––`
  line `( क ) राज्य नविान - मंर्ल के र् ीन सद्य नजनका ननवातचन उसके सद्यों द्व ारा हो गा; परन् र्ु जहां राज्य नविान - मंर्ल`
  line `दो सदनों से नमलकर बनर्ा है वहां नविान - सभा के सद्य अपने में से दो सद्यों को ननवातनचर् करेंगे और नविान पररषद् के`
  line `सद्य अपने में से एक सद्य ननवातनचर् करेंगे;`
  line `(ि) राज्य में प्र बन्ि सनमनर्यों के पांच संद्य, नजनका नन वातचन ऐसी सनमनर्यों द्व ारा अपने में से ही होगा, हर एक`
  line `ऐसी सनमनर् का इस प्र योजन के नलए एक मर् होगा;`
  line `( ग ) राज्य में समाज कल्या ण कायत का भारसािक अनिकारी, जो राज्य सरकार द्व ारा नामननर्दतष्ट ककया जाएगा;`
  line `( घ ) राज्य सरकार द्व ारा नामननर्दतष्ट छह सद्य नजन में से एक से अनिक व् य नक् र् उस राज्य से संसद् का सद्य नहीं`
  line `होगा और कम से कम र् ीन न् त्र यां होंगी।`
  line `(3) यकद उपिारा (2) के िण् र् ( ग ) में ननर्दतष्ट अनिकारी बोर्त के अनिवेशन में ककसी कारणवश उपन्थ र् होने में असमथत है र् ो`
  line `वह अपने अिीन्थ ककसी अनिकारी को ऐसे अनिवेशन में उपन्थ र् होने के नलए प्र नर्ननयुक् र् कर सकेगा।`
  line `(4) बोर्त का अध्य क्ष बोर्त के सद्यों द्व ारा अपने में से ननवातनचर् ककया जाएगा:`
  line `परन् र्ु राज्य सरकार बोर्त के प्र थम गठन के समय बोर्त के एक सद्य को उसका अध्य क्ष होने के नलए नामननर्दतष्ट करेगी।`
  line `6. पदावनि और आकन्म क ररनक् र् यां –– (1) इस िारा में जैसा उपबनन्ि र् है उसके नसवाय, बोर्त के सद्य की पदावनि उसके`
  line `ननवातचन या नामननदेशन की र् ारीि से पांच वषत या र् ब र् क होगी जब उसका उत्तरवर्ी सम्य क् रू प से ननवातनचर् या नामननदेनशर् कर`
  line `कदया जाए, इन में से जो भी अनिक हो:`
  line `परन् र्ु िारा 5 की उपिारा (2) के िण् र् ( क ) या िण् र् ( ि ) के अिीन ननवातनचर् सद्य या िारा 5 की उपिारा (2) के िण् र्`
  line `( घ ) के अिीन नामननर्दतष्ट संसद् सद्य की पदावनि जैसे ही वह, यथान्थ नर्, उस राज्य नविान - मंर्ल के सदन का, नजसने उसको`
  line `नन वातनचर् ककया है, उस प्र बन्ि सनमनर् या संसद् का सद्य नहीं रहर्ा है, वैसे ही समाप् र् हो जाएगी।`
  line `(2) कोई सद्य ककसी भी समय राज्य सरकार को नलनिर् सूचना देकर अपना पद त् या ग कर सकर्ा है और राज्य सरकार द्व`
  line `ारा राजपत्र में ऐसा त् या गपत्र अनिसूनचर् ककए जाने पर, ऐ से सद्य का ् था न ररक् र् हो जाएगा।`
  line `(3) बोर्त में आकन्म क ररनक् र् को, यथान्थ नर्, नव नन वातचन या नामननदेशन द्व ारा भ रा जाएगा; और ऐसी ररनक् र् को भरने के`
  line `नलए ननवातनचर् या नामननर्दतष्ट सद्य की पदावनि उस सद्य की शेष अवनि होगी नजसके ् था न पर उसे ननवात नचर् या नामाननर्दतष्ट`
  line `ककया गया है।`
  line `(4) बोर्त के सद्य पुन: ननवातचन या पुन: नामननदेशन के पात्र होंगे।`
  line `(5) बोर्त द्व ारा ककया गया कोई भी कायत या की गई कायतवाही केवल बोर्त में ककसी ररनक् र् के या उसके गठन में त्रु रट नवद्यमान`
  line `होने के आिार पर प्रश् न गर् नहीं की जाएगी।`
  line `7. बोर्त के कृत् य –– (1) बोर्त का कर्तव्य होगा कक वह इस अनिननयम के उपबन्िों के अनुसार आश्रमों के प्र बंि से संबंनिर् सभी`
  line `नवषयों का सािारणर्: पयतवेक्ष ााण और ननयंत्रण करे, और ऐसी अन्य शनक् र् यों का प्र योग करे र् था ऐसे अन्य कृत् य करे जो इस`
  line `अनिननयम द्व ारा या उसके अिीन नवनहर् ककए जाएं।`
  line `(2) इस अनिननयम के अिीन अपने कृत् यों का पालन करर्े समय, बोर्त ऐसे ननदेशों से आबद्ध होगा जो राज्य सरकार`
  line `उसको दे।`
  line `8. मान्य र् ाप्राप् र् आश्रम के प्र बन्ि क को ननदेश देने की बोर्त की शनक् र् –– िारा 7 की उपिारा (2) के अिीन कदए गए ननदेशों`
  line `के, यकद कोई हों अिीन रहर्े हु ए बोर्त समय - समय पर मान्य र् ाप्रा प् र् आश्रम के प्र बन्ि क को ऐसे सािारण या नवशेष ननदेश दे सकर्ा है,`
  line `जो वह आश्रम के दक्षर्ापूणत प्र बन्ि के नलए ठीक समझे, और प्र बन्ि क ऐसे ननदेशों का पालन करेगा।`
  line `9. ननरीक्षण की शनक् र् –– बोर्त का कोई सद्य इस नननमत्त सािारण या नवशेष आदेश द्व ारा नलनिर् रू प से प्र ानिकृर् बोर्त का`
  line `कोई अनिकारी ककसी भी आश्रम में यह अनभनननश्च र् करने के प्र योजन के नलए कक क् या इ स अनिननयम के उपबन्िों या र् द् िीन ककन्हीं`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line 3
  line `ननयमों, नवननयमों, ननदेशों या आदेशों का पालन ककया जा रहा है, युनक् र् युक् र् समय पर प्र वेश कर सकर्ा है और उसमें रिी ककसी भी`
  line `द् र्ा वेज, बही, रनज्ट र या अनभलेि को अपने ननरीक्ष ााण के नलए पेश ककए जाने की अपेक्षा कर सकर्ा है और आश्रम के कायतकरण से`
  line `संबंनिर् ककसी भी जानकारी की मांग क र सकर्ा है:`
  line `परन् र्ु ऐसा कोई भी सद्य या अनिकारी ककसी ऐसे आश्रम या उसके ककसी भाग में जहां मनहलाएं हैं, उस पररक्ष ाोत्र की दो प्र`
  line `नर्नष्ठ र् न् त्र यों की उपन्थ नर् के नबना प्र वेश नहीं करेगा।`
  line `10. बोर्त की नननियां –– बोर्त की नननियां, ––`
  line `( क ) ककसी व् य नक् र् द्व ा रा उसको कदए गए अनभदाय, चन्दे, संदान या की गई वसीयर्; और`
  line `( ि ) राज्य सरकार या ककसी ् था नीय या अन्य लोक ननकाय द्व ारा उसको कदए गए अनुदान,`
  line `से नमलकर बनेंगी।`
  line `11. बोर्त के कमतचाररवृन्द –– ऐसे ननयमों के अिीन रहर्े हु ए, जो राज्य सरकार द्व ारा इस नननमत्त बनए जाएं, बोर्त ् व र्: को`
  line `इस अनिननयम के अिीन अपने कृत् यों का दक्षर्ापूणत पालन करने या शनक् र् यों का प्र योग करने के नलए समथत बनाने के प्र योजन के नलए,`
  line `ऐसे अनिकारी या अन्य कमतचाररयों को, नजन्हें वह ठीक समझे, ननयुक् र् कर सकर्ा है और उनके कृत् य और सेवा की शर्ें अविाररर् कर`
  line `सकर्ा है।`
  line `12. शनक् र् यों का प्रत् या योजन –– राज्य सरकार के ननयन् त्र ण के अिीन रहर्े हु ए, बोर्त सािारण या नवशेष नलनिर् आदेश द्व ारा,`
  line `और ऐसी शर्ों और मयातदाओं के, यकद कोई हों, अिीन रहर्े हु ए, जो उसमें नवननर्दतष्ट की जाएं, अध्य क्ष या उसके ककसी अन्य सद्य या`
  line `ककसी अनिकारी को इस अनिननयम के अिीन अपनी ऐसी शनक् र् यां या कृत् य, जो वह अपने प्र शासन के दक्षर्ापूणत संचालन के नलए`
  line `आवश्य क समझे, प्रत् या योनजर् कर सकर्ा है।`
  line `अध्या य 3`
  line `आश्रमों को मान्य र् ा`
  line `13. प्र माणपत्र के नबना आश्रमों का न चलाया जाना –– इस अनिननय म के प्र ारम्भ ाा के पश्चा र््, इस अनिननयम के अिीन`
  line `अनुदत्त मान्य र् ा प्र माणपत्र की शर्ों के अिीन और उनके अनुसार के नसवाय, कोई व् य नक् र् कोई आश्रम नहीं रिेगा या संचानलर् करेगा।`
  line `14. प्र माणपत्र के नलए आवेदन –– प्रत् ये क व् य नक् र्, जो आश्रम रिना या संचानलर् करना चाहर्ा है, बोर्त को मान्य र् ा प्र माणपत्र`
  line `के नलए ऐसे प्ररू प में और ऐसी नवनशनष्ट यां अन् र् र् वतष्ट करर्े हु ए, जो नवनहर् की जाएं, आवेदन करेगा:`
  line `परन् र्ु इस अनिननयम के प्र ारम्भ पर आश्रम रिने या संचानलर् करने वाले व् य नक् र् को, ऐसे प्र माणपत्र के नलए आवदेन करने के`
  line `नलए ऐसे प्र ारम्भ से र् ीन मास की कालावनि अनुज्ञार् की जाएगी।`
  line `15. प्र माणपत्र का अनुदान या इंकार –– (1) िारा 1 4 के अिीन, आवेदन की प्र ानप् र् पर, बोर्त ऐसी जांच करने के पश्चा र्् जैसी`
  line `वह आवश्य क समझे, नलनिर् आदेश द्व ारा, या र् ो प्र माणपत्र अनुदत्त कर देगा या अनुदान करने से इंकार कर देगा।`
  line `(2) प्र माणपत्र के अनुदान से इन्का र करने का आदेश र् ब र् क नहीं ककया जाएगा जब र् क कक मामले में आवेदक को सुनवाई`
  line `का अवसर न कदया गया हो और जहां प्र माणपत्र के अनुदान से इन्का र ककया गया है, वहां ऐसे इन्का र करने के आिार आवेदक को`
  line `नवनहर् रीनर् में संसूनचर् ककए जाएंगे।`
  line `(3) प्र माणपत्र के अनुदान के नलए कोई शुल्क प्र भाररर् नहीं ककया जाएगा।`
  line `(4) प्र माणपत्र अंर्रणीय नहीं होगा।`
  line `16. प्र माणपत्र की अन् र् वत् र्ु –– (1) प्र माणपत्र में ननम्न नलनिर् नवननर्दतष्ट होंगे: ––`
  line `( क ) मान्य र् ाप्राप् र् आश्रम का नाम और उसका अव्था न;`
  line `( ि ) उसके प्र बन्ि क का नाम;`
  line `( ग ) आश्रम की प्र कृनर्, क् या वह सािारणर्: न् त्र यों के नलए या नविवाओं के नलए या सािारणर्: बालकों के नलए`
  line `या अनाथों के नलए या इनमें से एक या अनिक वगों के नलए है;`
  line `( घ ) आश्रम द्व ारा नलए जाने वाले वानसयों की संखया;`
  line `( ङ ) भोजन, वाससुनविा, कपड़े, ् व च् छ र् ा, ् वा ् ् य और ् व ् थ वृत्त के नवषय में न् यू नर्म मानक नजनका उस पररक्षेत्र`
  line `की, नजसमें मान्य र् ाप्राप् र् आश्रम न्थ र् है, दशाओं का और सािनों का ध् या न रिर्े हु ए; उस आश्रम में अनुपालन ककया जाना`
  line चानहए;
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
  orderNo 4
  title `Page 4`
  content obj_root_law_translations_hi_sections_4_content
  footnotes obj_root_law_translations_hi_sections_4_footnotes
