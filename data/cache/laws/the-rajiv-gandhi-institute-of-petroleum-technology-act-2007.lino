obj_root_law_sections_1:
  sectionId (11054)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11054&sectionno=1&orderno=1&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Rajiv Gandhi Institute of`
  line `Petroleum Technology Act, 2007.`
  line
  line `(2) It shall come into force on such date^1 as the Central Government may, by notification in the`
  line `Official Gazette, appoint, and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st June, 2008, vide notification No. S.O. 1244(E), dated 28th May, 2008, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (11055)
  sectionNo (2)
  orderNo 2
  title `Declaration of Rajiv Gandhi Institute of Petroleum Technology as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11055&sectionno=2&orderno=2&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the institution known as the Rajiv Gandhi Institute of Petroleum`
  line `Technology, Jais, District--Rae Bareli, Uttar Pradesh are such as to make the institution one of national`
  line `importance, it is hereby declared that the institution known as the Rajiv Gandhi Institute of Petroleum`
  line `Technology is an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (11056)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11056&sectionno=3&orderno=3&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means the date appointed under sub-section (2) of section (1) for coming into`
  line `force of this Act;`
  line
  line `(b) "Board" means the Board of Governors of the Institute constituted under sub-section (1) of`
  line `section 5;`
  line
  line `(c) "Chairperson" means the Chairperson of the General Council;`
  line
  line `(d) "Director" means the Director of the Institute appointed under section 20;`
  line
  line `(e) "fund" means the fund of the Institute to be maintained under section 24;`
  line
  line `(f) "General Council" means the General Council established under sub-section (1) of section 15;`
  line
  line `(g) "Institute" means the Rajiv Gandhi Institute of Petroleum Technology incorporated under`
  line `section 4;`
  line
  line `(h) "President" means the President of the Board appointed under clause (a) of sub-section (1) of`
  line `section 5;`
  line
  line `(i) "Registrar" means the Registrar of the Institute referred to in section 21;`
  line
  line `(j) "Senate" means the Senate of the Institute referred to in section 17;`
  line
  line `(k) "Society" means the Rajiv Gandhi Institute of Petroleum Technology Society, Jais`
  line `District--Rae Bareli, Uttar Pradesh registered under the Societies Registration Act, 1860`
  line `(21 of 1860); and`
  line
  line `(l) "Statutes" and "Ordinances" mean, respectively, the Statutes and Ordinances of the Institute`
  line `made under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (11057)
  sectionNo (4)
  orderNo 4
  title `Incorporation of Institute.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11057&sectionno=4&orderno=4&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_4_content:
  string
  line `The Rajiv Gandhi Institute of Petroleum Technology shall be a body`
  line `corporate having perpetual succession and a common seal with power, subject to the provisions of this`
  line `Act, to acquire, hold and dispose of property and to contract, and shall, by that name, sue and be sued.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (11058)
  sectionNo (5)
  orderNo 5
  title `Constitution of Board of Governors.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11058&sectionno=5&orderno=5&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_5_content:
  string
  line `(1) With effect from such date as the Central Government`
  line `may, by notification in the Official Gazette, appoint, there shall be constituted by the Central Government`
  line `for the purposes of this Act, a Board to be known as the Board of Governors consisting of the following`
  line `members, namely:--`
  line
  line `(a) the President to be appointed by the Central Government in such manner as may be provided`
  line `by the Statutes:`
  line
  line `Provided that the first President shall be appointed by the Central Government on such terms and`
  line `conditions as it deems fit, for a period not exceeding six months from the date the first Statutes comes`
  line `into force.`
  line
  line `(b) the Director of the Institute, ex officio;`
  line
  line `(c) two persons from the Board of Directors of the promoting companies to be nominated by the`
  line `Central Government.`
  line
  line `Explanation.-- For the purposes of this clause, promoting companies mean those companies`
  line `contributing to the endowment fund referred to in section 25;`
  line
  line `(d) one Professor of the Indian Institute of Technology, Kanpur to be nominated by the Director`
  line `of that Institute;`
  line
  line `(e) five eminent experts in the field of petroleum technology covering the entire hydrocarbon`
  line `value chain having specialised knowledge or operational experience in respect of education, research,`
  line `engineering and technology to be nominated by the General Council, in consultation with the Director`
  line `of the Institute;`
  line
  line `(f) two Professors of the Institute to be nominated by the Senate of the Institute; and`
  line
  line `(g) one representative of the graduates of the Institute to be nominated by the Executive`
  line `Committee of the Alumni Association.`
  line
  line `(2) The Registrar of the Institute shall act as the Secretary of the Board.`
  line
  line `(3) The Board shall ordinarily meet four times during a calendar year.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (11059)
  sectionNo (6)
  orderNo 6
  title `Term of office of, vacancies among, and allowances payable to, members of Board.`
  content obj_root_law_sections_6_content
  footnotes '`````````````````'
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11059&sectionno=6&orderno=6&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_6_content:
  string
  line `(1) Save`
  line `as otherwise provided in this section, the term of office of the President or any other member of the`
  line `Board, other than ex officio members shall be three years from the date of his appointment or nomination`
  line thereto.
  line
  line `(2) An ex officio member shall cease to be a member of the Board as soon as he vacates the office by`
  line `virtue of which he is a member of the Board.`
  line
  line `(3) The term of a member nominated to fill a casual vacancy shall continue for the remainder of the`
  line `term of the member in whose place he has been nominated.`
  line
  line `(4) Notwithstanding anything contained in this section, an outgoing member shall, unless the Central`
  line `Government otherwise directs, continue in office until another person is nominated as a member in his`
  line place.
  line
  line `(5) The members of the Board shall be entitled to such allowances, if any, from the Institute, as may`
  line `be provided for in the Statutes, but no member other than the member referred to in clause (f) of section 5`
  line `shall be entitled to any salary.`
obj_root_law_sections_7:
  sectionId (11060)
  sectionNo (7)
  orderNo 7
  title `Vesting of properties.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11060&sectionno=7&orderno=7&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_7_content:
  string
  line `On and from the appointed day and subject to the other provisions of this`
  line `Act, all properties which had vested in the Society immediately before that day, shall, on and from that`
  line `day, vest in the Institute.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (11061)
  sectionNo (8)
  orderNo 8
  title `Effect of incorporation of Institute.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11061&sectionno=8&orderno=8&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_8_content:
  string
  line `On and from the appointed day,--`
  line
  line `(a) any reference to the Society in any contract or other instrument shall be deemed as a reference`
  line `to the Institute;`
  line
  line `(b) all the rights and liabilities of the Society shall be transferred to, and be the rights and`
  line `liabilities of, the Institute; and`
  line
  line `(c) every person employed by the Society immediately before the appointed day shall hold office`
  line `or service in the Institute by the same tenure, at the same remuneration and upon the same terms and`
  line `conditions and with the same rights and privileges as to pension, leave, gratuity, provident fund and`
  line `other matters as he would have held the same if this Act had not been passed, and shall continue to be`
  line `so unless and until his employment is terminated or until such tenure, remuneration and terms and`
  line `conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the Institute in accordance with the terms of the contract with the employee or, if no`
  line `provision is made therein in this behalf, on payment to him by the Institute of compensation`
  line `equivalent to three months' remuneration in the case of permanent employees and one months`
  line `remuneration in the case of other employees.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (11062)
  sectionNo (9)
  orderNo 9
  title `Functions of Institute.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11062&sectionno=9&orderno=9&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_9_content:
  string
  line `The Institute shall perform the following functions, namely:--`
  line
  line `(i) nurture and promote quality and excellence in education and research in the area of petroleum`
  line `and hydrocarbons;`
  line
  line `(ii) provide for programmes and courses of instruction and research leading to the award of the`
  line `Bachelors, Masters and Doctoral degrees in engineering and technology, management, sciences and`
  line `arts in the area of petroleum and hydrocarbons;`
  line
  line `(iii) grant, subject to such conditions as the Institute may determine, degrees, diplomas,`
  line `certificates or other academic distinctions or titles at various academic levels to candidates who have`
  line `attained the prescribed standard of proficiency as judged on the basis of examination or on any other`
  line `basis of testing and evaluation and to withdraw any such degrees, diplomas, certificates or other`
  line `academic distinctions or titles for good and sufficient reasons;`
  line
  line `(iv) confer honorary degrees or other distinctions and to institute and award fellowships,`
  line `scholarships, exhibitions, prizes and medals;`
  line
  line `(v) lay down standards of admission to the Institute through an examination or any other method`
  line `of testing and evaluation;`
  line
  line `(vi) fix, demand and receive fees and other charges;`
  line
  line `(vii) manage the content, quality, design and continuous evaluation of its academic and research`
  line `programmes in a manner that earns accreditation of an international stature;`
  line
  line `(viii) promote research and development for the benefit of oil, gas and petrochemical industry`
  line `through the integration of teaching and research;`
  line
  line `(ix) foster close educational and research interaction through networking with national, regional`
  line `and international players in the oil, gas and petrochemical industry;`
  line
  line `(x) co-operate with educational and research institutions in any part of the world having objects`
  line `wholly or partly similar to those of the Institute by exchange of teachers and scholars, conduct of joint`
  line `research, undertaking sponsored research and consultancy projects, etc;`
  line
  line `(xi) organise national and international symposia, seminars and conferences in the area of`
  line `petroleum and hydrocarbons;`
  line
  line `(xii) establish, maintain and manage halls, residences and hostels for students;`
  line
  line `(xiii) create academic, administrative, technical and other posts and to make appointments`
  line thereto;
  line
  line `(xiv) lay down conditions of service including a code of conduct for teachers and other categories`
  line `of employees;`
  line
  line `(xv) supervise, control and regulate the discipline of all categories of employees of the Institute`
  line `and to make arrangements for promoting their health and general welfare;`
  line
  line `(xvi) supervise and regulate the discipline of students and to make arrangements for promoting`
  line `their health, general welfare and cultural and corporate life;`
  line
  line `(xvii) frame Statutes and Ordinances and to alter, modify or rescind the same;`
  line
  line `(xviii) deal with any property belonging to or vested in the Institute in such manner as the`
  line `Institute may deem fit for advancing its objects;`
  line
  line `(xix) receive gifts, grants, donations or benefactions from the Central and State Governments and`
  line `to receive bequests, donations, grants and transfers of movable or immovable properties from`
  line `testators, donors, transferors, alumni, industry or any other person;`
  line
  line `(xx) borrow money for the purposes of the Institute with or without security of the property of the`
  line Institute;
  line
  line `(xxi) integrate new technology in the classroom to encourage student-centric learning strategies`
  line `and the development of an attitude for learning;`
  line
  line `(xxii) develop and maintain an information resource centre of print and non-print knowledge`
  line `resources in the field of petroleum sector covering the entire hydrocarbon value chain as well as other`
  line `related areas of science and technology;`
  line
  line `(xxiii) provide for further education to the working professionals and other employees of the`
  line `Institute in the advanced areas of technology relating to oil, gas and complete hydrocarbon value`
  line `chain; and`
  line
  line `(xxiv) do all things, not specifically covered above, as may be necessary, incidental or conducive`
  line `to the attainment of all or any of the objects of the Institute.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (11063)
  sectionNo (10)
  orderNo 10
  title `Powers of Board.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11063&sectionno=10&orderno=10&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_10_content:
  string
  line `(1) Subject to the provisions of this Act, the Board shall be responsible for`
  line `the general superintendence, direction and control of the affairs of the Institute and shall exercise all the`
  line `powers not otherwise provided for by this Act, the Statutes and the Ordinances, and shall have the power`
  line `to review the acts of the Senate.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Board shall--`
  line
  line `(a) take decisions on questions of policy relating to the administration and working of the`
  line Institute;
  line
  line `(b) lay down policy regarding the duration of the courses, nomenclature of the degrees and other`
  line `distinctions to be conferred by the Institute;`
  line
  line `(c) institute courses of study and to lay down standards of proficiency and other academic`
  line `distinctions in respect of the courses offered by the Institute;`
  line
  line `(d) lay down policy regarding the cadre structure, qualification, the method of recruitment and`
  line `conditions of service of the teaching and research faculty as well as other employees of the Institute;`
  line
  line `(e) guide resource mobilisation of the Institute and to lay down policies for investment;`
  line
  line `(f) consider and approve proposals for taking loans for purposes of the Institute with or without`
  line `security of the property of the Institute;`
  line
  line `(g) frame Statutes and to alter, modify or rescind the same;`
  line
  line `(h) consider and pass resolutions on the annual report, the annual accounts and the budget`
  line `estimates of the Institute for the next financial year as it thinks fit together with a statement of its`
  line `development plans; and`
  line
  line `(i) do all such things as may be necessary, incidental or conducive to the attainment of all or any`
  line `of the aforesaid powers.`
  line
  line `(3) The Board shall have the power to appoint such committees as it considers necessary for the`
  line `exercise of its powers and the performance of its duties under this Act.`
  line
  line `(4) The Board shall have the power to establish campus and academic centres at any place within or`
  line `outside India:`
  line
  line `Provided that no campus or academic centre shall be established outside India without prior approval`
  line `of the Central Government.`
  line
  line `(5) Notwithstanding anything contained in section 4, the Board shall not dispose of in any manner,`
  line `any immovable property of the Institute without prior approval of the Central Government.`
  line
  line `(6) The Board may, through a specific resolution to this effect, delegate any of its powers and duties`
  line `to the President, Director, any officer or any authority of the Institute subject to reserving the right to`
  line `review the action that may be taken under such delegated authority.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (11064)
  sectionNo (11)
  orderNo 11
  title `Institute to be open to all races, creeds and classes.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11064&sectionno=11&orderno=11&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_11_content:
  string
  line `(1) The Institute shall be open to persons`
  line `of either sex and of whatever race, creed, caste or class, and no test or condition shall be imposed as to`
  line `religious belief or profession in admitting students, appointing teachers or employees or in any other`
  line `connection whatsoever.`
  line
  line `(2) No bequest, donation or transfer of any property shall be accepted by the Institute which in the`
  line `opinion of the Board involves conditions or obligations opposed to the spirit and object of this section.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (11065)
  sectionNo (12)
  orderNo 12
  title `Teaching at the Institute.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11065&sectionno=12&orderno=12&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_12_content:
  string
  line `All teaching and other academic activities at the Institute shall be`
  line `conducted by or in the name of the Institute in accordance with the Statutes and the Ordinances made in`
  line `this behalf.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (11066)
  sectionNo (13)
  orderNo 13
  title Visitor.
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11066&sectionno=13&orderno=13&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_13_content:
  string
  line `(1) The President of India shall be the Visitor of the Institute.`
  line
  line `(2) The Visitor may appoint one or more persons to review the work and progress of the Institute and`
  line `to hold inquiries into the affairs thereof and to report thereon in such manner as the Visitor may direct.`
  line
  line `(3) Upon receipt of any such report, the Visitor may take such action and issue such directions as he`
  line `considers necessary in respect of any of the matters dealt with in the report and the Institute shall be`
  line `bound to comply with such directions.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (11067)
  sectionNo (14)
  orderNo 14
  title `Authorities of Institute.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11067&sectionno=14&orderno=14&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_14_content:
  string
  line `The following shall be the authorities of the Institute, namely:--`
  line
  line `(a) the General Council;`
  line
  line `(b) the Board of Governors;`
  line
  line `(c) the Senate; and`
  line
  line `(d) such other authorities as may be declared by the Statutes to be the authorities of the Institute.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (11068)
  sectionNo (15)
  orderNo 15
  title `Establishment of General Council.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11068&sectionno=15&orderno=15&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_15_content:
  string
  line `(1) With effect from such date as the Central Government`
  line `may, by notification in the Official Gazette, appoint, there shall be established, for the purposes of this`
  line `Act, a body to be known as the General Council.`
  line
  line `(2) The General Council shall consist of the following members, namely:--`
  line
  line `(a) the Secretary, Ministry of Petroleum and Natural Gas in the Central Government, ex officio,`
  line `who shall be the Chairperson;`
  line
  line `(b) the Chairman, Indian Oil Corporation Limited, ex officio;`
  line
  line `(c) the Chairman and Managing Director, Hindustan Petroleum Corporation Limited, ex officio;`
  line
  line `(d) the Chairman and Managing Director, Bharat Petroleum Corporation Limited, ex officio;`
  line
  line `(e) the Chairman and Managing Director, Oil and Natural Gas Corporation, ex officio;`
  line
  line `(f) the Chairman and Managing Director, Gas Authority of India Limited, ex officio;`
  line
  line `(g) the Chairman and Managing Director, Oil India Limited, ex officio;`
  line
  line `(h) the Director General of Hydrocarbons, ex officio;`
  line
  line `(i) the Principal Advisor (Energy), Planning Commission, ex officio;`
  line
  line `(j) the Executive Director, Oil Industry Safety Directorate, ex officio;`
  line
  line `(k) the Director, Indian Institute of Technology, Kanpur, ex officio;`
  line
  line `(l) the Director, University Institute of Chemical Technology, Mumbai University, ex officio;`
  line
  line `(m) the Secretary, Oil Industry Development Board, ex officio;`
  line
  line `(n) the President of the Board, ex officio;`
  line
  line `(o) the Director of the Institute, ex officio; and`
  line
  line `(p) persons, not less than two but not exceeding four, representing the private entities in the field`
  line `of petroleum sector operating in the country, to be nominated by the Chairperson.`
  line
  line `(3) The Registrar of the Institute shall be the ex officio Secretary of the General Council.`
  line
  line `(4) The Chairperson shall have the power to invite any person who is not a member of the General`
  line `Council to attend its meeting but such invitee shall not be entitled to vote.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (11069)
  sectionNo (16)
  orderNo 16
  title `Powers and functions of General Council.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11069&sectionno=16&orderno=16&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_16_content:
  string
  line `Subject to the provisions of this Act, the General`
  line `Council shall have the following powers and functions, namely:--`
  line
  line `(a) review from time to time the broad policies and programmes of the institute and to suggest`
  line `measures for the improvement and development thereof;`
  line
  line `(b) consider the annual statement of accounts including a balance-sheet together with the audit`
  line `report thereto and the observations of the Board of Governors thereon and to suggest improvements in`
  line `fiscal management of the Institute;`
  line
  line `(c) review and evaluate overall quality and effectiveness of the Institute and to advise measures`
  line `for improvement of performance and for confidence-building between the Institute and its`
  line stakeholders;
  line
  line `(d) provide credibility, aura, connectivity and contacts for the Institute especially with regard to`
  line `student placement and resource mobilisation; and`
  line
  line `(e) advise the Institute and its Board in respect of the advanced areas of technology in the field of`
  line `petroleum sector covering the entire hydrocarbon value chain as well as in respect of any other matter`
  line `that may be referred to it for advice by the Board.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (11070)
  sectionNo (17)
  orderNo 17
  title Senate.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11070&sectionno=17&orderno=17&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_17_content:
  string
  line `The Senate of the Institute shall be the principal academic body and its composition`
  line `shall be such as may be provided by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (11071)
  sectionNo (18)
  orderNo 18
  title `Functions of Senate.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11071&sectionno=18&orderno=18&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_18_content:
  string
  line `Subject to the provisions of this Act, the Statutes and the Ordinances, the`
  line `Senate shall have the control and general regulation, and be responsible for the maintenance of standards`
  line `of instruction, education and examination in the Institute and shall exercise such other powers and`
  line `perform such other duties as may be conferred or imposed upon it by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (11072)
  sectionNo (19)
  orderNo 19
  title `President of Board.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11072&sectionno=19&orderno=19&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_19_content:
  string
  line `(1) The President shall ordinarily preside at the meetings of the Board and`
  line `at the Convocations of the Institute.`
  line
  line `(2) It shall be the duty of the President to ensure that the decisions taken by the Board are`
  line implemented.
  line
  line `(3) The President shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by this Act or the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (11073)
  sectionNo (20)
  orderNo 20
  title Director.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11073&sectionno=20&orderno=20&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_20_content:
  string
  line `(1) The Director of the Institute shall be appointed by the Central Government in such`
  line `manner and on such terms and conditions as may be provided by the Statutes:`
  line
  line `Provided that the first Director shall be appointed by the Central Government on such terms and`
  line `conditions as it deems fit, for a period not exceeding six months from the date the first Statutes comes`
  line `into force.`
  line
  line `(2) The Director shall be the principal academic and executive officer of the Institute and shall be`
  line `responsible for the proper administration and academic performance of the Institute and for imparting of`
  line `instruction and maintenance of discipline therein.`
  line
  line `(3) The Director shall submit annual reports and accounts to the Board.`
  line
  line `(4) The Director shall exercise such other powers and perform such other duties as may be assigned to`
  line `him by this Act, the Statutes or the Ordinances.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (11074)
  sectionNo (21)
  orderNo 21
  title Registrar.
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11074&sectionno=21&orderno=21&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_21_content:
  string
  line `(1) The Registrar of the Institute shall be appointed in such manner and on such`
  line `terms and conditions as may be provided by the Statutes and shall be the custodian of records, the`
  line `common seal, the funds of the Institute and such other property of the Institute as the Board shall commit`
  line `to his charge.`
  line
  line `(2) The Registrar shall act as the Secretary of the General Council, the Board, the Senate and such`
  line `committees as may be provided by the Statutes.`
  line
  line `(3) The Registrar shall be responsible to the Director for the proper discharge of his functions.`
  line
  line `(4) The Registrar shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by this Act, the Statutes or by the Director.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (11075)
  sectionNo (22)
  orderNo 22
  title `Powers and duties of other authorities and officers.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11075&sectionno=22&orderno=22&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_22_content:
  string
  line `The powers and duties of authorities and`
  line `officers, other than those hereinbefore mentioned, shall be determined by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (11076)
  sectionNo (23)
  orderNo 23
  title `Grants by Central Government.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11076&sectionno=23&orderno=23&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_23_content:
  string
  line `For the purpose of enabling the institute to discharge its`
  line `functions efficiently under this Act, the Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the institute in each financial year such sums of money and in`
  line `such manner as it may think fit.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (11077)
  sectionNo (24)
  orderNo 24
  title `Fund of Institute.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11077&sectionno=24&orderno=24&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_24_content:
  string
  line `(1) The Institute shall maintain a fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government;`
  line
  line `(b) all fees and other charges;`
  line
  line `(c) all moneys received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all moneys received by the Institute in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the fund shall be deposited in such banks or invested in such manner as`
  line `may be decided by the Board.`
  line
  line `(3) The fund shall be applied towards meeting the expenses of the Institute including expenses`
  line `incurred in the exercise of its powers and discharge of its duties under this Act.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (11078)
  sectionNo (25)
  orderNo 25
  title `Setting up of endowment fund.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11078&sectionno=25&orderno=25&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_25_content:
  string
  line `Notwithstanding anything contained in section 24, the Institute`
  line may,--
  line
  line `(a) set up an endowment fund and any other fund for a specified purpose; and`
  line
  line `(b) transfer money from its fund to the endowment fund or any other fund.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (11079)
  sectionNo (26)
  orderNo 26
  title `Accounts and audit.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11079&sectionno=26&orderno=26&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_26_content:
  string
  line `(1) The Institute shall maintain proper accounts and other relevant records`
  line `and prepare an annual statement of accounts, including the balance-sheet, in such form as may be`
  line `prescribed by the Central Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Institute shall be audited by the Comptroller and Auditor-General of India and`
  line `any expenditure incurred by him in Connection with such audit shall be payable by the Institute to the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Institute shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts, and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line Institute.
  line
  line `(4) The accounts of the Institute as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (11080)
  sectionNo (27)
  orderNo 27
  title `Pension and provident fund.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11080&sectionno=27&orderno=27&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_27_content:
  string
  line `(1) The Institute shall constitute for the benefit of its employees,`
  line `including the Director, such pension, insurance and provident fund scheme as it deems fit, in such manner`
  line `and subject to such conditions as may be provided by the Statutes.`
  line
  line `(2) Where any such provident fund has been so constituted, the Central Government may declare that`
  line `the provisions of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund as if it were a`
  line `Government provident fund.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (11081)
  sectionNo (28)
  orderNo 28
  title Appointments.
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11081&sectionno=28&orderno=28&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_28_content:
  string
  line `All appointments of the staff of the Institute, except that of the Director shall be`
  line `made in accordance with the procedure laid down in the Statutes,--`
  line
  line `(a) by the Board, if the appointment is made on the academic staff in the post of Assistant`
  line `Professor or above or if the appointment is made on the non-academic staff in any cadre, the`
  line `maximum of the pay-scale for which is the same or higher than that of Assistant Professor; and`
  line
  line `(b) by the Director, in any other case.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (11082)
  sectionNo (29)
  orderNo 29
  title Statutes.
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11082&sectionno=29&orderno=29&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_29_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:--`
  line
  line `(a) the formation of departments of teaching and other academic units;`
  line
  line `(b) the institution of fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(c) the classification of posts, term of office, method of appointment, powers and duties and other`
  line `terms and conditions of service of the officers of the Institute including the President, the Director,`
  line `the Registrar, and such other officers as may be declared as officers of the Institute by the Statutes;`
  line
  line `(d) the classification, the method of appointment and the determination of the terms and`
  line `conditions of service of officers, teachers and other staff of the Institute;`
  line
  line `(e) the reservation of posts for the Scheduled Castes, the Scheduled Tribes and other categories of`
  line `persons as may be determined by the Central Government;`
  line
  line `(f) the constitution of pension, insurance and provident funds for the benefit of the officers,`
  line `teachers and other staff of the Institute;`
  line
  line `(g) the constitution, powers and duties of the other authorities of the Institute referred in clause`
  line `(d) of section 14;`
  line
  line `(h) the delegation of power;`
  line
  line `(i) the code of conduct, disciplinary actions thereto for misconduct including removal from`
  line `service of employees on account of misconduct and the procedure for appeal against the actions of an`
  line `officer or authority of the Institute;`
  line
  line `(j) the conferment of honorary degrees;`
  line
  line `(k) the establishment and maintenance of halls, residences and hostels;`
  line
  line `(l) the authentication of the orders and decisions of the Board; and`
  line
  line `(m) any other matter which by this Act is to be, or may be, provided by the Statutes.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (11083)
  sectionNo (30)
  orderNo 30
  title `Statutes how made.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11083&sectionno=30&orderno=30&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_30_content:
  string
  line `(1) The first Statutes of the Institute shall be framed by the Central`
  line `Government and a copy of the same shall be laid, as soon as may be after it is made, before each House of`
  line Parliament.
  line
  line `(2) The Board may, from time to time, make new or additional Statutes or may amend or repeal the`
  line `Statutes in the manner hereafter in this section provided.`
  line
  line `(3) A new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require the`
  line `previous approval of the General Council who may assent thereto or withhold assent or remit it to the`
  line `Board for consideration.`
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the General Council.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (11084)
  sectionNo (31)
  orderNo 31
  title Ordinances.
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11084&sectionno=31&orderno=31&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_31_content:
  string
  line `Subject to the provisions of this Act and the Statutes, the Ordinances may provide`
  line `for all or any of the following matters, namely:--`
  line
  line `(a) the admission of the students to the Institute;`
  line
  line `(b) the reservation for the Scheduled Castes, the Scheduled Tribes and other categories of`
  line persons;
  line
  line `(c) the courses of study to be laid down for all degrees, diplomas and certificates of the Institute;`
  line
  line `(d) the conditions under which students shall be admitted to the degree, diploma and certificate`
  line `courses and to the examinations of the Institute and the eligibility conditions for awarding the same;`
  line
  line `(e) the conditions of award of the fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(f) the conditions and manner of appointment and duties of examining bodies, examiners and`
  line moderators;
  line
  line `(g) the conduct of examinations;`
  line
  line `(h) the maintenance of discipline among the students of the institute;`
  line
  line `(i) the fees to be charged for courses of study at the Institute and for admission to the`
  line examinations;
  line
  line `(j) the conditions of residence of students of the Institute and the levying of the fees for residence`
  line `in the halls and hostels and of other charges; and`
  line
  line `(k) any other matter which by this Act or the Statutes is to be, or may be, provided for by the`
  line Ordinances.
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (11085)
  sectionNo (32)
  orderNo 32
  title `Ordinances how made.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11085&sectionno=32&orderno=32&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_32_content:
  string
  line `(1) Save as otherwise provided in this section, Ordinances shall be made`
  line `by the Senate.`
  line
  line `(2) All Ordinances made by the Senate shall have effect from such date as it may direct, but every`
  line `Ordinance so made shall be submitted, as soon as may be, to the Board and shall be considered by the`
  line `Board at its next succeeding meeting.`
  line
  line `(3) The Board shall have power by resolution to modify or cancel any such Ordinance and such`
  line `Ordinance shall from the date of such resolution stand modified accordingly or cancelled, as the case may`
  line be.
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (11086)
  sectionNo (33)
  orderNo 33
  title `Conduct of business by authorities of Institute.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11086&sectionno=33&orderno=33&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_33_content:
  string
  line `The authorities of the Institute may have their`
  line `own rules of procedure, consistent with the provisions of this Act, the Statutes and the Ordinances for the`
  line `conduct of their own business and that of the committees, if any, appointed by them and not provided for`
  line `by this Act, the Statutes or the Ordinances.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (11087)
  sectionNo (34)
  orderNo 34
  title `Tribunal of Arbitration.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11087&sectionno=34&orderno=34&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_34_content:
  string
  line `(1) Any dispute arising out of a contract between the Institute and any`
  line `of its employees shall, at the request of the employee concerned or at the instance of the Institute, be`
  line `referred to a Tribunal of Arbitration consisting of one member appointed by the Institute, one member`
  line `nominated by the employee, and an umpire appointed by the Visitor.`
  line
  line `(2) The decision of the Tribunal of Arbitration shall be final.`
  line
  line `(3) No suit or proceeding shall lie in any court in respect of any matter which is required by`
  line `sub-section (1) to be referred to the Tribunal of Arbitration.`
  line
  line `(4) The Tribunal of Arbitration shall have power to regulate its own procedure.`
  line
  line `(5) Nothing in any law for the time being in force relating to arbitration shall apply to arbitrations`
  line `under this section.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (11088)
  sectionNo (35)
  orderNo 35
  title `Acts and proceedings not to be invalidated by vacancies.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11088&sectionno=35&orderno=35&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_35_content:
  string
  line `No act of the Institute or the`
  line `General Council or Board or Senate or any other body set up under this Act or the Statutes, shall be`
  line `invalid merely by reasons of--`
  line
  line `(a) any vacancy in, or defect in the constitution thereof, or`
  line
  line `(b) any defect in the election, nomination or appointment of a person acting as a member thereof,`
  line or
  line
  line `(c) any irregularity in its procedure not affecting the merits of the case.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (11089)
  sectionNo (36)
  orderNo 36
  title `Grant of degrees, etc., by Institute.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11089&sectionno=36&orderno=36&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_36_content:
  string
  line `Notwithstanding anything contained in the University`
  line `Grants Commission Act, 1956 (3 of 1956), or in any other law for the time being in force, the Institute`
  line `shall have power to grant degrees and other academic distinctions and titles under this Act.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (11090)
  sectionNo (37)
  orderNo 37
  title `Sponsored schemes.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11090&sectionno=37&orderno=37&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_37_content:
  string
  line `Notwithstanding anything in this Act, whenever the Institute receives`
  line `funds from any Government, the University Grants Commission or any other agency including industry`
  line `sponsoring a research scheme, a consultancy assignment, a teaching programme or a chaired`
  line `professorship or a scholarship, to be executed or endowed at the Institute,--`
  line
  line `(a) the amount received shall be kept by the Institute separately from the fund of the Institute and`
  line `utilised only for the purpose of the scheme; and`
  line
  line `(b) the staff required to execute the same shall be recruited in accordance with the terms and`
  line `conditions stipulated by the sponsoring organisation:`
  line
  line `Provided that any money remaining unutilised under clause (a) shall be transferred to the`
  line `endowment fund created under section 25.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (11091)
  sectionNo (38)
  orderNo 38
  title `Power to remove difficulties.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11091&sectionno=38&orderno=38&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_38_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `or give such directions not inconsistent with the provisions of this Act, as appears to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of two years from the appointed day.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (11092)
  sectionNo (39)
  orderNo 39
  title `Transitional provisions.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11092&sectionno=39&orderno=39&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_39_content:
  string
  line `Notwithstanding anything contained in this Act,--`
  line
  line `(a) the Board of Governors of the Society functioning as such immediately before the`
  line `commencement of this Act shall continue to so function until a new Board is constituted for the`
  line `Institute under this Act, but on the constitution of a new Board under this Act, the members of the`
  line `Board holding office before such constitution shall cease to hold office; and`
  line
  line `(b) until the first Statutes and the Ordinances are made under this Act, the Statutes and the`
  line `Ordinances of the Rajiv Gandhi Institute of Petroleum Technology Society, or notification as in force,`
  line `immediately before the commencement of this Act, shall continue to apply to the Institute in so far as`
  line `they are not inconsistent with the provisions of this Act.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (11093)
  sectionNo (40)
  orderNo 40
  title `Statutes, Ordinances and notifications to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_50_00005_200754_1517807322639&sectionId=11093&sectionno=40&orderno=40&orgactid=AC_CEN_32_50_00005_200754_1517807322639
obj_root_law_sections_40_content:
  string
  line `(1) Every Statute and every Ordinance made or notification issued under this Act`
  line `shall be published in the Official Gazette.`
  line
  line `(2) Every Statute and every Ordinance made or notification issued under this Act shall be laid, as`
  line `soon as may be after it is made, before each House of Parliament, while it is in session, for a total period`
  line `of thirty days which may be comprised in one session or in two or more successive sessions, and if,`
  line `before the expiry of the session immediately following the session or the successive sessions aforesaid,`
  line `both Houses agree in making any modification in the Statute, Ordinance or notification or both Houses`
  line `agree that the Statute, Ordinance or notification should not be made or issued, the Statute, Ordinance or`
  line `notification shall thereafter have effect only in such modified form or be of no effect, as the case may be;`
  line `so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that Statute, Ordinance or notification.`
  line
  line `(3) The power to make the Statutes, Ordinances or notification shall include the power to give`
  line `retrospective effect from a date not earlier than the date of commencement of this Act, to the Statutes,`
  line `Ordinances, notifications or any of them but no retrospective effect shall be given to any Statute,`
  line `Ordinance or notification so as to prejudicially affect the interests of any person to whom such Statute,`
  line `Ordinance or notification may be applicable.`
obj_root_law_sections_40_footnotes:
  string
  line
