obj_root_law_sections_1:
  sectionId (47426)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47426&sectionno=1&orderno=1&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Lok Sahayak Sena Act, 1956.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (47427)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47427&sectionno=2&orderno=2&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "camp" means any place established under section 4 as a camp where any body of volunteers`
  line `is for the time being undergoing training;`
  line
  line `(b) "Force" means the Lok Sahayak Sena constituted under this Act;`
  line
  line `(c) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(d) "superior officer" means any officer, junior commissioned officer, warrant officer or`
  line `non-commissioned officer of the regular Army or of the Territorial Army;`
  line
  line `(e) "volunteer" means a person enrolled in the Force under this Act;`
  line
  line `(f) all words and expressions used in this Act and not defined but defined in the Army`
  line `Act, 1950 (46 of 1950), or in the Territorial Army Act, 1948 (56 of 1948), shall have the meanings`
  line `respectively assigned to them in the said Acts.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47428)
  sectionNo (3)
  orderNo 3
  title `Constitution of the Lok Sahayak Sena.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47428&sectionno=3&orderno=3&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_3_content:
  string
  line `There shall be raised and maintained by the Central`
  line `Government a force to be designated the Lok Sahayak Sena by the enrolment of volunteers in the manner`
  line `hereinafter provided.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47429)
  sectionNo (4)
  orderNo 4
  title `Establishment of camps.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47429&sectionno=4&orderno=4&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_4_content:
  string
  line `The Central Government may establish such number of camps for the`
  line `purposes of the Force as it thinks fit and may close down or re-establish any such camps.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47430)
  sectionNo (5)
  orderNo 5
  title Enrolment.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47430&sectionno=5&orderno=5&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_5_content:
  string
  line `Any citizen of India not below the age of eighteen years and not above the age of`
  line `forty years may offer himself for enrolment as a volunteer and may, if he satisfies the prescribed`
  line `conditions, be enrolled in the prescribed manner by the prescribed authority for such period and subject to`
  line `such conditions as may be prescribed.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47431)
  sectionNo (6)
  orderNo 6
  title `Duties of volunteers.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47431&sectionno=6&orderno=6&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_6_content:
  string
  line `No person shall, on the ground only of being a volunteer be liable for`
  line `military service, but subject thereto a volunteer may be called upon to undergo such training as may be`
  line `prescribed, and while undergoing such training shall perform such duties and discharge such obligations`
  line `as the prescribed authority may, by general or special order, direct.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47432)
  sectionNo (7)
  orderNo 7
  title Discharge.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47432&sectionno=7&orderno=7&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_7_content:
  string
  line `Every volunteer shall be entitled to receive his discharge from the Force on the`
  line `expiration of the period for which he was enrolled, but may, prior to the expiration of that period, be`
  line `discharged from the Force by such authority and subject to such conditions as may be prescribed.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47433)
  sectionNo (8)
  orderNo 8
  title `Offences and penalties.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47433&sectionno=8&orderno=8&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_8_content:
  string
  line `(1) If any volunteer commits any of the following offences, that is`
  line `to say,--`
  line
  line `(i) without sufficient cause fails to attend at any place when duly required to do so; or`
  line
  line `(ii) while in camp on duty--`
  line
  line `(a) absents himself from the camp without leave;`
  line
  line `(b) uses criminal force or uses threatening or insubordinate language to a superior officer or`
  line `assaults a superior officer;`
  line
  line `(c) disobeys any lawful command of a superior officer;`
  line
  line `(d) neglects to obey any standing, general or other orders by the officer commanding the`
  line camp;
  line
  line `(e) uses criminal force to, or assaults, any volunteer or any person subject to the Army`
  line `Act, 1950 (46 of 1950), or the Territorial Army Act, 1948 (56 of 1948);`
  line
  line `(f) knowingly does any act which is prejudicial to the maintenance of good order or military`
  line `discipline in camp;`
  line
  line `he shall be punishable summarily by order of the prescribed authority with fine which may extend to fifty`
  line `rupees or, in default, by being confined to barracks for a term which may extend to seven days.`
  line
  line `(2) Any fine imposed by order of the prescribed authority under sub-section (1), may on application`
  line `made in this behalf by the prescribed authority to a magistrate having jurisdiction in the place where the`
  line `volunteer resides or has a place of business, be recovered in accordance with the provisions of the Code`
  line `of Criminal Procedure, 1898 (5 of 1898), as if it were a fine imposed by such magistrate.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (47434)
  sectionNo (9)
  orderNo 9
  title `Liability for causing loss of, or damage to, Government property.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47434&sectionno=9&orderno=9&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_9_content:
  string
  line `If any volunteer wilfully or`
  line `negligently causes loss of, or damage to, any property of the Government, the prescribed authority may,`
  line `after giving him an opportunity of being heard and after making such inquiry into the matter as it thinks`
  line `fit, make an order requiring him to make good the loss or damage within such time as may be specified in`
  line `the order within such further time as may be allowed by the prescribed authority in this behalf, and where`
  line `the amount thereof as determined by the prescribed authority is not paid within the time allowed, it shall,`
  line `on application made by the prescribed authority to the Collector of the district in which the volunteer`
  line `resides or has a place of business, be recovered from him in the same manner as an arrear of land`
  line revenue.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47435)
  sectionNo (10)
  orderNo 10
  title `Presumption as to certain documents.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47435&sectionno=10&orderno=10&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_10_content:
  string
  line `Where a volunteer is required by or in pursuance of any`
  line `rule made under this Act to attend at any place, a certificate purporting to be signed by the prescribed`
  line `officer, stating that the volunteer so required to attend failed to do so in accordance with such requirement`
  line `shall, without proof of the signature or appointment of such officer, be evidence of the matters stated`
  line therein.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (47436)
  sectionNo (11)
  orderNo 11
  title `Power to make rules.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 4 of 1986, s. 2 and the Schedule, for sub-section (3) (w.e.f. 15-5-1986).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00008_195653_1517807321824&sectionId=47436&sectionno=11&orderno=11&orgactid=AC_CEN_28_38_00008_195653_1517807321824
obj_root_law_sections_11_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the authorities by which, the manner in which, the period for which, and the conditions`
  line `subject to which, any person may be enrolled as a volunteer;`
  line
  line `(b) the training, discipline, duties, and obligations which a volunteer has to undergo, observe,`
  line `perform or discharge under this Act;`
  line
  line `(c) the authorities by which, and the conditions subject to which, a volunteer may be discharged;`
  line
  line `(d) the manner in which, and the conditions subject to which, a volunteer may be called out for`
  line `training or duties;`
  line
  line `(e) the determination of authorities for the purposes of this Act;`
  line
  line `(f) the officers by whom certificates may be signed under section 10; and`
  line
  line `(g) any other matter which under this Act is to be or may be prescribed.`
  line
  line `^1[(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.]`
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `लोक सहायक सेना अधिनियम,1956`
