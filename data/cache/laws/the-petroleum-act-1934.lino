  line
obj_root_law_sections_31:
  sectionId (38305)
  sectionNo (31)
  orderNo 31
  title `Power to limit powers of local authorities over petroleum.`
  content obj_root_law_sections_31_content
  footnotes `1. Subs. by the A.O. 1937, for "he".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_0_000010_193430_1523351268465&sectionId=38305&sectionno=31&orderno=31&orgactid=AC_CEN_32_0_000010_193430_1523351268465
obj_root_law_sections_31_content:
  string
  line `Where any enactment confers`
  line `powers upon any local authority in respect of the transport or storage of petroleum, the ^1[Central`
  line `Government] may, by notification in the Official Gazette,--`
  line
  line `(a) limit the operation of such enactment, or`
  line
  line `(b) restrict the exercise of such powers, in any manner ^5[it] deems fit.`
obj_root_law_sections_32:
  sectionId (38306)
  sectionNo (32)
  orderNo 32
  title [Repealed.].
  content `[Repeals.]-- Rep. by the Repealing Act, 1938 (1 of 1938), s. 2 and the Schedule.`
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_32_0_000010_193430_1523351268465&sectionId=38306&sectionno=32&orderno=32&orgactid=AC_CEN_32_0_000010_193430_1523351268465
obj_root_law_sections_32_footnotes:
  string
  line
