  (str handle) (str 1990)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Coal India (Regulation of Transfers and Validation) Act, 2000`)
  (str actNumber) (str 45)
  (str enactmentDate) (str 2000-12-08)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1990`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `कोल इंडिया (अन्तरणों का विनियमन औरविधिमान्यकरण) अधिनियम, 2000`)
  (str actYear) (str 2000)
  (str ministry) (str `Ministry of Coal`)
  (str longTitle) (str `An Act to empower the Central Government to direct the transfer of the land, or of the rights in or over land or of the right, title and interest in relation to a coal mine, coking coal mine or coke oven plant, vested in the Coal India Limited or in a subsidiary company to any subsidiary company of Coal India Limited or any other subsidiary company and to validate certain transfers of such land or rights.`)
  (str enforcementDate) (str 08-12-2000)
