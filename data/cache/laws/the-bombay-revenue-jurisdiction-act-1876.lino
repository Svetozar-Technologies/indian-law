  orderNo 17
  title Repealed.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00005_187610_1550814354714&sectionId=44288&sectionno=17&orderno=17&orgactid=AC_CEN_18_21_00005_187610_1550814354714
obj_root_law_sections_17_content:
  string
  line `[Revival of Bombay Regulation 17 of 1827, section 13.]—Rep. by Bombay Revenue Jurisdiction Act, 1880 (15 of 1880) but the repeal does not operate in any scheduled district unless and until the`
  line `Bombay Land-revenue Code (Bom. V of 1879) has been extended to such District.`
  line
  line `[Operation of same Regulation in sites of villages and towns.]— Rep. by Bombay Revenue Jurisdiction Act, 1880 (15 of 1880), s. 2.`
  line
  line `[Recovery of certain advances made by Local Government.]—Rep. by ibid.`
obj_root_law_sections_17_footnotes:
  string
  line
