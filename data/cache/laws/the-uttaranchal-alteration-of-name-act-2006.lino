obj_root_law_sections_1:
  sectionId (40081)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40081&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Uttaranchal (Alteration of`
  line `Name) Act, 2006.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st January, 2007, vide notification No. GSR 779(E), dated 29th December, 2006, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (40082)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40082&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "appointed day" means the date appointed under sub-section (2) of section 1 for the coming`
  line `into force of this Act;`
  line
  line `(b) "appropriate Government" means, as respects a law relating to a matter enumerated in List I`
  line `in the Seventh Schedule to the Constitution, the Central Government, and as respects any other law,`
  line `the State Government;`
  line
  line `(c) "law" includes any enactment, Ordinance, regulation, order, bye-law, rule, scheme,`
  line `notification or other instrument having the force of law in the whole or any part of the State of`
  line Uttaranchal.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (40083)
  sectionNo (3)
  orderNo 3
  title `Alteration of name of the State of Uttaranchal.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40083&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_3_content:
  string
  line `As from the appointed day, the State of`
  line `Uttaranchal shall be known as the State of Uttarakhand.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (40084)
  sectionNo (4)
  orderNo 4
  title `Amendment of First Schedule to the Constitution.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40084&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_4_content:
  string
  line `In the First Schedule to the Constitution,`
  line `under the heading "I. THE STATES", in entry 27, under the column "Name", for the word "Uttaranchal",`
  line `the word "Uttarakhand" shall be substituted.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (40085)
  sectionNo (5)
  orderNo 5
  title `Amendment of Fourth Schedule to the Constitution.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40085&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_5_content:
  string
  line `In the Fourth Schedule to the`
  line `Constitution, under the heading "TABLE", in entry 18, in the second column, for the word "Uttarachal"`
  line `the word "Uttarakhand" shall be substituted.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (40086)
  sectionNo (6)
  orderNo 6
  title `Power to adapt laws.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40086&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_6_content:
  string
  line `(1) For the purpose of giving effect to the alteration of the name of the`
  line `State of Uttaranchal by section 3, the appropriate Government may, before the expiration of one year`
  line `from the appointed day, by order, make such adaptations and modifications of any law made before the`
  line `appointed day, whether by way of repeal or amendment, as may be necessary or expedient, and thereupon`
  line `every such law shall have effect subject to the adaptations and modifications so made.`
  line
  line `(2) Nothing in sub-section (1) shall be deemed to prevent a competent Legislature or other competent`
  line `authority from repealing or amending any law adapted or modified by the appropriate Government under`
  line `the said sub-section.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (40087)
  sectionNo (7)
  orderNo 7
  title `Power to construe laws.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40087&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_7_content:
  string
  line `Notwithstanding that no provision or insufficient provision has been`
  line `made under section 6 for the adaptation of a law made before the appointed day, any court, tribunal or`
  line `authority, required or empowered to enforce such law, may construe the law in such manner, without`
  line `affecting the substance, as may be necessary or proper in regard to the matter before the court, tribunal or`
  line authority.
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (40088)
  sectionNo (8)
  orderNo 8
  title `Legal proceedings.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00056_200652_1517807327263&sectionId=40088&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00056_200652_1517807327263
obj_root_law_sections_8_content:
  string
  line `Where immediately before the appointed day any legal proceedings are`
  line `pending to which the State of Uttaranchal is a party, the State of Uttarakhand shall be deemed to be`
  line `substituted for the State of Uttaranchal in those proceedings.`
obj_root_law_sections_8_footnotes:
  string
  line
