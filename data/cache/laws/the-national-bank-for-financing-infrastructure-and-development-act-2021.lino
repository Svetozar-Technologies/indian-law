obj_root_law_sections_1:
  sectionId (53697)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53697&sectionno=1&orderno=1&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Bank for`
  line `Financing Infrastructure and Development Act, 2021.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act and any`
  line `reference in any provision to the commencement of this Act shall be construed as a reference to the`
  line `coming into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 19th April, 2021- Sections 2, sub-sections (1), (2) and (4) of section 3, 4 to 14, sub-section (3) of section 15, 16 to 23 and 25 to 48 vide notification No. S.O. 1657(E), dated 16th April, 2021, see Gazette of India, Extraordinary, Part II, sec. 3 (ii).`
  line
  line `19th April 2021-clause (2) of sub-section (1) of section 11, vide notification No. S.O. 1658(E), dated 19th April, 2021, seeGazette of India, Extraordinary, Part II, sec. 3(ii).`
  line
  line `30th November 2021-Sub-section (1), (2), (4) and (5) of section 15; and section (24), vide notification No. S.O. 4911(E), dated 30th November, 2021, see Gazette of India, Extraordinary, Part II, sec. 3 (ii).`
obj_root_law_sections_2:
  sectionId (53698)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53698&sectionno=2&orderno=2&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,---`
  line
  line `(a) "Audit Committee" means the Audit Committee of the Board constituted under sub-section`
  line `(1) of section 15;`
  line
  line `(b) "Board" means the Board of Directors constituted under section 6;`
  line
  line `(c) "Bureau" means a body which the Central Government may notify, for the purpose of`
  line `recommending candidates for appointment of Managing Director and Deputy Managing Directors`
  line `under sub-section (1) of section 6 and for removal of a director under clause (ii) of sub-section (1) of`
  line `section 11;`
  line
  line `(d) "Chairperson" means the Chairperson of the Board appointed under clause (a) of sub-section`
  line `(1) of section 6;`
  line
  line `(e) "committee" means a committee of the Board constituted under section 15;`
  line
  line `(f) "Deputy Managing Director" means the Deputy Managing Director appointed under clause (c)`
  line `of sub-section (1) of section 6;`
  line
  line `(g) "director" includes a Chairperson, Managing Director, Deputy Managing Directors and other`
  line `directors of the Board appointed or nominated under section 6;`
  line
  line `(h) "Executive Committee" means the Executive Committee of the Board constituted under subsection (2) of section 15;`
  line
  line `(i) "financial institution" shall have the meaning assigned to it in clause (m) of sub-section (1) of`
  line `section 2 of the Securitisation and Reconstruction of Financial Assets and Enforcement of Security`
  line `Interest Act, 2002 (54 of 2002);`
  line
  line `(j) "independent director" means the independent director of the Board appointed under clause (f)`
  line `of sub-section (1) of section 6;`
  line
  line `(k) "infrastructure" means the sectors covered in the list of infrastructure sector notified by the`
  line `Central Government from time to time;`
  line
  line `(l) "Institution" means the National Bank for Financing Infrastructure and Development`
  line `established under section 3;`
  line
  line `(m) "insurer" shall have the meaning assigned to it in sub-section (9) of section 2 of the Insurance`
  line `Act, 1938 (4 of 1938);`
  line
  line `(n) "Managing Director" means the director appointed under clause (b) of sub-section (1) of`
  line `section 6;`
  line
  line `(o) "Nomination and Remuneration Committee" means the Nomination and Remuneration`
  line `Committee of the Board constituted under sub-section (1) of section 15;`
  line
  line `(p) "notification" means a notification published in the Official Gazette and the expression`
  line `"notify" shall be construed accordingly;`
  line
  line `(q) "pension fund" shall have the meaning assigned to it in clause (l) of sub-section (1) of section`
  line `2 of the Pension Fund Regulatory and Development Authority Act, 2013 (23 of 2013);`
  line
  line `(r) "prescribed" means prescribed by rules made under this Act by the Central Government;`
  line
  line `(s) "regulations" means regulations made by the Board under this Act and includes the`
  line `regulations made by the Reserve Bank under section 29;`
  line
  line `(t) "Reserve Bank" means the Reserve Bank of India established under the Reserve Bank of India`
  line `Act, 1934 (2 of 1934);`
  line
  line `(u) "Risk Management Committee" means the Risk Management Committee of the Board`
  line `constituted under sub-section (1) of section 15;`
  line
  line `(v) "Schedule" means a Schedule appended to this Act.`
  line
  line `(2) Words and expressions used but not defined in this Act but defined in the Indian Contract Act,`
  line `1872 (9 of 1872), the Indian Partnership Act, 1932 (9 of 1932), the Securities Contracts (Regulation) Act,`
  line `1956 (42 of 1956), the Securities and Exchange Board of India Act, 1992 (15 of 1992), the Recovery of`
  line `Debts Due to Banks and Financial Institutions Act, 1993 (51 of 1993), the Limited Liability Partnership`
  line `Act, 2008 (6 of 2009) and the Companies Act, 2013 (18 of 2013), shall have the meanings respectively`
  line `assigned to them in those Acts.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (53652)
  sectionNo (3)
  orderNo 3
  title `Establishment and incorporation of Institution.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53652&sectionno=3&orderno=3&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established, for the`
  line `purposes of this Act, an Institution to be called the National Bank for Financing Infrastructure and`
  line `Development as a development financial institution.`
  line
  line `(2) The Institution shall be a body corporate by the name aforesaid, having perpetual succession and a`
  line `common seal, with power, subject to the provisions of this Act, to acquire, hold and dispose of property,`
  line `both movable and immovable, and to contract, and shall, by the said name, sue or be sued.`
  line
  line `(3) The head office of the Institution shall be in Mumbai.`
  line
  line `(4) The Institution may establish offices, branches or agencies at any place within or outside India.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (53653)
  sectionNo (4)
  orderNo 4
  title `Purposes and objectives of Institution.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53653&sectionno=4&orderno=4&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_4_content:
  string
  line `(1) The Institution shall have developmental and`
  line `financial objectives as set out in sub-sections (2) and (3).`
  line
  line `(2) The developmental objective of the Institution shall be to co-ordinate with the Central and State`
  line `Governments, regulators, financial institutions, institutional investors and such other relevant`
  line `stakeholders, in India or outside India, to facilitate building and improving the relevant institutions to`
  line `support the development of long term non-recourse infrastructure financing in India including the`
  line `domestic bonds and derivatives markets.`
  line
  line `(3) The financial objective of the Institution shall be to lend or invest, directly or indirectly, and seek`
  line `to attract investment from private sector investors and institutional investors, in infrastructure projects`
  line `located in India, or partly in India and partly outside India, with a view to foster sustainable economic`
  line `development in India.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (53654)
  sectionNo (5)
  orderNo 5
  title `Authorised share capital.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53654&sectionno=5&orderno=5&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_5_content:
  string
  line `(1) The authorised share capital of the Institution shall be one hundred`
  line `thousand crore rupees divided into ten thousand crores of fully paid-up shares of ten rupees each:`
  line
  line `Provided that the Board may increase or reduce the nominal or face value of the shares, and divide the`
  line `authorised capital into such denomination as it may decide:`
  line
  line `Provided further that the Board may, in consultation with the Central Government, increase or reduce`
  line `the authorised capital subject to the shares in all cases being fully paid-up shares.`
  line
  line `(2) The issued share capital of the Institution shall, on such date as may be notified by the Central`
  line `Government, stand allotted to the Central Government.`
  line
  line `(3) Shares of the Institution may be held by the Central Government, multilateral institutions,`
  line `sovereign wealth funds, pension funds, insurers, financial institutions, banks, and any such institution as`
  line `may be prescribed:`
  line
  line `Provided that the Central Government shall hold at least twenty-six per cent. of the shares of the`
  line `Institution at all times.`
  line
  line `(4) The Board may, with the prior approval of the Central Government, reduce its share capital,`
  line `including by way of buy-back of shares.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (53655)
  sectionNo (6)
  orderNo 6
  title `Board of Directors.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53655&sectionno=6&orderno=6&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_6_content:
  string
  line `(1) The Board of Directors of the Institution shall consist of the following,`
  line `namely:--`
  line
  line `(a) a Chairperson, to be appointed by the Central Government in consultation with the Reserve`
  line Bank;
  line
  line `(b) a Managing Director, to be appointed by the Board, on the recommendations of the Bureau`
  line `and subject to such procedure and clearances from such agencies, as may be determined by the`
  line `Central Government;`
  line
  line `(c) not more than three Deputy Managing Directors, each of whom shall be appointed by the`
  line `Board, on the recommendations of the Bureau and subject to such procedure and clearances from`
  line `such agencies, as may be determined by the Central Government;`
  line
  line `(d) two directors, to be nominated by the Central Government, who shall be the officials of the`
  line `Central Government;`
  line
  line `(e) such number of directors not exceeding three, elected by shareholders in such manner as may`
  line `be prescribed, such that a shareholder, other than the Central Government, holding ten per cent. or`
  line `more of the total issued equity share capital may nominate one director;`
  line
  line `(f) such number of independent directors not exceeding three or one-third of the total number of`
  line `directors on the Board, whichever is higher, to be appointed by the Board on the recommendations of`
  line `the Nomination and Remuneration Committee:`
  line
  line `Provided that if the percentage of holding of issued equity share capital with the shareholders does`
  line `not permit election of three directors or until the assumption of charge by the directors elected by the`
  line `shareholders, the Board may at any time co-opt such number of independent directors, not exceeding`
  line `three, to be appointed by the Board on the recommendations of the Nomination and Remuneration`
  line `Committee, who shall hold office until the assumption of charge by the directors elected by the`
  line `shareholders and an equal number of such co-opted independent directors shall retire in the order of cooption:`
  line
  line `Provided further that at least one of the directors specified in clause (e) or in clause (f) shall be a`
  line woman.
  line
  line `(2) The Managing Director and Deputy Managing Directors shall be whole-time directors of the`
  line Board.
  line
  line `(3) No person who is a salaried officer or other employee of the Institution shall be appointed as a`
  line `director of the Board except to the post of a Managing Director or a Deputy Managing Director.`
  line
  line `(4) The Chairperson shall preside over the meetings of the Board.`
  line
  line `(5) The terms and conditions of induction of independent directors to the Board under clause (f) of`
  line `sub-section (1) shall be such as may be prescribed.`
  line
  line `(6) The directors appointed under clauses (d) and (f) of sub-section (1) shall be deemed to be`
  line `independent directors under the Companies Act, 2013 (18 of 2013), for the purpose of immunities`
  line `available to independent directors.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (53699)
  sectionNo (7)
  orderNo 7
  title Management
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53699&sectionno=7&orderno=7&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_7_content:
  string
  line `(1) The general superintendence, direction and management of the affairs and`
  line `business of the Institution shall vest in the Board which shall exercise all powers and do all acts and`
  line `things which may be exercised or be done by the Institution.`
  line
  line `(2) Subject to the provisions of this Act, the Board in discharging its functions shall act on business`
  line principles.
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (53700)
  sectionNo (8)
  orderNo 8
  title `Delegation of powers.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53700&sectionno=8&orderno=8&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_8_content:
  string
  line `The Board may, by general or special order, delegate to any director or`
  line `committee constituted under this Act or to any officer or other employee of the Institution, subject to such`
  line `conditions and limitations, if any, as may be specified in the order, such of its powers and functions under`
  line `this Act as it may deem necessary.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (53701)
  sectionNo (9)
  orderNo 9
  title `Term of office and other terms and conditions of service of Chairperson and other directors of Board.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53701&sectionno=9&orderno=9&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_9_content:
  string
  line `(1) The Chairperson, Managing Director, Deputy Managing Directors and other directors of`
  line `the Board other than the directors nominated by the Central Government under clause (d) of sub-section`
  line `(1) of section 6, shall hold office for such term, not exceeding five years, and shall be eligible for reappointment subject to an overall term not exceeding ten years:`
  line
  line `Provided that the Managing Director and Deputy Managing Directors shall not hold office as such`
  line `after they have attained the age of sixty-five years and sixty-two years, respectively.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Chairperson and directors nominated`
  line `or appointed under sub-section (1) of section 6 shall hold office during the pleasure of the authority`
  line `nominating or appointing them.`
  line
  line `(3) The Chairperson and directors nominated by the Central Government or shareholders and`
  line `independent directors shall receive such fees and reimbursements as may be prescribed:`
  line
  line `Provided that any fees and reimbursements payable under this sub-section shall not be linked with the`
  line `profits of the Institution.`
  line
  line `(4) The salaries and allowances payable to the Managing Director and Deputy Managing Directors`
  line `shall be specified by regulations on the recommendations of the Nomination and Remuneration`
  line `Committee guided by market standards.`
  line
  line `(5) The term of office and other terms and conditions of service of, the Chairperson, Managing`
  line `Director, Deputy Managing Directors and other directors of the Board other than the directors nominated`
  line `by the Central Government under clause (d) of sub-section (1) of section 6, shall be such as may be`
  line prescribed.
  line
  line `(6) Notwithstanding anything contained in this Act, no fees shall be payable to any director who is an`
  line `officer of the Central Government.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (53658)
  sectionNo (10)
  orderNo 10
  title `Disqualification and removal of directors from office.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53658&sectionno=10&orderno=10&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_10_content:
  string
  line `(1) The Central Government may`
  line `remove from office any director who---`
  line
  line `(a) is, or at any time has been, adjudged as insolvent; or`
  line
  line `(b) has become physically or mentally incapable of acting as a director; or`
  line
  line `(c) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions as`
  line `a director; or`
  line
  line `(e) has, in the opinion of the Central Government, so abused his position as to render his`
  line `continuance in office detrimental to the public interest; or`
  line
  line `(f) has, for any reason, been removed or dismissed from the service of---`
  line
  line `(i) the Government; or`
  line
  line `(ii) any bank including the Reserve Bank or the State Bank of India; or`
  line
  line `(iii) any public financial institution or State financial corporation; or`
  line
  line `(iv) any other corporation owned or controlled by the Government.`
  line
  line `(2) No such director shall be removed under clause (d) or clause (e) of sub-section (1) unless he has`
  line `been given a reasonable opportunity of being heard in the matter.`
  line
  line `(3) Any director who is elected or nominated as a Member of Parliament or of any State legislature,`
  line `shall cease to be a director from the date of such election or nomination, as the case may be.`
  line
  line `(4) The disqualifications or removal under this section shall not take effect---`
  line
  line `(a) for thirty days from the date of the adjudication, sentence or order; or`
  line
  line `(b) where any appeal or petition is preferred within thirty days against the adjudication, sentence`
  line `or conviction resulting in the sentence or order, until the expiry of seven days from the date on which`
  line `such appeal or petition is disposed of.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (53659)
  sectionNo (11)
  orderNo 11
  title `Removal of Chairperson and other directors in certain cases.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53659&sectionno=11&orderno=11&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_11_content:
  string
  line `(1) Notwithstanding anything`
  line `contained in section 10,--`
  line
  line `(i) the Central Government may, after consulting the Reserve Bank, remove from office the`
  line `Chairperson and appoint in his place another person to fill the vacancy;`
  line
  line `(ii) the Board may, after consulting the Bureau, remove from office any director appointed under`
  line `clause (b) or clause (c) or clause (f) of sub-section (1) of section 6 and appoint in his place another`
  line `person to fill the vacancy;`
  line
  line `(iii) the shareholders, other than the Central Government, may, by a resolution passed by`
  line `majority, of the votes of such shareholders holding in the aggregate not less than one-half of the share`
  line `capital held by all such shareholders, remove any director elected under clause (e) of sub-section (1)`
  line `of section 6 and elect in his place another person to fill the vacancy:`
  line
  line `Provided that no person shall be removed from office under this sub-section unless such person has`
  line `been given an opportunity of showing cause against such removal.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Central Government shall, in`
  line `consultation with the Reserve Bank, have the right to terminate the term of office of the Chairperson,`
  line `Managing Director, Deputy Managing Directors or directors, as the case may be, at any time before the`
  line `expiry of the term prescribed under sub-section (5) of section 9, by giving notice of not less than three`
  line `months in writing or three months' salary and allowances in lieu of such notice.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (53660)
  sectionNo (12)
  orderNo 12
  title `Vacation and resignation of office by directors.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53660&sectionno=12&orderno=12&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_12_content:
  string
  line `(1) If a director--`
  line
  line `(a) becomes subject to any of the disqualifications mentioned in section 10 or is removed under`
  line `section 11; or`
  line
  line `(b) is absent without leave of the Board for three or more consecutive meetings thereof, his seat`
  line `shall thereupon become vacant.`
  line
  line `(2) Any director may resign his office by giving notice thereof in writing to the Board and on such`
  line `resignation being accepted by the Board, or, if such resignation is not accepted sooner, on the expiry of`
  line `three months from the receipt thereof by the Board, such director shall be deemed to have vacated his`
  line office.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (53661)
  sectionNo (13)
  orderNo 13
  title `Meetings of Board.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53661&sectionno=13&orderno=13&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_13_content:
  string
  line `(1) The Board shall meet at such times and places and shall observe such`
  line `rules of procedure in regard to the transaction of business at its meetings, as may be specified by`
  line regulations.
  line
  line `(2) A meeting of the Board shall be held at least once in every calendar quarter and at least four such`
  line `meetings shall be held every year.`
  line
  line `(3) The Chairperson of the Board, or, if for any reason he is unable to attend any meeting, the`
  line `Managing Director, or, in the event of both the Chairperson and the Managing Director being unable to`
  line `attend a meeting, any other director nominated by the Chairperson in this behalf and in the absence of`
  line `such nomination, any director elected by the directors present from among themselves at the meeting,`
  line `shall preside at the meeting of the Board.`
  line
  line `(4) All questions which come up before any meeting of the Board shall be decided by a majority of`
  line `votes of the directors present and voting, and in the event of an equality of votes, the Chairperson, or, in`
  line `his absence, the person presiding, shall have a second or casting vote.`
  line
  line `(5) Save as provided in sub-section (4), every director shall have one vote.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (53662)
  sectionNo (14)
  orderNo 14
  title `Defects in appointment not to invalidate acts, etc.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53662&sectionno=14&orderno=14&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_14_content:
  string
  line `(1) No act or proceeding of the Board or of`
  line `any of its committee shall be questioned on the ground merely of the existence of any vacancy in, or`
  line `defect in the constitution of, the Board or the committee, as the case may be.`
  line
  line `(2) No act done by any person acting in good faith as a director of the Board or as a member of its`
  line `committee shall become invalid merely on the ground that he was disqualified to be a director or that`
  line `there was any other defect in his appointment.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (53663)
  sectionNo (15)
  orderNo 15
  title `Committees of Board.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53663&sectionno=15&orderno=15&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_15_content:
  string
  line `(1) The Board shall constitute a Nomination and Remuneration`
  line `Committee, a Risk Management Committee and an Audit Committee, each consisting of a minimum of`
  line `three directors with independent directors forming a majority.`
  line
  line `(2) The Board shall constitute an Executive Committee consisting of such number of directors as it`
  line `may consider necessary.`
  line
  line `(3) The Chairperson of the Institution shall not be a member of the Executive Committee and after the`
  line `first year not be Chairperson of Audit Committee or the Nomination and Remuneration Committee.`
  line
  line `(4) The Board may constitute such other committees as it may deem fit.`
  line
  line `(5) The Executive Committee or any other committees constituted under this section shall meet at`
  line `such times and places, observe such rules of procedure in regard to transaction of business at its meetings`
  line `and shall perform such functions, as may be specified by regulations.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (53664)
  sectionNo (16)
  orderNo 16
  title `Disclosure of interest by members of Board or of committees.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53664&sectionno=16&orderno=16&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_16_content:
  string
  line `(1) Every director shall at the`
  line `first meeting of the Board in which he participates as a director and thereafter at the first meeting of the`
  line `Board in every financial year, or whenever there is any change in the disclosures already made, then at the`
  line `first Board meeting held after such change, disclose his concern or interest in any body corporate, which`
  line `shall include shareholding, in such manner as may be prescribed.`
  line
  line `(2) Every director who is in any way, whether directly or indirectly, concerned or interested in a`
  line `contract or arrangement or proposed contract or arrangement entered into or to be entered into by the`
  line Institution--
  line
  line `(a) with a body corporate in which such director or such director in association with any other`
  line `director, holds more than two per cent. shareholding of that body corporate, or is a promoter,`
  line `manager, chief executive officer or trustee of that body corporate; or`
  line
  line `(b) with a firm or other entity in which such director is a partner, owner or member, as the case`
  line `may be,`
  line
  line `shall not participate in any meeting of the Board or of its committee in which such contract or`
  line `arrangement is deliberated upon, or in any other deliberations or discussions regarding such contract or`
  line `arrangement, and shall, in the case of such deliberations in a meeting of the Board or its committee,`
  line `disclose the nature of his concern or interest to the Board or the committee, as the case may be:`
  line
  line `Provided that where any director who is not so concerned or interested at the time of entering into`
  line `such contract or arrangement, shall, if he becomes concerned or interested after the contract or`
  line `arrangement is entered into, disclose his concern or interest forthwith when he becomes concerned or`
  line `interested, or at the first meeting of the Board held after he becomes so concerned or interested.`
  line
  line `(3) A contract or arrangement entered into by the Institution without disclosure under sub-section (2)`
  line `or with participation by a director who is concerned or interested in any way, whether directly or`
  line `indirectly, in such contract or arrangement, shall be voidable at the option of the Institution.`
  line
  line `(4) Such employees as the Board may specify as constituting the senior management of the Institution`
  line `shall make disclosures to the Board relating to all material, financial and commercial transactions, in`
  line `which they have personal interest that may have a potential conflict with the interest of the Institution, and`
  line `the Board shall formulate a policy on such transactions, including any materiality threshold therefor, and`
  line `shall review such policy at least once every three years.`
  line
  line `Explanation.--For the purposes of this sub-section, conflict of interest relates to dealing in the shares`
  line `of the Institution or any of its subsidiaries or associate companies, commercial dealings with bodies in`
  line `which the senior management individual or his relatives have shareholding, etc.`
  line
  line `(5) If an individual who is a director contravenes the provisions of sub-section (1) or sub-section (2),`
  line `or an employee referred to in sub-section (4) contravenes such provisions, such an individual or employee`
  line `shall be liable to pay penalty of a sum of up to one lakh rupees.`
  line
  line `(6) Without prejudice to anything contained in sub-section (5), it shall be open to the Institution to`
  line `proceed against a director or any other employee who had entered into such contract or arrangement in`
  line `contravention of the provisions of this section for recovery of any loss sustained by it as a result of such`
  line `contract or arrangement.`
  line
  line `Explanation.--For the purposes of this section and section 19, the expression "body corporate" shall`
  line `include a company, a body corporate as defined in clause (11) of section 2 of the Companies Act, 2013`
  line `(18 of 2013), a firm, a financial institution or a scheduled bank or a public sector enterprise established or`
  line `constituted by or under any Central Act or State Act, and any other incorporated association of persons or`
  line `body of individuals.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (53665)
  sectionNo (17)
  orderNo 17
  title `Functions and powers of Institution.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53665&sectionno=17&orderno=17&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_17_content:
  string
  line `(1) The Institution shall perform the following functions`
  line `and exercise the following powers, namely:--`
  line
  line `(i) form subsidiaries or joint ventures or branches, in India or outside India, for carrying out its`
  line `functions; and enter into any arrangement with such subsidiary company or joint venture or branch`
  line `including for financing any such subsidiary company or joint venture or branch or guaranteeing any of`
  line `their liabilities or make any other arrangement which may seem desirable to the Board;`
  line
  line `(ii) co-ordinate its operations and the operations of various institutions engaged in the field of`
  line `infrastructure finance and maintain expert staff to study problems relating to infrastructure finance and`
  line `be available for consultation to the Central Government, the Reserve Bank and the other institutions`
  line `engaged in the field of infrastructure finance;`
  line
  line `(iii) set up trusts under the Indian Trusts Act, 1882 (2 of 1882) for establishment of funds for such`
  line `nature as would assist in financing of infrastructure projects located in India, or partly in India and`
  line `partly outside India, including real estate investment trusts and infrastructure investment trusts;`
  line
  line `(iv) support the development of a deep and liquid market for bonds, loans and derivatives for`
  line `infrastructure financing including facilitating electronic and negotiated markets infrastructure, investor`
  line `protection, adjudication infrastructure, etc.;`
  line
  line `(v) lend and invest in infrastructure projects located in India, or partly in India and partly outside`
  line `India, including by underwriting credit, securitisation of its receivables, including by way of any pass`
  line `through certificate or direct assignment, transfer or novation, or by means of innovative financial tools`
  line `including transactions secured by receivables from project;`
  line
  line `(vi) extend loans and advances to any company or statutory corporation or trust or any financial`
  line `institution funding infrastructure, for the purposes of providing financial assistance for infrastructure`
  line `projects located in India, or partly in India and partly outside India;`
  line
  line `(vii) take over or refinance existing loans extended by a lender for infrastructure projects located`
  line `in India, or partly in India and partly outside India;`
  line
  line `(viii) transfer loans and advances granted by it, with or without the securities, to trusts, for`
  line consideration;
  line
  line `(ix) set aside loans or advances held by the Institution and issue and sell securities based upon`
  line `such loans or advances so set aside in the form of debt obligations, trust certificates of beneficial`
  line `interest or other instruments, by whatever name called, and act as a trustee for the holders of such`
  line securities;
  line
  line `(x) assign securities issued to the Institution;`
  line
  line `(xi) subscribe to or purchase, underwrite, acquire, hold or sell stocks, shares, bonds, debenture`
  line `stocks, debt securities, obligations and securities, commercial papers, certificates of deposit or debentures issued or guaranteed by any company or trust or registered society or co-operative society`
  line `or association or the Central Government or any State Government or any financial institution`
  line `funding infrastructure, to facilitate financing of infrastructure projects in India, or partly in India and`
  line `partly outside India, or to facilitate deepening of bond market for infrastructure financing;`
  line
  line `(xii) borrow or raise money by way of loans or otherwise both in rupees and foreign currencies or`
  line `secure the payment of money by the issue and sale of debentures, debenture stocks, bonds,`
  line `obligations, mortgages and securities of all kinds, either perpetual or terminable and either`
  line `redeemable or otherwise and charge or secure the same by trust deed, or otherwise on the undertaking`
  line `of the Institution including its authorised or issued capital, or upon any specific property and rights,`
  line `present or future, of the Institution or otherwise, howsoever;`
  line
  line `(xiii) borrow money from the Central Government, scheduled banks, financial institutions, mutual`
  line `funds, any class of persons, and from any other institution or authority or organisation notified by the`
  line `Central Government, on such terms and conditions as may be agreed upon and accept short term`
  line `loans only for managing asset liability mismatches and not for any other business purpose;`
  line
  line `(xiv) buy or sell, or enter into such other dealings in foreign exchange as may be necessary for the`
  line `discharge of its functions;`
  line
  line `(xv) issue participation certificates or debt securities, and promote and facilitate securitisation of`
  line `loan portfolio of companies and other entities engaged in the development and financing of`
  line `infrastructure and create and develop a secondary market for the securitised receivables including by`
  line `way of acting as an intermediary;`
  line
  line `(xvi) lend money with or without security and make advances upon, hold in trust, issue, buy, sell`
  line `or otherwise acquire or dispose of on commission or otherwise any of the securities or investments or`
  line `act as an agent for any of the like purpose;`
  line
  line `(xvii) lend to or invest in or acquire professional or technical services of companies operating in`
  line `the infrastructure domain across the life cycle of projects;`
  line
  line `(xviii) act as an intermediary in respect of transactions or services relating to debt securities`
  line `issued by infrastructure companies and financial institutions for financing infrastructure projects`
  line `located in India, or partly in India and partly outside India, including by way of extension of credit`
  line `enhancement facilities;`
  line
  line `(xix) take an active role in negotiations and discussions with various Government authorities and`
  line `stakeholders for effective dispute resolution in the field of infrastructure financing;`
  line
  line `(xx) apply for, receive, accept, administer and manage grants, aids, subsidies, funds or donations,`
  line `etc., from national and international sources including World Bank, New Development Bank, Japan`
  line `International Cooperation Agency, United States Agency for International Development,`
  line `Kreditanstalt für Wiederaufbau, European Investment Bank, Asian Development Bank, International`
  line `Finance Corporation and other organisations and agencies, and organise and facilitate foreign`
  line `participation in infrastructure development projects;`
  line
  line `(xxi) issue guarantee, letters of comfort, or letters of credit for loans or credit arrangements made,`
  line `or, debentures or bonds issued, by any financial institution funding infrastructure projects in India, or`
  line `partly in India and partly outside India;`
  line
  line `(xxii) borrow money from the Reserve Bank repayable on demand or on the expiry of fixed`
  line `periods not exceeding ninety days from the date on which the money is so borrowed against the`
  line `security of stocks, funds or securities (other than immovable property) in which a trustee is authorised`
  line `to invest trust money by any law for the time being in force in India;`
  line
  line `(xxiii) borrow money from the Reserve Bank against bills of exchange or promissory notes`
  line `arising out of bona fide commercial or trade transactions maturing within five years from the date of`
  line `the borrowing;`
  line
  line `(xxiv) convert any debt it has extended to a borrower into equity; and`
  line
  line `(xxv) any other kind of business or undertake any other kind of activity which the Central`
  line `Government in consultation with the Reserve Bank may authorise.`
  line
  line `(2) In furtherance of sub-section (1), the Institution, either by itself or through its subsidiaries or joint`
  line `ventures or in association with others, may carry out the following functions, namely:--`
  line
  line `(a) organise and facilitate participation from the Central Government, public sector, private sector`
  line `and institutional investors from India or overseas in infrastructure development projects located in`
  line `India, or partly in India and partly outside India;`
  line
  line `(b) provide facilities for training, for dissemination of information and the promotion of research`
  line `including the undertaking of studies, researches, techno-economic and other surveys in the field of`
  line `infrastructure development and it may for the said purposes make loans or advances or grants`
  line `including grants by way of provision for fellowships and chairs to any institution;`
  line
  line `(c) provide technical, legal, marketing and administrative assistance to any person engaged in`
  line `infrastructure development activities;`
  line
  line `(d) provide consultancy services in the field of infrastructure development, project structuring,`
  line `capital structuring or operations subsequent to commissioning and other related matters in or outside`
  line India;
  line
  line `(e) act as trustees of any deeds constituting or securing any debentures, debenture stocks, or other`
  line `securities or obligation and undertake and execute any other trusts, and also undertake the office of or`
  line `exercise the powers of executor, administrator, receiver, treasurer, custodian and trust corporation;`
  line
  line `(f) acquire an undertaking including the business, assets and liabilities of any institution the`
  line `principal object of which is the promotion or development of infrastructure financing for projects`
  line `located in India, or partly in India and partly outside India;`
  line
  line `(g) act as a financial intermediary for the purpose of promotion, financing and development of`
  line `infrastructure projects and facilities located in India, or partly in India and partly outside India,`
  line `through developing and disseminating appropriate financial instruments, negotiating loans and`
  line `advances of all nature, and formulating schemes for mobilisation of resources;`
  line
  line `(h) structure proposals and negotiate agreements, with the proponents of infrastructure projects`
  line `and with investors in infrastructure projects located in India, or partly in India and partly outside`
  line India;
  line
  line `(i) open any account in any bank in or outside India or make any agency arrangement with, or act`
  line `as an agent or correspondent of, any bank or other institution in or outside India; and`
  line
  line `(j) do such other acts and things as may be incidental to, or consequential upon, the exercise of its`
  line `powers or the discharge of its duties under this Act or any other law for the time being in force,`
  line `including sale or transfer of any of its assets.`
  line
  line `(3) The Central Government may, on a request being made to it by the Institution, guarantee the`
  line `bonds, debentures and loans issued by the Institution as to the repayment of principal and the payment of`
  line `interest at such rate, terms and conditions as may be agreed by the Central Government.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (53666)
  sectionNo (18)
  orderNo 18
  title `Prohibited business.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53666&sectionno=18&orderno=18&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_18_content:
  string
  line `(1) The Institution shall not make any loan or advance on the security of`
  line `its own bonds or debentures.`
  line
  line `(2) The Institution shall not make loans or advances to any person or body of persons of which any of`
  line `the directors of the Institution is a proprietor, partner, director, employee or guarantor, or in which one or`
  line `more directors of the Institution hold substantial interest.`
  line
  line `(3) Sub-section (2) shall not apply to any borrower if any director of the Institution is nominated by`
  line `the Institution or the Central Government as director on the Board of such borrower or is elected on the`
  line `Board of such borrower by virtue of shares held in the borrower by the Institution.`
  line
  line `Explanation.-- For the purpose of this section, “substantial interest” in relation to a borrower, means`
  line `the beneficial interest held by one or more of the directors of the Institution or by any relative of such`
  line `director as defined in clause (77) of section 2 of the Companies Act, 2013 (18 of 2013) whether singly or`
  line `taken together, in the shares of the borrower, and the aggregate amount paid-up on which either exceeds`
  line `fifty lakhs rupees or two per cent. of the paid-up share capital of the borrower, whichever is lesser or such`
  line `other threshold as may be prescribed.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (53667)
  sectionNo (19)
  orderNo 19
  title `Related party transactions.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53667&sectionno=19&orderno=19&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_19_content:
  string
  line `(1) Except with the consent of the Board and subject to such`
  line `conditions as may be prescribed, the Institution shall not enter into any contract or arrangement with a`
  line `related party with respect to--`
  line
  line `(a) sale, purchase or supply of any goods or materials;`
  line
  line `(b) selling or otherwise disposing of, or buying, property of any kind;`
  line
  line `(c) leasing of property of any kind;`
  line
  line `(d) availing or rendering of any services;`
  line
  line `(e) appointment of any agent for purchase or sale of goods, materials, services or property;`
  line
  line `(f) such related party's appointment to any office or place of profit in the Institution, its`
  line `subsidiaries or joint ventures or associate companies;`
  line
  line `(g) underwriting the subscription of any securities, or derivatives thereof, of the Institution:`
  line
  line `Provided that no contract or arrangement involving transactions exceeding such sums as may be`
  line `specified by regulations, shall be entered into except with the prior approval in the general meeting of the`
  line `shareholders:`
  line
  line `Provided further that no shareholder shall vote in such general meeting to approve any contract or`
  line `arrangement which may be entered into by the Institution, if such shareholder is a related party:`
  line
  line `Provided also that nothing in this sub-section shall apply to any transactions entered into by the`
  line `Institution in its ordinary course of business, other than transactions which are not on an arm's length`
  line `basis:`
  line
  line `Provided also that the requirement of approval under the first proviso shall not be applicable for`
  line `transactions entered into between the Institution and its wholly owned subsidiary, if any, whose financial`
  line `statements are consolidated with the Institution and placed before the shareholders at the general meeting`
  line `for adoption.`
  line
  line `Explanation.--In this sub-section,--`
  line
  line `(a) the expression "office or place of profit" means any office or place--`
  line
  line `(i) where such office or place is held by a director, if the director holding it receives from the`
  line `Institution anything by way of remuneration over and above the remuneration to which he is entitled`
  line `as director, by way of salary, fee, commission, perquisites, any rent-free accommodation, or`
  line otherwise;
  line
  line `(ii) where such office or place is held by an individual other than a director or by any firm, private`
  line `company or other body corporate, if the individual, firm, private company or body corporate holding`
  line `it receives from the Institution anything by way of remuneration, salary, fee, commission, perquisites,`
  line `any rent-free accommodation, or otherwise;`
  line
  line `(b) the expression "arm's length transaction" means a transaction between two related parties that`
  line `is conducted as if they were unrelated, so that there is no conflict of interest.`
  line
  line `(2) Every contract or arrangement entered into under sub-section (1) shall be referred to in a report`
  line `made by the Board to the shareholders, along with the justification for entering into such contract or`
  line arrangement.
  line
  line `(3) Where any contract or arrangement is entered into by a director or any employee, without`
  line `obtaining the consent of the Board or approval by a resolution in the general meeting of the shareholders`
  line `under sub-section (1) and if it is not ratified by the Board or, as the case may be, by the shareholders at a`
  line `meeting within three months from the date on which such contract or arrangement was entered into, such`
  line `contract or arrangement shall be voidable at the option of the Board or, as the case may be, of the`
  line `shareholders and if the contract or arrangement is with a related party to any director, or is authorised by`
  line `any other director, the directors concerned shall indemnify the Institution against any loss incurred by it.`
  line
  line `(4) Without prejudice to anything contained in sub-section (3), it shall be open to the Institution to`
  line `proceed against a director or any other employee who had entered into such contract or arrangement in`
  line `contravention of the provisions of this section for recovery of any loss sustained by it as a result of such`
  line `contract or arrangement.`
  line
  line `(5) Any director or employee of the Institution who had entered into or authorised a contract or`
  line `arrangement in violation of the provisions of this section, shall be liable to pay penalty of a sum of up to`
  line `twenty-five lakh rupees.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (53668)
  sectionNo (20)
  orderNo 20
  title `Performance review of Institution.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53668&sectionno=20&orderno=20&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_20_content:
  string
  line `(1) The performance of the Institution shall, once in every`
  line `five years, be reviewed by an external agency to be appointed by the Central Government.`
  line
  line `(2) The external agency shall review the performance of the Institution for the last five years with`
  line `respect to the purpose and objectives of the Institution as set out in section 4 and shall take into account`
  line `such key performance indicators as may be prescribed.`
  line
  line `(3) The external agency shall submit a report of its findings to the Board which shall forward a copy`
  line `thereof along with action taken, if any, pursuant to such report to the Central Government within a period`
  line `of three months from the date of receipt of the report.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (53669)
  sectionNo (21)
  orderNo 21
  title `Grants and contribution.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53669&sectionno=21&orderno=21&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_21_content:
  string
  line `(1) The Central Government may support the Institution through`
  line `grants or contribution, as and when necessary, in the form of cash or marketable Government securities.`
  line
  line `(2) Without prejudice to the generality of the foregoing, the Central Government shall, by the end of`
  line `the first financial year from the establishment of Institution, grant or contribute an amount of five`
  line `thousand crore rupees to the Institution in the form of cash or marketable Government securities.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (53670)
  sectionNo (22)
  orderNo 22
  title `Concessional rate of Government guarantee.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53670&sectionno=22&orderno=22&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_22_content:
  string
  line `The Government shall prescribe a concessional`
  line `rate of fees, not exceeding 0.1 per cent. at which Government guarantee may be extended to the`
  line `Institution for borrowings from multilateral institutions, sovereign wealth funds, and such other foreign institutions as`
  line `may be prescribed.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (53671)
  sectionNo (23)
  orderNo 23
  title `Hedging costs.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53671&sectionno=23&orderno=23&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_23_content:
  string
  line `Hedging costs in connection with any borrowing of foreign currency by the`
  line `Institution for the purposes of granting loans and advances or its repayment, to insulate the Institution`
  line `from any fluctuations in the rates of exchange, may be reimbursed by the Central Government in part or`
  line `in full.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (53672)
  sectionNo (24)
  orderNo 24
  title `Disposal of profit accruing to Institution, to reserve fund.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53672&sectionno=24&orderno=24&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_24_content:
  string
  line `(1) The Institution shall establish`
  line `a reserve fund to which may be transferred such sums as the Board may deem fit out of the annual profits`
  line `accruing to the Institution:`
  line
  line `Provided that the sums to be transferred under this sub-section shall not be less than twenty per cent.`
  line `of the annual profits accruing to the Institution.`
  line
  line `(2) After making provisions for bad and doubtful debts, depreciation of assets and for all other`
  line `matters for which provision is necessary or expedient or which is usually provided for by bankers and for`
  line `the reserve fund referred to in sub-section (1), and after transferring a part of the profit to such other`
  line `reserves or funds as may be considered appropriate, the Board may out of its net profits propose a`
  line dividend.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (53673)
  sectionNo (25)
  orderNo 25
  title `Preparation of balance sheet and accounts.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53673&sectionno=25&orderno=25&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_25_content:
  string
  line `(1) The balance-sheet and accounts of the`
  line `Institution shall be prepared in such form and manner as may be prescribed.`
  line
  line `(2) The Board shall cause the books and accounts of the Institution to be closed and balanced as on`
  line `the 31st day of March each year or such other date as the Board may determine.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (53674)
  sectionNo (26)
  orderNo 26
  title Audit.
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53674&sectionno=26&orderno=26&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_26_content:
  string
  line `(1) The accounts of the Institution shall be audited by auditors duly qualified to act as`
  line `auditors under sub-section (1) of section 141 of the Companies Act, 2013 (18 of 2013), who shall be`
  line `appointed by the Institution in general meeting of the shareholders out of the panel of auditors approved`
  line `by the Reserve Bank for such term and on such remuneration as the Reserve Bank may fix.`
  line
  line `(2) The auditors shall be supplied with a copy of the annual balance-sheet of the Institution and it`
  line `shall be their duty to examine it together with the accounts and vouchers relating thereto and they shall`
  line `have a list delivered to them of all books kept by the Institution and shall at all reasonable times have`
  line `access to the books, accounts, vouchers and other documents of the Institution.`
  line
  line `(3) The auditors may, in relation to such accounts, examine any director or any officer or other`
  line `employee of the Institution and shall be entitled to require from the Board or officers or other employees`
  line `of the Institution such information and explanation as they may think necessary for the performance of`
  line `their duties.`
  line
  line `(4) The auditors shall make a report to the Institution upon the annual balance-sheet and accounts`
  line `examined by them and in every such report they shall state whether in their opinion the balance-sheet is a`
  line `full and fair balance-sheet containing all necessary particulars and properly drawn up so as to exhibit a`
  line `true and fair view of the state of affairs of the Institution and in case they had called for any explanation`
  line `or information from the Board or any officer or other employee of the Institution, whether it has been`
  line `given and whether it is satisfactory.`
  line
  line `(5) The Institution shall furnish to the Central Government and the Reserve Bank within four months`
  line `from the date on which its accounts are closed and balanced, a copy of its balance-sheet and accounts`
  line `together with a copy of the auditor's report and a report of the working of the Institution during the`
  line `relevant year, and the Central Government shall, as soon as may be after they are received by it, cause the`
  line `same to be laid before each House of Parliament.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (53675)
  sectionNo (27)
  orderNo 27
  title `Returns and report.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53675&sectionno=27&orderno=27&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_27_content:
  string
  line `The Institution shall furnish, from time to time, to the Central Government`
  line `and to the Reserve Bank, such returns as the Central Government or the Reserve Bank may require.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (53676)
  sectionNo (28)
  orderNo 28
  title `Receivables to be held in trust.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53676&sectionno=28&orderno=28&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_28_content:
  string
  line `(1) Any sums received by a financial institution for refinancing`
  line `from the Institution shall, to the extent of the accommodation granted by the Institution and remaining outstanding, be deemed to have been received by the financial institution in trust for the Institution and`
  line `shall accordingly be paid by such financial institution to the Institution.`
  line
  line `(2) Where any accommodation has been granted by the Institution to a financial institution, all`
  line `securities held, or which may be held, by such financial institution on account of any transaction in`
  line `respect of which such accommodation has been granted, shall be held by such financial institution in trust`
  line `for the Institution.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (53677)
  sectionNo (29)
  orderNo 29
  title `Setting up of other development financial institution.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53677&sectionno=29&orderno=29&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_29_content:
  string
  line `(1) Any person who intends to set up a`
  line `development financial institution, in addition to the Institution established under this Act, shall make an`
  line `application to the Reserve Bank for licence.`
  line
  line `(2) The Reserve Bank may in consultation with the Central Government, grant licence subject to such`
  line `criteria, terms and conditions as may be specified by the Reserve Bank by regulations.`
  line
  line `(3) Any institution to which licence is granted under sub-section (2) shall be subject to the provisions`
  line `of the Reserve Bank of India Act, 1934 (2 of 1934) or the Banking Regulation Act, 1949 (10 of 1949), as`
  line `the case may be.`
  line
  line `(4) The regulations made by the Reserve Bank shall apply to the Institution established under this Act`
  line `to such extent as are not inconsistent with the provisions of this Act.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (53678)
  sectionNo (30)
  orderNo 30
  title `Officers and employees.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53678&sectionno=30&orderno=30&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_30_content:
  string
  line `(1) The Institution may appoint such number of officers and other`
  line `employees as it considers necessary or desirable for the efficient performance of its functions and`
  line `determine the terms and conditions of their appointment of service.`
  line
  line `(2) The duties and conduct, terms and other conditions of service including their salaries and`
  line `allowances and the establishment and maintenance of provident fund or any other fund for the benefit of`
  line `the officers and other employees of the Institution appointed under sub-section (1) shall be such as may`
  line `be specified by regulations:`
  line
  line `Provided that the salaries and allowances payable to the officers and employees shall be determined`
  line `by the Nomination and Remuneration Committee guided by the market standards.`
  line
  line `(3) The Institution may depute any officer or any member of its staff for such period and on such`
  line `terms and conditions as it may determine, to any other institution including an infrastructure finance or`
  line `development institution.`
  line
  line `(4) The Institution may receive or take on deputation any officer or other employee from any`
  line `institution including an infrastructure finance or development institution, for such period and on such`
  line `terms and conditions as may be specified by regulations.`
  line
  line `(5) Nothing contained in this section shall empower the Institution to depute any officer or member of`
  line `its staff to any institution on any salary, emoluments or other terms and conditions which is or are less`
  line `favourable to him than that or those to which he is entitled to immediately before such deputation.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (53679)
  sectionNo (31)
  orderNo 31
  title `Powers of Central Government to make rules.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53679&sectionno=31&orderno=31&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_31_content:
  string
  line `(1) The Central Government may, by`
  line `notification, make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) institutions that may hold shares of the Institution under sub-section (3) of section 5;`
  line
  line `(b) the manner of election of directors by shareholders under clause (e) of sub-section (1) of`
  line `section 6;`
  line
  line `(c) the terms and conditions of induction of independent directors to the Board under sub-section`
  line `(5) of section 6;`
  line
  line `(d) the fees and reimbursements in respect of independent directors under sub-section (3), and the`
  line `term of office and other terms and conditions of service of, the Chairperson, Managing Director,`
  line `Deputy Managing Directors and other directors of Board under sub-section (5), of section 9;`
  line
  line `(e) manner of disclosure of interest by members of Board and of committees under sub-section`
  line `(1) of section 16;`
  line
  line `(f) the threshold for determination of beneficial interest by directors of the Institution or any`
  line `relative of such director under the Explanation to sub-section (3) of section 18;`
  line
  line `(g) conditions subject to which the Institution may enter into a contract or an arrangement under`
  line `sub-section (1) of section 19;`
  line
  line `(h) the parameters on the basis of which the external agency shall review the performance of the`
  line `Institution under sub-section (2) of section 20;`
  line
  line `(i) the rate of fees for Government under section 22;`
  line
  line `(j) the form and manner in which the balance-sheet and accounts of the Institution shall be`
  line `prepared under sub-section (1) of section 25;`
  line
  line `(k) any other matter which is to be, or may be, prescribed.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (53680)
  sectionNo (32)
  orderNo 32
  title `Powers of Board to make regulations.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53680&sectionno=32&orderno=32&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_32_content:
  string
  line `(1) The Board may, with the previous approval of the`
  line `Central Government and in consultation with the Reserve Bank, by notification, make regulations not`
  line `inconsistent with the provisions of this Act to provide for all matters for which provision is necessary or`
  line `expedient for the purpose of giving effect to the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the salaries and allowances payable to the Managing Director and Deputy Managing Directors`
  line `under sub-section (4) of section 9;`
  line
  line `(b) the times, places and rules of procedure in regard to the transaction of business of the Board`
  line `under sub-section (1) of section 13;`
  line
  line `(c) the times, places and rules of procedure in regard to the transaction of business of the`
  line `committees and their functions under sub-section (5) of section 15;`
  line
  line `(d) amount for transactions under the proviso to sub-section (1) of section 19;`
  line
  line `(e) the terms and other conditions of service of the officers and employees of the Institution under`
  line `sub-section (2) and the terms and conditions of deputation under sub-section (4), of section 30;`
  line
  line `(f) the mechanism under sub-section (1) of section 39 for the purpose of determining the penalties`
  line `specified under sub-section (5) of section 16 and sub-section (5) of section 19;`
  line
  line `(g) any other matter which is to be, or may be, specified by regulations.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (53681)
  sectionNo (33)
  orderNo 33
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53681&sectionno=33&orderno=33&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_33_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (53682)
  sectionNo (34)
  orderNo 34
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53682&sectionno=34&orderno=34&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_34_content:
  string
  line `No suit, prosecution or other legal proceedings shall`
  line `lie against the Institution or its Chairperson or other directors, employees or officers for anything which is`
  line `done in good faith or intended to be done under this Act, or the rules or the regulations made thereunder,`
  line `including in respect of assets created or transferred to the Institution.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (53683)
  sectionNo (35)
  orderNo 35
  title `Sanction for enquiry, inquiry, investigation and prosecution.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53683&sectionno=35&orderno=35&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_35_content:
  string
  line `(1) No investigation agency,`
  line `including but not limited to Police, Central Bureau of Investigation, Serious Fraud Investigation Office,`
  line `Directorate of Enforcement and such other agencies, shall conduct any enquiry or inquiry or investigation`
  line `into any offence alleged to have been committed under any law, in relation to any recommendation made`
  line `or decision taken by the Chairperson or other directors, employees or officers of the Institution in`
  line `discharge of his official functions or duties, without the previous approval of--`
  line
  line `(a) the Central Government, where the offence is alleged have to been committed by the`
  line `Chairperson or other directors; or`
  line
  line `(b) the Managing Director, where the offence is alleged to have been committed by an employee`
  line `or officer of the Institution:`
  line
  line `Provided that no such approval shall be necessary for cases involving arrest of a person on the spot on`
  line `the charge of accepting or attempting to accept any undue advantage for himself or for any other person:`
  line
  line `Provided further that the Central Government or the Managing Director, as the case may be, shall`
  line `convey its decision within a period of three months, and such period may, for reasons to be recorded in`
  line `writing by the Central Government or the Managing Director, as the case may be, be extended by a`
  line `further period of one month:`
  line
  line `Provided also that failure of the Central Government or the Managing Director to convey its decision`
  line `under this sub-section within the time specified under the second proviso shall not be considered as`
  line `deemed approval for initiation of any enquiry or inquiry or investigation.`
  line
  line `Explanation.--For the purposes of this sub-section, the expression "undue advantage" shall have the`
  line `meaning as assigned to it under the Prevention of Corruption Act, 1988 (49 of 1988).`
  line
  line `(2) No court shall take cognizance of an offence punishable under any law alleged to have been`
  line `committed by the Chairperson or other directors, employees or officers of the Institution for which a`
  line `sanction to conduct any enquiry or inquiry or investigation was granted under sub-section (1), except with`
  line `the previous sanction of--`
  line
  line `(a) the Central Government, where the offence is alleged to be committed by the Chairperson or`
  line `other directors; or`
  line
  line `(b) of the Managing Director, where the offence is alleged to be committed by an employee or`
  line `officer of the Institution:`
  line
  line `Provided that the Central Government or the Managing Director shall, after the receipt of the proposal`
  line `requiring sanction for prosecution under this sub-section, endeavour to convey the decision on such`
  line `proposal within a period of three months from the date of its receipt:`
  line
  line `Provided further that in case where, for the purpose of grant of sanction for prosecution, legal`
  line `consultation is required, such period may, for the reasons to be recorded in writing, be extended by a`
  line `further period of one month:`
  line
  line `Provided also that failure of the Central Government or the Managing Director to convey its decision`
  line `under this sub-section within the time specified shall not be considered as deemed approval for the`
  line `initiation of prosecution.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (53684)
  sectionNo (36)
  orderNo 36
  title `Appointment of directors by Institution to prevail.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53684&sectionno=36&orderno=36&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_36_content:
  string
  line `(1) Where any arrangement entered into`
  line `by the Institution with a borrowing entity while granting loans and advances provides for the appointment`
  line `or nomination by the Institution of one or more directors of such entity, such provision and any`
  line `appointment of directors made in pursuance thereof shall be valid and effective notwithstanding anything to the contrary contained in the Companies Act, 2013 (18 of 2013), or in any other law for the time being`
  line `in force or in the memorandum and articles of association or any other instrument relating to the entity,`
  line `and any provision regarding share qualification, age limit, number of directorships, removal from office`
  line `of directors and such like conditions contained in any such law or instrument aforesaid, shall not apply to`
  line `any director appointed by the Institution in pursuance of the arrangement as aforesaid.`
  line
  line `(2) Any director appointed as aforesaid shall---`
  line
  line `(a) be deemed to be an independent director under the Companies Act, 2013 (18 of 2013) for the`
  line `purpose of immunities available to independent directors;`
  line
  line `(b) hold office during the pleasure of the Institution and may be removed or substituted by any`
  line `person by order in writing of the Institution;`
  line
  line `(c) not incur any obligation or liability by reason only of his being a director or for anything done`
  line `or omitted to be done in good faith in the discharge of his duties as a director or anything in relation`
  line thereto;
  line
  line `(d) not be liable to retirement by rotation and shall not be taken into account for computing the`
  line `number of directors liable to such retirement.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (53685)
  sectionNo (37)
  orderNo 37
  title `Validity of loan or advance not to be questioned.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53685&sectionno=37&orderno=37&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_37_content:
  string
  line `(1) Notwithstanding anything to the`
  line `contrary contained in any other law for the time being in force, the validity of any loan or advance granted`
  line `by the Institution in pursuance of the provisions of this Act shall not be called in question merely on the`
  line `ground of non-compliance with the requirements of such other law as aforesaid or of any resolution,`
  line `contract, memorandum, articles of association or other instrument.`
  line
  line `(2) Nothing in this section shall enable any company to obtain any loan or advance where the`
  line `instrument relating to the constitution of such company does not empower such company to do so.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (53686)
  sectionNo (38)
  orderNo 38
  title `Obligations as to fidelity and secrecy.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53686&sectionno=38&orderno=38&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_38_content:
  string
  line `(1) The Institution shall not, except as otherwise`
  line `required by this Act or by any other law, divulge any information relating to, or to the affairs of, its`
  line `constituents except in circumstances in which it is, in accordance with the law or practice and usage`
  line `customary among bankers, necessary or appropriate for the Institution to divulge such information.`
  line
  line `(2) Every director, member of a committee, auditor, officer or other employee of the Institution or of`
  line `the Reserve Bank, whose services are utilised by the Institution under the provisions of this Act shall,`
  line `before entering upon his duties, make a declaration of fidelity and secrecy in the form set out in the First`
  line Schedule.
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (53687)
  sectionNo (39)
  orderNo 39
  title Adjudication.
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53687&sectionno=39&orderno=39&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_39_content:
  string
  line `(1) The Board shall make regulations for setting up a mechanism for the purpose`
  line `of determining the penalties specified under sub-section (5) of section 16 and sub-section (5) of section`
  line 19.
  line
  line `(2) The regulations shall provide for a reasonable opportunity of being heard to the director or an`
  line `employee against whom a complaint is made for violating the provisions of section 16 or section 19, as`
  line `the case may be, and a right to prefer an appeal against any order imposing the penalty.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (53688)
  sectionNo (40)
  orderNo 40
  title `Indemnity of directors.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53688&sectionno=40&orderno=40&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_40_content:
  string
  line `(1) Every director shall be indemnified by the Institution against all`
  line `losses and expenses incurred by him in, or in relation to, the discharge of his duties, except such as are`
  line `caused by his own wilful act or default.`
  line
  line `(2) A director shall not be responsible for any other director or for any officer or other employee of`
  line `the Institution or for any loss or expenses resulting to the Institution from the insufficiency or deficiency`
  line `of the value of, or title to, any property or security acquired or taken on behalf of the Institution or the`
  line `insolvency or wrongful act of any debtor or any person under obligation to the Institution or anything`
  line `done in good faith in the execution of the duties of his office or in relation thereto.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (53689)
  sectionNo (41)
  orderNo 41
  title `Bankers’ Books of Evidence Act, 1891 to apply in relation to the Institution.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53689&sectionno=41&orderno=41&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_41_content:
  string
  line `The Bankers'`
  line `Books Evidence Act, 1891 (18 of 1891), shall apply in relation to the Institution as if it were a bank as`
  line `defined in section 2 of that Act.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (53690)
  sectionNo (42)
  orderNo 42
  title `Section 34A and 36AD of the Banking Regulation Act, 1949 to apply to Institution.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53690&sectionno=42&orderno=42&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_42_content:
  string
  line `The provisions of sections 34A and 36AD of the Banking Regulation Act, 1949 (10 of`
  line `1949) shall apply to the Institution.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (53691)
  sectionNo (43)
  orderNo 43
  title `Liquidation of Institutions.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53691&sectionno=43&orderno=43&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_43_content:
  string
  line `No provision of law relating to the winding up of companies shall`
  line `apply to the Institution and the Institution shall not be placed in liquidation save by order of the Central`
  line `Government and in such manner as it may direct.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (53692)
  sectionNo (44)
  orderNo 44
  title `Powers of Central Government to issue directions.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53692&sectionno=44&orderno=44&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_44_content:
  string
  line `Without prejudice to the foregoing`
  line `provisions of this Act, the Institution shall, in the performance of its functions under this Act, be bound by`
  line `such directions on questions of policy as the Central Government may give in writing to it from time to`
  line time.
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (53693)
  sectionNo (45)
  orderNo 45
  title `Overriding effect of this Act.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53693&sectionno=45&orderno=45&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_45_content:
  string
  line `The provisions of this Act shall have effect, notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force or any instrument`
  line `having effect by virtue of any such law.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (53694)
  sectionNo (46)
  orderNo 46
  title `Power to remove difficulties.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53694&sectionno=46&orderno=46&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_46_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions`
  line `or give such directions not inconsistent with the provisions of this Act, as appears to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of three years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (53695)
  sectionNo (47)
  orderNo 47
  title `Amendment of Act 2 of 1934.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53695&sectionno=47&orderno=47&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_47_content:
  string
  line `The Reserve Bank of India Act, 1934 shall be amended in the`
  line `manner specified in the Second Schedule.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (53696)
  sectionNo (48)
  orderNo 48
  title `Amendment of Act 10 of 1949.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00047_202117_1619088293867&sectionId=53696&sectionno=48&orderno=48&orgactid=AC_CEN_2_33_00047_202117_1619088293867
obj_root_law_sections_48_content:
  string
  line `The Banking Regulation Act, 1949 shall be amended in the`
  line `manner specified in the Third Schedule.`
obj_root_law_sections_48_footnotes:
