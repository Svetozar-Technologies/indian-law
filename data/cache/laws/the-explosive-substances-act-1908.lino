obj_root_law_sections_1:
  sectionId (36513)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and application.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00051_190806_1545374878109&sectionId=36513&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00051_190806_1545374878109
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Explosive Substances`
  line `Act, 1908.`
  line
  line ^1
  line `[(2) It extends to the whole of India ^2`
  line `*** and applies also to citizens of India ^3`
  line `[outside India].]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for sub-section (2).`
  line
  line `2. The words and letter "except Part B States" omitted by Act 3 of 1951, s. 3 and the Schedule.`
  line
  line `3. Subs. by s. 3 and the Schedule, ibid., for "wherever they may be".`
obj_root_law_sections_2:
  sectionId (36514)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes `1. Subs. by Act 54 of 2001, s. 2, for sections 2 to 5 (w.e.f. 1-2-2002).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00051_190806_1545374878109&sectionId=36514&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00051_190806_1545374878109
obj_root_law_sections_2_content:
  string
  line `^1In this Act—`
  line
  line `(a) the expression "explosive substance" shall be deemed to include any materials for`
  line `making any explosive substance; also any apparatus, machine, implement or material used,`
  line `or intended to be used, or adapted for causing, or aiding in causing, any explosion in or with`
  line `any explosive substance; also any part of any such apparatus, machine or implement;`
  line
  line `(b) the expression "special category explosive substance" shall be deemed to include`
  line `research development explosive (RDX), penta erythritol tetra nitrate (PETN), high melting`
  line `explosive (HMX), tri nitro toluene (TNT), low temperature plastic explosive (LTPE),`
  line `composition exploding (CE) (2, 4, 6 phenyl methyl nitramine or tetryl), OCTOL (mixture of`
  line `high melting explosive and tri nitro toluene), plastic explosive kirkee -1 (PEK-1) and`
  line `RDX/TNT compounds and other similar type of explosives and a combination thereof and`
  line `remote control devices causing explosion and any other substance and a combination`
  line `thereof which the Central Government may, by notification in the Official Gazette, specify`
  line `or the purposes of this Act.`
obj_root_law_sections_3:
  sectionId (36515)
  sectionNo (3)
  orderNo 3
  title `Punishment for causing explosion likely to endanger life or property.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00051_190806_1545374878109&sectionId=36515&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00051_190806_1545374878109
obj_root_law_sections_3_content:
  string
  line `Any person who`
  line `unlawfully and maliciously causes by—`
  line
  line `(a) any explosive substance an explosion of a nature likely to endanger life or to cause serious`
  line `injury to property shall, whether any injury to person or property has been actually caused or not, be`
  line `punished with imprisonment for life, or with rigorous imprisonment of either description which shall`
  line `not be less than (ten years, and shall also be liable to fine;`
  line
  line `(b) any special category explosive substance an explosion of a nature likely to endanger life or to`
  line `cause serious injury to property shall, whether any injury to person or property has been actually`
  line `caused or not, be punished with death, or rigorous imprisonment for life, and shall also be liable to`
  line fine.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36520)
  sectionNo (4)
  orderNo 4
  title `Punishment for attempt to cause explosion, or for making or keeping explosive with intent to endanger life or property.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00051_190806_1545374878109&sectionId=36520&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00051_190806_1545374878109
obj_root_law_sections_4_content:
  string
  line `Any person who unlawfully and maliciously—`
  line
  line `(a) does any act with intent to cause by an explosive substance or special category explosive`
  line `substance, or conspires lo cause by an explosive substance or special category explosive substance,`
  line `an explosion of a nature likely to endanger life or to cause serious injury to property; or`
  line
  line `(b) makes or has in his possession or under his control any explosive substance or special`
  line `category explosive substance with intent by means thereof to endanger life, or cause serious injury to`
  line `property, or to enable any other person by means thereof to endanger life or cause serious injury to`
  line `property in India,`
  line
  line `shall, whether any explosion does or does not take place and whether any injury to person or property has`
  line `been actually caused or not, be punished,—`
  line
  line `(i) in the case of any explosive substance, with imprisonment for life, or with imprisonment`
  line `of either description for a term which may extend to ten years, and shall also be liable to fine;`
  line
  line `(ii) in the case of any special category explosive substance, with rigorous imprisonment for`
  line `life, or with rigorous imprisonment for a term which may extend to ten years, and shall also be`
  line `liable to fine.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (36517)
  sectionNo (5)
  orderNo 5
  title `Punishment for making or possessing explosives under suspicious circumstances.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00051_190806_1545374878109&sectionId=36517&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00051_190806_1545374878109
obj_root_law_sections_5_content:
  string
  line Any
  line `person who makes or knowingly has in his possession or under his control any explosive substance or`
  line `special category explosive substance, under such circumstances as to give rise to a reasonable suspicion`
  line `that he is not making it or does not have it in his possession or under his control for a lawful object, shall,`
  line `unless he can show that he made it or had it in his possession or under his control for a lawful object, be`
  line punished,—
  line
  line `(a) in the case of any explosive substance, with imprisonment for a term which may extend to ten`
  line `years, and shall also be liable to fine;`
  line
  line `(b) in the case of any special category explosive substance, with rigorous imprisonment for life,`
  line `or with rigorous imprisonment for a term which may extend to ten years, and shall also be liable to`
  line fine.]
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36518)
  sectionNo (6)
  orderNo 6
  title `Punishment of abettors.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00051_190806_1545374878109&sectionId=36518&sectionno=6&orderno=6&orgactid=AC_CEN_5_23_00051_190806_1545374878109
obj_root_law_sections_6_content:
  string
  line `Any person who by the supply or solicitation for money, the providing`
  line `of premises, the supply of materials, or in any manner whatsoever, procures, counsels, aids, abets, or is`
  line `accessory to, the commission of any offence under this Act shall be punished with the punishment`
  line `provided for the offence.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (36519)
  sectionNo (7)
  orderNo 7
  title `Restriction on trial of offences.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00051_190806_1545374878109&sectionId=36519&sectionno=7&orderno=7&orgactid=AC_CEN_5_23_00051_190806_1545374878109
obj_root_law_sections_7_content:
  string
  line `No court shall proceed to the trial of any person for an offence`
  line `against this Act except with the consent of ^1`
  line `*** the ^2`
  line `[District Magistrate].`
obj_root_law_sections_7_footnotes:
  string
  line `1. The words "the L.G. or" rep. by the A.O. 1937.`
  line
  line `2. Subs. by Act 54 of 2001, s. 3, for "Central Government" (w.e.f. 1-2-2002).`
