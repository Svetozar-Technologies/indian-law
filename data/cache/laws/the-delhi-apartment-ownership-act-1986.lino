obj_root_law:
  object
  (str slug) (str the-delhi-apartment-ownership-act-1986)
  (str handle) (str 1805)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Delhi Apartment Ownership Act, 1986`)
  (str actNumber) (str 58)
  (str enactmentDate) (str 1986-12-23)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1805`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `दिल्‍ली अपार्टमेंट स्‍वामित्‍व अधिनियम,1986`)
  (str actYear) (str 1986)
  (str ministry) (str `Ministry of Housing and Urban Affairs`)
  (str longTitle) (str `An Act to provide for the ownership of an individual apartment in a multi-storeyed building and of an undivided interest in the common areas and facilities appurtenant to such apartment and to make such apartment and interest heritable and transferable and for matters connected therewith or incidental thereto.`)
  (str notification) (str `Administrator notification`)
  (str fetchedAt) (str `2026-05-08T23:10:31.014Z`)
