obj_root_law:
  slug the-delhi-apartment-ownership-act-1986
  handle (1805)
  collectionHandle 123456789/1362
  title `The Delhi Apartment Ownership Act, 1986`
  actNumber (58)
  enactmentDate 1986-12-23
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1805`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `दिल्‍ली अपार्टमेंट स्‍वामित्‍व अधिनियम,1986`
  actYear (1986)
  ministry `Ministry of Housing and Urban Affairs`
  longTitle `An Act to provide for the ownership of an individual apartment in a multi-storeyed building and of an undivided interest in the common areas and facilities appurtenant to such apartment and to make such apartment and interest heritable and transferable and for matters connected therewith or incidental thereto.`
  notification `Administrator notification`
  fetchedAt `2026-05-08T23:10:31.014Z`
  translations obj_root_law_translations
