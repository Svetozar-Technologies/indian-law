obj_root_law:
  object
  (str slug) (str the-inchek-tyres-limited-and-national-rubber-manufacturers-limited-nationalisation-act-1984)
  (str handle) (str 1822)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Inchek Tyres Limited and National Rubber Manufacturers Limited (Nationalisation) Act, 1984`)
  (str actNumber) (str 17)
  (str enactmentDate) (str 1984-03-31)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1822`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `इनचैक टायर्स लिमिटेड और नेशनल रबर मैन्‍यूफैक्‍चरर्स लिमिटेड (राष्‍ट्रीयकरण) अधिनियम,1984`)
  (str actYear) (str 1984)
  (str ministry) (str `Ministry of Heavy Industries and Public Enterprises`)
  (str department) (str `Department of Heavy Industry`)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the undertakings of the Inchek Tyres Limited and the National Rubber Manufacturers Limited, with a view to securing the proper management of such undertakings so as to subserve the interests of the general public by ensuring the continued manufacture, production and distribution of tyres, tubes and other rubber goods which are essential to the needs of the economy of the country and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 14-02-1984)
  (str fetchedAt) (str `2026-05-08T23:24:42.097Z`)
  (str translations) obj_root_law_translations
