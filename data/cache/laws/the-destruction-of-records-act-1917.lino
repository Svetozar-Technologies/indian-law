  (str title) (str `अभिलेख नाश-करण अधिनियम,1917`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2359/3/H1917-5.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:43:18.077Z`)
  (str pageCount) (int 2)
