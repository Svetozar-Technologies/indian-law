  (str content) (str `[Application of Act to Acts made by the Governor-General.]
Rep. by the A.O. 1937. Earlier
Inserted by Act 11 of 1923, s. 2 and the First Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00050_189710_1523337761854&sectionId=43757&sectionno=30A&orderno=35&orgactid=AC_CEN_3_20_00050_189710_1523337761854)
