obj_root_law_sections_1:
  object
  (str sectionId) (str 38530)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `(1) This Act may be called the General Clauses Act, 1897; ^1
***

^2*****`)
  (str footnotes) (str `1. The word "and" rep. by Act 10 of 1914, s. 3 and the Second Schedule.

2. Sub-section (2) rep. by s. 3 and the Second Schedule, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00050_189710_1523337761854&sectionId=38530&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00050_189710_1523337761854)
