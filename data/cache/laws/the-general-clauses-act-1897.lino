  (str orderNo) (int 36)
  (str title) (str [Repealed.].)
  (str content) (str `[Construction of references to Local Government of a
Province.
] Rep. by the A.O. 1937. Earlier
Inserted by Act 31 of 1920, s. 2 and the First Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00050_189710_1523337761854&sectionId=38564&sectionno=31&orderno=36&orgactid=AC_CEN_3_20_00050_189710_1523337761854)
