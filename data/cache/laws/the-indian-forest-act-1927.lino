  sectionNo 85A
  orderNo 87
  title `Saving for rights of Central Government.`
  content obj_root_law_sections_85_a_content
  footnotes `1. Subs.,ibid., for section 85A.Earlier it was inserted by the A.O. 1937.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_0_00013_192716_1523350029217&sectionId=31947&sectionno=85A&orderno=87&orgactid=AC_CEN_16_0_00013_192716_1523350029217
obj_root_law_sections_85_a_content:
  string
  line `^1[85A. Saving for rights of Central Government.--Nothing in this Act shall authorise a`
  line `Government of any State to make any order or do anything in relation to any property not vested in that`
  line `State or otherwise prejudice any rights of the Central Government or the Government of any other State`
  line `without the consent of the Government concerned.]`
