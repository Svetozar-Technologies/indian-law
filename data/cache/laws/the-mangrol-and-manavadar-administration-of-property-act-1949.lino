obj_root_law_sections_1:
  sectionId (47726)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47726&sectionno=1&orderno=1&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Mangrol and Manavadar (Administration of Property)`
  line `Act, 1949.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (47727)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47727&sectionno=2&orderno=2&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_2_content:
  string
  line `In this Act, "Manager" means the Manager for the time being of the State of Mangrol`
  line `or the State of Manavadar, as the case may be, appointed by, or on behalf of, the Central Government.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47728)
  sectionNo (3)
  orderNo 3
  title `Vesting of property in Manager.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47728&sectionno=3&orderno=3&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_3_content:
  string
  line `Notwithstanding anything contained in any other law for the`
  line `time being in force or in any instrument or other document whatsoever, the properties described in the`
  line `Schedule, which stand in the name of the Sheikh of Mangrol or in the name of the Khan of Manavadar,`
  line `whether in his personal capacity or as the legal representative of any deceased person or in any other`
  line `capacity, or the Begum Sahiban Fatma, or of any karbhari or other officer of Mangrol or Manavadar in`
  line `his official capacity, or in the names of more than one of them, shall be deemed to have vested and always`
  line `to have been vested on and from the 1st day of November, 1947, as follows, namely:--`
  line
  line `(a) if the properties are included in Part I of the Schedule, then in the Manager of the State of`
  line `Mangrol, and`
  line
  line `(b) if the properties are included in Part II of the Schedule, then in the Manager of the State of`
  line Manavadar.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47729)
  sectionNo (4)
  orderNo 4
  title `Powers of Manager.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47729&sectionno=4&orderno=4&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_4_content:
  string
  line `The Manager shall have and exercise, in relation to properties vested in`
  line `him under section 3, all the rights, powers and authority which a full owner has or exercises in relation to`
  line `his own property:`
  line
  line `Provided that where any of the said properties was, immediately before the 1st day of`
  line `November, 1947, subject to any trust lawfully created, the Manager shall, in the exercise of his powers in`
  line `relation to such property be bound by the terms of that trust.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47730)
  sectionNo (5)
  orderNo 5
  title `Payment to Manager to be a discharge of obligations.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47730&sectionno=5&orderno=5&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_5_content:
  string
  line `Any payment made to the Manager in`
  line `the discharge of any of the obligations in relation to any of the properties described in the Schedule shall`
  line `be a full discharge to the person or authority making the payment from all liability in respect of such`
  line payment.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47731)
  sectionNo (6)
  orderNo 6
  title `Issue of duplicate securities.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47731&sectionno=6&orderno=6&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_6_content:
  string
  line `(1) Where for any reason any of the Government securities`
  line `described in the Schedule is not in the custody of the Manager in whom it has vested under the provisions`
  line `of this Act, the Manager may make an application to the Reserve Bank of India for the issue of a`
  line `duplicate security in lieu thereof.`
  line
  line `(2) When an application under sub-section (1) has been made, then, notwithstanding anything`
  line `contained in any other law for the time being in force, the Reserve Bank of India shall issue a duplicate`
  line `security to the Manager as if the original security had been lost.`
  line
  line `(3) Any duplicate security issued under the provisions of this section shall have the same effect as if it`
  line `had been issued under section 11 of the Public Debt (Central Government) Act, 1944 (18 of 1944).`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47732)
  sectionNo (7)
  orderNo 7
  title `Transfers otherwise than by Manager void.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47732&sectionno=7&orderno=7&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_7_content:
  string
  line `Any transfer or other disposition of any property`
  line `described in the Schedule made on or after the 1st day of November, 1947, by any person other than the`
  line `Manager or without his consent shall be, and shall always be deemed to have been, void and of no effect.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47733)
  sectionNo (8)
  orderNo 8
  title `Power to call for information.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47733&sectionno=8&orderno=8&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_8_content:
  string
  line `(1) Where the Central Government is of opinion that any person`
  line `is in possession of any property which belongs to the State of Mangrol or the State of Manavadar, it may,`
  line `by notice in writing, require such person to furnish such information as it may consider necessary for the`
  line `purpose of determining whether the property is property belonging to the State of Mangrol or the State of`
  line `Manavadar, as the case may be.`
  line
  line `(2) If any person to whom a notice is sent under sub-section (1)fails to comply therewith he shall be`
  line `punishable with imprisonment which may extend to three months or with fine which may extend to one`
  line `thousand rupees or with both.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (47734)
  sectionNo (9)
  orderNo 9
  title `Bar of jurisdiction of Court.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47734&sectionno=9&orderno=9&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_9_content:
  string
  line `(1) No Court shall have jurisdiction to entertain any civil or`
  line `criminal proceeding in relation to any of the properties described in the Schedule or to enforce any`
  line `liability in respect thereof save at the instance of the Manager.`
  line
  line `(2) Nothing in this section shall be deemed to prohibit the submission to the Central Government by`
  line `any person other than the Manager of any claim in relation to any such property and the decision of the`
  line `Central Government on such claim shall be final and shall not be called in question in any Court.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47735)
  sectionNo (10)
  orderNo 10
  title `. Power of the Central Government to add to the Schedule.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47735&sectionno=10&orderno=10&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_10_content:
  string
  line `(1) The Central Government may,`
  line `from time to time, by notification in the Official Gazette, amend or alter the Schedule.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, the Central`
  line `Government may, by notification as aforesaid, add to the items of property included in Parts I and II of`
  line `the Schedule any other item which in its opinion represents property belonging to the State of Mangrol or`
  line `the State of Manavadar, as the case may be, and on the issue of such notification any property specified in`
  line `the notification shall be deemed to be and always to have been included in Part I or Part II of the`
  line `Schedule, as the case may be.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (47736)
  sectionNo (11)
  orderNo 11
  title `Bar of legal proceedings.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47736&sectionno=11&orderno=11&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_11_content:
  string
  line `No suit, prosecution or other legal proceeding shall lie against the`
  line `Central Government, the Reserve Bank of India, any bank or company mentioned in the Schedule, or the`
  line `Manager or any other person for anything which is in good faith done or intended to be done in pursuance`
  line `of any of the provisions of this Act.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (47737)
  sectionNo (12)
  orderNo 12
  title Repeal.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00011_194902_1517807322792&sectionId=47737&sectionno=12&orderno=12&orgactid=AC_CEN_17_19_00011_194902_1517807322792
obj_root_law_sections_12_content:
  string
  line `(1) The Mangrol and Manavadar (Administration of Property)`
  line `Ordinance, 1948 (Ord. 22 of 1948), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken in exercise of any power`
  line `conferred by or under the said Ordinance shall be deemed to have been done or taken in exercise of the`
  line `powers conferred by or under this Act, as if this Act had come into force on the 16th day of August, 1948.`
obj_root_law_sections_12_footnotes:
  string
  line
