  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  sourcePage 5
obj_root_law_sections_5_content:
  string
  line 5
  line `( 3 ) No power under sub-section ( 1 ) or sub-section ( 2 ) shall be exercised by the Central`
  line `Government or, as the case may be, the State Government after the expiry of three years from the`
  line `appointed day.`
  line `( 4 ) Any order made under sub-section ( 1 ) or sub-section ( 2 ) may be so made as to be retrospective`
  line `to any date not earlier than the appointed day.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  kind page
  sectionId pdf-page-6
  sectionNo (6)
