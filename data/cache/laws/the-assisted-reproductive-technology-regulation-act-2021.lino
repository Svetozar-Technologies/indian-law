obj_root_law_sections_1:
  sectionId (62770)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 25th January, 2022, vide notification No. S.O. 291(E), dated 20th January, 2022, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62770&sectionno=1&orderno=1&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Assisted`
  line `Reproductive Technology (Regulation) Act, 2021.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_2:
  sectionId (62771)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62771&sectionno=2&orderno=2&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires, ---`
  line
  line `(a) "assisted reproductive technology" with its grammatical variations and cognate expressions, means all techniques that attempt to obtain a pregnancy by handling the sperm or the oocyte outside the human body and transferring the gamete or the embryo into the reproductive system of a woman;`
  line
  line `(b) "assisted reproductive technology bank" means an organisation which shall be responsible for collection of gametes, storage of gametes and embryos and supply of gametes to the assisted reproductive technology clinics or their patients;`
  line
  line `(c) "assisted reproductive technology clinic" means any premises equipped with requisite facilities and medical practitioners registered with the National Medical Commission for carrying out the procedures related to the assisted reproductive technology;`
  line
  line `(d) "child" means any individual born through the use of the assisted reproductive technology;`
  line
  line `(e) "commissioning couple" means an infertile married couple who approach an assisted reproductive technology clinic or assisted reproductive technology bank for obtaining the services authorised of the said clinic or bank;`
  line
  line `(f) "embryo" means a developing or developed organism after fertilisation till the end of fifty-six days from the day of fertilisation;`
  line
  line `(g) "gamete" means sperm and oocyte;`
  line
  line `(h) "gamete donor" means a person who provides sperm or oocyte with the objective of enabling an infertile couple or woman to have a child;`
  line
  line `(i) "gynaecologist" shall have the same meaning as assigned to it in the Pre-conception and Pre-natal Diagnostic Techniques (Prohibition of Sex Selection) Act, 1994 (57 of 1994);`
  line
  line `(j) "infertility" means the inability to conceive after one year of unprotected coitus or other proven medical condition preventing a couple from conception;`
  line
  line `(k) "National Board" means the National Assisted Reproductive Technology and Surrogacy Board to be constituted under sub-section (1) of section 17 of the Surrogacy Act;`
  line
  line `(l) "National Registry" means the National Assisted Reproductive Technology and Surrogacy Registry established under section 9;`
  line
  line `(m) "notification" means a notification published in the Official Gazette;`
  line
  line `(n) "patients" means an individual or couple who comes to any registered assisted reproductive technology clinic for management of infertility;`
  line
  line `(o) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(p) "appropriate authority" means the authority appointed under section 12;`
  line
  line `(q) "regulations" means the regulations made by the National Board under this Act;`
  line
  line `(r) "sperm" means the mature male gamete;`
  line
  line `(s) "State Board" means a State Assisted Reproductive Technology and Surrogacy Board to be constituted under section 26 of the Surrogacy Act;`
  line
  line `(t) "Surrogacy Act" means the Surrogacy (Regulation) Act, 2021; and`
  line
  line `(u) "woman" means any woman above the age of twenty-one years who approaches an assisted reproductive technology clinic or assisted reproductive technology bank for obtaining the authorised services of the clinic or bank.`
  line
  line `(2) The expressions "clinics" and "banks" occurring in this Act shall be construed as "assisted reproductive technology clinics" and "assisted reproductive technology banks".`
  line
  line `(3) Words and expressions used herein and not defined in this Act but defined in the Surrogacy (Regulation) Act shall have the meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (62816)
  sectionNo (3)
  orderNo 3
  title `National Assisted Reproductive Technology and Surrogacy Board.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62816&sectionno=3&orderno=3&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_3_content:
  string
  line `The National`
  line `Assisted Reproductive Technology and Surrogacy Board to be constituted under`
  line `sub-section (1) of section 17 of the Surrogacy Act shall be the National Board for the`
  line `purposes of this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (62773)
  sectionNo (4)
  orderNo 4
  title `Application of provisions of Surrogacy Act with respect to National Board.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62773&sectionno=4&orderno=4&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_4_content:
  string
  line `Subject to`
  line `the provisions of this Act and the rules made thereunder, the provisions of the Surrogacy Act relating`
  line to---
  line
  line `(i) constitution of the National Assisted Reproductive Technology and Surrogacy Board;`
  line
  line `(ii) term of office of Members of the National Board;`
  line
  line `(iii) meetings of the National Board;`
  line
  line `(iv) vacancies, etc., not to invalidate proceedings of the National Board;`
  line
  line `(v) disqualifications for appointment as Member of the National Board;`
  line
  line `(vi) temporary association of persons with the National Board for particular purposes;`
  line
  line `(vii) authentication of orders and other instruments of the National Board; and`
  line
  line `(viii) eligibility of Members of the National Board for re-appointment,`
  line
  line `shall, mutatis mutandis, apply, so far as may be, in relation to assisted reproductive technology as`
  line `they apply in relation to surrogacy, as if they are enacted under this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (62774)
  sectionNo (5)
  orderNo 5
  title `Powers and functions of National Board.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62774&sectionno=5&orderno=5&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_5_content:
  string
  line `The National Board shall exercise and discharge`
  line `the following powers and functions, namely:—`
  line
  line `(a) to advise the Central Government on policy matters relating to the assisted reproductive`
  line technology;
  line
  line `(b) to review and monitor the implementation of the Act, rules and regulations made`
  line `thereunder and recommend to the Central Government, any suitable changes therein;`
  line
  line `(c) to lay down code of conduct to be observed by persons working at clinics and banks, to set`
  line `the minimum standards of physical infrastructure, laboratory and diagnostic equipment and expert`
  line `manpower to be employed by clinics and banks;`
  line
  line `(d) to oversee the performance of various bodies constituted under this Act and take`
  line `appropriate steps to ensure their effective performance;`
  line
  line `(e) to supervise the functioning of the National Registry and liaison with the State Boards;`
  line
  line `(f) to pass orders as per the provisions made under this Act; and`
  line
  line `(g) such other powers and functions as may be prescribed.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (62817)
  sectionNo (6)
  orderNo 6
  title `State Assisted Reproductive Technology and Surrogacy Board.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62817&sectionno=6&orderno=6&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_6_content:
  string
  line `The State Assisted`
  line `Reproductive Technology and Surrogacy Board to be constituted under section 26 of the Surrogacy Act shall be the State Board for the purposes of this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (62776)
  sectionNo (7)
  orderNo 7
  title `Application of provisions of Surrogacy Act with respect to State Board.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62776&sectionno=7&orderno=7&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_7_content:
  string
  line `Subject to the`
  line `provisions of this Act and the rules made thereunder, the provisions of the Surrogacy Act relating to---`
  line
  line `(i) constitution of the State Assisted Reproductive Technology and Surrogacy Board;`
  line
  line `(ii) composition of the State Board;`
  line
  line `(iii) term of office of members of the State Board;`
  line
  line `(iv) meetings of the State Board;`
  line
  line `(v) vacancies, etc., not to invalidate proceedings of the State Board;`
  line
  line `(vi) disqualifications for appointment as member of the State Board;`
  line
  line `(vii) temporary association of persons with the State Board for particular purposes;`
  line
  line `(viii) authentication of orders and other instruments of the State Board; and`
  line
  line `(ix) eligibility of member of the State Board for re-appointment,`
  line
  line `shall, mutatis mutandis, apply, so far as may be, in relation to assisted reproductive technology as they`
  line `apply in relation to surrogacy, as if they are enacted under this Act.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (62777)
  sectionNo (8)
  orderNo 8
  title `Powers and functions of State Board.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62777&sectionno=8&orderno=8&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_8_content:
  string
  line `(1) Subject to the provisions of this Act and the rules`
  line `and regulations made thereunder, the State Board shall have the responsibility to follow the policies and plans laid by the National Board for clinics and banks in the State.`
  line
  line `(2) Without prejudice to the generality of the provisions contained in sub-section (1), the State`
  line `Board, taking into account the recommendations, policies and regulations of the National Board,`
  line shall—
  line
  line `(a) co-ordinate the enforcement and implementation of the policies and guidelines for assisted`
  line `reproduction; and`
  line
  line `(b) such other powers and functions as may be prescribed.`
  line
  line `(3) In the exercise of its functions under this Act, the State Board shall give such directions or pass such orders as directed by the National Board.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (62818)
  sectionNo (9)
  orderNo 9
  title `Establishment of National Registry of clinics and banks.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62818&sectionno=9&orderno=9&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_9_content:
  string
  line `The Central Government may,`
  line `within a period of ninety days from the date of commencement of this Act, by notification, establish for the purposes of this Act and Surrogacy Act, a Registry to be called the National Assisted Reproductive Technology and Surrogacy Registry`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (62779)
  sectionNo (10)
  orderNo 10
  title `Composition of National Registry.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62779&sectionno=10&orderno=10&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_10_content:
  string
  line `The National Registry referred to in section 9 shall`
  line `consist of such scientific, technical, administrative and supportive staff and the terms and conditions of their service shall be such as may be prescribed.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (62780)
  sectionNo (11)
  orderNo 11
  title `Functions of National Registry.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62780&sectionno=11&orderno=11&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_11_content:
  string
  line `The National Registry shall discharge the following`
  line `functions, namely:—`
  line
  line `(a) it shall act as a central database in the country through which the details of all the clinics and banks of the country including nature and types of services provided by them, outcome of the services and other relevant information shall be obtained on regular basis;`
  line
  line `(b) it shall assist the National Board in its functioning by providing the data generated from the central database of the Registry;`
  line
  line `(c) the data generated from the National Registry shall be utilised by the National Board for making policies, guidelines and shall help in identifying new research areas and conducting research in the area of assisted reproduction and other related fields in the country; and`
  line
  line `(d) such other functions as may be prescribed.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (62781)
  sectionNo (12)
  orderNo 12
  title `Appointment of appropriate authority.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62781&sectionno=12&orderno=12&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_12_content:
  string
  line `(1) The Central Government shall, within a`
  line `period of ninety days from the date of commencement of this Act, by notification, appoint one or more`
  line `appropriate assisted reproductive technology and surrogacy authorities for each of the Union territories`
  line `for the purposes of this Act and the Surrogacy Act.`
  line
  line `(2) The State Government shall, within a period of ninety days from the date of commencement`
  line `of this Act, by notification, appoint one or more appropriate assisted reproductive technology and`
  line `surrogacy authorities for the whole or any part of the State for the purposes of this Act and the`
  line `Surrogacy Act.`
  line
  line `(3) The appropriate authority, under sub-section (1) or sub-section (2), shall, ---`
  line
  line `(a) when appointed for the whole of the State or the Union territory, consist of---`
  line
  line `(i) an officer of or above the rank of the Joint Secretary of the Health and Family Welfare Department--- Chairperson, ex officio;`
  line
  line `(ii) an officer of or above the rank of the Joint Director of the Health and Family Welfare Department --- Vice Chairperson, ex officio;`
  line
  line `(iii) an eminent woman representing women's organisation---member;`
  line
  line `(iv) an officer of Law Department of the State or the Union territory concerned not below the rank of a Deputy Secretary---member, ex officio; and`
  line
  line `(v) an eminent registered medical practitioner---member:`
  line
  line `Provided that any vacancy occurring therein shall be filled within one month of the`
  line `occurrence of such vacancy;`
  line
  line `(b) when appointed for any part of the State or the Union territory, the officers of such other rank as the State Government or the Central Government, as the case may be, may deem fit.`
  line
  line `(4) The members of appropriate authority, other than ex officio members, shall receive only`
  line `compensatory travelling expenses for attending the meetings of such Authority.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (62782)
  sectionNo (13)
  orderNo 13
  title `Functions of appropriate authority.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62782&sectionno=13&orderno=13&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_13_content:
  string
  line `The appropriate authority shall discharge the`
  line `following functions, namely: —`
  line
  line `(a) to grant, suspend or cancel registration of a clinic or bank;`
  line
  line `(b) to enforce the standards to be fulfilled by the clinic or bank;`
  line
  line `(c) to investigate complaints of breach of the provisions of this Act, rules and regulations made thereunder and take legal action as per provisions of this Act;`
  line
  line `(d) to take appropriate legal action against the misuse of assisted reproductive technology by any person and also to initiate independent investigations in such matter;`
  line
  line `(e) to supervise the implementation of the provisions of this Act and the rules and regulations made thereunder;`
  line
  line `(f) to recommend to the National Board and State Boards about the modifications required in the rules and regulations in accordance with changes in technology or social conditions;`
  line
  line `(g) to take action after investigation of complaints received by it against the assisted reproductive technology clinics or banks; and`
  line
  line `(h) such other functions as may be prescribed.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (62783)
  sectionNo (14)
  orderNo 14
  title `Powers of appropriate authority.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62783&sectionno=14&orderno=14&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_14_content:
  string
  line `(1) The appropriate authority shall exercise the powers`
  line `in respect of the following matters, namely:—`
  line
  line `(a) summoning of any person who is in possession of any information relating to violation of the provisions of this Act and the rules and regulations made thereunder;`
  line
  line `(b) production of any document or material object relating to clause (a);`
  line
  line `(c) searching of any place suspected to be violating the provisions of this Act and the rules and regulations made thereunder; and`
  line
  line `(d) such other powers as may be prescribed.`
  line
  line `(2) The appropriate authority shall maintain the details of registration of assisted reproductive technology clinics and banks, cancellation of registration, renewal of registration, grant of certificates to the commissioning couple and woman or any other matter pertaining to grant of licence and the like of the clinic or bank in such format as may be prescribed and submit the same to the National Board.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (62819)
  sectionNo (15)
  orderNo 15
  title `Registration of assisted reproductive technology clinic or assisted reproductive technology bank.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62819&sectionno=15&orderno=15&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_15_content:
  string
  line `(1) No person shall establish any clinic or bank for undertaking assisted`
  line `reproductive technology or to render assisted reproductive technology procedures in any form unless such clinic or bank is duly registered under this Act.`
  line
  line `(2) Every application for registration under sub-section (1) shall be made to the National Registry through the appropriate assisted reproductive technology and surrogacy authority in such form, manner and shall be accompanied by such fees as may be prescribed.`
  line
  line `(3) Every clinic or bank which is conducting assisted reproductive technology, partly or exclusively shall, within a period of sixty days from the date of establishment of the National Registry, apply for registration:`
  line
  line `Provided that such clinics and banks shall cease to conduct any such counselling or procedures on the expiry of six months from the date of commencement of this Act, unless such clinics and banks have applied for registration and is so registered separately or till such application is disposed of, whichever is earlier.`
  line
  line `(4) No clinics or banks shall be registered under this Act, unless the appropriate authority is satisfied that such clinics and banks are in a position to provide such facilities and maintain such equipment and standards including specialised manpower, physical infrastructure and diagnostic facilities as may be prescribed.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (62785)
  sectionNo (16)
  orderNo 16
  title `Grant of registration.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62785&sectionno=16&orderno=16&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_16_content:
  string
  line `(1) On receipt of the application under sub-section (1) of section 15,`
  line `the appropriate authority shall within a period of thirty days—`
  line
  line `(i) grant registration subject to the provisions of this Act and the rules and regulations made thereunder, and provide a registration number to the applicant; or`
  line
  line `(ii) reject the application for reasons to be recorded in writing, if such application does not conform to the provisions of this Act or the rules or regulations made thereunder:`
  line
  line `Provided that no application shall be rejected unless the applicant has been given an opportunity of being heard in the matter.`
  line
  line `(2) If the appropriate authority fails to grant the registration or reject the application, as the case may be, as provided under sub-section (1), the appropriate authority shall, within a period of seven days from the expiry of the said period of thirty days specified under sub-section (1), provide a reason for the failure to process the application.`
  line
  line `(3) The appropriate authority shall, within a period of one month of registration being granted under this section, intimate such registration to the State Board.`
  line
  line `(4) The State Board shall maintain a record of all registrations applied for and granted under this section.`
  line
  line `(5) No registration shall be granted unless the State Board has inspected the premises of the applicant.`
  line
  line `(6) The registration granted under this section shall be valid for a period of five years from the date of registration granted by the appropriate authority.`
  line
  line `(7) The certificate of registration shall be displayed by the clinic or bank at a conspicuous place and such certificate shall contain the duration of validity of such registration.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (62786)
  sectionNo (17)
  orderNo 17
  title `Renewal of registration.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62786&sectionno=17&orderno=17&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_17_content:
  string
  line `The registration granted under section 16, may be renewed for a`
  line `further period of five years by the appropriate authority, on an application made by the applicant,`
  line `under such conditions, in such form and on payment of such fee as may be prescribed:`
  line
  line `Provided that no application for renewal of registration shall be rejected without giving an opportunity of being heard to the applicant.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (62787)
  sectionNo (18)
  orderNo 18
  title `Suspension or cancellation of registration.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62787&sectionno=18&orderno=18&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_18_content:
  string
  line `(1) The appropriate authority may on receipt of a complaint, issue a notice to the clinic or bank to show cause as to why its registration should not be suspended or cancelled for the reasons mentioned in the notice.`
  line
  line `(2) If after giving a reasonable opportunity of being heard to the clinic or bank, the appropriate authority is satisfied that there has been a breach of the provision of this Act or the rules or regulations made thereunder or if the data obtained from them periodically do not satisfy the provisions of this Act, the rules and regulations made thereunder, it may, without prejudice to any criminal action, suspend its registration for such period as it may deem fit or cancel its registration.`
  line
  line `(3) On cancellation of registration, a copy of the cancellation letter shall be sent to the respective State Board and accordingly the State Board shall cancel the registration of such clinics and banks.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (62788)
  sectionNo (19)
  orderNo 19
  title Appeal.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62788&sectionno=19&orderno=19&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_19_content:
  string
  line `The clinic or bank or the commissioning couple or the woman may, within a`
  line `period of thirty days from the date of receipt of the communication relating to order of rejection of`
  line `application, suspension or cancellation of registration passed by the appropriate authority under`
  line `section 16 or section 18, prefer an appeal against such order to--`
  line
  line `(a) the State Government, where the appeal is against the order of the appropriate authority of a State;`
  line
  line `(b) the Central Government, where the appeal is against the order of the appropriated authority of a Union territory,`
  line
  line `in such manner as may be prescribed.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (62789)
  sectionNo (20)
  orderNo 20
  title `Power to inspect premises, etc.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62789&sectionno=20&orderno=20&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_20_content:
  string
  line `The National Board, the National Registry and the State`
  line `Board shall have the power to, --`
  line
  line `(i) inspect, any premises relating to assisted reproductive technology; or`
  line
  line `(ii) call for any document or material,`
  line
  line `in exercise of their powers and discharge of their functions.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (62790)
  sectionNo (21)
  orderNo 21
  title `General duties of assisted reproductive technology clinics and banks.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62790&sectionno=21&orderno=21&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_21_content:
  string
  line `The clinics and`
  line `banks shall perform the following duties, namely:---`
  line
  line `(a) the clinics and banks shall ensure that commissioning couple, woman and donors of`
  line `gametes are eligible to avail the assisted reproductive technology procedures subject to such`
  line `criteria as may be prescribed;`
  line
  line `(b) the clinics shall obtain donor gametes from the banks and such banks shall ensure that the`
  line `donor has been medically tested for such diseases as may be prescribed;`
  line
  line `(c) the clinics shall---`
  line
  line `(i) provide professional counselling to commissioning couple and woman about all the`
  line `implications and chances of success of assisted reproductive technology procedures in the`
  line clinic;
  line
  line `(ii) inform the commissioning couple and woman of the advantages, disadvantages and`
  line `cost of the procedures, their medical side effects, risks including the risk of multiple`
  line `pregnancy; and`
  line
  line `(iii) help the commissioning couple or woman to arrive at an informed decision on such`
  line `matters that would most likely be the best for the commissioning couple;`
  line
  line `(d) the clinics shall make commissioning couple or woman, aware of the rights of a child born`
  line `through the use of assisted reproductive technology;`
  line
  line `(e) the clinics and banks shall ensure that information about the commissioning couple,`
  line `woman and donor shall be kept confidential and the information about treatment shall not be`
  line `disclosed to anyone except to the database to be maintained by the National Registry, in a medical`
  line `emergency at the request of the commissioning couple to whom the information relates, or by an`
  line `order of a court of competent jurisdiction;`
  line
  line `(f) every clinic and every bank shall maintain a grievance cell in respect of matters relating to`
  line `such clinics and banks and the manner of making a compliant before such grievance cell shall be`
  line `such as may be prescribed;`
  line
  line `(g) the clinics shall apply the assisted reproductive technology services,---`
  line
  line `(i) to a woman above the age of twenty-one years and below the age of fifty years;`
  line
  line `(ii) to a man above the age of twenty-one years and below the age of fifty-five years;`
  line
  line `(h) the clinics shall issue to the commissioning couple or woman a discharge certificate stating`
  line `details of the assisted reproductive technology procedure performed on the commissioning couple`
  line `or woman;`
  line
  line `(i) all clinics and banks shall co-operate and make available their premises for physical`
  line `inspection by the National Board, National Registry and State Boards;`
  line
  line `(j) all clinics and banks shall provide all information related to---`
  line
  line `(i) enrolment of the commissioning couple, woman and gamete donors;`
  line
  line `(ii) the procedure being undertaken; and`
  line
  line `(iii) outcome of the procedure, complications, if any, to the National Registry`
  line `periodically, in such manner as may be prescribed.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (62791)
  sectionNo (22)
  orderNo 22
  title `Written informed consent.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62791&sectionno=22&orderno=22&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_22_content:
  string
  line `(1) The clinic shall not perform any treatment or procedure`
  line without--
  line
  line `(a) the written informed consent of all the parties seeking assisted reproductive technology;`
  line
  line `(b) an insurance coverage of such amount as may be prescribed for a period of twelve months`
  line `in favour of the oocyte donor by the commissioning couple or woman from an insurance company`
  line `or an agent recognised by the Insurance Regulatory and Development Authority established under`
  line `the provisions of the Insurance Regulatory and Development Authority Act, 1999 (41 of 1999).`
  line
  line `(2) The clinics and banks shall not cryo-preserve any human embryos or gamete, without specific`
  line `instructions and consent in writing from all the parties seeking assisted reproductive technology, in`
  line `case of death or incapacity of any of the parties.`
  line
  line `(3) The clinic shall not use any human reproductive material, except in accordance with the`
  line `provisions of this Act to create a human embryo or use an in-vitro human embryo for any purpose`
  line `without the specific consent in writing of all the concerned persons to whom the assisted reproductive`
  line `technology relates.`
  line
  line `(4) Any of the commissioning couple may withdraw his or her consent under sub-section (1), any`
  line `time before the human embryos or the gametes are transferred to the concerned woman's uterus.`
  line
  line `Explanation. --For the purposes of this section, the expressions--`
  line
  line `(i) "cryo-preserve" means the freezing and storing of gametes, zygotes, embryos, ovarian and`
  line `testicular tissues;`
  line
  line `(ii)"insurance" means an arrangement by which a company, individual or commissioning`
  line `couple undertake to provide a guarantee of compensation for specified loss, damage, complication`
  line `or death of oocyte donor during the process of oocyte retrieval; and`
  line
  line `(iii) "parties" includes the commissioning couple or woman and the donor.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (62792)
  sectionNo (23)
  orderNo 23
  title `Duties of assisted reproductive technology clinics and banks to keep accurate records.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62792&sectionno=23&orderno=23&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_23_content:
  string
  line `The duties of clinics and banks while keeping the records relating to such clinics and banks are as`
  line `under:--`
  line
  line `(a) all clinics and banks shall maintain detailed records of all donor’s oocytes, sperm or`
  line `embryos used or unused, the manner and technique of their use in such manner as may be`
  line prescribed;
  line
  line `(b) all clinics and banks shall, as and when the National Registry is established, submit by`
  line `online, --`
  line
  line `(i) all information available with them in regard to progress of the commissioning couple`
  line `or woman; and`
  line
  line `(ii) information about number of donors (sperm and oocyte), screened, maintained and`
  line `supplied and the like to the National Registry within a period of one month from the date of`
  line `receipt of such information;`
  line
  line `(c) the records maintained under clause (a) shall be maintained for at least a period of ten`
  line `years, upon the expiry of which the clinic and bank shall transfer the records to a central database`
  line `of the National Registry:`
  line
  line `Provided that if any criminal or other proceedings are instituted against any clinics or banks,`
  line `the records and all other documents of such clinics and banks shall be preserved till the final`
  line `disposal of such proceedings;`
  line
  line `(d) in the event of the closure of any clinic or bank before the expiry of the period of ten years`
  line `under clause (c), such clinic or bank shall immediately transfer the records to the central database`
  line `of the National Registry; and`
  line
  line `(e) all such records shall, at all reasonable times, be made available for inspection to the`
  line `National Board or the National Registry or the State Board or to any other person authorised by`
  line `the National Board in this behalf.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (62793)
  sectionNo (24)
  orderNo 24
  title `Duties of assisted reproductive technology clinics using human gametes and embryos.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62793&sectionno=24&orderno=24&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_24_content:
  string
  line `While using human gametes and embryos, the duties to be performed by the clinics and banks shall be`
  line `as under:--`
  line
  line `(a) the clinics shall retrieve oocytes in such manner as may be specified by regulations;`
  line
  line `(b) not more than three oocytes or embryos may be placed in the uterus of a woman during the`
  line `treatment cycle in such manner as may be specified by regulations;`
  line
  line `(c) a woman shall not be treated with gametes or embryos derived from more than one man or woman during any one treatment cycle;`
  line
  line `(d) a clinic shall never mix semen from two individuals for the procedures specified under this Act;`
  line
  line `(e) the embryos shall not be split and used for twinning to increase the number of available embryos;`
  line
  line `(f) the collection of gametes posthumously shall be done only if prior consent of the commissioning couple is available in such manner as may be prescribed;`
  line
  line `(g) the clinic shall not use ovum that are derived from a foetus, in any process of in-vitro fertilisation; and`
  line
  line `(h) such other duties as may be prescribed.`
  line
  line `Explanation.--For the purposes of this section, the expression--`
  line
  line `(i) "fertilisation" means the penetration of the ovum by the spermatozoon and fusion of genetic materials resulting in the development of a zygote; and`
  line
  line `(ii) "foetus" means a human organism during the period of its development beginning on the fifty-seventh day following fertilisation and ending at birth or abortion.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (62794)
  sectionNo (25)
  orderNo 25
  title `Preimplantation Genetic Diagnosis.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62794&sectionno=25&orderno=25&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_25_content:
  string
  line `(1) The Pre-implantation Genetic testing shall be used`
  line `to screen the human embryo for known, pre-existing, heritable or genetic diseases only.`
  line
  line `(2) The donation of an embryo after Pre-implantation Genetic Diagnosis to an approved research laboratory for research purposes shall be done only--`
  line
  line `(a) with the approval of the commissioning couple or woman; and`
  line
  line `(b) when the embryo suffers from pre-existing, heritable, life-threatening or genetic diseases.`
  line
  line `(3) The National Board may lay down such other conditions as it deems fit in the interests of the`
  line `Pre-implantation Genetic testing.`
  line
  line `Explanation.--For the purposes of this section, the expression--`
  line
  line `(i) "Pre-implantation Genetic Diagnosis" means the genetic diagnosis when one or both genetic parents has a known genetic abnormality and testing is performed on an embryo to determine if it also carries a genetic abnormality; and`
  line
  line `(ii) "Pre-implantation Genetic testing" means a technique used to identify genetic defects in embryos created through in-vitro fertilisation before pregnancy.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (62795)
  sectionNo (26)
  orderNo 26
  title `Sex selection.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62795&sectionno=26&orderno=26&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_26_content:
  string
  line `(1) Subject to the provisions of the Pre-conception and Pre-natal Diagnostic`
  line `Techniques (Prohibition of Sex Selection) Act, 1994, (57 of 1994) the clinic shall not offer to provide`
  line `a couple or woman with a child of a pre-determined sex.`
  line
  line `(2) It is prohibited for anyone to do any act, at any stage, to determine the sex of the child to be born through the process of assisted reproductive technology to separate, or yield fractions enriched in sperm of X or Y variations.`
  line
  line `(3) A person shall not knowingly provide, prescribe or administer anything that shall ensure or increase the probability that an embryo shall be of a particular sex, or that shall identify the sex of an in-vitro embryo, except to diagnose, prevent or treat a sex-linked disorder or disease.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (62796)
  sectionNo (27)
  orderNo 27
  title `Sourcing of gametes by assisted reproductive technology banks.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62796&sectionno=27&orderno=27&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_27_content:
  string
  line `(1) The screening of`
  line `gamete donors, the collection, screening and storage of semen; and provision of oocyte donor, shall be`
  line `done only by a bank registered as an independent entity under the provisions of this Act.`
  line
  line `(2) The banks shall--`
  line
  line `(a) obtain semen from males between twenty-one years of age and fifty-five years of age, both`
  line inclusive;
  line
  line `(b) obtain oocytes from females between twenty-three years of age and thirty-five years of`
  line `age; and`
  line
  line `(c) examine the donors for such diseases, as may be prescribed.`
  line
  line `(3) A bank shall not supply the sperm or oocyte of a single donor to more than one commissioning`
  line couple.
  line
  line `(4) An oocyte donor shall donate oocytes only once in her life and not more than seven oocyte`
  line `shall be retrieved from the oocyte donor.`
  line
  line `(5) All unused oocytes shall be preserved by the banks for use on the same recipient, or given for`
  line `research to an organisation registered under this Act after seeking written consent from the`
  line `commissioning couple.`
  line
  line `(6) A bank shall obtain all necessary information in respect of a sperm or oocyte donor, including the name, Aadhaar number as defined in clause (a) of section 2 of the Aadhaar (Targeted Delivery of Financial and other Subsidies, Benefits and Services) Act, 2016, address and any other details of such donor, in such manner as may be prescribed, and shall undertake in writing from such donor about the confidentiality of such information.`
  line
  line `Explanation. --For the purposes of this section, the expressions---`
  line
  line `(i) "retrieval" means a procedure of removing oocytes from the ovaries of a woman;`
  line
  line `(ii) "screening" means the genetic test performed on embryos produced through in-vitro fertilisation.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (62797)
  sectionNo (28)
  orderNo 28
  title `Storage and handling of human gametes and embryos.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62797&sectionno=28&orderno=28&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_28_content:
  string
  line `(1) The standards for the storage`
  line `and handling of gametes, gonadal tissues and human embryos in respect of their security, recording`
  line `and identification shall be such as may be prescribed.`
  line
  line `(2) The gamete of a donor or embryo shall be stored for a period of not more than ten years and at`
  line `the end of such period such gamete or embryo shall be allowed to perish or be donated to a research`
  line `organisation registered under this Act for research purposes with the consent of the commissioning`
  line `couple or individual, in such manner as may be prescribed.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (62798)
  sectionNo (29)
  orderNo 29
  title `Restriction on sale, etc., of human gametes, zygotes and embryos.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62798&sectionno=29&orderno=29&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_29_content:
  string
  line `The sale, transfer or`
  line `use of gametes, zygotes and embryos, or any part thereof or information related thereto, directly or`
  line `indirectly to any party within or outside India shall be prohibited except in the case of transfer of own`
  line `gametes and embryos for personal use with the permission of the National Board.`
  line
  line `Explanation.--For the purposes of this section, the expression "zygote" means the fertilised oocyte prior to the first cell division.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (62799)
  sectionNo (30)
  orderNo 30
  title `Research on human gametes and embryos.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62799&sectionno=30&orderno=30&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_30_content:
  string
  line `(1) The use of any human gametes and embryos or their transfer to any country outside India for research shall be absolutely prohibited.`
  line
  line `(2) The research on human gamete or embryo within India shall be performed in such manner as may be prescribed.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (62800)
  sectionNo (31)
  orderNo 31
  title `Rights of child born through assisted reproductive technology.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62800&sectionno=31&orderno=31&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_31_content:
  string
  line `(1) The child born`
  line `through assisted reproductive technology shall be deemed to be a biological child of the`
  line `commissioning couple and the said child shall be entitled to all the rights and privileges available to a`
  line `natural child only from the commissioning couple under any law for the time being in force.`
  line
  line `(2) A donor shall relinquish all parental rights over the child or children which may be born from`
  line `his or her gamete.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (62801)
  sectionNo (32)
  orderNo 32
  title `Sex selective assisted reproductive technology.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62801&sectionno=32&orderno=32&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_32_content:
  string
  line `(1) The clinic, or bank or agent`
  line `thereof, shall not issue, publish, distribute, communicate or cause to be issued, published,`
  line `distributed or communicated any advertisement in any manner including internet, regarding`
  line `facilities of sex selective assisted reproductive technology.`
  line
  line `(2) Whoever contravenes the provisions of sub-section (1) shall be punishable with`
  line `imprisonment for a term which shall not be less than five years but may extend to ten years or`
  line `with fine which shall not be less than ten lakh rupees but may extend to twenty-five lakh rupees`
  line `or with both.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (62802)
  sectionNo (33)
  orderNo 33
  title `Offences and penalties.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62802&sectionno=33&orderno=33&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_33_content:
  string
  line `(1) Any medical geneticist, gynaecologist, registered medical`
  line `practitioner or any person shall not--`
  line
  line `(a) abandon, disown or exploit or cause to be abandoned, disowned or exploited in any form the child or children born through assisted reproductive technology;`
  line
  line `(b) sell human embryos or gametes, run an agency, a racket or an organisation for selling, purchasing or trading in human embryos or gametes;`
  line
  line `(c) import or help in getting imported in whatsoever manner, the human embryos or human gametes;`
  line
  line `(d) exploit the commissioning couple, woman or the gamete donor in any form;`
  line
  line `(e) transfer human embryo into a male person or an animal;`
  line
  line `(f) sell any human embryo or gamete for the purpose of research; or`
  line
  line `(g) use any intermediates to obtain gamete donors or purchase gamete donors.`
  line
  line `(2) Whoever contravenes the provisions of clauses (a) to (g) of sub-section (1), shall be punishable with a fine which shall not be less than five lakh rupees but may extend to ten lakh rupees for the first contravention and for subsequent contravention, shall be punishable with imprisonment for a term which shall not be less than three years but may extend to eight years and with fine which shall not be less than ten lakh rupees but may extend to twenty lakh rupees.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (62820)
  sectionNo (34)
  orderNo 34
  title `Punishment for contravention of provisions of Act or rules for which no specific punishment is provided.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62820&sectionno=34&orderno=34&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_34_content:
  string
  line `Whoever contravenes any of the provisions of this Act or any`
  line `rules made thereunder, for which no penalty has been provided in this Act shall be punishable`
  line `as per sub-section (2) of section 33.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (62804)
  sectionNo (35)
  orderNo 35
  title `Cognizance of offences.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62804&sectionno=35&orderno=35&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_35_content:
  string
  line `(1) No court shall take cognizance of any offence punishable`
  line `under this Act, save on a complaint made by the National Board or the State Board or by an`
  line `officer authorised by it.`
  line
  line `(2) No court inferior to that of a Metropolitan Magistrate or a Judicial Magistrate of the first`
  line `class shall try any offence punishable under this Act.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (62805)
  sectionNo (36)
  orderNo 36
  title `Offences to be cognizable and bailable.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62805&sectionno=36&orderno=36&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_36_content:
  string
  line `Notwithstanding anything contained in the`
  line `Code of Crimincal Procedure, 1973 (2 of 1974), all the offences under this Act shall be`
  line `cognizable and bailable.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (62806)
  sectionNo (37)
  orderNo 37
  title `Offences by clinics or banks.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62806&sectionno=37&orderno=37&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_37_content:
  string
  line `(1) Where an offence under this Act has been`
  line `committed by any clinic or bank, the executive head of such clinic or bank shall be deemed to`
  line `be guilty of an offence and shall be liable to be proceeded against and punished accordingly`
  line `unless he proves that the offence was committed without his knowledge or that he had`
  line `exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act`
  line `has been committed by any clinic or bank and it is proved that the offence has been committed`
  line `with the consent or connivance of, or is attributable to any neglect on the part of any officer,`
  line `other than the executive head of the clinic or bank, such officer shall also be deemed to be`
  line `guilty of that offence and shall be liable to be proceeded against and punished accordingly.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (62821)
  sectionNo (38)
  orderNo 38
  title `Power of Central Government to issue directions to National Board, National Registry and appropriate authority.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62821&sectionno=38&orderno=38&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_38_content:
  string
  line `(1) The Central Government may, from time to time`
  line `issue to the National Board, the National Registry and the appropriate authority with respect to`
  line `the Union territory, such directions as it may think necessary in the interest of the sovereignty`
  line `and integrity of India, security of the State, friendly relation with foreign States, public order,`
  line `decency or morality.`
  line
  line `(2) Without prejudice to the foregoing provisions of this Act, the National Board, the`
  line `National Registry and the appropriate authority shall, in exercise of its powers or the`
  line `performance of its functions under this Act, be bound by such directions on questions of policy`
  line `as the Central Government or the State Government, as the case may be, may give in writing to`
  line `it from time to time:`
  line
  line `Provided that the National Board shall, as far as practicable, be given an opportunity to`
  line `express its views before any direction is given under sub-section (1).`
  line
  line `(3) If any dispute arises between the Central Government and the National Board as to`
  line `whether a question is or is not a question of policy, the decision of the Central Government`
  line `shall be final.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (62808)
  sectionNo (39)
  orderNo 39
  title `Power of State Government to issue directions to State Board, etc.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62808&sectionno=39&orderno=39&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_39_content:
  string
  line `(1) The State`
  line `Government may, from time to time issue to the State Board and to the appropriate authority`
  line `with respect to the State Government such directions as it may think necessary in the interest of`
  line `the sovereignty and integrity of India, security of the State, friendly relation with foreign States,`
  line `public order, decency or morality.`
  line
  line `(2) Without prejudice to the foregoing provisions of this Act, the State Board and the`
  line `appropriate authority shall, in exercise of its powers or the performance of its functions under`
  line `this Act, be bound by such directions on questions of policy as the State Government may give`
  line `in writing to it from time to time:`
  line
  line `Provided that the State Board and the appropriate authority shall, as far as practicable, be`
  line `given an opportunity to express its views before any direction is given under sub-section (1).`
  line
  line `(3) If any dispute arises between the State Government and the State Board as to whether a`
  line `question is or is not a question of policy, the decision of the State Government shall be final.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (62809)
  sectionNo (40)
  orderNo 40
  title `Power to search and seize records, etc.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62809&sectionno=40&orderno=40&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_40_content:
  string
  line `(1) If the National Board, the National`
  line `Registry or the State Board has reason to believe that an offence under this Act has been or is`
  line `being committed at any facility using assisted reproductive technology, such Board or any`
  line `officer authorised in this behalf may, subject to such rules as may be prescribed, enter and`
  line `search at all reasonable times with such assistance, if any, as such Board or officer considers`
  line `necessary, such facility using assisted reproductive technology and examine any record,`
  line `register, document, book, pamphlet, advertisement or any other material object found therein`
  line `and seize the same, if the said Board has reason to believe that it may furnish evidence of the`
  line `commission of an offence punishable under this Act.`
  line
  line `(2) The provisions of the Code of Criminal Procedure, 1973 (2 of 1974), relating to searches`
  line `and seizures shall, so far as may be, apply to every search or seizure made under this Act.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (62810)
  sectionNo (41)
  orderNo 41
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62810&sectionno=41&orderno=41&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_41_content:
  string
  line `No suit, prosecution or other legal`
  line `proceeding shall lie against the Central Government or the State Government or the National`
  line `Board or the National Registry or the State Board or the appropriate authority or any other`
  line `officer authorised by the Central Government or the State Government or the National Board or`
  line `the National Registry or the State Board or the appropriate authority for anything which is done`
  line `in good faith or intended to be done in pursuance of the provisions of this Act or the rules or`
  line `regulations made thereunder.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (62811)
  sectionNo (42)
  orderNo 42
  title `Power to make rules.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62811&sectionno=42&orderno=42&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_42_content:
  string
  line `(1) The Central Government may by notification make rules`
  line `for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules`
  line `may provide for--`
  line
  line `(a) the other powers and functions of the National Board under clause (g) of section 5;`
  line
  line `(b) the other powers and functions of the State Board under clause (b) of sub-section (2)`
  line `of section 8;`
  line
  line `(c) the terms of office and other conditions of service of scientific, technical and other`
  line `employees of the National Registry under section 10;`
  line
  line `(d) the other functions of the National Registry under clause (d) of section 11;`
  line
  line `(e) the other functions of the appropriate authority under clause (h) of section 13;`
  line
  line `(f) the other powers to be exercised by the appropriate authority under clause (d) of`
  line `sub-section (1) of section 14;`
  line
  line `(g) the format for granting of licences to the clinic or bank by the appropriate authority`
  line `under sub-section (2) of section 14;`
  line
  line `(h) the form and manner in which an application shall be made for registration and fee`
  line `payable thereof under sub-section (2) of section 15;`
  line
  line `(i) the facilities and equipments to be provided and maintained by the clinics and banks`
  line `under sub-section (4) of section 15;`
  line
  line `(j) the conditions, form and fee for application of renewal of the registration of clinic or`
  line `bank under section 17;`
  line
  line `(k) the manner in which an appeal may be preferred to the State Government or the`
  line `Central Government under section 19;`
  line
  line `(l) the criteria for availing the assisted reproductive technology procedures under`
  line `clause (a) of section 21;`
  line
  line `(m) the medical examination of the diseases with respect to which the donor shall be`
  line `tested under clause (b) of section 21;`
  line
  line `(n) the manner of making a complaint before a grievance cell and the mechanism`
  line `adopted by the clinic under clause (f) of section 21;`
  line
  line `(o) the manner of providing information by the clinics and banks to the National`
  line `Registry under clause (j) of section 21;`
  line
  line `(p) the amount of insurance coverage for oocyte donor under clause (b) of`
  line `sub-section (1) of section 22;`
  line
  line `(q) the manner of maintaining the records by the clinics and banks under clause (a) of`
  line `section 23;`
  line
  line `(r) the manner of collection of gametes posthumously under clause (f) of section 24;`
  line
  line `(s) the other duties of clinics under clause (h) of section 24;`
  line
  line `(t) the examination of the donors by the assisted reproductive technology banks for`
  line `diseases under clause (c) of sub-section (2) of section 27;`
  line
  line `(u) the manner of obtaining information in respect of a sperm or oocyte donor by a bank`
  line `under sub-section (6) of section 27;`
  line
  line `(v) the standards for the storage and handling of gametes, human embryos in respect of`
  line `their security, recording and identification under sub-section (1) of section 28;`
  line
  line `(w) the manner of obtaining the consent of the commissioning couple or individual for`
  line `perishing or donating the gametes of a donor or embryo under sub-section (2) of section 28;`
  line
  line `(x) the manner of performing research on human gametes or embryo within India under`
  line `sub-section (2) of section 30;`
  line
  line `(y) the manner of entry and search by the National Board, the National Registry or the`
  line `State Board or any officer authorised by it under sub-section (1) of section 40;.`
  line
  line `(z) any other matter which is to be, or may be prescribed, or in respect of which`
  line `provision is to be made by rules.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (62812)
  sectionNo (43)
  orderNo 43
  title `Power to make regulations.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62812&sectionno=43&orderno=43&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_43_content:
  string
  line `(1) The National Board may, with the prior approval of`
  line `the Central Government, by notification make regulations consistent with this Act and the rules`
  line `made thereunder to carry out the provisions of the Act;`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such`
  line `regulations may provide for--`
  line
  line `(a) the manner of retrieving the oocytes under clause (a) of section 24;`
  line
  line `(b) the manner of placing the oocytes or embryos in the uterus of a woman under`
  line `clause (b) of section 24; and`
  line
  line `(c) any other matter which is required to be, specified by regulations or in respect of`
  line `which provision is to be made by regulations.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (62813)
  sectionNo (44)
  orderNo 44
  title `Laying of rules, regulations and notifications.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62813&sectionno=44&orderno=44&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_44_content:
  string
  line `Every rule or regulation made and`
  line `notification issued under this Act shall be laid, as soon as may be after it is made or issued,`
  line `before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the`
  line `expiry of the session immediately following the session or the successive sessions aforesaid,`
  line `both Houses agree in making any modification in the rules or regulations or notifications, as the`
  line `case may be or both Houses agree that the rules or regulations or notifications, as the case may`
  line `be, should not be made or issued, such rules or regulations or notifications, as the case may be,`
  line `shall thereafter have effect only in such modified form or be of no effect, as the case may be;`
  line `so, however, that any such modification or annulment shall be without prejudice to the validity`
  line `of anything previously done under that rule or regulation or notification, as the case may be.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (62814)
  sectionNo (45)
  orderNo 45
  title `Application of other laws not barred.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62814&sectionno=45&orderno=45&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_45_content:
  string
  line `The provisions of this Act shall be in`
  line `addition to, and not in derogation of, the provisions of the Pre-conception and Pre-natal`
  line `Diagnostic Techniques (Prohibition of Sex Selection) Act, 1994 (57 of 1994) and the Clinical`
  line `Establishment (Registration and Regulation) Act, 2010 (23 of 2010) or of any other law for`
  line `the time being in force.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (62815)
  sectionNo (46)
  orderNo 46
  title `Power to remove difficulties.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00001_202142_1643274805540&sectionId=62815&sectionno=46&orderno=46&orgactid=AC_CEN_12_72_00001_202142_1643274805540
obj_root_law_sections_46_content:
  string
  line `(1) If any difficulty arises in giving effect to the`
  line `provisions of this Act, the Central Government may, by order published in the Official`
  line `Gazette, make such provisions not inconsistent with the provisions of this Act as may appear`
  line `to it to be necessary or expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of three years from`
  line `the date of commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
