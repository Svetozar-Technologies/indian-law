obj_root_law_sections_1:
  sectionId (29859)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_000010_196530_1517807320098&sectionId=29859&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_000010_196530_1517807320098
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Goa, Daman and Diu`
  line `(Extension of the Code of Civil Procedure and the Arbitration Act) Act, 1965.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 15th, June, 1966, vide notification No. S.O. 1597(E), dated 24th, June, 1966, see Gazette of India, Extraordinary`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (29860)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_000010_196530_1517807320098&sectionId=29860&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_000010_196530_1517807320098
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,`
  line
  line `(a) "Goa, Daman and Diu" means the Union territory of Goa, Daman and Diu;`
  line
  line `(b) "Lieutenant-Governor" means the administrator of Goa, Daman and Diu appointed by the`
  line `President under article 239 of the Constitution.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (29861)
  sectionNo (3)
  orderNo 3
  title `Extension of Code of Civil Procedure and Arbitration Act, 1940, to Goa, Daman and Diu.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_000010_196530_1517807320098&sectionId=29861&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_000010_196530_1517807320098
obj_root_law_sections_3_content:
  string
  line `The Code of Civil Procedure, 1908 (5 of 1908), and the Arbitration Act, 1940 (10 of 1940), as`
  line `in force in the territories to which they generally extend, are hereby extended to, and shall be in force`
  line `in, Goa, Daman and Diu.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (29862)
  sectionNo (4)
  orderNo 4
  title `Repeal and saving.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_000010_196530_1517807320098&sectionId=29862&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_000010_196530_1517807320098
obj_root_law_sections_4_content:
  string
  line `(1) So much of any law in force in Goa, Daman and Diu as corresponds`
  line `to the Code of Civil Procedure, 1908 (5 of 1908), or the Arbitration Act, 1940 (10 of 1940), or any`
  line `part of the said Code or Act, as the case may be, shall stand repealed as from the coming into force of`
  line `this Act in Goa, Daman and Diu:`
  line
  line `Provided that the repeal shall not affect--`
  line
  line `(a) the previous operation of any law so repealed or anything duly done or suffered`
  line `thereunder, or`
  line
  line `(b) any right, privilege, obligation or liability acquired, accrued or incurred under any law so`
  line `repealed, or`
  line
  line `(c) any investigation, legal proceeding or remedy in respect of any such right, privilege,`
  line `obligation or liability as aforesaid,`
  line
  line `and any such investigation, legal proceeding or remedy may be instituted, continued or enforced as if`
  line `this Act had not been passed:`
  line
  line `Provided further that, subject to the preceding proviso, notifications published, declarations and`
  line `rules made, places appointed, agreements filed, awards made or filed, scales prescribed, forms`
  line `framed, appointments made and powers conferred under any law so repealed shall, so far as they are`
  line `consistent with the said Code or, as the case may be, the said Act have the same force and effect as if`
  line `they had been respectively published, made, appointed, filed, prescribed, framed and conferred under`
  line `the said Code or the said Act and by the authority empowered thereby in such behalf.`
  line
  line `(2) In every law or notification passed or issued before the commencement of this Act in which`
  line `reference is made to or to any Chapter or section or provision of any law hereby repealed, such`
  line `reference shall, so far as may be practicable, be taken to be made to the said Code or, as the case may`
  line `be, to the said Act or its corresponding Part, Order, section or rule.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (29863)
  sectionNo (5)
  orderNo 5
  title `Rules of construction.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_000010_196530_1517807320098&sectionId=29863&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_000010_196530_1517807320098
obj_root_law_sections_5_content:
  string
  line `(1) In the Code of Civil Procedure, 1908 (5 of 1908), and in the`
  line `Arbitration Act, 1940 (10 of 1940),—`
  line
  line `(a) any reference to any provision of law not in force, or to any functionary not in existence,`
  line `in Goa, Daman and Diu shall be construed as a reference to the corresponding law in force, or to`
  line `the corresponding functionary in existence, in that Union territory:`
  line
  line `Provided that—`
  line
  line `(i) if any question arises as to who that corresponding functionary is, or`
  line
  line `(ii) if there is no such corresponding functionary,`
  line
  line `the Lieutenant-Governor shall decide as to who such functionary will be and his decision shall`
  line `be final;`
  line
  line `(b) any reference to the State Government shall be construed as a reference to the Central`
  line `Government and also as including a reference to the Lieutenant-Governor.`
  line
  line `(2) For the purpose of facilitating the application in relation to Goa, Daman and Diu of the said`
  line `Code or the said Act, any court or other authority may construe it in such manner not affecting the`
  line `substance as may be necessary or proper to adapt it to the matter before the court or other authority.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (29864)
  sectionNo (6)
  orderNo 6
  title `Power to remove Difficulties.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_000010_196530_1517807320098&sectionId=29864&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_000010_196530_1517807320098
obj_root_law_sections_6_content:
  string
  line `If any difficulty arises in giving effect in Goa, Daman and Diu`
  line `to the provisions of the Code of Civil Procedure, 1908 (5 of 1908), or the Arbitration`
  line `Act, 1940 (10 of 1940), extended by this Act to that Union territory, the Central Government may, by`
  line `order in the Official Gazette, make such provisions or give such directions as appear to it to be`
  line `necessary for the removal of the difficulty.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (29865)
  sectionNo (7)
  orderNo 7
  title `Consequential provisions.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_000010_196530_1517807320098&sectionId=29865&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_000010_196530_1517807320098
obj_root_law_sections_7_content:
  string
  line `As from the commencement of this Act, in the Goa, Daman and`
  line `Diu (Judicial Commissioner's Court) Regulation, 1963 (Reg. 10 of 1963),—`
  line
  line `(i) in section 8, in sub-section (1), the words "Subject to the provisions of any law for the time`
  line `being in force" shall be inserted at the commencement;`
  line
  line `(ii) in section 16, after the words "subject to the provisions of this Regulation", the words`
  line `"and until other provision is made by law" shall be inserted;`
  line
  line `(iii) in section 17, in sub-section (1), after the word "shall", the words ", until other provision`
  line `is made by law,", shall be inserted.`
obj_root_law_sections_7_footnotes:
  string
  line
