obj_root_law:
  slug the-armed-forces-tribunal-act-2007
  handle (2077)
  collectionHandle 123456789/1362
  title `The Armed Forces Tribunal Act, 2007`
  actNumber (55)
  enactmentDate 2007-12-25
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2077`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `सशस्‍त्र बल अधिकरण अधिनियम, 2007`
  actYear (2007)
  ministry `Ministry of Defence`
  department `Department of Defence`
  longTitle `An Act to provide for the adjudication or trial by Armed Forces Tribunal of disputes and complaints with respect to commission, appointments, enrolment and conditions of service in respect of persons subject to the Army Act, 1950, the Navy Act, 1957 and the Air Force Act 1950 and also to provide for appeals arising out of orders, findings or sentences of court martial held under the said Acts and for matters connected therewith or incidental thereto.`
  enforcementDate 15-06-2008
  notification `15th June, 2008, vide notification No. S.O. 14(E), dated 13th June, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T18:28:28.679Z`
  translations obj_root_law_translations
