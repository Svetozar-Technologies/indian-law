obj_root_law_sections_1:
  sectionId (3323)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 15th June, 2008, vide notification No. S.O. 14(E), dated 13th June, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3323&sectionno=1&orderno=1&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Armed Forces Tribunal Act,`
  line 2007.
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification, appoint.`
obj_root_law_sections_2:
  sectionId (3324)
  sectionNo (2)
  orderNo 2
  title `Applicability of the Act.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3324&sectionno=2&orderno=2&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_2_content:
  string
  line `(1) The provisions of this Act shall apply to all persons subject to the`
  line `Army Act, 1950 (46 of 1950), the Navy Act, 1957 (62 of 1957) and the Air Force Act, 1950 (45 of 1950).`
  line
  line `(2) This Act shall also apply to retired personnel subject to the Army Act, 1950 (46 of 1950) or the`
  line `Navy Act, 1957 (62 of 1957) or the Air Force Act, 1950 (45 of 1950), including their dependants, heirs`
  line `and successors, in so far as it relates to their service matters.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (3325)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3325&sectionno=3&orderno=3&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Administrative Member" means a member of the Tribunal who is not a Judicial Member`
  line `within the meaning of clause (g);`
  line
  line `(b) "application" means an application made under sub-section (2) of section 14;`
  line
  line `(c) "appointed day" means the date with effect from which the Tribunal is established by`
  line `notification under section 4;`
  line
  line `(d) "Bench" means a Bench of the Tribunal;`
  line
  line `(e) "Chairperson" means the Chairperson of the Tribunal;`
  line
  line `(f) "court martial" means a court martial held under the Army Act, 1950 (46 of 1950) or the Navy`
  line `Act, 1957 (62 of 1957) including the disciplinary courts constituted under the Act or the Air Force`
  line `Act, 1950 (45 of 1950);`
  line
  line `(g) "Judicial Member" means a member of the Tribunal appointed as such under this Act, and`
  line `includes the Chairperson, who possesses any of the qualifications specified in sub-section (2) of`
  line `section 6;`
  line
  line `(h) "Member" means a member (whether Judicial or Administrative) of the Tribunal and includes`
  line `the Chairperson;`
  line
  line `(i) "military custody" means the arrest or confinement of a person according to the usages of the`
  line `service and includes naval or air force custody;`
  line
  line `(j) "notification" means a notification published in the Official Gazette;`
  line
  line `(k) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(l) "President" means the President of India;`
  line
  line `(m) "rules" means the rules made under this Act;`
  line
  line `(n) "service" means the service within or outside India;`
  line
  line `(o) "service matters", in relation to the persons subject to the Army Act, 1950 (46 of 1950), the`
  line `Navy Act, 1957 (62 of 1957) and the Air Force Act, 1950 (45 of 1950), mean all matters relating to`
  line `the conditions of their service and shall include--`
  line
  line `(i) remuneration (including allowances), pension and other retirement benefits;`
  line
  line `(ii) tenure, including commission, appointment, enrolment, probation, confirmation, seniority,`
  line `training, promotion, reversion, premature retirement, superannuation, termination of service and`
  line `penal deductions;`
  line
  line `(iii) summary disposal and trials where the punishment of dismissal is awarded;`
  line
  line `(iv) any other matter, whatsoever,`
  line
  line `but shall not include matters relating to`
  line
  line `(i) orders issued under section 18 of the Army Act, 1950 (46 of 1950), sub-section (1) of`
  line `section 15 of the Navy Act, 1957 (62 of 1957) and section 18 of the Air Force Act, 1950 (45 of`
  line `1950); and`
  line
  line `(ii) transfers and postings including the change of place or unit on posting whether`
  line `individually or as a part of unit, formation or ship in relation to the persons subject to the Army`
  line `Act, 1950 (46 of 1950), the Navy Act, 1957 (62 of 1957) and the Air Force Act, 1950 (45 of`
  line `1950);`
  line
  line `(iii) leave of any kind;`
  line
  line `(iv) summary court martial except where the punishment is of dismissal or imprisonment for`
  line `more than three months;`
  line
  line `(p) "summary disposals and trials' means summary disposals and trials held under the Army Act,`
  line `1950 (46 of 1950), the Navy Act, 1957 (62 of 1957) and the Air Force Act, 1950 (45 of 1950);`
  line
  line `(q) "Tribunal" means the Armed Forces Tribunal established under section 4.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (3326)
  sectionNo (4)
  orderNo 4
  title `Establishment of Armed Forces Tribunal.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3326&sectionno=4&orderno=4&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_4_content:
  string
  line `The Central Government shall, by notification,`
  line `establish a Tribunal to be known as the Armed Forces Tribunal to exercise the jurisdiction, powers and`
  line `authority conferred on it by or under this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (3327)
  sectionNo (5)
  orderNo 5
  title `Composition of Tribunal and Benches thereof.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3327&sectionno=5&orderno=5&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_5_content:
  string
  line `(1) The Tribunal shall consist of a Chairperson,`
  line `and such number of Judicial and Administrative Members as the Central Government may deem fit and,`
  line `subject to the other provisions of this Act, the jurisdiction, powers and authority of the Tribunal may be`
  line `exercised by Benches thereof.`
  line
  line `(2) Subject to the other provisions of this Act, a Bench shall consist of one Judicial Member and one`
  line `Administrative Member.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1), the Chairperson--`
  line
  line `(a) may, in addition to discharging the functions of a Judicial Member of the Bench to which he`
  line `is appointed, discharge the functions of an Administrative Member of any other Bench;`
  line
  line `(b) may transfer a Member from one Bench to another Bench;`
  line
  line `(c) may, for the purpose of securing that any case or cases, which having regard to the nature of`
  line `the questions involved, requires or require, in his opinion, or under the rules made under this Act, to`
  line `be decided by a Bench composed of more than two members, issue such general or special orders, as`
  line `he may deem fit:`
  line
  line `Provided that every Bench constituted in pursuance of this clause shall include at least one`
  line `Judicial Member and one Administrative Member.`
  line
  line `(4) Subject to the other provisions of this Act, the Benches of the Tribunal shall ordinarily sit at Delhi`
  line `(which shall be known as the Principal Bench), and at such other places as the Central Government may,`
  line `by notification, specify.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (3328)
  sectionNo (6)
  orderNo 6
  title `Qualifications for appointment of Chairperson and other Members.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3328&sectionno=6&orderno=6&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_6_content:
  string
  line `(1) A person shall not be`
  line `qualified for appointment as the Chairperson unless he is a retired Judge of the Supreme Court or a retired`
  line `Chief Justice of a High Court.`
  line
  line `(2) A person shall not be qualified for appointment as a Judicial Member unless he is or has been a`
  line `Judge of a High Court.`
  line
  line `(3) A person shall not be qualified for appointment as an Administrative Member unless--`
  line
  line `(a) he has held or has been holding the rank of Major General or above for a total period of at`
  line `least three years in the Army or equivalent rank in the Navy or the Air Force; and`
  line
  line `(b) he has served for not less than one year as Judge Advocate General in the Army or the Navy`
  line `or the Air Force, and is not below the rank of Major General, Commodore and Air Commodore`
  line respectively.
  line
  line `Explanation.--When a serving person is appointed as an Administrative Member, he shall have`
  line `retired from service prior to assuming such appointment.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (3329)
  sectionNo (7)
  orderNo 7
  title `Appointment of Chairperson and other Members.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3329&sectionno=7&orderno=7&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of this section,`
  line `the Chairperson and other Members of the Tribunal shall be appointed by the President:`
  line
  line `Provided that no appointment under this sub-section shall be made except after consultation with the`
  line `Chief Justice of India.`
  line
  line `(2) The President may appoint one or more Members of the Tribunal to be the Vice-Chairperson, or,`
  line `as the case may be, the Vice-Chairpersons, thereof.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (3330)
  sectionNo (8)
  orderNo 8
  title `Term of office.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3330&sectionno=8&orderno=8&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_8_content:
  string
  line `The Chairperson or a Member shall hold office for a term of four years from the`
  line `date on which he enters upon his office and shall be eligible for re-appointment:`
  line
  line `Provided that no Chairperson shall hold office as such after he has attained,--`
  line
  line `(a) in case he has been a Judge of the Supreme Court, the age of seventy years; and`
  line
  line `(b) in case he has been the Chief Justice of a High Court, the age of sixty-five years:`
  line
  line `Provided further that no other Member shall hold office as such Member after he has attained the age`
  line `of sixty-five years.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (3331)
  sectionNo (9)
  orderNo 9
  title `Resignation and removal.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3331&sectionno=9&orderno=9&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_9_content:
  string
  line `(1) The Chairperson or a Member may, by notice in writing under his`
  line `hand addressed to the President, resign his office:`
  line
  line `Provided that the Chairperson or a Member shall, unless he is permitted by the President to relinquish`
  line `his office sooner, continue to hold office until the expiry of three months from the date of receipt of such`
  line `notice or until a person duly appointed as his successor enters upon his office or until the expiry of his`
  line `term of office, whichever is the earliest.`
  line
  line `(2) The Chairperson or a Member shall not be removed from his office except by an order made by`
  line `the President on the ground of proved misbehaviour or incapacity after an inquiry made by a sitting Judge`
  line `of the Supreme Court in which such Chairperson or other Member had been informed of the charges`
  line `against him and given a reasonable opportunity of being heard in respect of those charges.`
  line
  line `(3) The Central Government may, by rules, regulate the procedure for the investigation of`
  line `misbehaviour or incapacity of the Chairperson or other Member referred to in sub-section (2).`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_9_a:
  sectionId (48993)
  sectionNo 9A
  orderNo 10
  title `Qualifications, terms and conditions of service of Chairperson and Member`
  content obj_root_law_sections_9_a_content
  footnotes obj_root_law_sections_9_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=48993&sectionno=9A&orderno=10&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_9_a_content:
  string
  line `^1[9A. Qualifications, terms and conditions of service of Chairperson and Member.--`
  line `Notwithstanding anything contained in this Act, the qualifications, appointment, term of office, salaries`
  line `and allowances, resignation, removal and terms and conditions of service of the Chairperson and other`
  line `Members of the Appellate Tribunal appointed after the commencement of ^2[the Tribunals Reforms Act, 2021, shall be governed by the provisions of Chapter II of the said Act]:`
  line
  line `Provided that the Chairperson and Member appointed before the commencement of Part XIV of`
  line `Chapter VI of the Finance Act, 2017, shall continue to be governed by the provisions of this Act, and the`
  line `rules made thereunder as if the provisions of section 184 of the Finance Act, 2017 had not come into`
  line force.]
obj_root_law_sections_9_a_footnotes:
  string
  line `1. Ins. by Act 7 of 2017, s. 181 (w.e.f. 26-5-2017).`
  line
  line `2. Subs. by Act 33 of 2021, s. 26, for “Part XIV of Chapter VI of the Finance Act, 2017 (7 of 2017), shall be governed by the provisions of the section 184 of that Act” (w.e.f. 4-4-2021).`
obj_root_law_sections_10:
  sectionId (3332)
  sectionNo (10)
  orderNo 11
  title `Salaries, allowances and other terms and conditions of service of Chairperson and other Members.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3332&sectionno=10&orderno=11&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_10_content:
  string
  line `The salaries and allowances payable to, and the other terms and conditions of service (including pension, gratuity and other retirement benefits) of, the Chairperson and other Members shall be`
  line `such as may be prescribed by the Central Government:`
  line
  line `Provided that neither the salary and allowances nor the other terms and conditions of service of the`
  line `Chairperson and other Members shall be varied to their disadvantage after their appointment.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (3333)
  sectionNo (11)
  orderNo 12
  title `Prohibitions as to holding of offices, etc., by Chairperson or Member on ceasing to be such Chairperson or Member.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3333&sectionno=11&orderno=12&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_11_content:
  string
  line `On ceasing to hold office--`
  line
  line `(a) the Chairperson shall be ineligible for further employment either under the Government of`
  line `India or under the Government of a State;`
  line
  line `(b) a Member other than the Chairperson shall, subject to the provisions of this Act, be eligible`
  line `for appointment as a member of any other Tribunal but not for any other employment either under the`
  line `Government of India or under the Government of a State; and`
  line
  line `(c) the Chairperson or other Members shall not appear, act or plead before the Tribunal.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (3334)
  sectionNo (12)
  orderNo 13
  title `Financial and administrative powers of Chairperson.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3334&sectionno=12&orderno=13&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_12_content:
  string
  line `The Chairperson shall exercise such`
  line `financial and administrative powers over the Benches as may be prescribed:`
  line
  line `Provided that the Chairperson shall have the authority to delegate such of his financial and`
  line `administrative powers as he may think fit to any other Member or any officer of the Tribunal, subject to`
  line `the conditions that such Member or officer shall, while exercising such delegated powers, continue to act`
  line `under the direction, control and supervision of the Chairperson.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (3335)
  sectionNo (13)
  orderNo 14
  title `Staff of the Tribunal.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3335&sectionno=13&orderno=14&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_13_content:
  string
  line `(1) The Central Government shall determine the nature and categories of`
  line `the officers and other employees required to assist the Tribunal in the discharge of its functions and`
  line `provide the Tribunal with such officers and other employees as it may think fit.`
  line
  line `(2) The salaries and allowances payable to, and the other terms and conditions of service of the`
  line `officers and other employees of the Tribunal shall be such as may be prescribed.`
  line
  line `(3) The officers and other employees of the Tribunal shall discharge their functions under the general`
  line `superintendence of the Chairperson.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (3336)
  sectionNo (14)
  orderNo 15
  title `Jurisdiction, powers and authority in service matters.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3336&sectionno=14&orderno=15&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_14_content:
  string
  line `(1) Save as otherwise expressly`
  line `provided in this Act, the Tribunal shall exercise, on and from the appointed day, all the jurisdiction,`
  line `powers and authority, exercisable immediately before that day by all courts (except the Supreme Court or`
  line `a High Court exercising jurisdiction under articles 226 and 227 of the Constitution) in relation to all`
  line `service matters.`
  line
  line `(2) Subject to the other provisions of this Act, a person aggrieved by an order pertaining to any`
  line `service matter may make an application to the Tribunal in such form and accompanied by such documents`
  line `or other evidence and on payment of such fee as may be prescribed.`
  line
  line `(3) On receipt of an application relating to service matters, the Tribunal shall, if satisfied after due`
  line `inquiry, as it may deem necessary, that it is fit for adjudication by it, admit such application; but where`
  line `the Tribunal is not so satisfied, it may dismiss the application after recording its reasons in writing.`
  line
  line `(4) For the purpose of adjudicating an application, the Tribunal shall have the same powers as are`
  line `vested in a Civil Court under the Code of Civil Procedure, 1908 (5 of 1908), while trying a suit in respect`
  line `of the following matters, namely--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) receiving evidence on affidavits;`
  line
  line `(d) subject to the provisions of sections 123 and 124 of the Indian Evidence Act,`
  line `1872 (1 of 1872), requisitioning any public record or document or copy of such record or document`
  line `from any office;`
  line
  line `(e) issuing commissions for the examination of witnesses or documents;`
  line
  line `(f) reviewing its decisions;`
  line
  line `(g) dismissing an application for default or deciding it ex parte;`
  line
  line `(h) setting aside any order of dismissal of any application for default or any order passed by it`
  line `ex parte; and`
  line
  line `(i) any other matter which may be prescribed by the Central Government.`
  line
  line `(5) The Tribunal shall decide both questions of law and facts that may be raised before it.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (3337)
  sectionNo (15)
  orderNo 16
  title `Jurisdiction, powers and authority in matters of appeal against court martial.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3337&sectionno=15&orderno=16&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_15_content:
  string
  line `(1) Save as`
  line `otherwise expressly provided in this Act, the Tribunal shall exercise, on and from the appointed day, all`
  line `the jurisdiction, powers and authority exercisable under this Act in relation to appeal against any order,`
  line `decision, finding or sentence passed by a court martial or any matter connected therewith or incidental`
  line thereto.
  line
  line `(2) Any person aggrieved by an order, decision, finding or sentence passed by a court martial may`
  line `prefer an appeal in such form, manner and within such time as may be prescribed.`
  line
  line `(3) The Tribunal shall have power to grant bail to any person accused of an offence and in military`
  line `custody, with or without any conditions which it considers necessary:`
  line
  line `Provided that no accused person shall be so released if there appears reasonable ground for believing`
  line `that he has been guilty of an offence punishable with death or imprisonment for life.`
  line
  line `(4) The Tribunal shall allow an appeal against conviction by a court martial where--`
  line
  line `(a) the finding of the court martial is legally not sustainable due to any reason whatsoever; or`
  line
  line `(b) the finding involves wrong decision on a question of law; or`
  line
  line `(c) there was a material irregularity in the course of the trial resulting in miscarriage of justice,`
  line
  line `but, in any other case, may dismiss the appeal where the Tribunal considers that no miscarriage of justice`
  line `is likely to be caused or has actually resulted to the appellant:`
  line
  line `Provided that no order dismissing the appeal by the Tribunal shall be passed unless such order is`
  line `made after recording reasons therefor in writing.`
  line
  line `(5) The Tribunal may allow an appeal against conviction, and pass appropriate order thereon.`
  line
  line `(6) Notwithstanding anything contained in the foregoing provisions of this section, the Tribunal shall`
  line `have the power to--`
  line
  line `(a) substitute for the findings of the court martial, a finding of guilty for any other offence for`
  line `which the offender could have been lawfully found guilty by the court martial and pass a sentence`
  line `afresh for the offence specified or involved in such findings under the provisions of the Army Act,`
  line `1950 (46 of 1950) or the Navy Act, 1957 (62 of 1957) or the Air Force Act, 1950 (45 of 1950), as the`
  line `case may be; or`
  line
  line `(b) if sentence is found to be excessive, illegal or unjust, the Tribunal may--`
  line
  line `(i) remit the whole or any part of the sentence, with or without conditions;`
  line
  line `(ii) mitigate the punishment awarded;`
  line
  line `(iii) commute such punishment to any lesser punishment or punishments mentioned in the`
  line `Army Act, 1950 (46 of 1950), the Navy Act, 1957 (62 of 1957) and the Air Force Act,`
  line `1950 (45 of 1950), as the case may be;`
  line
  line `(c) enhance the sentence awarded by a court martial:`
  line
  line `Provided that no such sentence shall be enhanced unless the appellant has been given an`
  line `opportunity of being heard;`
  line
  line `(d) release the appellant, if sentenced to imprisonment, on parole with or without conditions;`
  line
  line `(e) suspend a sentence of imprisonment;`
  line
  line `(f) pass any other order as it may think appropriate.`
  line
  line `(7) Notwithstanding any other provisions in this Act, for the purposes of this section, the Tribunal`
  line `shall be deemed to be a criminal court for the purposes of sections 175, 178, 179, 180, 193, 195, 196 or`
  line `228 of the Indian Penal Code (45 of 1860) and Chapter XXVI of the Code of Criminal Procedure, 1973`
  line `(2 of 1974).`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (3338)
  sectionNo (16)
  orderNo 17
  title Re-trial.
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3338&sectionno=16&orderno=17&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_16_content:
  string
  line `(1) Except as provided by this Act, where the conviction of a person by court martial`
  line `for an offence has been quashed, he shall not be liable to be tried again for that offence by a court martial`
  line `or by any other Court.`
  line
  line `(2) The Tribunal shall have the power of quashing a conviction, to make an order authorising the`
  line `appellant to be retried by court martial, but shall only exercise this power when the appeal against`
  line `conviction is allowed by reasons only of evidence received or available to be received by the Tribunal`
  line `under this Act and it appears to the Tribunal that the interests of justice require that an order under this`
  line `section should be made:`
  line
  line `Provided that an appellant shall not be retried under this section for an offence other than--`
  line
  line `(a) the offence for which he was convicted by the original court martial and in respect of which`
  line `his appeal is allowed;`
  line
  line `(b) any offence for which he could have been convicted at the original court martial on a charge`
  line `of the first-mentioned offence;`
  line
  line `(c) any offence charged in the alternative in respect of which the court martial recorded no`
  line `finding in consequence of convicting him of the first-mentioned offence.`
  line
  line `(3) A person who is to be retried under this section for an offence shall, if the Tribunal or the`
  line `Supreme Court so directs, whether or not such person is being tried or retried on one or more of the`
  line `original charges, no fresh investigation or other action shall be taken under the relevant provision of the`
  line `Army Act, 1950 (46 of 1950) or the Navy Act, 1957 (62 of 1957) or the Air Force Act, 1950 (45 of 1950)`
  line `as the case may be, or rules and regulations made there under, in relation to the said charge or charges on`
  line `which he is to be retried.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (3339)
  sectionNo (17)
  orderNo 18
  title `Powers of the Tribunal on appeal under section 15.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3339&sectionno=17&orderno=18&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_17_content:
  string
  line `The Tribunal, while hearing and deciding`
  line `an appeal under section 15, shall have the power--`
  line
  line `(a) to order production of documents or exhibits connected with the proceedings before the court`
  line martial;
  line
  line `(b) to order the attendance of the witnesses;`
  line
  line `(c) to receive evidence;`
  line
  line `(d) to obtain reports from Court martial;`
  line
  line `(e) order reference of any question for enquiry;`
  line
  line `(f) appoint a person with special expert knowledge to act as an assessor; and`
  line
  line `(g) to determine any question which is necessary to be determined in order to do justice in the`
  line case.
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (3340)
  sectionNo (18)
  orderNo 19
  title Cost.
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3340&sectionno=18&orderno=19&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_18_content:
  string
  line `While disposing of the application under section 14 or an appeal under section 15, the`
  line `Tribunal shall have power to make such order as to costs as it may deem just.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (3341)
  sectionNo (19)
  orderNo 20
  title `Power to punish for contempt.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3341&sectionno=19&orderno=20&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_19_content:
  string
  line `(1) Any person who is guilty of contempt of the Tribunal by`
  line `using any insulting or threatening language, or by causing any interruption or disturbance in the`
  line `proceedings of such Tribunal shall, on conviction, be liable to suffer imprisonment for a term which may`
  line `extend to three years.`
  line
  line `(2) For the purposes of trying an offence under this section, the provisions of sections 14, 15, 17, 18`
  line `and 20 of the Contempt of Courts Act, 1971 (70 of 1971) shall mutatis mutandis apply, as if a reference`
  line `therein to--`
  line
  line `(a) Supreme Court or High Court were a reference to the Tribunal;`
  line
  line `(b) Chief Justice were a reference to the Chairperson;`
  line
  line `(c) Judge were a reference to the Judicial or Administrative Member of the Tribunal;`
  line
  line `(d) Advocate-General were a reference to the prosecutor; and`
  line
  line `(e) Court were a reference to the Tribunal.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (3342)
  sectionNo (20)
  orderNo 21
  title `Distribution of business among the Benches.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3342&sectionno=20&orderno=21&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_20_content:
  string
  line `The Chairperson may make provisions as to the`
  line `distribution of the business of the Tribunal among its Benches.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (3343)
  sectionNo (21)
  orderNo 22
  title `Application not to be admitted unless other remedies exhausted.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3343&sectionno=21&orderno=22&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_21_content:
  string
  line `(1) The Tribunal shall not`
  line `ordinarily admit an application unless it is satisfied that the applicant had availed of the remedies`
  line `available to him under the Army Act, 1950 (46 of 1950) or the Navy Act, 1957 (62 of 1957) or the Air`
  line `Force Act, 1950 (45 of 1950), as the case may be, and respective rules and regulations made thereunder.`
  line
  line `(2) For the purposes of sub-section (1), a person shall be deemed to have availed of all the remedies`
  line `available to him under the Army Act, 1950 (46 of 1950) or the Navy Act, 1957 (62 of 1957) or the Air`
  line `Force Act, 1950 (45 of 1950), and respective rules and regulations--`
  line
  line `(a) if a final order has been made by the Central Government or other authority or officer or other`
  line `person competent to pass such order under the said Acts, rules and regulations, rejecting any petition`
  line `preferred or representation made by such person;`
  line
  line `(b) where no final order has been made by the Central Government or other authority or officer or`
  line `other person competent to pass such order with regard to the petition preferred or representation made`
  line `by such person, if a period of six months from the date on which such petition was preferred or`
  line `representation was made has expired.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (3344)
  sectionNo (22)
  orderNo 23
  title Limitation.
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3344&sectionno=22&orderno=23&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_22_content:
  string
  line `The Tribunal shall not admit an application--`
  line
  line `(a) in a case where a final order such as is mentioned in clause (a) of sub-section (2) of section 21`
  line `has been made unless the application is made within six months from the date on which such final`
  line `order has been made;`
  line
  line `(b) in a case where a petition or a representation such as is mentioned in clause (b) of`
  line `sub-section (2) of section 21 has been made and the period of six months has expired thereafter`
  line `without such final order having been made;`
  line
  line `(c) in a case where the grievance in respect of which an application is made had arisen by reason`
  line `of any order made at any time during the period of three years immediately preceding the date on`
  line `which jurisdiction, powers and authority of the Tribunal became exercisable under this Act, in respect`
  line `of the matter to which such order relates and no proceedings for the redressal of such grievance had`
  line `been commenced before the said date before the High Court.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Tribunal may admit an application`
  line `after the period of six months referred to in clause (a) or clause (b) of sub-section (1), as the case may be,`
  line `or prior to the period of three years specified in clause (c), if the Tribunal is satisfied that the applicant`
  line `had sufficient cause for not making the application within such period.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (3345)
  sectionNo (23)
  orderNo 24
  title `Procedure and powers of the Tribunal.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3345&sectionno=23&orderno=24&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_23_content:
  string
  line `(1) The Tribunal shall not be bound by the procedure`
  line `laid down in the Code of Civil Procedure, 1908 (5 of 1908) but shall be guided by the principles of`
  line `natural justice and subject to the other provisions of this Act and any rules made thereunder, the Tribunal`
  line `shall have the power to lay down and regulate its own procedure including the fixing of place and time of`
  line `its inquiry and deciding whether to sit in public or in camera.`
  line
  line `(2) The Tribunal shall decide every application made to it as expeditiously as possible after a perusal`
  line `of documents, affidavits and written representations and after hearing such oral arguments as may be`
  line `advanced:`
  line
  line `Provided that where the Tribunal deems it necessary, for reasons to be recorded in writing, it may`
  line `allow oral evidence to be adduced.`
  line
  line `(3) No adjournment shall be granted by the Tribunal without recording the reasons justifying the grant`
  line `of such adjournment and cost shall be awarded, if a party requests for adjournment more than twice.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (3346)
  sectionNo (24)
  orderNo 25
  title `Term of sentence and its effect on appeal.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3346&sectionno=24&orderno=25&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_24_content:
  string
  line `(1) The term of any sentence passed by the`
  line `Tribunal under clause (a) of sub-section (6) of section 15 of this Act shall, unless the Tribunal otherwise`
  line `directs, be reckoned to commence on the day on which it would have commenced under the Army Act,`
  line `1950 (46 of 1950), the Navy Act, 1957 (62 of 1957) or the Air Force Act, 1950 (45 of 1950), as the case`
  line `may be, under which the court martial against which the appeal was filed, had been held.`
  line
  line `(2) Subject to the provisions of sub-section (3), any sentence passed on an appeal from the Tribunal to`
  line `the Supreme Court in substitution for another sentence shall, unless the Supreme Court otherwise directs,`
  line `be reckoned to commence on the day on which the original sentence would have commenced.`
  line
  line `(3) Where a person who is undergoing sentence is granted stay of the operation of the said sentence,`
  line `either by suspension or otherwise, pending an appeal, the period during which he is so released due to the`
  line `sentence having been so stayed, shall be excluded in computing the term for which he is so sentenced by`
  line `the Tribunal or the Supreme Court, as the case may be.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (3347)
  sectionNo (25)
  orderNo 26
  title `Right of applicant or of appellant to take assistance of a legal practitioner and of Government, etc., to appoint counsel.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3347&sectionno=25&orderno=26&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_25_content:
  string
  line `(1) A person making an application or preferring an appeal to`
  line `the Tribunal may either appear in person or take the assistance of a legal practitioner of his choice to`
  line `present his case before the Tribunal..`
  line
  line `(2) The Central Government or the competent authority, as may be prescribed, may authorise one or`
  line `more legal practitioners or any of its law officers to act as counsel and every person so authorised by it`
  line `may present its case with respect to any application or appeal, as the case may be, before the Tribunal.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (3348)
  sectionNo (26)
  orderNo 27
  title `Condition as to making of interim order.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3348&sectionno=26&orderno=27&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_26_content:
  string
  line `(1) Notwithstanding anything contained in any other`
  line `provisions of this Act or in any other law for the time being in force, no interim order (whether by way of`
  line `injunction or stay or in any other manner) shall be made on an application or appeal, or in any proceeding`
  line `relating thereto, unless--`
  line
  line `(a) copies of such application or appeal, as the case may be, and all documents in support of the`
  line `plea for such interim order are furnished to the party against whom such application or appeal, as the`
  line `case may be, is made or proposed to be made; and`
  line
  line `(b) opportunity of being heard is given to the other party in the matter:`
  line
  line `Provided that the Tribunal may dispense with the requirements of clauses (a) and (b) and make an`
  line `interim order as an exceptional measure if it is satisfied, for reasons to be recorded in writing, that it is`
  line `necessary so to do for preventing any loss being caused to the applicant or to the appellant, as the case`
  line `may be.`
  line
  line `(2) Where any party against whom an interim order, whether by way of injunction or stay or in any`
  line `other manner, is made on an application or appeal or in any proceeding relating thereto under`
  line `sub-section (1), without--`
  line
  line `(a) furnishing to such party copies of such application or appeal, as the case may be, and all`
  line `documents in support of the plea for such interim order; and`
  line
  line `(b) giving such party an opportunity of being heard, and making an application to the Tribunal for`
  line `the vacation of such order and furnishing a copy of such application or appeal, as the case may be, to`
  line `the party in whose favour such order has been made or the counsel of such party,`
  line
  line `the Tribunal shall dispose of the application within a period of fourteen days from the date on which it is`
  line `received or from the date on which the copy of such application is so furnished, whichever is later, or`
  line `where the Tribunal is closed on the last day of that period, before the expiry of the next working day; and`
  line `if the application is not so disposed of, the interim order shall, on the expiry of that period, or, as the case`
  line `may be, the expiry of the said next working day, stand vacated.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (3349)
  sectionNo (27)
  orderNo 28
  title `Power of Chairperson to transfer cases from one Bench to another.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3349&sectionno=27&orderno=28&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_27_content:
  string
  line `On the application of`
  line `any of the parties and after notice to the parties concerned, and after hearing such of them as he may`
  line `desire to be heard, or on his own motion without such notice, the Chairperson may transfer any case`
  line `pending before one Bench for disposal, to any other Bench.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (3350)
  sectionNo (28)
  orderNo 29
  title `Decision to be by majority.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3350&sectionno=28&orderno=29&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_28_content:
  string
  line `If the Members of a Bench differ in opinion on any point, the point`
  line `shall be decided according to the opinion of the majority, if there is a majority, but if the Members are`
  line `equally divided, they shall state the point or points on which they differ and make a reference to the`
  line `Chairperson who shall either hear the point or points himself or refer the case for hearing on such point or`
  line `points by one or more of the Members of the Tribunal and such point or points shall be decided according`
  line `to the opinion of the majority of the Members of the Tribunal who have heard the case, including those`
  line `who first heard it.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (3351)
  sectionNo (29)
  orderNo 30
  title `Execution of order of Tribunal.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3351&sectionno=29&orderno=30&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_29_content:
  string
  line `Subject to the other provisions of this Act and the rules made`
  line `thereunder, the order of the Tribunal disposing of an application shall be final and shall not be called in`
  line `question in any Court and such order shall be executed accordingly.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (3352)
  sectionNo (30)
  orderNo 31
  title `Appeal to Supreme Court.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3352&sectionno=30&orderno=31&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_30_content:
  string
  line `(1) Subject to the provisions of section 31, an appeal shall lie to the`
  line `Supreme Court against the final decision or order of the Tribunal (other than an order passed under`
  line `section 19):`
  line
  line `Provided that such appeal is preferred within a period of ninety days of the said decision or order:`
  line
  line `Provided further that there shall be no appeal against an interlocutory order of the Tribunal.`
  line
  line `(2) An appeal shall lie to the Supreme Court as of right from any order or decision of the Tribunal in`
  line `the exercise of its jurisdiction to punish for contempt:`
  line
  line `Provided that an appeal under this sub-section shall be filed in the Supreme Court within sixty days`
  line `from the date of the order appealed against.`
  line
  line `(3) Pending any appeal under sub-section (2), the Supreme Court may order that--`
  line
  line `(a) the execution of the punishment or the order appealed against be suspended; or`
  line
  line `(b) if the appellant is in confinement, he be released on bail:`
  line
  line `Provided that where an appellant satisfies the Tribunal that he intends to prefer an appeal, the`
  line `Tribunal may also exercise any of the powers conferred under clause (a) or clause (b), as the case may be.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (3353)
  sectionNo (31)
  orderNo 32
  title `Leave to appeal.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3353&sectionno=31&orderno=32&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_31_content:
  string
  line `(1) An appeal to the Supreme Court shall lie with the leave of the Tribunal;`
  line `and such leave shall not be granted unless it is certified by the Tribunal that a point of law of general`
  line `public importance is involved in the decision, or it appears to the Supreme Court that the point is one`
  line `which ought to be considered by that Court.`
  line
  line `(2) An application to the Tribunal for leave to appeal to the Supreme Court shall be made within a`
  line `period of thirty days beginning with the date of the decision of the Tribunal and an application to the`
  line `Supreme Court for leave shall be made within a period of thirty days beginning with the date on which`
  line `the application for leave is refused by the Tribunal.`
  line
  line `(3) An appeal shall be treated as pending until any application for leave to appeal is disposed of and if`
  line `leave to appeal is granted, until the appeal is disposed of; and an application for leave to appeal shall be`
  line `treated as disposed of at the expiration of the time within which it might have been made, but it is not`
  line `made within that time.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (3354)
  sectionNo (32)
  orderNo 33
  title Condonation.
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3354&sectionno=32&orderno=33&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_32_content:
  string
  line `The Supreme Court may, upon an application made at any time by the appellant,`
  line `extend the time within which an appeal may be preferred by him to that Court under section 30 or`
  line `sub-section (2) of section 31.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (3355)
  sectionNo (33)
  orderNo 34
  title `Exclusion of jurisdiction of civil courts.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3355&sectionno=33&orderno=34&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_33_content:
  string
  line `On and from the date from which any jurisdiction,`
  line `powers and authority becomes exercisable by the Tribunal in relation to service matters under this Act, no`
  line `civil court shall have, or be entitled to exercise, such jurisdiction, power or authority in relation to those`
  line `service matters.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (3356)
  sectionNo (34)
  orderNo 35
  title `Transfer of pending cases.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3356&sectionno=34&orderno=35&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_34_content:
  string
  line `(1) Every suit, or other proceeding pending before any court`
  line `including a High Court or other authority immediately before the date of establishment of the Tribunal`
  line `under this Act, being a suit or proceeding the cause of action whereon it is based, is such that it would`
  line `have been within the jurisdiction of the Tribunal, if it had arisen after such establishment within the`
  line `jurisdiction of such Tribunal, stand transferred on that date to such Tribunal.`
  line
  line `(2) Where any suit, or other proceeding stands transferred from any court including a High Court or`
  line `other authority to the Tribunal under sub-section (1),--`
  line
  line `(a) the court or other authority shall, as soon as may be, after such transfer, forward the records of`
  line `such suit, or other proceeding to the Tribunal;`
  line
  line `(b) the Tribunal may, on receipt of such records, proceed to deal with such suit, or other`
  line `proceeding, so far as may be, in the same manner as in the case of an application made under subsection`
  line `(2) of section 14, from the stage which was reached before such transfer or from any earlier`
  line `stage or de novo as the Tribunal may deem fit.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (3357)
  sectionNo (35)
  orderNo 36
  title `Provision for filing of certain appeals.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3357&sectionno=35&orderno=36&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_35_content:
  string
  line `Where any decree or order has been made or passed by`
  line `any court (other than a High Court) or any other authority in any suit or proceeding before the`
  line `establishment of the Tribunal, being a suit or proceeding the cause of action whereon it is based, is such`
  line `that it would have been, if it had arisen after such establishment, within the jurisdiction of the Tribunal,`
  line `and no appeal has been preferred against such decree or order before such establishment or if preferred,`
  line `the same is pending for disposal before any court including High Court and the time for preferring such`
  line `appeal under any law for the time being in force had not expired before such establishment, such appeal`
  line `shall lie to the Tribunal, within ninety days from the date on which the Tribunal is established, or within`
  line `ninety days from the date of receipt of the copy of such decree or order, whichever is later.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (3358)
  sectionNo (36)
  orderNo 37
  title `Proceedings before Tribunal to be judicial proceedings.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3358&sectionno=36&orderno=37&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_36_content:
  string
  line `All proceedings before the Tribunal`
  line `shall be deemed to be judicial proceedings within the meaning of sections 193, 219 and 228 of the Indian`
  line `Penal Code (45 of 1860).`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (3359)
  sectionNo (37)
  orderNo 38
  title `Members and staff of Tribunal to be public servants.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3359&sectionno=37&orderno=38&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_37_content:
  string
  line `The Chairperson, other Members and`
  line `the officers and other employees provided under section 13 to the Tribunal shall be deemed to be public`
  line `servants within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (3360)
  sectionNo (38)
  orderNo 39
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3360&sectionno=38&orderno=39&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_38_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government or against the Chairperson or any other Member or any other person`
  line `authorised by the Chairperson, for anything which is done in good faith or intended to be done in`
  line `pursuance of this Act or any rule or order made thereunder in the discharge of official duties.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (3361)
  sectionNo (39)
  orderNo 40
  title `Act to have overriding effect.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3361&sectionno=39&orderno=40&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_39_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force or in any instrument`
  line `having effect by virtue of any law other than this Act.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (3362)
  sectionNo (40)
  orderNo 41
  title `Power to remove difficulties.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3362&sectionno=40&orderno=41&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_40_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (3363)
  sectionNo (41)
  orderNo 42
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3363&sectionno=41&orderno=42&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_41_content:
  string
  line `(1) The Central Government may, by`
  line `notification, make rules for the purposes of carrying out the provisions of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may provide for all or any`
  line `of the following matters, namely:--`
  line
  line `(a) the case or cases which shall be decided by a Bench composed of more than two Members`
  line `under clause (c) of sub-section (3) of section 5;`
  line
  line `(b) the procedure under sub-section (3) of section 9 for the investigation of misbehaviour or`
  line `incapacity of Chairperson or other Member;`
  line
  line `(c) the salaries and allowances payable to, and the other terms and conditions of service of the`
  line `Chairperson and other Members under section 10;`
  line
  line `(d) the financial and administrative powers which the Chairperson may exercise over the Benches`
  line `of the Tribunal under section 12;`
  line
  line `(e) the salaries and allowances payable to, and other terms and conditions of service of the`
  line `officers and other employees of the Tribunal under sub-section (2) of section 13;`
  line
  line `(f) the form in which an application may be made under sub-section (2) of section 14, the`
  line `documents and other evidence by which such application shall be accompanied and the fee payable in`
  line `respect of the filing of such application or for the service of execution of processes;`
  line
  line `(g) the other matter which may be prescribed under clause (i) of sub-section (4) of section 14;`
  line
  line `(h) the form and manner in which an appeal may be filed, the fee payable thereon and the time`
  line `within which such appeal may be filed under sub-section (2) of section 15;`
  line
  line `(i) the rules subject to which the Tribunal shall have power to regulate its own procedure under`
  line `sub-section (1) of section 23;`
  line
  line `(j) competent authority who may authorise legal practitioners or law officers to act as counsel`
  line `under sub-section (2) of section 25;`
  line
  line `(k) any other matter which may be prescribed or in respect of which rules are required to be made`
  line `by the Central Government.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (3364)
  sectionNo (42)
  orderNo 43
  title `Power to make rules retrospectively.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3364&sectionno=42&orderno=43&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_42_content:
  string
  line `The powers to make rules under section 41 shall include`
  line `the power to make such rules or any of them retrospectively from a date not earlier than the date on which`
  line `this Act shall come into operation but no such retrospective effect shall be given to any such rule so as to`
  line `prejudicially affect the interests of any person to whom such rule may be applicable.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (3365)
  sectionNo (43)
  orderNo 44
  title `Laying of rules.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00013_200755_1517807323574&sectionId=3365&sectionno=43&orderno=44&orgactid=AC_CEN_28_38_00013_200755_1517807323574
obj_root_law_sections_43_content:
  string
  line `Every rule made under this Act shall be laid, as soon as may be after it is`
  line `made, before each House of Parliament while it is in session, for a total period of thirty days which may`
  line `be comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule.`
obj_root_law_sections_43_footnotes:
  string
  line
