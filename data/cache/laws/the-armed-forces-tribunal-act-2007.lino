obj_root_law:
  object
  (str slug) (str the-armed-forces-tribunal-act-2007)
  (str handle) (str 2077)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Armed Forces Tribunal Act, 2007`)
  (str actNumber) (str 55)
  (str enactmentDate) (str 2007-12-25)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2077`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `सशस्‍त्र बल अधिकरण अधिनियम, 2007`)
  (str actYear) (str 2007)
  (str ministry) (str `Ministry of Defence`)
  (str department) (str `Department of Defence`)
  (str longTitle) (str `An Act to provide for the adjudication or trial by Armed Forces Tribunal of disputes and complaints with respect to commission, appointments, enrolment and conditions of service in respect of persons subject to the Army Act, 1950, the Navy Act, 1957 and the Air Force Act 1950 and also to provide for appeals arising out of orders, findings or sentences of court martial held under the said Acts and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 15-06-2008)
  (str notification) (str `15th June, 2008, vide notification No. S.O. 14(E), dated 13th June, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T18:28:28.679Z`)
  (str translations) obj_root_law_translations
