obj_root_law_sections_16:
  sectionId (14166)
  sectionNo (16)
  orderNo 32
  title `Bar of legal proceedings.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00002_194861_1517807318751&sectionId=14166&sectionno=16&orderno=32&orgactid=AC_CEN_20_25_00002_194861_1517807318751
obj_root_law_sections_16_content:
  string
  line `No suit, prosecution or other legal proceeding shall lie against the`
  line `Board, or any member or officer of the Board, for anything in good faith done or intended to be done`
  line `under this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_16_a:
  sectionId (14167)
  sectionNo 16A
  orderNo 33
  title `Effect of Act and rules, etc., inconsistent with other enactments.`
  content obj_root_law_sections_16_a_content
  footnotes `1 Ins. by s. 15, ibid. (w.e.f. 1-7-2007).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00002_194861_1517807318751&sectionId=14167&sectionno=16A&orderno=33&orgactid=AC_CEN_20_25_00002_194861_1517807318751
obj_root_law_sections_16_a_content:
  string
  line `^1[16A. Effect of Act and rules, etc., inconsistent with other enactments.--The provisions of this`
  line `Act or any rule or regulation made thereunder shall have effect notwithstanding anything inconsistent`
  line `therewith contained in any enactment other than this Act or any instrument having effect by virtue of any`
  line `enactment other than this Act.]`
