  (str orderNo) (int 34)
  (str title) (str Omitted..)
  (str content) (str `7^1. [Temporary powers of the Central Government.]Omitted by the Central Silk Board (Amendment)
Act, 1953 (31 of 1953), s. 11.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00002_194861_1517807318751&sectionId=14168&sectionno=17&orderno=34&orgactid=AC_CEN_20_25_00002_194861_1517807318751)
