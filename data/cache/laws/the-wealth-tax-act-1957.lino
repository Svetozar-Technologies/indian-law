  footnotes obj_root_law_sections_8_footnotes
  sourcePage 8
obj_root_law_sections_8_content:
  string
  line 8
  line `1 [( e ) “ assets ” includes property of every description, movable or immovable, but does not`
  line `include, —`
  line `( 1 ) in relation to the assessment year commencing on the 1st day of April, 1969, or any`
  line `earlier assessment year —`
  line `( i ) agricultural land and growing crops, grass or standing trees on such land;`
  line `( ii ) any building owned or occupied by a cultivator of, or receiver of rent or revenue out`
  line `of, agricultural land:`
  line `Provided that the building is on or in the immediate vicinity of the land and is a building`
  line `which the cultivator or the receiver of rent or revenue by reason of his connection with the`
  line `land requires as a dwelling house or a store-house or an out-house;`
  line `( iii ) animals;`
  line `( iv ) a right to any annuity in any case where the terms and conditions relating thereto`
  line `preclude the commutation of any portion thereof into a lump sum grant;`
  line `( v ) any interest in property where the interest is available to an assessee for a period not`
  line `exceeding six years from the date the interest vests in the assessee;`
  line `( 2 ) in relation to the assessment year commencing on the 1st day of April, 1970, or any`
  line `subsequent assessment year 2 [but before the 1st day of April, 1993] —`
  line `( i ) animals;`
  line `( ii ) a right to 3 [any annuity (not being an annuity purchased by the assessee or purchased`
  line `by any other person in pursuance of a contract with the assessee)] in any case where the terms`
  line `and conditions relating thereto preclude the commutation of any portion thereof into a lump`
  line `sum grant;`
  line `( iii ) any interest in property where the interest is available to an assessee for a period not`
  line `exceeding six years from the date the interest vests in the assessee:]`
  line `4 [Provided that in relation to the assessment year commencing on the 1st day of April,`
  line `1981, 5 [and the assessment year commencing on the 1st day of April, 1982], this sub-clause`
  line `shall have effect subject to the modification that for item ( i ) thereof, the following item shall`
  line `be substituted, namely: —`
  line `“ ( i ) ( a ) agricultural land other than land comprised in any tea, coffee, rubber or`
  line `cardamom plantation;`
  line `( b ) any building owned or occupied by a cultivator of, or receiver of rent or revenue`
  line `out of, agricultural land other than land comprised in any tea, coffee, rubber or cardamom`
  line `plantation:`
  line `Provided that the building is on or in the immediate vicinity of the land and is a`
  line `building which the cultivator or the receiver of the rent or revenue by reason of his`
  line `connection with the land requires as a dwelling-house or a store-house or an out-house;`
  line `( c ) animals:`
  line `1. Subs. by Act 14 of 1969, s. 24, for clause ( e ) (w.e.f. 1-4-1969).`
  line `2. Ins. by Act 18 of 1992, s. 89 (w.e.f. 1-4-1993).`
  line `3. Subs. by Act 20 of 1974, s. 14, for “any annuity” (w.e.f. 1 -4-1975).`
  line `4. Subs. by Act 4 4 of 1980, s. 36, for “Provided that” (w.e.f. 1 -4-1981).`
  line `5. Subs. by Act 14 of 1982, s. 33, for “or any subsequent assessment year” (w.e.f. 1 -4-1983).`
obj_root_law_sections_8_footnotes:
  string
  line
