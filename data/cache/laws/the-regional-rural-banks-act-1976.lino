obj_root_law:
  slug the-regional-rural-banks-act-1976
  handle (1492)
  collectionHandle 123456789/1362
  title `The Regional Rural Banks Act, 1976`
  actNumber (21)
  enactmentDate 1976-02-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1492`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `प्रादेशिक ग्रामीण बैंक अधिनियम,1976`
  actYear (1976)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to provide for the incorporation, regulation and winding up of Regional Rural Banks with a view to developing the rural economy by providing, for the purpose of development of agriculture, trade, commerce, industry and other productive activities in the rural areas, credit and other facilities, particularly to the small and marginal farmers, agricultural labourers, artisans and small entrepreneurs, and for matters connected therewith and incidental thereto.`
  enforcementDate 26-09-1975
  fetchedAt `2026-05-08T20:17:35.084Z`
  translations obj_root_law_translations
