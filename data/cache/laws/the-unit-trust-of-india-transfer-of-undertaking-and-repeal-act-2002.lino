  (str title) (str `भारतीय यूनिट ट्रस्ट (उपक्रम का अंतरणऔर निरसन) अधिनियम, 2002`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1889/3/H2002-58.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T12:38:06.880Z`)
