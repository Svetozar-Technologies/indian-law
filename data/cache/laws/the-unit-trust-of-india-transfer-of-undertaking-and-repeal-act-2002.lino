obj_root_law_sections_1:
  sectionId (32709)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32709&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Unit Trust of India (Transfer of`
  line `Undertaking and Repeal) Act, 2002.`
  line
  line `(2) It shall be deemed to have come into force on the 29th day of October, 2002.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (32710)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32710&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Administrator" means a person or a body of persons appointed as Administrator under`
  line `section 7;`
  line
  line `(b) "appointed day" means such date as the Central Government may, by notification in the`
  line `Official Gazette, appoint under section 4;`
  line
  line `(c) "bank" shall have the meaning assigned to it in clause (d) of section 2 of the Recovery of`
  line `Debts Due to Banks and Financial Institutions Act, 1993 (51 of 1993);`
  line
  line `(d) "Development Bank" means the Industrial Development Bank of India established under the`
  line `Industrial Development Bank of India Act, 1964 (18 of 1964);`
  line
  line `(e) "financial institution" shall have the meaning assigned to it in clause (h) of section 2of the`
  line `Recovery of Debts Due to Banks and Financial Institutions Act, 1993 (51 of 1993);`
  line
  line `(f) "Life Insurance Corporation of India" means the Life Insurance Corporation of India`
  line `established under sub-section (1) of section 3 of the Life Insurance Corporation Act, 1956`
  line `(31 of 1956);`
  line
  line `(g) "Schedule" means Schedules I and II to this Act;`
  line
  line `(h) "specified company" means a company to be formed and registered under the Companies Act,`
  line `1956 (1 of 1956) and whose entire capital is subscribed by such financial institutions or banks as may`
  line `be specified by the Central Government, by notification in the Official Gazette, for the purpose of`
  line `transfer and vesting of the undertaking;`
  line
  line `(i) "specified undertaking" includes all business, assets, liabilities and properties of the Trust`
  line `representing and relatable to the schemes and Development Reserve Fund specified in the Schedule I;`
  line
  line `(j) "State Bank" means the State Bank of India constituted under the State Bank of India Act,`
  line `1955 (23 of 1955);`
  line
  line `(k) "Trust" means the Unit Trust of India established under sub-section (1) of section 3 of the`
  line `Unit Trust of India Act, 1963 (52 of 1963);`
  line
  line `(l) "undertaking" includes all business, assets, liabilities and properties of the Trust representing`
  line `and relatable to the schemes and plans specified in the Schedule II;`
  line
  line `(m) "unit" means a unit issued under a unit scheme made under section 21 of the Unit Trust of`
  line `India Act, 1963 (52 of 1963).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (32711)
  sectionNo (3)
  orderNo 3
  title `Transfer of initial capital.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32711&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_3_content:
  string
  line `(1) On the appointed day, the initial capital of the Trust, contributed`
  line `by the Development Bank, the Life Insurance Corporation, the State Bank and the subsidiary banks and`
  line `other institutions under sections 4 and 4A of the Unit Trust of India Act, 1963(52 of 1963), as it stood`
  line `immediately before the commencement of this Act, shall stand transferred to, and vest in, the Central`
  line Government.
  line
  line `(2) The initial capital contributed by the Development Bank, the Life Insurance Corporation, the State`
  line `Bank and the subsidiary banks and other institutions shall be refunded, by the Central Government, to`
  line `such extent as may be determined by it, having regard to the book value, the assets and liabilities of the`
  line Trust.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (32712)
  sectionNo (4)
  orderNo 4
  title `Undertaking of Trust to vest in specified company and specified undertaking of Trust to vest in Administrator.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32712&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_4_content:
  string
  line `(1) On such date as the Central Government may, by notification in the Official`
  line `Gazette, appoint, there shall be transferred to, and vest in,--`
  line
  line `(a) the specified company, the undertaking (excluding the specified undertaking) of the Trust for`
  line `such consideration and on such terms and conditions as may be mutually agreed upon between the`
  line `Central Government and the subscribers to the capital of the specified company;`
  line
  line `(b) the Administrator, the specified undertaking of the Trust.`
  line
  line `(2) The decision of the Central Government, as to whether any business, assets, liabilities or`
  line `properties represent or relate to the undertaking or specified undertaking, shall be final:`
  line
  line `Provided that any business, asset or property which is not represented or related to the undertaking or`
  line `specified undertaking, shall vest in the Central Government.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (32713)
  sectionNo (5)
  orderNo 5
  title `General effect of vesting of undertaking or specified undertaking in specified company or Administrator.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32713&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_5_content:
  string
  line `(1) The undertaking of the Trust which is transferred to, and which vest in, the`
  line `specified company or the specified undertaking of the Trust, which is transferred to, and vest in, the`
  line `Administrator, as the case may be, under section 4, shall be deemed to include all business, assets, rights,`
  line `powers, authorities and privileges and all properties, movable and immovable, real and personal,`
  line `corporeal and incorporeal, in possession or reservation, present or contingent of whatever nature and`
  line `wheresoever situate including lands, buildings, vehicles, cash balances, deposits, foreign currencies,`
  line `disclosed and undisclosed reserves, reserve fund, special reserve fund, benevolent reserve fund, any other`
  line `fund, stocks, investments, shares, bonds, debentures, security, management of any industrial concern,`
  line `loans, advances and guarantees given to industrial concerns, tenancies, leases and book-debts and all`
  line `other rights and interests arising out of such property as were immediately before the appointed day in the`
  line `ownership, possession or power of the Trust in relation to the undertaking or the specified undertaking, as`
  line `the case may be, within or without India, all books of account, registers, records and documents relating`
  line `thereto and shall also be deemed to include all borrowings, liabilities, units issued and obligations of`
  line `whatever kind within or without India then subsisting of the Trust in relation to such undertaking or the`
  line `specified undertaking, as the case may be.`
  line
  line `(2) All contracts, deeds, bonds, guarantees, powers-of-attorney, other instruments (including all units`
  line `issued and unit schemes formulated by the Trust) and working arrangements subsisting immediately`
  line `before the appointed day and affecting the Trust shall cease to have effect or to be enforceable against the`
  line `Trust and shall be of as full force and effect against or in favour of the specified company or the`
  line `Administrator, as the case may be, in which the undertaking or specified undertaking has vested by virtue`
  line `of this Act and enforceable as fully and effectually as if instead of the Trust, the specified company or the`
  line `Administrator, as the case may be, had been named therein or had been a party thereto.`
  line
  line `(3) All unit schemes taken by the Board of the Trust immediately before the commencement of this`
  line `Act shall be deemed to have been taken by the specified company or the Administrator, as the case may be, and all the units issued by the Trust under such scheme shall be deemed to be the units issued by the`
  line `specified company or the Administrator, as the case may be, and the income on such units shall be`
  line `distributed and such units shall be redeemed or purchased by them in the same manner as would have`
  line `been done by the Trust had the undertaking or the specified undertaking not been transferred under`
  line `section 4.`
  line
  line `(4) Any proceeding or cause of action pending or existing immediately before the appointed day by or`
  line `against the Trust may, as from the appointed day, be continued and enforced by or against the specified`
  line `company or the Administrator, as the case may be, in which the undertaking or specified undertaking has`
  line `vested by virtue of this Act as it might have been enforced by or against the Trust if this Act had not been`
  line `enacted and shall cease to be enforceable by or against the Trust.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (32714)
  sectionNo (6)
  orderNo 6
  title `Provisions in respect of officers and other employees of Trust.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32714&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_6_content:
  string
  line `(1) Every officer or other`
  line `employee of the Trust (except a trustee of the Board, the Chairman and executive trustee) serving in the`
  line `employment immediately before the appointed day shall become, as from the appointed day, an officer or,`
  line `as the case may be, other employee of the specified company and shall hold his office or service therein`
  line `by the same tenure, at the same remuneration, upon the same terms and conditions, with the same`
  line `obligations and with the same rights and privileges as to leave, leave fare concession, welfare scheme,`
  line `medical benefit scheme, insurance, provident fund, other funds, retirement, voluntary retirement, gratuity`
  line `and other benefits as he would have held under the Trust if its undertaking had not vested in the specified`
  line `company and shall continue to do so as an officer or, as the case may be, other employee of the specified`
  line `company or until the expiry of a period of six months from the appointed day if such officer or other`
  line `employee opts not to continue to be the officer or other employee of the specified company within such`
  line period.
  line
  line `(2) The Administrator, in consultation with the specified company, may requisition, the services of`
  line `such officers or other employees as it may deem fit, on such terms and conditions which may be mutually`
  line `agreed upon between the Administrator and the specified company.`
  line
  line `(3) Where an officer or other employee of the Trust opts under sub-section (1) not to be in`
  line `employment or service of the specified company, such officer or other employee shall be deemed to have`
  line resigned.
  line
  line `(4) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947) or in any`
  line `other law for the time being in force, the transfer of the services of any officer or other employee of the`
  line `Trust to the specified company shall not entitle such officer or other employee to any compensation under`
  line `this Act or under any other law for the time being in force and no such claim shall be entertained by any`
  line `court, tribunal or other authority.`
  line
  line `(5) The officers and other employees who have retired before the appointed day from the service of`
  line `the Trust and are entitled to any benefits, rights or privileges shall be entitled to receive the same benefits,`
  line `rights or privileges from the specified company.`
  line
  line `(6) The trust of the provident fund or the gratuity fund of the Unit Trust of India and any other bodies`
  line `created for the welfare of officers or other employees would continue to discharge their functions in the`
  line `specified company as was being done hitherto in the Unit Trust of India and any tax exemption granted to`
  line `the provident fund or the gratuity fund would continue to be applied to the specified company.`
  line
  line `(7) Notwithstanding anything contained in this Act or in the Companies Act, 1956 (1 of 1956) or in`
  line `any other law for the time being in force or in the regulations of the Unit Trust of India, the Chairman, the`
  line `trustees, executive trustee or any other person entitled to manage the whole or substantial part of the`
  line `business and affairs of the Trust shall not been titled to any compensation against the Trust for the loss of`
  line `office or for the premature termination of any contract of management entered into by him with the Trust.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (32715)
  sectionNo (7)
  orderNo 7
  title `Appointment of Administrator to manage specified undertaking.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32715&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_7_content:
  string
  line `(1) The Central`
  line `Government shall, on and from the appointed day, appoint a person or a body of persons, as the`
  line `Administrator of the specified undertaking of the Unit Trust of India for the purpose of taking over the administration thereof and the Administrator shall carry on the management of the specified undertaking`
  line `of the Trust for and on behalf of the Central Government.`
  line
  line `(2) The Central Government may issue such directions (including directions as to initiating,`
  line `defending or continuing any legal proceedings before any court, tribunal or other authority) to the`
  line `Administrator as to his powers and functions as that Government may deem desirable and the`
  line `Administrator may apply to the Central Government at any time for instructions as to the manner in which`
  line `he shall conduct the management of the specified undertaking or in relation to any matter arising in the`
  line `course of such management.`
  line
  line `(3) Subject to the other provisions of this Act and the Schemes made thereunder and the control of the`
  line `Central Government, the Administrator shall be entitled, notwithstanding anything contained in any other`
  line `law for the time being in force, to exercise, in relation to the management of the specified undertaking,`
  line `the powers specified under section 10 including powers to dispose of any property or assets of such`
  line `specified undertaking whether such powers are derived under any law for the time being in force.`
  line
  line `(4) Every person having possession, custody or control of any property forming part of the specified`
  line `undertaking of the Trust shall deliver forthwith such property to the Administrator.`
  line
  line `(5) Any person who, on the appointed day, has in his possession or under his control any books,`
  line `papers or other documents relating to the specified undertaking, including the minutes book containing`
  line `the resolutions of the persons in charge of the management of the specified undertaking before the`
  line `appointed day, the current cheque books relating to the specified undertaking, any letters, memoranda,`
  line `notes or other communications between him and the Trust so far they relate to the specified undertaking`
  line `shall, notwithstanding anything contained in any other law for the time being in force, be liable to account`
  line `for the books, papers and other documents (including such minutes book, letters, memoranda, notes or`
  line `other communications) to the Administrator.`
  line
  line `(6) Any person in charge of the management of the specified undertaking immediately before the`
  line `appointed day shall, within ten days from that day or within such further period as the Central Government`
  line `may allow in this behalf, furnish to the Administrator the complete inventory of all the properties and assets`
  line `(including particulars of book-debts and investments and belongings) forming part of the specified`
  line `undertaking immediately before the appointed day and of all the liabilities and obligations of such`
  line `specified undertaking, in relation to its administration, subsisting immediately before that day, and also of`
  line `all agreements relating to specified undertaking entered into by the Trust in relation to its administration`
  line `and in force immediately before that day.`
  line .
  line
  line `(7) The Administrator shall receive from the funds of the specified undertaking such remuneration as`
  line `the Central Government may fix.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (32716)
  sectionNo (8)
  orderNo 8
  title `Administrator to vacate office.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 8 of 2023, s. 173, for "investors, shall" (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32716&sectionno=8&orderno=8&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_8_content:
  string
  line `(1) The Administrator shall, immediately on redemption of all`
  line `the schemes of the specified undertaking and the payment of entire amount to ^1[investors or from such`
  line `date as may be notified by the Central Government in the Official Gazette, whichever is earlier,] vacate`
  line `his office; but nothing in this sub-section shall be construed as prohibiting his appointment as a member`
  line `of the Board of Advisers after vacation of his office as such.`
  line
  line `(2) On the vacation of his office, the Administrator shall forthwith deliver, to the Central Government`
  line `or any institution or officer specified by it, possession of all assets and properties representing and`
  line `relatable to the specified undertaking which are in his possession, custody and control on the date`
  line `immediately preceding the date on which he vacates his office as the Administrator.`
obj_root_law_sections_9:
  sectionId (32717)
  sectionNo (9)
  orderNo 9
  title `Board of Advisers.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32717&sectionno=9&orderno=9&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_9_content:
  string
  line `(1) On such date as the Central Government may, by notification in the`
  line `Official Gazette, appoint a Board of Advisers to advise and assist the Administrator in carrying on the`
  line `management of the specified undertaking.`
  line
  line `(2) The composition, term of office of the Advisers, the fees and allowances and other conditions of`
  line `appointment, disqualifications for being an Adviser, filling up of casual vacancy in the office of the`
  line `Adviser, the meetings of the Board of Advisers, vacation and resignation of office of the Advisers, shall`
  line `be such as may be specified in the Scheme made by the Central Government.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (32718)
  sectionNo (10)
  orderNo 10
  title `Powers and functions of Administrator.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32718&sectionno=10&orderno=10&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_10_content:
  string
  line `(1) Subject to the provisions of this Act and the`
  line `Scheme made thereunder, the Administrator may, on the advice of the Board of Advisers, transact any of`
  line `the following kinds of business in India in relation to the specified undertaking only, namely:--`
  line
  line `(a) selling and purchasing units of the schemes specified in Schedule I;`
  line
  line `(b) investing in and acquiring, holding or disposing of securities and exercising and enforcing, all`
  line `powers and rights incidental thereto including protection or realisation of such investment and the`
  line `taking over of the administration of any property offered as security for such investment;`
  line
  line `(c) granting of loans and advances upon the security of any movable or immovable property or`
  line otherwise;
  line
  line `(d) accepting, collecting, discounting, re-discounting, purchasing, selling or negotiating or`
  line `otherwise dealing with, any bills of exchange, hundies, promissory notes, coupons, drafts, bill of`
  line `lading, railway receipts, warehouse receipts, documents of title to goods, warrants, certificates, scrips`
  line `and other mercantile instruments;`
  line
  line `(e) purchasing, selling or issuing participation certificates in relation to any loan or advance`
  line `granted by any public financial institution or scheduled bank or such other institution as may be`
  line `specified by the Central Government;`
  line
  line `(f) keeping money on deposit with companies or other bodies corporate, scheduled banks or such`
  line `other institutions as may be specified by the Central Government;`
  line
  line `(g) formulating in relation to any unit scheme specified in Schedule I,--`
  line
  line `(i) savings and life insurance plan or plans under which a person may acquire an interest in`
  line `units in association with or as the agent of, the Life Insurance Corporation of India or the Central`
  line `Government, but not including the life insurance business;`
  line
  line `(ii) savings and insurance plan or plans under which a person may acquire an interest in units`
  line `in association with, or as the agent of, the General Insurance Corporation but not including the`
  line `general insurance business; or`
  line
  line `(iii) any other plan or plans, under which a person may acquire an interest in units;`
  line
  line `(h) acquiring immovable property or any interest therein, the development (including`
  line `construction) and sale of such property and the rendering of financial and other assistance to any`
  line `person for the acquisition of any immovable property or any interest therein and for the development`
  line `(including construction) of such property;`
  line
  line `(i) providing leasing and hire purchase finance to persons, companies, and other bodies corporate;`
  line
  line `(j) providing merchant banking and investment advisory services;`
  line
  line `(k) extending investment or fund or port folio management services to persons resident outside`
  line India;
  line
  line `(l) opening of an account or the making of an agency arrangement with a bank incorporated`
  line `outside India;`
  line
  line `(m) buying or selling of or entering into such other dealings in, foreign exchange, as maybe`
  line `necessary for the discharge of its functions;`
  line
  line `(n) doing any other kind of business connected with mobilisation of savings or investments which`
  line `the Central Government may authorise;`
  line
  line `(o) generally doing all such acts and things as may be incidental to or consequential upon the`
  line `discharge of its functions under this Act.`
  line
  line `(2) The Administrator shall, on and after the appointed day, neither formulate any new scheme nor`
  line `issue any new unit, whether related to the undertaking or the specified undertaking or otherwise.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (32719)
  sectionNo (11)
  orderNo 11
  title `Maintenance of accounts by Administrator.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32719&sectionno=11&orderno=11&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_11_content:
  string
  line `(1) The Administrator shall maintain separate`
  line `accounts of each of the specified undertaking asset possession whereof has been taken by him, and shall`
  line `cause to be made therein entries of all receipts and expenditure in respect thereof.`
  line
  line `(2) The separate accounts under sub-section (1) shall be maintained in such form and in such manner`
  line `as may be specified by the Central Government.`
  line
  line `(3) The Central Government shall cause the accounts maintained under this section to be inspected`
  line `and audited at such intervals and by such persons as may be specified by it.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (32720)
  sectionNo (12)
  orderNo 12
  title `Concession, etc., to be deemed to have been granted to specified undertaking.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32720&sectionno=12&orderno=12&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_12_content:
  string
  line `With effect`
  line `from the appointed day, all fiscal and other concessions, licences, benefits, privileges and exemptions`
  line `granted to the Trust in connection with the affairs and business of the specified undertaking of the Trust`
  line `under any law for the time being in force shall be deemed to have been granted in relation to the specified`
  line undertaking.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (32721)
  sectionNo (13)
  orderNo 13
  title `Tax exemption or benefit to continue to have effect.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32721&sectionno=13&orderno=13&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_13_content:
  string
  line `(1) Notwithstanding anything contained`
  line `in the Income-tax Act, 1961 (43 of 1961) or any other enactment for the time being in force relating to tax`
  line `on income, profits or gains, no income-tax or any other tax shall be payable by the Administrator in`
  line `relation to the specified undertaking ^1[for the period beginning on the appointed day and ending on the`
  line `^2[31st day of March, ^3[2027]] in respect of any income, profits or gains derived, or any amount received in`
  line `relation to the specified undertaking.`
  line
  line `(2) The transfer and vesting of the undertaking or the specified undertaking in terms of section 4 shall`
  line `not be construed as a transfer within the meaning of the Income-tax Act, 1961 (43 of 1961) for the`
  line `purposes of capital gains.`
obj_root_law_sections_13_footnotes:
  string
  line `1. Subs. by Act 18 of 2008, s. 123, for "for a period of five years computed from the appointed day" (w.e.f. 1-2-2008).`
  line
  line `2. Subs. by Act 8 of 2023, s. 173, for "31st day of March, 2023" (w.e.f. 1-4-2023).`
  line
  line `3. Subs. By Act 7 of 2025, s. 136, for “2025” (w.e.f 1-4-2025)`
obj_root_law_sections_14:
  sectionId (32722)
  sectionNo (14)
  orderNo 14
  title `Exemption from stamp duty.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32722&sectionno=14&orderno=14&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_14_content:
  string
  line `Notwithstanding anything contained in the Indian Stamp Act,`
  line `1899 (2 of 1899), the transfer and vesting of the undertaking and the specified undertaking in terms of`
  line `section 4 shall not be liable to the payment of any stamp duty under that Act.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (32723)
  sectionNo (15)
  orderNo 15
  title `Guarantee to be operative.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32723&sectionno=15&orderno=15&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_15_content:
  string
  line `Any guarantee given for or in favour of the Trust with respect to`
  line `any loan, lease, finance or other assistance shall continue to be operative in relation to the specified`
  line `undertaking managed by the Administrator.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (32724)
  sectionNo (16)
  orderNo 16
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32724&sectionno=16&orderno=16&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_16_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `the Central Government or the Administrator, Board of Advisers or any of the officers or other employees`
  line `of the Central Government for any damage caused or likely to be caused by anything which is in good`
  line `faith done or intended to be done under this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (32725)
  sectionNo (17)
  orderNo 17
  title `Shares, bonds, debentures and units to be deemed to be approved securities.`
  content obj_root_law_sections_17_content
  footnotes `1. The words and figures "and the Banking Regulation Act, 1949 (10 of 1949)" omitted by Act 4 of 2013, the Schedule and s. 17`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32725&sectionno=17&orderno=17&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_17_content:
  string
  line `Notwithstanding anything contained in any other law for the time being in force, the shares,`
  line `bonds, debentures and units of the specified undertaking shall be deemed to be approved securities for the`
  line `purposes of the Indian Trusts Act, 1882 (2 of 1882), the Insurance Act, 1938 (4 of 1938) ^1***.`
obj_root_law_sections_18:
  sectionId (32726)
  sectionNo (18)
  orderNo 18
  title `Substitution in every Act, rule, regulation or notification by specified company or Administrator in place of Trust.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32726&sectionno=18&orderno=18&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_18_content:
  string
  line `In every Act, rule, regulation or notification in force on the appointed`
  line `day, for the words "Unit Trust of India", wherever they occur, the words, brackets and figures "specified`
  line `company referred to in the Unit Trust of India (Transfer of Undertaking and Repeal) Act, 2002 or`
  line `"Administrator of the specified undertaking of the Unit Trust of India referred to in the Unit Trust of India`
  line `(Transfer of Undertaking and Repeal) Act, 2002", as the case may be, shall be substituted.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (32727)
  sectionNo (19)
  orderNo 19
  title `Power of Central Government to alter Schedules I and II.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32727&sectionno=19&orderno=19&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_19_content:
  string
  line `(1) The Central Government may,`
  line `by notification in the Official Gazette, alter Schedules I and II.`
  line
  line `(2) Every alteration made by the Central Government under sub-section (1) shall be laid, as soon as`
  line `may be after it is made, before each House of Parliament, while it is in session, for a total period of thirty`
  line `days which may be comprised in one session or in two or more successive sessions, and if, before the`
  line `expiry of the session immediately following the session or the successive sessions aforesaid, both Houses agree in making any modification in the alteration, or both Houses agree that the alteration should not be`
  line `made, the alteration shall thereafter have effect only in such modified form or be of no effect, as the case`
  line `may be; so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that alteration.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (32728)
  sectionNo (20)
  orderNo 20
  title `Power of Central Government to make Scheme.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32728&sectionno=20&orderno=20&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_20_content:
  string
  line `(1) The Central Government may, by`
  line `notification in the Official Gazette, make a Scheme for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, the said Scheme may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner in which the specified undertaking and schemes and assets and investments`
  line `specified in Schedule I shall be managed;`
  line
  line `(b) the term of office of the Advisers, the fee and allowances and other conditions of appointment`
  line `of the Advisers, disqualifications for being an Adviser, filling up of casual vacancy in the office of`
  line `Adviser, the meetings of Board of Advisers, vacation and resignation of office of the Advisers;`
  line
  line `(c) the manner of payment of consideration for which the undertaking shall be transferred to the`
  line `specified company;`
  line
  line `(d) the assets representing and relatable to the undertaking and the specified undertaking; and`
  line
  line `(e) such incidental, consequential and supplemental matters as may be necessary to carry out the`
  line `provisions of this Act.`
  line
  line `(3) Every Scheme made under sub-section (1) shall be laid, as soon as may be after it is made before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions and if before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the Scheme or both Houses agree that the Scheme should not be made, the Scheme shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Scheme.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (32729)
  sectionNo (21)
  orderNo 21
  title `Repeal and saving of Act 52 of 1963.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32729&sectionno=21&orderno=21&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_21_content:
  string
  line `(1) On the appointed day, the Unit Trust of India`
  line `Act, 1963 shall stand repealed and the Board of trustees referred to in section 10 of the said Act (herein`
  line `after referred to as the repealed Act) shall stand dissolved.`
  line
  line `(2) On the dissolution of the said Board, the person appointed as the Chairman of the Board and every`
  line `other person appointed as the trustee and executive trustee and holding office as such immediately before`
  line `such date shall vacate their respective office.`
  line
  line `(3) Notwithstanding such repeal, anything done or any action taken or purported to have been done or`
  line `taken including any rule, regulation, notification, scheme, inspection, order or notice made or issued or`
  line `any appointment, confirmation or declaration made or any permission, authorisation or exemption granted`
  line `or any document or instrument executed or any direction given under the Act hereby repealed shall, in so`
  line `far as it is not inconsistent with the provisions of this Act, be deemed to have been done or taken under`
  line `the corresponding provisions of this Act.`
  line
  line `(4) Notwithstanding the repeal of the Unit Trust of India Act, 1963 (52 of 1963), the Administrator`
  line `shall, so far as may be, comply with the provisions of Chapter VI of the Act so repealed for any of the`
  line `purposes related to the annual accounts and audit of the Trust.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (32730)
  sectionNo (22)
  orderNo 22
  title `Act to have overriding effect.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32730&sectionno=22&orderno=22&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_22_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything in consistent therewith contained in any enactment other than this Act or in any instrument`
  line `having effect by virtue of any enactment other than this Act.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (32731)
  sectionNo (23)
  orderNo 23
  title `Application of other laws not barred.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32731&sectionno=23&orderno=23&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_23_content:
  string
  line `The provisions of this Act shall be in addition to, and`
  line `not in derogation of the provisions of any other law for the time being in force.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (32732)
  sectionNo (24)
  orderNo 24
  title `Power to remove difficulties.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32732&sectionno=24&orderno=24&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_24_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions, not in consistent with the provisions of this Act as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (32733)
  sectionNo (25)
  orderNo 25
  title `Repeal and saving.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00012_200258_1517807319709&sectionId=32733&sectionno=25&orderno=25&orgactid=AC_CEN_2_11_00012_200258_1517807319709
obj_root_law_sections_25_content:
  string
  line `(1) The Unit Trust of India (Transfer of Undertaking and Repeal)`
  line `Ordinance, 2002 (5of 2002) is hereby repealed.`
  line
  line `(2) Notwithstanding the repeal of the Unit Trust of India (Transfer of Undertaking and Repeal)`
  line `Ordinance, 2002 (5 of 2002), anything done or any action taken under the said Ordinance, shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_25_footnotes:
  string
  line
