  slug the-unit-trust-of-india-transfer-of-undertaking-and-repeal-act-2002
  handle (1889)
  collectionHandle 123456789/1362
  title `The Unit Trust of India (Transfer of Undertaking and Repeal) Act, 2002`
  actNumber (58)
  enactmentDate 2002-12-17
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1889`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भारतीय यूनिट ट्रस्ट (उपक्रम का अंतरणऔर निरसन) अधिनियम, 2002`
  actYear (2002)
  ministry `Ministry of Finance`
  department `Department of Investment and Public Asset Management`
  longTitle `An Act to provide for the transfer and vesting of the undertaking (excluding the specified undertaking) of the Unit Trust of India to the specified company to be formed and registered under the Companies Act, 1956, and the transfer and vesting of the specified undertaking of the Unit Trust of India in the Administrator and for matters connected therewith or incidental thereto and also to repeal the Unit Trust of India Act, 1963.`
  enforcementDate 29-10-2002
  notification undefined
  fetchedAt `2026-05-10T12:38:04.719Z`
