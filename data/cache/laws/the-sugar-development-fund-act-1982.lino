obj_root_law_sections_1:
  object
  (str sectionId) (str 20982)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title, extent and commencement.`)
  (str content) (str `(1) This Act may be called the Sugar Development
Fund Act, 1982.

(2) It extends to the whole of India.

(3) It shall come into force on such date^1
as the Central Government may, by notification in the
Official Gazette, appoint.`)
  (str footnotes) (str `11st June, 1982, vide notification No. G.S.R. 436(E), dated 29th May, 1982, see Gazette of India, Extraordinary, Part II,
sec. 3(i).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20982&sectionno=1&orderno=1&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_2:
  object
  (str sectionId) (str 20983)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act, unless the context otherwise requires,--

(a) "Committee" means the Committee constituted under section 6;

(b) "Fund" means the Sugar Development Fund formed under section 3;

(c) "prescribed" means prescribed by rules made under this Act;

(d) all other words and expressions used in this Act and not defined, but defined in the Sugar Cess
Act, 1982 (3 of 1982), shall have the meanings respectively assigned to them in that Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20983&sectionno=2&orderno=2&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_3:
  object
  (str sectionId) (str 20984)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Sugar Development Fund.`)
  (str content) (str `(1) There shall be formed a fund to be called the Sugar Development
Fund.

(2) An amount equivalent to the proceeds of the duty of excise levied and collected under the Sugar
Cess Act, 1982(3 of 1982), reduced by the cost of collection as determined by the Central Government,
together with any moneys received by the Central Government for the purposes of this Act, shall, after
due appropriation made by Parliament by law, be credited to the Fund.

(3) The Fund shall consist of the amounts credited under sub-section (2) and any income from
investment of such amounts.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20984&sectionno=3&orderno=3&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_4:
  object
  (str sectionId) (str 20985)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Application of Fund.`)
  (str content) (str `(1) The Fund shall be applied by the Central Government,

(a) for making loans for facilitating the rehabilitation and modernisation of any sugar factory or
any unit thereof or the undertaking of any scheme for development of sugarcane in the area in which
any sugar factory is situated;

^1[(aa) for making loans to any sugar factory or any unit thereof for bagasse-based co-generation
power projects with a view to improving their viability;

(aaa) for making loans to any sugar factory or any unit thereof for production of anhydrous
alcohol or ethanol from alcohol with a view to improving their viability;]

(b) for making grants for the purpose of any research project aimed at development of sugar
industry;

^2[(bb) for defraying expenditure for the purpose of building up and maintenance of buffer stocks
of sugar with a view to establishing price of sugar;]

^1[(bbb) for defraying expenditure on internal transport and freight charge to the sugar factories on
export shipments of sugar with a view to promoting its export;]

^3[(bbbb) for defraying expenditure for the purpose of financial assistance to sugar factories
towards interest on loans given in terms of any scheme approved by the Central Government from
time to time;]

(c) for defraying any other expenditure for the purposes of this Act.

(2) The manner in which any loans or grants may be made under this section and the terms and
conditions subject to which such loans or grants may be made shall be such as may be prescribed.`)
  (str footnotes) (str `1 Ins.by Act 30 of 2002, s. 2 (w.e.f. 21-6-2002).

2 Ins. by Act 64 of 1982, s. 2 (w.e.f.12-11-1982).

3 Ins. by Act 4 of 2008, s. 2 (w.e.f. 5-2-2008).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20985&sectionno=4&orderno=4&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_5:
  object
  (str sectionId) (str 20986)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Applications for loans or grants.`)
  (str content) (str `Every application for loan or grant under section 4 shall be
made to the Committee in such manner and in such form as may be prescribed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20986&sectionno=5&orderno=5&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_6:
  object
  (str sectionId) (str 20987)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str Committee.)
  (str content) (str `(1) For the purpose of securing speedy consideration and disposal of applications
received under section 5 and for considering any problems arising in the course of the administration of
this Act, the Central Government may constitute a committee of officers of that Government.

(2) The composition of the Committee and the procedure to be followed by the Committee in the
discharge of its functions under this Act shall be such as may be prescribed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20987&sectionno=6&orderno=6&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_7:
  object
  (str sectionId) (str 20988)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Annual report of activities financed under the Act.`)
  (str content) (str `The Central Government shall, as soon as
may be, after the end of each financial year, cause to be published in the Official Gazette, a report giving
an account of the activities financed under this Act during the financial year, together with a statement of
accounts.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20988&sectionno=7&orderno=7&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_8:
  object
  (str sectionId) (str 20989)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str `Power to call for reports and returns.`)
  (str content) (str `The Central Government may require an occupier of a
sugar factory to furnish, for the purposes of this Act, such statistical and other information, in such form
and within such period as may be prescribed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20989&sectionno=8&orderno=8&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_sections_9:
  object
  (str sectionId) (str 20990)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str `Power to make rules.`)
  (str content) (str `(1) The Central Government may, by notification in the Official Gazette,
make rules for carrying out the provisions of this Act.

(2) In particular and without prejudice to the generality of the foregoing power, such rules may
provide for,

(a) the manner in which any loans or grants may be made and the terms and conditions subject to
which such loans or grants may be made under section 4;

(b) the manner and form in which applications may be made under section 5;

(c) the composition of the Committee under section 6 and the procedure to be followed by the
Committee in the discharge of its functions under this Act;

(d) the form in which and the period within which statistical and other information may be
furnished under section 8;

(e) any other matter which is required to be or may be prescribed.

(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each
House of Parliament, while it is in session, for a total period of thirty days which may be comprised in
one session or in two or more successive sessions, and if, before the expiry of the session immediately
following the session or the successive sessions aforesaid, both Houses agree in making any modification
in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only
in such modified form or be of no effect, as the case may be; so, however, that any such modification or
annulment shall be without prejudice to the validity of anything previously done under that rule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_78_00002_198204_1517807325916&sectionId=20990&sectionno=9&orderno=9&orgactid=AC_CEN_21_78_00002_198204_1517807325916)
obj_root_law_translations:
  object
  (str hi) obj_root_law_translations_hi
obj_root_law_translations_hi:
  object
  (str title) (str `चीनी विकास निधि अधिनियम, 1982`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1780/3/H1982-4.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:21:13.818Z`)
  (str pageCount) (int 2)
  (str sections) obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
  array
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
obj_root_law_translations_hi_sections_1:
  object
  (str kind) (str page)
  (str sectionId) (str pdf-page-1)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Page 1`)
  (str content) (str `चीनी विकास वनवि अविवनयम, 1982
( 1982 का अविवनयम संखयां क 4 )
[19 माचच, 1982]
चीनी उद्योग के विकास के क्र ियाकलापों के वित्तपोषण
के वलए और उससे सम्ब वधित या उससे आनुषंवगक
विषयों के वलए उपबध ि
करने के वलए
अविवनयम
भारत गणराज्य के तैंतीसिें िषच में संसद् द्व ा रा वनम्न वलवित रू प में यह अविवनयवमत हो: —
1. संविप्त नाम, विस्ता र और प्र ारम्भ — ( 1 ) इस अविवनयम का संविप्त नाम चीनी विकास वनवि अविवनयम, 1982 है।
( 2 ) इसका विस्ता र संपूणच भारत पर है।
( 3 ) यह उस तारीि को प्र िृत्त होगा जो केधरी य सरकार, राजपत्र में अविसूचना द्व ारा, वनयत करे।
2. पररभाषाएं — इस अविवनयम में, जब तक क्र क संदभच से अधयथा अपेवित न हो, —
(क) “ सवमवत ” से िारा 6 के अिीन गरित सवमवत अवभप्रेत है;
(ि) “ वनवि ” से िारा 3 के अिीन स् थावपत चीनी विकास वनवि अवभप्रेत है;
( ग ) “ विवहत ” से इस अविवनयम के अिीन बनाए गए वनयमों द्व ारा विवहत अवभप्रेत है;
( घ ) उन सभी अधय शब्दों और पदों के जो इस अविवनयम में प्र युक्त हैं और पररभावषत नहीं हैं, क्र कधतु चीनी उपकर
अविवनयम, 1982 ( 1982 का 3 ) में पररभावषत हैं, िही अथच होंगे जो उनके उस अविवनयम में हैं।
3. चीनी वि कास वनवि — ( 1 ) चीनी विकास वनवि के नाम से एक वनवि स् था वपत की जाएगी।
( 2 ) चीनी उपकर अविवनयम, 1982 ( 1982 का 3 ) के अिीन उद्गृहीत और संगृहीत उत्पा द - शुल्क के आगमों के बराबर रकम,
वजसमें से संग्रहण की लागत, जैसी क्र क केधरी य सरकार द्व ारा अििाररत की जाए, घटाकर, इ स अविवनयम के प्र यो जनों के वलए केधरीय
सरकार द्व ारा प्र ाप्त क्र कसी िन के साथ, संसद् द्व ारा विवि द्व ारा सम्यक् विवनयोग क्र कए जाने के पश्चा त्, वनवि में जमा की जाएगी।
( 3 ) वनवि में उपिारा ( 2 ) के अिीन जमा रकमों और ऐसी रकमों के विवनिान से कोई आय होगी।
4. वनवि का उपयोजन — ( 1 ) वनवि का उपयोजन, केधरी य सरकार द्व ारा वनम्न वलवित के वलए क्र कया जाएगा, —
( क ) क्र कसी चीनी का रिाने या उसकी क्र कसी यूवनट के पुन रुद्ध ार और आिुवनकीकरण की सुवििा के वलए उिार देना
या ऐसे क्र कसी िेत्र में वजसमें कोई चीनी कारिाना वस्थ त है, गधना के विका स के वलए क्र कसी स् कीम को हाथ में लेना;
1 [ (क क ) क्र कसी चीनी कारिाने या उसकी क्र कसी यूवनट को, उसकी जीिन िमता में सुिार करने की दृवट से िोई
आिाररत सह - उत्पा दन विद्युत पररयोजनाओं के वलए उिार देना;
(ककक) क्र कसी चीनी कारिाने या उसकी क्र कसी यूवनट को, उसकी जीिन िमता में सुिार करने की दृवट से, वनजचल
एल्को हल या एल्को हल से एथा नील के उत्पा दन के वलए उिार देना; ]
( ि ) चीनी उद्योग के विकास के उद्देश्य से क्र कसी अनुसंिान पररयोजना के प्र योजन के वलए अनुदान देना;
2 [ ( िि ) चीनी की कीमत में वस्थ रता लाने की दृवट से चीनी के सुरवित भण्डा रों का वनमाचण करने और उधहें बनाए
रिने के प्र योजन के वलए होने िाले व् य य को चुकाना; ]
1 [ ( ििि ) आंतररक पररिहन और भाडा प्र भारों पर चीनी कारिानों को, उनके वनयाचत का संििचन करने की
दृवट से, चीनी के वनयाचत लदानों पर हु ए व् य य को चुका ने के वलए; ]
3 [ ( िििि ) केधरी य सरकार द्व ारा समय - समय पर अनुमोक्रदत क्र कसी स् की म के वनबंिनों के अनुसार चीनी कारिानों
को क्र दए गए उिारों पर ब् याज मद्दे वित्तीय सहायता के प्र योजन के वलए होने िाले व् य य को चुकाना; ]
1 2002 के अविवनयम सं ० 30 की िारा 2 द्व ारा अंत:स्था वपत।
2 1982 के अविवनयम सं ० 64 की िारा 2 द्व ारा अंत:स्था वपत।
3 2008 के अविवनयम सं ० 4 की िारा 2 द्व ारा अंत:स्था वपत।`)
  (str footnotes) (str )
  (str sourcePage) (int 1)
obj_root_law_translations_hi_sections_2:
  object
  (str kind) (str page)
  (str sectionId) (str pdf-page-2)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Page 2`)
  (str content) (str `2
( ग ) इस अविवनयम के प्र योजनों के वलए क्र कसी अधय व् य य को चुकाना।
( 2 ) िह रीवत वजससे इस िारा के अिीन कोई उिार या अनुदान क्र दए जा सकेंगे और िे वनबधि न और शतें, वजनके अिीन ऐसे
उिार और अनुदान क्र दए जा सकेंगे, ऐसी होंगी जो विवहत की जाएं।
5. उिारों या अनुदानों के वलए आिेदन — िारा 4 के अिीन उिार या अनुदान के वलए प्रत् ये क आिेदन सवमवत को ऐसी रीवत
से और ऐसे प्ररू प में क्र कया जाएगा जो विवहत क्र कया जाए।
6. सवमवत — ( 1 ) िारा 5 के अिीन प्र ाप्त आिेदनों के शीघ्र विचारण और वनपटारे को सुवनवश्च त करने के प्र योजन के वल ए और
इस अविवनयम के प्र शासन के अनुिम में उत्प धन होने िाली क्र कसी समस्या पर विचार करने के वलए केधरी य सरकार उस सरकार के
अविकाररयों की एक सवमवत गरित कर सकेगी।
( 2 ) सवमवत की संरचना और सवमवत द्व ारा इस अविवनयम के अिीन अपने कृत्यों के वनिचहन में अनुसरण की जाने िाली प्रक्र
िया ऐसी होगी जो विवहत की जाए।
7. अविवनयम के अिीन वित्तपोवषत क्र ियाकलापों की िार्षचक ररपोटच — केधरी य सरकार, हर एक वित्तीय िषच के अंत के पश्चा त्
यथाशक्य शीघ्र वित्तीय िषच के दौरान इस अविवनयम के अिीन वित्तपोवषत क्र ियाकलापों का वििरण देने िाली एक ररपोटच, एक लेिा -
वििरण सवहत, राजपत्र में प्र कावशत कराएगी।
8. ररपोटें और वििरवणयां मांगने की शवक्त — केधरी य सरकार क्र कसी चीनी कारिाने के क्र कसी अविभोगी से यह अपेिा कर
सकेगी क्र क िह इस अविवनयम के प्र योजनों के वलए, आंकडों की ऐसी जानकारी और अधय जानकारी, ऐसे प्ररू प में और ऐसी अिवि के
भीतर दे जो विवहत की जाए।
9. वनयम बनाने की शवक्त — ( 1 ) केधरीय सरकार राजपत्र में अविसूचना द्व ारा इस अविवनयम के उपबंिों को कायाचवधि त करने
के वलए वनयम बना सकेगी।
( 2 ) विवशट तया और पूिचगामी शवक् त की व् या पकता पर प्र वतकूल प्र भाि डाले वबना, ऐसे वनयम वनम्न वलवित का उपबंि
कर सकेंगे, —
( क ) िह रीवत वजससे कोई उिार या अनुदान और िे वनबधि न और शतें वजनके अिीन ऐसे उिार या अनुदान
िारा 4 के अिीन क्र दए जा सकेंगे;
( ि ) िह रीवत वजससे और िह प्ररू प वजसमें िारा 5 के अिीन आिेदन क्र कए जा सकेंगे;
( ग ) िा रा 6 के अिीन सवमवत की संरचना और इस अविवनयम के अिीन अपने कृत्यों का वनिचहन करने में सवमवत द्व
ारा अनुसरण की जाने िाली प्रक्र िया;
( घ ) िह प्ररू प वजसमें और िह अिवि वजसके भीतर आंकडों की जानकारी और अधय जानकारी िारा 8 के अिीन दी
जा सकेगी;
( ङ ) कोई अधय विषय वज सके विवहत क्र कए जाने की अपेिा है या जो विवहत क्र कया जाए।
( 3 ) इस िारा के अिीन बनाया गया प्रत् येक वनयम बनाए जाने के पश्चा त् यथाशीघ्र, संसद् के प्रत् ये क सदन के समि जब िह
सत्र में हो, कुल तीस क्र दन की अिवि के वलए रिा जाएगा। यह अिवि उस सत्र में अथिा दो या अवि क आनुिवमक सत्रों में पूरी हो
सकेगी। यक्रद उस सत्र के या पूिोक्त आनुिवमक सत्रों के िीक बाद के सत्र के अिसान के पूिच दोनों सदन उस वनयम में कोई पररितचन
करने के वलए सहमत हो जाएं, तो तत्प श् चा त् िह ऐसे पररिर्तचत रू प में ही प्र भािी होगा। यक्रद उक्त अिसा न के पूिच दोनों सदन सहमत
हो जाएं क्र क िह वनयम नहीं बनाया जाना चावहए तो तत्पश्चा त् िह वन प्र भाि हो जाएगा। क्र कधतु वनयम के ऐसे पररिर्तचत या
वन प्र भाि होने से उसके अिीन पहले की गई क्र कसी बात की विविमाधय ता पर प्र वतकूल प्र भाि नहीं पडेगा।
