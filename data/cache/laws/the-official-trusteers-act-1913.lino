obj_root_law_sections_1:
  sectionId (33901)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33901&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Official Trustees`
  line `Act, 1913.`
  line
  line `^1[(2) It extends to the whole of India ^2* * *.`
  line
  line `(3) It shall come into force on such date^3 as the Central Government, by notification in the Official`
  line `Gazette, may direct.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for sub-section (2).`
  line
  line `2. The words "except the State of Jammu and Kashmir" omitted by Act 25 of 1968, s. 2 and Schedule (w.e.f. 15-8-1968).`
  line
  line `3. The 1st April, 1914, see Gazette of India, 1914, Pt. I, p. 365.`
obj_root_law_sections_2:
  sectionId (33902)
  sectionNo (2)
  orderNo 2
  title `Interpretation clause.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33902&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_2_content:
  string
  line `^1[2. Interpretation clause.-- In this Act, unless there is anything repugnant in the subject or`
  line context,--
  line
  line `(1) "Government" or "the Government" means, in relation to a State, the State`
  line `Government and, in relation to a Union territory, the Central Government.`
  line
  line `^2** * * *`
  line
  line `(3) "prescribed" means prescribed by rules under this Act.]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by the A.O. (No. 2) 1956, for section 2.`
  line
  line `2. Clause (2) omitted by Act 48 of 1964, s. 3.`
obj_root_law_sections_3:
  sectionId (33903)
  sectionNo (3)
  orderNo 3
  title `Extent of jurisdiction of High Court.`
  content obj_root_law_sections_3_content
  footnotes `1. Ins. by s. 4, ibid., s. 3, Earlier section 3 was omitted by the A.O. (No. 2) 1956.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33903&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_3_content:
  string
  line `^1[3. Extent of jurisdiction of High Court.-- The High Court shall, in respect of proceedings`
  line `instituted by or against the Official Trustee under this Act or the Indian Trusts Act, 1882`
  line `(2 of 1882), be a competent Court throughout the territories in relation to which it exercises civil`
  line `appellate jurisdiction:`
  line
  line `Provided that nothing in this section shall be construed as affecting the jurisdiction of any`
  line `district court.`
obj_root_law_sections_4:
  sectionId (33904)
  sectionNo (4)
  orderNo 4
  title `Official Trustees.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33904&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_4_content:
  string
  line `^1[(1) ^2[The Government shall appoint an Official Trustee for each`
  line `State]:`
  line
  line `Provided that nothing herein contained shall be deemed to bar the appointment of the`
  line `same person as Official Trustee for two or more ^3[States].]`
  line
  line `^4[(2) No person shall be appointed to the office of Official Trustee unless he has been for at least--`
  line
  line `(a) seven years, an advocate; or`
  line
  line `(b) seven years, an attorney of a High Court; or`
  line
  line `(c) ten years, a member of the judicial service of a State; or`
  line
  line `(d) five years, a Deputy Official Trustee.]`
  line
  line `^5** * * *`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by the A. O. 1937, for sub-section (1).`
  line
  line `2. Subs. by the A.O. (No. 2) 1956, for the first paragraph.`
  line
  line `3. Subs. by the A.O. 1950, for "Divisions".`
  line
  line `4. Subs. by Act 48 of 1964, s. 5, for sub-section (2).`
  line
  line `5. Sub-section (3) omitted by the A.O. 1937.`
obj_root_law_sections_5:
  sectionId (33905)
  sectionNo (5)
  orderNo 5
  title `Appointment and powers of Deputy Official Trustee.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33905&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_5_content:
  string
  line `^1[(1)] The Government may appoint a`
  line `Deputy or Deputies to assist the Official Trustee; and any Deputy so appointed shall, subject to the control of`
  line `the Government and the general or special orders of the Official Trustee, be competent to discharge any of`
  line `the duties and exercise any of the powers of the Official Trustee, and, when discharging such duties or`
  line `exercising such powers shall have the same privileges and be subject to the same- liabilities as the Official`
  line Trustee.
  line
  line `^2[(2) No person shall be appointed as a Deputy unless he has been for at least three years--`
  line
  line `(a) an advocate; or`
  line
  line `(b) an attorney of a High Court; or`
  line
  line `(c) a member of the judicial service of a State.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Section 5 was renumbered as sub-section (1) thereof by Act 48 of 1964, s. 6.`
  line
  line `2. Ins, by s. 6, ibid.`
obj_root_law_sections_6:
  sectionId (33906)
  sectionNo (6)
  orderNo 6
  title `Official Trustee to be corporation sole, to have perpetual succession and official seal, and to sue and be sued in his corporate name.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by the A.O. 1950, for "Division" which had been subs. by the A.O. 1937, for "Presidency".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33906&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_6_content:
  string
  line `The Official Trustee shall be a corporation sole by the name of the`
  line `Official Trustee of the ^1[State] for which he is appointed and, as such Official Trustee, shall have perpetual`
  line `succession and an official seal, and may sue and be sued in his corporate name.`
obj_root_law_sections_7:
  sectionId (33907)
  sectionNo (7)
  orderNo 7
  title `General powers and duties of Official Trustee.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33907&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_7_content:
  string
  line `(1) Subject to, and in accordance with, the`
  line `provisions of this Act and the rules made thereunder, the Official Trustee may, if he thinks fit,--`
  line
  line `(a) act as an ordinary trustee;`
  line
  line `(b) be appointed trustee by a Court of competent jurisdiction.`
  line
  line `(2) Save as hereinafter expressly provided, the Official Trustee shall have the same powers, duties and`
  line `liabilities and be entitled to the same rights and privileges and be subject to the same control and orders of the`
  line `Court as any other trustee acting in the same capacity.`
  line
  line `(3) The Official Trustee may decline, either absolutely or except on such conditions as he may impose, to`
  line `accept any trust.`
  line
  line `(4) The Official Trustee shall not accept, any trust under any composition or scheme of arrangement for`
  line `the benefit of creditors, nor of any estate known or believed by him to be insolvent.`
  line
  line `(5) The Official Trustee shall not, save as provided by any rules made under this Act, accept any trust for`
  line `a religious purpose or any trust which involves the management or carrying on of any business.`
  line
  line `(6) The Official Trustee shall not administer the estate of a deceased person, unless he is expressly`
  line `appointed sole executor of, and sole trustee under, the will of such person.`
  line
  line `(7) The Official Trustee shall always be sole trustee, and it shall not be lawful to appoint the Official`
  line `Trustee to be trustee along with any other person.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (33908)
  sectionNo (8)
  orderNo 8
  title `Official Trustee may with consent be appointed trustee of settlement by grantor.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33908&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_8_content:
  string
  line `(1) Any person`
  line `intending to create a trust other than a trust which the Official Trustee is prohibited from accepting under the`
  line `provisions of this Act may by the instrument creating the trust and with the consent of the Official Trustee,`
  line `appoint him by that name or any other sufficient description to be the trustee of the property subject to such`
  line `trust:`
  line
  line `Provided that the consent of the Official Trustee shall be recited in the said instrument and that such`
  line `instrument shall be duly executed by the Official Trustee.`
  line
  line `(2) Upon such appointment the property subject to the trust shall vest in such Official Trustee, and shall`
  line `be held by him upon the trusts declared in such instrument.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (33909)
  sectionNo (9)
  orderNo 9
  title `Appointment of Official Trustee as trustee by will.`
  content obj_root_law_sections_9_content
  footnotes `1. Subs. by Act 18 of 1919, s. 2 and first Schedule, for "such testator".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33909&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_9_content:
  string
  line `When the Official Trustee has by that name or`
  line `any other sufficient description been appointed trustee under any will, the executor of the will of ^1[the testator] or the administrator of his estate shall, after obtaining probate or letters of administration, notify in`
  line `the prescribed manner the contents of such will to such Official Trustee; and, if such Official Trustee`
  line `consents to accept the trust, then upon the execution by such executor or administrator of an instrument in`
  line `writing transferring the property subject to the Official Trustee, such property shall vest in such Official`
  line `Trustee, and shall be held by him upon the trusts expressed in the said will:`
  line
  line `Provided that the consent of the Official Trustee shall be recited in the said instrument and that such`
  line `instrument shall be duly executed by the Official Trustee.`
obj_root_law_sections_10:
  sectionId (33910)
  sectionNo (10)
  orderNo 10
  title `Power of High Court to appoint Official Trustee to be trustee of property.`
  content obj_root_law_sections_10_content
  footnotes `1. The words and figures "the Trustees' and Mortgagees' Powers Act, 1866, or" omitted by Act 48 of 1964, s. 7.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33910&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_10_content:
  string
  line `(1) If any property is`
  line `subject to a trust other than a trust which the Official Trustee is prohibited from accepting under the`
  line `provisions of this Act, and there is no trustee within the local limits of the ordinary or extraordinary original`
  line `civil jurisdiction of the High Court willing or capable to act in the trust, the High Court may on application`
  line `make an order for the appointment of the Official Trustee by that name with his consent to be the trustee of`
  line `such property.`
  line
  line `(2) Upon such order such property shall vest in the Official Trustee and shall be held by him upon the`
  line `same trusts as the same was held previously to such order, and the previous trustee or trustees (if any) shall be`
  line `exempt from the liability as trustees of such property save in respect of acts done before the date of such`
  line order.
  line
  line `(3) Nothing in this section shall be deemed to affect the provisions of ^1* * * the Indian Trusts Act, 1882`
  line `(2 of 1882).`
obj_root_law_sections_11:
  sectionId (33911)
  sectionNo (11)
  orderNo 11
  title `Power of private trustees to appoint Official Trustee to be trustee of property.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33911&sectionno=11&orderno=11&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_11_content:
  string
  line `(1) If any`
  line `property is subject to a trust other than a trust which the Official Trustee is prohibited from accepting under`
  line `the provisions of this Act, and all the trustees or the surviving or continuing trustee or trustees and all persons beneficially interested in the trust arc desirous that the Official Trustee shall be appointed in the room of such`
  line `trustee or trustees, it shall be lawful for such trustee or trustees, by an instrument in writing to appoint the`
  line `Official Trustee by that name or any other sufficient description with his consent to be the trustee of such`
  line `property:`
  line
  line `Provided that the consent of the Official Trustee shall be recited in the said instrument and that such`
  line `instrument shall be duly executed by him.`
  line
  line `(2) Upon such appointment such property shall vest in the Official Trustee and shall be held by him upon`
  line `the same trusts as the same was held previously to such appointment, and the previous trustee or trustees shall`
  line `be exempt from all liability as trustees of such property save in respect of acts done before the date of such`
  line appointment.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (33912)
  sectionNo (12)
  orderNo 12
  title `Executor or administrator may pay to Official Trustee legacy, share, etc., of minor or lunatic.`
  content obj_root_law_sections_12_content
  footnotes `1. Subs. by Act 48 of 1964, s. 8, for "infant".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33912&sectionno=12&orderno=12&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_12_content:
  string
  line `(1) If any ^1[minor] or lunatic is entitled to any gift, legacy or share of the assets of a deceased`
  line `person, it shall be lawful for the person by whom such gift is made, or executor or administrator by whom`
  line `such legacy or share is payable or transferable or any trustee of such gift, legacy or share, to transfer the same`
  line `by an instrument in writing to the Official Trustee by that name or any other sufficient description with his`
  line `consent:`
  line
  line `Provided that the consent of the Official Trustee shall be recited in the said instrument and that such`
  line `instrument shall be duly executed by the Official Trustee.`
  line
  line `(2) Any money or property transferred to the Official Trustee under this section shall vest in him and`
  line `shall be subject to the same provisions as arc contained in this Act as to other property vested in such Official`
  line Trustee.
obj_root_law_sections_13:
  sectionId (33913)
  sectionNo (13)
  orderNo 13
  title `Official Trustee not to be required to give bond or security.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33913&sectionno=13&orderno=13&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_13_content:
  string
  line `(1) No Official Trustee shall be`
  line `required by any Court to enter into any bond or security on his appointment in any capacity under this Act.`
  line
  line `(2) No Official Trustee ^1* * * shall be required to verify otherwise than by his signature any petition`
  line `presented by him under the provisions of this Act, and if the facts stated in any such petition are not within`
  line `^2[his personal knowledge], the petition may be verified and subscribed by any person competent to make the`
  line verification.
obj_root_law_sections_13_footnotes:
  string
  line `1. The words "or Deputy Official Trustee" omitted by s. 9, ibid.`
  line
  line `2. Subs. by s. 9, ibid., for "the Official Trustees' personal knowledge".`
obj_root_law_sections_14:
  sectionId (33914)
  sectionNo (14)
  orderNo 14
  title `Entry of Official Trustee not to constitute notice of a trust.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33914&sectionno=14&orderno=14&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_14_content:
  string
  line `The entry of the Official Trustee by`
  line `that name in the books of a company shall not constitute notice of a trust; and a company shall not be entitled`
  line `to object to enter the name of the Official Trustee on its register by reason only that the Official Trustee is a`
  line `corporation; and, in dealing with property, the fact that the person dealt with is the Official Trustee shall not`
  line `of itself constitute notice of a trust.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (33915)
  sectionNo (15)
  orderNo 15
  title `Liability of Government.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33915&sectionno=15&orderno=15&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_15_content:
  string
  line `(1) The ^1* * * Government ^2* * * shall be liable to make good all sums`
  line `required to discharge any liability which the Official Trustee, if he were a private trustee, would be personally`
  line `liable to discharge, except when the liability is one to which neither the Official Trustee nor any of his`
  line `officers has in any way contributed or which neither he nor any of his officers could by the exercise of`
  line `reasonable diligence have averted, and in either of those cases the Official Trustee shall not, nor shall the`
  line `^3[Government], be subject to any liability.`
  line
  line `(2) Nothing in sub-section (1) shall be deemed to render the ^3[Government] or any Official Trustee`
  line `appointed under this Act liable for anything done by or under the authority of any Official Trustee before the`
  line `commencement of this Act.`
obj_root_law_sections_15_footnotes:
  string
  line `1. The words "revenues of the" omitted by s. 10, ibid.`
  line
  line `2. The words "of India" omitted by Act 21 of 1922, s. 3.`
  line
  line `3. The words "revenues of the Government of India" have been successively amended by Act 21 of 1922, s. 3, the A.O. 1937 and Act`
  line `48 of 1964, s. 10, to read as above.`
obj_root_law_sections_16:
  sectionId (33916)
  sectionNo (16)
  orderNo 16
  title `Notice- of suit not required in certain cases.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33916&sectionno=16&orderno=16&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_16_content:
  string
  line `Nothing in section 80 of the Code of Civil Procedure,`
  line `1908 (5 of 1908) shall apply to any suit against the Official Trustee in which no relief is claimed against him`
  line personally.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (33917)
  sectionNo (17)
  orderNo 17
  title Fees.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33917&sectionno=17&orderno=17&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_17_content:
  string
  line `(1) There shall be charged in respect of the duties of the Official Trustee such fees, whether`
  line `by way of percentage or otherwise, as the Government may prescribe.`
  line
  line `^1** * * *`
  line
  line `(2) The fees under this section may be at different rates for different properties or classes of`
  line `properties or for different duties, and shall, so far as may be, be arranged so as to produce an`
  line `amount sufficient to discharge the salaries and all other expenses incidental to the working of this`
  line `Act (including such sum as Government may determine to be required to insure ^2*** the`
  line `Government ^3*** against loss under this Act).`
obj_root_law_sections_17_footnotes:
  string
  line `1. The proviso omitted by Act 48 of 1964, s. 11.`
  line
  line `2. The words "the revenues of" omitted by s. 11, ibid.`
  line
  line `3. The words "of India" omitted by Act 21 of 1922, s. 4.`
obj_root_law_sections_18:
  sectionId (33918)
  sectionNo (18)
  orderNo 18
  title `Disposal of fees.`
  content obj_root_law_sections_18_content
  footnotes `1. The words "the revenues of" omitted by s. 11, ibid.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33918&sectionno=18&orderno=18&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_18_content:
  string
  line `(1) All expenses which might be retained or paid out of the trust`
  line `fund, if the Official Trustee were a private trustee, shall be so retained or paid, and any fees leviable`
  line `under this Act shall be retained or paid in like manner as and in addition to such expenses.`
  line
  line `(2) The Official Trustee shall transfer and pay to such authority and in such manner and at such times`
  line `as the Government may prescribe, all fees received by him under this Act, and the same shall be carried to the`
  line `account and credit of the Government ^1***.`
obj_root_law_sections_19:
  sectionId (33919)
  sectionNo (19)
  orderNo 19
  title `Auditors to be appointed to examine Official Trustees‟s accounts, etc., and to report to Government.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by Act 48 of 1964, s. 12, for clause (a).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33919&sectionno=19&orderno=19&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_19_content:
  string
  line `(1) The accounts of the Official Trustee shall be audited at least once annually and at any`
  line `other time if the Government so direct by the prescribed person and in the prescribed manner.`
  line
  line `(2) The auditor shall examine such accounts, and shall forward to Government a statement thereof in the`
  line `prescribed form, together with a report thereon and a certificate signed by him showing--`
  line
  line `^1[(a) whether the accounts have been audited in the prescribed manner, and whether, so far as can be`
  line `ascertained by such audit, the accounts contain a full and true account of everything which ought to be`
  line `contained therein;]`
  line
  line `(b) whether the books, which by any rules made under this Act are directed to be kept by the Official`
  line `Trustee, have been duly and regularly kept, and`
  line
  line `(c) whether the trust funds and securities have been duly kept and invested and deposited`
  line `in the manner prescribed by this .Act or any rules made thereunder;`
  line
  line `or (as the case may be) that such accounts are deficient, or that the Official Trustee has failed to comply with`
  line `this Act or the rules made thereunder, in such respects as may be specified in such certificate.`
obj_root_law_sections_20:
  sectionId (33920)
  sectionNo (20)
  orderNo 20
  title `Auditor‟s power to summon witnesses and to call for documents.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33920&sectionno=20&orderno=20&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_20_content:
  string
  line `(1) Every auditor shall have`
  line `the powers of a Civil Court under the Code of Civil Procedure, 1908 (5 of 1908),--`
  line
  line `(a) to summon any person whose presence he may think necessary to attend him from time to time,`
  line and
  line
  line `(b) to examine any person, on oath to be by him administered, and`
  line
  line `(c) to issue a commission for the examination on interrogatories or otherwise of any person, and`
  line
  line `(d) to summon any person to produce any document or thing, the production of which appears to be`
  line `necessary for the purposes of such audit or examination.`
  line
  line `(2) Any person who, when summoned, refuses, or without reasonable cause neglects to attend or to`
  line `produce any document or thing or attends and refuses to be sworn, or to be examined shall be deemed`
  line `to have committed an offence within the meaning of, and punishable under section 188 of the Indian`
  line `Penal Code (45 of 1860), and the auditor shall report every case of such refusal or neglect to`
  line Government.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (33921)
  sectionNo (21)
  orderNo 21
  title `Costs of audit, etc., how paid.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33921&sectionno=21&orderno=21&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_21_content:
  string
  line `The cost of and incidental to every such audit and examination shall`
  line `be determined in accordance with rules made by the Government and shall be defrayed in the prescribed`
  line manner.
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (33922)
  sectionNo (22)
  orderNo 22
  title `Right of beneficiary to inspection and copies of accounts.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33922&sectionno=22&orderno=22&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_22_content:
  string
  line `Every beneficiary under a trust`
  line `which is being administered by the Official Trustee shall, subject to such conditions and restrictions as`
  line `may be prescribed, be entitled, at all reasonable times, to inspect the accounts of such trust, and the`
  line `report and certificate of the auditor and, on payment of the prescribed fee, to be furnished with copies`
  line `thereof .or extracts therefrom, and nothing in the Indian Trusts Act, 1882 (2 of 1882), shall affect the`
  line `provisions of this section.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (33923)
  sectionNo (23)
  orderNo 23
  title `Transfer to Government of accumulations in the hands of Official Trustee.`
  content obj_root_law_sections_23_content
  footnotes `1. The words "of India" omitted by Act 21 of 1922, s. 4.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33923&sectionno=23&orderno=23&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_23_content:
  string
  line `When any moneys`
  line `payable to a beneficiary under a trust have been in the hands of any Official Trustee for a period of, twelve`
  line `years or upwards whether before or after the commencement of this Act in consequence of the Official`
  line `"Trustee having been unable to trace the person entitled to receive the same, such money shall be transferred`
  line `in the prescribed manner to the account and credit of the Government ^1***:`
  line
  line `Provided that no such moneys shall be so transferred if any suit or proceeding is pending in respect`
  line `thereof in any Court.`
obj_root_law_sections_24:
  sectionId (33924)
  sectionNo (24)
  orderNo 24
  title `Mode of proceeding by claimant to recover money so transferred.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33924&sectionno=24&orderno=24&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_24_content:
  string
  line `(1) If any claim is`
  line `made to any moneys so transferred and such claim is established to the satisfaction of the`
  line `prescribed authority, the Government ^1*** shall pay to the claimant the amount in respect of`
  line `which the claim is established.`
  line
  line `(2) If such claim is not established to the satisfaction of the prescribed authority, the claimant`
  line `may, without prejudice to his right to take any other proceedings for the recovery of such moneys,`
  line `apply by petition to the High Court against the ^2[Government], and, after taking such evidence as it`
  line `thinks fit, such Court shall make such order on the petition in regard to the payment of such`
  line `moneys as it thinks fit, and such order shall be binding on all parties to the proceedings.`
  line
  line `^3** * * *`
  line
  line `(3) The Court may further direct by whom all or any part of the costs of such proceedings shall be paid.`
obj_root_law_sections_24_footnotes:
  string
  line `1. The words "of India" omitted by Act 21 of 1922, s. 4.`
  line
  line `2. Subs. by the A.O. 1937, for "Secretary of State for India in Council".`
  line
  line `3. The proviso omitted by the A.O. 1950. Earlier inserted by the A.O. 1937.`
obj_root_law_sections_25:
  sectionId (33925)
  sectionNo (25)
  orderNo 25
  title `Power of High Court to make orders in respect of property vested in Official Trustee.`
  content obj_root_law_sections_25_content
  footnotes `1. Subs. by Act 48 of 1964, s. 13, for "interest".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33925&sectionno=25&orderno=25&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_25_content:
  string
  line The
  line `High Court may make such orders as it thinks fit respecting any trust property vested in the Official Trustee,`
  line `or the ^1[income] or produce thereof.`
obj_root_law_sections_26:
  sectionId (33926)
  sectionNo (26)
  orderNo 26
  title `Who may apply for order under Act.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33926&sectionno=26&orderno=26&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_26_content:
  string
  line `Any order under this Act may be made, on the application`
  line `of any person beneficially interested in any trust property or of any trustee thereof.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (33927)
  sectionNo (27)
  orderNo 27
  title `Order of Court to have effect of a decree.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33927&sectionno=27&orderno=27&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_27_content:
  string
  line `Any order made by a High Court under this Act shall`
  line `have the same effect as a decree.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (33928)
  sectionNo (28)
  orderNo 28
  title `General powers of administration.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33928&sectionno=28&orderno=28&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_28_content:
  string
  line `The Official Trustee may, in addition to and not in derogation`
  line `of any other powers of expenditure lawfully exercisable by him, incur expenditure--`
  line
  line `(a) on such acts as may be necessary for the proper care and management of any property belonging`
  line `to any trust administered by him; and`
  line
  line `(b) with the sanction of the High Court on such religious, charitable and other objects and on such`
  line `improvements as may be reasonable and proper in the case of such property.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (33929)
  sectionNo (29)
  orderNo 29
  title `Transfer of trust property by Official Trustee to original trustee or any other trustee.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33929&sectionno=29&orderno=29&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_29_content:
  string
  line `(1)`
  line `Nothing in this Act shall be deemed to prevent the transfer by the Official Trustee of any property vested in`
  line `him to--`
  line
  line `(a) the original trustee (if any); or`
  line
  line `(b) any other lawfully appointed trustee; or`
  line
  line `(c) any other person if the Court so directs.`
  line
  line `(2) Upon such transfer such property shall vest in such trustee, and shall be held by him upon the same`
  line `trusts as those upon which it was held prior to such transfer, and the Official Trustee shall be exempt from all`
  line `liability as trustee of such property except in respect of acts done before such transfer:`
  line
  line `Provided that, in the case of any transfer under this section, the Official Trustee shall be entitled to`
  line `retain out of the property any fees leviable in accordance with the provisions of this Act.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (33930)
  sectionNo (30)
  orderNo 30
  title Rules.
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33930&sectionno=30&orderno=30&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_30_content:
  string
  line `(1) The Government shall make rules for carrying into effect the objects of this Act`
  line `and for regulating the proceedings of the Official Trustee in the discharge of his duties.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may provide`
  line for--
  line
  line `(a) the accounts to be kept by the Official Trustee and the audit and inspection thereof;`
  line
  line `(b) the safe custody, and deposit of the funds and securities which come into the hands of the Official`
  line Trustee;
  line
  line `(c) the remittance of sums of money in the hands of the Official Trustee in cases in which such`
  line `remittances are required;`
  line
  line `(d) the statements, schedules and other documents to be submitted by the Official Trustee`
  line `to Government or to any other authority and the publication of such statements, schedules or`
  line `other documents;`
  line
  line `(e) the realization of the cost of preparing any such statements, schedules or other documents;`
  line
  line `^1** * * *`
  line
  line `(f) subject to the provisions of this Act, the fees to be paid thereunder and the collection and`
  line `accounting for any fees so fixed;`
  line
  line `(g) the manner in which and the person by whom the costs of and incidental to any audit under the`
  line `provisions of this Act are to be determined and defrayed;`
  line
  line `(h) the manner in which summonses issued under the provisions of section 20 are to be served and`
  line `the payment of the expenses of any persons summoned or examined under the provisions of this Act and`
  line `of any expenditure incidental to such examination;`
  line
  line `(i) the acceptance by the Official Trustee of trusts for religious purposes and trusts which involve the`
  line `management or carrying on of business; and`
  line
  line `(j) any matter in this Act directed to be prescribed.`
  line
  line `(3) Rules made under the provisions of this section shall be published in the Official Gazette, and shall`
  line `thereupon have effect as if enacted in this Act.`
  line
  line `^2[(3A) Every rule made by the State Government under this section shall be laid, as soon as it is made,`
  line `before the State Legislature.]`
  line
  line `^3[(4) Every rule made by the Central Government under this section shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament while it is in session for a total period of thirty days which may`
  line `be comprised in one session or ^4[in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid], both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the`
  line `rule shall thereafter have effect only in such modified form or be of no effect, as the case may be;`
  line
  line `so however that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that rule.]`
obj_root_law_sections_30_footnotes:
  string
  line `1. Clause (ee) rep. by the Act 5 of 1917, s. 6 and the Schedule. Earlier inserted by Act 10 of 1914, s. 2 and the first Schedule.`
  line
  line `2. Ins. by Act 20 of 1983, s. 2 and Schedule (w.e.f. 15-3-1984).`
  line
  line `3. Ins. by Act 48 of 1964, s. 14.`
  line
  line `4. Subs. by Act 20 of 1983, s. 2 and the Schedule, for certain words (w.e.f. 15-3-1984).`
obj_root_law_sections_31:
  sectionId (33931)
  sectionNo (31)
  orderNo 31
  title [Repealed.].
  content `[Division. of Presidency into Provinces.] Rep. by the Adaptation of Laws (Order), 1937.`
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33931&sectionno=31&orderno=31&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (33932)
  sectionNo (32)
  orderNo 32
  title `Saving of provisions of Indian Registration Act, 1908.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33932&sectionno=32&orderno=32&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_32_content:
  string
  line `Nothing contained in this Act`
  line `shall be deemed to affect the provisions of the Indian Registration Act, 1908 (16 of 1908).`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_32_a:
  sectionId (33933)
  sectionNo 32A
  orderNo 33
  title Saving.
  content obj_root_law_sections_32_a_content
  footnotes obj_root_law_sections_32_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33933&sectionno=32A&orderno=33&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_32_a_content:
  string
  line `^1[32A. Saving.-- ^2[(1)] The amendments of this Act which come into force on ^3[the 26th day of`
  line `January, 1950], shall not affect any legal proceedings pending in any Court on that date or be`
  line `construed as automatically transferring any property from any Official Trustee to any other Official`
  line `Trustee: but nothing in this section shall be construed as preventing a transfer of any such property`
  line `in accordance with any of the other provisions of this Act.]`
  line
  line `^4[(2) The amendments of this Act, which come into force on the 26th day of January, 1950, shall`
  line `not affect any legal proceeding arising out of the application of this Act to any person in a Part B`
  line `State and pending in any Court on the said date or the administration of any property or estate of any`
  line `such person which was immediately before that date vested in an Official Trustee under this Act, and`
  line `the provisions of this Act shall, notwithstanding the said amendments, continue to apply with`
  line `necessary modifications, in relation to such proceedings or such property or estate, as the case may`
  line be.]
obj_root_law_sections_32_a_footnotes:
  string
  line `1. Ins. by the A.O. 1937.`
  line
  line `2. Renumbered as sub-section (1) by the A.O. 1950.`
  line
  line `3. Subs., ibid., for "the commencement of Part III of the Government of India Act, 1935.".`
  line
  line `4. Added, ibid`
obj_root_law_sections_32_b:
  sectionId (33934)
  sectionNo 32B
  orderNo 34
  title `Special provision regarding certain Official Trustees affected by States‟ reorganisation.`
  content obj_root_law_sections_32_b_content
  footnotes `1. Ins. by the A.O. (No. 2) 1956.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33934&sectionno=32B&orderno=34&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_32_b_content:
  string
  line `^1[32B. Special provision regarding certain Official Trustees affected by States’`
  line `reorganisation.--The amendments of this Act which come into force on the 1st November, 1956,`
  line `shall not affect any legal proceedings pending in any Court on that date and where, on acc ount of`
  line `the reorganisation of States under the States Reorganisation Act, 1956 (37 of 1956), or the Bihar`
  line `and West Bengal (Transfer of Territories) Act, 1956 (40 of 1956), the whole or any part of a State is transferred to any other State, such transfer of the territory of the State shall not be construed as`
  line `automatically transferring any property from any Official Trustee to any other Official Trustee; but`
  line `if, by reason of such transfer of territory, it appears to the Central Government that the whole or`
  line `any part of the property vested in an Official Trustee, should be vested in another Official Trustee,`
  line `that Government may direct that the property will be so vested and thereupon it shall vest in that`
  line `other Official Trustee and his successors as fully and effectually for the purposes of this Act, as if`
  line `it had been originally vested in him under this Act.]`
obj_root_law_sections_33:
  sectionId (33935)
  sectionNo (33)
  orderNo 35
  title [Repealed.].
  content `[Repeals.] Rep. by the Repealing Act, 1927 (12 of 1927), s. 2 and Schedule.`
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00054_191302_1523341485774&sectionId=33935&sectionno=33&orderno=35&orgactid=AC_CEN_3_20_00054_191302_1523341485774
obj_root_law_sections_33_footnotes:
  string
  line
