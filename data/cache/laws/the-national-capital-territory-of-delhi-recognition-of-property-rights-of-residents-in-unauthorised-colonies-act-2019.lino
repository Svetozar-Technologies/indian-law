obj_root_law_sections_1:
  sectionId (49747)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_201945_1576820830514&sectionId=49747&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00079_201945_1576820830514
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Capital Territory of Delhi`
  line `(Recognition of Property Rights of Residents in Unauthorised Colonies) Act, 2019.`
  line
  line `(2) It extends to the National Capital Territory of Delhi.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (49748)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_201945_1576820830514&sectionId=49748&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00079_201945_1576820830514
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) “resident” means a person having physical possession of property on the basis of a registered`
  line `sale deed or latest Power of Attorney, Agreement to Sale, Will, possession letter and other documents`
  line `including documents evidencing payment of consideration in respect of a property in unauthorised`
  line `colonies and includes their legal heirs but does not include tenant, licensee or permissive user;`
  line
  line `(b) “unauthorised colony” means a colony or development comprising of a contiguous area,`
  line `where no permission has been obtained for approval of layout plan or building plans and has been`
  line `identified for regularisation of such colony in pursuance to the notification number S.O. 683(E), dated`
  line `the 24th March, 2008 of the Delhi Development Authority, published in the Gazette of India,`
  line `Extraordinary, Part II, Section 3, Sub-section (ii), dated the 24th March, 2008.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (49749)
  sectionNo (3)
  orderNo 3
  title `Recognition of property rights.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_201945_1576820830514&sectionId=49749&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00079_201945_1576820830514
obj_root_law_sections_3_content:
  string
  line `(1) Notwithstanding anything contained in the Indian Stamp`
  line `Act, 1899 (2 of 1899) and the Registration Act, 1908 (16 of 1908) as applicable to the National Capital`
  line `Territory of Delhi or any rules or regulations or bye-laws made there under and the judgment of the`
  line `Supreme Court in the case of Suraj Lamp & Industries (P) Ltd. Vs. State of Haryana & others, dated the`
  line `11th October, 2011, the Central Government may, by notification in the Official Gazette, regularise the`
  line `transactions of immovable properties based on the latest Power of Attorney, Agreement to Sale, Will,`
  line `possession letter and other documents including documents evidencing payment of consideration for`
  line `conferring or recognising right of ownership or transfer or mortgage in regard to an immovable property`
  line `in favour of a resident of an unauthorised colony.`
  line
  line `(2) The Central Government may, by notification published in the Official Gazette, fix charges on`
  line `payment of which transactions of immovable properties based on the latest Power of Attorney,`
  line `Agreement to Sale, Will, possession letter and other documents including documents evidencing payment`
  line `of consideration for conferring or recognising right of ownership or transfer or mortgage in regard to an`
  line `immovable property in favour of a resident of an unauthorised colony through a conveyance deed or`
  line `authorisation slip, as the case may be.`
  line
  line `(3) Notwithstanding anything contained in section 27 of the Indian Stamp Act, 1899 (2 of 1899), the`
  line `stamp duty and registration charges shall be payable on the amount mentioned in the conveyance deed or`
  line `authorisation slip, as the case may be.`
  line
  line `(4) Any resident of an unauthorised colony having registered or un-registered or notarised Power of`
  line `Attorney, Agreement to Sale, Will, possession letter and other documents including documents`
  line `evidencing payment of consideration shall be eligible for right of ownership or transfer or mortgage`
  line `through a conveyance deed or authorisation slip, as the case may be, on payment of charges referred to in`
  line `sub-section (2).`
  line
  line `(5) No stamp duty and registration charges shall be payable on any previous sale transactions made`
  line `prior to any transaction referred to in sub-section (4).`
  line `(6) The tenants, licensees or permissive users shall not be considered for conferring or recognising`
  line `any property rights under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
