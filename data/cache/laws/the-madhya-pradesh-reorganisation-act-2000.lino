obj_root_law_sections_1:
  sectionId (26702)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Madhya Pradesh Reorganisation Act, 2000.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26702&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (26703)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26703&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "appointed day" means the day^1 which the Central Government may, by notification in the`
  line `Official Gazette, appoint;`
  line
  line `(b) "article" means an article of the Constitution;`
  line
  line `(c) "assembly constituency", "council constituency" and "parliamentary constituency" have the`
  line `same meanings as in the Representation of the People Act, 1950 (43 of 1950);`
  line
  line `(d) "Election Commission" means the Election Commission appointed by the President under`
  line `article 324;`
  line
  line `(e) "existing State of Madhya Pradesh" means the State of Madhya Pradesh as existing`
  line `immediately before the appointed day;`
  line
  line `(f) "law" includes any enactment, ordinance, regulation, order, bye-law, rule, scheme, notification`
  line `or other instrument having, immediately before the appointed day, the force of law in the whole or in`
  line `any part of the existing State of Madhya Pradesh;`
  line
  line `(g) "notified order" means an order published in the Official Gazette;`
  line
  line `(h) "population ratio" in relation to the States of Madhya Pradesh and Chhattisgarh means the`
  line `ratio of 485.7 : 176.2;`
  line
  line `(i) "sitting member", in relation to either House of Parliament or of the Legislature of the existing`
  line `State of Madhya Pradesh means a person who immediately before the appointed day, is a member of`
  line `that House;`
  line
  line `(j) "successor State", in relation to the existing State of Madhya Pradesh, means the State of`
  line `Madhya Pradesh or Chhattisgarh;`
  line
  line `(k) "transferred territory" means the territory which on the appointed day is transferred from the`
  line `existing State of Madhya Pradesh to the State of Chhattisgarh;`
  line
  line `(l) "treasury" includes a sub-treasury; and`
  line
  line `(m) any reference to a district, tehsil or other territorial division of the existing State of Madhya`
  line `Pradesh shall be construed as a reference to the area comprised within that territorial division on the`
  line `appointed day.`
obj_root_law_sections_2_footnotes:
  string
  line `1. 1st November, 2000, vide notification No. S.O. 827(E), dated 14th September, 2000, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii)`
obj_root_law_sections_3:
  sectionId (26704)
  sectionNo (3)
  orderNo 3
  title `Formation of Chhattisgarh State.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26704&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_3_content:
  string
  line `On and from the appointed day, there shall be formed a new`
  line `State to be known as the State of Chhattisgarh comprising the following territories of the existing State of`
  line `Madhya Pradesh, namely:—`
  line
  line `Bastar, laspur, Dantewada, Dhamtari, Durg, Janjgir-Champa, Jashpur, Kanker,`
  line `Kawardha, Korba, Koria, Mahasamund, Raigarh, Raipur, Rajnandgaon and Surguja districts, and thereupon the said territories shall cease to form part of the existing State of Madhya Pradesh.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (26705)
  sectionNo (4)
  orderNo 4
  title `State of Madhya Pradesh and territorial divisions thereof.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26705&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_4_content:
  string
  line `On and from the appointed day,`
  line `the State of Madhya Pradesh shall comprise the territories of the existing State of Madhya Pradesh other`
  line `than those specified in section 3.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (26706)
  sectionNo (5)
  orderNo 5
  title `Amendment of the First Schedule to the Constitution.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26706&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_5_content:
  string
  line `On and from the appointed day, in the`
  line `First Schedule to the Constitution, under the heading “I. THE STATES”,—`
  line
  line `(a) in the paragraph relating to the territories of the State of Madhya Pradesh, after the words,`
  line `brackets and figures, "the Rajasthan and Madhya Pradesh (Transfer of Territories) Act, 1959`
  line `(47 of 1959)", the following shall be added, namely:—`
  line
  line `"but excluding the territories specified in section 3 of the Madhya Pradesh Reorganisation`
  line `Act, 2000.";`
  line
  line `(b) after entry 25, the following entry shall be inserted, namely:—`
  line
  line `"26. Chhattisgarh: The territories specified in section 3 of the Madhya Pradesh`
  line
  line `Reorganisation Act, 2000.".`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (26707)
  sectionNo (6)
  orderNo 6
  title `Saving powers of the State Government.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26707&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_6_content:
  string
  line `Nothing in the foregoing provisions of this Part shall`
  line `be deemed to affect the power of the Government of Madhya Pradesh or Chhattisgarh to alter, after the`
  line `appointed day, the name, area or boundaries of any district or other territorial division in the State.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (26708)
  sectionNo (7)
  orderNo 7
  title `Amendment of the Fourth Schedule to the Constitution.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26708&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_7_content:
  string
  line `On and from the appointed day, in`
  line `the Fourth Schedule to the Constitution, in the Table,—`
  line
  line `(a) entries 9 to 27 shall be renumbered as entries 10 to 28 respectively;`
  line
  line `(b) in entry 8, for the figures "16", the figures "11 " shall be substituted;`
  line
  line `(c) after entry 8, the following entry shall be inserted, namely:—`
  line
  line `“9. Chhattisgarh ……………………5.”.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (26709)
  sectionNo (8)
  orderNo 8
  title `Allocation of sitting members.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26709&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_8_content:
  string
  line `(1) On and from the appointed day, the sixteen sitting members`
  line `of the Council of States representing the existing State of Madhya Pradesh, shall be deemed to have been`
  line `elected to fill the seats allotted to the States of Madhya Pradesh and Chhattisgarh, as specified in the First`
  line `Schedule to this Act.`
  line
  line `(2) The term of office of such sitting members shall remain unaltered.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (26710)
  sectionNo (9)
  orderNo 9
  title `Representation in the House of the People.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26710&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_9_content:
  string
  line `On and from the appointed day, there shall be`
  line `allocated 29 seats to the successor State of Madhya Pradesh, and 11 to the successor State of`
  line `Chhattisgarh, in the House of the People, and the First Schedule to the Representation of the People Act,`
  line `1950 (43 of 1950) shall be deemed to be amended accordingly.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (26711)
  sectionNo (10)
  orderNo 10
  title `Delimitation of Parliamentary and Assembly constituencies.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26711&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_10_content:
  string
  line `On and from the appointed day,`
  line `the Delimitation of Parliamentary and Assembly Constituencies Order, 1976, shall stand amended as`
  line `directed in the Second Schedule to this Act.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (26712)
  sectionNo (11)
  orderNo 11
  title `Provision as to sitting members.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26712&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_11_content:
  string
  line `(1) Every sitting member of the House of the People`
  line `representing a constituency which, on the appointed day by virtue of the provisions of section 10, stands`
  line `allotted, with or without alteration of boundaries, to the successor States of Madhya Pradesh or`
  line `Chhattisgarh, shall be deemed to have been elected to the House of the People by that constituency as so`
  line allotted.
  line
  line `(2) The term of office of such sitting members shall remain unaltered.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (26713)
  sectionNo (12)
  orderNo 12
  title `Provisions as to Legislative Assemblies.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26713&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_12_content:
  string
  line `(1) The number of seats as on the appointed day in`
  line `the Legislative Assemblies of the States of Madhya Pradesh and Chhattisgarh shall be two hundred and`
  line `thirty and ninety respectively.`
  line
  line `(2) In the Second Schedule to the Representation of the People Act, 1950 (43 of 1950), under heading`
  line `“I. States”,—`
  line
  line `(a) entries 5 to 25 shall be renumbered as entries 6 to 26 respectively;`
  line
  line `(b) after entry 4, the following entry shall be inserted, namely :—`
  line
  line `"1 5`
  line
  line `5. Chhattisgarh...90.";`
  line
  line `(c) in entry 13, as so renumbered, for the figures "320", the figures "230" shall be substituted.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (26714)
  sectionNo (13)
  orderNo 13
  title `Allocation of sitting members.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26714&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_13_content:
  string
  line `(1) Every sitting member of the Legislative Assembly of the`
  line `existing State of Madhya Pradesh elected to fill a seat in that Assembly from a constituency which on the`
  line `appointed day by virtue of the provisions of section 10 stands allotted, with or without alteration of`
  line `boundaries, to the State of Chhattisgarh shall, on and from that day, cease to be a member of the`
  line `Legislative Assembly of Madhya Pradesh and shall be deemed to have been elected to fill a seat in the`
  line `Legislative Assembly of Chhattisgarh from that constituency so allotted.`
  line
  line `(2) All other sitting members of the Legislative Assembly of the existing State of Madhya Pradesh`
  line `shall continue to be members of the Legislative Assembly of that State and any such sitting member`
  line `representing a constituency the extent, or the name and extent of which are altered by virtue of the`
  line `provisions of section 9 shall be deemed to have been elected to the Legislative Assembly of Madhya`
  line `Pradesh by that constituency as so altered.`
  line
  line `(3) Notwithstanding anything contained in any other law for the time being in force, the Legislative`
  line `Assemblies of Madhya Pradesh and Chhattisgarh shall be deemed to be duly constituted on the appointed`
  line day.
  line
  line `(4) The sitting member of the Legislative Assembly of the existing State of Madhya Pradesh`
  line `nominated to that Assembly under Article 333 to represent the Anglo-Indian community shall be deemed`
  line `to have been nominated to represent the said community in the Legislative Assembly of Madhya Pradesh`
  line `under that Article.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (26715)
  sectionNo (14)
  orderNo 14
  title `Duration of Legislative Assemblies.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26715&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_14_content:
  string
  line `The period of five years referred to in clause (1) of`
  line `article 172, shall, in the case of Legislative Assembly of the State of Madhya Pradesh and the State of`
  line `Chhattisgarh be deemed to have commenced on the date on which it actually commenced in the case of`
  line `Legislative Assembly of the existing State of Madhya Pradesh.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (26716)
  sectionNo (15)
  orderNo 15
  title `Speakers and Deputy Speakers.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26716&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_15_content:
  string
  line `(1) The persons who immediately before the appointed day`
  line `are the Speaker and Deputy Speaker of the Legislative Assembly of the existing State of Madhya Pradesh`
  line `shall continue to be the Speaker and Deputy Speaker respectively of that Assembly on and from that day.`
  line
  line `(2) As soon as may be after the appointed day, the Legislative Assembly of the successor State of`
  line `Chhattisgarh shall choose two members of that Assembly to be respectively Speaker and Deputy Speaker`
  line `thereof and until they are so chosen, the duties of the office of the Speaker shall be performed by such`
  line `member of the Assembly as the Governor may appoint for the purpose.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (26717)
  sectionNo (16)
  orderNo 16
  title `Rules of procedure.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26717&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_16_content:
  string
  line `The rules of procedure and conduct of business of the Legislative`
  line `Assembly of Madhya Pradesh as in force immediately before the appointed day shall, until rules are made`
  line `under clause (1) of article 208, be the rules of procedure and conduct of business of the Legislative`
  line `Assembly of the State of Chhattisgarh, subject to such modifications and adaptations as may be made`
  line `therein by the Speaker thereof.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (26718)
  sectionNo (17)
  orderNo 17
  title `Delimitation of constituencies.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26718&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_17_content:
  string
  line `(1) For the purpose of giving effect to the provisions of section`
  line `12, the Election Commission shall determine in the manner hereinafter provided—`
  line
  line `(a) the number of seats to be reserved for the Scheduled Castes and the Scheduled Tribes in the`
  line `Legislative Assemblies of the States of Madhya Pradesh and Chhattisgarh, respectively having regard`
  line `to the relevant provisions of the Constitution;`
  line
  line `(b) the assembly constituencies into which each State referred to in clause (a) shall be divided,`
  line `the extent of each of such constituencies and in which of them seats shall be reserved for the`
  line `Scheduled Castes or for the Scheduled Tribes; and`
  line
  line `(c) the adjustments in the boundaries and description of the extent of the parliamentary`
  line `constituencies in each State referred to in clause (a) that may be necessary or expedient.`
  line
  line `(2) In determining the matters referred to in clauses (b) and (c) of sub-section (1), the Election`
  line `Commission shall have regard to the following provisions, namely:—`
  line
  line `(a) all the constituencies shall be single-member constituencies;`
  line
  line `(b) all constituencies shall, as far as practicable, be geographically compact areas, and in`
  line `delimiting them, regard shall be had to physical features, existing boundaries of administrative units,`
  line `facilities of communication and conveniences to the public; and`
  line
  line `(c) constituencies in which seats are reserved for the Scheduled Castes and the Scheduled Tribes`
  line `shall, as far as practicable, be located in areas where the proportion of their population to the total`
  line `population is the largest.`
  line
  line `(3) The Election Commission shall, for the purpose of assisting it in the performance of its functions`
  line `under sub-section (1), associate with itself as associate members, five persons as the Central Government`
  line `may, by order specify, being persons who are members of the Legislative Assembly of the State or of the`
  line `House of the People representing the State:`
  line
  line `Provided that none of the associate members shall have a right to vote or to sign any decision of the`
  line `Election Commission.`
  line
  line `(4) If, owing to death or resignation, the office of an associate member falls vacant, it shall be filled`
  line `as far as practicable, in accordance with the provisions of sub-section (3).`
  line
  line `(5) The Election Commission shall`
  line
  line `(a) publish its proposals for the delimitation of constituencies together with the dissenting`
  line `proposals, if any, of any associate member who desires publication thereof in the Official Gazette and`
  line `in such other manner as the Commission may consider fit, together with a notice inviting objections`
  line `and suggestions in relation to the proposals and specifying a date on or after which the proposals will`
  line `be further considered by it;`
  line
  line `(b) consider all objections and suggestions which may have been received by it before the date so`
  line `specified; and`
  line
  line `(c) after considering all objections and suggestions which may have been received by it before the`
  line `date so specified, determine by one or more orders the delimitation of constituencies and cause such`
  line `order or orders to be published in the Official Gazette; and upon such publication, the order or orders`
  line `shall have the full force of law and shall not be called in question in any court.`
  line
  line `(6) As soon as may be after such publication, every such order relating to assembly constituencies`
  line `shall be laid before the Legislative Assembly of the concerned State.`
  line
  line `(7) The delimitation of constituencies in the States of Madhya Pradesh and Chhattisgarh shall be`
  line `determined on the basis of the published figures of the census taken in the year 1971.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (26719)
  sectionNo (18)
  orderNo 18
  title `Power of the Election Commission to maintain Delimitation Orders up-to-date.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26719&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_18_content:
  string
  line `(1) The`
  line `Election Commission may, from time to time, by notification in the Official Gazette,—`
  line
  line `(a) correct any printing mistakes in any order made under section 17 or any error arising therein`
  line `from inadvertent slip or omission; and`
  line
  line `(b) where the boundaries or name of any territorial division mentioned in any such order or orders`
  line `is or are altered, make such amendments as appear to it to be necessary or expedient for bringing such`
  line `order up-to-date.`
  line
  line `(2) Every notification under this section relating to an assembly constituency shall be laid, as soon as`
  line `may be after it is issued, before the concerned Legislative Assembly.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (26720)
  sectionNo (19)
  orderNo 19
  title `Amendment of the Scheduled Castes Order.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26720&sectionno=19&orderno=19&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_19_content:
  string
  line `On and from the appointed day, the Constitution`
  line `(Scheduled Castes) Order, 1950, shall stand amended as directed in the Third Schedule.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (26721)
  sectionNo (20)
  orderNo 20
  title `Amendment of the Scheduled Tribes Order.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26721&sectionno=20&orderno=20&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_20_content:
  string
  line `On and from the appointed day, the Constitution`
  line `(Scheduled Tribes) Order, 1950, shall stand amended as directed in the Fourth Schedule.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (26722)
  sectionNo (21)
  orderNo 21
  title `High Court of Chhattisgarh.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26722&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_21_content:
  string
  line `(1) As from the appointed day, there shall be a separate High`
  line `Court for the State of Chhattisgarh (hereinafter referred to as “the High Court of Chhattisgarh”) and the`
  line `High Court of Madhya Pradesh shall become the High Court for the State of Madhya Pradesh (hereinafter`
  line `referred to as the High Court of Madhya Pradesh).`
  line
  line `(2) The principal seat of High Court of Chhattisgarh shall be at such place as the President may, by`
  line `notified order, appoint.`
  line
  line `(3) Notwithstanding anything contained in sub-section (2), the Judges and Division Courts of the`
  line `High Court of Chhattisgarh may sit at such other place or places in the State of Chhattisgarh other than its`
  line `principal seat as the Chief Justice may, with the approval of the Governor of Chhattisgarh, appoint.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (26723)
  sectionNo (22)
  orderNo 22
  title `Judges of Chhattisgarh High Court.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26723&sectionno=22&orderno=22&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_22_content:
  string
  line `(1) Such of the Judges of the High Court of Madhya`
  line `Pradesh holding office immediately before the appointed day as may be determined by the President shall`
  line `on that day cease to be Judges of the High Court of Madhya Pradesh and become Judges of the High`
  line `Court of Chhattisgarh.`
  line
  line `(2) The persons who by virtue of sub-section (1) become Judges of the High Court of Chhattisgarh`
  line `shall, except in the case where any such person is appointed to be the Chief Justice of that High Court,`
  line `rank in that Court according to the priority of their respective appointments as Judges of the High Court`
  line `of Madhya Pradesh.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (26724)
  sectionNo (23)
  orderNo 23
  title `Jurisdiction of Chhattisgarh High Court.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26724&sectionno=23&orderno=23&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_23_content:
  string
  line `The High Court of Chhattisgarh shall have, in`
  line `respect of any part of the territories included in the State of Chhattisgarh, all such jurisdiction, powers and`
  line `authority as, under the law in force immediately before the appointed day, are exercisable in respect to`
  line `that part of the said territories by the High Court of Madhya Pradesh.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (26725)
  sectionNo (24)
  orderNo 24
  title `Special provision relating to Bar Council and advocates.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26725&sectionno=24&orderno=24&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_24_content:
  string
  line `On and from the appointed day, in`
  line `the Advocates Act, 1961 (25 of 1961) in section 3, in sub-section (1), in clause (a), for the words "and`
  line `Madhya Pradesh", the words "Madhya Pradesh and Chhattisgarh" shall be substituted.`
  line
  line `(2) Any person who immediately before the appointed day is an Advocate on the roll of the Bar`
  line `Council of the existing State of Madhya Pradesh may give his option in writing, within one year from the`
  line `appointed day to the Bar Council of such existing State, to transfer his name on the roll of the Bar Council`
  line `of Chhattisgarh and notwithstanding anything contained in the Advocates Act, 1961 (25 of 1961) and the`
  line `rules made thereunder, on such option so given his name shall be deemed to have been transferred on the`
  line `roll of the Bar Council of Chhattisgarh with effect from the date of the option so given for the purposes of`
  line `the said Act and the rules made thereunder.`
  line
  line `(3) The persons other than the Advocates who are entitled immediately before the appointed day, to`
  line `practise in the High Court of Madhya Pradesh or any subordinate court thereof shall, on and after the`
  line `appointed day, be recognised as such persons entitled also to practise in the High Court of Chhattisgarh or`
  line `any subordinate court thereof, as the case may be.`
  line
  line `(4) The right of audience in the High Court of Chhattisgarh shall be regulated in accordance with the`
  line `like principles as immediately before the appointed day are in force with respect to the right of audience`
  line `in the High Court of Madhya Pradesh.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (26726)
  sectionNo (25)
  orderNo 25
  title `Practice and procedure in Chhattisgarh High Court.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26726&sectionno=25&orderno=25&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_25_content:
  string
  line `Subject to the provisions of this Part,`
  line `the law in force immediately before the appointed day with respect to practice and procedure in the High`
  line `Court of Madhya Pradesh shall, with the necessary modifications, apply in relation to the High Court of`
  line `Chhattisgarh, and accordingly, the High Court of Chhattisgarh shall have all such powers to make rules`
  line `and orders with respect to practice and procedure as are immediately before the appointed day exercisable`
  line `by the High Court of Madhya Pradesh:`
  line
  line `Provided that any rules or orders which are in force immediately before the appointed day with`
  line `respect to practice and procedure in the High Court of Madhya Pradesh shall, until varied or revoked by`
  line `rules or orders made by the High Court of Chhattisgarh, apply with the necessary modifications in`
  line `relation to practice and procedure in the High Court of Chhattisgarh as if made by that Court`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (26727)
  sectionNo (26)
  orderNo 26
  title `Custody of seal of Chhattisgarh High Court.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26727&sectionno=26&orderno=26&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_26_content:
  string
  line `The law in force immediately before the`
  line `appointed day with respect to the custody of the seal of the High Court of Madhya Pradesh shall, with the`
  line `necessary modifications, apply with respect to the custody of the seal of the High Court of Chhattisgarh.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (26728)
  sectionNo (27)
  orderNo 27
  title `Form of writs and other processes.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26728&sectionno=27&orderno=27&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_27_content:
  string
  line `The law in force immediately before the appointed day`
  line `with respect to the form of writs and other processes used, issued or awarded by the High Court of`
  line `Madhya Pradesh shall, with the necessary modifications, apply with respect to the form of writs and other`
  line `processes used, issued or awarded by the High Court of Chhattisgarh.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (26729)
  sectionNo (28)
  orderNo 28
  title `Powers of Judges.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26729&sectionno=28&orderno=28&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_28_content:
  string
  line `The law in force immediately before the appointed day relating to the`
  line `powers of the Chief Justice, Single Judge and Division Courts of the High Court of Madhya Pradesh and`
  line `with respect to all matters ancillary to the exercise of those powers shall, with the necessary`
  line `modifications, apply in relation to the High Court of Chhattisgarh.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (26730)
  sectionNo (29)
  orderNo 29
  title `Procedure as to appeals to Supreme Court.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26730&sectionno=29&orderno=29&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_29_content:
  string
  line `The law in force immediately before the`
  line `appointed day relating to appeals to the Supreme Court from the High Court of Madhya Pradesh and the`
  line `Judges and division courts thereof shall, with the necessary modifications, apply in relation to the High`
  line `Court of Chhattisgarh.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (26731)
  sectionNo (30)
  orderNo 30
  title `Transfer of proceedings from Madhya Pradesh High Court to Chhattisgarh High Court.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26731&sectionno=30&orderno=30&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_30_content:
  string
  line `(1) Except as hereinafter provided, the High Court of Madhya Pradesh shall, as from the appointed day,`
  line `have no jurisdiction in respect of the transferred territory.`
  line
  line `(2) Such proceedings pending in the High Court of Madhya Pradesh immediately before the`
  line `appointed day as are certified, whether before or after that day, by the Chief Justice of that High Court,`
  line `having regard to the place of accrual of the cause of action and other circumstances, to be proceedings`
  line `which ought to be heard and decided by the High Court of Chhattisgarh shall, as soon as may be after`
  line `such certification, be transferred to the High Court of Chhattisgarh.`
  line
  line `(3) Notwithstanding anything contained in sub-sections (1) and (2) of this section or in section 23, but`
  line `save as hereinafter provided, the High Court of Madhya Pradesh shall have, and the High Court of`
  line `Chhattisgarh shall not have, jurisdiction to entertain, hear or dispose of appeals, applications for leave to`
  line `the Supreme Court, applications for review and other proceedings where any such proceedings seek any`
  line `relief in respect of any order passed by the High Court of Madhya Pradesh before the appointed day:`
  line
  line `Provided that if after any such proceedings have been entertained by the High Court of Madhya`
  line `Pradesh, it appears to the Chief Justice of that High Court that they ought to be transferred to the High`
  line `Court of Chhattisgarh, he shall order that they shall be so transferred, and such proceedings shall`
  line `thereupon be transferred accordingly.`
  line
  line `(4) Any order made by the High Court of Madhya Pradesh—`
  line
  line `(a) before the appointed day, in any proceedings transferred to the High Court of Chhattisgarh by`
  line `virtue of sub-section (2); or`
  line
  line `(b) in any proceedings with respect to which the High Court of Madhya Pradesh retains`
  line `jurisdiction by virtue of sub-section (3),`
  line
  line `shall for all purposes have effect, not only as an order of the High Court of Madhya Pradesh, but also as`
  line `an order made by the High Court of Chhattisgarh.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (26732)
  sectionNo (31)
  orderNo 31
  title `Right to appear or to act in proceedings transferred to Chhattisgarh High Court.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26732&sectionno=31&orderno=31&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_31_content:
  string
  line Any
  line `person, who, immediately before the appointed day, is an Advocate entitled to practise or any other`
  line `persons entitled to practise in the High Court of Madhya Pradesh and was authorised to appear in any proceedings transferred from that High Court to the High Court of Chhattisgarh under section 30, shall`
  line `have the right to appear in the High Court of Chhattisgarh in relation to those proceedings.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (26733)
  sectionNo (32)
  orderNo 32
  title Interpretation.
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26733&sectionno=32&orderno=32&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_32_content:
  string
  line `For the purposes of section 30`
  line
  line `(a) proceedings shall be deemed to be pending in a Court until that Court has disposed of all`
  line `issues between the parties, including any issues with respect to the taxation of the costs of the`
  line `proceedings and shall include appeals, applications for leave to the Supreme Court, applications for`
  line `review, petitions for revision and petitions for writs; and`
  line
  line `(b) references to a High Court shall be construed as including references to a Judge or division`
  line `court thereof, and references to an order made by a Court or a Judge shall be construed as including`
  line `references to a sentence, judgment or decree passed or made by that Court or Judge.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (26734)
  sectionNo (33)
  orderNo 33
  title Saving.
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26734&sectionno=33&orderno=33&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_33_content:
  string
  line `Nothing in this Part shall affect the application to the High Court of Chhattisgarh of any`
  line `provisions of the Constitution, and this Part shall have effect subject to any provision that may be made`
  line `on or after the appointed day with respect to that High Court by any Legislature or other authority having`
  line `power to make such provision.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (26735)
  sectionNo (34)
  orderNo 34
  title `Authorisation of expenditure of Chhattisgarh State.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26735&sectionno=34&orderno=34&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_34_content:
  string
  line `The Governor of Madhya Pradesh may,`
  line `at any time before the appointed day, authorise such expenditure from the Consolidated Fund of the State`
  line `of Chhattisgarh as he deems necessary for any period not more than six months beginning with the`
  line `appointed day pending the sanction of such expenditure by the Legislative Assembly of the State of`
  line `Chhattisgarh:`
  line
  line `Provided that the Governor of Chhattisgarh may, after the appointed day, authorise such further`
  line `expenditure as he deems necessary from the Consolidated Fund of the State of Chhattisgarh for any`
  line `period not extending beyond the said period of six months.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (26736)
  sectionNo (35)
  orderNo 35
  title `Reports relating to accounts of Madhya Pradesh State.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26736&sectionno=35&orderno=35&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_35_content:
  string
  line `(1) The reports of the Comptroller`
  line `and Auditor-General of India referred to in clause (2) of article 151 relating to the accounts of the State of`
  line `Madhya Pradesh in respect of any period prior to the appointed day shall be submitted to the Governor of`
  line `each of the successor States of Madhya Pradesh and Chhattisgarh who shall cause them to be laid before`
  line `the Legislature of that State.`
  line
  line `(2) The President may by order—`
  line
  line `(a) declare any expenditure incurred out of the Consolidated Fund of Madhya Pradesh on any`
  line `service in respect of any period prior to the appointed day during the financial year or in respect of`
  line `any earlier financial year in excess of the amount granted for that service and for that year as`
  line `disclosed in the reports referred to in sub-section (1) to have been duly authorised; and`
  line
  line `(b) provide for any action to be taken on any matter arising out of the said reports.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (26737)
  sectionNo (36)
  orderNo 36
  title `Distribution of revenue.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26737&sectionno=36&orderno=36&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_36_content:
  string
  line `The President shall, by order, determine the share of the States of`
  line `Madhya Pradesh and Chhattisgarh in the total amount payable to the existing State of Madhya Pradesh on`
  line `the recommendation of the Finance Commission constituted under article 280 of the Constitution, in such`
  line `manner as he thinks fit.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (26738)
  sectionNo (37)
  orderNo 37
  title `Application of Part.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26738&sectionno=37&orderno=37&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_37_content:
  string
  line `(1) The provisions of this Part shall apply in relation to the apportionment`
  line `of the assets and liabilities of the State of Madhya Pradesh immediately before the appointed day`
  line
  line .
  line `(2) The successor State shall be entitled to receive benefits arising out of the decisions taken by the`
  line `predecessor State and the successor States shall be liable to bear the financial liabilities arising out of the`
  line `decision taken by the existing State of Madhya Pradesh.`
  line
  line `(3) The apportionment of assets and liabilities would be subject to such financial adjustment as may`
  line `be necessary to secure just, reasonable and equitable apportionment of the assets and liabilities amongst`
  line `the successor States.`
  line
  line `(4) Any dispute regarding the amount of financial assets and liabilities shall be settled through mutual`
  line `agreement, failing which by order by the Central Government on the advice of the Comptroller and`
  line `Auditor-General of India.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (26739)
  sectionNo (38)
  orderNo 38
  title `Land and goods.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26739&sectionno=38&orderno=38&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_38_content:
  string
  line `(1) Subject to the other provisions of this Part, all land and all stores, articles`
  line `and other goods belonging to the existing State of Madhya Pradesh shall,—`
  line
  line `(a) if within the transferred territory, pass to the State of Chhattisgarh; or`
  line
  line `(b) in any other case, remain the property of the State of Madhya Pradesh:`
  line
  line `Provided that any land, stores, articles or other goods may be distributed otherwise than in accordance`
  line `with the situation of such land, stores, articles or goods by mutual agreement between the successor`
  line `States, failing which the Central Government may, on the request of any of the Governments of the`
  line `successor States and after consulting both the Governments of the successor States, issue directions for`
  line `the just and equitable distribution of such land, stores, articles or goods between the successor States and`
  line `the land, articles or goods shall accordingly pass to the successor States:`
  line
  line `Provided further that in case of the distribution, of any land, stores, articles and goods or class of`
  line `goods under this sub-section located outside the existing State of Madhya Pradesh, such distribution shall`
  line `be made through mutual agreement arrived at between the Governments of the successor States for that`
  line `purpose, failing which the Central Government may, on request by any of the Governments of the`
  line `successor States, after consulting both the Governments of the successor States, issue such direction as it`
  line `may deem fit for the distribution of such land, stores, articles and goods or class of goods, as the case may`
  line `be, under this sub-section.`
  line
  line `(2) Stores held for specific purposes, such as use or utilisation in particular institutions, workshops or`
  line `undertakings or on particular works under construction, shall pass to the successor States in whose`
  line `territories such institutions, workshops, undertakings or works are located.`
  line
  line `(3) Stores relating to the Secretariat and offices of Heads of Departments having jurisdiction over the`
  line `whole of the existing State of Madhya Pradesh shall be divided between the successor States in`
  line `accordance with the mutual agreement arrived at between the Government of the successor States for that`
  line `purpose, failing which the Central Government may, on request by any of the Governments of the`
  line `successor States, after consulting both the Governments of the successor States, issue such direction as it`
  line `may deem fit for the distribution of such stores or any part of such stores, as the case may be.`
  line
  line `(4) Any other unissued stores of any class in the existing State of Madhya Pradesh shall be divided`
  line `between the successor States in proportion to the total stores of that class purchased in the period of three`
  line `years prior to the appointed day, for the territories of the existing State of Madhya Pradesh included`
  line `respectively in each of the successor States:`
  line
  line `Provided that where such proportion cannot be ascertained in respect of any class of stores or where`
  line `the value of any class of such stores does not exceed rupees ten thousand, that class of stores shall be`
  line `divided between the successor States according to the population ratio.`
  line
  line `(5) In this section, the expression "land" includes immovable property of every kind and any rights in`
  line `or over such property, and the expression "goods" does not include coins, bank notes and currency notes.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (26740)
  sectionNo (39)
  orderNo 39
  title `Treasury and bank balances.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26740&sectionno=39&orderno=39&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_39_content:
  string
  line `The total of the cash balances in all treasuries of the State of`
  line `Madhya Pradesh and the credit balances of the State with Reserve Bank of India, the State Bank of India`
  line `or any other bank immediately before the appointed day shall be divided between the States of Madhya`
  line `Pradesh and Chhattisgarh according to the population ratio:`
  line
  line `Provided that for the purposes of such division, there shall be no transfer of cash balances from any`
  line `treasury to any other treasury and the apportionments shall be effected by adjusting the credit balances of`
  line `the two States in the books of the Reserve Bank of India on the appointed day:`
  line
  line `Provided further that if the State of Chhattisgarh has no account on the appointed day with the`
  line `Reserve Bank of India, the adjustment shall be made in such manner as the Central Government may, by`
  line `order, direct.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (26741)
  sectionNo (40)
  orderNo 40
  title `Arrears of taxes.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26741&sectionno=40&orderno=40&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_40_content:
  string
  line `The right to recover arrears of any tax or duty on property, including arrears`
  line `of land revenue, shall belong to the successor State in which the property is situated, and the right to recover arrears of any other tax or duty shall belong to the successor State in whose territories the place of`
  line `assessment of that tax or duty is included on the appointed day.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (26742)
  sectionNo (41)
  orderNo 41
  title `Right to recover loans and advances.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26742&sectionno=41&orderno=41&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_41_content:
  string
  line `(1) The right of the existing State of Madhya Pradesh to`
  line `recover any loans or advances made before the appointed day to any local body, society, agriculturist or`
  line `other person in an area within that State shall belong to the successor State in which that area is included`
  line `on that day.`
  line
  line `(2) The right of the existing State of Madhya Pradesh to recover any loans or advances made before`
  line `the appointed day to any person or institution outside that State shall belong to the State of Madhya`
  line `Pradesh:`
  line
  line `Provided that any sum recovered in respect of any such loan or advance shall be divided between the`
  line `States of Madhya Pradesh and Chhattisgarh according to the population ratio.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (26743)
  sectionNo (42)
  orderNo 42
  title `Investments and credits in certain funds.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26743&sectionno=42&orderno=42&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_42_content:
  string
  line `(1) The securities held in respect of the investments`
  line `made from Cash Balances Investment Account or from any Fund in the Public Account of the existing`
  line `State of Madhya Pradesh as specified in the Fifth Schedule to this Act shall be apportioned in the ratio of`
  line `population of the successor States:`
  line
  line `Provided that the securities held in investments made from the Calamity Relief Fund of the existing`
  line `State of Madhya Pradesh shall be divided in the ratio of the area of the territories occupied by the`
  line `successor States:`
  line
  line `Provided further that the balance in the Reserve Funds in the Public Account of Madhya Pradesh`
  line `created wholly out of appropriations from the Consolidated Fund of the existing State of Madhya`
  line `Pradesh, to the extent the balances have not been invested outside Government account, shall not be`
  line `carried forward to similar Reserve Funds in the Public Account of, successor States:`
  line
  line `Provided also that the balances in any other Reserve Funds, excluding those specified in`
  line `sub-section (2), shall be allocated between the States of Madhya Pradesh and Chhattisgarh in the ratio of`
  line `population of those States.`
  line
  line `(2) The investments of the existing State of Madhya Pradesh immediately before the appointed day in`
  line `any special fund the objects of which are confined to a local area shall belong to the State in which that`
  line `area is included on the appointed day.`
  line
  line `(3) The investments of the existing State of Madhya Pradesh immediately before the appointed day in`
  line `any private, commercial or industrial undertaking, in so far as such investments have not been made or`
  line `are deemed not to have been made from the cash balance investment account, shall pass to the State in`
  line `which the principal seat of business of the undertaking is located.`
  line
  line `(4) Where any body corporate constituted under a Central Act, State Act or Provincial Act for the`
  line `existing State of Madhya Pradesh or any part thereof has, by virtue of the provisions of Part II of this Act,`
  line `become an inter-State body corporate, the investments in, or loans or advances to, any such body`
  line `corporate by the existing State of Madhya Pradesh made before the appointed day shall, save as otherwise`
  line `expressly provided by or under this Act, be divided between the States of Madhya Pradesh and`
  line `Chhattisgarh in the same proportion in which the assets of the body corporate are divided under the`
  line `provisions of this Part.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (26744)
  sectionNo (43)
  orderNo 43
  title `Assets and liabilities of State undertaking.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26744&sectionno=43&orderno=43&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_43_content:
  string
  line `(1) The assets and liabilities relating to any`
  line `undertaking of the existing State of Madhya Pradesh whether directly owned or through a body corporate`
  line `constituted or incorporated or registered under any Central, State or Provincial Act, shall,—`
  line
  line `(a) if exclusively located in a successor State, pass to the successor State, and where a`
  line `depreciation reserve is maintained by the existing State of Madhya Pradesh for such undertaking, the`
  line `securities held in respect of investment made from that fund shall also pass to such successor State;`
  line
  line `(b) where any such undertaking or part thereof is located, in more than one successor State, the`
  line `assets, liabilities and securities shall be divided in such manner as may be agreed upon between the`
  line `successor States within a period of two years from the appointed day or in failure of such agreement`
  line `as the Central Government may by order direct.`
  line
  line `(2) An agreement entered into between the successor States, or order made by the Central`
  line `Government under sub-section (1) may provide for the dissolution of the undertaking or transfer or re-employment of any employee of the undertaking to or by the successor States, subject to the provisions`
  line `of section 62.`
  line
  line `(3) An agreement entered into between the successor States, or order made by the Central`
  line `Government under sub-section (1) may also provide for the transfer of the assets and liabilities which`
  line `would otherwise have passed to a successor State to any other undertaking of that successor State; and`
  line `any employee of the undertaking referred to in sub-section (1), who would otherwise have been`
  line `transferred to or re-employed by a successor State, may be transferred to or be re-employed by such`
  line `undertaking instead of that successor State.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (26745)
  sectionNo (44)
  orderNo 44
  title `Public Debt.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26745&sectionno=44&orderno=44&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_44_content:
  string
  line `(1) All liabilities on account of Public Debt and Public Account of the existing`
  line `State of Madhya Pradesh outstanding immediately before the appointed day shall be apportioned in the`
  line `ratio of population of the successor States unless a different mode of apportionment is provided under the`
  line `provisions of this Act.`
  line
  line `(2) The individual items of liabilities to be allocated to the successor States and the amount of`
  line `contribution required to be made by one successor State to another shall be such as may be ordered by the`
  line `Central Government in consultation with the Comptroller and Auditor-General of India:`
  line
  line `Provided that till such orders are issued, the liabilities on account of Public Debt and Public Account`
  line `of the existing State of Madhya Pradesh shall continue to be the liabilities of the successor State of`
  line `Madhya Pradesh.`
  line
  line `(3) The liability on account of loans raised from any source and re-lent by the existing State of`
  line `Madhya Pradesh to such entities as may be specified by the Central Government and whose area of`
  line `operation is confined to either of the successor States shall devolve on the respective States as specified in`
  line `sub-section (4).`
  line
  line `(4) The Public Debt of the existing State of Madhya Pradesh attributable to loan taken from any`
  line `source for the express purpose of re-lending the same to a specific institution and outstanding`
  line `immediately before the appointed day shall—`
  line
  line `(a) if re-lent to any local body, body corporate or other institution in any local area, be the debt of`
  line `the State in which the local area is included on the appointed day; or`
  line
  line `(b) if re-lent to the Madhya Pradesh State Electricity Board, the Madhya Pradesh State Road`
  line `Transport Corporation, or the Madhya Pradesh Housing Board or any other institution which becomes`
  line `an inter-State institution on the appointed day, be divided between the States of Madhya Pradesh and`
  line `Chhattisgarh in the same proportion in which the assets of such body corporate or institution are`
  line `divided under the provisions of Part VII of this Act.`
  line
  line `(5) Where a sinking fund or a depreciation fund is maintained by the existing State of Madhya`
  line `Pradesh for repayment of any loan raised by it, the securities held in respect of investments made from`
  line `that fund shall be divided between the successor States of Madhya Pradesh and Chhattisgarh in the same`
  line `proportion in which the total public debt is divided between the two States under this section.`
  line
  line `(6) In this section, the expression "Government security" means a security, created and issued by a`
  line `State Government for the purpose of raising a public loan and having any of the forms specified in, or`
  line `prescribed under clause (2) of section 2 of the Public Debt Act, 1944 (18 of 1944).`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (26746)
  sectionNo (45)
  orderNo 45
  title `Floating loans.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26746&sectionno=45&orderno=45&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_45_content:
  string
  line `All liabilities of the existing State of Madhya Pradesh of any floating loan to`
  line `provide short term finance to any local body, body corporate or other institution shall be determined by`
  line `mutual agreement between the successor States, failing which the Central Government shall determine`
  line `such liability between the successor States in consultation with such States.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (26747)
  sectionNo (46)
  orderNo 46
  title `Refund of taxes collected in excess.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26747&sectionno=46&orderno=46&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_46_content:
  string
  line `The liability of the existing State of Madhya Pradesh to`
  line `refund any tax or duty on property, including land revenue, collected in excess shall be the liability of the`
  line `successor State in whose territories the property is situated, and the liability of the existing State of`
  line `Madhya Pradesh to refund any other tax or duty collected in excess shall be the liability of the successor`
  line `State in whose territories the place of assessment of that tax or duty is included.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (26748)
  sectionNo (47)
  orderNo 47
  title `Deposits, etc.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26748&sectionno=47&orderno=47&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_47_content:
  string
  line `(1) The liability of the existing State of Madhya Pradesh in respect of any civil`
  line `deposit or local fund deposit shall, as from the appointed day, be the liability of the State in whose area`
  line `the deposit has been made.`
  line
  line `(2) The liability of the existing State of Madhya Pradesh in respect of any charitable or other`
  line `endowment shall, as from the appointed day, be the liability of the State in whose area the institution`
  line `entitled to the benefit of the endowment is located or of the State to which the objects of the endowment,`
  line `under the terms thereof, are confined.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (26749)
  sectionNo (48)
  orderNo 48
  title `Provident fund.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26749&sectionno=48&orderno=48&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_48_content:
  string
  line `The liability of the existing State of Madhya Pradesh in respect of the`
  line `provident fund account of a Government servant in service on the appointed day shall, as from that day,`
  line `be the liability of the State to which that Government servant is permanently allotted.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (26750)
  sectionNo (49)
  orderNo 49
  title Pensions.
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26750&sectionno=49&orderno=49&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_49_content:
  string
  line `The liability of the existing State of Madhya Pradesh in respect of pensions shall pass`
  line `to, or be apportioned between the successor States of Madhya Pradesh and Chhattisgarh in accordance`
  line `with the provisions contained in the Sixth Schedule to this Act.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (26751)
  sectionNo (50)
  orderNo 50
  title Contracts.
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26751&sectionno=50&orderno=50&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_50_content:
  string
  line `(1) Where, before the appointed day, the existing State of Madhya Pradesh has made`
  line `any contract in the exercise of its executive power for any purposes of the State, that contract shall be`
  line `deemed to have been made in the exercise of the executive power—`
  line
  line `(a) if the purposes of the contract are, on and from the appointed day, exclusive purposes of either`
  line `of the successor States of Madhya Pradesh and Chhattisgarh, then, of that State; or`
  line
  line `(b) in any other case, of the State of Madhya Pradesh,`
  line
  line `all rights and liabilities which have accrued, or may accrue under any such contract shall, to the extent to`
  line `which they would have been rights or liabilities of the existing State of Madhya Pradesh, be rights or`
  line `liabilities of the State of Chhattisgarh or the State of Madhya Pradesh, as the case may be:`
  line
  line `Provided that in any such case as is referred to in clause (b), the initial allocation of rights and`
  line `liabilities made by this sub-section shall be subject to such financial adjustment as may be agreed upon`
  line `between the successor States of Madhya Pradesh and Chhattisgarh or in default of such agreement, as the`
  line `Central Government may, by order, direct.`
  line
  line `(2) For the purposes of this section, there shall be deemed to be included in the liabilities which have`
  line `accured or may accrue under any contract—`
  line
  line `(a) any liability to satisfy an order or award made by any court or other tribunal in proceedings`
  line `relating to the contract; and`
  line
  line `(b) any liability in respect of expenses incurred in or in connection with any such proceedings.`
  line
  line `(3) This section shall have effect subject to the other provisions of this Part relating to the`
  line `apportionment of liabilities in respect of loans, guarantees and other financial obligations; and bank`
  line `balances and securities shall, notwithstanding that they partake of the nature of contractual rights, be dealt`
  line `with under those provisions.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (26752)
  sectionNo (51)
  orderNo 51
  title `Liability in respect of actionable wrong.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26752&sectionno=51&orderno=51&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_51_content:
  string
  line `Where, immediately before the appointed day, the`
  line `existing State of Madhya Pradesh is subject to any liability in respect of any actionable wrong other than`
  line `breach of contract, that liability shall,—`
  line
  line `(a) if the cause of action arose wholly within the territories which, as from that day, are the`
  line `territories of either of the successor States of Madhya Pradesh or Chhattisgarh, be a liability of that`
  line `successor State; and`
  line
  line `(b) in any other case, be initially a liability of the State of Madhya Pradesh, but subject to such`
  line `financial adjustment as may be agreed upon between the States of Madhya Pradesh and Chhattisgarh`
  line `or, in default of such agreement, as the Central Government may, by order, direct.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (26753)
  sectionNo (52)
  orderNo 52
  title `Liability as guarantor.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26753&sectionno=52&orderno=52&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_52_content:
  string
  line `Where, immediately before the appointed day, the existing State of`
  line `Madhya Pradesh is liable as guarantor in respect of any liability of a registered co-operative society or`
  line `other person, that liability of the existing State of Madhya Pradesh shall—`
  line
  line `(a) if the area of operations of such society or persons is limited to the territories which, as from`
  line `that day, are the territories of either of the States of Madhya Pradesh or Chhattisgarh, be a liability of`
  line `that successor State; and`
  line
  line `(b) in any other case, be initially a liability of the State of Madhya Pradesh, subject to such`
  line `financial adjustment as may be agreed upon between the States of Madhya Pradesh and Chhattisgarh`
  line `or, in default of such agreements, as the Central Government may, by order, direct.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (26754)
  sectionNo (53)
  orderNo 53
  title `Items in suspense.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26754&sectionno=53&orderno=53&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_53_content:
  string
  line `If any item in suspense is ultimately found to affect an asset or liability of`
  line `the nature referred to in any of the foregoing provisions of this Part, it shall be dealt with in accordance`
  line `with that provision.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (26755)
  sectionNo (54)
  orderNo 54
  title `Residuary provision.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26755&sectionno=54&orderno=54&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_54_content:
  string
  line `The benefit or burden of any asset or liability of the existing State of`
  line `Madhya Pradesh not dealt with in the foregoing provisions of this Part shall pass to the State of Madhya`
  line `Pradesh in the first instance, subject to such financial adjustment as may be agreed upon between the`
  line `States of Madhya Pradesh and Chhattisgarh or, in default of such agreement, as the Central Government`
  line `may, by order, direct.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (26756)
  sectionNo (55)
  orderNo 55
  title `Apportionment of assets or liabilities by agreement.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26756&sectionno=55&orderno=55&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_55_content:
  string
  line `Where the successor States of Madhya`
  line `Pradesh and Chhattisgarh agree that the asset, liability or benefit or burden of any particular asset or`
  line `liability should be apportioned between them in a manner other than that provided for in the foregoing`
  line `provisions of this Part then, notwithstanding anything contained therein, the assets, liability or benefit or`
  line `burden of that asset or liability shall be apportioned in the manner agreed upon.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (26757)
  sectionNo (56)
  orderNo 56
  title `Power of Central Government to order allocation or adjustment in certain cases.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26757&sectionno=56&orderno=56&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_56_content:
  string
  line Where,
  line `by virtue of any of the provisions of this Part, any of the successor States of Madhya Pradesh and`
  line `Chhattisgarh becomes entitled to any property or obtains any benefits or becomes subject to any liability,`
  line `and the Central Government is of opinion, on a reference made within a period of three years from the`
  line `appointed day by either of the States, that it is just and equitable that property or those benefits should be`
  line `transferred to, or shared with, the other successor State, or that a contribution towards that liability should`
  line `be made by the other successor State, the said property or benefits shall be allocated in such manner`
  line `between the two States, or the other State shall make to the State subject to the liability such contribution`
  line `in respect thereof, as the Central Government may, after consultation with the two State Governments, by`
  line `order determine.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (26758)
  sectionNo (57)
  orderNo 57
  title `Certain expenditure to be charged on Consolidated Fund.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26758&sectionno=57&orderno=57&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_57_content:
  string
  line `All sums payable either by the`
  line `State of Madhya Pradesh or by the State of Chhattisgarh to the other States or by the Central Government`
  line `to either of those States, by virtue of the provisions of this Act, shall be charged on the Consolidated Fund`
  line `of the State by which such sums are payable or, as the case may be, the Consolidated Fund of India.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (26759)
  sectionNo (58)
  orderNo 58
  title `Provisions as to Madhya Pradesh State Electricity Board, State Road Transport Corporation and State Warehousing Corporation, etc.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26759&sectionno=58&orderno=58&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_58_content:
  string
  line `(1) The following bodies corporate constituted for the existing`
  line `State of Madhya Pradesh, namely:—`
  line
  line `(a) the State Electricity Board constituted under the Electricity Supply Act, 1948 (54 of 1948);`
  line
  line `(b) the State Road Transport Corporation established under the Road Transport Corporations Act,`
  line `1950 (64 of 1950); and`
  line
  line `(c) the State Warehousing Corporation established under the Warehousing Corporations Act,`
  line `1962 (58 of 1962),`
  line
  line `shall, on and from the appointed day, continue to function in those areas in respect of which they were`
  line `functioning immediately before that day, subject to the provisions of this section and arrangements for the`
  line `functioning of such body corporates as may be mutually agreed upon between the successor States failing`
  line `which to such directions as may, from time to time, be issued by the Central Government.`
  line
  line `(2) Any directions issued by the Central Government under sub-section (1) in respect of the Board or`
  line `the Corporation shall include a direction that the Act under which the Board or the Corporation was`
  line `constituted shall, in its application to that Board or Corporation, have effect subject to such exceptions`
  line `and modifications as the Central Government thinks fit.`
  line
  line `(3) The Board or the Corporation referred to in sub-section (1) shall cease to function as from, and`
  line `shall be deemed to be dissolved on such date as the Central Government may, by order, appoint; and upon`
  line `such dissolution, its assets, rights and liabilities shall be apportioned between the successor States of`
  line `Madhya Pradesh and Chhattisgarh in such manner as may be agreed upon between them within one year of the dissolution of the Board or the Corporation, as the case may be, or if no agreement is reached, in`
  line `such manner as the Central Government may, by order, determine:`
  line
  line `Provided that any liabilities of the said Board relating to the unpaid dues of the coal supplied to the`
  line `Board by any public sector coal company shall be provisionally apportioned between the successor`
  line `organisations constituted respectively in the successor States of the existing State of Madhya Pradesh or`
  line `after the date appointed for the dissolution of the Board under this sub-section in such manner as may be`
  line `agreed upon between the Governments of the successor States within one month of such dissolution or if`
  line `no agreement is reached, in such manner as the Central Government may, by order, determine subject to`
  line `reconciliation and finalisation of the liabilities which shall be completed within three months from the`
  line `date of such dissolution by the mutual agreement between the successor States or failing such agreement`
  line `by the direction of the Central Government:`
  line
  line `Provided further that an interest at the rate of two per cent. higher than the Cash Credit interest shall`
  line `be paid on outstanding unpaid dues of the coal supplied to the Board by the public sector coal company`
  line `till the liquidation of such dues by the concerned successor organisations constituted in the successor`
  line `States on or after the date appointed for the dissolution of the Board under this sub-section.`
  line
  line `(4) Nothing in the preceding provisions of this section shall be construed as preventing the`
  line `Government of the State of Madhya Pradesh or, as the case may be, the Government of the State of`
  line `Chhattisgarh from constituting, at any time on or after the appointed day, a State Electricity Board or a`
  line `State Road Transport Corporation or a State Warehousing Corporation for the State under the provisions`
  line `of the Act relating to such Board or Corporation; and if such a Board or Corporation is so constituted in`
  line `either of the States before the dissolution of the Board or the Corporation referred to in sub-section (1),—`
  line
  line `(a) provision may be made by order of the Central Government enabling the new Board or the`
  line `new Corporation to take over form the existing Board or Corporation all or any of its undertakings,`
  line `assets, rights and liabilities in that State, and`
  line
  line `(b) upon the dissolution of existing Board or Corporation,—`
  line
  line `(i) any assets, rights and liabilities which would otherwise have passed to that State by or`
  line `under the provisions of sub-section (3) shall pass to the new Board or the new Corporation`
  line `instead of to that State;`
  line
  line `(ii) any employee who would otherwise have been transferred to or re-employed by that State`
  line `under sub-section (3), read with clause (i) of sub-section (5), shall be transferred to or`
  line `re-employed by the new Board or the new Corporation instead of to or by that State.`
  line
  line `(5) An agreement entered into between the successor States under sub-section (3) and an order made`
  line `by the Central Government under that sub-section or under clause (a) of sub-section (4) may provide for`
  line `the transfer or re-employment of any employee of the Board or the Corporation referred to in sub-section`
  line `(1),—`
  line
  line `(i) to or by the successor States, in the case of an agreement under sub-section (4) or an order`
  line `made under that sub-section;`
  line
  line `(ii) to or by the new Board or the new Corporation constituted, under sub-section (4), in the case`
  line `of an order made under clause (a) of that sub-section,`
  line
  line `and subject to the provisions of section 64, also for the terms and conditions of service applicable to such`
  line `employees after such transfer or re-employment.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (26760)
  sectionNo (59)
  orderNo 59
  title `Provisions as to Madhya Pradesh State Financial Corporation.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26760&sectionno=59&orderno=59&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_59_content:
  string
  line `(1) The Madhya Pradesh`
  line `State Financial Corporation established under the State Financial Corporation Act, 1951 (63 of 1951)`
  line `shall, on and from the appointed day, continue to function in those areas in respect of which it was`
  line `functioning immediately before that day, subject to the provisions of this section and to such directions as`
  line `may from time to time, be issued by the Central Government after consultation with the Governments of`
  line `the successor States.`
  line
  line `(2) Any directions issued by the Central Government under sub-section (1) in respect of the`
  line `Corporation may include a direction that the said Act, in its application to the Corporation, shall have`
  line `effect subject to such exceptions and modifications as may be specified in the direction.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1) or sub-section (2), the Board of Directors`
  line `of the Corporation may, with the previous approval of the Central Government and shall, if so required by the Central Government, convene at any time after the appointed day a meeting for the consideration of a`
  line `scheme for the reconstitution or reorganisation or dissolution, as the case may be, of the Corporation,`
  line `including proposals regarding the formation of new Corporations, and the transfer thereto of the assets,`
  line `rights and liabilities of the existing Corporation, and if such a scheme is approved at the general meeting`
  line `by a resolution passed by a majority of the shareholders present and voting, the scheme shall be submitted`
  line `to the Central Government for its sanction.`
  line
  line `(4) If the scheme is sanctioned by the Central Government either without modifications or with`
  line `modifications which are approved at a general meeting, the Central Government shall certify the scheme,`
  line `and upon such certification, the scheme shall, notwithstanding anything to the contrary contained in any`
  line `law for the time being in force, be binding on the corporations affected by the scheme as well as the`
  line `shareholders and creditors thereof.`
  line
  line `(5) If the scheme is not so approved or sanctioned, the Central Government may refer the scheme to`
  line `such Judge of the High Court of Madhya Pradesh as may be nominated in this behalf by the Chief Justice`
  line `thereof, and the decision of the Judge in regard to the scheme shall be final and shall be binding on the`
  line `corporations affected by the scheme as well as the shareholders and creditors thereof.`
  line
  line `(6) Nothing in the preceding provisions of this section shall be construed as preventing the`
  line `Government of the State of Madhya Pradesh and Chhattisgarh from constituting, at any time on or after`
  line `the appointed day, a State Financial Corporation for that State under the State Financial Corporation Act,`
  line `1951 (63 of 1951).`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (26761)
  sectionNo (60)
  orderNo 60
  title `Provisions as to certain companies.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26761&sectionno=60&orderno=60&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_60_content:
  string
  line `(1) Notwithstanding anything contained in the foregoing`
  line `provisions of this Part, each of the companies specified in the Seventh Schedule to this Act shall, on and`
  line `from the appointed day and until otherwise provided for in any law, or in any agreement among the`
  line `successor States, or in any direction issued by the Central Government, continue to function in the areas`
  line `in which it was functioning immediately before that day; and the Central Government may, after`
  line `consultation with the Governments of the successor States, from time to time issue such directions in`
  line `relation to such functioning as it may deem fit, notwithstanding anything to the contrary contained in the`
  line `Companies Act, 1956 (1 of 1956) or in any other law.`
  line
  line `(2) Any directions issued under sub-section (1), in respect of a company referred to in that subsection,`
  line `may include directions—`
  line
  line `(a) regarding the division of the interests and shares of existing State of Madhya Pradesh in the`
  line `company among the successor States;`
  line
  line `(b) requiring the reconstitution of the Board of Directors of the company so as to give adequate`
  line `representation to both the successor States.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (26762)
  sectionNo (61)
  orderNo 61
  title `Functioning of organisation, registered society or trust incorporated on behest of State Government.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26762&sectionno=61&orderno=61&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_61_content:
  string
  line `(1) Notwithstanding anything contained in the foregoing provisions of this Part or any`
  line `other law for the time being in force, any organisation, registered society or trust, incorporated at the`
  line `behest of the State Government, shall, on and from the appointed day, and until otherwise provided for in`
  line `any law for the time being in force, or in any agreement between the successor States, or in any direction`
  line `issued by the Central Government in consultation with the successor States, continue to function in the`
  line `areas in which it was functioning immediately before that day, and the Central Government may, after`
  line `consulting the Governments of successor States, issue directions in relation to such functioning.`
  line
  line `(2) Any directions issued under sub-section (1) may include directions regarding the—`
  line
  line `(i) reconstitution of the Board of Directors of the organisation, society or trust by whatever name`
  line `it may be called; or`
  line
  line `(ii) appointment of the Chief Executive by whatever name it may be called; or`
  line
  line `(iii) regulations or bye-laws, by whatever name they may be called; or`
  line
  line `(iv) assessment and apportionment of financial support, if any, provided by the existing State of`
  line `Madhya Pradesh for meeting fixed charges.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (26763)
  sectionNo (62)
  orderNo 62
  title `General provisions as to statutory corporations.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26763&sectionno=62&orderno=62&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_62_content:
  string
  line `(1) Save as otherwise expressly provided by`
  line `the foregoing provisions of this Part, where any body corporate constituted under a Central Act, State Act`
  line `or Provincia1 Act for the existing State of Madhya Pradesh or any part thereof has, by virtue of the`
  line `provisions of Part II of this Act, become an inter-State body corporate, then, the body corporate shall, on`
  line `and from the appointed day, continue to function and operate in those areas in respect of which it was functioning and operating immediately before that day, subject to such directions as may from time to`
  line `time be issued by the Central Government, after consultation with the Governments of the successor`
  line `States, until other provision is made by law in respect of the said body corporate.`
  line
  line `(2) Any directions issued by the Central Government under sub-section (1) in respect of any such`
  line `body corporate shall include a direction that any law by which the said body corporate is governed shall,`
  line `in its application to that body corporate, have effect subject to such exceptions and modifications as may`
  line `be specified in the direction.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (26764)
  sectionNo (63)
  orderNo 63
  title `Temporary provisions as to continuance of certain existing road transport permits.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26764&sectionno=63&orderno=63&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_63_content:
  string
  line `Notwithstanding anything contained in section 88 of the Motor Vehicles Act, 1988 (59 of 1988), a permit`
  line `granted by the State Transport Authority of the existing State of Madhya Pradesh or any Regional`
  line `Transport Authority in that State shall, if such permit was, immediately before the appointed day, valid`
  line `and effective in any area in the transferred territory, be deemed to continue to be valid and effective in`
  line `that area after that day subject to the provisions of that Act as for the time being in force in that area; and`
  line `it shall not be necessary for any such permit to be countersigned by the State Transport Authority of`
  line `Chhattisgarh or any Regional Transport Authority therein for the purpose of validating it for use in such`
  line `area:`
  line
  line `Provided that the Central Government may, after consultation with the successor State Government or`
  line `Governments concerned add to, amend or vary the conditions attached to the permit by the Authority by`
  line `which the permit was granted.`
  line
  line `(2) No tolls, entrance fees or other charges of a like nature shall be levied after the appointed day in`
  line `respect any transport vehicle for its operations in any of the successor States under any such permit, if`
  line `such vehicle was, immediately before that day, exempt from the payment of any such toll, entrance fees`
  line `or other charges for its operations in the transferred territory:`
  line
  line `Provided that the Central Government may, after consultation with the State Government or`
  line `Governments concerned, authorise the levy of any such toll, entrance fees or other charges, as the case`
  line `may be.`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (26765)
  sectionNo (64)
  orderNo 64
  title `Special provisions relating to retrenchment compensation in certain cases.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26765&sectionno=64&orderno=64&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_64_content:
  string
  line `Where on`
  line `account of the reorganisation of the existing State of Madhya Pradesh under this Act, any body corporate`
  line `constituted under a Central Act, State Act or Provincial Act, any co-operative society registered under any`
  line `law relating to co-operative societies or any commercial or industrial undertaking of that State is`
  line `reconstituted or reorganised in any manner whatsoever or is amalgamated with any other body corporate,`
  line `co-operative society or undertaking, or is dissolved, and in consequence of such reconstitution,`
  line `reorganisation, amalgamation or dissolution, any workman employed by such body corporate or in any`
  line `such co-operative society or undertaking, is transferred to, or re-employed by any other body corporate, or`
  line `in any other co-operative society or undertaking, then notwithstanding anything contained in section 25F,`
  line `section 25FF or section 25FFF of the Industrial Disputes Act, 1947 (14 of 1947), such transfer or`
  line `re-employment shall not entitle him to any compensation under that section:`
  line
  line `Provided that—`
  line
  line `(a) the terms and conditions of service applicable to the workman after such transfer or`
  line `re-employment are not less favourable to the workman than those applicable to him immediately`
  line `before the transfer or re-employment;`
  line
  line `(b) the employer in relation to the body corporate, the co-operative society or the undertaking`
  line `where the workman is transferred or re-employed is, by agreement or otherwise, legally liable to pay`
  line `to the workman, in the event of his retrenchment, compensation under section 25F, section 25FF or`
  line `section 25FFF of the Industrial Disputes Act, 1947 (14 of 1947) on the basis that his service has been`
  line `continuous and has not been interrupted by the transfer or re-employment.`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (26766)
  sectionNo (65)
  orderNo 65
  title `Special provisions as to income-tax.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26766&sectionno=65&orderno=65&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_65_content:
  string
  line `Where the assets, rights and liabilities of any body`
  line `corporate carrying on any business are, under the provisions of this Part, transferred to any other bodies`
  line `corporate which after the transfer carry on the same business, the losses or profits or gains sustained by`
  line `the body corporate first mentioned which, but for such transfer, would have been allowed to be carried`
  line `forward and set off in accordance with the provisions of Chapter VI of the Income-tax Act, 1961 (43 of`
  line `1961), shall be apportioned amongst the transferee bodies corporate in accordance with the rules to be`
  line `made by the Central Government in this behalf and, upon such apportionment, the share of loss allotted to`
  line `each transferee body corporate shall be dealt with in accordance with the provisions of Chapter VI of the said Act, as if the transferee body corporate had itself sustained such loss in a business carried on by it in`
  line `the years in which these losses were sustained.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (26767)
  sectionNo (66)
  orderNo 66
  title `Continuance of facilities in certain State institutions.`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26767&sectionno=66&orderno=66&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_66_content:
  string
  line `(1) The Government of State of`
  line `Madhya Pradesh or Chhattisgarh, as the case may be, shall, in respect of the institutions specified in the`
  line `Eighth Schedule to this Act, located in that State, continue to provide facilities to the people of the other`
  line `State which shall not, in any respect, be less favourable to such people than what were being provided to`
  line `them before the appointed day, for such period and upon such terms and conditions as may be agreed`
  line `upon between the two State Governments within a period of one year from the appointed day or if no`
  line `agreement is reached within the said period of one year, then, as may be fixed by order of the Central`
  line Government.
  line
  line `(2) The Central Government may, at any time within a period of one year from the appointed day, by`
  line `notification in the Official Gazette, specify in the Eighth Schedule any other institution existing on the`
  line `appointed day in the States of Madhya Pradesh and Chhattisgarh and on the issue of such notification, the`
  line `Schedule shall be deemed to be amended by the inclusion of the said institution therein.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (26768)
  sectionNo (67)
  orderNo 67
  title `Provisions relating to All-India Services.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26768&sectionno=67&orderno=67&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_67_content:
  string
  line `(1) In this section, the expression “State cadre”,—`
  line
  line `(a) in relation to the Indian Administrative Service, has the meaning assigned to it in the Indian`
  line `Administrative Service (Cadre) Rules, 1954;`
  line
  line `(b) in relation to the Indian Police Service, has the meaning assigned to it in the Indian Police`
  line `Service (Cadre) Rules, 1954;`
  line
  line `(c) in relation to the Indian Forest Service, has the meaning assigned to it in the Indian Forest`
  line `Service (Cadre) Rules, 1966.`
  line
  line `(2) In place of the cadres of the Indian Administrative Service, Indian Police Service and Indian`
  line `Forest Service for the existing State of Madhya Pradesh, there shall, on and from the appointed day, be`
  line `two separate cadres, one for the State of Madhya Pradesh and the other for the State of Chhattisgarh in`
  line `respect of each of these services.`
  line
  line `(3) The initial strength and composition of the State cadres referred to in sub-section (2) shall be such`
  line `as the Central Government may, by order, determine before the appointed day.`
  line
  line `(4) The members of each of the said service borne on the Madhya Pradesh cadre thereof immediately`
  line `before the appointed day shall be allocated to the State cadres of the same service constituted under`
  line `sub-section (2) in such manner and with effect from such date or dates as the Central Government may,`
  line `by order, specify.`
  line
  line `(5) Nothing in this section shall be deemed to affect the operation, on or after the appointed day, of`
  line `the All-India Service Act, 1951 (61 of 1951) or the rules made thereunder.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (26769)
  sectionNo (68)
  orderNo 68
  title `Provisions relating to services in Madhya Pradesh and Chhattisgarh.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26769&sectionno=68&orderno=68&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_68_content:
  string
  line `(1) Every person who`
  line `immediately before the appointed day is serving in connection with the affairs of the existing State of`
  line `Madhya Pradesh shall, on and from that day provisionally continue to serve in connection with the affairs`
  line `of the State of Madhya Pradesh unless he is required, by general or special order of the Central`
  line `Government to serve provisionally in connection with the affairs of the State of Chhattisgarh:`
  line
  line `Provided that no direction shall be issued under this section after the expiry of a period of one year`
  line `from the appointed day.`
  line
  line `(2) As soon as may be after the appointed day, the Central Government shall, by general or special`
  line `order, determine the successor State to which every person referred to in sub-section (1) shall be finally`
  line `allotted for service and the date with effect from which such allotment shall take effect or be deemed to`
  line `have taken effect.`
  line
  line `(3) Every person who is finally allotted under the provisions of sub-section (2) to a successor State`
  line `shall, if he is not already serving therein be made available for serving in the successor State from such`
  line `date as may be agreed upon between the Governments concerned or in default of such agreement, as may`
  line `be determined by the Central Government.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (26770)
  sectionNo (69)
  orderNo 69
  title `Provisions relating to other services.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26770&sectionno=69&orderno=69&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_69_content:
  string
  line `(1) Nothing in this section or section 68 shall be deemed`
  line `to affect on or after the appointed day the operation of the provisions of Chapter I of Part XIV of the Constitution in relation to determination of the conditions of service of persons serving in connection with`
  line `the affairs of the Union or any State:`
  line
  line `Provided that the conditions of service applicable immediately before the appointed day in the case of`
  line `any person deemed to have been allocated to the State of Madhya Pradesh or to the State of Chhattisgarh`
  line `under section 68 shall not be varied to his disadvantage except with the previous approval of the Central`
  line Government.
  line
  line `(2) All services prior to the appointed day rendered by a person—`
  line
  line `(a) if he is deemed to have been allocated to any State under section 68, shall be deemed to have`
  line `been rendered in connection with the affairs of that State;`
  line
  line `(b) if he is deemed to have been allocated to the Union in connection with the administration of`
  line `the Chhattisgarh shall be deemed to have been rendered in connection with the affairs of the Union,`
  line
  line `for the purposes of the rules regulating his conditions of service.`
  line
  line `(3) The provisions of section 68, shall not apply in relation to members of any All-India Service.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (26771)
  sectionNo (70)
  orderNo 70
  title `Provisions as to continuance of officers in same post.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26771&sectionno=70&orderno=70&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_70_content:
  string
  line `(1) Every person who, immediately`
  line `before the appointed day is holding or discharging duties of any post or office in connection with the`
  line `affairs of the existing State of Madhya Pradesh in any area which on that day falls within any of the`
  line `successor States shall continue to hold the same post or office in that successor State, and shall be`
  line `deemed, on and from that day, to have been duly appointed to the post or office by the Government of, or`
  line `any other appropriate authority in, that successor State:`
  line
  line `Provided that nothing in this section shall be deemed to prevent a competent authority, on and from`
  line `the appointed day, from passing in relation to such person any order affecting the continuance in such`
  line `post or office.`
obj_root_law_sections_70_footnotes:
  string
  line
obj_root_law_sections_71:
  sectionId (26772)
  sectionNo (71)
  orderNo 71
  title `Advisory Committees.`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26772&sectionno=71&orderno=71&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_71_content:
  string
  line `The Central Government may, by order establish one or more Advisory`
  line `Committees for the purpose of assisting it in regard to—`
  line
  line `(a) the discharge of any of its functions under this Part; and`
  line
  line `(b) the ensuring of fair and equitable treatment to all persons affected by the provisions of this`
  line `Part and the proper consideration of any representations made by such persons.`
obj_root_law_sections_71_footnotes:
  string
  line
obj_root_law_sections_72:
  sectionId (26773)
  sectionNo (72)
  orderNo 72
  title `Power of Central Government to give directions.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26773&sectionno=72&orderno=72&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_72_content:
  string
  line `The Central Government may, give such`
  line `directions to the State Government of Madhya Pradesh and the State Government of Chhattisgarh as may`
  line `appear to it to be necessary for the purpose of giving effect to the foregoing provisions of this Part and the`
  line `State Governments shall comply with such directions.`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (26774)
  sectionNo (73)
  orderNo 73
  title `Provisions as to State Public Service Commission.`
  content obj_root_law_sections_73_content
  footnotes obj_root_law_sections_73_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26774&sectionno=73&orderno=73&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_73_content:
  string
  line `(1) The Public Service Commission for`
  line `the existing State of Madhya Pradesh shall, on and from the appointed day, be the Public Service`
  line `Commission for the State of Madhya Pradesh.`
  line
  line `(2) The persons holding office immediately before the appointed day as Chairman or other member of`
  line `the Public Service Commission for the existing State of Madhya Pradesh shall, as from the appointed day,`
  line `be the Chairman or, as the case may be, the other member of the Public Service Commission for the State`
  line `of Madhya Pradesh.`
  line
  line `(3) Every person who becomes Chairman or other member of the Public Service Commission for the`
  line `State of Madhya Pradesh on the appointed day under sub-section (2), shall—`
  line
  line `(a) be entitled to receive from the Government of the State of Madhya Pradesh conditions of`
  line `service not less favourable than those to which he was entitled under the provisions applicable to him;`
  line
  line `(b) subject to the proviso to clause (2) of article 316, hold office or continue to hold office until`
  line `the expiration of his term of office as determined under the provisions applicable to him immediately`
  line `before the appointed day.`
  line
  line `(4) The report of the Madhya Pradesh Public Service Commission as to the work done by the`
  line `Commission in respect of any period prior to the appointed day shall be presented under clause (2) of`
  line `article 323 to the Governors of the States of Madhya Pradesh and Chhattisgarh, and the Governor of the`
  line `State of Madhya Pradesh shall, on receipt of such report, cause a copy thereof together with a`
  line `memorandum explaining as far as possible, as respects the cases, if any, where the advice of the Commission was not accepted, the reasons for such non-acceptance to be laid before the Legislature of`
  line `the State of Madhya Pradesh and it shall not be necessary to cause such report or any such memorandum`
  line `to be laid before the Legislative Assembly of the State of Chhattisgarh.`
obj_root_law_sections_73_footnotes:
  string
  line
obj_root_law_sections_74:
  sectionId (26775)
  sectionNo (74)
  orderNo 74
  title `Jurisdiction of the Commissions, authorities and tribunals.`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26775&sectionno=74&orderno=74&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_74_content:
  string
  line `(1) Notwithstanding anything`
  line `contained in any law for the time being in force, every Commission, Authority, Tribunal, University,`
  line `Board or any other body constituted under a Central Act, State Act or Provincial Act and having`
  line `jurisdiction over the existing State of Madhya Pradesh shall on and from the appointed day continue to`
  line `function in the successor State of Madhya Pradesh and also exercise jurisdiction as existed before the`
  line `appointed day over the State of Chhattisgarh for a maximum period of two years from the appointed day`
  line `or till such period as is decided by mutual agreement between the successor States—`
  line
  line `(i) to continue such body as a joint body for the successor States; or`
  line
  line `(ii) to abolish it, on the expiry of that period, for either of the successor States; or`
  line
  line `(iii) to constitute a separate Commission, Authority, Tribunal, University, Board or any other`
  line `body, as the case may be, for the State of Chhattisgarh,`
  line
  line `whichever is earlier.`
  line
  line `(2) No suit or other legal proceeding shall be instituted, in case such body is abolished under`
  line `clause (ii) of sub-section (1), by any employee of such body against the termination of his appointment or`
  line `for the enforcement of any service conditions or for securing absorption in alternative public employment`
  line `against the Central Government or any of the successor States.`
  line
  line `(3) Notwithstanding anything contained in any law for the time being in force or in any judgment,`
  line `decree or order of any court or Tribunal or contract or agreement, any Chairman or member of any body`
  line `abolished under clause (ii) of sub-section (1) shall not be entitled to any compensation for the unexpired`
  line `period of his tenure.`
  line
  line `(4) Notwithstanding anything contained in this section or any law for the time being in force, the`
  line `Central Government, shall, in accordance with any mutual agreement between the successor States or if`
  line `there is no such agreement, after consultation with the Governments of the successor States, issue`
  line `directions for the resolution of any matter relating to any body referred to in sub-section (1) and falling`
  line `within the jurisdiction of any of the successor States within any period referred to in sub-section (1).`
obj_root_law_sections_74_footnotes:
  string
  line
obj_root_law_sections_75:
  sectionId (26776)
  sectionNo (75)
  orderNo 75
  title `Management of power and water supply in certain cases.`
  content obj_root_law_sections_75_content
  footnotes obj_root_law_sections_75_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26776&sectionno=75&orderno=75&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_75_content:
  string
  line `(1) Where it appears to the Central`
  line `Government that the arrangement in regard to the generation or supply of electric power or the supply of`
  line `water for any area or in regard to the execution of any project for such generation or supply has been or is`
  line `likely to be, modified to the disadvantage of that area by reason of the formation of successor States, the`
  line `Central Government may, after consultation with the successor States, give such directions to the State`
  line `Government or other authority responsible for the maintenance, so far as practicable, of such arrangement`
  line `before the appointed day.`
  line
  line `(2) The Central Government shall within a period of three months from the appointed day, by order,`
  line `also determine the share of the successor States in the entitlement of the existing State of Madhya Pradesh`
  line `to power produced by the Central Government undertakings having due regard to the likely disadvantage`
  line `which might have been occasioned to any successor State as a result of modified arrangements for`
  line `generation and supply of electric power.`
obj_root_law_sections_75_footnotes:
  string
  line
obj_root_law_sections_76:
  sectionId (26777)
  sectionNo (76)
  orderNo 76
  title `Inter-State River Water Board.`
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26777&sectionno=76&orderno=76&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_76_content:
  string
  line `(1) The Central Government may, as and when it considers`
  line `necessary, constitute an inter-State River Water Board, after consultation with the successor States, for`
  line `the planning and development of inter-State rivers and river valleys.`
  line
  line `(2) The Inter-State River Board constituted under sub-section (1) may be entrusted with the following`
  line `functions, namely:—`
  line
  line `(a) to examine the requirement of funds for various projects according to the programmes laid`
  line `down for such projects and to advise regarding the apportionment of the expenditure to the State`
  line `participating to implement such programmes keeping in view the agreement on the sharing of costs;`
  line
  line `(b) to decide the sharing and withdrawal of water from the reservoirs for irrigation, power and`
  line `other purposes with a view to securing better use of available water;`
  line
  line `(c) to determine the programmes of re-settlement of displaced persons as a result of the projects;`
  line and
  line
  line `(d) to approve and supervise the planning, survey and investigation, preparation of project reports`
  line `and construction of joint inter-State Projects and their subsequent operation and maintenance.`
obj_root_law_sections_76_footnotes:
  string
  line
obj_root_law_sections_77:
  sectionId (26778)
  sectionNo (77)
  orderNo 77
  title `Amendment of Act 37 of 1956.`
  content obj_root_law_sections_77_content
  footnotes obj_root_law_sections_77_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26778&sectionno=77&orderno=77&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_77_content:
  string
  line `On and from the appointed day, in section 15 of the States`
  line `Reorganisation Act, 1956, in clause (b), for the words “Uttar Pradesh and Madhya Pradesh”, the words “Uttar Pradesh, Madhya Pradesh and Chhattisgarh” shall be substituted.`
obj_root_law_sections_77_footnotes:
  string
  line
obj_root_law_sections_78:
  sectionId (26779)
  sectionNo (78)
  orderNo 78
  title `Territorial extent of laws.`
  content obj_root_law_sections_78_content
  footnotes obj_root_law_sections_78_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26779&sectionno=78&orderno=78&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_78_content:
  string
  line `The provisions of Part II of this Act shall not be deemed to have`
  line `effected any change in the territories to which any law in force immediately before the appointed day`
  line `extends or applies, and territorial references in any such law to the State of Madhya Pradesh shall, until`
  line `otherwise provided by a competent Legislature or other competent authority be constituted as meaning the`
  line `territories within the existing State of Madhya Pradesh before the appointed day.`
obj_root_law_sections_78_footnotes:
  string
  line
obj_root_law_sections_79:
  sectionId (26780)
  sectionNo (79)
  orderNo 79
  title `Power to adapt laws.`
  content obj_root_law_sections_79_content
  footnotes obj_root_law_sections_79_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26780&sectionno=79&orderno=79&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_79_content:
  string
  line `For the purpose of facilitating the application in relation to the State of`
  line `Madhya Pradesh or Chhattisgarh of any law made before the appointed day, the appropriate Government`
  line `may, before the expiration of two years from that day, by order, make such adaptations and modifications`
  line `of the law, whether by way of repeal or amendment, as may be necessary or expedient, and thereupon`
  line `every such law shall have effect subject to the adaptations and modifications so made until altered,`
  line `repealed or amended by a competent legislature or other competent authority.`
  line
  line `Explanation.—In this Section, the expression appropriate Government means as respects any law`
  line `relating to a matter enumerated in the Union List, the Central Government, and as respects any other law`
  line `in its application to a State, the State Government.`
obj_root_law_sections_79_footnotes:
  string
  line
obj_root_law_sections_80:
  sectionId (26781)
  sectionNo (80)
  orderNo 80
  title `Power to construe laws.`
  content obj_root_law_sections_80_content
  footnotes obj_root_law_sections_80_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26781&sectionno=80&orderno=80&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_80_content:
  string
  line `Notwithstanding that no provision or insufficient provision has been`
  line `made under section 79 for the adaptation of a law made before the appointed day, any court, tribunal or`
  line `authority, required or empowered to enforce such law may, for the purpose of facilitating its application`
  line `in relation to the State of Madhya Pradesh or Chhattisgarh, construe the law in such manner, without`
  line `affecting the substance, as may be necessary or proper in regard to the matter before the court, tribunal or`
  line authority.
obj_root_law_sections_80_footnotes:
  string
  line
obj_root_law_sections_81:
  sectionId (26782)
  sectionNo (81)
  orderNo 81
  title `Power to name authorities, etc., for exercising statutory functions.`
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26782&sectionno=81&orderno=81&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_81_content:
  string
  line `The Government of the`
  line `State of Chhattisgarh, as respects the transferred territory may, by notification in the Officia1 Gazette,`
  line `specify the authority, officer or person who, on or after the appointed day, shall be competent to exercise`
  line `such functions exercisable under any law in force on that day as may be mentioned in that notification and`
  line `such law shall have effect accordingly.`
obj_root_law_sections_81_footnotes:
  string
  line
obj_root_law_sections_82:
  sectionId (26783)
  sectionNo (82)
  orderNo 82
  title `Legal proceedings.`
  content obj_root_law_sections_82_content
  footnotes obj_root_law_sections_82_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00037_200028_1517807323263&sectionId=26783&sectionno=82&orderno=82&orgactid=AC_CEN_5_5_00037_200028_1517807323263
obj_root_law_sections_82_content:
  string
  line `Where immediately before the appointed day, the existing State of Madhya`
  line `Pradesh is a party to any legal proceedings with respect to any property, rights or liabilities subject to`
  line `apportionment between the States of Madhya Pradesh and Chhattisgarh under this Act, the State of`
  line `Madhya Pradesh or Chhattisgarh which succeeds to, or acquires a share in, that property or those rights or`
  line `liabilities by virtue of any provision of this Act shall be deemed to be substituted for the existing State of`
  line `Madhya Pradesh or added as a party to those proceedings, and the proceedings may continue accordingly.`
obj_root_law_sections_82_footnotes:
  string
