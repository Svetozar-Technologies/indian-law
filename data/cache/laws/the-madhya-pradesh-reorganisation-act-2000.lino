obj_root_law_translations_hi_sections_32_content:
  string
  line 28
  line `30. कोली, कोरी`
  line `31. खांगर, कनेरा, िमधा ᭅ`
  line `32. कुचबंिधया`
  line `33. महार, मेहरा, मेहर`
  line `34. मांग, मांग गरौड़ी, मांग गा ᱨ ड़ी, दंखनी मांग, मांग महाशी, मदारी, गा ᱨ ड़ी, राधे मांग`
  line `35. मेघवाल`
  line `36. मोिघया`
  line `37. मुसखान`
  line `38. नट, कालबेिलया, सपेरा, नव ᳰ दगार, कुबुतार`
  line `39. पासी`
  line `40. ᱨ᭔ झा र`
  line `41. सांसी, सांिसया`
  line `42. िसलावट`
  line `43. झमराल। ”।`
