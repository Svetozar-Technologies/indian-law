obj_root_law_sections_1:
  sectionId (17020)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17020&sectionno=1&orderno=1&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_1_content:
  string
  line `^1[(1) This Act may be called the Coal Mines Provident Fund and`
  line `Miscellaneous Provisions Act 1948].`
  line
  line `^2[(2) It extends to the whole of India ^3* * *.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 99 of 1976, s. 3, for sub-section (1) (w.e.f. 1-8-1976).`
  line
  line `2. Subs. by the A.O. 1950, for sub-section (2).`
  line
  line `3. The words "except the State of Jammu and Kashmir" omitted by Act 51 of 1970, s. 2 and the Schedule (w.e.f. 1-9-1971).`
obj_root_law_sections_2:
  sectionId (17021)
  sectionNo (2)
  orderNo 2
  title Interpretation.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17021&sectionno=2&orderno=2&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context,--`
  line
  line `(a) "bonus" means any sum of money payable to an ^1[employee] under the Coal Mines Bonus`
  line `Scheme framed under this Act;`
  line
  line `^2[(aa) "coal" includes lignite;]`
  line
  line `^3[(b) "coal mine" means any excavation where any operation for the purpose of searching for or`
  line `obtaining coal has been or is being carried on, and includes--`
  line
  line `(i) all borings and bore holes;`
  line
  line `(ii) all shafts, in or adjacent to and belonging to a coal mine, whether in the course of being`
  line `sunk or not;`
  line
  line `(iii) all levels and inclined planes in the course of being driven;`
  line
  line `(iv) any open cast working or quarry, that is to say, an excavation where any operation for the`
  line `purpose of searching for or obtaining coal has been or is being carried on, not being a shaft or an`
  line `excavation which extends below superjacent ground;`
  line
  line `(v) all conveyors or aerial rope-ways provided for the bringing into or removal from a coal`
  line `mine of coal or other articles or for the removal of refuse therefrom;`
  line
  line `(vi) all adits, levels, planes, machinery, works, railways, tramways and sidings, in or adjacent`
  line `to and belonging to a coal mine;`
  line
  line `(vii) all workshops situated within the precincts of a coal mine and under the same`
  line `management and used for purposes connected with that coal mine or a number of coal mines`
  line `under the same management;`
  line
  line `(viii) any office of a coal mine;`
  line
  line `(ix) all power stations for supplying electricity for the purpose of working the coal mine or a`
  line `number of coal mines under the same management;`
  line
  line `(x) any premises for the time being used for depositing refuse from a coal mine, or in which`
  line `any operation in connection with such refuse is being carried on, being premises exclusively`
  line `occupied by the employer of the coal mine;`
  line
  line `(xi) all hospitals and canteens maintained for the benefit of the employees of a coal mine or a`
  line `number of coal mines under the same management;`
  line
  line `(xii) any coke oven or plant;`
  line
  line `(xiii) any premises in or adjacent to and belonging to a coal mine, on which any plant or other`
  line `machinery connected with a coal mine is situated or on which any process ancillary to the work`
  line `of a coal mine is being carried on;]`
  line
  line `(c) "contribution" means the contribution payable in respect of a member under the Coal Mines`
  line `Provident Fund Scheme framed under this Act of ^4[or the contribution payable in respect of an`
  line `employee to whom the Insurance Scheme applies];`
  line
  line `^5[(d) "employee" means any person who is employed for wages in any kind of work, manual or`
  line `otherwise, in or in connection with a coal mine, and who gets his wages directly or indirectly from the`
  line `employer, and includes--`
  line
  line `(1) any person employed by or through a contractor in or in connection with a coal mine, and`
  line
  line `(2) for the purposes of the Coal Mines Provident Fund Scheme, also`
  line
  line `(i) any other person who is employed as a sanitary worker, mali, teacher or domestic`
  line `servant in or in connection with a coal mine and who receives wages directly from the`
  line `employer, and`
  line
  line `(ii) any apprentice or trainee who receives stipend or other remuneration from the`
  line employer.]
  line
  line `^6[(e) "employer", when used in relation to a coal mine, means any person who is the immediate`
  line `proprietor or lessee or occupier of the coal mine or of any part thereof and in the case of a coal mine`
  line `the business whereof is being carried on by a liquidator or receiver, such liquidator or receiver and in`
  line `the case of a coal mine owned by a company the business whereof is being carried on by a managing`
  line `agent, such managing agent; but does not include a person who merely receives a royalty, rent or fine`
  line `from the coal mine, or is merely the proprietor of the coal mine, subject to any lease, grant or licence`
  line `for the working thereof, or is merely the owner of the soil and not interested in the coal of the coal`
  line `mine; but any contractor for the working of a coal mine or any part thereof shall be subject to this Act`
  line `in like manner as if he were an employer, but not so as to exempt the employer from any liability;]`
  line
  line `^7* * * * *`
  line
  line `(f) "Fund" means the provident fund established under the Coal Mines Provident Fund`
  line `Scheme; ^8* * *`
  line
  line `^4[(fa) "Insurance Fund" means the Deposit-linked Insurance Fund established under subsection`
  line `(2) of section 3G;`
  line
  line `(fb) "Insurance Scheme" means the Coal Mines Deposit-linked Insurance Scheme framed under`
  line `sub-section (1) of section G;]`
  line
  line ^9[
  line `^10[(fc)] ["managing agent" has the meaning assigned to it in the Companies Act, 1956`
  line `(1 of 1956); and;]`
  line
  line `(g) "member" means a member of the Fund.`
  line
  line `^11[(h) "Pension Fund" means the Pension Fund established under sub-section (2) of section 3E;`
  line
  line `(i) "Pension Scheme" means the Coal Mines Pension Scheme framed under sub-section (1) of`
  line `section 3E;`
  line
  line `(j) "superannuation", ,,in relation to an employee who is a member of the Pension Scheme, means`
  line `the attainment, by the said employee, of such age as is fixed in the contract or conditions of service as`
  line `the age on the attainment of which such employee shall vacate the employment.]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 80 of 1950, s. 3, for "employee in a coal mine".`
  line
  line `2. Ins. by Act 45 of 1965, s. 2 (w.e.f. 1-4-1966).`
  line
  line `3. Subs. by s. 2, ibid., for clause (b) (w.e.f. 1-4-1966).`
  line
  line `4. Ins. by Act 99 of 1976, s. 4 (w.e.f. 1-8-1976).`
  line
  line `5. Subs. by Act 45 of 1965, s. 2, for clause (d) (w.e.f. 1-4-1966).`
  line
  line `6. Subs. by s. 2, ibid., for clause (e) (w.e.f. 1-4-1966).`
  line
  line `7. Omitted by Act 23 of 1996, s. 3 (w.e.f. 31-3-1998).`
  line
  line `8. The word "and" omitted by Act 45 of 1965, s. 2 (w.e.f. 1-4-1966).`
  line
  line `9. Ins. by s. 2, ibid. (w.e.f. 1-4-1966).`
  line
  line `10. Clause (ff) re-lettered as clause (fc) thereof by Act 99 of 1976, s. 4 (w.e.f. 1-8-1976).`
  line
  line `11. Ins. by Act 23 of 1996, s. 3 (w.e.f. 31-3-1998).`
obj_root_law_sections_3:
  sectionId (17022)
  sectionNo (3)
  orderNo 3
  title `Coal Mines Provident Fund Scheme.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17022&sectionno=3&orderno=3&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_content:
  string
  line `(1) The Central Government may, by notification in the`
  line `Official Gazette, frame a scheme to be called the Coal Mines Provident Fund Scheme a for the`
  line `establishment of a provident fund for ^1[employees] and specify the coal mines to which the said scheme`
  line `shall apply.`
  line
  line `^2[(1A) The Fund shall vest in, and be administered by, the Board constituted under section 3A.]`
  line
  line `(2) Any scheme framed under the provisions of sub-section (1) may provide for all or any of the`
  line `matters specified in the First Schedule.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 80 of 1950, s. 4, for "employees in coal mines".`
  line
  line `2. Ins. by Act 45 of 1965, s. 3 (w.e.f. 1-4-1966).`
obj_root_law_sections_3_a:
  sectionId (17023)
  sectionNo 3A
  orderNo 4
  title `Constitution of Board of Trustees.`
  content obj_root_law_sections_3_a_content
  footnotes obj_root_law_sections_3_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17023&sectionno=3A&orderno=4&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Constitution of Board of Trustees.--(1) The Central Government may, by notification in the`
  line `Official Gazette, constitute, with effect from such date as may be specified therein, a Board of Trustees`
  line `for the territories to which this Act extends (hereinafter in this Act referred to as the Board) consisting of`
  line `the following persons, namely:--`
  line
  line `(a) a Chairman appointed by the Central Government;`
  line
  line `(b) the Coal Mines Provident Fund Commissioner, ex Officio;`
  line
  line `(c) three persons appointed by the Central Government;`
  line
  line `(d) not more than six persons representing Governments of such States as the Central`
  line `Government may specify in this behalf, from time to time, appointed by the Central Government;`
  line
  line `(e) six persons representing employers, appointed by the Central Government after consultation`
  line `with such organisations of employers as may be recognised by the Central Government in this behalf,`
  line `and of whom at least one shall be a person who is not a member of any such organisation;`
  line
  line `(f) six persons representing employees, appointed by the Central Government after consultation`
  line `with such organisations of employees as may be recognised by the Central Government in this behalf`
  line `and of whom at least one shall be an employee himself and at least one shall be a person who is not a`
  line `member of any such organisation.`
  line
  line `(2) The terms and conditions subject to which a member of the Board may be appointed and the time,`
  line `place and procedure of the meetings of the Board shall be such as may be provided for in the Coal Mines`
  line `Provident Fund Scheme.`
  line
  line `(3) The Board shall ^2[, subject to the provisions of section 3E ^3[and section 3G],] administer the Fund`
  line `Fund vested in it in such manner as may be specified in the Scheme aforesaid.`
  line
  line `(4) The Board shall perform such other functions as it may be required to perform by or under any`
  line `provisions of ^4[the Coal Mines Provident Fund Scheme ^5[, the Coal Mines Family Pension Scheme and`
  line `the Insurance Scheme]].]`
obj_root_law_sections_3_a_footnotes:
  string
  line `1. Ins. by s. 4, ibid. (w.e.f. 1-4-1966).`
  line
  line `2. Ins. by Act 16 of 1971, s. 6 (w.e.f. 13-2-1971).`
  line
  line `3. Ins. by Act 99 of 1976, s. 5 (w.e.f. 1-8-1976).`
  line
  line `4. Subs. by Act 16 of 1971, s. 6, for "the scheme aforesaid" (w.e.f. 13-2-1971).`
  line
  line `5. subs. by Act 99 of 1976, s. 5, for "and the Coal Mines Family Pension Scheme" (w.e.f. 1-8-1976).`
obj_root_law_sections_3_b:
  sectionId (17024)
  sectionNo 3B
  orderNo 5
  title `Board of Trustee to be a body corporate.`
  content obj_root_law_sections_3_b_content
  footnotes `1. Ins. by s. 4, ibid. (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17024&sectionno=3B&orderno=5&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_b_content:
  string
  line `^13B. Board of Trustee to be a body corporate.--The board of Trustees constituted under section 3 A`
  line `shall be a body corporate under the name specified in the notification constituting it, having perpetual`
  line `succession and a common seal and shall by the said name sue and be sued.]`
obj_root_law_sections_3_c:
  sectionId (17025)
  sectionNo 3C
  orderNo 6
  title `Appointment of officers.`
  content obj_root_law_sections_3_c_content
  footnotes obj_root_law_sections_3_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17025&sectionno=3C&orderno=6&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_c_content:
  string
  line `^1[3C. Appointment of officers.--(1) The Central Government shall appoint a Coal Mines Provident`
  line `Fund Commissioner, who shall be the chief executive officer of the Board and shall be subject to the`
  line `general control and superintendence of the Board.`
  line
  line `(2) The Central Government may also appoint as many other officers, whose minimum monthly`
  line `salary in the scale of pay (if any) applicable to them is not less than four hundred rupees, as it may`
  line `consider necessary to assist the Coal Mines Provident Fund Commissioner in the discharge of his duties.`
  line
  line `(3) Subject to the provisions of sub-sections (1) and (2), the Board may appoint such other officers`
  line `and employees as it may consider necessary for the efficient administration of the Coal Mines Provident`
  line `Fund Scheme, ^2[, the Coal Mines Family Pension Scheme and the Insurance Scheme.]`
  line
  line `(4) The method of recruitment, salary and allowance, discipline and other conditions of service of the`
  line `Coal Mines Provident Fund Commissioner shall be such as may be specified by the Central Government`
  line `and such salary and allowances shall be paid out of the Fund.`
  line
  line `(5) The method of recruitment, salary and allowances, discipline and other conditions of service of`
  line `other officers and employees of the Board shall be such as may be specified by the Board with the`
  line `approval of the Central Government.]`
obj_root_law_sections_3_c_footnotes:
  string
  line `1. Ins. by s. 4, ibid. (w.e.f. 1-4-1966).`
  line
  line `2. Subs. by Act 99 of 1976, s. 6, for "and the Coal Mines Family Pension Scheme" (w.e.f. 1-8-1976).`
obj_root_law_sections_3_d:
  sectionId (17026)
  sectionNo 3D
  orderNo 7
  title `Transfer of accounts.`
  content obj_root_law_sections_3_d_content
  footnotes `1. Ins. by s. 4, ibid. (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17026&sectionno=3D&orderno=7&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_d_content:
  string
  line `^1[3D. Transfer of accounts.--(1) Where any employee who is a subscriber to any provident fund of`
  line `the coal mine in which he is employed becomes a member of the fund in accordance with the provisions`
  line `of any Coal Mines Provident Fund Scheme, the accumulations in the provident fund of the coal mine`
  line `standing to the credit of the employees shall, notwithstanding anything to the contrary contained in any`
  line `law for the time being in force or in any deed or other instrument establishing the provident fund but`
  line `subject to the provisions, if any, contained in the Scheme, be transferred, by such person and within such`
  line `time as may be provided in the Scheme, to the Fund and shall be credited to the account of the employee`
  line `in the Fund.`
  line
  line `(2) Where a member of the Fund leaves his employment in a coal mine and obtains re-employment in`
  line `any other establishment (not being a coal mine to which the Coal Mines Provident Fund Scheme applies)`
  line `and becomes a subscriber to any provident fund of that establishment, the amount of accumulations to the`
  line `credit of such employee in the Fund shall be transferred, within such time as may be specified by the`
  line `Central Government in this behalf, to the credit of his account in the provident fund of the establishment`
  line `in which he is re-employed, if the employee so desires and the rules in relation to that provident fund`
  line `permit such transfer.`
  line
  line `(3) Where any employee who is a subscriber to any provident fund of an establishment (not being a`
  line `coal mine to which the Coal Mines Provident Fund Scheme applies) leaves his employment in that`
  line `establishment and obtains re-employment in a coal-mine and becomes a member of the Fund, the amount`
  line `of accumulations to the credit 100 of such employee in the provident fund of the establishment left by him`
  line `shall, if the employee so desires and the rules in relation to such provident fund so permit, be transferred`
  line `to the credit of his account in the Fund.]`
obj_root_law_sections_3_e:
  sectionId (17027)
  sectionNo 3E
  orderNo 8
  title `Coal Mines Pension Scheme.`
  content obj_root_law_sections_3_e_content
  footnotes `1. Subs. by Act 23 of 1996, s. 5, for section 3E (w.e.f. 31-3-1998).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17027&sectionno=3E&orderno=8&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_e_content:
  string
  line `^1[3E. Coal Mines Pension Scheme.--(1) The Central Government may, by notification in the`
  line `Official Gazette, frame a scheme to be called the Coal Mines Pension Scheme for the purpose of`
  line `providing for--`
  line
  line `(a) superannuation pension, retiring pension or permanent total disablement pension to the`
  line `persons employed in any coal mine or class of coal mines to which this Act applies; and`
  line
  line `(b) widow or widower pension, children pension or orphan pension and life assurance benefits,`
  line `payable to the beneficiaries of such employees.`
  line
  line `(2) Notwithstanding anything contained in section 3, there shall be established, as soon as may be`
  line `after framing of the Pension Scheme, a Pension Fund into which there shall be paid, from time to time, in`
  line `respect of every employee who is a member of the Pension Scheme,--`
  line
  line `(a) such sums, not exceeding one-fourth, of the amount payable to the Fund under sub-section (1)`
  line `of section 10D as the employer's contribution as well as the employee's contribution, as may be`
  line `specified in the Pension Scheme;`
  line
  line `(b) such sums as the Central Government may, after due appropriation made by Parliament by`
  line `law in this behalf, specify;`
  line
  line `(c) the net assets of the Pension Fund as existed immediately before the establishment of the`
  line `Pension Fund; and`
  line
  line `(d) any other contribution which may be made to the Pension Fund with the previous approval of`
  line `the Central Government.`
  line
  line `(3) On the establishment of the Pension Fund, the Pension Scheme (hereinafter referred to as the`
  line `ceased scheme) shall cease to operate and all assets of the ceased scheme shall vest in, and shall stand`
  line `transferred to, and all liabilities under the ceased scheme shall be enforceable against, the Pension Fund`
  line `and the beneficiaries under the ceased scheme shall be entitled to draw the benefits, not less than the`
  line `benefits, they were entitled to under the ceased scheme, from the Pension Fund.`
  line
  line `(4) The Pension Fund shall vest in and be administered by the Board in such manner as may be`
  line `specified in the Pension Scheme.`
  line
  line `(5) A Scheme framed under the provision of sub-section (1) may provide for all or any of the matters`
  line `specified in the Second Schedule.]`
obj_root_law_sections_3_f:
  sectionId (17028)
  sectionNo 3F
  orderNo 9
  title `Special grant by Central Government.`
  content obj_root_law_sections_3_f_content
  footnotes `1. Subs. by Act 23 of 1996, s. 5, for section 3E (w.e.f. 31-3-1998).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17028&sectionno=3F&orderno=9&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_f_content:
  string
  line `^1[3F. Special grant by Central Government.--The Central Government shall, after due appropriation`
  line `made by Parliament by law in this behalf, pay such further sums as may be determined by it into the`
  line `Family Pension Fund to meet all the expenses in connection with the administration of the Coal Mines`
  line `Family Pension Scheme other than the expenses towards the cost of any benefits provided by or under the`
  line `said Scheme.]`
obj_root_law_sections_3_g:
  sectionId (17029)
  sectionNo 3G
  orderNo 10
  title `Coal Mines Deposit-linked Insurance Scheme.`
  content obj_root_law_sections_3_g_content
  footnotes `1. Ins. by Act 99 of 1976, s. 7 (w.e.f. 1-8-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=17029&sectionno=3G&orderno=10&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_3_g_content:
  string
  line `^1[3G. Coal Mines Deposit-linked Insurance Scheme.--(1) The Central Government may, by`
  line `notification in the Official Gazette, frame a scheme to be called the Coal Mines Deposit-linked Insurance`
  line `Scheme for the purpose of providing life insurance benefits to such employees as are covered by the Coal`
  line `Mines Provident Fund Scheme.`
  line
  line `(2) There shall be established, as soon as may be after the framing of the Insurance Scheme, a`
  line `Deposit-linked Insurance Fund into which shall be paid by the employer from time to time in respect of`
  line `every such employee in relation to whom he is the employer such amount, not being more than one per`
  line `cent. of the aggregate of the basic wages, dearness allowance and retaining allowance (if any) for the time`
  line `being payable in relation to such employee, as the Central Government may, be notification in the Official`
  line `Gazette, specify.`
  line
  line `Explanation.--For the purposes of this sub-section,--`
  line
  line `(a) the expression "basic wages" has the meaning assigned to it in the Employees' Provident`
  line `Funds and Miscellaneous Provisions Act, 1952 (19 of 1952);`
  line
  line `(b) "dearness allowance" means all cash payments, by whatever name called, paid to an employee`
  line `on account of a rise in the cost of living and shall be deemed to include also the cash value of any`
  line `food concession allowed to the employee;`
  line
  line `(c) "retaining allowance" means an allowance payable for the time being to an employee of any`
  line `coal mine during any period in which the coal mine is not working, for retaining his services.`
  line
  line `(3) The Central Government shall after due appropriation made by Parliament by law, contribute to`
  line `the Insurance Fund in relation to each employee covered by the Coal Mines Provident Fund Scheme, an amount representing one half of the contribution which an employer is required, by sub-section (2), to`
  line make.
  line
  line `(4) (a) The employer shall pay into the Insurance Fund such further sums of money, not exceeding`
  line `one-fourth of the contribution which he is required to make under sub-section (2), as the Central`
  line `Government, may from time to time, determine, to meet all the expenses in connection with the`
  line `administration of the Insurance Scheme other than the expenses towards the cost of any benefits provided`
  line `by or under that scheme.`
  line
  line `(b) The Central Government shall, after due appropriation made by Parliament by law, pay into the`
  line `Insurance Fund such further sums of money representing one-half of the sums payable by the employer`
  line `under clause (a), to meet all the expenses in connection with the administration of the Insurance Scheme`
  line `other than the expenses towards the cost of any benefits provided by or under that scheme.`
  line
  line `(5) The Insurance Fund shall vest in the Board and shall be administered by the Board in such manner`
  line `as may be specified in the Insurance Scheme.`
  line
  line `(6) Any scheme framed under the provisions of sub-section (1) may provide for all or any of the`
  line `matters specified in the Third Schedule.]`
obj_root_law_sections_4:
  sectionId (29229)
  sectionNo (4)
  orderNo 11
  title `Fund to be recognised under Act 43 of 1961.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 23 of 1996, s. 6, for section 4 (w.e.f. 31-3-1996).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29229&sectionno=4&orderno=11&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_4_content:
  string
  line `^1[4. Fund to be recognised under Act 43 of 1961.--For the purposes of the Income-tax Act, 1961,`
  line `the Fund shall be deemed to be a recognised Provident Fund within the meaning of Part A of the Fourth`
  line `Schedule to that Act.]`
obj_root_law_sections_5:
  sectionId (29230)
  sectionNo (5)
  orderNo 12
  title `Coal Mines Bonus Schemes`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29230&sectionno=5&orderno=12&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_5_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, frame a scheme to be called the Coal Mines Bonus Scheme for the payment of bonus to`
  line `^1[employees] and specify the coal mines to which the said scheme shall apply.`
  line
  line `(2) A scheme framed under the provisions of sub-section (1) may provide for all or any of the matters`
  line `specified in the ^2[Fourth Schedule.]`
  line
  line `^3[(3) The employer shall pay the bonus in accordance with the Scheme as aforesaid.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 80 of 1950, s. 4, for "employees in coal mines".`
  line
  line `2. Subs. by Act 99 of 1976, s. 8, for "Third Schedule" (w.e.f. 1-8-1976).`
  line
  line `3. Ins. by Act 45 of 1965, s. 5 (w.e.f. 1-4-1966).`
obj_root_law_sections_6:
  sectionId (29231)
  sectionNo (6)
  orderNo 13
  title `Retrospective operation of a scheme.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29231&sectionno=6&orderno=13&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_6_content:
  string
  line `A scheme framed under this Act may provide that any of`
  line `its provisions shall come into force either prospectively or retrospectively with effect from such date as`
  line `may be specified in this behalf in the scheme.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (29232)
  sectionNo (7)
  orderNo 14
  title `Modification of a scheme`
  content obj_root_law_sections_7_content
  footnotes `1. Ins. by Act 99 of 1976, s. 9 (w.e.f. 1-8-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29232&sectionno=7&orderno=14&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_7_content:
  string
  line `The Central Government may, by notification in the Official Gazette,`
  line `add to, amend or vary, ^1[either prospectively or retrospectively] a scheme framed under this Act.`
obj_root_law_sections_7_a:
  sectionId (29233)
  sectionNo 7A
  orderNo 15
  title `Schemes to be laid before Parliament`
  content obj_root_law_sections_7_a_content
  footnotes obj_root_law_sections_7_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29233&sectionno=7A&orderno=15&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_7_a_content:
  string
  line `^1[7A. Schemes to be laid before Parliament.--Every scheme made under this Act shall be laid as`
  line `soon as may be after it is made, before each House of Parliament while it is in session for a total period of`
  line `thirty days which may be comprised in one session or in ^2[two or more successive sessions, and if, before`
  line `the expiry of the session immediately following the session or the successive sessions aforesaid], both`
  line `Houses agree in making any modification in the scheme or both Houses agree that the scheme should not`
  line `be made, the scheme shall thereafter have effect only in such modified form or be of no effect, as the case`
  line `may be; so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that scheme.]`
obj_root_law_sections_7_a_footnotes:
  string
  line `1. Ins. by Act 45 of 1965, s. 6 (w.e.f. 1-4-1966).`
  line
  line `2. Subs. by Act 99 of 1976, s. 10, for certain words (w.e.f. 1-8-1976).`
obj_root_law_sections_7_b:
  sectionId (29234)
  sectionNo 7B
  orderNo 16
  title `Determination of moneys due from employers.`
  content obj_root_law_sections_7_b_content
  footnotes `1. Ins. by Act 45 of 1965, s. 6 (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29234&sectionno=7B&orderno=16&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_7_b_content:
  string
  line `^1[7B. Determination of moneys due from employers.--(1) The Coal Mines Provident Fund`
  line `Commissioner or any other officer duly authorised in this behalf by the Central Government may, by`
  line `order, determine the amount due from any employer under any provision of this Act or of any scheme`
  line `framed thereunder and for this purpose may conduct such enquiry as he may deem necessary.`
  line
  line `(2) The officer conducting the enquiry under sub-section (1) shall, for the purpose of such enquiry,`
  line `have the same powers as are vested in a Court under the Code of Civil Procedure, 1908 (5 of 1908) for`
  line `trying a suit in respect of the following matters, namely:--`
  line
  line `(a) enforcing the attendance of any person or examining him on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) receiving evidence on affidavit;`
  line
  line `(d) issuing commissions for the examination of witnesses;`
  line
  line `and any such enquiry shall be deemed to be a judicial proceeding within the meaning of sections 193 and`
  line `228, and for the purpose of section 196, of the Indian Penal Code (45 of 1860).`
  line
  line `(3) No order determining the amount due from any employer shall be made under sub-section (1)`
  line `unless the employer is given a reasonable opportunity of representing his case.`
  line
  line `(4) An order made under this section shall be final and shall not be questioned in any Court of law.]`
obj_root_law_sections_8:
  sectionId (29235)
  sectionNo (8)
  orderNo 17
  title `Protection against attachment`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29235&sectionno=8&orderno=17&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_8_content:
  string
  line `(1) The amount of provident fund standing to the credit of any`
  line `member in the Fund shall not in any way be capable of being assigned or charged and shall not be liable`
  line `to attachment under any decree or order of any Court in respect of any debt or liability incurred by the`
  line `member and neither the Official Assignee nor any Receiver appointed under the Provincial Insolvency`
  line `Act, 1920 (5 of 1920), shall be entitled to, or have any claim on, any such amount.`
  line
  line `(2) Any amount standing to the credit of any member in the Fund at the time of his death and payable`
  line `to his nominee under the Coal Mines Provident Fund Scheme shall, subject to any deduction authorized`
  line `by the said scheme, vest in the nominee and shall be free from any debt or other liability incurred by the`
  line `deceased or incurred by the nominee before the death of the member.`
  line
  line `^1[(3) The provisions of sub-section (1) and sub-section (2) shall, so far as may be, apply in relation to`
  line `the family pension or any other amount payable under the Coal Mines Family Pension Scheme ^2[and also`
  line `in relation to any amount payable under the Insurance Scheme] as they apply in relation to any amount`
  line `payable out of the Fund.]`
obj_root_law_sections_8_footnotes:
  string
  line `1. Ins. by Act 16 of 1971, s. 10 (w.e.f. 13-2-1971).`
  line
  line `1. Ins. by Act 99 of 1976, s. 11 (w.e.f. 1-8-1976)`
obj_root_law_sections_9:
  sectionId (29236)
  sectionNo (9)
  orderNo 18
  title Penalty.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29236&sectionno=9&orderno=18&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_9_content:
  string
  line `^1[(1) If any person--`
  line
  line `(a) contravenes any provisions of this Act or of any scheme framed thereunder, he shall be`
  line `punishable with imprisonment for a term which may extend to six months, or with fine which may`
  line `extend to one thousand rupees or with both;`
  line
  line `(b) who has been convicted of any offence punishable is aforesaid, is again guilty of any such`
  line `offence within a period of two years from the date of the previous conviction, he shall be punishable`
  line `on conviction with imprisonment for a term which may extend to one year, or with fine which may`
  line `extend to two thousand rupees, or with both.]`
  line
  line `(2) No Court shall take cognizance of any offence punishable under ^2[sub-section (1)] except on a`
  line `report in writing of the facts constituting such offence made by an Inspector with the previous sanction of`
  line `such authority as may be specified in this behalf by the Central Government.`
  line
  line `^3[(3) No Court inferior to that of a Presidency Magistrate or a Magistrate of the first class shall try any`
  line `offence punishable under sub-section (1)].`
obj_root_law_sections_9_footnotes:
  string
  line `1. Subs. by Act 45 of 1965, s. 7, for sub-section (1) (w.e.f. 1-4-1966).`
  line
  line `2. Subs. by s. 7, ibid., for "any such scheme" (w.e.f. 1-4-1966).`
  line
  line `3. Ins. by s. 7, ibid. (w.e.f. 1-4-1966).`
obj_root_law_sections_10:
  sectionId (29237)
  sectionNo (10)
  orderNo 19
  title Inspectors
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29237&sectionno=10&orderno=19&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_10_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette, appoint`
  line `such persons as it thinks fit to be Inspectors for the purposes of the Coal Mines Provident Fund Scheme`
  line `^1[or the Insurance Scheme] or the Coal Mines Bonus Scheme and may define their jurisdiction.`
  line
  line `(2) An Inspector may, in respect of any coal mine within his jurisdiction,--`
  line
  line `^2[(a) require an employer or any contractor from whom any amount is recoverable under`
  line `section 10E--`
  line
  line `(i) to furnish such information, or`
  line
  line `(ii) to produce in the office of the Inspector or such other place as may be nearer to the`
  line `employer or, as the case may be, the contractor, such accounts, books, registers and other`
  line documents,
  line
  line `relating to the employment of persons in a coal mine as the Inspector may consider necessary for the`
  line `purposes of any scheme framed under this Act;]`
  line
  line `(b) at any reasonable time ^3[and with such assistance, if any, as he may think fit, enter and search`
  line `any coal mine] and require any one found in charge thereof to produce before him such accounts,`
  line `books, registers and other documents relating to the employment of persons in the coal mine as he`
  line `may consider necessary;`
  line
  line `(c) examine, with respect to any matter relevant to any of the purposes aforesaid, the employer`
  line `^4[or any contractor from whom any amount is recoverable under section 10E], his agent or servant or`
  line `any other person found in charge of the coal mine ^5* * * or whom the Inspector has reasonable cause`
  line `to believe to be or to have been an employee in the coal mine.`
  line
  line `^4(d) make copies of, or take extracts from, any accounts, books, registers or other documents`
  line `maintained in relation to a coal mine and where he has reason to believe that any offence under this`
  line `Act has been committed by an employer or contractor, seize with such assistance as he may think fit,`
  line `such accounts, books, registers or other documents or portions thereof as he may consider relevant in`
  line `respect of that offence;`
  line
  line `(e) exercise such other powers as any such Scheme may provide.]`
  line
  line `^4(2A) Every person required to furnish any information or produce any document under clause (a) or`
  line `clause (b) of sub-section (2) shall be deemed to be legally bound to do so within the meaning of section`
  line `175 of the Indian Penal Code (45 of 1860).`
  line
  line `(2B) The provisions of the ^6[Code of Criminal Procedure, 1973, (2 of 1974)] shall, so far as may be,`
  line `apply to any search or seizure under sub-section (2) as they apply to any search or seizure made under the`
  line `authority of a warrant issued under ^6[section 94 of the said Code.]`
  line
  line `(3) Every Inspector shall be deemed to be a public servant within the meaning of section 21 of the`
  line `Indian Penal Code, 1860 (45 of 1860).`
obj_root_law_sections_10_footnotes:
  string
  line `1. Ins. by Act 99 of 1976, s. 12 (w.e.f. 1-8-1976).`
  line
  line `2. Subs. by Act 45 of 1965, s. 8, for clause (a) (w.e.f. 1-4-1966).`
  line
  line `3. Subs. by s. 8, ibid., for "enter any coal mine or its office" (w.e.f. 1-4-1966).`
  line
  line `4. Ins. by s. 8, ibid. (w.e.f. 1-4-1966).`
  line
  line `5. The words "or its office" omitted by s. 8, ibid. (w.e.f. 1-4-1996).`
  line
  line `6. Subs. by Act 23 of 1996, s. 7, for certain words (w.e.f. 31-3-1996).`
obj_root_law_sections_10_a:
  sectionId (29238)
  sectionNo 10A
  orderNo 20
  title `Mode of recovery of money due from an employer`
  content obj_root_law_sections_10_a_content
  footnotes obj_root_law_sections_10_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29238&sectionno=10A&orderno=20&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_10_a_content:
  string
  line `^1[10A, Mode of recovery of money due from an employer.--Any amount due from an employer in`
  line `in respect of any contribution or bonus under any scheme framed under this Act ^2[or any accumulations`
  line `required to be transferred under sub-section (1) or sub-section (3) of section 3D or any damages`
  line `recoverable under section 10F or any charges payable by the employer under this Act in respect of the`
  line `administration of any such scheme] may be recovered by the Central Government in the same manner as`
  line `an arrear of land revenue.]`
obj_root_law_sections_10_a_footnotes:
  string
  line `1. Ins. by Act 21 of 1951, s. 2.`
  line
  line `2. Ins. by Act 45 of 1965, s. 9 (w.e.f. 1-4-1966).`
obj_root_law_sections_10_b:
  sectionId (29239)
  sectionNo 10B
  orderNo 21
  title `Determination of employer in certain cases.`
  content obj_root_law_sections_10_b_content
  footnotes `1. Ins. by s. 10, ibid. (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29239&sectionno=10B&orderno=21&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_10_b_content:
  string
  line `^1[10B. Determination of employer in certain cases.--(1) Where the employer is a firm or other`
  line `association of individuals, all, or any of the partners or members thereof, or where the employer is a`
  line `company, all or any of the directors thereof, may be prosecuted and punished under this Act for any`
  line `offence for which the employer is punishable:`
  line
  line `Provided that where a firm, association or company has given notice in writing to the Coal Mines`
  line `Provident Fund Commissioner or any officer specified by the Central Government in this behalf that it`
  line `has nominated,--`
  line
  line `(a) in the case of a firm, any of its partners,`
  line
  line `(b) in the case of an association, any of its members,`
  line
  line `(c) in the case of a company, any of its directors,`
  line
  line `who is resident in each case in any place to which this Act extends and who is in each case either in fact`
  line `in charge of the management of, or holds the largest number of shares in, such firm, association or`
  line `company, to assume the responsibility of the employer for the purposes of this Act or of any scheme`
  line `framed thereunder, such partner, member or director, as the case may be, shall, so long as he continues to`
  line `so reside and be in charge or hold the largest number of shares as aforesaid, be deemed to be the employer`
  line `for the purposes of this Act or any scheme framed thereunder, unless a notice in writing cancelling his`
  line `nomination or stating that he has ceased to be a partner, member or director, as the case may be, is`
  line `received by the Coal Mines Provident Fund Commissioner or any officer specified by the Central`
  line `Government in this behalf.`
  line
  line `(2) Where the employer is a Government or any local authority, all or any of the officers or persons`
  line `authorised by such Government or local authority, as the case may be, to manage the affairs of the coal`
  line `mine, shall, notwithstanding anything to the contrary contained in any law or contract for the time being`
  line `in force, be deemed to be the employers or employer in respect of the coal mine and may be prosecuted`
  line `and punished under this Act for any offence for which the employer is punishable.]`
obj_root_law_sections_10_c:
  sectionId (29240)
  sectionNo 10C
  orderNo 22
  title `Delegation of powers`
  content obj_root_law_sections_10_c_content
  footnotes `1. Ins. by s. 10, ibid. (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29240&sectionno=10C&orderno=22&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_10_c_content:
  string
  line `^1[10C. Delegation of powers.--(1) The Central Government may, by notification in the Official`
  line `Gazette, direct that any power exercisable by it under this Act or any scheme framed thereunder shall,`
  line `subject to such conditions, if any, as may be specified in the notification, be exercisable also by the Coal`
  line `Mines Provident Fund Commissioner or any officer authorised in this behalf by the Central Government.`
  line
  line `(2) The Board may delegate to its Chairman or the Coal Mines Provident Fund Commissioner or any`
  line `other officer or the Board, subject to such conditions and limitations, if any, as the Board may specify,`
  line `such of the powers and functions of the Board under this act or any scheme framed thereunder, as the`
  line `Board may deem necessary for the efficient administration of any scheme framed under this Act.]`
obj_root_law_sections_10_d:
  sectionId (29241)
  sectionNo 10D
  orderNo 23
  title `Payment of contribution by employers and recovery thereof from members`
  content obj_root_law_sections_10_d_content
  footnotes `1. Ins. by s. 10, ibid. (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29241&sectionno=10D&orderno=23&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_10_d_content:
  string
  line `^1[10D. Payment of contribution by employers and recovery thereof from members.--(1) The`
  line `contribution shall be payable by the employer (hereinafter referred to as the employer's contribution) and`
  line `by the employee (hereinafter referred to as the employees contribution) at such rate as may be specified`
  line `in the Coal Mines Provident Fund Scheme, and the employer shall pay the employer's contribution as`
  line `well as the employee's contribution, whether or not he has recovered from any employee the employee's`
  line `share of the contribution.`
  line
  line `(2) The amount of any contribution paid by the employer on behalf of a member shall,`
  line `notwithstanding anything to the contrary contained in any other law for the time being in force or any`
  line `contract, be recoverable by means of deduction from the wages of the member and not otherwise.`
  line
  line `(3) Save as otherwise provided in the Coal Mines Provident Fund Scheme, no deduction under`
  line `sub-section (2) shall be made from any wages other than such as are paid in respect of the period for`
  line `which the contribution is payable.`
  line
  line `(4) Notwithstanding any contract to the contrary, the employer shall not be entitled to deduct the`
  line `employer's contribution or the charges referred to in section 10A from the wages of a member or`
  line `otherwise to recover such contribution or charges from such member.]`
obj_root_law_sections_10_e:
  sectionId (29242)
  sectionNo 10E
  orderNo 24
  title `Recovery of monies by employers and contractors.`
  content obj_root_law_sections_10_e_content
  footnotes obj_root_law_sections_10_e_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29242&sectionno=10E&orderno=24&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_10_e_content:
  string
  line `^1[10E. Recovery of monies by employers and contractors.--(1) ^2[The amount of contribution (that is`
  line `to say the employer's contribution as well as the employee's contribution in pursuance of the Coal Mines`
  line `Provident Fund Scheme and the employer's contribution in pursuance of the Insurance Scheme)] and any`
  line `charges referred to in section 10A paid or payable by an employer in respect of an employee employed by`
  line `or through a contractor and any bonus paid or payable under any Coal Mines Bonus Scheme in respect of any such employee may be recovered by such employer from the contractor either by deduction from any`
  line `amount payable to the contractor under any contract or as a debt payable by the contractor.`
  line
  line `(2) A contractor from whom the amounts mentioned in sub-section (1) may be recovered in respect of`
  line `any employee employed by or through him may, save as otherwise provided in the Coal Mines Provident`
  line `Fund Scheme, recover from such employee the employee's contribution under any such Scheme by`
  line `deduction from the wages payable to the employee subject to the condition that no such deduction shall`
  line `be made from any wages other than such as are payable in respect of the period to which the employee's`
  line `contribution relates.`
  line
  line `(3) Notwithstanding any contract to the contrary, no contractor shall be entitled to deduct the`
  line `employer's contribution or the charges or bonus referred to in sub-section (1) from the amount payable to`
  line `an employee employed by or through him or otherwise to recover such contribution or charges or bonus`
  line `from such employee.]`
obj_root_law_sections_10_e_footnotes:
  string
  line `1. Ins. by s. 10, ibid. (w.e.f. 1-4-1966).`
  line
  line `2. Subs. by Act 99 of 1976, s. 13, for certain words and brackets (w.e.f. 1-8-1976).`
obj_root_law_sections_10_f:
  sectionId (29243)
  sectionNo 10F
  orderNo 25
  title `Power to recover damages.`
  content obj_root_law_sections_10_f_content
  footnotes `1. Ins. by s. 10, ibid. (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29243&sectionno=10F&orderno=25&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_10_f_content:
  string
  line `^1[10F. Power to recover damages.--Where an employer makes default in the payment of any`
  line `contribution or bonus or any charges payable by him under any scheme framed under this Act, or where`
  line `any person who is required to transfer provident fund accumulations in accordance with the provisions of`
  line `section 3D makes default in the transfer of such accumulations, the Central Government may recover`
  line `from such employer or person, as the case may be, such damages, not exceeding twenty-five per cent of`
  line `the amount of arrears, as it may think fit to impose.]`
obj_root_law_sections_11:
  sectionId (29244)
  sectionNo (11)
  orderNo 26
  title `Priority of payment of contributions and bonus over other debts`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 23 of 1996, s. 8, for certain words (w.e.f. 31-3-1998).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29244&sectionno=11&orderno=26&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_11_content:
  string
  line `The amount due in respect`
  line `of any contribution or bonus under a scheme framed under this Act or any charges incurred in respect of`
  line `the administration of any such scheme, shall, where the liability therefore has accrued before the persons`
  line `liable has been adjudicated insolvent or, in the case of a company ordered to be wound up, before the date`
  line `of such order, be deemed to be included among the debts which, under section 49 of the`
  line `Presidency-towns Insolvency Act, 1909 (3 of 1909), or under section 61 of the Provincial Insolvency Act,`
  line `1920 (5 of 1920), or under section 230 of the ^1[Companies Act, 1956 (1 of 1956),] are to be paid in`
  line `priority to all other debts in the distribution of the property of the insolvent or the assets of a company`
  line `being wound up, as the case may be.`
obj_root_law_sections_11_a:
  sectionId (29245)
  sectionNo 11A
  orderNo 27
  title `Protection for acts done in good faith.`
  content obj_root_law_sections_11_a_content
  footnotes `1. Ins. by Act 80 of 1950, s. 5.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29245&sectionno=11A&orderno=27&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_11_a_content:
  string
  line `^1[11A. Protection for acts done in good faith.--No suit or other legal proceeding shall lie against`
  line `any person in respect of anything which is in good faith done or intended to be done under this Act or`
  line `under any schemes framed thereunder.]`
obj_root_law_sections_11_b:
  sectionId (29246)
  sectionNo 11B
  orderNo 28
  title `Power to remove difficulties`
  content obj_root_law_sections_11_b_content
  footnotes `1. Ins. by Act 45 of 1965, s. 11 (w.e.f. 1-4-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29246&sectionno=11B&orderno=28&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_11_b_content:
  string
  line `^1[11B. Power to remove difficulties.--If any difficulty arises in giving effect to the provisions of`
  line `this Act or any scheme framed thereunder the Central Government may, by order published in the Official`
  line `Gazette, make such provision or give such direction not inconsistent with the purposes of this Act, as it`
  line `appears to it to be necessary or expedient for removing the difficulty.]`
obj_root_law_sections_11_c:
  sectionId (29247)
  sectionNo 11C
  orderNo 29
  title `Power to exempt`
  content obj_root_law_sections_11_c_content
  footnotes `1. Ins. by Act 99 of 1976, s. 14 (w.e.f. 1-8-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29247&sectionno=11C&orderno=29&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_11_c_content:
  string
  line `^1[11C. Power to exempt.--(1) The Central Government may, if requested so to do by the employer,`
  line `by notification in the Official Gazette, and subject to such conditions as may be specified in the`
  line `notification, exempt any coal mine from the operation of all or any of the provisions of the Insurance`
  line `Scheme, if it is satisfied that the employees of such coal mine are without making any separate`
  line `contribution or payment of premium, in enjoyment of benefits in the nature of life insurance, whether`
  line `linked to their deposits in provident fund or not, and such benefits are more favourable to such employees`
  line `than the benefits admissible under the Insurance Scheme.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Insurance Scheme may provide for the`
  line `exemption of any person or class of persons employed in any coal mine and covered by that scheme from`
  line `the operation of all any of the provisions thereof, if the benefits in the nature of life insurance admissible`
  line `to such person or class of persons are more favourable than the benefits provided under the Insurance`
  line Scheme.
  line
  line `(3) Where in respect of any person or class of persons employed in any coal mine, an exemption is`
  line `granted under this section from the operation of all or any of the provisions of the Insurance Scheme`
  line `(whether such exemption is granted to the coal mine wherein such person or class of persons is employed`
  line `or to the person or class of persons as such), the employer in relation to such coal mine--`
  line
  line `(a) shall, in relation to the benefits in the nature of life insurance, to which any such person or`
  line `class of persons is entitled, or any insurance fund, maintain such accounts, submit such returns, make`
  line `such investment, provide for such facilities for inspection and pay such inspection charges, as the`
  line `Central Government may direct;`
  line
  line `(b) shall not, at any time after the exemption without the leave of the Central Government, reduce`
  line `the total quantum of benefits in the nature of life insurance to which any such person or class of`
  line `persons was entitled immediately before the date of the exemption; and`
  line
  line `(c) shall, where any such person leaves his employment and obtains reemployment in any other`
  line `coal mine transfer within such time as may be specified in this behalf by the Central Government, the`
  line `amount of accumulations to the credit of that person in the insurance fund of the coal mine left by him`
  line `to the credit of that person-s account in the insurance fund of the coal mine in which he is`
  line `reemployed or, as the case may be, in the Deposit-linked Insurance Fund.`
  line
  line `Explanation.--For the purposes of this sub-section "insurance fund" means any fund established by`
  line `an employer under any scheme for providing benefits in the nature of life insurance to employees,`
  line `whether linked to their deposits in provident fund or not, without payment by the employees of any`
  line `separate contribution or premium in that behalf.`
  line
  line `(4) Any exemption granted under this section may be cancelled by the authority which granted it, by`
  line `order in writing, if an employer fails to comply--`
  line
  line `(a) in the case of an exemption granted under sub-section (1) with any of the conditions imposed`
  line `under that sub-section or with any of the provisions of sub-section (3);`
  line
  line `(b) in the case of an exemption granted under sub-section (2), with any of the provisions of`
  line `sub-section (3).`
  line
  line `(5) Where any exemption granted under sub-section (1) or sub-section (2) is cancelled, the amount of`
  line `accumulations to the credit of every employee to whom such exemption applied, in the insurance fund of`
  line `the coal mine in which he is employed shall be transferred within such time and in such manner as may be`
  line `specified in the Insurance Scheme to the credit of his account in the Insurance Fund.]`
obj_root_law_sections_11_d:
  sectionId (29248)
  sectionNo 11D
  orderNo 30
  title `Act to have effect notwithstanding anything contained in Act 31 of 1956.`
  content obj_root_law_sections_11_d_content
  footnotes `1. Ins. by Act 99 of 1976, s. 14 (w.e.f. 1-8-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29248&sectionno=11D&orderno=30&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_11_d_content:
  string
  line `^1[11D. Act to have effect notwithstanding anything contained in Act 31 of 1956.--The provisions`
  line `of this Act shall have effect notwithstanding anything inconsistent therewith contained in the Life`
  line `Insurance Corporation Act, 1956.]`
obj_root_law_sections_12:
  sectionId (29249)
  sectionNo (12)
  orderNo 31
  title `Repeal of Ordinance 7 of 1948.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_8_8_00009_194846_1517807326587&sectionId=29249&sectionno=12&orderno=31&orgactid=AC_CEN_8_8_00009_194846_1517807326587
obj_root_law_sections_12_content:
  string
  line `(1) The Coal Mines Provident Fund and Bonus Schemes`
  line `Ordinance, 1948, is hereby repealed.`
  line
  line `(2) Notwithstanding any such repeal, anything done or any action taken in exercise of any power`
  line `conferred by or under the said Ordinance shall be deemed to have been done or taken in exercise of the`
  line `powers conferred by or under this Act, as if this Act had commenced on the 23rd day of April, 1948.`
obj_root_law_sections_12_footnotes:
  string
  line
