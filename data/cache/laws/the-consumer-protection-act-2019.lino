obj_root_law:
  slug the-consumer-protection-act-2019
  handle (15256)
  collectionHandle 123456789/1362
  title `The Consumer Protection Act, 2019`
  actNumber (35)
  enactmentDate 2019-08-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/15256`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `उपभोक्ता- संरक्षण अधिनियम, 2019`
  actYear (2019)
  ministry `Ministry of Consumer Affairs, Food and Public Distribution`
  department `Department of Consumer Affairs`
  longTitle `An Act to provide for protection of the interests of consumers and for the said purpose, to establish authorities for timely and effective administration and settlement of consumers' disputes and for matters connected therewith or incidental thereto`
  enforcementDate `24th July, 2020.-- S. 2 clauses (4), (13), (14), (16), (40), s. 10 to 27 (both inclusive), sub-clause (iv) of clause (a) of sub-section (1) of section 58, s. 88, 89, 92 and 93, 94, 96, 97 and 99, clause (f) to (m) of sub-section 2 and clauses (zg), (zh) and (zi) of sub-section 2 of s. 101, 104, vide notification No. S.O. 2421(E), dated 23rd July 2020, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T21:06:57.908Z`
  translations obj_root_law_translations
