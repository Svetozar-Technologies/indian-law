obj_root_law_sections_1:
  sectionId (39686)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39686&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Places of Worship`
  line `(Special Provisions) Act, 1991.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
  line
  line `(3) The provisions of sections 3, 6 and 8 shall come into force at once and the remaining provisions of`
  line `this Act shall be deemed to have come into force on the 11th day of July, 1991.`
obj_root_law_sections_2:
  sectionId (39687)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39687&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a)“commencement of this Act” means the commencement of this Act on the 11th day of July, 1991;`
  line
  line `(b) “conversion”, with its grammatical variations, includes alteration or change of whatever nature;`
  line
  line `(c) “place of worship” means a temple, mosque, gurudwara, church, monastery or any other place of public religious worship of any religious denomination or any section thereof, by whatever name called.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39688)
  sectionNo (3)
  orderNo 3
  title `Bar of conversion of places of worship.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39688&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_3_content:
  string
  line `No person shall convert any place of worship of any`
  line `religious denomination or any section thereof into a place of worship of a different section of the same`
  line `religious denomination or of a different religious denomination or any section thereof.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39693)
  sectionNo (4)
  orderNo 4
  title `Declaration as to the religious character of certain places of worship and bar of jurisdiction of courts, etc.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39693&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_4_content:
  string
  line `(1) It is hereby declared that the religious character of a place of worship existing on the`
  line `15th day of August, 1947 shall continue to be the same as it existed on that day.`
  line
  line `(2) If, on the commencement of this Act, any suit, appeal or other proceeding with respect to the`
  line `conversion of the religious character of any place of worship, existing on the 15th day of August, 1947, is`
  line `pending before any court, tribunal or other authority, the same shall abate, and no suit, appeal or other`
  line `proceeding with respect to any such matter shall lie on or after such commencement in any court, tribunal`
  line `or other authority:`
  line
  line `Provided that if any suit, appeal or other proceeding, instituted or filed on the ground that conversion`
  line `has taken place in the religious character of any such place after the 15th day of August, 1947, is pending`
  line `on the commencement of this Act, such suit, appeal or other proceeding shall be disposed of in`
  line `accordance with the provisions of sub-section (1).`
  line
  line `(3) Nothing contained in sub-section (1) and sub-section (2) shall apply to,—`
  line
  line `(a) any place of worship referred to in the said sub-sections which is an ancient and historical`
  line `monument or an archaeological site or remains covered by the Ancient Monuments and`
  line `Archaeological Sites and Remains Act, 1958 (24 of 1958) or any other law for the time being in`
  line force;
  line
  line `(b) any suit, appeal or other proceeding, with respect to any matter referred to in sub-section (2),`
  line `finally decided, settled or disposed of by a court, tribunal or other authority before the`
  line `commencement of this Act;`
  line
  line `(c) any dispute with respect to any such matter settled by the parties amongst themselves before`
  line `such commencement;`
  line
  line `(d) any conversion of any such place effected before such commencement by acquiescence;`
  line
  line `(e) any conversion of any such place effected before such commencement which is not liable to`
  line `be challenged in any court, tribunal or other authority being barred by limitation under any law for the`
  line `time being in force.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39690)
  sectionNo (5)
  orderNo 5
  title `Act not to apply to Ram Janma Bhumi-Babri Masjid.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39690&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_5_content:
  string
  line `Nothing contained in this Act shall`
  line `apply to the place or place of worship commonly known as Ram Janma Bhumi-Babri Masjid situated in`
  line `Ayodhya in the State of Uttar Pradesh and to any suit, appeal or other proceeding relating to the said place`
  line `or place of worship.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39691)
  sectionNo (6)
  orderNo 6
  title `Punishment for contravention of section 3.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39691&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_6_content:
  string
  line `(1) Whoever contravenes the provisions of section`
  line `3 shall be punishable with imprisonment for a term which may extend to three years and shall also be`
  line `liable to fine.`
  line
  line `(2) Whoever attempts to commit any offence punishable under sub-section (1) or to cause such`
  line `offence to be committed and in such attempt does any act towards the commission of the offence shall be`
  line `punishable with the punishment provided for the offence.`
  line
  line `(3) Whoever abets, or is a party to a criminal conspiracy to commit, an offence punishable under`
  line `sub-section (1) shall, whether such offence be or be not committed in consequence of such abetment or in`
  line `pursuance of such criminal conspiracy, and notwithstanding anything contained in section 116 of the`
  line `Indian Penal Code (45 of 1860), be punishable with the punishment provided for the offence.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (39692)
  sectionNo (7)
  orderNo 7
  title `Act to override other enactments.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39692&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_7_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force or any instrument`
  line `having effect by virtue of any law other than this Act.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (39694)
  sectionNo (8)
  orderNo 8
  title Repealed.
  content `[Amendment of Act 43 of 1951.]—Rep. by the Repealing and Amending Act, 2001 (30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00036_199142_1517807323144&sectionId=39694&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00036_199142_1517807323144
obj_root_law_sections_8_footnotes:
  string
  line
