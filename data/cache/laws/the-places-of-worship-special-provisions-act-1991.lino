  (str title) (str `The Places of Worship (Special Provisions) Act, 1991`)
  (str actNumber) (str 42)
  (str enactmentDate) (str 1991-09-18)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1922`)
