  object
  (str title) (str `उपासना स्‍थल (विशेष उपबंध) अधिनियम, 1991`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1922/2/hH1991-42.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:24:29.801Z`)
