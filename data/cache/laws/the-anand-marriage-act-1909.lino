obj_root_law_sections_1:
  sectionId (33947)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00053_190907_1523341015192&sectionId=33947&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00053_190907_1523341015192
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Anand Marriage Act, 1909; and.`
  line
  line `(2) Its extends to the whole of India ^1***`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule`
  line `(w.e.f. 31-10- 2019).`
obj_root_law_sections_2:
  sectionId (33948)
  sectionNo (2)
  orderNo 2
  title `Validity of Anand marriages.`
  content obj_root_law_sections_2_content
  footnotes `1. Ins. by Act 29 of 2012, s. 2 (w.e.f. 1-11-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00053_190907_1523341015192&sectionId=33948&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00053_190907_1523341015192
obj_root_law_sections_2_content:
  string
  line `All marriages which may be or may have been duly`
  line `solemnized according to the Sikh marriage ceremony called Anand ^1[(commonly known as Anand Karaj)] shall be, and shall be deemed to have been with effect from the date Of the solemnization`
  line `or each respectively, good and valid in law.`
obj_root_law_sections_3:
  sectionId (33949)
  sectionNo (3)
  orderNo 3
  title `Exemption of certain marraiges from Act.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00053_190907_1523341015192&sectionId=33949&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00053_190907_1523341015192
obj_root_law_sections_3_content:
  string
  line `Nothing in this Act shall apply to--`
  line
  line `(a) any marriage between persons not professing the Sikh religion, or`
  line
  line `(b) any marriage which has been judically declared to be null and void.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (33950)
  sectionNo (4)
  orderNo 4
  title `Saving of marriages solemnized according to other ceremonies.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00053_190907_1523341015192&sectionId=33950&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00053_190907_1523341015192
obj_root_law_sections_4_content:
  string
  line `Nothing in this Act shall`
  line `affect the validity of any marriage duly solemnized according to any other marriage ceremony customary among the Sikhs.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (33951)
  sectionNo (5)
  orderNo 5
  title `Non-validation of marriages within prohibited degrees.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00053_190907_1523341015192&sectionId=33951&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00053_190907_1523341015192
obj_root_law_sections_5_content:
  string
  line `Nothing in this Act shall be deemed`
  line `to validate any marriage between persons who are related to each other in any degree of consanguinity or`
  line `effinity which would, according to the customary law of the Sikhs, render a marriage between them`
  line illegal.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (33952)
  sectionNo (6)
  orderNo 6
  title `Registration of marriages.`
  content obj_root_law_sections_6_content
  footnotes `1. Ins. by s. 3, ibid. (w.e.f. 1-11-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00053_190907_1523341015192&sectionId=33952&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00053_190907_1523341015192
obj_root_law_sections_6_content:
  string
  line `^1[6.Registration of marriages.--(1) For the purposes of facilitation of proof of marriage ceremony`
  line `(commonly known as Anand Karaj) customary among the Sikhs, the State Government shall, without`
  line `prejudice to anything contained in the Hindu Marriage Act, 1955 (25 of 1955) or any other law for the`
  line `time being in force, make rules providing that the parties to any such marriage [whether solemnized`
  line `before or after the commencement of the Anand Marriage (Amendment) Act, 2012], may have the`
  line `particulars relating to their marriage entered, in such manner and subject to such conditions as may be`
  line `provided in the said rules, in a Marriage Register kept by such officer of the State Government or of a`
  line `local authority authorised by the State Government, by notification in the Official Gazette, in this behalf.`
  line
  line `(2) The Marriage Register shall, at all reasonable times, be open for inspection, and shall be`
  line `admissible as evidence of the statements contained therein and certified extracts therefrom shall, on an`
  line `application, be given by the Registrar to the parties to the marriage on payment of such fees as may be`
  line `provided in the rules.`
  line
  line `(3) Notwithstanding anything contained in this section, the validity of any Anand Marriage`
  line `solemnized shall in no way be affected by the omission to make an entry in the Marriage Register.`
  line
  line `(4) Every rule made by the State Government under this section shall be laid before the State`
  line `Legislature, as soon as may be, after they are made.`
  line
  line `(5) The parties to the marriage, whose marriage has been registered under this Act, shall not be`
  line `required to get their marriage registered under any other law for the time being in force (including State`
  line `Act).]`
