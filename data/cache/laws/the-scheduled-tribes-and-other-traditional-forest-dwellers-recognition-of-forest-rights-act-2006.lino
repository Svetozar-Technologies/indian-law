obj_root_law:
  slug the-scheduled-tribes-and-other-traditional-forest-dwellers-recognition-of-forest-rights-act-2006
  handle (2070)
  collectionHandle 123456789/1362
  title `The Scheduled Tribes and Other Traditional Forest Dwellers (Recognition of Forest Rights) Act, 2006`
  actNumber (02)
  enactmentDate 2006-12-29
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2070`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `अनुसूचित जनजाति और अन्य परंपरागत वन निवासी (वन अधिकारों की मान्यता) अधिनियम, 2006`
  actYear (2007)
  ministry `Ministry of Tribal Affairs`
  longTitle `An Act to recognise and vest the forest rights and occupation in forest land in forest dwelling Scheduled Tribes and other traditional forest dwellers who have been residing in such forests for generations but whose rights could not be recorded; to provide for a framework for recording the forest rights so vested and the nature of evidence required for such recognition and vesting in respect of forest land.`
  enforcementDate 31-12-2007
  notification `31st December, 2007, vide notification No. S. O. 2224(E), dated 31st December, 2007, see Gazette of India Extraordinary, Part II, sec 3(ii).`
  fetchedAt `2026-05-08T21:36:00.094Z`
  translations obj_root_law_translations
