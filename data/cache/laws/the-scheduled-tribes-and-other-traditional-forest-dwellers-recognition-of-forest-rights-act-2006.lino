obj_root_law:
  object
  (str slug) (str the-scheduled-tribes-and-other-traditional-forest-dwellers-recognition-of-forest-rights-act-2006)
  (str handle) (str 2070)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Scheduled Tribes and Other Traditional Forest Dwellers (Recognition of Forest Rights) Act, 2006`)
  (str actNumber) (str 02)
  (str enactmentDate) (str 2006-12-29)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2070`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `अनुसूचित जनजाति और अन्य परंपरागत वन निवासी (वन अधिकारों की मान्यता) अधिनियम, 2006`)
  (str actYear) (str 2007)
  (str ministry) (str `Ministry of Tribal Affairs`)
  (str longTitle) (str `An Act to recognise and vest the forest rights and occupation in forest land in forest dwelling Scheduled Tribes and other traditional forest dwellers who have been residing in such forests for generations but whose rights could not be recorded; to provide for a framework for recording the forest rights so vested and the nature of evidence required for such recognition and vesting in respect of forest land.`)
  (str enforcementDate) (str 31-12-2007)
  (str notification) (str `31st December, 2007, vide notification No. S. O. 2224(E), dated 31st December, 2007, see Gazette of India Extraordinary, Part II, sec 3(ii).`)
  (str fetchedAt) (str `2026-05-08T21:36:00.094Z`)
  (str translations) obj_root_law_translations
