obj_root_law_sections_1:
  sectionId (3383)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00007_195746_1517807321552&sectionId=3383&sectionno=1&orderno=1&orgactid=AC_CEN_28_38_00007_195746_1517807321552
obj_root_law_sections_1_content:
  string
  line `^1[(1)] This Act may be called the Cantonments (Extension of Rent Control Laws)`
  line `Act, 1957.`
  line
  line `^2[(2) It shall be deemed to have come into force on the 26th day of January, 1950.]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Section 1 re-numbered as sub-section (1) thereof by Act 22 of 1972, s. 2 (w.e.f. 26-1-1950).`
  line
  line `2. Ins. by s. 2, ibid. (w.e.f. 26-1-1950).`
obj_root_law_sections_2:
  sectionId (3384)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00007_195746_1517807321552&sectionId=3384&sectionno=2&orderno=2&orgactid=AC_CEN_28_38_00007_195746_1517807321552
obj_root_law_sections_2_content:
  string
  line `In this Act, "cantonment" means any place declared to be a cantonment under`
  line `section 3 of the Cantonments Act, 1924 (2 of 1924).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (3385)
  sectionNo (3)
  orderNo 3
  title `Power to extend to cantonments laws relating to control of rents and regulation of house accommodation.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00007_195746_1517807321552&sectionId=3385&sectionno=3&orderno=3&orgactid=AC_CEN_28_38_00007_195746_1517807321552
obj_root_law_sections_3_content:
  string
  line `^1[(1)] The Central Government may, by notification in the Official Gazette, extend to`
  line `any cantonment with such restrictions and modifications as it thinks fit, any enactment relating to the`
  line `control of rent and regulation of house accommodation which is in force^2*** in the State in which the`
  line `cantonment is situated:`
  line
  line `Provided that nothing contained in any enactment so extended shall apply to--`
  line
  line `(a) any premises within the cantonment belonging to the Government;`
  line
  line `(b) any tenancy or other like relationship created by a grant from the Government in respect of`
  line `premises within the cantonment taken on lease or requisitioned by the Government; or`
  line
  line `(c) any house within the cantonment which is, or may be, appropriated by the Central`
  line `Government on lease under the Cantonments (House Accommodation) Act, 1923 (6 of 1923).`
  line
  line `^3[(2) The extension of any enactment under sub-section (1) may be made from such earlier or future`
  line `date as the Central Government may think fit:`
  line
  line `Provided that no such extension shall be made from a date earlier than`
  line
  line `(a) the commencement of such enactment, or`
  line
  line `(b) the establishment of the cantonment, or`
  line
  line `(c) the commencement of this Act,`
  line
  line `whichever is later.`
  line
  line `(3) Where any enactment in force in any State relating to the control of rent and regulation of house`
  line `accommodation is extended to a cantonment from a date earlier than the date on which such extension is`
  line `made (hereafter referred to as the "earlier date"), such enactment, as in force on such earlier date, shall`
  line `apply to such cantonment, and, where any such enactment has been amended at any time after the earlier`
  line `date but before the commencement of the Cantonments (Extension of Rent Control Laws) Amendment`
  line `Act, 1972 (22 of 1972), such enactment as amended, shall apply to the cantonment on and from the date`
  line `on which the enactment by which such amendment was made came into force.`
  line
  line `(4) Where, before the extension to a cantonment of any enactment relating to the control of rent and`
  line `regulation of house accommodation therein (hereafter referred to as the "Rent Control Act"),--`
  line
  line `(i) any decree or order for the regulation of, or for eviction from, any house accommodation in`
  line `that cantonment, or`
  line
  line `(ii) any order in the proceedings for the execution of such decree or order, or`
  line
  line `(iii) any order relating to the control of rent or other incident of such house accommodation,`
  line
  line `was made by any court, tribunal or other authority in accordance with any law for the control of rent and`
  line `regulation of house accommodation for the time being in force in the State in which such cantonment is`
  line `situated, such decree or order shall, on and from the date on which the Rent Control Act is extended to`
  line `that cantonment, be deemed to have been made under the corresponding provisions of the Rent Control`
  line `Act, as extended to that cantonment, as if the said Rent Control Act, as so extended, were in force in that`
  line `cantonment, on the date on which such decree or order was made.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Section 3 re-numbered as sub-section (1) thereof by s. 3, ibid. (w.e.f. 26-1-1950).`
  line
  line `2. The words "on the date of the notification" omitted by s. 3, ibid. (w.e.f. 26-1-1950).`
  line
  line `3. Ins. by s. 3, ibid. (w.e.f. 26-1-1950).`
obj_root_law_sections_4:
  sectionId (3386)
  sectionNo (4)
  orderNo 4
  title `Extension of the Madhya Bharat Accommodation Control Act, 1955 to the cantonment of Mhow.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00007_195746_1517807321552&sectionId=3386&sectionno=4&orderno=4&orgactid=AC_CEN_28_38_00007_195746_1517807321552
obj_root_law_sections_4_content:
  string
  line `^1[(1)] The Madhya Bharat Accommodation Control Act, 1955 (Madhya Bharat Act 23 of 1955),`
  line `as in force in that part of the State of Madhya Pradesh which immediately before the 1st day of`
  line `November, 1956, formed the State of Madhya Bharat is hereby extended to, and brought into force in, the`
  line `cantonment of Mhow with the following modifications, namely:--`
  line
  line `In the said Act,--`
  line
  line `(a) for the words "commencement of this Act" wherever they occur, the words extension of`
  line `this Act to the cantonment" shall be substituted;`
  line
  line `(b) in section 1, for sub-sections (2), (3) and (4), the following sub-sections shall be`
  line `substituted, namely:--`
  line
  line `"(2) It extends to the Cantonment of Mhow.`
  line
  line `(3) It shall remain in force upto the 31st day of December, 1957; but the Central`
  line `Government may, by notification in the Official Gazette, direct from time to time that it shall`
  line `remain in force for such further period as may be specified in the notification so, however,`
  line `that the total period for which it may remain in force shall not exceed two years from the 31st`
  line `day of December, 1957.";`
  line
  line `(c) in section 2, in clause (b) of sub-section (1), for the words "a Municipality", the words`
  line `"the Cantonment Board" shall be substituted;`
  line
  line `(d) in section 3, in clause (e), for the word "Municipal", the words "Cantonment Board" shall`
  line `be substituted;`
  line
  line `(e) in section 4,--`
  line
  line `(i) in clause (g), for the words "city or town concerned", the word "cantonment" shall be`
  line substituted;
  line
  line `(ii) in clause (h), for the words "city or town for that purpose and if he was in occupation,`
  line `has for sufficient reasons vacated it after the Act has been extended to that city or town", the`
  line `words "cantonment for that purpose or if he was in occupation, has for sufficient reasons`
  line `vacated it after the extension of this Act thereto" shall be substituted;`
  line
  line `(f) in section 6,--`
  line
  line `(i) in sub-section (1), the words and brackets "situated in the city of Lashkar (including`
  line `Gwalior and Morar), Indore, Ujjain or Ratlam" shall be omitted;`
  line
  line `(ii) sub-section (2) shall be omitted;`
  line
  line `(g) in section 14, the words "the provisions of this Act cease to be applicable to any town, or"`
  line `shall be omitted;`
  line
  line `(h) in section 15, after the word "instituted", the words "or if instituted, continued", shall be`
  line inserted;
  line
  line `(i) in section 18, sub-section (4) shall be omitted;`
  line
  line `(j) in section 21, the words "or deemed to have been passed" shall be omitted;`
  line
  line `(k) in section 22, the words "or deemed to have been made" shall be omitted;`
  line
  line `(l) section 23, section 27 and the Schedule shall be omitted;`
  line
  line `(m) in sections 24 and 25, the words "or deemed to have been made" shall be omitted.`
  line
  line `^2[(2) Any law relating to the control of rent and regulation of house accommodation in force in the`
  line `cantonment of Mhow immediately before the commencement therein of the Madhya Bharat`
  line `Accommodation Control Act, 1955 (Madhya Bharat Act 23 of 1955), shall be, and shall be deemed`
  line `always to have been, extended to that cantonment under section 3 of this Act with effect from the`
  line `commencement of such law in that cantonment or from the commencement of this Act, whichever is`
  line `later:`
  line
  line `Provided that no such law shall continue, and shall be deemed to have continued, in force in the`
  line `cantonment of Mhow on and from the commencement therein of the Madhya Bharat Accommodation`
  line `Control Act, 1955 (Madhya Bharat Act 23 of 1955).`
  line
  line `(3) Where, before the extension under sub-section (2) of any law to the cantonment of Mhow,--`
  line
  line `(i) any decree or order for the regulation of, or for eviction from, any house accommodation in`
  line `that cantonment; or`
  line
  line `(ii) any order in the proceedings for the execution of such decree or order; or`
  line
  line `(iii) any order relating to the control of rent or other incident of such house accommodation,`
  line
  line `was made by any court, tribunal or other authority in accordance with any law for the control of rent and`
  line `regulation of house accommodation for the time being in force in that cantonment, such decree or order`
  line `shall, on and from the commencement of such law in that cantonment, be deemed to have been made`
  line `under the corresponding provisions of the first-mentioned Act as if the said Act were in force in that`
  line `cantonment on the date on which such decree or order was made.]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Section 4 re-numbered as sub-section (1) thereof by Act 22 of 1972, s. 4 (w.e.f. 26-1-1950).`
  line
  line `2. Ins. by Act 22 of 1972, s. 4 (w.e.f. 26-1-1950).`
