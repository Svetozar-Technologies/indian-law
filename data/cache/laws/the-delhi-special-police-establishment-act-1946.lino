  (str slug) (str the-delhi-special-police-establishment-act-1946)
  (str handle) (str 2258)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Delhi Special Police Establishment Act, 1946`)
  (str actNumber) (str 25)
  (str enactmentDate) (str 1946-11-19)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2258`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `दिल्ली विशेष पुलिस स्थापन अधिनियम, 1946`)
  (str actYear) (str 1946)
  (str ministry) (str `Ministry of Personnel, Public Grievances and Pensions`)
  (str department) (str `Department of Personnel and Training`)
  (str longTitle) (str `An Act to make provision for the constitution of a special police force in Delhi for the investigation of certain offences in the Union territories for the superintendence and administration of the said force and for the extension to other areas 3* * * of the powers and jurisdiction of members of the said force in regard to the investigation of the said offences.`)
  (str enforcementDate) (str 19-11-1946)
  (str notification) (str -)
