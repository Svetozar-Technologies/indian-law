obj_root_law_sections_1:
  sectionId (38419)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38419&sectionno=1&orderno=1&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Delhi Special Police Establishment`
  line `Act, 1946.`
  line
  line `(2) It extends to the whole of India ^1***.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" which were subs. by Act 3 of 1951, s. 3 and the Schedule, for "except`
  line `Part B State" omitted by Act 62 of 1956, s. 2 and the Sch.`
obj_root_law_sections_1_a:
  sectionId (38420)
  sectionNo 1A
  orderNo 2
  title `Interpretation section.`
  content obj_root_law_sections_1_a_content
  footnotes `1. Ins. by Act 45 of 2003, s. 26 (w.e.f. 11-9-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38420&sectionno=1A&orderno=2&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_1_a_content:
  string
  line `^1[1A. Interpretation section.-- Words and expressions used herein and not defined but defined in`
  line `the Central Vigilance Commission Act, 2003 (45 of 2003), shall have the meanings, respectively,`
  line `assigned to them in that Act.]`
obj_root_law_sections_2:
  sectionId (38421)
  sectionNo (2)
  orderNo 3
  title `Constitution and powers of special police establishment.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38421&sectionno=2&orderno=3&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_2_content:
  string
  line `(1) Notwithstanding anything in`
  line `the Police Act, 1861 (5 of 1861), the Central Government may constitute a special police force to be`
  line `called the Delhi Special Police Establishment ^1*** for the investigation ^2[in any ^3[Union territory]] of`
  line `offences notified under section 3.`
  line
  line `(2) Subject to any orders which the Central Government may make in this behalf, members of`
  line `the said police establishment shall have throughout ^4[any ^3[Union territory]], in relation to the`
  line `investigation of such offences and arrest of persons concerned in such offences, all the powers,`
  line `duties, privileges and liabilities which police officers of ^5[that Union territory] have in`
  line `connection with the investigation of offences committed therein.`
  line
  line `(3) Any member of the said police establishment of or above the rank of Sub-Inspector`
  line `may, subject to any orders which the Central Government may make in this behalf, exercise in`
  line `^4[any ^3[Union territory]] any of the powers of the officer in charge of a police station in`
  line `the area in which he is for the time being and when so exercising such powers shall, subject to any such orders as aforesaid, be deemed to be an officer in charge of a police station discharging`
  line `functions of such an officer within the limits of his station.`
obj_root_law_sections_2_footnotes:
  string
  line `1. The words "for the State of Delhi" omitted by Act 26 of 1952, s. 3.`
  line `2. Subs. by s. 3, ibid., for "in that State".`
  line `3. Subs., by the A.O. 1956, for “Part C State”.`
  line `4. Subs., ibid., for "the State of Delhi".`
  line `5. Subs., ibid., for "that State".`
obj_root_law_sections_3:
  sectionId (38422)
  sectionNo (3)
  orderNo 4
  title `Offences to be investigated by special police establishment.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38422&sectionno=3&orderno=4&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_3_content:
  string
  line `The Central`
  line `Government may, by notification in the Official Gazette, specify the offences or classes of`
  line `offences ^1*** which are to be investigated by the Delhi Special Police Establishment.`
obj_root_law_sections_3_footnotes:
  string
  line `1. The words "committed in connection with matters concerning Departments of the Central Government" omitted by Act 26 of`
  line `1952, s. 5.`
obj_root_law_sections_4:
  sectionId (38423)
  sectionNo (4)
  orderNo 5
  title `Superintendence and administration of Special Police Establishment.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 45 of 2003, s. 26, for section 4 (w.e.f. 11-9-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38423&sectionno=4&orderno=5&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_4_content:
  string
  line `^1[4. Superintendence and administration of Special Police Establishment.--(1) The`
  line `superintendence of the Delhi Special Police Establishment in so far as it relates to investigation of`
  line `offences alleged to have been committed under the Prevention of Corruption Act, 1988 (49 of 1988),`
  line `shall vest in the Commission.`
  line
  line `(2) Save as otherwise provided in sub-section (1), the superintendence of the said police establishment`
  line `in all other matters shall vest in the Central Government.`
  line
  line `(3) The administration of the said police establishment shall vest in an officer appointed in this behalf`
  line `by the Central Government (hereinafter referred to as the Director) who shall exercise in respect of that`
  line `police establishment such of the powers exercisable by an Inspector-General of Police in respect of the`
  line `police force in a State as the Central Government may specify in this behalf.]`
obj_root_law_sections_4_a:
  sectionId (38424)
  sectionNo 4A
  orderNo 6
  title `Committee for appointment of Director.`
  content obj_root_law_sections_4_a_content
  footnotes obj_root_law_sections_4_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38424&sectionno=4A&orderno=6&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_4_a_content:
  string
  line `^1[4A. Committee for appointment of Director.--^2[(1) The Central Government shall appoint the`
  line `Director on the recommendation of the Committee consisting of--`
  line
  line `(a) the Prime Minister -- Chairperson;`
  line
  line `^3[(b) the Leader of Opposition recognised -- Member;]`
  line
  line `as such in the House of the People or where`
  line
  line `there is no such Leader of Opposition, then`
  line
  line `the Leader of the single largest Opposition`
  line
  line `Party in that House`
  line
  line `(c) the Chief Justice of India or Judge of the Supreme -- Member.]`
  line
  line `Court nominated by him`
  line
  line `^4[(2) No appointment of a Director shall be invalid merely by reason of any vacancy or absence of a`
  line `Member in the Committee.]`
  line
  line `(3) The Committee shall recommend a panel of officers--`
  line
  line `(a) on the basis of seniority, integrity and experience in the investigation of anti-corruption cases;`
  line and
  line
  line `(b) chosen from amongst officers belonging to the Indian Police Service constituted under the`
  line `All-India Services Act, 1951 (61 of 1951),`
  line
  line `for being considered for appointment as the Director.]`
obj_root_law_sections_4_a_footnotes:
  string
  line `1. Subs. by Act 45 of 2003, s. 26, for section 4 (w.e.f. 11-9-2003).`
  line
  line `2. Subs. by Act 1 of 2014, s. 58 and the Schedule, for sub-section (1) (w.e.f. 16-1-2014).`
  line
  line `3. Subs. by Act 28 of 2014, s. 2, for clause (b) (w.e.f. 29-11-2014).`
  line
  line `4. Ins. by s. 2, ibid. (w.e.f. 29-11-2014).`
obj_root_law_sections_4_b:
  sectionId (38425)
  sectionNo 4B
  orderNo 7
  title `Terms and conditions of service of Director.`
  content obj_root_law_sections_4_b_content
  footnotes obj_root_law_sections_4_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38425&sectionno=4B&orderno=7&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_4_b_content:
  string
  line `^1[4B. Terms and conditions of service of Director.--(1) The Director shall, notwithstanding anything`
  line `to the contrary contained in the rules relating to his conditions of service, continue to hold office for a`
  line `period of not less than two years from the date on which he assumes office.`
  line
  line `^2[Provided That the period for which the Director holds the office on his initial appointment may, in public interest, on the recommendation of the Committee under sub-section (1) of section 4A and for the reasons to be recorded in writing, Be extended up to one year at a time :.`
  line
  line `Provided further that no such extension shall be granted after the completion of a period of five years in total including the period mentioned in the initial appointment.].`
  line
  line `(2) The Director shall not be transferred except with the previous consent of the Committee referred`
  line `to in sub-section (1) of section 4A.]`
obj_root_law_sections_4_b_footnotes:
  string
  line `1. Subs. by Act 45 of 2003, s. 26, for section 4 (w.e.f. 11-9-2003).`
  line
  line `2 Ins. by Act 45 of 2021, s. 2 (w.e.f. 14-11-2021).`
obj_root_law_sections_4_ba:
  sectionId (38426)
  sectionNo 4BA
  orderNo 8
  title `Director of Prosecution.`
  content obj_root_law_sections_4_ba_content
  footnotes obj_root_law_sections_4_ba_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38426&sectionno=4BA&orderno=8&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_4_ba_content:
  string
  line `^1[ ^2[4BA. Director of Prosecution. --(1) There shall be a Directorate of Prosecution headed by a Director`
  line `who shall be an officer not below the rank of Joint Secretary to the Government of India, for conducting`
  line `prosecution of cases under this Act.`
  line
  line `(2) The Director of Prosecution shall function under the overall supervision and control of the Director.`
  line
  line `(3) The Central Government shall appoint the Director of Prosecution on the recommendation of the`
  line `Central Vigilance Commission.`
  line
  line `(4) The Director of Prosecution shall nothwithstanding anything to the contrary contained in the rules`
  line `relating to hi conditions of service, continue to hold office for a period of not less than two years from the date`
  line `on which he assumes office.]]`
obj_root_law_sections_4_ba_footnotes:
  string
  line `1. Subs. by Act 45 of 2003, s. 26, for section 4 (w.e.f. 11-9-2003).`
  line
  line `2. Ins. by Act 1 of 2014, s. 58 and the Schedule (w.e.f. 16-1-2014).`
obj_root_law_sections_4_c:
  sectionId (38432)
  sectionNo 4C
  orderNo 9
  title `Appointment for posts of Superintendent of Police and above, extension and curtailment of their tenure, etc.`
  content obj_root_law_sections_4_c_content
  footnotes obj_root_law_sections_4_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38432&sectionno=4C&orderno=9&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_4_c_content:
  string
  line `^1[4C. Appointment for posts of Superintendent of Police and above, extension and curtailment of`
  line `their tenure, etc.--^2[(1) The Central Government shall appoint officers to the posts of the level of`
  line `Superintendent of Police and above except Director, and also recommend the extension or curtailment of`
  line `the tenure of such officers in the Delhi Special Police Establishment, on the recommendation of a`
  line `committee consisting of : --`
  line
  line `(a) the Central Vigilance Commissioner --Chairperson;`
  line
  line `(b) Vigilance Commissioners --Members;`
  line
  line `(c) Secretary to the Government of India in --Members;`
  line
  line `Charge of the Ministry of Home`
  line
  line `(d) Secretary to the Government of India in charge of the --Members:`
  line
  line `Department of Personnel`
  line
  line `Provided that the Committee shall consult the Director before submitting its recommendation to the`
  line `Central Government.]`
  line
  line `(2) On receipt of the recommendation under sub-section (1), the Central Government shall pass such`
  line `orders as it thinks fit to give effect to the said recommendation.]`
obj_root_law_sections_4_c_footnotes:
  string
  line `1. Subs. by Act 45 of 2003, s. 26, for section 4 (w.e.f. 11-9-2003).`
  line
  line `2. Subs. by s. 58 and the Schedule, ibid., for sub-section (1) (w.e.f. 16-1-2014).`
obj_root_law_sections_5:
  sectionId (38428)
  sectionNo (5)
  orderNo 10
  title `Extension of powers and jurisdiction of special police establishment to other areas.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38428&sectionno=5&orderno=10&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_5_content:
  string
  line `(1) The`
  line `Central Government may by order extend to any area (including Railway areas) ^1[in ^2[a State, not being a`
  line `Union territory]] the powers and jurisdiction of members of the Delhi Special Police Establishment for`
  line `the investigation of any offences or classes of offences specified in a notification under section 3.`
  line
  line `(2) When by an order under sub-section (1) the powers and jurisdiction of members of the said police`
  line `establishment are extended to any such area, a member thereof may, subject to any orders which the`
  line `Central Government may make in this behalf, discharge the functions of a police officer in that area and`
  line `shall, while so discharging such functions, be deemed to be a member of the police force of that area and`
  line `be vested with the powers, functions and privileges and be subject to the liabilities of a police officer`
  line `belonging to that police force.`
  line
  line `^3[(3) Where any such order under sub-section (1) is made relation to any area, then, without prejudice`
  line `prejudice to the provisions of sub-section (2), any member of the Delhi Special Police Establishment of or`
  line `above the rank of Sub-Inspector may, subject to any orders which the Central Government may make in`
  line `this behalf, exercise the powers of the officer in charge of a police station in that area and when so exercising such powers, shall be deemed to be an officer in charge of a police station discharging the`
  line `functions of such an officer within the limits of his station.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 26 of 1952, s. 5, for "in India outside the State of Delhi".`
  line
  line `2. Subs. by the A.O. 1956, for "a Part A State or a Part B State".`
  line
  line `3. Ins. by Act 40 of 1964, s. 5.`
obj_root_law_sections_6:
  sectionId (38429)
  sectionNo (6)
  orderNo 11
  title `Consent of State Government to exercise of powers and jurisdiction.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38429&sectionno=6&orderno=11&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_6_content:
  string
  line `^1[6. Consent of State Government to exercise of powers and jurisdiction.--Nothing contained`
  line `in section 5 shall be deemed to enable any member of the Delhi Special Police Establishment to`
  line `exercise powers and jurisdiction in any area in ^2[a State, not being a Union territory or railway area],`
  line `without the consent of the Government of that State.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 26 of 1952, s. 6 for section 6.`
  line
  line `2. Subs. by the A.O. 1956, for "a Part A State or a Part B State, not being a railway area".`
obj_root_law_sections_6_a:
  sectionId (38430)
  sectionNo 6A
  orderNo 12
  title `Approval of Central Government to conduct, inquiry or investigation.`
  content obj_root_law_sections_6_a_content
  footnotes `1. Ins. by Act 45 of 2003, s. 26 (w.e.f. 11-9-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38430&sectionno=6A&orderno=12&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_6_a_content:
  string
  line `^* ^1[6A. Approval of Central Government to conduct, inquiry or investigation.-- (1) The Delhi`
  line `Special Police Establishment shall not conduct any inquiry or investigation into any offence alleged to have been`
  line `committed under the Prevention of Corruption Act, 1988 (49 of 1988) except with the previous approval`
  line `of the Central Government where such allegation relates to--`
  line
  line `(a) the employees of the Central Government of the level of Joint Secretary and above; and`
  line
  line `(b) such officers as are appointed by the Central Government in corporations established by or`
  line `under any Central Act, Government companies, societies and local authorities owned or controlled by`
  line `that Government.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no such approval shall be necessary for cases`
  line `involving arrest of a person on the spot on the charge of accepting or attempting to accept any gratification`
  line `other than legal remuneration referred to in clause (c) of the Explanation to section 7 of the Prevention of`
  line `Corruption Act, 1988 (49 of 1988)].`
obj_root_law_sections_7:
  sectionId (38431)
  sectionNo (7)
  orderNo 13
  title [Repealed.].
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00012_00012_1523948002193&sectionId=38431&sectionno=7&orderno=13&orgactid=AC_CEN_26_36_00012_00012_1523948002193
obj_root_law_sections_7_content:
  string
  line `[Repeal of Ordinance 22 of 1946.] Rep. by the Repealing and Amending Act, 1950 (35 of 1950),`
  line `s. 2 and Sch. I.`
obj_root_law_sections_7_footnotes:
  string
  line
