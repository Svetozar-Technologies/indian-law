  slug the-digital-personal-data-protection-act-2023
  handle (22037)
  collectionHandle 123456789/1362
  title `The Digital Personal Data Protection Act, 2023.`
  actNumber (22)
  enactmentDate 2023-08-11
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/22037`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (2023)
  ministry `Ministry of Electronics and Information Technology`
  department undefined
  longTitle `An Act to provide for the processing of digital personal data in a manner that recognises both the right of individuals to protect their personal data and the need to process such personal data for lawful purposes and for matters connected therewith or incidental thereto.`
  enforcementDate undefined
  notification undefined
  fetchedAt `2026-05-10T14:22:30.221Z`
