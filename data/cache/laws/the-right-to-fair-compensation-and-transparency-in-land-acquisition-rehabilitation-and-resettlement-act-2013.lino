obj_root_law:
  object
  (str slug) (str the-right-to-fair-compensation-and-transparency-in-land-acquisition-rehabilitation-and-resettlement-act-2013)
  (str handle) (str 2121)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Right to Fair Compensation and Transparency in Land Acquisition, Rehabilitation and Resettlement Act, 2013`)
  (str actNumber) (str 30)
  (str enactmentDate) (str 2013-09-26)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2121`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भूमि अर्जन, पुनर्वासन और पुनर्व्यिवस्थारपन मेंउचित प्रतिकर और पारदर्शिता अधिकारअधिनियम, 2013`)
  (str actYear) (str 2013)
  (str ministry) (str `Ministry of Rural Development`)
  (str department) (str `Department of Land Resources`)
  (str longTitle) (str `An Act to ensure, in consultation with institutions of local self-government and Gram Sabhas established under the Constitution, a humane, participative, informed and transparent process for land acquisition for industrialisation, development of essential infrastructural facilities and urbanisation with the least disturbance to the owners of the land and other affected families and provide just and fair compensation to the affected families whose land has been acquired or proposed to be acquired or are affected by such acquisition and make adequate provisions for such affected persons for their rehabilitation and resettlement and for ensuring that the cumulative outcome of compulsory acquisition should be that affected persons become partners in development leading to an improvement in their post acquisition social and economic status and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-01-2014)
  (str notification) (str `1st January 2014, vide notification No. 3729 (E), dated 19th December, 2013, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T00:36:25.147Z`)
  (str translations) obj_root_law_translations
