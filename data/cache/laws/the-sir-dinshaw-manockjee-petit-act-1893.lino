obj_root_law:
  slug the-sir-dinshaw-manockjee-petit-act-1893
  handle (19225)
  collectionHandle 123456789/1362
  title `The Sir Dinshaw Manockjee Petit Act, 1893`
  actNumber (06)
  enactmentDate 1893-03-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/19225`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (1893)
  ministry `Ministry of Home Affairs`
  department `Department of States`
  longTitle `An Act for settling Bonds of the Municipal Corporation of the City of Bombay producing an annual income of one lakh and twenty five thousand rupees and a Mansion-house and hereditaments called Petit Hall in the Island of Bombay, the property of Sir Dinshaw Manockjee Petit, Baronet, so as to accompany and support the title and dignity of a Baronet lately conferred by Her Present Majesty Queen Victoria on him for and during the term of his natural life, and from and immediately after his decease to hold to his second son, Framjee Dinshaw Petit, Esquire, and the heirs male of his body lawfully begotten, and in default of such issue with remainder to the heirs male of the body of the said Sir Dinshaw Manockjee Petit, and for other purposes connected therewith.`
  enforcementDate undefined
  notification undefined
