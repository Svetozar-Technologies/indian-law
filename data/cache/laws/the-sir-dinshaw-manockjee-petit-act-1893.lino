obj_root_law:
  object
  (str slug) (str the-sir-dinshaw-manockjee-petit-act-1893)
  (str handle) (str 19225)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Sir Dinshaw Manockjee Petit Act, 1893`)
  (str actNumber) (str 06)
  (str enactmentDate) (str 1893-03-09)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/19225`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (undefined)
  (str actYear) (str 1893)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of States`)
  (str longTitle) (str `An Act for settling Bonds of the Municipal Corporation of the City of Bombay producing an annual income of one lakh and twenty five thousand rupees and a Mansion-house and hereditaments called Petit Hall in the Island of Bombay, the property of Sir Dinshaw Manockjee Petit, Baronet, so as to accompany and support the title and dignity of a Baronet lately conferred by Her Present Majesty Queen Victoria on him for and during the term of his natural life, and from and immediately after his decease to hold to his second son, Framjee Dinshaw Petit, Esquire, and the heirs male of his body lawfully begotten, and in default of such issue with remainder to the heirs male of the body of the said Sir Dinshaw Manockjee Petit, and for other purposes connected therewith.`)
  (str enforcementDate) (undefined)
  (str notification) (undefined)
