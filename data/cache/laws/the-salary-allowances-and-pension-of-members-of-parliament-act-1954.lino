  (str orderNo) (int 21)
  (str title) (str Repealed.)
  (str content) (str `[Validation of payment of certain travelling allowances.] Rep. by the Repealing and Amending
Act, 1960 (58 of 1960), s. 2 and the First Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00003_195430_1517807322476&sectionId=10769&sectionno=10&orderno=21&orgactid=AC_CEN_33_52_00003_195430_1517807322476)
