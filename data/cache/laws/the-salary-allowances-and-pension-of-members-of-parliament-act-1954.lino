obj_root_law_translations_hi_sections_12:
  kind page
  sectionId pdf-page-12
  sectionNo (12)
  orderNo 12
  title `Page 12`
  content obj_root_law_translations_hi_sections_12_content
  footnotes obj_root_law_translations_hi_sections_12_footnotes
  sourcePage 12
obj_root_law_translations_hi_sections_12_content:
  string
  line 12
  line `(4) उपिारा ( 3 ) के अिी न बनाए गए धनयम तब तक प्र भावी नहीं होंगे जब तक वे राज्य सभा के सभापधत द्व ारा तथा िोक`
  line `सभा के अध्य ि द्व ारा अनुमोददत तथा पुष्ट न दकए जाएं तथा राजपत्र में प्र काधशत न कर ददए जाएं और धनयमों का ऐसा प्र काशन इस`
  line `बात का धनश्चा यक सबूत होगा दक वे सम्य क् रू प से बना ए गए हैं।`
  line `10. कधतपय यात्रा भत्तों के संदाय का धवधिमान्य करण –– धनरसन तथा संशोिन अधिधनयम, 1960 (1960 का 58 ) की िारा 2`
  line `तथा अनुसूची 1 द्व ारा धनरधसत।`
  line _______
obj_root_law_translations_hi_sections_12_footnotes:
  string
  line
