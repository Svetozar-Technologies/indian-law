obj_root_law_sections_1:
  object
  (str sectionId) (str 54989)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Sikh Gurdwaras (Supplementary-) Act, 1925.

(2) It shall come into force on the date^1 appointed by the ^2 ^3(State Government), under sub-section (3) of section 1 of the Sikh Gurdwaras Act, 1925.`)
  (str footnotes) (str `1. It came into force on the 1st January, 1926.

2. Substituted for the words “Local Government” by the Government of India (Adaptation of Indian Laws) Order, 1937.

3. Substituted for the word “Provincial” by Adaptation of Laws Order, 1950.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_192424_1623833765446&sectionId=54989&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00080_192424_1623833765446)
obj_root_law_sections_2:
  object
  (str sectionId) (str 54990)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Validation of certain provisions of Punjab Act 8 of 1925.`)
  (str content) (str `The Sikh Gurdwaras Act, 1925 (hereinafter referred to as the said Act), shall so far as it adds to or takes from the jurisdiction of the ^1High Court of ^2(Punjab) or prescribes the procedure of the said Court, be as valid as if it had been passed by the Indian Legislature.`)
  (str footnotes) (str `1.Substituted for the words “High Court of Judicature of Lahore” by the India (Adaptation of Existing Laws) Order, 1947.

2. Substituted for “East Punjab” by Adaptation of Laws, Order, 1950.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_192424_1623833765446&sectionId=54990&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00080_192424_1623833765446)
obj_root_law_sections_3:
  object
  (str sectionId) (str 54991)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str Repealed.)
  (str content) (str `^1Repealed by the Repealing Act, 1938 (1 of 1938), section 2 and Schedule.`)
  (str footnotes) (str `1.The amendment to s. 12 of the Sikh Gurudwaras act, 1925, directed by this section were omitted by the Government of India (Adaptation of Indian Laws) Order, 1937 section later repealed by Central Act 1 of 1938, schedule.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_192424_1623833765446&sectionId=54991&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00080_192424_1623833765446)
