  sectionId (54989)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_192424_1623833765446&sectionId=54989&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00080_192424_1623833765446
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Sikh Gurdwaras (Supplementary-) Act, 1925.`
  line
  line `(2) It shall come into force on the date^1 appointed by the ^2 ^3(State Government), under sub-section (3) of section 1 of the Sikh Gurdwaras Act, 1925.`
obj_root_law_sections_1_footnotes:
  string
  line `1. It came into force on the 1st January, 1926.`
  line
  line `2. Substituted for the words “Local Government” by the Government of India (Adaptation of Indian Laws) Order, 1937.`
  line
  line `3. Substituted for the word “Provincial” by Adaptation of Laws Order, 1950.`
obj_root_law_sections_2:
  sectionId (54990)
  sectionNo (2)
  orderNo 2
  title `Validation of certain provisions of Punjab Act 8 of 1925.`
  content `The Sikh Gurdwaras Act, 1925 (hereinafter referred to as the said Act), shall so far as it adds to or takes from the jurisdiction of the ^1High Court of ^2(Punjab) or prescribes the procedure of the said Court, be as valid as if it had been passed by the Indian Legislature.`
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_192424_1623833765446&sectionId=54990&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00080_192424_1623833765446
obj_root_law_sections_2_footnotes:
  string
  line `1.Substituted for the words “High Court of Judicature of Lahore” by the India (Adaptation of Existing Laws) Order, 1947.`
  line
  line `2. Substituted for “East Punjab” by Adaptation of Laws, Order, 1950.`
obj_root_law_sections_3:
  sectionId (54991)
  sectionNo (3)
  orderNo 3
  title Repealed.
  content `^1Repealed by the Repealing Act, 1938 (1 of 1938), section 2 and Schedule.`
  footnotes `1.The amendment to s. 12 of the Sikh Gurudwaras act, 1925, directed by this section were omitted by the Government of India (Adaptation of Indian Laws) Order, 1937 section later repealed by Central Act 1 of 1938, schedule.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_192424_1623833765446&sectionId=54991&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00080_192424_1623833765446
