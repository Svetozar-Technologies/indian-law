obj_root_law_sections_1:
  sectionId (47885)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1 1st April, 1968, vide notification No. S.O. 1225, dated 1st April, 1968, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47885&sectionno=1&orderno=1&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Railway Property`
  line `(Unlawful Possession) Act, 1966.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_2:
  sectionId (47886)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47886&sectionno=2&orderno=2&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Force" means the Railway Protection Force constituted under section 3 of the Railway`
  line `Protection Force Act, 1957 (23 of 1957);`
  line
  line `(b) "member of the Force" means a person appointed to the Force, other than a superior officer;`
  line
  line `(c) "officer of the Force" means an officer of and above the rank of Assistant Sub-Inspector`
  line `appointed to the Force and includes a superior officer;`
  line
  line `(d) "railway property" includes any goods, money or valuable security or animal, belonging to, or`
  line `in the charge or possession of, a railway administration;`
  line
  line `(e) "superior officer" means any of the officers appointed under section 4 of the Railway`
  line `Protection Force Act, 1957 (23 of 1957), and includes any other officer appointed by the Central`
  line `Government as a superior officer of the force;`
  line
  line `(f) words and expressions used but not defined in this Act and defined in the Indian Railways`
  line `Act, 1890 (9 of 1890), shall have the meanings respectively assigned to them under that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47887)
  sectionNo (3)
  orderNo 3
  title `Penalty for theft, dishonest misappropriation or unlawful possession of railway property.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47887&sectionno=3&orderno=3&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_3_content:
  string
  line 3.
  line ^1
  line `[Penalty for theft, dishonest misappropriation or unlawful possession of railway`
  line property].--^2
  line `[Whoever commits theft, or dishonestly misappropriates or is found, or is proved] to have`
  line `been, in possession of any railway property reasonably suspected of having been stolen or unlawfully`
  line `obtained shall, unless he proves that the railway property came into his possession lawfully, be`
  line punishable--
  line
  line `(a) for the first offence, with imprisonment for a term which may extend to five years, or with`
  line `fine, or with both and in the absence of special and adequate reasons to be mentioned in the judgment`
  line `of the court, such imprisonment shall not be less than one year and such fine shall not be less than one`
  line `thousand rupees;`
  line
  line `(b) for the second or a subsequent offence, with imprisonment for a term which may extend to`
  line `five years and also with fine and in the absence of special and adequate reasons to be mentioned in`
  line `the judgment of the court, such imprisonment shall not be less than two years and such fine shall not`
  line `be less than two thousand rupees.`
  line
  line ^3
  line `[Explanation.--For the purposes of this section, "theft" and "dishonest misappropriation" shall have`
  line `the same meanings as assigned to them respectively in section 378 and section 403 of the Indian Penal`
  line `Code (45 of 1860).]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 25 of 2012, s. 2, for the marginal heading (w.e.f. 15-8-2012).`
  line
  line `2. Subs. by s. 2, ibid., for "Whoever is found, or is proved" (w.e.f. 15-8-2012).`
  line
  line `3. Explanation ins. by s. 2, ibid. (w.e.f. 15-8-2012).`
obj_root_law_sections_4:
  sectionId (47888)
  sectionNo (4)
  orderNo 4
  title `Punishment for abetment, conspiracy or connivance at offences.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47888&sectionno=4&orderno=4&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_4_content:
  string
  line 4.
  line ^1
  line `[Punishment for abetment, conspiracy or connivance at offences.]--^2`
  line `[Whoever abets or`
  line `conspires in the commission of an offence punishable under this Act, or any owner] or occupier of land or`
  line `building, or any agent of such owner or occupier in charge of the management of that land or building,`
  line `who wilfully connives at an offence against the provisions of this Act, shall be punishable with`
  line `imprisonment for a term which may extend to five years, or with fine, or with both.`
  line
  line ^3
  line `[Explanation.--For the purposes of this section, the words "abet" and "conspire" shall have the same`
  line `meanings as assigned to them respectively in sections 107 and 120A of the Indian Penal`
  line `Code (45 of 1860.)]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 25 of 2012, s. 3, for the marginal heading (w.e.f. 15-8-2012).`
  line
  line `2. Subs. by s. 3, ibid., for "Any owner" (w.e.f. 15-8-2012).`
  line
  line `3. Explanation ins. by s. 3, ibid. (w.e.f. 15-8-2012).`
obj_root_law_sections_5:
  sectionId (47889)
  sectionNo (5)
  orderNo 5
  title `Offences under the Act not to be cognizable.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47889&sectionno=5&orderno=5&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_5_content:
  string
  line `Notwithstanding anything contained in the Code`
  line `of Criminal Procedure, 1898 (5 of 1898), an offence under this Act shall not be cognizable`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47890)
  sectionNo (6)
  orderNo 6
  title `Power to arrest without warrant.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47890&sectionno=6&orderno=6&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_6_content:
  string
  line `Any superior officer or member of the Force may, without an`
  line `order from a Magistrate and without a warrant, arrest any person who has been concerned in an offence`
  line `punishable under this Act or against whom a reasonable suspicion exists of his having been so concerned.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47891)
  sectionNo (7)
  orderNo 7
  title `Disposal of persons arrested.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47891&sectionno=7&orderno=7&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_7_content:
  string
  line `Every person arrested for an offence punishable under this Act`
  line `shall, if the arrest was made by a person other than an officer of the Force, be forwarded without delay to`
  line `the nearest officer of the Force.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47892)
  sectionNo (8)
  orderNo 8
  title `Inquiry how to be made.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47892&sectionno=8&orderno=8&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_8_content:
  string
  line 8.
  line ^1
  line `[Inquiry how to be made].--(1)`
  line ^2
  line `[When an officer of the Force receives information about the`
  line `commission of an offence punishable under this Act, or when any person is arrested] by an officer of the`
  line `Force for an offence punishable under this Act or is forwarded to him under section 7, he shall proceed to`
  line `inquire into the charge against such person.`
  line
  line `(2) For this purpose the officer of the Force may exercise the same powers and shall be subject to the`
  line `same provisions as the officer incharge of a police-station may exercise and is subject to under the Code`
  line `of Criminal Procedure, 1898 (5 of 1898), when investigating a cognizable case:`
  line
  line `Provided that--`
  line
  line `(a) if the officer of the Force is of opinion that there is sufficient evidence or reasonable ground`
  line `of suspicion against the accused person, he shall either admit him to bail to appear before a`
  line `Magistrate having jurisdiction in the case, or forward him in custody to such Magistrate;`
  line
  line `(b) if it appears to the officer of the Force that there is not sufficient evidence or reasonable`
  line `ground of suspicion against the accused person, he shall release the accused person on his executing a`
  line `bond, with or without sureties as the officer of the Force may direct, to appear, if and when so`
  line `required before the Magistrate having jurisdiction, and shall make a full report of all the particulars of`
  line `the case to his official superior.`
obj_root_law_sections_8_footnotes:
  string
  line `1. Subs. by s. 4, ibid., for the marginal heading (w.e.f. 15-8-2012).`
  line
  line `2. Subs. by s. 4, ibid., for "When any person is arrested" (w.e.f. 15-8-2012).`
obj_root_law_sections_9:
  sectionId (47893)
  sectionNo (9)
  orderNo 9
  title `Power to summon persons to give evidence and produce documents.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47893&sectionno=9&orderno=9&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_9_content:
  string
  line `(1) An officer of the`
  line `Force shall have power to summon any person whose attendance he considers necessary either to give`
  line `evidence or to produce a document, or any other thing in any inquiry which such officer in making for`
  line `any of the purposes of this Act.`
  line
  line `(2) A summons to produce documents or other things may be for the production of certain specified`
  line `documents or things or for the production of all documents or things of a certain description in the`
  line `possession or under the control of the person summoned.`
  line
  line `(3) All persons, so summoned, shall be bound to attend either in person or by an authorised agent as`
  line `such officer may direct; and all persons so summoned shall be bound to state the truth upon any subject`
  line `respecting which they are examined or make statements and to produce such documents and other things`
  line `as may be required:`
  line
  line `Provided that the exemptions under sections 132 and 133 of the Code of Civil`
  line `Procedure, 1908 (5 of 1908), shall be applicable to requisitions for attendance under this section.`
  line
  line `(4) Every such inquiry as aforesaid, shall be deemed to be a "judicial proceeding" within the meaning`
  line `of sections 193 and 228 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47894)
  sectionNo (10)
  orderNo 10
  title `Issue of search warrant.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47894&sectionno=10&orderno=10&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_10_content:
  string
  line `(1) If an officer of the Force has reason to believe that any place is`
  line `used for the deposit or sale of railway property which had been stolen or unlawfully obtained, he shall`
  line `make an application to the Magistrate, having jurisdiction over the area in which that place is situate, for`
  line `issue of a search warrant.`
  line
  line `(2) The Magistrate to whom an application is made under sub-section (1), may, after such inquiry as`
  line `he thinks necessary, by his warrant authorise any officer of the Force--`
  line
  line `(a) to enter, with such assistance as may be required, such place;`
  line
  line `(b) to search the same in the manner specified in the warrant;`
  line
  line `(c) to take possession of any railway property therein found which he reasonably suspects to be`
  line `stolen or unlawfully obtained; and`
  line
  line `(d) to convey such railway property before a Magistrate, or to guard the same on the spot until the`
  line `offender is taken before a Magistrate, or otherwise to dispose thereof in some place of safety.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (47895)
  sectionNo (11)
  orderNo 11
  title `Searches and arrests how to be made.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47895&sectionno=11&orderno=11&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_11_content:
  string
  line `All searches and arrests made under this Act shall be`
  line `carried out in accordance with the provisions of the Code of Criminal Procedure, 1898 (5 of 1898),`
  line `relating respectively to searches and arrests made under that Code.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (47896)
  sectionNo (12)
  orderNo 12
  title `Officers required to assist.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47896&sectionno=12&orderno=12&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_12_content:
  string
  line `All officers of Government and all village officers are hereby`
  line `empowered and required to assist the superior officers and members of the Force in the enforcement of`
  line `this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (47897)
  sectionNo (13)
  orderNo 13
  title `Power of courts to order forfeiture of vehicles, etc.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47897&sectionno=13&orderno=13&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_13_content:
  string
  line `Any court trying an offence punishable`
  line `under this Act may order the forfeiture to Government of any property in respect of which the Court is`
  line `satisfied that an offence under this Act has been committed and may also order the forfeiture of any`
  line `receptacles, packages or coverings in which such property is contained, and the animals, vehicles, or other`
  line `conveyances used in carrying the property.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (47898)
  sectionNo (14)
  orderNo 14
  title `Act to override other laws.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47898&sectionno=14&orderno=14&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_14_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (47899)
  sectionNo (15)
  orderNo 15
  title `Construction of references to laws not in force in Jammu and Kashmir.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47899&sectionno=15&orderno=15&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_15_content:
  string
  line `[Construction of references to laws not in force in Jammu and Kashmir].--Omitted by the Jammu`
  line `and Kashmir Reorganization (Adaptation of Central Laws) Order, 2020, vide notification No.`
  line `S.O. 1123(E) dated (18-3-2020) and vide Union Territory of Ladakh Reorganisation (Adaptation of`
  line `Central Laws) Order, 2020, notification No. S.O.3774(E), dated (23-10-2020).`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (47900)
  sectionNo (16)
  orderNo 16
  title `Repeal and savings.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00005_196629_1517807324593&sectionId=47900&sectionno=16&orderno=16&orgactid=AC_CEN_1_1_00005_196629_1517807324593
obj_root_law_sections_16_content:
  string
  line `(1) The Railway Stores (Unlawful Possession) Act, 1955 (51 of 1955), is`
  line `hereby repealed.`
  line
  line `(2) Nothing contained in this Act shall apply to offences punishable under the Act hereby repealed`
  line `and such offences may be investigated and tried as if this Act had not been passed.`
  line
  line `(3) The mention of particular matters in sub-section (2) shall not be held to prejudice or affect the`
  line `general application of section 6 of the General Clauses Act, 1897 (10 of 1897), with regard to the effect of`
  line repeals.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_translations:
