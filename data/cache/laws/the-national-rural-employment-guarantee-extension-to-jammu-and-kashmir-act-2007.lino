obj_root_law_sections_1:
  object
  (str sectionId) (str 37823)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act maybe called the National Rural Employment
Guarantee (Extension to Jammu and Kashmir) Act, 2007.

(2) It shall come into force on such date^1
as the Central Government may, by notification in the
Official Gazette, appoint; and different dates may be appointed for different areas in the State and any
reference to the commencement of this Act shall be construed as a reference to the coming into force of
that Act in such areas.`)
  (str footnotes) (str `1. 6th June, 2007, vide notification no. S.O. 943(E), dated 4th June, 2007, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00012_200723_1517807327001&sectionId=37823&sectionno=1&orderno=1&orgactid=AC_CEN_18_21_00012_200723_1517807327001)
obj_root_law_sections_2:
  object
  (str sectionId) (str 37824)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Extension and amendment of the National Rural Employment Guarantee Act, 2005.`)
  (str content) (str `(1) The
National Rural Employment Guarantee Act, 2005 (42 of 2005) (hereinafter referred to as the principal
Act) and all rules, orders and schemes made thereunder by the Central Government are hereby extended
to, and shall be in force in, the State of Jammu and Kashmir*.

(2) With effect from the date of commencement of this Act, in the principal Act, in sub-section (2) of
section 1, the words "except the State of Jammu and Kashmir*" shall be omitted.`)
  (str footnotes) (str `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00012_200723_1517807327001&sectionId=37824&sectionno=2&orderno=2&orgactid=AC_CEN_18_21_00012_200723_1517807327001)
obj_root_law_sections_3:
  object
  (str sectionId) (str 37825)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Construction of reference to a law not in force in Jammu and Kashmir.`)
  (str content) (str `Any reference in any
Act mentioned in the principal Act to a law which is not in force in the State of Jammu and Kashmir* shall,
in relation to that State, be construed as a reference to the corresponding law, if any, in force in that State.`)
  (str footnotes) (str `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_18_21_00012_200723_1517807327001&sectionId=37825&sectionno=3&orderno=3&orgactid=AC_CEN_18_21_00012_200723_1517807327001)
