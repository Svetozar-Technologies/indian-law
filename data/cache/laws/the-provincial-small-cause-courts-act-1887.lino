  (str sectionId) (str 42996)
  (str sectionNo) (str 15)
  (str orderNo) (int 15)
  (str title) (str `Cognizance of suits by Courts of Small Causes.`)
  (str content) (str )
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42996&sectionno=15&orderno=15&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
