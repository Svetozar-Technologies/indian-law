obj_root_law_sections_1:
  object
  (str sectionId) (str 42982)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Title, extent and commencement.`)
  (str content) (str `(1) This Act may be called the Provincial Small Cause Courts
Act, 1887.

(2) It extends to the whole of India except ^1[the territories which, immediately before the 1st
November, 1956, were comprised in Part B States]; and

(3) It shall come into force on the first day of July, 1887.`)
  (str footnotes) (str `1. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part B States".`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42982&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_2:
  object
  (str sectionId) (str 42983)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str [Repealed.].)
  (str content) (str `[Repeal.] Rep. partly by the Amending Act, 1891 (12 of 1891), s. 2 and the First
Schedule and partly by the Repealing Act, 1938 (1 of 1938), s. 2 and the Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42983&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_3:
  object
  (str sectionId) (str 42984)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str Savings.)
  (str content) (str `Nothing in this Act shall be construed to affect--

(a) any proceedings before or after decree in any suit instituted before the commencement of this
Act; or

(b) The jurisdiction of a Magistrate under any law for the time being in force with respect
to debts or other claims of a civil nature, or of village-munsifs or village-panchayats, under the
provisions of the Madras Code, or of village-munsifs under the Dekkhan Agriculturists’ Relief
Act, 1879 (17 of 1879); or

(c) any local law or any special law other than the Code of Civil Procedure^3

(14 of 1882).`)
  (str footnotes) (str `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42984&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_4:
  object
  (str sectionId) (str 42985)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str Definition.)
  (str content) (str `In this Act, unless there is something repugnant in the subject or context,
"Court of Small Causes" means a Court of Small Causes constituted under this Act, and includes
any person exercising jurisdiction under this Act in any such Court.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42985&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_5:
  object
  (str sectionId) (str 42986)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Establishment of Courts of Small Causes.`)
  (str content) (str `(1) The State Government ^1*** may, by order
in writing, establish a Court of Small Causes at any place within the territories under its
administration beyond the local limits for the time being of the ordinary original civil jurisdiction
of a High Court of Judicature established in a Presidency-town.

(2) The local limits of the jurisdiction of the Court of Small Causes shall be such as the State
Government may define, and the Court may be held at such place or places within those limits as the
State Government may appoint.^2`)
  (str footnotes) (str `1. The words "with the previous sanction of the G. G. in C." rep. by Act 4 of 1914. s. 2 and the Schedule.

2. For notifications issued under cl. (2) of s. 5, see different local R. and O.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42986&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_6:
  object
  (str sectionId) (str 42987)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str Judge.)
  (str content) (str `b@^1[6. Judge.--When a Court of Small Causes has been established there shall be appointed, by order in
writing, a Judge of the Court:

Provided that if the State Government so direct, the same person shall be the Judge of more than one
such Court.]`)
  (str footnotes) (str `1. Subs. by the A.O. 1937, for section 6.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42987&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_7:
  object
  (str sectionId) (str 42988)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Appointment of times of sitting in certain circumstances.`)
  (str content) (str `(1) A Judge who is the
Judge of two or more such Courts may, with the sanction of the District Court, fix the times at
which he will sit in each of the Courts of which he is Judge.

(2) Notice of the times shall be published in such manner as the High Court from time to time directs.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42988&sectionno=7&orderno=7&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_8:
  object
  (str sectionId) (str 42989)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str `Additional Judges.`)
  (str content) (str `^1[(1) If the State Government so direct, there may be appointed, by
order in writing, Additional Judges of a Court of Small Causes or of two or more such Courts.]

(2) ^2[An Additional] Judge shall discharge such of the functions of the Judge of the Court or
Courts as the Judge may assign to him, and in the discharge of those functions shall exercise the
same powers as the Judge.

(3) The Judge may withdraw from ^2[an Additional] Judge any business pending before
him.

(4) When the Judge is absent, the ^4[senior] Additional Judge may discharge all or any of the functions
of the Judge.`)
  (str footnotes) (str `1. Subs., ibid., for the sub-section (1).

2. Subs. by Act 11 of 1915, s. 2 and the First Schedule, for "the Additional".

3. Ins. by s. 2 and the First Schedule, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42989&sectionno=8&orderno=8&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_9:
  object
  (str sectionId) (str 42990)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str [Repealed.].)
  (str content) (str `[Suspension and removal of Judges.] Rep. by the A.O. 1937.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42990&sectionno=9&orderno=9&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_10:
  object
  (str sectionId) (str 42991)
  (str sectionNo) (str 10)
  (str orderNo) (int 10)
  (str title) (str `Power to require two Judges to si t as a bench.`)
  (str content) (str `The State Government, after
consultation with the High Court, may, by order in writing, direct that two Judges of Courts of
Small Causes or a Judge and an Additional Judge of a Court of Small Causes shall sit together
for the trial of such class or classes of suits or applications cognizable by a Court of Small
Causes as may be described in the order.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42991&sectionno=10&orderno=10&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
obj_root_law_sections_11:
  object
  (str sectionId) (str 42992)
  (str sectionNo) (str 11)
  (str orderNo) (int 11)
  (str title) (str `Decision in case heard by a bench.`)
  (str content) (str )
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42992&sectionno=11&orderno=11&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
