  object
  (str sectionId) (str 42997)
  (str sectionNo) (str 16)
  (str orderNo) (int 16)
  (str title) (str `Exclusive jurisdiction of Courts of Small Causes.`)
  (str content) (str )
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00026_188709_1523273740812&sectionId=42997&sectionno=16&orderno=16&orgactid=AC_CEN_3_3_00026_188709_1523273740812)
