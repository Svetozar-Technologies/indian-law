  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  sourcePage 28
obj_root_law_sections_28_content:
  string
  line 28
  line `1 [THE SECOND SCHEDULE`
  line `[ See section 15( 2 )]`
  line `( i ) Convention for the Suppression of Unlawful Seizure of Aircraft (1970);`
  line `( ii ) Convention for the Suppression of Unlawful Acts against the Safety of Civil Aviation ( 1 971);`
  line `( iii ) Convention on the Prevention and Punishment of Crimes against Internationally Protected`
  line `Persons, including Diplomatic Agents (1973);`
  line `( iv ) International Convention against the Taking of Hostages (1979);`
  line `( v ) Convention on the Physical Protection of Nuclear Material (1980) 2 [as amended from time to`
  line time];
  line `( vi ) Protocol for the Suppression of Unlawful A cts of Violence at Airports Serving International Civil`
  line `Aviation, supplementary to the Convention for the Suppression of Unlawful Acts against the Safety of`
  line `Civil Aviation (1988);`
  line `( vii ) Convention for the Suppression of Unlawful Acts against the safety of Maritime Navigation`
  line `(1988);`
  line `( viii ) Protocol for the Suppression of Unlawful Acts against the Safety of Fixed Platforms located on`
  line `the Continental Shelf (1988); and`
  line `( ix ) International Convention for the Suppression of Terrorist Bombings (1997).`
  line `3 [( x ) Intern ational Convention for Suppression of Acts of Nuclear Terrorism (2005).]`
  line `1. Ins. by Act 3 of 2013, s. 14 (w.e.f. 1 - 2 - 2013).`
