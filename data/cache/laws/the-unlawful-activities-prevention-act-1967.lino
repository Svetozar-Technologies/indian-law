  line 33
  line `1 [ 46. जफर इकबाल @ सलीम @ जमालदीन @ शमशेर नाई @`
  line `शमशेर खान।]`
  line `2 [ 47. िबलाल अहमद बेग @ बाबर।]`
  line `3 [48. शेख जमील-उर-रहमान @ शेख साहब @ रहमान @ अबू नुसरत`
  line `@ फयाज अहमद डार।]`
  line `4 [49. एजाज अहमद अहंगर उफ ᭅ अबू उ ᭭ मान अल - क ᭫ मीरी। ]`
  line `5 [50. मुह ᭥ मद अमीन खुबैअब उफ ᭅ अबू खुबैअब उफ ᭅ िप ᳖ ा उफ ᭅ मुह ᭥ मद`
  line `अमीन बट।]`
  line `6 [51. अरबाज अहमद मीर।]`
  line `7 [52. डॉ. आिसफ मकबूल डार।]`
  line `8 [53. अश ᭅ दीप ᳲ सह िगल उफ ᭅ अश ᭅ डाला। ]`
  line `9 [54. हर ᳲ वदर ᳲ सह संधू उफ ᭅ ᳳ रदा। ]`
  line `10 [55. लखबीर ᳲ सह उफ ᭅ लांडा। ]`
  line `11 [56. सत ᳲ वदर ᳲ सह उफ ᭅ स ᳲ तदरजीत ᳲ सह उफ ᭅ गो ᭨ डी बराड़। ]`
  line `12 [57. मोह ᭥ मद कािसम गु Ჯ र उफ ᭅ सलमान @ सुलेमान।]`
