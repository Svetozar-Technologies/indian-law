obj_root_law_sections_1:
  sectionId (28207)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28207&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Dentists Act, 1948.`
  line
  line `(2) It extends to ^1[the whole of India ^2***.]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "all the Provinces of India".`
  line
  line `2. The words "except the State of Jammu and Kashmir" omitted by Act 42 of 1972, s. 2 (w.e.f. 1-11-1972).`
obj_root_law_sections_2:
  sectionId (28208)
  sectionNo (2)
  orderNo 2
  title Interpretation.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28208&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_2_content:
  string
  line `In this Act, Unless there is anything repugnant in the subject or context,--`
  line
  line `(a) "the Council" means the Dental Council of India constituted under section 3;`
  line
  line `(b) "dental hygienist" means a person not being a dentist or a medical practitioner, who scales,`
  line `cleans or polishes teeth, or gives instruction in dental hygiene;`
  line
  line `(c) "dental mechanic" means a person who makes or repairs denture and dental appliances;`
  line
  line `(d) "dentistry" includes--`
  line
  line `(i) the performance of any operation on, and the treatment on any disease, deficiency or`
  line `lesion of, human teeth or jaws, and the performance of radiographic work in connection with`
  line `human teeth or jaws or the oral cavity;`
  line
  line `(ii) the giving of any anaesthetic in connection with any such operation or treatment;`
  line
  line `(iii) the mechanical construction or the renewal of artificial dentures or restorative dental`
  line appliances;
  line
  line `(iv) the performance of any operation on, or the giving of any treatment, advice or attendance`
  line `to, any person preparatory to, or for the purpose of, or in connection with, the fitting, inserting,`
  line `fixing, constructing, repairing or renewing of artificial dentures or restorative dental appliances,`
  line `and the performance of any such operation and the giving of any such treatment, advice or`
  line `attendance, as is usually performed or given by dentists;`
  line
  line `(e) "dentist" means a person who practises dentistry;`
  line
  line `(f) "medical practitioner" means a person who holds a qualification granted by an authority`
  line `specified or notified under section 3 of the Indian Medical Degrees Act, 1916 (7 of 1916), or`
  line `specified in the Schedules to the ^1[Indian Medical Council Act, 1956 (102 of 1956),]^2[or specified in`
  line `any other law for the time being in force in any State,] or who practises any system of medicine and is`
  line `registered or is entitled to be registered in any ^3[State] medical register by whatever name called;`
  line
  line `(g) "prescribed" means prescribed by rules or regulations made under this Act;`
  line
  line `(h) "`
  line `^4[State] Council" means a ^4[State] Dental Council constituted under section 21, and includes`
  line `a Joint ^4[State] Council constituted in accordance with an agreement under section 22;`
  line
  line `(i) "register" means a register maintained under this Act;`
  line
  line `^5[(j) "recognised dental qualification" means any of the qualifications included in the Schedule;]`
  line
  line `(k) "recognised dental hygiene qualification" means a qualification recognisedby the Council`
  line `under section 11;`
  line
  line `(l) "registered dentist", "registered dental hygienist" and "registered dental mechanic" shall mean,`
  line `respectively, a person whose name is for the time being registered in a register of dentists, a register`
  line `of dental hygienists and a register of dental mechanics.`
  line
  line `^6* * * * *`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. bys. 3,ibid., for "Indian Medical Council Act, 1933 (27 of 1933)" (w.e.f. 1-11-1972).`
  line
  line `2. Ins. by Act 12 of 1955, s. 3.`
  line
  line `3. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `4. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `5. Subs. by Act 42 of 1972, s. 3, for clause (j) (w.e.f. 1-11-1972).`
  line
  line `6. Omitted by s. 3, ibid. (w.e.f. 1-11-1972).`
obj_root_law_sections_2_a:
  sectionId (28209)
  sectionNo 2A
  orderNo 3
  title `Construction of references to laws not in force in Jammu and Kashmir.`
  content obj_root_law_sections_2_a_content
  footnotes obj_root_law_sections_2_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28209&sectionno=2A&orderno=3&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_2_a_content:
  string
  line `2A. [Construction of references to laws not in force in Jammu and Kashmir.] Omitted by the Jammu`
  line `and Kashmir Reorganisation (Adaptation of Central Laws) Order, 2020, vide Notification No. S.O.`
  line `1123(E) dated (18-3-2020) and vide Union Territory of Ladakh Reorganisation (Adaptation of Central`
  line `Laws) Order, 2020, Notification No. S.O. 3774(E), dated (23-10-2020)].`
obj_root_law_sections_2_a_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (28210)
  sectionNo (3)
  orderNo 4
  title `Constitution and composition of council.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28210&sectionno=3&orderno=4&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_3_content:
  string
  line `The Central Government shall, as soon as may be,`
  line `constitute a Council consisting of the following members, namely:--`
  line
  line `(a) one registered dentist possessing a recognised dental qualification elected by the dentists`
  line `registered in Part A of each ^1[State] register;`
  line
  line `(b) one member elected from amongst themselves by the members of the Medical Council of`
  line India;
  line
  line ^2[
  line `^3[(c) not more than four members elected from among themselves, by--`
  line
  line `(a) Principals, Deans, Directors and Vice-Principals of dental colleges in the States training`
  line `students for recognised dental qualifications:`
  line
  line `Provided that not more than one member shall be elected from the same dental college;`
  line
  line `(b) Heads of dental wings of medical colleges in the States training students for recognised`
  line `dental qualifications;]`
  line
  line `(d) one member from each University established by law in the States which grants a recognised`
  line `dental qualification, to be elected by the members of the Senate of the University, or in case the`
  line `University has no Senate, by the members of the court, from amongst the members of the Dental`
  line `Faculty of the University or in case the University has no Dental Faculty, from amongst the members`
  line `of the Medical Faculty thereof;`
  line
  line `(e)one member to represent ^4[each State ^5***] nominated by the Government of each such State`
  line `from among persons registered either in a medical register or a dental register of the State;]`
  line
  line `^6[Explanation.--In this clause, State does not include a Union territory;]`
  line
  line `(f) six members nominated by the Central Government, of whom at least one shall be a registered`
  line `dentist possessing a recognised dental qualification and practising or holding an appointment in an`
  line `institution for the training of dentists in a ^7[Union territory] ^8***;`
  line
  line `^9[(g) the Director General of Health Services, ex officio;]`
  line
  line `Provided that pending the preparation of registers the ^10[State] Governments may nominate to the`
  line `first Council members referred to in parts (a) and (e) and the Central Government members referred`
  line `to in part (f) out of persons who are eligible for registration in the respective registers and such`
  line `persons shall hold office for such period as the ^10[State] or Central Government may, by notification in`
  line `the Official Gazette, specify.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Subs. by Act 12 of 1955, s. 4, for clauses (c), (d) and (e).`
  line
  line `3. Subs. by Act 42 of 1972, for clause (c) (w.e.f. 1-11-1972).`
  line
  line `4. Subs. by the A.O. (No. 3), 1956, for "each Part A State and Part B State other than the State of Jammu and Kashmir".`
  line
  line `5. Omitted by Act 42 of 1972, s. 5 (w.e.f. 1-11-1972).`
  line
  line `6. Added by s. 5, ibid. (w.e.f. 1-11-1972).`
  line
  line `7. Subs. by the A.O. (No. 3), 1956, for "Part C State".`
  line
  line `8. The words and letter "and at least two shall be dentists registered in Part B of a State register" omitted by Act 13 of 2019, s. 2`
  line `(w.e.f. 30-7-2019).`
  line
  line `9. Ins. by Act 12 of 1955, s. 4.`
  line
  line `10. Subs. by the A.O. 1950, for "Provincial".`
obj_root_law_sections_4:
  sectionId (28211)
  sectionNo (4)
  orderNo 5
  title `Incorporation of Council.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28211&sectionno=4&orderno=5&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_4_content:
  string
  line `The Council shall be a body corporate by the name of the Dental`
  line `Council of India, having perpetual succession and a common seal, with power to acquire and hold`
  line `property, both movable and immovable, and shall by the said name sue and be sued.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (28212)
  sectionNo (5)
  orderNo 6
  title `Mode of election.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28212&sectionno=5&orderno=6&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_5_content:
  string
  line `Elections under this Chapter shall be conducted in the prescribed manner, and`
  line `where any dispute arises regarding any such election, it shall be referred to the Central Government`
  line `whose decision shall be final.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (28213)
  sectionNo (6)
  orderNo 7
  title `Term of office and casual vacancies.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28213&sectionno=6&orderno=7&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_6_content:
  string
  line `(1) Subject to the provisions of this section an elected or`
  line `nominated member shall hold office for a term of five years from the date of his election or nomination or`
  line `until his successor has been duly elected or nominated, whichever is longer:`
  line
  line `^2[Provided that a member nominated under clause (e) or clause (f) section 3, shall hold office during`
  line `the pleasure of the authority nominating him.]`
  line
  line `(2) An elected or nominated member may at any time resign his membership by writing under his`
  line `hand addressed to the President and the seat of such member shall thereupon become vacant.`
  line
  line `(3) An elected or nominated member shall be deemed to have vacated his seat if he is absent without`
  line `excuse, sufficient in the opinion of the Council, from three consecutive ordinary meetings of the Council`
  line `or, in the case of a member whose name is required to be included in a ^1-[State] register, if his name is`
  line `removed from such register, or if he has been elected under clause (c) of section 3 ^3[if he ceases to hold`
  line `his appointment as the ^4[Principal, Dean, Director or Vice-Principal] of a dental college, or as ^5[the Head`
  line `Head of the dental wing] of a medical college, or if he has been elected under clause (b) or (d) of section`
  line `3, if he ceases to be a member of the Medical Council of India or ^6[the Dental or Medical Faculty] of the`
  line `University, as the case may be.`
  line
  line `(4) A casual vacancy in the Council shall be filled by fresh election or nomination, as the case may`
  line `be, and the person elected or nominated to fill the vacancy shall hold office only for the remainder of the`
  line `term for which the member whose place he takes was elected or nominated.`
  line
  line `(5) Members of the Council shall be eligible for re-election or re-nomination.`
  line
  line `(6) No act done by the Council shall be called in question on the ground merely of the existence of`
  line `any vacancy in, or defect in the constitution of, the Council.`
obj_root_law_sections_6_footnotes:
  string
  line `1 Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2 Added by Act 42 of 1972, s. 6 (w.e.f. 1-11-1972).`
  line
  line `3 Subs. by Act 12 of 1955, s. 5, for "if he ceases to hold his appointment as head of a college".`
  line
  line `4 Subs. by Act 42 of 1972, s. 6, for "Principal or Vice-Principal" (w.e.f. 1-11-1972).`
  line
  line `5 Subs. by Act 12 of 1955, s. 6, for "a Professor of dental surgery" (w.e.f. 1-11-1972).`
  line
  line `6 Subs. by s. 5, ibid., for "the Medical Faculty".`
obj_root_law_sections_7:
  sectionId (28214)
  sectionNo (7)
  orderNo 8
  title `President and Vice-President of Council.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28214&sectionno=7&orderno=8&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_7_content:
  string
  line `(1) The President and Vice-President of the Council`
  line `shall be elected by the members thereof from among themselves:`
  line
  line `Provided that on the first constitution of the Council and until the President is elected, a member of`
  line `the Council nominated by the Central Government in this behalf shall discharge the functions of the`
  line `President:`
  line
  line `Provided further that for five years from the first constitution of the Council, the President shall, if the`
  line `Central Government so decides, be a person nominated by the Central Government, who shall hold office`
  line `during the pleasure of the Central Government, and where he is not already a member, shall be a member`
  line `of the Council in addition to the members referred to in section 3.`
  line
  line `(2)An elected President or Vice-President shall hold office as such for a term not exceeding five years`
  line `and not extending beyond the expiry of his term as member of the Council, but subject to his being a`
  line `member of the Council, he shall be eligible for re-election.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (28215)
  sectionNo (8)
  orderNo 9
  title `Staff remuneration and allowances.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28215&sectionno=8&orderno=9&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_8_content:
  string
  line `(1) The Council shall--`
  line
  line `(a) appoint a Secretary who may also, if so decided by the Council, act as Treasurer;`
  line
  line `(b) appoint such other officers and servants as the Council deems necessary to enable it to carry`
  line `out its functions under this Act;`
  line
  line `(c) require and take from the Secretary or from any other officer or servant such security for the`
  line `due performance of his duties as the Council considers necessary; and`
  line
  line `(d) with the previous sanction of the Central Government, fix the fees and allowances of the`
  line `President, Vice-President and other members of the Council, and the pay and allowances and other`
  line `conditions of service of officers and servants of the Council.`
  line
  line `(2) Notwithstanding anything contained in clause (a) of sub-section (1), for the first four years from`
  line `the first constitution of the Council, the Secretary of the Council shall be a person appointed by the`
  line `Central Government, who shall hold office during the pleasure of the Central Government.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (28216)
  sectionNo (9)
  orderNo 10
  title `The Executive Committee.`
  content obj_root_law_sections_9_content
  footnotes `1. Ins. by Act 42 of 1972, s. 7 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28216&sectionno=9&orderno=10&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_9_content:
  string
  line `(1) The Council shall constitute from among its members an`
  line `Executive Committee, and may so constitute other Committees for such general or special purposes as the`
  line `Council considers necessary for carrying out its functions under this Act.`
  line
  line `(2) The Executive Committee shall consist of the President and Vice-President ex officio^1[and the`
  line `Director-General of Health Services ex officio] and five other members elected by the Council.`
  line
  line `(3) The President and Vice-President of the Council shall be Chairman and Vice-Chairman,`
  line `respectively, of the Executive Committee.`
  line
  line `(4) A member of the Executive Committee shall hold office as such until the expiry of his term of`
  line `office as member of the Council but, subject to his being a member of the Council, he shall be eligible for`
  line re-election.
  line
  line `(5)In addition to the powers and duties conferred and imposed on it by this Act, the Executive`
  line `Committee shall exercise and discharge such powers and duties as may be prescribed.`
obj_root_law_sections_10:
  sectionId (28217)
  sectionNo (10)
  orderNo 11
  title `Recognition of dental qualifications.`
  content obj_root_law_sections_10_content
  footnotes `1. Subs. by s. 8, ibid., for section 10 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28217&sectionno=10&orderno=11&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_10_content:
  string
  line `^1[10.Recognition of dental qualifications.--(1) The dental qualifications, granted by any authority`
  line `or institution in India, which are included in Part I of the Schedule shall be recognised dental`
  line `qualifications for the purposes of this Act.`
  line
  line `(2) Any authority or institution in India which grants a dental qualification not included in Part I of the`
  line `Schedule may apply to the Central Government to have such qualification recognised and included in that`
  line `Part, and the Central Government, after consulting the Council, and after such inquiry, if any, as it may`
  line `think fit for the purpose, may, by notification in the Official Gazette, amend Part I of the Schedule so as`
  line `to include such qualification therein, and any such notification may also direct that , an entry shall be`
  line `made in Part I of Schedule against such dental qualification declaring that it shall be a recognised dental`
  line `qualification only when granted after a specified date.`
  line
  line `(3) (a) The dental qualifications, granted by any authority or institution outside India, which are`
  line `included in Part II of the Schedule shall be recognised dental qualifications only for the purposes of the`
  line `registration of citizens of India when the register is first prepared under this Act.`
  line
  line `(b) Where any dental qualification granted by any authority or institution outside India, and held by a`
  line `citizen of India, is recognised for the purposes of the register when it is first prepared, after the`
  line `commencement of the Dentists (Amendment) Act, 1972 (42 of 1972), the Central Government may, after`
  line `consultation with the Council, by notification in the Official Gazette, amend Part II of the Schedule so as`
  line `to include therein the dental qualification so recognised.`
  line
  line `(4) (a) The dental qualifications granted by any authority or institution outside India, which are`
  line `included in Part III of the Schedule, shall be recognised dental qualifications for the purposes of this Act,`
  line `but no person possessing any such qualification shall be entitled for registration unless he is a citizen of`
  line India.
  line
  line `(b) Where any dental qualification granted by any authority or institution outside India, and held by a`
  line `citizen of India, is recognised, except on reciprocal basis, after the commencement of the Dentists`
  line `(Amendment) Act, 1972 (42 of 1972), the Central Government may, after consultation with the Council,`
  line `by notification in the Official Gazette, amend Part III of the Schedule so as to include therein the dental`
  line `qualification recognised.`
  line
  line `(5) The Council may enter into negotiations with any authority or institution in any State or country`
  line `outside India which, by law of any such State or country, is entrusted with the maintenance of a register`
  line `of dentists, for the settling of a scheme of reciprocity for the recognition of dental qualifications and in`
  line `pursuance of any such scheme, the Central Government may, by notification in the Official Gazette,`
  line `declare that any such qualification granted by any authority or institution in any such State or country, or`
  line `such qualification, only when granted after a specified date, shall be a recognised dental qualification for`
  line `the purposes of this Act, and any such notification may provide for an amendment of the Schedule and`
  line `may also direct that any such dental qualification as is specified in the notification shall be entered in the`
  line `Schedule as so amended.`
  line
  line `(6) The Central Government may, after consultation with the Council, by notification in the Official`
  line `Gazette, amend the Schedule by directing that an entry be made therein in respect of any dental`
  line `qualification declaring that it shall be a recognised dental qualification only when granted before a`
  line `specified date.]`
obj_root_law_sections_10_a:
  sectionId (28218)
  sectionNo 10A
  orderNo 12
  title `Permission for establishment of new dental college, new courses of study, etc.`
  content obj_root_law_sections_10_a_content
  footnotes `1. Ins. by Act 30 of 1993, s. 2 (w.e.f. 27-8-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28218&sectionno=10A&orderno=12&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_10_a_content:
  string
  line `^1[10A. Permission for establishment of new dental college, new courses of study, etc.--(1)`
  line `Notwithstanding anything contained in this Act or any other law for the time being in force,--`
  line
  line `(a) no person shall establish an authority or institution for a course of study or training (including`
  line `a post-graduate course of study or training) which would enable a student of such course or training to`
  line `qualify himself for the grant of recognised dental qualification; or`
  line
  line `(b) no authority or institution conducting a course of study or training (including a post-graduate`
  line `course of study or training) for grant of recognised dental qualification shall--`
  line
  line `(i) open a new or higher course of study or training (including a post-graduate course of study`
  line `or training) which would enable a student of such course or training to qualify himself for the`
  line `award of any recognised dental qualification; or`
  line
  line `(ii) increase its admission capacity in any course of study or training (including a postgraduate`
  line `course of study or training),`
  line
  line `except with the previous permission of the Central Government obtained in accordance with the`
  line `provisions of this section.`
  line
  line `Explanation 1.--For the purposes of this section, "person" includes any University or a trust but does`
  line `not include the Central Government.`
  line
  line `Explanation 2.--For the purposes of this section, "admission capacity", in relation to any course of`
  line `study or training (including a post-graduate course of study or training) in an authority or institution`
  line `granting recognised dental qualification, means the maximum number of students that may be fixed by`
  line `the Council from time to time for being admitted to such course or training.`
  line
  line `(2) (a) Every person, authority or institution granting recognised dental qualification shall, for the`
  line `purpose of obtaining permission under sub-section (1), submit, to the Central Government a scheme in`
  line `accordance with the provisions of clause (b) and the Central Government shall refer the said scheme to`
  line `the Council for its recommendations.`
  line
  line `(b) The scheme referred to in clause (a) shall be in such form and contain such particulars and be`
  line `preferred in such manner and be accompanied with such fee as may be prescribed.`
  line
  line `(3) On receipt of a scheme by the Council under sub-section (2), the Council may obtain such other`
  line `particulars as may be considered necessary by it from the person, authority or institution concerned,`
  line `granting recognised dental qualification and thereafter, it may,--`
  line
  line `(a) if the scheme is defective and does not contain any necessary particulars, give a reasonable`
  line `opportunity to the person, authority or institution concerned for making a written representation and it`
  line `shall be open to such person, authority or institution to rectify the defects, if any, specified by the`
  line Council;
  line
  line `(b) consider the scheme, having regard to the factors referred to in sub-section (7), and submit the`
  line `scheme together with its recommendations thereon to the Central Government.`
  line
  line `(4) The Central Government may, after considering the scheme and the recommendations of the`
  line `Council under sub-section (3) and after obtaining, where necessary, such other particulars as may be`
  line `considered necessary by it from the person, authority or institution concerned, and having regard to the`
  line `factors referred to in sub-section (7), either approve (with such conditions, if any, as it may consider`
  line `necessary) or disapprove the scheme and any such approval shall be a permission under sub-section (1):`
  line
  line `Provided that no scheme shall be disapproved by the Central Government except after giving the`
  line `person, authority or institution concerned granting recognised dental qualification a reasonable`
  line `opportunity of being heard:`
  line
  line `Provided further that nothing in this sub-section shall prevent any person, authority or institution`
  line `whose scheme has not been approved to submit a fresh scheme and the provisions of this section shall`
  line `apply to such scheme, as if such scheme has been submitted for the first time under sub-section (2).`
  line
  line `(5) Where within a period of one year from the date of submission of the scheme to the Central`
  line `Government under sub-section (2), no order passed by the Central Government has been communicated`
  line `to the person, authority or institution submitting the scheme,such scheme shall be deemed to have been`
  line `approved by the Central Government in the form in which it has been submitted, and, accordingly, the`
  line `permission of the Central Government required under sub-section (1) shall also be deemed to have been`
  line granted.
  line
  line `(6) In computing the time-limit specified in sub-section (5), the time taken by the person, authority or`
  line `institution concerned submitting the scheme in furnishing any particulars called for by the Council or by`
  line `the Central Government, shall be excluded.`
  line
  line `(7) The Council, while making its recommendations under clause (b) of sub-section (3) and the`
  line `Central Government, while passing an order either approving or disapproving the scheme under`
  line `sub-section (4), shall have due regard to the following factors, namely:--`
  line
  line `(a) whether the proposed authority or institution for grant of recognised dental qualification or the`
  line `existing authority or institution seeking to open a new or higher course of study or training, would be`
  line `in a position to offer the minimum standards of dental education in conformity with the requirements`
  line `referred to in section 16A and the regulations made under sub-section (1)of section 20;`
  line
  line `(b) whether the person seeking to establish an authority or institution or the existing authority or`
  line `institution seeking to open a new or higher course of study or training or to increase its admission`
  line `capacity has adequate resources;`
  line
  line `(c) whether necessary facilities in respect of staff, equipment, accommodation, training and other`
  line `facilities to ensure; proper functioning of the authority or institution or conducting the new course of`
  line `study or training or accommodating the increased admission capacity have been provided or would be`
  line `provided within the time-limit specified in the scheme;`
  line
  line `(d) whether adequate hospital facilities, having regard to the number of students likely to attend`
  line `such authority or institution or course of study or training or as a result of the increased admission`
  line `capacity have been provided or would be provided within the time-limit specified in the scheme;`
  line
  line `(e) whether any arrangement has been made or programme drawn to impart proper training to`
  line `students likely to attend such authority or institution or course of study or training by persons having`
  line `the recognised dental qualifications;`
  line
  line `(f) the requirement of manpower in the field of practice of dentistry; and`
  line
  line `(g) any other factors as may be prescribed.`
  line
  line `(8) Where the Central Government passes an order either approving or disapproving a scheme under`
  line `this section, a copy of the order shall be communicated to the person, authority or institution concerned.]`
obj_root_law_sections_10_b:
  sectionId (28219)
  sectionNo 10B
  orderNo 13
  title `Non-recognition of dental qualifications in certain cases.`
  content obj_root_law_sections_10_b_content
  footnotes `1. Ins. by Act 30 of 1993, s. 2 (w.e.f. 27-8-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28219&sectionno=10B&orderno=13&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_10_b_content:
  string
  line `^1[10B.Non-recognition of dental qualifications in certain cases.--(1) Where any authority or`
  line `institution is established for grant of recognised dental qualification except with the previous permission`
  line `of the Central Government in accordance with the provisions of section 10A, no dental qualification`
  line `granted to any student of such authority or institution shall be a recognised dental qualification for the`
  line `purposes of this Act.`
  line
  line `(2) Where any authority or institution granting recognised dental qualification opens a new or higher`
  line `course of study or training (including a post-graduate course of study or training) except with the previous`
  line `permission of the Central Government in accordance with the previous permission of the Central`
  line `Government in accordance with the provisions of section 10A, no dental qualification granted to any`
  line `student of such authority or institution on the basis of such study or training shall be a recognised dental`
  line `qualification for the purposes of this Act.`
  line
  line `(3) Where any authority or institution granting recognised dental qualification increases its admission`
  line `capacity in any course of study or training (including a post-graduate course of study or training) except`
  line `with the previous permission of the Central Government in accordance with the provisions of section`
  line `10A, no dental qualification granted to any student of such authority or institution on the basis of the`
  line `increase in its admission capacity shall be a recognised dental qualification for the purposes of this Act.`
  line
  line `Explanation.--For the purposes of this section, the criteria for identifying a student who has been`
  line `granted a dental qualification on the basis of such increase in the admission capacity shall be such as may`
  line `be prescribed.]`
obj_root_law_sections_10_c:
  sectionId (28220)
  sectionNo 10C
  orderNo 14
  title `Time for seeking permission for certain existing authorities.`
  content obj_root_law_sections_10_c_content
  footnotes `1. Ins. by Act 30 of 1993, s. 2 (w.e.f. 27-8-1992).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28220&sectionno=10C&orderno=14&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_10_c_content:
  string
  line `^1[10C.Time for seeking permission for certain existing authorities.--(1) If, after the 1st day of June,`
  line `1992 and on and before the commencement of the Dentists (Amendment) Act, 1993 (30 of 1993) any`
  line `person has established an authority or institution for grant of recognised dental qualification or any`
  line `authority or institution granting recognised dental qualification has opened a new or higher course of`
  line `study or training (including a post-graduate course of study or training) or increased its admission`
  line `capacity, such person, authority or institution, as the case may be, shall seek, within a period of one year`
  line `from the commencement of the Dentists (Amendment) Act, 1993, the permission of the Central`
  line `Government in accordance with the provisions of section 10A.`
  line
  line `(2)If any person or, as the case may be, any authority or institution granting recognised dental`
  line `qualification fails to seek the permission under sub-section (1), the provisions of section 10B shall apply,`
  line `so far as may be, as if permission of the Central Government under section 10A has been refused.]`
obj_root_law_sections_10_d:
  sectionId (28221)
  sectionNo 10D
  orderNo 15
  title `Uniform entrance examination for undergraduate and post-graduate level.`
  content obj_root_law_sections_10_d_content
  footnotes `1. Ins. by Act 40 of 2016, s. 2 (w.e.f. 24-5-2016).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28221&sectionno=10D&orderno=15&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_10_d_content:
  string
  line `^1[10D. Uniform entrance examination for undergraduate and post-graduate level.--There shall`
  line `be conducted a uniform entrance examination to all dental educational institutions at the undergraduate`
  line `level and post-graduate level through such designated authority in Hindi, English and such other`
  line `languages and in such manner as may be prescribed and the designated authority shall ensure the conduct`
  line `of uniform entrance examination in the aforesaid manner:`
  line
  line `Provided that notwithstanding any judgment or order of any court, the provisions of this section shall`
  line `not apply, in relation to the uniform entrance examination at the undergraduate level for the academic`
  line `year 2016-17 conducted in accordance with any regulations made under this Act, in respect of the State`
  line `Government seats (Whether in Government Dental College or in a Private Dental College) where such`
  line `State has not opted for such examination.]`
obj_root_law_sections_11:
  sectionId (28222)
  sectionNo (11)
  orderNo 16
  title `Qualifications of dental hygienists.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28222&sectionno=11&orderno=16&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_11_content:
  string
  line `Any authority in a ^1[State]`
  line `^2*** which grants a qualification`
  line `for dental hygienists may apply to the Council to have such qualification recognised, and the Council`
  line `may, after such inquiry, if any, as it thinks fit, and after consulting the Government and the ^3[State]`
  line `Council of the ^1[State] in which the authority making the application is situated, declare that such`
  line `qualification, or such qualification only when granted after a specified date, shall be a recognised dental`
  line `hygiene qualification for the purposes of this Act.`
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Province".`
  line
  line `2. The words "of India" omitted, ibid.`
  line
  line `3 Subs. ibid., for "Provincial".`
obj_root_law_sections_12:
  sectionId (28223)
  sectionNo (12)
  orderNo 17
  title `Qualifications of dental mechanics.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28223&sectionno=12&orderno=17&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_12_content:
  string
  line `The Council may prescribe the period and nature of an`
  line `apprenticeship or training which shall be undergone and the other conditions which shall be satisfied by a`
  line `person before he is entitled to be registered under this Act as a dental mechanic.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (28224)
  sectionNo (13)
  orderNo 18
  title `Effect of recognition.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by the A.O. 1950, for "Province".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28224&sectionno=13&orderno=18&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_13_content:
  string
  line `Notwithstanding anything contained in any other law, but subject to the`
  line `provisions of this Act,--`
  line
  line `(a) anyrecognised dental or dental hygiene qualification shall be a sufficient qualification for`
  line `enrolment in the appropriate register of any ^1[State];`
  line
  line `(b) no person shall, after the first registers are compiled under this Act, be entitled to be enrolled`
  line `in any register as a dentist or dental hygienist unless he holds a recognised dental or dental hygiene`
  line `qualification or as a dental mechanic unless he has undergone training which satisfies the prescribed`
  line `requirements referred to in section 12.`
obj_root_law_sections_14:
  sectionId (28225)
  sectionNo (14)
  orderNo 19
  title `Power to require information as to courses of study and training and examinations.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28225&sectionno=14&orderno=19&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_14_content:
  string
  line Every
  line `authority in a ^1[State] ^2*** which grants any recognised dental or dental hygiene qualification shall`
  line `furnish such information as the Council may from time to time require as to the courses of study and`
  line `training and examinations to be undergone in order to obtain such qualification, as to the ages at which`
  line `such courses of study and examinations are required to be undergone, and generally as to the requisites`
  line `for obtaining such qualification.`
obj_root_law_sections_14_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provinc".`
  line
  line `2. The words "of India" omitted, ibid.`
obj_root_law_sections_15:
  sectionId (28226)
  sectionNo (15)
  orderNo 20
  title Inspection.
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28226&sectionno=15&orderno=20&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_15_content:
  string
  line `(1) The Executive Committee ^2[may, subject to regulations, if any, made by the`
  line `Council appoint] such number of Inspectors as it deems necessary to attend at any examinations held by`
  line `authorities in the ^3[States]`
  line `^1*** which grant recognised dental or dental hygiene qualifications and to`
  line `inspect any institution recognised as a training institution.`
  line
  line `(2) Inspectors appointed under this section shall not interfere with the course of any examination but`
  line `they shall report to the Executive Committee on the sufficiency of every examination at which they attend`
  line `and of the courses of study and training at every institution which they inspect, and on any other matters`
  line `with regard to which the Executive Committee may require them to report.`
  line
  line `(3) The Executive Committee shall forward a copy of such report to the authority or institution`
  line `concerned and shall also forward copies with remarks, if any, of the authority or institution concerned`
  line `thereon to the Central Government and to the Government of the State in which the authority or`
  line `institution is situated.`
obj_root_law_sections_15_footnotes:
  string
  line `1. The words "of India” omitted, ibid.`
  line
  line `2. Subs. by Act 12 of 1955, s. 6, for "may appoint".`
  line
  line `3. Subs. by the A.O. 1950, for "Provinces".`
obj_root_law_sections_15_a:
  sectionId (28227)
  sectionNo 15A
  orderNo 21
  title `Appointment of Visitors.`
  content obj_root_law_sections_15_a_content
  footnotes `1. Ins. by Act 42 of 1972, s. 9 (w.e.f. 1-11-1973).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28227&sectionno=15A&orderno=21&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_15_a_content:
  string
  line `^1[15A.Appointment of Visitors.--(1) The Council may appoint such number of Visitors as it may`
  line `deem necessary to attend at any examination held by any authority or institution in a State which grants`
  line `recognised dental qualifications and to inspect any institution training students for recognised dental`
  line qualifications.
  line
  line `(2) Any person, whether he is a member of the Council or not, may be appointed as a Visitor under`
  line `this section, but a person who is appointed as an Inspector under section 15 for any inspection or`
  line `examination shall not be appointed as a Visitor for the same inspection or examination.`
  line
  line `(3) The Visitor shall not interfere with the course of any examination but shall report to the President`
  line `of the Council on the sufficiency of every examination at which he attends and of the courses of study and training at every institution which he inspects, and on the adequacy of the standards of dental education`
  line `including staff, equipment, accommodation and other facilities prescribed for giving dental education, and`
  line
  line `on any other matters with regard to which the Council may require him to report.`
  line
  line `(4) The report of a Visitor shall be treated as confidential unless in any particular case the President of`
  line `the Council otherwise directs:`
  line
  line `Provided that if the Central Government requires a copy of the report of a Visitor, the Council shall`
  line `furnish the same.`
  line ]
obj_root_law_sections_16:
  sectionId (28228)
  sectionNo (16)
  orderNo 22
  title `Withdrawal of recognition.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28228&sectionno=16&orderno=22&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_16_content:
  string
  line `(1) When upon report by the Executive Committee it appears to`
  line `the Council--`
  line
  line `(a) that the courses of study and training or the examinations to be undergone in order to obtain a`
  line `recognised^1*** dental hygiene qualification from any authority in a ^2[State]`
  line `^3*** or the conditions for`
  line `admission to such courses or the standards of proficiency required from the candidates at such`
  line `examinations are not in conformity with regulations made under this Act or fall short of the standards`
  line `required thereby, or`
  line
  line `(b) that an institution does not satisfy the requirements of the Council,`
  line
  line `the Council may send to the Government of the ^4[States] in which the authority or institution is situated a`
  line `statement to such, effect, and the ^5[State] Government shall forward it, along with such remarks as it may`
  line `think fit, to the authority or institution concerned with an intimation of the period within which the`
  line `authority or institution may submit its explanation to the ^5[State] Government.`
  line
  line `(2) On receipt of the explanation, or where no explanation is submitted within the period fixed, then`
  line `on the expiry of the period, the ^5[State] Government shall after consulting the ^5[State] Council, forward its`
  line `recommendations and those of the ^5[State] Council, if any, to the Council.`
  line
  line `(3) The Council, after considering the recommendations of the ^5[State] Government and the State`
  line `Council and after such further inquiry, if any, as it may think fit to make, may declare that the`
  line `qualification granted by the authority or institution shall be a recognised^1*** dental hygiene qualification`
  line `only when granted before a specified date.`
  line
  line `(4) The Council may declare that any recognised^1*** dental hygiene qualification granted outside the`
  line ^4[States]
  line `^3*** shall be recognised as such only if granted before a specified date.`
obj_root_law_sections_16_footnotes:
  string
  line `1. The words "dental or" omitted by Act 42 of 1972, s. 10 (w.e.f. 1-11-1972).`
  line
  line `2. Subs. by the A.O. 1950, for "Province".`
  line
  line `3. The words "of India" omitted, ibid.`
  line
  line `4. Subs., ibid, for "Provinces".`
  line
  line `5. Subs., ibid, for "Provincial".`
obj_root_law_sections_16_a:
  sectionId (28229)
  sectionNo 16A
  orderNo 23
  title `Withdrawal of recognition of recognised dental qualification.`
  content obj_root_law_sections_16_a_content
  footnotes `1. Ins. by Act 42 of 1972, s. 11 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28229&sectionno=16A&orderno=23&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_16_a_content:
  string
  line `^1[16A.Withdrawal of recognition of recognised dental qualification.--(1) When, upon report by`
  line `the Executive Committee or the Visitor, it appears to the Council--`
  line
  line `(a) that the courses of study and training or the examination to be undergone in order to obtain a`
  line `recognised dental qualification from any authority or institution in a State, or the conditions for`
  line `admission to such courses or the standards of proficiency required from the candidates as such`
  line `examinations are not in conformity with the regulations made under this Act or fall short of the`
  line `standards required thereby, or`
  line
  line `(b) that an institution does not, in the matter of staff, equipment, accommodation, training and`
  line `other facilities, satisfy the requirements of the Council,`
  line `the Council shall send a statement to that effect to the Central Government.`
  line
  line `(2) After considering such a statement, the Central Government may send it to the Government of the`
  line `State in which the authority exercises power or the institution is situated, and the State Government shall`
  line `forward it, along with such remarks as it may think fit to make, to the authority or institution concerned,`
  line `with an intimation of the period within which the authority or institution may submit its explanation to the`
  line `State Government.`
  line
  line `(3) After considering the explanation, or where no explanation is submitted within the period fixed,`
  line `then, on the expiry of that period, the State Government shall make its recommendations to the Central`
  line Government.
  line
  line `(4) The Central Government may, after considering the recommendations of the State Government`
  line `and after making such further inquiry, if any, as it may think fit, by notification in the Official Gazette,`
  line `direct that an entry shall be made in Part I of the Schedule against the qualification granted by the`
  line `authority or institution declaring that it shall be a recognised dental qualification only when granted`
  line `before a specified date or that the said recognised dental qualification if granted to students of a specified`
  line `college or institution affiliated to any University shall be a recognised dental qualification only when`
  line `granted before a specified date or, as the case may be, that the said recognised dental qualification shall be`
  line `a recognised dental qualification in relation to a specified college or institution affiliated to any University`
  line `only when granted after a specified date.]`
obj_root_law_sections_17:
  sectionId (28230)
  sectionNo (17)
  orderNo 24
  title `Mode of declarations.`
  content obj_root_law_sections_17_content
  footnotes `1. The word and figures "section 10" omitted by Act 42 of 1972, s. 12 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28230&sectionno=17&orderno=24&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_17_content:
  string
  line `All declarations under ^1*** section 11 or section 16 shall be made by a`
  line `resolution passed at a meeting of the Council and shall forthwith be published in the Official Gazette.`
obj_root_law_sections_17_a:
  sectionId (28231)
  sectionNo 17A
  orderNo 25
  title `Professional conduct.`
  content obj_root_law_sections_17_a_content
  footnotes `1. Ins. by s. 13, ibid. (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28231&sectionno=17A&orderno=25&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_17_a_content:
  string
  line `^1[17A.Professional conduct.--(1) The Council may prescribe standards of professional conduct and`
  line `etiquette or the code of ethics for dentists.`
  line
  line `(2) Regulations made by the Council under sub-section (1) may specify which violations thereof shall`
  line `constitute infamous conduct in any professional respect, that is to say, professional misconduct, and such`
  line `provision shall have effect notwithstanding anything to the contrary contained in any other law for the`
  line `time being in force.]`
obj_root_law_sections_18:
  sectionId (28232)
  sectionNo (18)
  orderNo 26
  title `The Indian Register.`
  content obj_root_law_sections_18_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28232&sectionno=18&orderno=26&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_18_content:
  string
  line `(1) The Council shall maintain a register of dentists to be known as the`
  line `Indian Dentists Register and consisting of the entries in all the ^1[State] registers of dentists.`
  line
  line `(2) Each ^1[State] Council shall supply to the Council twenty printed copies of the ^1[State] register as`
  line `soon as may be after the 1st day of April of each year, and each Registrar shall inform the Council`
  line `without delay of all additions to and other amendments in the ^1[State] register.`
obj_root_law_sections_19:
  sectionId (28233)
  sectionNo (19)
  orderNo 27
  title `Information to be furnished.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28233&sectionno=19&orderno=27&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_19_content:
  string
  line `(1) The Council shall furnish copies of its minutes and of the`
  line `minutes of the Executive Committee and an annual report of its activities together with an abstract of its`
  line `accounts to the Central Government.`
  line
  line `(2) The Central Government may publish in such manner as it thinks fit any report, copy or abstract`
  line `furnished to it under this section.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (28234)
  sectionNo (20)
  orderNo 28
  title `Power to make regulations.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28234&sectionno=20&orderno=28&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_20_content:
  string
  line `(1) The Council may, with the approval of the Central`
  line `Government, ^1[by notification in the Official Gazette,] make regulations not inconsistent with the`
  line `provisions of this Act to carry out the purposes of this Chapter.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power such regulations`
  line may--
  line
  line `(a) provide for the management of the property of the Council ^2***;`
  line
  line `(b) prescribe the manner in which elections under this Chapter shall be conducted;`
  line
  line `(c) provide for the summoning and holding of meetings of the Council and the Executive`
  line `Committee, the times and places at which such meetings shall be held, the conduct of business thereat`
  line `and the number of members necessary to constitute a quorum;`
  line
  line `(d) prescribe the functions of the Executive Committee;`
  line
  line `(e) prescribe the powers and duties of the President and Vice-President;`
  line
  line `(f) prescribe the tenure of office and the powers and duties of the Secretary ^3[and other officers`
  line `and servants of the Council and Inspectors and Visitors appointed by the Council];`
  line
  line `^4[(fa) prescribe the form of the scheme, the particulars to be given in such scheme, the manner in`
  line `which the scheme is to be preferred and the fee payable with the scheme under clause (b) of`
  line `sub-section (2) of section 10A;`
  line
  line `(fb) prescribe any other factors under clause (g) of sub-section (7) of section 10A;`
  line
  line `(fc) prescribe the criteria for identifying a student who has been granted a dental qualification`
  line `referred to in the Explanation to sub-section (3) of section 10B;]`
  line
  line `(g) prescribe the standard curricula for the training of dentists and dental hygienists, and the`
  line `conditions for admission to courses of such training;`
  line
  line `(h) prescribe the standards of examinations and other requirements to be satisfied to secure for`
  line `qualifications recognition under this Act;`
  line
  line `^5[(ha) the designated authority, other languages and the manner of conducting of uniform`
  line `entrance examination to all dental educational institutions at the undergraduate level and postgraduate level;]`
  line
  line `(i) any other matter which is to be or may be prescribed under this Act:`
  line
  line `Provided that regulations under clauses (g) and (h) shall be made after consultation with ^6[State]`
  line Governments.
  line
  line `(3) To enable the Council to be first constituted, the Central Government may make regulations for`
  line `the conduct of the elections to the Council, and any regulation so made may be altered or rescinded by the`
  line `Council in exercise of its powers under this section.`
  line
  line `^7[(4) Every regulation made under this section shall be laid, as soon as may be after it is made before`
  line `each House of Parliament, while it is in session for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the regulation or both Houses agree that the regulation should not be made, the regulation`
  line `shall thereafter have effect only in such modified form or be of no effect, as the case may be; so, however,`
  line `that any such modification or annulment shall be without prejudice to the validity of anything previously`
  line `done under that regulation.]`
obj_root_law_sections_20_footnotes:
  string
  line `1. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
  line
  line `2. The words "and the maintenance and audit of its accounts" omitted by Act 42 of 1972, s. 14 (w.e.f. 1-11-1972).`
  line
  line `3. Subs. by Act 42 of 1972, s. 14, for "Inspectors and other officers and servants of the Council" (w.e.f. 1-11-1972).`
  line
  line `4. Ins. by Act 30 of 1993, s. 3 (w.e.f. 27-8-1992).`
  line
  line `5. Ins. by Act 40 of 2016, s. 3 (w.e.f. 24-5-2016).`
  line
  line `6. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `7. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
obj_root_law_sections_21:
  sectionId (28235)
  sectionNo (21)
  orderNo 29
  title `Constitution and Composition of State Councils.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28235&sectionno=21&orderno=29&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_21_content:
  string
  line `^1[21.Constitution and Composition of State Councils.--Except where a Joint ^1[State] Council is`
  line `constituted in accordance with an agreement made under section 22, the ^1[State] Government shall`
  line `constitute a ^1[State] Council consisting of the following members,namely:--`
  line
  line `(a) four members elected from among themselves by dentists registered in Part A of the ^1[State]`
  line register;
  line
  line `^2* * * * *`
  line
  line `^3[(c) the heads of dental colleges, if any, in the State which train students for any of the`
  line `recognised dental qualifications included in Part I of the Schedule, ex officio;]`
  line
  line `(d) one member elected from amongst themselves by the members of the Medical Council or the`
  line `Council of Medical Registration of the ^4[State], as the case may be;^5***`
  line
  line `(e) three members nominated by the ^1[State] Government; ^6[and]`
  line
  line `^5[(f) the Chief Medical Officer of the State, by whatever name called, ex officio:]`
  line
  line `^7[Provided that in the State of Saurashtra^8[as it existed before the 1st November, 1956], the State`
  line `Dental Council constituted under Saurashtra Ordinance XXV of 1948, as amended by Saurashtra`
  line `Ordinance XL of 1949, shall be deemed to the State Council constituted under this Act.]`
obj_root_law_sections_21_footnotes:
  string
  line `1. Ins. by Act 40 of 2016, s. 3 (w.e.f. 24-5-2016).`
  line
  line `2. Clause (b) omitted by Act 13 of 2019, s. 3 (w.e.f. 30-7-2019).`
  line
  line `3. Subs. by Act 12 of 1955, s. 7, for clause (c).`
  line
  line `4. Subs. by the A.O. 1950, for "Province".`
  line
  line `5. The word "and" omitted by Act 42 of 1972, s. 15 (w.e.f. 1-11-1972).`
  line
  line `6. Ins. by s. 15, ibid. (w.e.f. 1-11-1972).`
  line
  line `7. Added by Act 12 of 1955, s. 7.`
  line
  line `8. Ins. by the Adaptation of Laws (No. 3) Order, 1956.`
obj_root_law_sections_22:
  sectionId (28236)
  sectionNo (22)
  orderNo 30
  title `Inter-State agreements.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28236&sectionno=22&orderno=30&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_22_content:
  string
  line `(1) Two or more ^1[State] Governments may enter into an agreement to`
  line `be in force for such period and to be subject to renewal for such further periods, if any, as may be`
  line `specified in the agreement, to provide`
  line
  line `(a) for the constitution of a Joint ^1[State] Council for all the participating ^2[States], or`
  line
  line `(b) for the ^1[State] Council of one ^3[State] to serve the needs of the other participating ^2[States].`
  line
  line `(2) In addition to such matters as are in this Act specified, an agreement under this section may--`
  line
  line `(a) provide for the apportionment between the participating ^2[States] of the expenditure in`
  line `connection with the ^1[State] Council or Joint ^1[State] Council;`
  line
  line `(b) determine which of the participating ^1[State] Governments shall exercise the several functions`
  line `of the ^1[State] Government under this Act, and the references in this Act to the ^1[State] Government`
  line `shall be construed accordingly;`
  line
  line `(c) provide for consultation between the participating ^1[State] Governments either generally or`
  line `with reference to particular matters arising under this Act;`
  line
  line `(d) make such incidental and ancillary provisions, not inconsistent with this Act, as may be`
  line `deemed necessary or expedient for giving effect to the agreement.`
  line
  line `(3) An agreement under this section shall be published in the Official Gazettes of the participating`
  line ^2[States].
obj_root_law_sections_22_footnotes:
  string
  line `1. Subs. by the A. O. 1950, for "Provincial".`
  line
  line `2. Subs.,ibid., for "Provinces.`
  line
  line `3. Subs., ibid., for "Province".`
obj_root_law_sections_23:
  sectionId (28237)
  sectionNo (23)
  orderNo 31
  title `Composition of Joint State Councils.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28237&sectionno=23&orderno=31&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_23_content:
  string
  line `A Joint ^1[State] Council shall consist of the following`
  line `members, namely:--`
  line
  line `(a) two members elected from among themselves by dentists registered in Part A of the register of`
  line `each of the participating ^2[States];`
  line
  line `^3* * * * *`
  line
  line `^4[(c) the heads of dental colleges, if any, in all the participating States which train students for any`
  line `any of the recognised dental qualifications included in Part I of the Schedule, ex officio;]`
  line
  line `(d) one member elected by the Medical Council or the Council of Medical Registration, of each`
  line `participating ^1[State], as the case may be;`
  line
  line `(e) two members nominated by each participating ^1[State] Government;`
  line
  line `^5[(f) the Chief Medical Officer of each participating State, by whatever name called, ex officio.]`
obj_root_law_sections_23_footnotes:
  string
  line `1. Subs. by the A. O. 1950, for "Provincial".`
  line
  line `2. Subs.,ibid., for "Provinces".`
  line
  line `3. Clause (b) omitted by Act 13 of 2019, s. 4 (w.e.f. 30-7-2019).`
  line
  line `4. Subs. by Act 12 of 1955, s. 8, for clause (c).`
  line
  line `5. Ins. by Act 42 of 1972, s. 16 (w.e.f. 1-11-1972).`
obj_root_law_sections_24:
  sectionId (28238)
  sectionNo (24)
  orderNo 32
  title `Incorporation of State Councils.`
  content obj_root_law_sections_24_content
  footnotes `1. Subs. by the A. O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28238&sectionno=24&orderno=32&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_24_content:
  string
  line `Every ^1[State] Council shall be a body corporate by such`
  line `name as may be notified by the ^1[State] Government in the Official Gazette or, in the case of a Joint`
  line `^1[State] Council, as may be determined in the agreement, having perpetual succession and a common seal`
  line `with power to acquire and hold property, both movable and immovable, and shall by the said name sue`
  line `and be sued.`
obj_root_law_sections_25:
  sectionId (28239)
  sectionNo (25)
  orderNo 33
  title `President and Vice-President of State Council.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28239&sectionno=25&orderno=33&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_25_content:
  string
  line `(1) The President and Vice-President of the`
  line `^1[State] Council shall be elected by the members from among themselves:`
  line
  line `Provided that for five years from the first constitution of the ^2`
  line `[State] Council, the President shall, if`
  line `the ^2[State] Government so decides, be a person nominated by the ^2[State] Government who shall hold`
  line `office during the pleasure of the ^2[State] Government, and where he is not already a member, shall be a`
  line `member of the ^2[State] Council in addition to the members referred to in section 21 or 23, as the case may`
  line be.
  line
  line `(2) The President or Vice-President shall hold office as such for a term not exceeding five years and`
  line `not extending beyond the expiry of his term as a member of the ^2[State] Council, but subject to his being a`
  line `member of the ^2State] Council, he shall be eligible for re-election.`
obj_root_law_sections_25_footnotes:
  string
  line `1. Subs. by the A. O. 1950, for "Provincial".`
  line
  line `2. Subs. by the A. O. 1950, for "Provincial".`
obj_root_law_sections_26:
  sectionId (28240)
  sectionNo (26)
  orderNo 34
  title `Mode of elections.`
  content obj_root_law_sections_26_content
  footnotes `1. Subs. by the A. O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28240&sectionno=26&orderno=34&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_26_content:
  string
  line `Elections under this Chapter shall be conducted in the prescribed manner,`
  line `and where any dispute arises regarding any such election, it shall be referred to the ^1[State] Government`
  line `whose decision shall be final.`
obj_root_law_sections_27:
  sectionId (28241)
  sectionNo (27)
  orderNo 35
  title `Term of office and casual vacancies.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28241&sectionno=27&orderno=35&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_27_content:
  string
  line `(1) Subject to the provisions of this section, an elected or`
  line `nominated member shall hold office for a term of five years from the date of his election or nomination or`
  line `until his successor has been duly elected or nominated whichever is longer:`
  line
  line `^2[Provided that a member nominated under clause (e) of section 21 or clause (e) of section 23, shall`
  line `hold office during the pleasure of the authority nominating him.]`
  line
  line `(2) An elected or nominated member may at any time resign his membership by writing under his`
  line `hand addressed to the President, and the seat of such member shall thereupon become vacant.`
  line
  line `(3) An elected or nominated member shall be deemed to have vacated his seat--`
  line
  line `(a) if he is absent without excuse, sufficient in the opinion of the ^1[State] Council, from three`
  line `consecutive ordinary meetings of the ^1[State] Council, or`
  line
  line `(b) in the case of a member whose name is required to be included in any ^1[State] register, if his`
  line `name is removed from the register, or`
  line
  line `(c) where he has been elected under clause (d) of section 21 or under clause (d) of section 23, if`
  line `he ceases to be a member of the Medical Council or the Council of Medical Registration of the`
  line `^3[State] as the case may be.`
  line
  line `(4) A casual vacancy in the ^1[State] Council shall be filled by fresh election or nomination, as the case`
  line `may be, and the person elected or nominated to fill the vacancy shall hold office only for the remainder of`
  line `the term for which the member whose place he takes was elected or nominated.`
  line
  line `(5) Members of the ^1[State] Council shall be eligible for re-election or re-nomination.`
  line
  line `(6) No act done by the ^1[State] Council shall be called in question on the ground merely of the`
  line `existence of any vacancy in, or defect in the constitution of, the ^1[State] Council.`
  line
  line `STATE AMENDMENT`
  line
  line `Andhra Pradesh.--`
  line
  line `In the Dentist Act, 1948 (Act 16 of 1948), in section 27, for sub-section (1), the following shall be`
  line `substituted, namely:--`
  line
  line `"(1) Subject to the provisions of this section, an elected or nominated member shall hold office for a`
  line `term of five (5) years from the date of his election or nomination."`
  line
  line `[Vide Andhra Pradesh Act 19 of 2017, s. 2]`
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by the A. O. 1950, for "Provincial".`
  line
  line `2. Added by Act 42 of 1972, s. 17 (w.e.f. 1-11-1972).`
  line
  line `3 Subs. by the A.O. 1950, for "Province".`
obj_root_law_sections_28:
  sectionId (28242)
  sectionNo (28)
  orderNo 36
  title `Staff, remuneration and allowances.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28242&sectionno=28&orderno=36&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_28_content:
  string
  line `(1) The ^1[State] Council may, with the previous sanction`
  line `of the ^1[State] Government,--`
  line
  line `(a) appoint a Registrar who shall also act as Secretary and if so decided by the`
  line `State Council`
  line `also as its Treasurer;`
  line
  line `(b) appoint such other officers and servants as may be required to enable the`
  line `State Council to`
  line `carry out its functions under this Act;`
  line
  line `(c) require and take from the Registrar or from any other officer or servant such security for the`
  line `due performance of his duties as the`
  line `State Council considers necessary;`
  line
  line `(d) fix the salaries and allowances and other conditions of service of the Registrar and other`
  line `officers and servants of the^1[State] Council;`
  line
  line `(e) fix the rate of allowances payable to members of the ^1[State] Council.`
  line
  line `(2) Notwithstanding anything contained in clause (a) of sub-section (1), for the first four years from`
  line `the first constitution of the ^2[State] Council, the Registrar of the ^2[State] Council shall be a person`
  line `appointed by the ^2[State] Government who shall hold office during the pleasure of the ^2[State]`
  line Government.
obj_root_law_sections_28_footnotes:
  string
  line `1. Subs. by the A. O. 1950, for "Provincial".`
  line
  line `2. Subs. by the A.O. 1950, for "Provincial".`
obj_root_law_sections_29:
  sectionId (28243)
  sectionNo (29)
  orderNo 37
  title `Executive Committee.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28243&sectionno=29&orderno=37&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_29_content:
  string
  line `(1) The ^1`
  line `State Council shall constitute from among its members an`
  line `Executive Committee consisting of the President and Vice-President ex officio ^2[and the Chief Medical`
  line `Officer of the State or the States concerned, by whatever name called, ex officio] and such number of`
  line `other members elected by the ^1[State] Council as may be prescribed.`
  line
  line `(2) The President and Vice-President of the ^1[State] Council shall be Chairman and Vice-Chairman,`
  line `respectively, of the Executive Committee.`
  line
  line `(3) A member of the Executive Committee shall bold office as such until the expiry of his term of`
  line `office as member of the ^1[State] Council, but subject to his being a member of the ^1[State] Council, he`
  line `shall be eligible for re-election.`
  line
  line `(4) The Executive Committee shall exercise and discharge such powers and duties as may be`
  line prescribed.
obj_root_law_sections_29_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Ins. by Act 42 of 1972, s. 18 (w.e.f. 1-11-1972).`
obj_root_law_sections_30:
  sectionId (28244)
  sectionNo (30)
  orderNo 38
  title `Information to be furnished.`
  content obj_root_law_sections_30_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28244&sectionno=30&orderno=38&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_30_content:
  string
  line `(1) The ^1[State] Council shall furnish such reports, copies of its`
  line `minutes and of the minutes of the Executive Committee, and abstracts of its accounts to the ^1[State]`
  line `Government as the ^1[State] Government may from time to time require and shall forward copies of all`
  line `material so furnished to the ^1[State] Government to the Council.`
  line
  line `(2) The ^1[State] Government may published in such manner as it thinks fit any report copy or abstract`
  line `furnished to it under this section.`
obj_root_law_sections_31:
  sectionId (28245)
  sectionNo (31)
  orderNo 39
  title `Preparation and maintenance of register.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28245&sectionno=31&orderno=39&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_31_content:
  string
  line `(1) The ^1[State] Government shall as soon as may be`
  line `cause to be prepared in the manner hereinafter provided a register of dentists for the ^2[State].`
  line
  line `(2) The ^1[State] Council shall upon its constitution assume the duty of maintaining the register in`
  line `accordance with the provisions of this Act.`
  line
  line `(3) The register of dentists shall be maintained in two Parts, A and B, persons possessing recognised`
  line `dental qualifications being registered in Part A and persons not possessing such qualifications being`
  line `registered in Part B.`
  line
  line `(4) The register shall include the following particulars, namely:--`
  line
  line `(a) the full name, nationality and residential address of the registered person;`
  line
  line `(b) the date of this first admission to the register;`
  line
  line `(c) his qualification for registration, and the date on which he obtained his degree or diploma in`
  line `dentistry, if any, and the authority which conferred it;`
  line
  line `(d) his professional address; and`
  line
  line `(e) such further particulars as may be prescribed.`
obj_root_law_sections_31_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line `2. Subs. by the A.O. 1950, for "Province".`
obj_root_law_sections_32:
  sectionId (28246)
  sectionNo (32)
  orderNo 40
  title `First preparation of register.`
  content obj_root_law_sections_32_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial"`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28246&sectionno=32&orderno=40&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_32_content:
  string
  line `(1) For the purpose of first preparing the register of dentists, the`
  line `^1[State] Government shall, by notification in the Official Gazette, constitute a Registration Tribunal`
  line `consisting of three persons and shall also appoint a Registrar who shall act as Secretary of the Tribunal.`
  line
  line `(2) The ^1[State] Government shall, by the same or a like notification, appoint a date on or before`
  line `which application for registration, which shall be accompanied by the prescribed fee, shall be made to the`
  line `Registration Tribunal.`
  line
  line `(3) The Registration Tribunal shall examine every application received on or before the appointed`
  line `date, and if it is satisfied that the applicant is qualified for registration under section 33, shall direct the`
  line `entry of the name of the applicant on the register.`
  line
  line `(4) The register so prepared shall thereafter be published in such manner as the ^1[State] Government`
  line `may direct, and any person aggrieved by a decision of the Registration Tribunal expressed or implied in`
  line `the register as so published may, within thirty days from the date of such publication, appeal to an`
  line `authority appointed by the ^1[State] Government in this behalf by notification in the Official Gazette.`
  line
  line `(5) The Registrar shall amend the register in accordance with the decisions of the authority appointed`
  line `under sub-section (4) and shall thereupon issue to every person whose name is entered on the register a`
  line `certificate of registration in the prescribed form.`
  line
  line `(6) Upon the constitution of the ^1[State] Council, the register shall be given into its custody, and the`
  line `^1[State] Government may direct that all or any specified part of the application fees for registration in the`
  line `first register shall be paid to the credit of the ^1[State] Council.`
obj_root_law_sections_33:
  sectionId (28247)
  sectionNo (33)
  orderNo 41
  title `Qualifications for entry on first preparation of register.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28247&sectionno=33&orderno=41&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_33_content:
  string
  line `(1) A person shall be entitled on payment of`
  line `the prescribed fee to have his name entered on the register when it is first prepared, if he resides or carries on the`
  line `profession of dentistry in the ^1`
  line
  line `[State] and if he--`
  line
  line `(a) holds a recognised dental qualification, or`
  line
  line `(b) does not hold such a qualification but, being a ^2`
  line `[citizen of India], has been engaged in practice as a`
  line
  line `dentist as his principal means of livelihood for a period of not less than five years prior to ^3`
  line
  line `[the date appointed`
  line
  line `under sub-section (2) of section 32]:`
  line
  line `Provided that no person other than a ^3`
  line `[citizen of India] shall be entitled to registration by virtue of a`
  line
  line qualification--
  line
  line `(a) specified in Part I of the Schedule unless by the law and practice of the State or country to which such`
  line `person belongs persons of Indian origin holding dental qualifications registrable in that State or country are`
  line `permitted to enter and practise the profession of dentistry in such State or country, or`
  line
  line `^4[(b) recognised, in pursuance of a scheme of reciprocity, under sub-section (5) of section 10:]`
  line
  line `Provided further that a person shall be entitled to registration by virtue of a qualification specified in ^5[Part II]`
  line
  line `of the Schedule only if he is a ^3`
  line `[citizen of India]:`
  line
  line `^6[Provided further that for the purpose of the first preparation of the register of dentists under this Act, a person`
  line `shall be entitled to have his name entered in the appropriate part of the register without payment of any registration`
  line fee.--
  line
  line `(a) in the State of Saurashtra ^7[as it existed before the 1st November, 1956], if he is registered on the`
  line `register of dental practitioners maintained under Saurashtra Ordinance No. 25 of 1948, as amended by`
  line `Saurashtra Ordnance No. 40 of 1949; or`
  line
  line `(b) in the State of Travancore-Cochin ^7`
  line `[as it existed before the 1st November, 1956], if he is registered on`
  line `the register of dental practitioners maintained under the Travancore Medical Practitioners Act, 1119; ^8[or]`
  line
  line `^9* * * * * *`
  line
  line `(2) A person domiciled in a ^1`
  line `[State] ^10*** shall be entitled on payment of the prescribed fee to temporary`
  line `registration as a dentist for a period of five years, if he has been engaged in practice as a dentist as his principal means of livelihood for a period of not less than two years during the five years prior to ^11[the date`
  line `appointed under sub-section (2) of section 32], and a person so registered shall be entitled to permanent`
  line `registration if ^12`
  line `[for a period of five years from the date of his temporary registration he has been engaged`
  line `in practice as a dentist].`
obj_root_law_sections_33_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Subs. by the A.O. 1950, for "British subject of Indian domicile".`
  line
  line `3. Subs. by Act 12 of 1955, s. 9, for "the commencement of this Act".`
  line
  line `4. Subs. by Act 42 of 1972, s. 19, for clause (b) (w.e.f. 1-11-1972).`
  line
  line `5. Subs. by s. 19, ibid., for Part III (w.e.f. 1-11-1972).`
  line
  line `6. Subs. by Act 12 of 1955, s. 9, for the last proviso.`
  line
  line `7. Ins. by the Adaptation of Laws (No. 3) Order, 1956.`
  line
  line `8. Ins. by Act 42 of 1972, s. 19 (w.e.f. 1-11-1972).`
  line
  line `9. Clause (c) omitted by the Jammu and Kashmir Reorganisation (Adaptation of Central Laws) Order, 2020, vide notification No. S.O. 1123(E)`
  line `dated (18-3-2020) and vide Union Territory of Ladakh Reorganisation (Adaptation of Central Laws) Order, 2020, Notification No. S.O.`
  line `3774(E), dated (23-10-2020).`
  line
  line `10. The words "or India" omitted, ibid.`
  line
  line `11. Subs. by Act 12 of 1955, s. 9, for "the date of the commencement of this Act".`
  line
  line `12. Subs. by s. 9, ibid., for certain words.`
obj_root_law_sections_34:
  sectionId (28248)
  sectionNo (34)
  orderNo 42
  title `Qualification for subsequent registration.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28248&sectionno=34&orderno=42&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_34_content:
  string
  line `^2[(1)] After the date appointed under`
  line `sub-section (2) of section 32 a person shall, on payment of the prescribed fee, be entitled to have his name`
  line `entered on the register of dentists, if he resides or carries on the profession of dentistry in the ^1[State] and`
  line `if he--`
  line
  line `(i) holds a recognised dental qualification, or`
  line
  line `(ii) does not hold such a qualification but, being a ^3[citizen of India], has been engaged in practice`
  line `practice as a dentist as his principal means of livelihood for a period of not less than ^4[two years`
  line `before the date appointed under sub-section (2) of section 32] and has passed, within a period of ^5[ten`
  line `years after the said date], an examination recognised for this purpose by the ^6[Central Government]:`
  line
  line `Provided that no person other than a ^3[citizen of India] shall be entitled to registration by virtue of a`
  line qualification--
  line
  line `(a) specified in Part I of the Schedule unless by the law and practice of the State or country to`
  line `which such person belongs persons of Indian origin holding dental qualifications registrable in that`
  line `State or country are permitted to enter and practice the profession of dentistry in such State or`
  line `country, or`
  line
  line `^7[(b) recognised, in pursuance of a scheme of reciprocity, under sub-section (5) of section 10:]`
  line
  line `Provided further that a person registered in Part B of the register shall be entitled to be registered in`
  line `Part A thereof, if within a period of ^8[ten years after the date of his registration in Part B] he passes an`
  line `examination recognised for the purpose by the ^6[Central Government].`
  line
  line `^9[(2) Notwithstanding anything contained in sub-section (1),--`
  line
  line `(a) a ^10[State Council] may during the period of two years immediately after the commencement`
  line `of the Dentists (Amendment) Act, ^11[1955 (12 of 1955)], permit for sufficient reasons the registration`
  line `in the State register of any displaced person who does not hold a recognised dental qualification but has been actually practising the profession of dentistry as his principal means of livelihood from a`
  line `date prior to the 29th day of March, 1948;`
  line
  line `Explanation.--In this clause "displaced person" means any person who, on account of the setting`
  line `up of the Dominions of India and Pakistan or on account of civil disturbances or fear of such`
  line `disturbances in any area now forming part of Pakistan has, after the 1st day of March, 1947, left or`
  line `been displaced from, his place of residence in such area and who has since then been residing in`
  line India;
  line
  line `^12[(aa) the State Council may, during the period of two years immediately after the`
  line `commencement of the Dentists (Amendment) Act,1972(42 of 1972), permit, for sufficient reasons,`
  line `the registration in the State register of any displaced person or a repatriate who does not hold any`
  line `recognised dental qualification but has been actually practising the profession of dentistry as his`
  line `principal means of livelihood from a date prior to the 29th day of March, 1948.`
  line
  line `Explanation.--In this clause,--`
  line
  line `(i) "displaced person" means any person who, on account of civil disturbances or fear of such`
  line `disturbances in any area now forming part of Bangla Desh, has, after the 14th day of April, 1957`
  line `but before the 25th day of March, 1971, left. or has been displaced from, his place of residence in`
  line `such area and who has since then been residing in India ;]`
  line
  line `(ii) "repatriate" means any person who, on account of civil disturbances or fear of such`
  line `disturbances in any area now forming part of Burma or Ceylon, has. after the 14th day of April,`
  line `1957, left or has been displaced from, his place of residence in such area and who has since then`
  line `been residing in India;]`
  line
  line `(b) a person other than a citizen of India holding a reputable dental qualification and`
  line `employed for teaching or research in a dental institution situated in any of the States may be`
  line `permitted ^13*** temporary registration in the State register of dentists for the period of his`
  line `employment or for a period of five years, whichever is shorter:`
  line
  line `Provided that he does not practise the profession of dentistry for personal gain and his`
  line `application for registration is approved by the President of the Council.]`
obj_root_law_sections_34_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Province".`
  line
  line `2. Section 34 renumbered as sub-section (1) thereof by Act 12 of 1955, s. 10.`
  line
  line `3. Subs. by the A.O. 1950, for "British subject of Indian domicile."`
  line
  line `4. Subs. by Act 12 of 1955, s. 10, for "two years before the commencement of this Act".`
  line
  line `5. Subs. by s. 10, ibid., for "five years after the commencement of this Act".`
  line
  line `6. Subs. by Act 42 of 1972, s. 20, for "Council" (w.e.f. 1-11-1972).`
  line
  line `7. Subs. by s. 20,ibid.,for clause (b) (w.e.f. 1-11-1972).`
  line
  line `8. Subs. by Act 12 of 1955, s. 10, for "five years".`
  line
  line `9. Ins. by Act 12 of 1955, s. 10.`
  line
  line `10. Subs. by Act 42 of 1972, s. 20, for "State Dental Council" (w.e.f. 1-11-1972).`
  line
  line `11. Subs. by Act 36 of 1957, s. 3 and the Second Schedule, for "1954".`
  line
  line `12. Ins. by Act 42 of 1972, s. 20 (w.e.f. 1-11-1972).`
  line
  line `13. The words "irrespective of any considerations of reciprocity" omitted by s. 20, ibid. (w.e.f. 1-11-1972).`
obj_root_law_sections_35:
  sectionId (28249)
  sectionNo (35)
  orderNo 43
  title `Scrutiny of applications for registration.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28249&sectionno=35&orderno=43&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_35_content:
  string
  line `(1) After the date appointed for the receipt of`
  line `applications for registration in the first register of dentists, all applications for registration shall be`
  line `addressed to the Registrar of the ^1[State] Council and shall be accompanied by the prescribed fee.`
  line
  line `(2)If upon such application the Registrar is of opinion that the applicant is entitled to have his name`
  line `entered on the register, he shall enter thereon the name of the applicant:`
  line
  line `Provided that no person, whose name has under the provisions of this Act been removed from the`
  line `register of any ^2[State], shall be entitled to have his name entered on the register except with the approval`
  line `of the ^1[State] Council from whose register his name was removed.`
  line
  line `(3) Any person whose application for registration is rejected by the Registrar may, within three`
  line `months from the date of such rejection, appeal to the ^1[State] Council, and the decision of the`
  line `^1[State]Council thereon shall be final.`
  line
  line `(4) Upon entry in the register of a name under this section, the Registrar shall issue a certificate of`
  line `registration in the prescribed form .`
obj_root_law_sections_35_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Subs., ibid.,for "Province".`
obj_root_law_sections_35_a:
  sectionId (28250)
  sectionNo 35A
  orderNo 44
  title `Special provision for amending the register of dentists.`
  content obj_root_law_sections_35_a_content
  footnotes `1. Ins. by the Madras Adaptation of Laws Order, 1954.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28250&sectionno=35A&orderno=44&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_35_a_content:
  string
  line `^1[35A. Special provision for amending the register of dentists.--Notwithstanding anything`
  line `contained in this Chapter, the Registrar may, by order in writing, amend the register by deleting therefrom the name of any person who by reason of the formation of the State of Andhra, has ceased to reside or`
  line `carry on the business or profession of dentistry in the State of Madras:`
  line
  line `Provided that the Registrar shall, before passing an order, make such inquiry as he deems necessary.`
  line
  line `(2) Any person aggrieved by an order under sub-section (1) may appeal to such authority and within`
  line `such time, as may be specified in this behalf by the State Government of Madras; and such authority shall`
  line `pass such order on the appeal as it thinks fit.`
  line
  line `(3) An order of the Registrar under sub-section (1), or where an appeal has been preferred against it`
  line `under sub-section (2), the order of the appellate authority shall be final.`
  line
  line `(4) The provision of this section shall cease to be in force from such date as the State Government of`
  line `Madras may by notification in the Official Gazette appoint.]`
obj_root_law_sections_36:
  sectionId (28251)
  sectionNo (36)
  orderNo 45
  title `Registers of dental hygienists and dental mechanics.`
  content obj_root_law_sections_36_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28251&sectionno=36&orderno=45&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_36_content:
  string
  line `(1) The ^1[State] Government may, by`
  line `notification in the Official Gazette direct that the ^1[State] Council shall maintain a register of dental`
  line `hygienists or a register of dental mechanics.`
  line
  line `(2) The provisions of section 35 shall, so far as they may be made applicable, apply in respect of`
  line `applications for registration in a register referred to in this section.`
obj_root_law_sections_37:
  sectionId (28252)
  sectionNo (37)
  orderNo 46
  title `Qualification for registration as a dental hygienist.`
  content obj_root_law_sections_37_content
  footnotes `1. Subs., ibid., for "Province".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28252&sectionno=37&orderno=46&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_37_content:
  string
  line `A person shall be entitled on payment of`
  line `the prescribed fee to have his name registered on the register of dental hygienists, if he resides in the`
  line `^1[State] and holds a recognised dental hygiene qualification:`
  line
  line `Provided that for the purposes of the first register of dental hygienists, a person shall be entitled to be`
  line `registered, if he has been engaged as a dental hygienist as his principal means of livelihood for a period of`
  line `not less than two years prior to the date of notification under sub-section (1) of section 36.`
obj_root_law_sections_38:
  sectionId (28253)
  sectionNo (38)
  orderNo 47
  title `Qualification for registration as a dental mechanic.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28253&sectionno=38&orderno=47&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_38_content:
  string
  line `A person shall be entitled on payment of`
  line `the prescribed fee to have his name entered in the register of dental mechanics, if he satisfies the`
  line `prescribed requirements referred to in section 12:`
  line
  line `Provided that for the purposes of the preparation of the first register of dental mechanics a person`
  line `shall be entitled to be registered, if he has been engaged as a dental mechanic as his principal means of`
  line `livelihood for a period of not less than two years prior to the date of notification under sub-section (1) of`
  line `section 36.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (28254)
  sectionNo (39)
  orderNo 48
  title `Renewal fees.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28254&sectionno=39&orderno=48&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_39_content:
  string
  line `(1) The ^1[State] Government may, by notification in the Official Gazette, direct`
  line `that for the retention of a name in a register after the 31st day of December of the year following the year`
  line `in which the name is first entered in the register, there shall be paid annually to the ^1[State] Council such`
  line `renewal fee as may be prescribed in respect of each register, and where such direction has been made,`
  line `such renewal fee shall be due to be paid before the 1st day of April of the year to which it relates.`
  line
  line `(2) Where a renewal fee is not paid before the due date, the Registrar shall remove the name of the`
  line `defaulter from the register:`
  line
  line `Provided that a name so removed may be restored to the register on payment in such manner as may`
  line `be prescribed.`
  line
  line `^2[(3) On payment of the renewal fee, the Registrar shall issue a certificate of renewal and such`
  line `certificate shall be proof of renewal of registration.]`
obj_root_law_sections_39_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Subs. by Act 42 of 1972, s. 21, for sub-section (3) (w.e.f. 1-11-1972).`
obj_root_law_sections_40:
  sectionId (28255)
  sectionNo (40)
  orderNo 49
  title `Entry of additional qualifications.`
  content obj_root_law_sections_40_content
  footnotes `1. Ins. by Act 12 of 1955, s. 11.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28255&sectionno=40&orderno=49&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_40_content:
  string
  line `A registered dentist shall on payment of the prescribed fee`
  line `be entitled to have entered in the register any further recognised ^1[dental] qualification which he may`
  line obtain.
obj_root_law_sections_41:
  sectionId (28256)
  sectionNo (41)
  orderNo 50
  title `Removal from register.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28256&sectionno=41&orderno=50&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_41_content:
  string
  line `(1) Subject to the provisions of this section, the ^1[State] Council may`
  line `order that the name of any person shall be removed from any register where it is satisfied, after giving that`
  line `person a reasonable opportunity of being heard and after such further inquiry, if any, as it may think fit to`
  line make,--
  line
  line `(i) that his name has been entered in the register by error or on account of misrepresentation or`
  line `suppression of a material fact, or`
  line
  line `(ii) that he has been convicted of any offence or has been guilty of any infamous conduct in any`
  line `professional respect ^2[ or has violated the standards of professional conduct and etiquette or the code`
  line `of ethics prescribed under section 17A], which in the opinion of the ^1[State] Council renders him unfit`
  line `to be kept in the register, ^3[or]`
  line
  line `^3[(iii) that he having been permitted temporary registration under clause (b) of sub-section (2) of`
  line `section 34 has, on such registration, been found to practise the profession of dentistry for personal`
  line gain.]
  line
  line `(2) An order under sub-section (1) may direct that any person whose name is ordered to be removed`
  line `from a register shall be ineligible for registration in the ^4[State] under this Act either permanently or for`
  line `such period of years as may be specified.`
  line
  line `(3) An order under sub-section (1) shall not take effect until the expiry of three months from the date`
  line thereof.
  line
  line `(4) A person aggrieved by an order under sub-section (1) may, within thirty days from the date`
  line `thereof, appeal to the ^1[State] Government, and the order of the ^1State] Government upon such appeal`
  line `shall be final.`
  line
  line `(5) A person whose name has been removed from the register under this section or under`
  line `sub-section (2) of section 39 shall forthwith surrender his certificate of registration ^2[and certificate of`
  line `renewal, if any, to the Registrar, and the name so removed shall be published in the Official Gazette.`
  line
  line `^3[(6) A person whose name has been removed from the State register of dentists under this section or`
  line `under sub-section (2) of section 39 shall not be entitled to have his name registered in the register of`
  line `dentists in any other State register of dentists except with the approval of the State Council from whose`
  line `register his name has been removed.]`
obj_root_law_sections_41_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Ins. by Act 42 of 1972, s. 22 (w.e.f. 1-11-1972).`
  line
  line `3. Ins. by Act 12 of 1955, s. 12.`
  line
  line `4. Subs. by the A.O. 1950, for "Province".`
obj_root_law_sections_42:
  sectionId (28257)
  sectionNo (42)
  orderNo 51
  title `Restoration to register.`
  content obj_root_law_sections_42_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28257&sectionno=42&orderno=51&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_42_content:
  string
  line `The ^1[State] Council may at any time, for reasons appearing to it`
  line `sufficient and subject to the approval of the ^1[State] Government, order that upon payment of the`
  line `prescribed fee the name of a person removed from a register shall be restored thereto.`
obj_root_law_sections_43:
  sectionId (28258)
  sectionNo (43)
  orderNo 52
  title `Bar of jurisdiction.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28258&sectionno=43&orderno=52&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_43_content:
  string
  line `No order refusing to enter a name in a register or removing a name from a`
  line `register shall be called in question in any Court.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (28259)
  sectionNo (44)
  orderNo 53
  title `Issue of duplicate certificates.`
  content obj_root_law_sections_44_content
  footnotes `1. Ins. by Act 42 of 1972, s. 23 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28259&sectionno=44&orderno=53&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_44_content:
  string
  line `Where it is shown to the satisfaction of the Registrar that a`
  line `certificate of registration ^1[or a certificate of renewal] has been lost or destroyed, the Registrar may, on`
  line `payment of the prescribed fee, issue a duplicate certificate in the prescribed form.`
obj_root_law_sections_45:
  sectionId (28260)
  sectionNo (45)
  orderNo 54
  title `Printing of registers.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28260&sectionno=45&orderno=54&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_45_content:
  string
  line `As soon as may be after the 1st day of April in each year, the Registrar`
  line `shall cause to be printed copies of the registers as they stood on the said date and such copies shall be`
  line `made available to persons applying therefor on payment of the prescribed charge, and shall be evidence`
  line `that on the said date the persons whose names are entered therein were registered dentists, registered`
  line `dental hygienists or registered dental mechanics, as the case may be.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (28261)
  sectionNo (46)
  orderNo 55
  title `Effect of registration.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28261&sectionno=46&orderno=55&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_46_content:
  string
  line `(1) Any reference in any other law to a person recognised by law as a`
  line `dentist shall be deemed to be a reference to a dentist registered under this Act.`
  line
  line `(2) No certificate required by or under any other law from a dentist shall be valid unless the person`
  line `signing it is registered as a dentist under this Act.`
  line
  line `(3) After the expiry of ^1[three years] from ^2[the date appointed under sub-section (2) of section 32], a`
  line `person who is not registered in Part A of the ^3[State] register of dentists shall not, except with the sanction`
  line `of ^4[the Central Government or the State Government] hold any appointment as dentist in any dispensary,`
  line `hospital or other institution ^5*** which is supported wholly or partially from public or local funds:`
  line
  line `Provided that the provisions of this sub-section shall not apply to any such person who is holding`
  line `such an appointment ^6[immediately before the said date].`
  line
  line `(4) After the expiry of two years from the publication of a register of dental hygienists in a ^7[State],`
  line `no person whose name is not entered in that register shall hold appointment as dental hygienist in any`
  line `dispensary, hospital or other institution in the ^7[State] which is supported wholly or partially from public`
  line `or local funds.`
  line
  line `(5) Any person who is a registered dentist, registered dental hygienist or registered dental mechanic in`
  line `a ^7[State] may practise as such in any other ^7[State].`
obj_root_law_sections_46_footnotes:
  string
  line `1. Subs. by Act 58 of 1950, s. 3, for "two years".`
  line
  line `2. Subs. by Act 12 of 1955, s. 13, for "the commencement of this Act".`
  line
  line `3. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `4. Subs. by Act 12 of 1955, s. 13, for "the State Government".`
  line
  line `5. The words "in the State" omitted by s. 13, ibid.`
  line
  line `6. Subs. by s. 13, ibid., for "at the commencement of this Act".`
  line
  line `7. Subs. by the A.O. 1950, for "Province".`
obj_root_law_sections_46_a:
  sectionId (28262)
  sectionNo 46A
  orderNo 56
  title `Transfer of registration.`
  content obj_root_law_sections_46_a_content
  footnotes `1. Ins. by Act 42 of 1972, s. 24 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28262&sectionno=46A&orderno=56&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_46_a_content:
  string
  line `^1[46A.Transfer of registration.--Where a dentist registered in one State is practising dentistry in`
  line `another State, he may, on payment of the prescribed fee which shall not exceed the renewal fee for`
  line `registration in such other State, make an application in the prescribed form to the Council for the transfer`
  line `of his name from the register of the State where he is registered to the register of the State in which he is`
  line `practising dentistry, and on receipt of any such application, the Council shall, notwithstanding anything`
  line `contained elsewhere in this Act, direct that the name of such person be removed from the first-mentioned`
  line `register and entered in the register of the Second-mentioned State and the State Councils concerned shall`
  line `comply with such directions:`
  line
  line `Provided that such a person shall be required to produce a certificate to the effect that all dues in`
  line `respect of his registration in the former State have been paid:`
  line
  line `Provided further that where any such application for transfer is made by a dentist against whom any`
  line `disciplinary proceeding is pending or where for any other reason it appears to the Council that the`
  line `application for transfer has not been made bona fide and the transfer should not be made, the Council`
  line `may, after giving the dentist a reasonable opportunity of making a representation in this behalf, reject the`
  line application.]
obj_root_law_sections_47:
  sectionId (28263)
  sectionNo (47)
  orderNo 57
  title `Penalty for falsely claiming to be registered.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28263&sectionno=47&orderno=57&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_47_content:
  string
  line `If any person whose name is not for the time`
  line `being entered in a register falsely represents that it is so entered, or uses in connection with his name or`
  line `title any words or letters reasonably calculated to suggest that his name is so entered, he shall be`
  line `punishable on first conviction with fine which may extend to five hundred rupees, and on any subsequent`
  line `conviction with imprisonment which may extend to six months or with fine not exceeding one thousand`
  line `rupees or with both.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (28264)
  sectionNo (48)
  orderNo 58
  title `Misuse of titles.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28264&sectionno=48&orderno=58&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_48_content:
  string
  line `If any person,--`
  line
  line `(a) not being a person registered in a register of dentists, takes or uses the description of dental`
  line `practitioner, dental surgeon, surgeon dentist, or dentist, or`
  line
  line `(b) not being a person whose name entered on a register of dental hygienists, takes or uses in a`
  line `^1[State] where such register has been published, the title of dental hygienist, or`
  line
  line `(c) not being a person whose name is entered on a register of dental mechanics, takes or uses in a`
  line `^1[State] where such register has been published, the title of dental mechanic, ^2[or]`
  line
  line `^2[(d) not possessing a recognised dental qualification, uses a degree or a diploma or an`
  line `abbreviation indicating or implying a dental qualification,]`
  line
  line `he shall be punishable on first conviction with fine which may extend to five hundred rupees, and any`
  line `subsequent, conviction with imprisonment which may extend to six months or with fine not exceeding`
  line `one thousand rupees or with both.`
obj_root_law_sections_48_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Province".`
  line
  line `2. Ins. by Act 12 of 1955, s. 14`
obj_root_law_sections_49:
  sectionId (28265)
  sectionNo (49)
  orderNo 59
  title `Practice by unregistered persons.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28265&sectionno=49&orderno=59&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_49_content:
  string
  line `(1) After the expiry of ^1[three years] from ^2[the date`
  line `appointed under sub-section (2) of section 32] in the case of dentists, and in the ^3[States] where a register`
  line `of dental hygienists or dental mechanics has been prepared under section 36 from such date as may be`
  line `specified in this behalf by the ^4[State] Government by notification in the Official Gazette, in the case of`
  line `dental hygienists or dental mechanics, no person, other than a registered dentist, registered dental`
  line `hygienist or registered dental mechanic, shall practise dentistry, or the art of scaling, cleaning or polishing`
  line `teeth, or of making or repairing dentures and dental appliances, as the case may be, or indicate in any way`
  line `that he is prepared to so practise:`
  line
  line `Provided that the provisions of this section shall not apply to--`
  line
  line `(a) practice of dentistry by a registered medical practitioner;`
  line
  line `(b) the extraction of a tooth by any person when the case is urgent and no registered dentist is`
  line `available, so however that the operation is performed without the use of any general or local`
  line anaesthetic;
  line
  line `(c) the performance of dental work or radiographic work in any hospital or dispensary maintained`
  line `or supported from public or local funds.`
  line
  line `(2) If any person contravenes the provisions of sub-section (1), he shall be punishable on first`
  line `conviction with fine which may extend to five hundred rupees, and on any subsequent conviction with`
  line `imprisonment which may extend to six months or with fine not exceeding one thousand rupees or with`
  line both.
obj_root_law_sections_49_footnotes:
  string
  line `1. Subs. by Act 58 of 1950, s. 3, for "two years" (retrospectively).`
  line
  line `2. Subs. by Act 12 of 1955, s. 15, for "the commencement of this Act".`
  line
  line `3. Subs. by the A.O. 1950, for "Provinces".`
  line
  line `4. Subs., ibid., for "Provincial".`
obj_root_law_sections_50:
  sectionId (28266)
  sectionNo (50)
  orderNo 60
  title `Failure to surrender certificate of registration.`
  content obj_root_law_sections_50_content
  footnotes `1. Ins. by Act 42 of 1972, s. 25 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28266&sectionno=50&orderno=60&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_50_content:
  string
  line `If any person whose name has been removed`
  line `from a register fails without sufficient cause forthwith to surrender his certificate of registration ^1[or`
  line `certificate of renewal, or both], he shall be punishable with fine which may extend to fifty rupees per`
  line `month of such failure and in the case of a continuing offence with an additional fine which may extend to`
  line `two rupees per day after the first day during which the offence continues.`
obj_root_law_sections_51:
  sectionId (28267)
  sectionNo (51)
  orderNo 61
  title `Companies not to engage in dentistry.`
  content obj_root_law_sections_51_content
  footnotes `1. Subs. by Act 12 of 1955, s. 16, for "at the date of the commencement of this Act".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28267&sectionno=51&orderno=61&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_51_content:
  string
  line `(1) Except as hereinafter provided, the profession of`
  line `dentistry shall not be carried on by a company or other corporate body.`
  line
  line `(2) The provisions of sub-section (1) shall not apply to--`
  line
  line `(a) a company or other corporate body which carries on no business other than the profession of`
  line `dentistry or some business ancillary to the profession of dentistry and of which the majority of the`
  line `directors and all the operating staff are registered dentists;`
  line
  line `(b) the carrying on of the profession of dentistry by employers who provide dental treatment for`
  line `their employees by registered dentists otherwise than for profit;`
  line
  line `(c) the carrying on of the profession of dentistry by any hospital or dispensary or institution for`
  line `the training of dentists or dental hygienists or by any local authority or other body authorised or`
  line `required by law to provide dental treatment:`
  line
  line `Provided that any company or other corporate body carrying on the profession of dentistry`
  line `^1[immediately before the date appointed under sub-section (2) of section 32] may continue so to do until`
  line `the expiry of three years from such date.`
  line
  line `(3) if any person contravenes the provisions of sub-section (1), he shall be punishable with fine which`
  line `may extend, on first conviction to five hundred rupees, or on any subsequent conviction with`
  line `imprisonment which may extend to six months or with fine not exceeding one thousand rupees or with`
  line both.
obj_root_law_sections_52:
  sectionId (28268)
  sectionNo (52)
  orderNo 62
  title `Cognizance of offences.`
  content obj_root_law_sections_52_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28268&sectionno=52&orderno=62&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_52_content:
  string
  line `No court shall take cognizance of any offence punishable under this`
  line `Act except upon complaint made by order of the ^1[State] Government or the ^1[State] Council.`
obj_root_law_sections_53:
  sectionId (28269)
  sectionNo (53)
  orderNo 63
  title `Payment of part of fees to Council.`
  content obj_root_law_sections_53_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28269&sectionno=53&orderno=63&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_53_content:
  string
  line `The ^1[State] Council shall before the end of June in each`
  line `year pay to the Council a sum equivalent to one-fourth of the total fees realised by the ^1[State] Council`
  line `under this Act during the period of twelve months ending on the 31st day of March of that year.`
obj_root_law_sections_53_a:
  sectionId (28270)
  sectionNo 53A
  orderNo 64
  title `Accounts and audit.`
  content obj_root_law_sections_53_a_content
  footnotes `1. Ins. by Act 42 of 1972, s. 26 (w.e.f. 1-11-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28270&sectionno=53A&orderno=64&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_53_a_content:
  string
  line `^1[53A.Accounts and audit.-- (1) The Council shall maintain appropriate accounts and other relevant`
  line `records and prepare an annual statement of accounts including the balance-sheet, in accordance with such`
  line `general directions as may be issued and in such form as may be specified by the Central Government in`
  line `consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Council shall be audited annually by the Comptroller and Auditor-General of`
  line `India or any person appointed by him in this behalf and any expenditure incurred by him or any person so`
  line `appointed in connection with such audit shall be payable by the Council to the Comptroller and AuditorGeneral`
  line `of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Council shall have the same rights and privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of Government accounts, and in particular, shall have the right to demand the production of books`
  line `of accounts, connected vouchers and other documents and papers and to inspect the office of the Council.`
  line
  line `(4) The accounts of the Council as certified by the Comptroller and Auditor-General of India or any`
  line `person appointed by him in this behalf, together with the audit report thereon, shall be forwarded annually`
  line `to the Central Government.`
  line
  line `(5) A copy of the accounts of the Council as so certified together with the audit report thereon shall be`
  line `forwarded simultaneously to the Council.]`
obj_root_law_sections_54:
  sectionId (28271)
  sectionNo (54)
  orderNo 65
  title `Appointment of Commission of Enquiry.`
  content obj_root_law_sections_54_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28271&sectionno=54&orderno=65&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_54_content:
  string
  line `(1) Whenever it appears to the Central Government`
  line `that the Council is not complying with any of the provisions of this Act, the Central Government may`
  line `appoint a Commission of Enquiry consisting of three persons, two of whom shall be appointed by the`
  line `Central Government, one being the Judge of a High Court, and one by the Council; and refer to it the`
  line `matters on which the enquiry is to be made.`
  line
  line `(2) The Commission shall proceed to enquire in a summary manner and report to the Central`
  line `Government on the matters referred to it together with such remedies, if any, as the Commission may like`
  line `to recommend.`
  line
  line `(3) The Central Government may accept the report or remit the same to the Commission for`
  line `modification or reconsideration.`
  line
  line `(4) After the report is finally accepted, the Central Government may order the Council to adopt the`
  line `remedies so recommended within such time as may be specified in the order and if the Council fails to comply within the time so specified, the Central Government may pass such order or take such action as`
  line `may be necessary to give effect to the recommendations of the Commission.`
  line
  line `(5) Whenever it appears to the ^1[State] Government that the ^1[State] Council is not complying with`
  line `any of the provisions of this Act, the ^1[State] Government may likewise appoint a similar Commission of`
  line `Enquiry in respect of the ^1[State] Council to make enquiry in like manner and pass such order or take such`
  line `action as specified in sub-sections (3) and (4).`
obj_root_law_sections_55:
  sectionId (28272)
  sectionNo (55)
  orderNo 66
  title `Power to make rules.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00002_194816_1517807317945&sectionId=28272&sectionno=55&orderno=66&orgactid=AC_CEN_12_13_00002_194816_1517807317945
obj_root_law_sections_55_content:
  string
  line `(1) The ^1[State] Government may, by notification in the Official Gazette,`
  line `make rules to carry out the purposes of Chapters III, IV and V.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for--`
  line
  line `(a) the management of the property of the ^1[State] Council, and the maintenance and audit of its`
  line accounts;
  line
  line `(b) the manner in which elections under Chapter III shall be conducted;`
  line
  line `(c) the summoning and holding of meetings of the ^1[State] Council, the times and places at which`
  line `such meetings shall be held, the conduct of business thereat and the number of members necessary to`
  line `form a quorum;`
  line
  line `(d) the powers and duties of the President and Vice-President of the ^1[State] Council;`
  line
  line `(e) the constitution and functions of the Executive Committee, the summoning and holding of`
  line `meetings thereof, the times and places at which such meetings shall be held, the number of members`
  line `necessary to constitute a quorum;`
  line
  line `(f) the term of office and the powers and duties of the Registrar and other officers and servants of`
  line `the ^1[State] Council, including the amount and nature of the security to be given by the Treasurer;`
  line
  line `(g) the particulars to be stated, and the proof of qualifications to be given in applications for`
  line `registration under this Act;`
  line
  line `^2[(gg) the form of application for transfer of registration from one State to another;]`
  line
  line `^3[(h) the charge for supplying printed copies of the registers, and the fees payable fo--`
  line
  line `(i) registration or renewal of registration;`
  line
  line `(ii) supplying a duplicate certificate of registration or renewal; and`
  line
  line `(iii) transfer of registration from one State to another;`
  line
  line `(i) the forms of certificates of registration and renewal;`
  line
  line `(j) any other matter which is to be or may be prescribed under Chapters III, IV and V, except`
  line `sub-sections (1), (2), (3) and (4) of section 54.]`
  line
  line `^4[(3) Every rule made by the State Government under this section shall be laid, as soon as may be`
  line `after it is made, before the State Legislature.]`
obj_root_law_sections_55_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Ins. by Act 42 of 1972, s. 27 (w.e.f. 1-11-1972).`
  line
  line `3. Subs. by s. 27, ibid., for clauses (h) and (i) (w.e.f. 1-11-1972).`
  line
  line `4. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986)`
