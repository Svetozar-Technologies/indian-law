obj_root_law_sections_1:
  sectionId (29950)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_19683_1532945434555&sectionId=29950&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00072_19683_1532945434555
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Jammu and Kashmir`
  line `Representation of the People (Supplementary) Act, 1968.`
  line
  line `(2) It shall be deemed to have come into force on the 9th day of February, 1968.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (29951)
  sectionNo (2)
  orderNo 2
  title `Application of sections 116A, 116B and 116C of the Representation of the People Act, 1951, to orders made by Jammu and Kashmir High Court.`
  content obj_root_law_sections_2_content
  footnotes `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_19683_1532945434555&sectionId=29951&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00072_19683_1532945434555
obj_root_law_sections_2_content:
  string
  line `The provisions of sections`
  line `116A, 116B and 116C of the Representation of the People Act, 1951 (43 of 1951) shall, so far as may`
  line `be, apply to every order made by the High Court of Jammu and Kashmir subject to the following`
  line `modifications, namely:`
  line
  line `(a) references therein to the High Court shall be construed as including references to the High`
  line `Court of Jammu and Kashmir,`
  line
  line `(b) references therein to the State Legislature or to the Speaker or Chairman thereof, shall be`
  line `construed as including references to the Legislature of the State of Jammu and Kashmir* and to the`
  line `Speaker or Chairman thereof, and`
  line
  line `(c) references therein to the provisions of the Representation of the People`
  line `Act, 1951 (43 of 1951), shall, in relation to the State of Jammu and Kashmir*, be construed as`
  line `references to the corresponding provisions of the Jammu and Kashmir Representation of the`
  line `People Act, 1957 (Jammu and Kashmir Act No. IV of 1957).`
obj_root_law_sections_3:
  sectionId (29952)
  sectionNo (3)
  orderNo 3
  title `Repeal and saving.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00072_19683_1532945434555&sectionId=29952&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00072_19683_1532945434555
obj_root_law_sections_3_content:
  string
  line `(1) The Jammu and Kashmir Representation of the People`
  line `(Supplementary) Ordinance, 1968 (2 of 1968) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall`
  line `be deemed to have been done or taken under this Act 1957.`
obj_root_law_sections_3_footnotes:
  string
  line
