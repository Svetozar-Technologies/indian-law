  content obj_root_law_sections_877_content
  footnotes obj_root_law_sections_877_footnotes
  sourcePage 877
obj_root_law_sections_877_content:
  string
  line 877
  line `THE FOURTEENTH SCHEDULE`
  line `[ See section 80-IC( 2 )]`
  line `LIST OF ARTICLES OR THINGS OR OPERATIONS`
  line `PART A`
  line _______
  line `F OR THE NORTH-EASTERN STATES`
  line `1. Fruit and Vegetable Processing industries manufacturing or producing —`
  line `( i ) Canned or bottled products;`
  line `( ii ) Aseptic packaged products;`
  line `( iii ) Frozen products;`
  line `( iv ) De-hydrated products;`
  line `( v ) Oleoresins.`
  line `2. Meat and Poultry Product industries manufacturing or producing —`
  line `( i ) Meat Products (buffalo, sheep, goat and pork);`
  line `( ii ) Poultry production;`
  line `( iii ) Egg Powder Plant.`
  line `3. Cereal Based Product industries manufacturing or producing —`
  line `( i ) Maize Milling including starch and its derivatives;`
  line `( ii ) Bread, Biscuits, Breakfast Cereal.`
  line `4. Food and Beverage industries manufacturing or producing —`
  line `( i ) Snacks;`
  line `( ii ) Non-alcoholic beverages;`
  line `( iii ) Confectionery including chocolate;`
  line `( iv ) Pasta products;`
  line `( v ) Processed spices, etc.;`
  line `( vi ) Processed pulses;`
  line `( vii ) Tapioca products.`
  line `5. Milk and milk based product industries manufacturing or producing —`
  line `( i ) Milk powder;`
  line `( ii ) Cheese;`
  line `( iii ) Butter/ghee;`
  line `( iv ) Infant food;`
  line `( v ) Weaning food;`
  line `( vi ) Malted milk food.`
  line `6. Food packaging industry.`
  line `7. Paper products industry.`
  line `8. Jute and mesta products industry.`
  line `9. Cattle or poultry or fishery feed products industry.`
  line `10. Edible Oil processing or vanaspati industry.`
obj_root_law_sections_877_footnotes:
  string
  line
