obj_root_law_sections_132:
  kind page
  sectionId pdf-page-132
  sectionNo (132)
  orderNo 132
  title `Page 132`
  content obj_root_law_sections_132_content
  footnotes obj_root_law_sections_132_footnotes
  sourcePage 132
obj_root_law_sections_132_content:
  string
  line 132
  line `1 [( 1A ) All applications, pending before the 2 [Principal Chief Commissioner or Chief Commissioner]`
  line `on which no order has been passed under clause ( b ) of sub-section ( 1 ) before the 1st day of June, 1999,`
  line `shall stand transferred on that day to the 3 [Principal Commissioner or Commissioner] and the 3 [Principal`
  line `Commissioner or Commissioner] may proceed with such applications under that sub-section from the`
  line `stage at which they were on that day.]`
  line `( 2 ) Every order granting or refusing registration under clause ( b ) of sub-section ( 1 ) shall be passed`
  line `before the expiry of six months from the end of the month in which the application was received under`
  line `clause ( a ) 4 [or clause ( aa ) 5 [or clause ( ab )] of sub-section ( 1 )] of section 12A.]`
  line `6 [( 3 ) Where a trust or an institution has been granted registration under clause ( b ) of sub-section ( 1 )`
  line `7 [or has obtained registration at any time under section 12A. [as it stood before its amendment by the`
  line `Finance (No. 2) Act, 1996 (33 of 1996)]] and subsequently the 3 [Principal Commissioner or`
  line `Commissioner] is satisfied that the activities of such trust or institution are not genuine or are not being`
  line `carried out in accordance with the objects of the trust or institution, as the case may be, he shall pass an`
  line `order in writing cancelling the registration of such trust or institution:`
  line `Provided that no order under this sub-section shall be passed unless such trust or institution has been`
  line `given a reasonable opportunity of being heard.]`
  line `8 [( 4 ) Without prejudice to the provisions of sub-section ( 3 ), where a trust or an institution has been`
  line `granted registration under clause ( b ) of sub-section ( 1 ) or has obtained registration at any time under`
  line `section 12A [as it stood before its amendment by the Finance (No. 2) Act, 1996 (33 of 1996)] and`
  line `subsequently it is noticed that the activities of the trust or the institution are being carried out in a manner`
  line `that the provisions of sections 11 and 12 do not apply to exclude either whole or any part of the income of`
  line `such trust or institution due to operation of sub-section ( 1 ) of section 13, then, the Principal`
  line `Commissioner or the Commissioner may by an order in writing cancel the registration of such trust or`
  line `institution:`
  line `Provided that the registration shall not be cancelled under this sub-section, if the trust or institution`
  line `proves that there was a reasonable cause for the activities to be carried out in the said manner.]`
  line `1. Ins. by Act 27 of 1999, s. 9 (w.e.f. 1-6-1999).`
  line `2. Subs. by Act 25 of 2014, s. 4, for “Chief Commissioner” (w.r.e.f. 1 -6-2013)`
  line `3. Subs. by s. 4, ibid., for “Commissioner” (w.r.e.f. 1 -6-2013)`
  line `4. Ins. by Act 22 of 2007, s. 9 (w.e.f. 1-6-2007).`
  line `5. Ins. by Act 7 of 2017, s. 10 (w.e.f. 1-4-2018).`
  line `6. Ins. by Act 23 of 2004, s. 6 (w.e.f. 1-10-2004).`
  line `7. Ins. by Act 14 of 2010, s. 7 (w.e.f. 1-6-2010).`
  line `8. Ins. by Act 25 of 2014, s. 9 (w.e.f. 1-10-2014).`
