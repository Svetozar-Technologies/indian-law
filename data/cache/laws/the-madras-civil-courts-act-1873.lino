obj_root_law_sections_1:
  sectionId (46468)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46468&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_1_content:
  string
  line `This Act may be called "The Madras Civil Court's Act, 1873":`
  line
  line `Local extent. — It extends to all the territories for the time being under the government of the`
  line `Governor of Fort. St. George in Council, except the Tracts respectively under the jurisdiction of the`
  line `Agents for Ganjam and. Vizagapatam .`
  line
  line `Commencement. — And it shall come into force on the first day of March, 1873.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (46469)
  sectionNo (2)
  orderNo 2
  title [Repealed.].
  content `[Repeal of enactments]. — Rep. by the Repealing Act, 1873 (12 of 1873), s. 2 and the Schedule.`
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46469&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (46470)
  sectionNo (3)
  orderNo 3
  title `Number of District Courts.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46470&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_3_content:
  string
  line `The number of District (heretofore designated Zila) Courts to`
  line `be established or continued under this`
  line
  line `Act, shall be fixed, and may from time to time be altered, by the Local Government :`
  line
  line `Provided that no increase to the number of such Courts shall be made by such Government without`
  line `the previous sanction of the Governor General in Council.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (46471)
  sectionNo (4)
  orderNo 4
  title `Number of Subordinate Judges and District Munsifs.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46471&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_4_content:
  string
  line `The number of Subordinate Judges`
  line `and District Munsifs to be appointed under this Act for each District, shall be fixed, and may from`
  line `time to time be altered, by the Local Government :`
  line
  line `Provided that no addition to the number of such officers shall be made by such Government`
  line `without the previous sanction of the Governor General in Council.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (46472)
  sectionNo (5)
  orderNo 5
  title `Court's locality.`
  content obj_root_law_sections_5_content
  footnotes `1. Added by Act 21 of 1885, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46472&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_5_content:
  string
  line `The place at which any Court under this Act shall be held may be fixed, and`
  line `may, from time to time, be altered,`
  line
  line `in the case of a District Court or a Subordinate Judge's Court, by the Local Government,`
  line
  line `in the case of a District Munsif's Court, by the High Court.`
  line
  line ^1
  line `[The places fixed for any Court under this section shall be deemed to be within the local`
  line `jurisdiction of that Court.]`
obj_root_law_sections_6:
  sectionId (46473)
  sectionNo (6)
  orderNo 6
  title `Appointment to vacancy in office of District Judge or Subordinate Judge.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46473&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_6_content:
  string
  line `Whenever the`
  line `office of the Judge of a District Court (hereinafter called a 'District Judge') or of a Subordinate Judge`
  line `under this Act is vacant,`
  line
  line `or whenever the Governor General in Council has sanctioned an addition to the number of District`
  line `Judges or Subordinate Judges under the provisions of section three or section four,`
  line
  line `the Local Government shall appoint to the office such duly qualified person as it thinks proper.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (46474)
  sectionNo (7)
  orderNo 7
  title `Appointment to vacancy in office of District Munsif.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46474&sectionno=7&orderno=7&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_7_content:
  string
  line `Whenever the office of a District`
  line `Munsif under Appointment.—this Act is vacant,`
  line
  line `the High Court shall appoint to the office such person as it thinks fit :`
  line
  line `Provided that he possesses the qualifications for the time being required by the rules in this behalf`
  line `which the High Court, with the previous sanction of the Local Government, are hereby empowered to`
  line `make and alter.`
  line
  line `Publication of appointments. — Every appointment made under this section shall be published in`
  line `the same manner as appointments made by the Local Government.`
  line
  line `Annulment of appointments . — The Local Government may, for good and sufficient, reason,`
  line `annul any appointment made under this section.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (46475)
  sectionNo (8)
  orderNo 8
  title `District Courts, Subordinate Judges and District Munsifs.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46475&sectionno=8&orderno=8&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_8_content:
  string
  line `The present Zila Courts,`
  line `Principal Sadr Amins, and District Munsifs, shall be respectively the first "District Courts,"`
  line `"Subordinate Judges," and "Dis-District rict Munsifs" under this Act.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (46476)
  sectionNo (9)
  orderNo 9
  title `Seal of Court.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46476&sectionno=9&orderno=9&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_9_content:
  string
  line `Every Court under this Act shall use a seal of such form and dimensions as`
  line `are, for the time being, prescribed by the Local Government.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (46478)
  sectionNo (10)
  orderNo 10
  title `Local limits of jurisdiction of District Court or Subordinate Judge.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46478&sectionno=10&orderno=10&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_10_content:
  string
  line `The Local`
  line `Government shall fix, and may from time to time vary, the local limits of the juris-diction of any`
  line `District Judge Subordinate Judge under this Act:`
  line
  line `Local limits of jurisdiction of each of several Subordinate Judges. — Provided that, where`
  line `more than one Subordinate Judge is appointed to any district, the District Judge may assign to each`
  line `such Subordinate Judge the local limits of his particular jurisdiction within such district.`
  line
  line `The present local limits of the jurisdiction of every Civil Court (other than the High Court) shall be`
  line `deemed to have been fixed under this Act.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (46479)
  sectionNo (11)
  orderNo 11
  title `Local jurisdiction of District Munsifs.`
  content obj_root_law_sections_11_content
  footnotes `1. Added by s. 3, ibid.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46479&sectionno=11&orderno=11&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_11_content:
  string
  line `The High Court shall fix, and may from time to`
  line `time modify, the local jurisdiction of District Munsifs.`
  line
  line ^1
  line `[If the High Court assigns the same local jurisdiction to two or more District Munsifs, it shall`
  line `declare which of them shall be deemed the Principal District Munsif, and the other, or others, shall be`
  line `called Additional District Munsifs, and shall take cognizance only of such suits and applications as`
  line `may, by special or general order in this behalf, be directed by the District Judge.]`
obj_root_law_sections_12:
  sectionId (46907)
  sectionNo (12)
  orderNo 12
  title `Jurisdiction of District Judge or Subordinate Judge in original suits.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46907&sectionno=12&orderno=12&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_12_content:
  string
  line `The jurisdiction of a`
  line `District Judge or a Subordinate Judge extends, subject to the rules contained in the Code of Civil`
  line `Procedure, to all original suits and proceedings of a civil nature.`
  line
  line `Jurisdiction of District Munsif. —The jurisdiction of a District Munsif extends to all like suits`
  line `and proceedings, not otherwise exempted from his cognizance, of which the amount or value of the`
  line `subject-matter does not exceed two thousand five hundred rupees.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (46481)
  sectionNo (13)
  orderNo 13
  title `Appeals from decrees of District Courts.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46481&sectionno=13&orderno=13&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_13_content:
  string
  line `Regular or special appeals, ^1`
  line `*** shall, when`
  line `such appeals are allowed by law, lie from the decrees and orders of a District Court to the High Court.`
  line
  line `Appellate jurisdiction of District Court.—Appeals from the decrees and orders of Subordinate`
  line `Judges and District. Mirnsifs shall, when such appeals are allowed by law, lie to the District Court,`
  line `except when the amount or value of the subject-matter of the suit exceeds rupees five thousand, in`
  line `which case the appeal shall lie to the High Court:`
  line
  line `Appellate jurisdiction of Subordinate Judge. —Provided that, whenever a Subordinate Judges`
  line `Court is established in any District at a place remote from the station of the District Court, the High`
  line `Court may, with the previous sanction of the Local Government, direct that appeals from the decrees`
  line `or orders of District Munsifs within the local limits of the jurisdiction of such Subordinate Judge be`
  line `preferred in the Court of the latter:`
  line
  line `Disposal of appeal by District Judge.—Provided also, that the District Judge may remove`
  line `to his own Court, from time to time, appeals so preferred, and dispose of them himself, or may,`
  line `subject to the orders of the High Court, refer any appeals from the decrees and orders of`
  line `District Munsifs, preferred in the District Court, to any Subordinate Judge within the District.`
obj_root_law_sections_13_footnotes:
  string
  line `1. The words and figures "or appeals under Madras Regulation XI of 1832, section nine," rep. by Act 12 of 1891, the First`
  line Schedule.
obj_root_law_sections_14:
  sectionId (46483)
  sectionNo (14)
  orderNo 14
  title `Valuation of suits for immovable property.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46483&sectionno=14&orderno=14&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_14_content:
  string
  line `When the subject-matter of any suit or`
  line `proceeding is land, a house or a garden;, its value shall, for the purposes of the jurisdiction`
  line `conferred by this Act, be fixed in manner provided by the Court Fees' Act, 1870, section seven`
  line `clause v.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (46484)
  sectionNo (15)
  orderNo 15
  title `Power to require witness or party to make oath or affirmation.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46484&sectionno=15&orderno=15&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_15_content:
  string
  line `Every Court under this`
  line `Act may require a witness or party to any suit or other proceeding pending in such Court to make such`
  line `oath or affirmation as is prescribed by the law for the time being in force.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (46908)
  sectionNo (16)
  orderNo 16
  title `Law administered by Courts to Natives.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46908&sectionno=16&orderno=16&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_16_content:
  string
  line `Where, in any suit or proceeding, it is necessary`
  line `for any Court under this Act to decide any question regarding succession, inheritance, marriage or`
  line `caste, or any religious usage or institution,`
  line
  line `(a) the Muhammadan law in cases where the parties are Muhammadans, and the Hindu law in`
  line `cases where the parties are Hindus, or`
  line
  line `(b) any custom (if such there be) having the force of law and governing the parties or property`
  line concerned,
  line
  line `shall form the rule of decision, unless such law or custom has, by legislative enactment, been`
  line `altered or abolished.`
  line
  line `(c) In cases where no specific rule exists, the Court shall act according to justice, equity and`
  line `good conscience.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (46502)
  sectionNo (17)
  orderNo 17
  title `Judges not to try suits in which they are interested; nor to try appeals from decrees passed by them in other capacities.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46502&sectionno=17&orderno=17&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_17_content:
  string
  line `No District Judge, Subordinate Judge`
  line `or District Munsif, shall try any suit to or in which he is a party or personally interested, or shall`
  line `adjudicate upon any proceeding connected with, or arising out of, such suit.`
  line
  line `nor to try appeals form decrees passed by them in other capacities.— No District Judge or`
  line `Subordinate Judge, shall try any appeal against a decree or order passed by himself in another`
  line capacity.
  line
  line `Mode of disposing of such suits and appeals. — When any such suit, proceeding or appeal`
  line `comes before any such officer, he shall report the circumstances to the Court to which he is`
  line `immediately subordinate.`
  line
  line `The superior Court shall thereupon dispose of the case in the manner prescribed by the Code of`
  line `Civil Procedure, section six.`
  line
  line `Nothing in the last preceding clause of this section shall be deemed to affect the extraordinary`
  line `original civil jurisdiction of the High Court.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (46487)
  sectionNo (18)
  orderNo 18
  title `Suspension of Judge by Local Government.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46487&sectionno=18&orderno=18&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_18_content:
  string
  line `Any District Judge, Subordinate Judge, or`
  line `District Munsif may, for any misconduct, be suspended or removed by the Local Government.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (46488)
  sectionNo (19)
  orderNo 19
  title `Suspension of Subordinate Judge by High Court.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46488&sectionno=19&orderno=19&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_19_content:
  string
  line `The High Court may, whenever it sees`
  line `urgent necessity for so doing, suspend a Subordinate Judge pending the orders of the Local`
  line Government.
  line
  line `The High Court shall immediately report the circumstances of such suspension,`
  line
  line `and the Local Government shall make such order thereon as it thinks fit.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (46489)
  sectionNo (20)
  orderNo 20
  title `Suspension of District Munsif by High Court. Commission of Inquiry.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46489&sectionno=20&orderno=20&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_20_content:
  string
  line `The High Court`
  line `may suspend any District Munsif who is alleged to have misconducted himself, or may appoint a`
  line `commission for enquiring into his alleged misconduct.`
  line
  line `Exercise by High Court of powers conferred on Government by Act 37 of 1850. — The`
  line `provisions of Act No. 37 of 1850 (for regulating enquiries into the behaviour of public servants) shall`
  line `apply to enquiries under this section, the powers conferred by that Act on the Government being`
  line `exercised by the High Court.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (46490)
  sectionNo (21)
  orderNo 21
  title `Suspension of District Munsif by District Judge.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46490&sectionno=21&orderno=21&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_21_content:
  string
  line `The District Judge may suspend from`
  line `office, whenever he sees urgent necessity for so doing, any District Munsif under his control.`
  line
  line `Report to High Court. —Whenever a District Judge exercises the power Report to conferred by`
  line `this section, he shall forthwith send to High Court the High Court a full report of the circumstances of`
  line `the case, together with the evidence, if any, and the High Court shall make such order thereon as it`
  line `thinks fit.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (46491)
  sectionNo (22)
  orderNo 22
  title `Appointment, suspension or removal of Ministerial Officers of District Courts.`
  content obj_root_law_sections_22_content
  footnotes `1. Ins. by Act 21 of 1885, s. 4.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46491&sectionno=22&orderno=22&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_22_content:
  string
  line The
  line `Ministerial Officers of the District Courts shall be appointed, and may be suspended or removed, by`
  line `the Judges of such Courts, whose orders in such matters shall ^1`
  line `[subject to the control of the High`
  line `Court] be final.`
obj_root_law_sections_23:
  sectionId (46492)
  sectionNo (23)
  orderNo 23
  title `Appointment and removal of ministerial officers of subordinate Courts.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46492&sectionno=23&orderno=23&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_23_content:
  string
  line ^2
  line `[23. Appointment and removal of ministerial officers of subordinate Courts.—The`
  line `ministerial officers of the Courts of the Subordinate Judges and District Munsifs shall be appointed by`
  line `such Subordinate Judges and District Munsifs, respectively, subject to the approval or confirmation of`
  line `the District Judge within whose jurisdiction such Courts are situate, and may ^1`
  line `[Subject to the control`
  line `of the High Court] be suspended or removed from offices either by the said District Judge or (subject`
  line `to his approval or confirmation) by such Subordinate Judges and District Munsifs respectively.]`
obj_root_law_sections_23_footnotes:
  string
  line `1. Ins. by Act 21 of 1885, s. 4.`
  line
  line `2. Subs. by Act 19 of 1877, s. 2, for section 23.`
obj_root_law_sections_24:
  sectionId (46493)
  sectionNo (24)
  orderNo 24
  title `Rules regulating such appointments.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46493&sectionno=24&orderno=24&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_24_content:
  string
  line `Every appointment under this Part shall be made`
  line `subject to such rules as the Local Government from time to time prescribes on this behalf.`
  line
  line `Duties of Ministerial Officers.— Every person appointed under this Part shall perform such`
  line `duties as may from time to time be imposed upon him by the presiding officer of the Court to which`
  line `he belongs.`
  line
  line `Present Ministerial Officers. —The present Ministerial Officers of the Courts under this Act`
  line `shall be deemed to have been appointed under this Part.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_24_a:
  sectionId (46494)
  sectionNo 24A
  orderNo 25
  title `Transfer of ministerial officers.`
  content obj_root_law_sections_24_a_content
  footnotes `1. Ins. by Act 19 of 1877, s. 3.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46494&sectionno=24A&orderno=25&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_24_a_content:
  string
  line ^1
  line `[24A. Transfer of ministerial officers. — The Local Government may, at the instance of the`
  line `District Judge, transfer from any Court, except the High Court, all or any of the ministerial officers of`
  line `the Court of such Judge, or of any Subordinate Judge or Distric Munsif under his control.`
  line
  line `The District Judge may transfer all or any of the ministerial officers of any Court under his control`
  line `to any other such Court.]`
  line
  line `Present Ministerial Officers. —The present Ministerial Officers of the Courts un der this Act`
  line `shall be deemed to have been appointed under this Part.`
obj_root_law_sections_25:
  sectionId (46496)
  sectionNo (25)
  orderNo 26
  title `Temporary discharge of duties of District Judge.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46496&sectionno=25&orderno=26&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_25_content:
  string
  line `In the event of the death of the District`
  line Judge,
  line
  line `or of his being incapacitated by illness or otherwise for the performance of his duties,`
  line
  line `or of his absence from the station in which his Court is held,`
  line
  line `the senior Subordinate Judge of the District shall, without interruption to his ordinary duties,`
  line `assume charge of the District Judge's office, and shall discharge such of the current duties thereof as`
  line `are connected with the filing of suits and appeals, the execution of processes and the like,`
  line
  line `and shall continue in charge of the office until the same is resumed or assumed by an officer duly`
  line `appointed thereto.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (46497)
  sectionNo (26)
  orderNo 27
  title `District Judge may nominate to vacancy in office of District Munsif.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46497&sectionno=26&orderno=27&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_26_content:
  string
  line `The District Judge,`
  line `on the occurrence within his district of any vacancy in the office of District Munsif may, pending the`
  line `orders of the High Court thereon, appoint such person as he thinks fit to act in such office ; and he`
  line `shall at once report to the High Court the ,occurrence of every such vacancy and such appointment.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (46498)
  sectionNo (27)
  orderNo 28
  title `District Judge to control Civil Courts of District.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46498&sectionno=27&orderno=28&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_27_content:
  string
  line `Subject to the other provisions of this`
  line `Act and to the rules for the time being in force and prescribed by the High Court in this behalf, the`
  line `general control over all the Civil Courts under this Act in any District is vested in the District Judge.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (46499)
  sectionNo (28)
  orderNo 29
  title `Investiture of District or Subordinate Judge with Small Cause jurisdiction.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46499&sectionno=28&orderno=29&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_28_content:
  string
  line `28. Investiture of ^1[District or] Subordinate Judge with Small Cause jurisdiction. -- The`
  line `Local Government may, by notification in the official Gazette, invest, within such local limits as it`
  line `shall from time to time appoint,`
  line
  line `any ^1[District or] Subordinate Judge with the jurisdiction of a Judge of a Court of Small Causes for`
  line `the trial of suits cognizable by such Courts up to the amount of rupees ^2`
  line `[one thousand],`
  line
  line `Investiture of District Munsif with similar jurisdiction. and any District Munsif with the`
  line `same jurisdiction up to the amount of rupees fifty ^3`
  line `[or on the recommendation of the High Court up to any amount not exceeding rupees ^4`
  line `[three hundred]],`
  line
  line `and may, by like notification, whenever it thinks fit, withdraw such jurisdiction from the Subordinate`
  line `Judge or Munsif so Invested.`
obj_root_law_sections_28_footnotes:
  string
  line `1. Ins. by Act 21 of 1885, s. 5.`
  line
  line `2. Subs. by Act 18 of 1926, s. 2, for "five hundred".`
  line
  line `3. Ins. by Act 21 of 1885, s. 5.`
  line
  line `4. Subs. by Act 18 of 1926, s. 2, for "two hundred"`
obj_root_law_sections_29:
  sectionId (46500)
  sectionNo (29)
  orderNo 30
  title `Exercise by Subordinate Judge of jurisdiction of District Judge in certain proceedings.`
  content obj_root_law_sections_29_content
  footnotes `1. Ins. by Act 14 of 1926, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46500&sectionno=29&orderno=30&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_29_content:
  string
  line ^1
  line `[29. Exercise by Subordinate Judge of jurisdiction of District Judge in certain`
  line `proceedings. — (1) The High Court may, by general or special order, authorise any Subordinate`
  line `Judge to take cognizance of, or any District Judge to transfer to any Subordinate Judge under his`
  line `control, any proceedings under the Indian Succession Act, 1925 (29 of 1925), which cannot be`
  line `disposed of by District Delegates.`
  line
  line `(2) The District Judge may withdraw any such proceedings taken cognizance of by, or transferred`
  line `to, a Subordinate Judge, and may either himself dispose of them or transfer them to a Court under his`
  line `control competent to dispose of them.`
  line
  line `(3) Notwithstanding anything contained in section 13, proceedings taken cognizance of by, or`
  line `transferred to, a Subordinate Judge under the provisions of this section shall be disposed of by him`
  line `subject to the law applicable to like proceedings when disposed of by the District Judge.]`
obj_root_law_sections_30:
  sectionId (46501)
  sectionNo (30)
  orderNo 31
  title Vacation.
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00024_187303_1523269251496&sectionId=46501&sectionno=30&orderno=31&orgactid=AC_CEN_3_3_00024_187303_1523269251496
obj_root_law_sections_30_content:
  string
  line `The High Court may permit the Civil Courts vacation. under its control to adjourn`
  line `from time to time for periods not exceeding in the aggregate two months in each year.`
obj_root_law_sections_30_footnotes:
  string
  line
