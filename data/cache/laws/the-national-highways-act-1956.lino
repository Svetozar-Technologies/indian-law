obj_root_law_sections_1:
  sectionId (14471)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 15th April, 1957, vide S.R.O. 1180(E), dated 4th April, 1957, see Gazette of India, 1957, Part II, s. 3(ii).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14471&sectionno=1&orderno=1&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Highways`
  line `Act, 1956.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_2:
  sectionId (14472)
  sectionNo (2)
  orderNo 2
  title `Declaration of certain highways to be national highways.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14472&sectionno=2&orderno=2&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_2_content:
  string
  line `(1) Each of the highways`
  line `specified in the Schedule ^1*** is hereby declared to be a national highway.`
  line
  line `(2) The Central Government may, by notification in the Official Gazette, declare any other`
  line `highway to be a national highway and on the publication of such notification such highway shall be`
  line `deemed to be specified in the Schedule.`
  line
  line `(3) The Central Government may, by like notification, omit any highway from the Schedule and`
  line `on the publication of such notification, the highway so omitted shall cease to be a national highway.`
obj_root_law_sections_2_footnotes:
  string
  line `1. The words "except such parts thereof as are situated within any municipal area" omitted by Act 16 of 1997, s. 2 (w.e.f. 24-`
  line `1-1997).`
obj_root_law_sections_3:
  sectionId (14473)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14473&sectionno=3&orderno=3&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_content:
  string
  line `^1[3. Definitions.--In this Act, unless the context otherwise requires,--`
  line
  line `(a) "competent authority" means any person or authority authorised by the Central`
  line `Government, by notification in the Official Gazette, to perform the functions of the competent`
  line `authority for such area as may be specified in the notification;`
  line
  line `(b) "land" includes benefits to arise out of land and things attached to the earth or`
  line `permanently fastened to anything attached to the earth.]`
obj_root_law_sections_3_a:
  sectionId (14474)
  sectionNo 3A
  orderNo 4
  title `Power to acquire land, etc.`
  content obj_root_law_sections_3_a_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14474&sectionno=3A&orderno=4&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Power to acquire land, etc.--(1) Where the Central Government is satisfied that for a public`
  line `purpose any land is required for the building, maintenance, management or operation of a national`
  line `highway or part thereof, it may, by notification in the Official Gazette, declare its intention to acquire`
  line `such land.`
  line
  line `(2) Every notification under sub-section (1) shall give a brief description of the land.`
  line
  line `(3) The competent authority shall cause the substance of the notification to be published in two`
  line `local newspapers, one of which will be in a vernacular language.]`
obj_root_law_sections_3_b:
  sectionId (14475)
  sectionNo 3B
  orderNo 5
  title `Power to enter for survey, etc.`
  content obj_root_law_sections_3_b_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14475&sectionno=3B&orderno=5&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_b_content:
  string
  line `^1[3B. Power to enter for survey, etc.--On the issue of a notification under sub-section (1) of`
  line `section 3A, it shall be lawful for any person, authorised by the Central Government in this behalf,`
  line to--
  line
  line `(a) make any inspection, survey, measurement, valuation or enquiry;`
  line
  line `(b) take levels;`
  line
  line `(c) dig or bore into sub-soil;`
  line
  line `(d) set out boundaries and intended lines of work;`
  line
  line `(e) mark such levels, boundaries and lines placing marks and cutting trenches; or`
  line
  line `(f) do such other acts or things as may be laid down by rules made in this behalf by that`
  line Government.]
obj_root_law_sections_3_c:
  sectionId (14476)
  sectionNo 3C
  orderNo 6
  title `Hearing of objections.`
  content obj_root_law_sections_3_c_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14476&sectionno=3C&orderno=6&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_c_content:
  string
  line `^1[3C. Hearing of objections.--(1) Any person interested in the land may, within twenty-one days`
  line `from the date of publication of the notification under sub-section (1) of section 3A, object to the use`
  line `of the land for the purpose or purposes mentioned in that sub-section.`
  line
  line `(2) Every objection under sub-section (1) shall be made to the competent authority in writing and`
  line `shall set out the grounds thereof and the competent authority shall give the objector an opportunity of`
  line `being heard, either in person or by a legal practitioner, and may, after hearing all such objections and`
  line `after making such further enquiry, it any, as the competent authority thinks necessary, by order, either`
  line `allow or disallow the objections.`
  line
  line `Explanation.--For the purposes of this sub-section, "legal practitioner" has the same meaning as`
  line `in clause (i) of sub-section (1) of section 2 of the Advocates Act, 1961 (25 of 1.961).`
  line
  line `(3) Any order made by the competent authority under sub-section (2) shall be final.]`
obj_root_law_sections_3_d:
  sectionId (14477)
  sectionNo 3D
  orderNo 7
  title `Declaration of acquisition.`
  content obj_root_law_sections_3_d_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14477&sectionno=3D&orderno=7&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_d_content:
  string
  line `^1[3D. Declaration of acquisition.--(1) Where no objection under sub-section (1) of section 3C has`
  line `been made to the competent authority within the period specified therein or where the competent`
  line `authority has disallowed the objection under sub-section (2) of that section, the competent authority`
  line `shall, as soon as may be, submit a report accordingly to the Central Government and on receipt of`
  line `such report, the Central Government shall declare, by notification in the Official Gazette, that the land`
  line `should be acquired for the purpose or purposes mentioned in sub-section (1) of section 3A.`
  line
  line `(2) On the publication of the declaration under sub-section (1), the land shall vest absolutely in`
  line `the Central Government free from all encumbrances.`
  line
  line `(3) Where in respect of any land, a notification has been published under sub-section (1) of`
  line `section 3A for its acquisition but no declaration under sub-section (1) has been published within a`
  line `period of one year from the date of publication of that notification, the said notification shall cease to`
  line `have any effect:`
  line
  line `Provided that in computing the said period of one year, the period or periods during which any`
  line `action or proceedings to be taken in pursuance of the notification issued under sub-section (1) of`
  line `section 3A is stayed by an order of a court shall be excluded.`
  line
  line `(4) A declaration made by the Central Government under sub-section (1) shall not be called in`
  line `question in any court or by any other authority.]`
obj_root_law_sections_3_e:
  sectionId (14478)
  sectionNo 3E
  orderNo 8
  title `Power to take possession.`
  content obj_root_law_sections_3_e_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14478&sectionno=3E&orderno=8&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_e_content:
  string
  line `^1[3E. Power to take possession.--(1) Where any land has vested in the Central Government under`
  line `sub-section (2) of section 3D, and the amount determined by the competent authority under section`
  line `3G with respect to such land has been deposited under sub-section (1) of section 3H, with the`
  line `competent authority by the Central Government, the competent authority may by notice in writing`
  line `direct the owner as well as any other person who may be in possession of such land to surrender or`
  line `deliver possession thereof to the competent authority or any person duly authorised by it in this behalf`
  line `within sixty days of the service of the notice.`
  line
  line `(2) If any person refuses or fails to comply with any direction made under sub-section (1), the`
  line `competent authority shall apply--`
  line
  line `(a) in the case of any land situated in any area falling within the metropolitan area, to the`
  line `Commissioner of Police;`
  line
  line `(b) in case of any land situated in any area other than the area referred to in clause (a), to the`
  line `Collector of a District,`
  line
  line `and such Commissioner or Collector, as the case may be, shall enforce the surrender of the land, to the`
  line `competent authority or to the person duly authorised by it.]`
obj_root_law_sections_3_f:
  sectionId (14479)
  sectionNo 3F
  orderNo 9
  title `Right to enter into the land where land has vested in the Central Government.`
  content obj_root_law_sections_3_f_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14479&sectionno=3F&orderno=9&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_f_content:
  string
  line `^1[3F. Right to enter into the land where land has vested in the Central Government.--Where`
  line `the land has vested in the Central Government under section 3D, it shall be lawful for any person`
  line `authorised by the Central Government in this behalf, to enter and do other act necessary upon the land for carrying out the building, maintenance, management or operation of a national highway or a part`
  line `thereof, or any other work connected therewith.]`
obj_root_law_sections_3_g:
  sectionId (14480)
  sectionNo 3G
  orderNo 10
  title `Determination of amount payable as compensation.`
  content obj_root_law_sections_3_g_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14480&sectionno=3G&orderno=10&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_g_content:
  string
  line `^1[3G. Determination of amount payable as compensation.--(1) Where any land is acquired`
  line `under this Act, there shall be paid an amount which shall be determined by an order of the competent`
  line authority.
  line
  line `(2) Where the right of user or any right in the nature of an easement on, any land is acquired`
  line `under this Act, there shall be paid an amount to the owner and any other person whose right of`
  line `enjoyment in that land has been affected in any manner whatsoever by reason of such acquisition an`
  line `amount calculated at ten per cent, of the amount determined under sub-section (1), for that land.`
  line
  line `(3) Before proceeding to determine the amount under sub-section (1) or sub-section (2), the`
  line `competent authority shall give a public notice published in two local newspapers, one of which will be`
  line `in a vernacular language inviting claims from all persons interested in the land to be acquired.`
  line
  line `(4) Such notice shall state the particulars of the land and shall require all persons interested in`
  line `such land to appear in person or by an agent or by a legal practitioner referred to in sub-section (2) of`
  line `section 3C, before the competent authority, at a time and place and to state the nature of their`
  line `respective interest in such land.`
  line
  line `(5) If the amount determined by the competent authority under sub-section (1) or sub-section (2)`
  line `is not acceptable to either of the parties, the amount shall, on an application by either of the parties, be`
  line `determined by the arbitrator to be appointed by the Central Government--`
  line
  line `(6) Subject to the provisions of this Act, the provisions of the Arbitration and Conciliation Act,`
  line `1996 (26 of 1996) shall apply to every arbitration under this Act.`
  line
  line `(7) The competent authority or the arbitrator while determining the amount under sub-section`
  line `(1) or sub-section (5), as the case may be, shall take into consideration--`
  line
  line `(a)the market value of the land on the date of publication of the notification under`
  line `section 3A;`
  line
  line `(b) the damage, if any, sustained by the person interested at the time of taking possession of`
  line `the land, by reason of the severing of such land from other land;`
  line
  line `(c) the damage, if any, sustained by the person interested at the time of taking possession of`
  line `the land, by reason of the acquisition injuriously affecting his other immovable property in any`
  line `manner, or his earnings;`
  line
  line `(d) if, in consequences of the acquisition of the land, the person interested is compelled to`
  line `change his residence or place of business, the reasonable expenses, if any, incidental to`
  line `such change.]`
obj_root_law_sections_3_h:
  sectionId (14481)
  sectionNo 3H
  orderNo 11
  title `Deposit and payment of amount.`
  content obj_root_law_sections_3_h_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14481&sectionno=3H&orderno=11&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_h_content:
  string
  line `^1[3H. Deposit and payment of amount.--(1) The amount determined under section 3G shall be`
  line `deposited by the Central Government in such manner asmay be laid down by rules made in this`
  line `behalf by that Government, with the competent authority before taking possession of the land.`
  line
  line `(2) As soon as may be after the amount has been deposited under sub-section (1), the competent`
  line `authority shall on behalf of the Central Government pay the amount to the person or persons`
  line `entitled thereto.`
  line
  line `(3) Where several persons claim to be interested in the amount deposited under sub-section (1),`
  line `the competent authority shall determine the persons who in its opinion are entitled to receive the`
  line `amount payable to each of them.`
  line
  line `(4) If any dispute arises as to the apportionment of the amount or any part thereof or to any`
  line `person to whom the same or any part thereof is payable, the competent authority shall refer the`
  line `dispute to the decision of the principal civil court of original jurisdiction within the limits of`
  line `whose jurisdiction the land is situated.`
  line
  line `(5) Where the amount determined under section 3G by the arbitrator is in excess of the`
  line `amount determined by the competent authority, the arbitrator may award interest at nine per cent,`
  line `per annum on such excess amount from the date of taking possession under section 3D till the date`
  line `of the actual deposit thereof.`
  line
  line `(6)Where the amount determined by the arbitrator is in excess of the amount determined by the`
  line `competent authority, the excess amount together with interest, if any, awarded under sub-section`
  line
  line `(5) shall be deposited by the Central Government in such manner as may be laid down by rules`
  line `made in this behalf by that Government, with the competent authority and the provisions of subsections`
  line `(2) to (4) shall apply to such deposit.]`
obj_root_law_sections_3_i:
  sectionId (14492)
  sectionNo 3-I
  orderNo 12
  title `Competent authority to have certain powers of civil court.`
  content obj_root_law_sections_3_i_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14492&sectionno=3-I&orderno=12&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_i_content:
  string
  line `^1[3I. Competent authority to have certain powers of civil court.--The competent authority shall`
  line `have, for the purposes of this Act, all the powers of a civil court while trying a suit under the Code of`
  line `Civil Procedure, 1908 (5 of 1908), in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) requiring the discovery and production of any document;`
  line
  line `(c) reception of evidence on affidavits;`
  line
  line `(d) requisitioning any public record from any court or office;`
  line
  line `(e) issuing commission for examination of witnesses.]`
obj_root_law_sections_3_j:
  sectionId (14493)
  sectionNo 3J
  orderNo 13
  title `Land Acquisition Act 1 of 1894 not to apply`
  content obj_root_law_sections_3_j_content
  footnotes `1. Subs. by Act 16 of 1997, s. 3, for section 3 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14493&sectionno=3J&orderno=13&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_3_j_content:
  string
  line `^1[3J. Land Acquisition Act 1 of 1894 not to apply.--Nothing in the Land Acquisition Act, 1894`
  line `shall apply to an acquisition under this Act.]`
obj_root_law_sections_4:
  sectionId (14494)
  sectionNo (4)
  orderNo 14
  title `National highways to vest in the Union`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14494&sectionno=4&orderno=14&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_4_content:
  string
  line `All national highways shall vest in the Union, and`
  line `for the purposes of this Act "highways" include--`
  line
  line `(i) all lands appurtenant thereto, whether demarcated or not;`
  line
  line `(ii) all bridges, culverts, tunnels, causeways, carriageways and other structures constructed on`
  line `or across such highways; and`
  line
  line `(iii) all fences, trees, posts and boundary, furlong and milestones of such highways or any`
  line `land appurtenant to such highways.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (14495)
  sectionNo (5)
  orderNo 15
  title `Responsibility for development and maintenance of national highways.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14495&sectionno=5&orderno=15&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_5_content:
  string
  line `It shall be the`
  line `responsibility of the Central Government to develop and maintain in proper repair all national`
  line `highways; but the Central Government may, by notification in the Official Gazette, direct that any`
  line `function in relation to the development or maintenance of any national highway shall, subject to such`
  line `conditions, if any, as may be specified in the notification, also be exercisable by the Government of`
  line `the State within which the national highway is situated or by any officer or authority subordinate to`
  line `the Central Government or to the State Government.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (14496)
  sectionNo (6)
  orderNo 16
  title `Power to issue directions`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14496&sectionno=6&orderno=16&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_6_content:
  string
  line `The Central Government may give directions to the Government`
  line `of any State as to the carrying out in the State of any of the provisions of this Act or of any rule,`
  line `notification or order made thereunder.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (14497)
  sectionNo (7)
  orderNo 17
  title `Fees for services or benefits rendered on national highways.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14497&sectionno=7&orderno=17&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_7_content:
  string
  line `(1) The Central Government`
  line `may, by notification in the Official Gazette, levy fees at such rates as may be laid down by rules made`
  line `in this behalf for services or benefits rendered in relation to the use of ferries, ^1[permanent bridges the`
  line `cost of construction of each of which is more than rupees twenty-five lakhs and which are opened to traffic on or after the 1st day of April, 1976,] temporary bridges and tunnels on national`
  line `highways^2[and the use of sections of national highways].`
  line
  line `(2) Such fees when so levied shall be collected in accordance with the rules made under this Act.`
  line
  line `(3) Any fee leviable immediately before the commencement of this Act for services or benefits`
  line `rendered in relation to the use of ferries, temporary bridges and tunnels on any highway specified in`
  line `the Schedule shall continue to be leviable under this Act unless and until it is altered in exercise of the`
  line `powers conferred by sub-section (1):`
  line
  line `^3[Provided that if the Central Government is of opinion that it is necessary in the public interest so`
  line `to do, it may, by like notification, specify any bridge in relation to the use of which fees shall not be`
  line `leviable under this sub-section.]`
obj_root_law_sections_7_footnotes:
  string
  line `1. Ins. by Act 30 of 1977, s. 2 (w.e.f. 12-8-1977).`
  line
  line `2. Ins. by Act 1 of 1993, s. 2 (w.r.e.f. 23-10-1992).`
  line
  line `3. The proviso ins. by Act 30 of 1977, s. 2 (w.e.f. 12-8-1977).`
obj_root_law_sections_8:
  sectionId (14498)
  sectionNo (8)
  orderNo 18
  title Omitted..
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14498&sectionno=8&orderno=18&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_8_content:
  string
  line `[Agreements with State Governments or municipalities.] Omitted by the National Highways`
  line `Laws (Amendment) Act, 1997 (16 of 1997), s. 4 (w.e.f. 24-1-1997).`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_8_a:
  sectionId (14499)
  sectionNo 8A
  orderNo 19
  title `Power of Central Government to enter into agreements for development and maintenance of national highways.`
  content obj_root_law_sections_8_a_content
  footnotes `1. Ins. by Act 26 of 1995, s. 2 (w.e.f. 16-6-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14499&sectionno=8A&orderno=19&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_8_a_content:
  string
  line `^1[8A. Power of Central Government to enter into agreements for development and`
  line `maintenance of national highways.--Notwithstanding anything contained in this Act, the`
  line `Central Government may enter into an agreement with any person in relation to the development and`
  line `maintenance of the whole or any part of a national highway.`
  line
  line `(2) Notwithstanding anything contained in section 7, the person referred to in sub-section (1) is`
  line `entitled to collect and retain fees at such rate, for services or benefits rendered by him as the Central`
  line `Government may, by notification in the Official Gazette, specify having regard to the expenditure`
  line `involved in building, maintenance, management and operation of the whole or part of such national`
  line `highway, interest on the capital invested, reasonable return, the volume of traffic and the period of`
  line `such agreement.`
  line
  line `(3) A person referred to in sub-section (1) shall have powers to regulate and control the traffic in`
  line `accordance with the provisions contained in Chapter VIII of the Motor Vehicles Act, 1988 (59 of`
  line `1988) on the national highway forming subject-matter of such agreement, for proper management`
  line thereof.]
obj_root_law_sections_8_b:
  sectionId (14500)
  sectionNo 8B
  orderNo 20
  title `Punishment for mischief by injury to national highway.`
  content obj_root_law_sections_8_b_content
  footnotes `1. Ins. by Act 26 of 1995, s. 2 (w.e.f. 16-6-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14500&sectionno=8B&orderno=20&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_8_b_content:
  string
  line `^1[8B. Punishment for mischief by injury to national highway.--Whoever commits mischief by`
  line `doing any act which renders or which he knows to be likely to render any national highway referred to`
  line `in sub-section (1) of section 8A impassable or less safe for traveling or conveying property, shall be`
  line `punished with imprisonment of either description for a term which may extend to five years, or with a`
  line `fine, or with both.]`
obj_root_law_sections_9:
  sectionId (14501)
  sectionNo (9)
  orderNo 21
  title `Power to make rules.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14501&sectionno=9&orderno=21&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner in which, and the conditions subject to which, any function in relation to the`
  line `development or maintenance of a national highway or any part thereof may be exercised by the`
  line `State Government or any officer or authority subordinate to the Central Government or the State`
  line Government;
  line
  line `^1[(aa) the manner in which the amount shall be deposited with the competent authority under`
  line `sub-sections (1) and (6) of section 3H;]`
  line
  line `^2[(b) the rates at which fees for services rendered in relation to the use of ferries, permanent`
  line `bridges, temporary bridges and tunnels on any national highway ^3[and the use of sections of any national highway] may be levied, and the manner in which such fees shall be collected, under`
  line `section 7;]`
  line
  line `(c) the periodical inspection of national highways and the submission of inspection reports to`
  line `the Central Government;`
  line
  line `(d) the reports on works carried out on national highways;`
  line
  line `(e) any other matter for which provision should be made under this Act.`
  line
  line `^4[(3) Every rule made under this section shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making`
  line `any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however,`
  line `that any such modification or annulment shall be without prejudice to the validity of anything`
  line `previously done under that rule.]`
obj_root_law_sections_9_footnotes:
  string
  line `1. Ins. by Act 16 of 1997, s. 5 (w.e.f. 21-1-1997).`
  line
  line `2. Subs. by Act 30 of 1977, s. 3, for clause (b) (w.e.f. 12-8-1977).`
  line
  line `3. Ins. by Act 1 of 1993, s. 3 (w.r.e.f. 23-10-1992).`
  line
  line `4. Ins. by Act 30 of 1977, s. 3 (w.e.f. 12-8-1977).`
obj_root_law_sections_10:
  sectionId (14502)
  sectionNo (10)
  orderNo 22
  title `Laying of notifications, rules, etc., before Parliament.`
  content obj_root_law_sections_10_content
  footnotes `1. Certain words omitted by Act 30 of 1977, s. 4 (w.e.f. 12-8-1977).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00002_195648_1517807321068&sectionId=14502&sectionno=10&orderno=22&orgactid=AC_CEN_30_42_00002_195648_1517807321068
obj_root_law_sections_10_content:
  string
  line `All notifications or agreements`
  line `issued or entered into under this Act shall be laid before both Houses of Parliament as soon as may be`
  line `after they are issued or entered into ^1***.`
