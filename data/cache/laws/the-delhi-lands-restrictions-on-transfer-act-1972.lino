  (str title) (str `The Delhi Lands (Restrictions on Transfer) Act, 1972`)
  (str actNumber) (str 30)
  (str enactmentDate) (str 1972-06-14)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1723`)
