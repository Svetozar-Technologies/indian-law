obj_root_law_sections_1:
  sectionId (47908)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47908&sectionno=1&orderno=1&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Delhi Lands`
  line `(Restrictions on Transfer) Act, 1972.`
  line
  line `(2) It extends to the whole of the Union territory of Delhi.`
  line
  line `(3) It shall come into force at once.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (47909)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47909&sectionno=2&orderno=2&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,`
  line
  line `(a) "Administrator" means the administrator of the Union territory of Delhi appointed by the`
  line `President under article 239 of the Constitution;`
  line
  line `(b) "competent authority" means any person or authority authorised by the Administrator, by`
  line `notification in the Official Gazette, to perform the functions of the competent authority under this Act`
  line `for such areas as may be specified in the notification;`
  line
  line `(c) "Development Act" means the Delhi Development Act, 1957 (61 of 1957);`
  line
  line `(d) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(e) "Scheme" means the scheme of acquisition of land for the planned development of Delhi and`
  line `includes any scheme, project or work to be implemented in pursuance of the provisions of the Delhi`
  line `Master Plan as approved by the Central Government under sub-section (2) of section 9 of the`
  line `Development Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47910)
  sectionNo (3)
  orderNo 3
  title `Prohibition on transfer of lands acquired by Central Government.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47910&sectionno=3&orderno=3&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_3_content:
  string
  line `No person shall purport to`
  line `transfer by sale, mortgage, gift, lease or otherwise any land or part thereof situated in the Union`
  line `territory of Delhi, which has been acquired by the Central Government under the Land Acquisition`
  line `Act, 1984 (1 of 1984), or under any other law providing for acquisition of land for a public purpose.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47911)
  sectionNo (4)
  orderNo 4
  title `Regulation on transfer of lands in relation to which acquisition proceedings have been initiated.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47911&sectionno=4&orderno=4&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_4_content:
  string
  line `No person shall, except with the previous permission in writing of the competent authority,`
  line `transfer or purport to transfer by sale, mortgage, gift, lease or otherwise any land or part thereof situated`
  line `in the Union territory of Delhi, which is proposed to be acquired in connection with the Scheme and in`
  line `relation to which a declaration to the effect that such land or part thereof is needed for a public`
  line `purpose having been made by the Central Government under section 6 of the Land Acquisition`
  line `Act, 1894 (1 of 1894), the Central Government has not withdrawn from the acquisition under section 48`
  line `of that Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47912)
  sectionNo (5)
  orderNo 5
  title `Application for grant of permission for transfer under section 4.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47912&sectionno=5&orderno=5&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_5_content:
  string
  line `(1) Any person desiring to`
  line `transfer any land referred to in section 4 by sale, mortgage, gift, lease or otherwise may make an`
  line `application in writing to the competent authority containing such particulars as may be prescribed.`
  line
  line `(2) On receipt of an application under sub-section (1), the competent authority shall, after making`
  line `such inquiries as it deems fit, may, by order in writing, grant or refuse to grant the permission applied for.`
  line
  line `(3) The competent authority shall not refuse to grant the permission applied for under this section`
  line `except on one or more of the following grounds, namely:--`
  line
  line `(i) that the land is needed or is likely to be needed for the effective implementation of the`
  line Scheme;
  line
  line `(ii) that the land is needed or is likely to be needed for securing the objects of the Delhi`
  line `Development Authority referred to in section 6 of the Development Act;`
  line
  line `(iii) that the land is needed or is likely to be needed for any development within the meaning of`
  line `clause (d) of section 2 of the Development Act or for such things as public buildings and other public`
  line `works and utilities, roads, housing, recreation, industry, business, markets, schools and other`
  line `educational institutions, hospitals and public open spaces and other categories of public uses.`
  line
  line `(4) Where the competent authority refuses to grant the permission applied for, it shall record in`
  line `writing the reasons for doing so and a copy of the same shall be communicated to the applicant.`
  line
  line `(5) Where within a period of thirty days of the date of receipt of an application under this section the`
  line `competent authority does not refuse to grant the permission applied for or does not communicate the`
  line `refusal to the applicant, the competent authority shall be deemed to have granted the permission applied`
  line for.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47913)
  sectionNo (6)
  orderNo 6
  title `Appeals against orders of competent authority.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47913&sectionno=6&orderno=6&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_6_content:
  string
  line `(1) Any person aggrieved by an order of the`
  line `competent authority under section 5 may, within thirty days of the date of receipt of the order by him, file`
  line `an appeal to the prescribed authority in such form and containing such particulars as may be prescribed.`
  line
  line `(2) On receipt of an appeal under sub-section (1), the prescribed authority shall, after giving the`
  line `appellant an opportunity of being heard in the matter, dispose of the appeal as expeditiously as possible.`
  line
  line `(3) Every order made by the prescribed authority in appeal under this section shall be final.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47914)
  sectionNo (7)
  orderNo 7
  title `Period of operation of orders of refusal to grant permission to transfer land.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47914&sectionno=7&orderno=7&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_7_content:
  string
  line `Where the`
  line `competent authority has made any order under section 5 refusing to grant permission to transfer any land`
  line `or where, an appeal having been filed against such order, the prescribed authority has made an order`
  line `under section 6 confirming such order, then, the order refusing to grant permission to transfer such land`
  line `shall be in operation only for a period of three years from the date of the order made by the competent`
  line `authority or the prescribed authority, as the case may be, and thereafter, but subject to the provisions of`
  line `section 3, it shall be lawful for the person who has applied for permission, or his successor-in-interest, to`
  line `transfer such land by sale, mortgage, gift, lease or otherwise.`
  line
  line `Explanation.--In computing the period of three years, under this section, in relation to any land, the`
  line `period during which the acquisition proceedings in relation to such land have been stayed by any court`
  line `shall be excluded`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47915)
  sectionNo (8)
  orderNo 8
  title `Restrictions on registration of transfers of land.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47915&sectionno=8&orderno=8&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_8_content:
  string
  line `Notwithstanding anything contained in any`
  line `other law for the time being in force, where any document required to be registered under the provisions`
  line `of clause (a) to clause (e) of sub-section (1) of section 17 of the Registration Act, 1908 (16 of 1908),`
  line `purports to transfer by sale, mortgage, gift, lease or otherwise any land or part thereof referred to in`
  line `section 4, no registering officer appointed under that Act shall register any such document unless the`
  line `transferor produces before such registering officer a permission in writing of the competent authority for`
  line `such transfer.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (47916)
  sectionNo (9)
  orderNo 9
  title Penalty.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47916&sectionno=9&orderno=9&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_9_content:
  string
  line `If any person contravenes the provisions of section 3 or section 4, he shall be punishable`
  line `with imprisonment for a term which may extend to three years or with fine or with both.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47917)
  sectionNo (10)
  orderNo 10
  title `Offences by companies.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47917&sectionno=10&orderno=10&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_10_content:
  string
  line `(1) If the person committing an offence under this Act is a company,`
  line `every person, who, at the time the offence was committed, was in charge of, and was responsible to, the`
  line `company for the conduct of the business of the company as well as the company shall be deemed to be`
  line `guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he exercised all`
  line `due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), when an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be`
  line `guilty of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.-- For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of`
  line `individuals; and`
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (47918)
  sectionNo (11)
  orderNo 11
  title `Power to make rules.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00022_197230_1517807324983&sectionId=47918&sectionno=11&orderno=11&orgactid=AC_CEN_17_19_00022_197230_1517807324983
obj_root_law_sections_11_content:
  string
  line `(1) The Administrator may, by notification in the Official Gazette, make`
  line `rules for carrying out the purposes of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing provision, such rules may provide for all or`
  line `any of the following matters, namely:--`
  line
  line `(a) the particulars which an application to be made under sub-section (1) of section 5 shall`
  line contain;
  line
  line `(b) the authority to which an appeal may be filed under sub-section (1) of section 6, the form in`
  line `which such appeal may be filed and the particulars which such appeal shall contain;`
  line
  line `(c) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_11_footnotes:
  string
  line
