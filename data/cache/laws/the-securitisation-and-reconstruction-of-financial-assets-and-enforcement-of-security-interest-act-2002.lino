obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `वित्तीय आवि यों का प्र विभूविकरण और पुनर्गठन`
  line `िथा प्र विभूवि विि का प्र ििगन अविवनयम, 2002`
  line _________
  line `िाराओं का क्र म`
  line _________
  line `ि ााराएं`
  line `अध्या य 1 प्र`
  line ारंवभक
  line `1. संविप् ि नाम, वििा र और प्र ारंभ।`
  line `2. पररभाषाएं।`
  line `अध्या य 2`
  line `बैंकों और वित्तीय संथा ओं की वित्ती य आवि यों के प्र विभूविकरण और पुनर्गठन का विवनयमन`
  line `3. प्र विभूविकरण कंपवनयों या पुनर्गठन कंपवनयों का रविरी करण।`
  line `4. रविरी करण प्र माणपत्र का रद्दकरण।`
  line `5. वित्तीय आवि यों में अविकारों या विि का अिगन।`
  line `5 क. कविपय मामलों में लवब ि आिेदनों का ककसी एक ऋण िसूली अविकरण को अंिरण।`
  line `6. बाध्य िािारी को सूचना और ऐसे बाध्य िािारी की बाध्य िा का उन्मो चन।`
  line `7. प्र विभूविकरण कंपनी या पुनर्गठन कंपनी द्व ारा प्र ावप्ि यों या वनवियों की था पना करके प्र विभूवि का पुरोद्धरण।`
  line `8. प्र विभूवि रसीद के रविरी करण से छूट।`
  line `9. आवि पुनर्गठन के वलए उपाय।`
  line `10. प्र विभूविकरण कंपनी या पुनर्गठन कंपनी के अन्य कृत् य।`
  line `11. वििादों का समािान।`
  line `12. ररििग बैंक की नीवि - वनिागरण करने और वनदेश िारी करने की शवि।`
  line `12 क. वििरण और िानकारी मांर्ने की ररििग बैंक की शवि।`
  line `अध्या य 3 प्र`
  line `विभूवि विि का प्र ििगन`
  line `13. प्र विभूवि विि का प्र ििगन।`
  line `14. मुख्य मिानर्र मविरे ट या विला मविरे ट द्व ारा प्र विभूि लेनदार की प्र विभूि आवि का कब्िा लेने में`
  line `सिायिा करना।`
  line `15. प्र बंि ग्र िण करने की रीवि और उसका प्र भाि।`
  line `16. पद की िावन के वलए वनदेशकों को कोई प्र विकर निीं।`
  line `17. अपील करने का अविकार।`
  line `17 क. कविपय मामलों में विला न् या यािीश के न् या यालय में आिेदन ककया िाना।`
  line `18. अपील अविकरण को अपील।`
  line `18 क. उद्र्ृिीि फीस का विविमान्य करण।`
  line `18 ख. कविपय मामलों में उच्च न् या यालय को अपील।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `18 र्. केवियट दावखल करने का अविकार।`
  line `19. कविपय मामलों में प्र विकर और खचे प्र ाप्ि करने के वलए उिार लेने िाले का अविकार।`
  line `अध्या य 4`
  line `केन्री य रविरी`
  line `20. केन्री य रविरी।`
  line `21. केन्री य रविरा र।`
  line `22. प्र विभूविकरण, पुनर्गठन और प्र विभूवि वििों के संव्य ििारों का रविट र।`
  line `23. प्र विभूविकरण पुनर्गठन और प्र विभूवि विि के सृिन के संव्य ििारों का फाइल ककया िाना।`
  line `24. इस अविवनयम के अिीन रविरी कृि प्र विभूवि विि का उपांिरण।`
  line `25. प्र विभूविकरण कंपनी या पुनर्गठन कंपनी या प्र विभूि लेनदार द्व ारा प्र विभू वि विि की िुवट की ररपोटग करना।`
  line `26. प्र विभूविकरण, पुनर्गठन और प्र विभूवि विि संव्य ििारों की विवशवट यों का वनरीिण करने का अविकार।`
  line `26 क. रविरी करण, उपांिरण और िुवट आकद के विषयों में केन्री य सरकार द्व ारा पररशोिन।`
  line `अध्या य 5`
  line `अपराि और शावि यां`
  line `27. शावि यां।`
  line `28. ररििग बैंक के वनदेशों के अननुपालन के वलए शावि यां।`
  line `29. अपराि।`
  line `30. अपरािों का संज्ञान।`
  line `अध्या य 6 प्र`
  line कीणग
  line `31. कविपय मामलों में इस अविवनयम के उपबंिों का लार्ू न िोना।`
  line `31 क. बैंकों या वित्तीय संथा ओं के ककसी िर्ग या िर्ों को छू ट देने की शवि।`
  line `32. सद्भािपूिगक की र् ई कारगिाई के वलए संरिण।`
  line `33. कंपवनयों द्व ारा अपराि।`
  line `34. वसविल न् या यालय की अविकाररिा का न िोना।`
  line `35. इस अविवनयम के उपबंिों का अन्य विवियों पर अध्या रोिी िोना।`
  line `36. पररसीमा।`
  line `37. अन्य विवियों का लार्ू िोना िर्िग ि निीं।`
  line `38. केन्री य सरकार की वनयम बनाने की शवि।`
  line `39. इस अविवनयम के कविपय उपबंिों का केन्री य रविरी था वपि िो िाने या था वपि कराए िाने के पश्चा ि् लार्ू`
  line िोना।
  line `40. करठनाई दूर करने की शवि।`
  line `41. कविपय अविवनयवमवियों का संशोिन।`
  line `42. वनरस न और व् या िृवत्त।`
  line अनुसूची।
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line `वित्तीय आवि यों का प्र विभूविकरण और पुनर्गठन`
  line `िथा प्र विभूवि विि का प्र ििगन अविवनयम, 2002`
  line `( 2002 का अविवनयम संख्यां क 54 )`
  line `[17 कदसंबर, 2002 ]`
  line `1 [ वित्तीय आवि यों के प्र विभूविकरण और पुनर्गठन िथा प्र विभूवि वििों के प्र ििगन`
  line `को वि वनयवमि करने िथा संपवत्त अविकारों पर सृविि प्र विभूवि`
  line `विि के केन्री य आंकडों का उपबंि करने िथा उससे`
  line `संसि औ र उनके आनुषंवर्क विषयों`
  line `का उपबंि करने के वलए`
  line `अविवनयम ]`
  line `भारि र् णराज्य के विरपनिें िषग में संसद् द्व ारा वनन वलवखि रू प में यि अविवनयवमि िो: ––`
  line `अध्या य 1 प्र`
  line ारंवभक
  line `1. संविप्ि नाम, वििा र और प्र ारंभ –– (1) इस अविवनयम का संविप् ि नाम वित्तीय आवि यों का प्र विभूविकरण और पु नर्गठन`
  line `िथा प्र विभू वि विि का प्र ििगन अविवनयम, 2002 िै।`
  line `(2) इसका वििा र संपूणग भारि पर िै।`
  line `(3) यि 21 िून, 2002 को प्र िृत्त हु आ समझा िाएर्ा।`
  line `2. पररभाषाएं –– इस अविवनयम में, िब िक कक संदभग से अन्य था अपेविि न िो, ––`
  line `( क ) “ अपील अविकरण ” से बैंकों और वित्तीय संथा ओं को शोध्य ऋण िसूली अविवनयम, 1993 (1993 का 51) की`
  line `िारा 8 की उपिारा (1) के अिीन था वपि ऋण िसूली अपील अविकरण अवभप्रेि िै;`
  line `( ख ) “ आवि पुनर्गठन ” से ककसी 2 [ आवि पुनर्गठन कंपनी ] द्व ारा ककसी वित्तीय सिायिा में, ऐसी वित्तीय सिायिा`
  line `की िसूली के प्र योिन के वलए, ककसी बैंक या वित्तीय संथा के ककसी अविकार या विि का अिगन अवभप्रेि िै;`
  line `3 [( खक ) “ आवि पुनर्गठन कं पनी ” से ऐसी कोई कंपनी अवभप्रेि िै, िो आवि पुनर्गठन या प्र विभूविकरण या दोनों`
  line `के कारबार को संचावलि करने के प्र योिन के वलए इस अविवनयम की िारा 3 के अिीन ररििग बैंक के पास रविरी कृि िैं; ]`
  line `( र् ) “ बैंक ” से अवभप्रेि िै, ––`
  line `(i) कोई बैंककारी कंपनी; या`
  line `(ii ) कोई ित्था नी नया बैंक; या`
  line `(iii) भारिीय टे ट बैंक; या`
  line `(iv) कोई समनुषंर्ी बैंक; या`
  line `4 [(iv क ) बहुराज्य सिकारी बैंक; या ]`
  line `(v) ऐसा अन्य बैंक, विसे केन्री य सरकार, अविसूचना द्व ारा इस अविवनयम के प्र योिनों के वलए`
  line `विवनर्दगट करे;`
  line `( घ ) “ बैंककारी कंप नी ” का ििी अथग िै िो बैंककारी विवनयमन अविवनयम, 1949 (1949 का 10) की िारा 5 के`
  line `खंड ( र् ) में उसका िै;`
  line `1 201 6 के अविवनयम सं ० 44 की िारा 2 द्व ारा प्र वि था वपि।`
  line `2 201 6 के अविवनयम सं ० 44 की िारा 3 द्व ारा प्र वि था वपि।`
  line `3 201 6 के अविवनयम सं ० 44 की िारा 4 द्व ारा अं ि:था वपि।`
  line `4 2013 के अविवनयम सं ० 1 की िारा 2 द्व ारा अं ि:था वपि।`
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
