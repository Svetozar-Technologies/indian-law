obj_root_law_sections_18_c:
  sectionId (20664)
  sectionNo 18C
  orderNo 25
  title `Right to lodge a caveat.`
  content obj_root_law_sections_18_c_content
  footnotes `1. Ins. by Act 1 of 2013, s. 7 (w.e.f. 15-1-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20664&sectionno=18C&orderno=25&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_18_c_content:
  string
  line `^1[18C. Right to lodge a caveat.--(1) Where an application or an appeal is expected to be made or`
  line `has been made under sub-section (1) of section 17 or section 17A or sub-section (1) of section 18 or`
  line `section 18B, the secured creditor or any person claiming a right to appear before the Tribunal or the Court`
  line `of District Judge or the Appellate Tribunal or the High Court, as the case may be, on the hearing of such`
  line `application or appeal, may lodge a caveat in respect thereof.`
  line
  line `(2) Where a caveat has been lodged under sub-section (1),--`
  line
  line `(a) the secured creditor by whom the caveat has been lodged (hereafter in this section referred to`
  line `as the caveator) shall serve notice of the caveat by registered post, acknowledgement due, on the`
  line `person by whom the application has been or is expected to be made under sub-section (1);`
  line
  line `(b) any person by whom the caveat has been lodged (hereafter in this section referred to as the`
  line `caveator) shall serve notice of the caveat by registered post, acknowledgement due, on the person by`
  line `whom the application has been or is expected to be made under sub-section (1).`
  line
  line `(3) Where after a caveat has been lodged under sub-section (1), any application or appeal is filed`
  line `before the Tribunal or the court of District Judge or the Appellate Tribunal or the High Court, as the case`
  line `may be, the Tribunal or the District Judge or the Appellate Tribunal or the High Court, as the case may`
  line `be, shall serve a notice of application or appeal filed by the applicant or the appellant on the caveator.`
  line
  line `(4) Where a notice of any caveat has been served on the applicant or the Appellant, he shall`
  line `periodically furnish the caveator with a copy of the application or the appeal made by him and also with`
  line `copies of any paper or document which has been or may be filed by him in support of the application or`
  line `the appeal.`
  line
  line `(5) Where a caveat has been lodged under sub-section (1), such caveat shall not remain in force after`
  line `the expiry of the period of ninety days from the date on which it was lodged unless the application or`
  line `appeal referred to in sub-section (1) has been made before the expiry of the said period.]`
  line
  line `STATE AMENDMENTS`
  line
  line `Jammu and Kashmir (UT).--`
  line
  line `Amendment of section 18(C)--(i) in sub-section (1), omit "or section 17A", "or section 18B", "or the`
  line `court of District Judge" and "or the High Court"; and`
  line
  line `(ii) in sub-section (3), omit "or the court of District Judge" and "or the High Court".`
  line
  line `[Vide Order No. 3807(E) dated 26th October, 2020, the Union Territory of Jammu and Kashmir`
  line `Reorganisation (Adaptation of Central Laws) Third Order, 2020 (w.e.f. 26-10-2020).`
  line
  line `Ladakh (UT).--`
  line
  line `Amendment of section 18(C)--`
  line
  line `(a) In sub-section (1), omit,--`
  line
  line `(i) "or section 17A" and "or section 18B"; and`
  line
  line `(ii) "or the court of District Judge" and "or the High Court" whenever they occur;`
  line
  line `(b) in sub-section (3) omit "or the court of District Judge" and "or the High Court".`
  line
  line `[Vide Union Territory of Ladakh Reorganisation (Adaptation of Central Laws) Order, 2020, notification No.`
  line `S.O. 3774(E), dated (23-10-2020).]`
obj_root_law_sections_19:
  sectionId (20665)
  sectionNo (19)
  orderNo 26
  title `Right of borrower to receive compensation and costs in certain cases.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20665&sectionno=19&orderno=26&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_19_content:
  string
  line `^1[19. Right of borrower to receive compensation and costs in certain cases.-- If the Debts`
  line `Recovery Tribunal or the Court of District Judge, on an application made under section 17 or section 17A`
  line `or the Appellate Tribunal or the High Court on an appeal preferred under section 18 or section 18A, holds`
  line `that the possession of secured assets by the secured creditor is not in accordance with the provisions of`
  line `this Act and rules made thereunder and directs the secured creditors to return such secured assets to the`
  line `^2[concerned borrowers or any other aggrieved person, who has filed the application under section 17 or`
  line `section 17A or appeal under section 18 or section 18A, as the case may be, the borrower or such other`
  line `person shall be entitled to the payment of such compensation and costs as may be determined by such`
  line `Tribunal or Court of District Judge or Appellate Tribunal or the High Court referred to in section 18B.]`
  line
  line `STATE AMENDMENTS`
  line
  line `Union Territory of Jammu and Kashmir.--`
  line
  line `Amendment of section 19.--(i) Omit "or the Court of District Judge", occurring at both the places;`
  line
  line `(ii) Omit "or section 17A" occurring at both the places;`
  line
  line `(iii) Omit "or the High Court;`
  line
  line `(iv) Omit "or section 18A" occurring at both the places; and`
  line
  line `(v) Omit "or the High Court referred to in section 18B" occurring at the end.`
  line
  line `Insertion of new section:--After section 19, insert--`
  line
  line `19A. Transfer of Pending Applications.--All the pending applications before the court of District`
  line `Judge and the High Court under sections 17A and 18B respectively, shall stand transferred to the Tribunal`
  line `and the Appellate Tribunal, as the case may be.`
  line
  line `[Vide Order No. 3807(E) dated 26th October, 2020, the Union Territory of Jammu and Kashmir`
  line `Reorganisation (Adaptation of Central Laws) Third Order, 2020 (w.e.f. 26-10-2020)].`
  line
  line `Union Territory of Ladakh--`
  line
  line `Section 19.--In section 19,--`
  line
  line `(i) omit "or the court of District Judge", "or the High Court" and "or the High Court referred to in`
  line `section 18B";`
  line
  line `(ii) omit "or section 17A" and "or section 18A".`
obj_root_law_sections_19_footnotes:
  string
  line `1. Subs. by Act 30 of 2004, s. 14, for section 19 (w.e.f. 11-11-2004).`
  line
  line `2. Subs. by Act 44 of 2016, s. 15, for "concerned borrowers, such borrower" (w.e.f. 1-9-2016).`
obj_root_law_sections_20:
  sectionId (20666)
  sectionNo (20)
  orderNo 27
  title `Central Registry.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20666&sectionno=20&orderno=27&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_20_content:
  string
  line `(1) The Central Government may, by notification, set up or cause to be set up`
  line `from such date as it may specify in such notification, a registry to be known as the Central Registry with`
  line `its own seal for the purposes of registration of transaction of securitisation and reconstruction of financial`
  line `assets and creation of security interest under this Act.`
  line
  line `(2) The head office of the Central Registry shall be at such place as the Central Government may`
  line `specify and for the purpose of facilitating registration of transactions referred to in sub-section (1), there`
  line `may be established at such other places as the Central Government may think fit, branch offices of the`
  line `Central Registry.`
  line
  line `(3) The Central Government may, by notification, define the territorial limits within which an office`
  line `of the Central Registry may exercise its functions.`
  line
  line `(4) The provisions of this Act pertaining to the Central Registry shall be in addition to and not in`
  line `derogation of any of the provisions contained in the Registration Act, 1908 (16 of 1908), the Companies`
  line `Act, 1956 (1 of 1956), the Merchant Shipping Act, 1958 (44 of 1958), the Patents Act, 1970 (39 of 1970),`
  line `the Motor Vehicles Act, 1988 (49 of 1988), and the Designs Act, 2000 (16 of 2000) or any other law`
  line `requiring registration of charges and shall not affect the priority of charges or validity thereof under those`
  line `Acts or laws.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_20_a:
  sectionId (20667)
  sectionNo 20A
  orderNo 28
  title `Integration of registration systems with Central Registry.`
  content obj_root_law_sections_20_a_content
  footnotes `1. Ins. by Act 44 of 2016, s. 16 (w.e.f. 1-9-2016).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20667&sectionno=20A&orderno=28&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_20_a_content:
  string
  line `^1[20A.Integration of registration systems with Central Registry.-- (1) The Central Government`
  line `may, for the purpose of providing a Central database, in consultation with State Governments or other`
  line `authorities operating registration system for recording rights over any property or creation, modification`
  line `or satisfaction of any security interest on such property, integrate the registration records of such`
  line `registration systems with the records of Central Registry established under section 20, in such manner as`
  line `may be prescribed.`
  line
  line `Explanation.--For the purpose of this sub-section, the registration records includes records of`
  line `registration under the Companies Act, 2013 (18 of 2013), the Registration Act, 1908 (16 of 1908), the`
  line `Merchant Shipping Act, 1958 (44 of 1958), the Motor Vehicles Act, 1988 (59 of 1988), the Patents`
  line `Act, 1970 (39 of 1970), the Designs Act, 2000 (16 of 2000) or other such records under any other law for`
  line `the time being in force.`
  line
  line `(2) The Central Government shall after integration of records of various registration systems referred`
  line `to in sub-section (1) with the Central Registry, by notification, declare the date of integration of`
  line `registration systems and the date from which such integrated records shall be available; and with effect`
  line `from such date, security interests over properties which are registered under any registration system`
  line `referred to in sub-section (1) shall be deemed to be registered with the Central Registry for the purposes`
  line `of this Act.]`
obj_root_law_sections_20_b:
  sectionId (20668)
  sectionNo 20B
  orderNo 29
  title `Delegation of powers.`
  content obj_root_law_sections_20_b_content
  footnotes `1. Ins. by Act 44 of 2016, s. 16 (w.e.f. 1-9-2016).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20668&sectionno=20B&orderno=29&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_20_b_content:
  string
  line `^1[20B. Delegation of powers.--The Central Government may, by notification, delegate its powers and`
  line `functions under this Chapter, in relation to establishment, operations and regulation of the Central`
  line `Registry to the Reserve Bank, subject to such terms and conditions as may be prescribed.]`
obj_root_law_sections_21:
  sectionId (20669)
  sectionNo (21)
  orderNo 30
  title `Central Registrar.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20669&sectionno=21&orderno=30&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_21_content:
  string
  line `(1) The Central Government may, by notification, appoint a person for the`
  line `purpose of registration of transactions relating to securitisation, reconstruction of financial assets and`
  line `security interest created over properties, to be known as the Central Registrar.`
  line
  line `(2) The Central Government may appoint such other officers with such designations as it thinks fit for`
  line `the purpose of discharging, under the superintendence and direction of the Central Registrar, such`
  line `functions of the Central Registrar under this Act as he may, from time to time, authorise them to`
  line discharge.
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (20670)
  sectionNo (22)
  orderNo 31
  title `Register of securitisation, reconstruction and security interest transactions.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20670&sectionno=22&orderno=31&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_22_content:
  string
  line `(1) For the`
  line `purposes of this Act, a record called the Central Register shall be kept at the head office of the Central`
  line `Registry for entering the particulars of the transactions relating to--`
  line
  line `(a) securitisation of financial assets;`
  line
  line `(b) reconstruction of financial assets; and`
  line
  line `(c) creation of security interest.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), it shall be lawful for the Central Registrar`
  line `to keep the records wholly or partly in computer, floppies, diskettes or in any other electronic form`
  line `subject to such safeguards as may be prescribed.`
  line
  line `(3) Where such register is maintained wholly or partly in computer, floppies, diskettes or in any other`
  line `electronic form, under sub-section (2), any reference in this Act to entry in the Central Register shall be`
  line `construed as a reference to any entry as maintained in computer or in any other electronic form.`
  line
  line `(4) The register shall be kept under the control and management of the Central Registrar.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (20671)
  sectionNo (23)
  orderNo 32
  title `Filing of transactions of securitisation, reconstruction and creation of security interest.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20671&sectionno=23&orderno=32&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_23_content:
  string
  line `^1[(1)] The particulars of every transaction of securitisation, asset reconstruction or creation of security`
  line `interest shall be filed, with the Central Registrar in the manner and on payment of such fee as may be`
  line `prescribed ^2***:`
  line
  line `^3* * * * *`
  line
  line `^4[Provided ^5*** that the Central Government may, by notification, require registration of all`
  line `transactions of securitisation, or asset reconstruction or creation of security interest which are subsisting`
  line `on or before the date of establishment of the Central Registry under sub-section (7) of section 20 within`
  line `such period and on payment of such fees as may be prescribed.]`
  line
  line `^6[(2) The Central Government may, by notification, require the registration of transaction relating to`
  line `different types of security interest created on different kinds of property with the Central Registry.`
  line
  line `(3) The Central Government may, by rules, prescribe forms for registration for different types of`
  line `security interest under this section and fee to be charged for such registration.]`
obj_root_law_sections_23_footnotes:
  string
  line `1. Section 23 numbered as sub-section (1) by Act 44 of 2016, s. 17 (w.e.f. 24-1-2020).`
  line
  line `2. The certain words omitted by s. 17, ibid. (w.e.f. 24-1-2020).`
  line
  line `3. The Proviso omitted by s. 17, ibid. (w.e.f. 24-1-2020).`
  line
  line `4. Ins. by Act 1 of 2013, s.8 (w.e.f. 15-5-2013).`
  line
  line `5. The word "further" omitted by Act 44 of 2016, s. 17 (w.e.f. 24-1-2020).`
  line
  line `6. Ins. by s. 17, ibid. (w.e.f. 24-1-2020).`
obj_root_law_sections_24:
  sectionId (20672)
  sectionNo (24)
  orderNo 33
  title `Modification of security interest registered under this Act.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20672&sectionno=24&orderno=33&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_24_content:
  string
  line `Whenever the terms or`
  line `conditions, or the extent or operation of any security interest registered under this Chapter are or is`
  line `^1[asset reconstruction company] or the secured creditors, as the case may be, to send to the Central`
  line `Registrar, the particulars of such modification, and the provisions of this Chapter as to registration of a`
  line `security interest shall apply to such modification modified, it shall be the duty of the ^2[asset`
  line `reconstruction company] or the of such security interest.`
obj_root_law_sections_24_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for "reconstruction company" (w.e.f. 1-9-2016).`
  line
  line `2. Subs. by s. 3,ibid., for "securitisation company" (w.e.f. 1-9-2016).`
obj_root_law_sections_25:
  sectionId (20673)
  sectionNo (25)
  orderNo 34
  title `Asset reconstruction companyor secured creditors to report satisfaction of security interest.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20673&sectionno=25&orderno=34&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_25_content:
  string
  line `25. ^1`
  line `[Asset reconstruction company] or secured creditors to report satisfaction of security`
  line `interest.--(1) The ^1`
  line `[asset reconstruction company] or the secured creditors as the case may be, shall give`
  line `intimation to the Central Registrar of the payment or satisfaction in full, of any security interest relating to`
  line `the ^2[asset reconstruction company] or the secured creditors and requiring registration under this Chapter,`
  line `within thirty days from the date of such payment or satisfaction.`
  line
  line `^3[(1A) On receipt of intimation under sub-section (1), the Central Registrar shall order that a`
  line `memorandum of satisfaction shall be entered in the Central Register.]`
  line
  line `(2) ^4[If the concerned borrower gives an intimation to the Central Registrar for not recording the`
  line `payment or satisfaction referred to in sub-section (1),the Central Registrar shall on receipt of such`
  line `intimation], cause a notice to be sent to the ^5[asset reconstruction company] or the secured creditors`
  line `calling upon it to show cause within a time not exceeding fourteen days specified in such notice, as to`
  line `why payment or satisfaction should not be recorded as intimated to the Central Registrar.`
  line
  line `(3) If no cause is shown, the Central Registrar shall order that a memorandum of satisfaction shall be`
  line `entered in the Central Register.`
  line
  line `(4) If cause is shown, the Central Registrar shall record a note to that effect in the Central Register,`
  line `and shall inform the borrower that he has done so.`
obj_root_law_sections_25_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for "securitisation company or reconstruction company" (w.e.f. 1-9-2016).`
  line
  line `2. Subs. by s. 3, ibid., for "securitisation company or the reconstruction company" (w.e.f. 1-9-2016).`
  line
  line `3. Ins. by Act 30 of 2004, s. 15 (w.e.f. 11-11-2004)..`
  line
  line `4. Subs. by s. 15, ibid., for "The Central Registrar shall, on receipt of such intimation" (w.e.f. 11-11-2004).`
  line
  line `5. Subs. by s. 3, ibid., for "securitisation company" (w.e.f. 1-9-2016).`
obj_root_law_sections_26:
  sectionId (20674)
  sectionNo (26)
  orderNo 35
  title `Right to inspect particulars of securitisation, reconstruction and security interest transactions.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20674&sectionno=26&orderno=35&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_26_content:
  string
  line `(1) The particulars of securitisation or reconstruction or security interest entered in the`
  line `Central register of such transactions kept under section 22 shall be open during the business hours for`
  line `inspection by any person on payment of such fees as may be prescribed.`
  line
  line `(2) The Central Register referred to in sub-section (1) maintained in electronic form shall also be`
  line `open during the business hours for the inspection of any person through electronic media on payment of`
  line `such fees as may be prescribed.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_26_a:
  sectionId (20675)
  sectionNo 26A
  orderNo 36
  title `Rectification by Central Government in matters of registration, modification and satisfaction, etc.`
  content obj_root_law_sections_26_a_content
  footnotes obj_root_law_sections_26_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20675&sectionno=26A&orderno=36&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_26_a_content:
  string
  line `^1[26A.Rectification by Central Government in matters of registration, modification and`
  line `satisfaction, etc.--(1) The Central Government, on being satisfied--`
  line
  line `(a) that the omission to file with the Registrar the particulars of any transaction of securitisation,`
  line `asset reconstruction or security interest or modification or satisfaction of such transaction or; the`
  line `omission or mis-statement of any particular with respect to any such transaction or modification or`
  line `with respect to any satisfaction or other entry made in pursuance of section 23 or section 24 or section`
  line `25 of the principal Act was accidental or due to inadvertence or some other sufficient cause or it is not`
  line `of a nature to prejudice the position of creditors; or`
  line
  line `(b) that on other grounds, it is just and equitable to grant relief,`
  line
  line `may, on the application of a secured creditor or ^2[asset reconstruction company] or any other person`
  line `interested on such terms and conditions as it may seem to the Central Government just and expedient,`
  line `direct that the time for filing of the particulars of the transaction for registration or modification or`
  line `satisfaction shall be extended or, as the case may require, the omission or mis-statement shall be rectified.`
  line
  line `(2) Where the Central Government extends the time for the registration of transaction of security`
  line `interest or securitisation or asset reconstruction or modification or satisfaction thereof, the order shall not`
  line `prejudice any rights acquired in respect of the property concerned or financial asset before the transaction`
  line `is actually registered.]`
obj_root_law_sections_26_a_footnotes:
  string
  line `1. Ins. by Act 1 of 2013, s. 9 (w.e.f. 15-1-2013).`
  line
  line `2. Subs. by Act 44 of 2016, s. 3, for "securitisation company or reconstruction company" (w.e.f. 1-9-2016).`
obj_root_law_sections_26_b:
  sectionId (20676)
  sectionNo 26B
  orderNo 37
  title `Registration by secured creditors and other creditors.`
  content obj_root_law_sections_26_b_content
  footnotes `1. Ins. by s. 18, ibid. (w.e.f. 24-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20676&sectionno=26B&orderno=37&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_26_b_content:
  string
  line `^126B. Registration by secured creditors and other creditors.-- (1) The Central Government may by`
  line `notification, extend the provisions of Chapter IV relating to Central Registry to all creditors other than`
  line `secured creditors as defined in clause (zd) of sub-section (1) of section 2, for creation, modification or`
  line `satisfaction of any security interest over any property of the borrower for the purpose of securing due`
  line `repayment of any financial assistance granted by such creditor to the borrower.`
  line
  line `(2) From the date of notification under sub-section (1), any creditor including the secured creditor`
  line `may file particulars of transactions of creation, modification or satisfaction of any security interest with`
  line `the Central Registry in such form and manner as may be prescribed.`
  line
  line `(3) A creditor other than the secured creditor filing particulars of transactions of creation,`
  line `modification and satisfaction of security interest over properties created in its favour shall not be entitled`
  line `to exercise any right of enforcement of securities under this Act.`
  line
  line `(4) Every authority or officer of the Central Government or any State Government or local authority,`
  line `entrusted with the function of recovery of tax or other Government dues and for issuing any order for`
  line `attachment of any property of any person liable to pay the tax or Government dues, shall file with the`
  line `Central Registry such attachment order with particulars of the assessee and details of tax or other`
  line `Government dues from such date as may be notified by the Central Government, in such form and manner`
  line `as may be prescribed.`
  line
  line `(5) If any person, having any claim against any borrower, obtains orders for attachment of property`
  line `from any court or other authority empowered to issue attachment order, such person may file particulars`
  line `of such attachment orders with Central Registry in such form and manner on payment of such fee as may`
  line `be prescribed.]`
obj_root_law_sections_26_c:
  sectionId (20677)
  sectionNo 26C
  orderNo 38
  title `Effect of the registration of transactions, etc.`
  content obj_root_law_sections_26_c_content
  footnotes `1. Ins. by s. 18, ibid. (w.e.f. 24-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20677&sectionno=26C&orderno=38&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_26_c_content:
  string
  line `^1[26C. Effect of the registration of transactions, etc.--(1) Without prejudice to the provisions`
  line `contained in any other law, for the time being in force, any registration of transactions of creation,`
  line `modification or satisfaction of security interest by a secured creditor or other creditor or filing of`
  line `attachment orders under this Chapter shall be deemed to constitute a public notice from the date and time`
  line `of filing of particulars of such transaction with the Central Registry for creation, modification or`
  line `satisfaction of such security interest or attachment order, as the case may be.`
  line
  line `(2) Where security interest or attachment order upon any property in favour of the secured creditor or`
  line `any other creditor are filed for the purpose of registration under the provisions of Chapter IV and this`
  line `Chapter, the claim of such secured creditor or other creditor holding attachment order shall have priority`
  line `over any subsequent security interest created upon such property and any transfer by way of sale, lease or`
  line `assignment or licence of such property or attachment order subsequent to such registration, shall be`
  line `subject to such claim:`
  line
  line `Provided that nothing contained in this sub-section shall apply to transactions carried on by the`
  line `borrower in the ordinary course of business.]`
obj_root_law_sections_26_d:
  sectionId (20678)
  sectionNo 26D
  orderNo 39
  title `Right of enforcement of securities.`
  content obj_root_law_sections_26_d_content
  footnotes `1. Ins. by s. 18, ibid. (w.e.f. 24-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20678&sectionno=26D&orderno=39&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_26_d_content:
  string
  line `^1[26D. Right of enforcement of securities.--Notwithstanding anything contained in any other law for`
  line `the time being in force, from the date of commencement of the provisions of this Chapter, no secured`
  line `creditor shall be entitled to exercise the rights of enforcement of securities under Chapter III unless the`
  line `security interest created in its favour by the borrower has been registered with the Central Registry.]`
obj_root_law_sections_26_e:
  sectionId (20679)
  sectionNo 26E
  orderNo 40
  title `Priority to secured creditors.`
  content obj_root_law_sections_26_e_content
  footnotes `1. Ins. by s. 18, ibid. (w.e.f. 24-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20679&sectionno=26E&orderno=40&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_26_e_content:
  string
  line `^1[26E. Priority to secured creditors.--Notwithstanding anything contained in any other law for the`
  line `time being in force, after the registration of security interest, the debts due to any secured creditor shall be`
  line `paid in priority over all other debts and all revenues, taxes, cesses and other rates payable to the Central`
  line `Government or State Government or local authority.`
  line
  line `Explanation.--For the purposes of this section, it is hereby clarified that on or after the`
  line `commencement of the Insolvency and Bankruptcy Code, 2016 (31 of 2016), in cases where insolvency or`
  line `bankruptcy proceedings are pending in respect of secured assets of the borrower, priority to secured`
  line `creditors in payment of debt shall be subject to the provisions of that Code.]`
obj_root_law_sections_27:
  sectionId (20680)
  sectionNo (27)
  orderNo 41
  title Penalties.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20680&sectionno=27&orderno=41&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_27_content:
  string
  line `If a default is made--`
  line
  line `(a) in filing under section 23, the particulars of every transaction of any securitisation or asset`
  line `reconstruction or security interest created by a ^1[asset reconstruction company]or secured creditors; or`
  line
  line `(b) in sending under section 24, the particulars of the modification referred to in that section; or`
  line
  line `(c) in giving intimation under section 25, every company and every officer of the company or the`
  line `secured creditors and every officer of the secured creditor who is in default shall be punishable with`
  line `fine which may extend to five thousand rupees for every day during which the default continues:`
  line
  line `^2[Provided that provisions of this section shall be deemed to have been omitted from the date of`
  line `coming into force of the provisions of this Chapter and section 23 as amended by the Enforcement of`
  line `Security Interest and Recovery of Debts Laws and Miscellaneous Provisions (Amendment) Act,`
  line `2016 (44 of 2016).]`
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by Act 44 of 2016, s. 3, for "securitisation company or reconstruction company" (w.e.f. 1-9-2016).`
  line
  line `2. Ins. by s. 19, ibid. (w.e.f.24-1-2020).`
obj_root_law_sections_28:
  sectionId (20681)
  sectionNo (28)
  orderNo 42
  title [Omitted.].
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20681&sectionno=28&orderno=42&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_28_content:
  string
  line `[Penalties for non-compliance of direction of Reserve Bank.] Omitted by the Enforcement of`
  line `Security Interest and Recovery of Debts Laws and Miscellaneous Provisions (Amendment) Act,`
  line `2016 (44 of 2016) s. 20 (w.e.f. 1-9-2016).`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (20682)
  sectionNo (29)
  orderNo 43
  title Offences.
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20682&sectionno=29&orderno=43&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_29_content:
  string
  line `If any person contravenes or attempts to contravene or abets the contravention of the`
  line `provisions of this Act or of any rules made thereunder, he shall be punishable with imprisonment for a`
  line `term which may extend to one year, or with fine, or with both.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (20683)
  sectionNo (30)
  orderNo 44
  title `Cognizance of offence.`
  content obj_root_law_sections_30_content
  footnotes `1 Subs. by Act 1 of 2013, s. 10, for section 30 (w.e.f. 15-1-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20683&sectionno=30&orderno=44&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_30_content:
  string
  line 3
  line `[30. Cognizance of offences.--(1) No court shall take cognizance of any offence punishable under`
  line `section 27 in relation to non-compliance with the provisions of section 23, section 24 or section 25 or`
  line `under section 28 or section 29 or any other provisions of the Act, except upon a complaint in writing`
  line `made by an officer of the Central Registry or an officer of the Reserve Bank, generally or specially`
  line `authorised in writing in this behalf by the Central Registrar or, as the case may be, the Reserve Bank.`
  line
  line `(2) No court inferior to that of a Metropolitan Magistrate or a Judicial Magistrate of the first class`
  line `shall try any offence punishable under this Act.]`
obj_root_law_sections_30_a:
  sectionId (20684)
  sectionNo 30A
  orderNo 45
  title `Power of adjudicating authority to impose penalty.`
  content obj_root_law_sections_30_a_content
  footnotes `1. Ins. by Act 44 of 2016, s. 21 (w.e.f. 1-9-2016).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20684&sectionno=30A&orderno=45&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_30_a_content:
  string
  line `^1[30A. Power of adjudicating authority to impose penalty.-- (1) Where any asset reconstruction`
  line `company or any person fails to comply with any direction issued by the Reserve Bank under this Act the`
  line `adjudicating authority may, by an order, impose on such company or person in default, a penalty not`
  line `exceeding one crore rupees or twice the amount involved in such failure where such amount is`
  line `quantifiable, whichever is more, and where such failure is a continuing one, a further penalty which may`
  line `extend to one lakh rupees for every day, after the first, during which such failure continues.`
  line
  line `(2) For the purpose of imposing penalty under sub-section (1), the adjudicating authority shall serve a`
  line `notice on the asset reconstruction company or the person in default requiring such company or person to`
  line `show cause why the amount specified in the notice should not be imposed as a penalty and a reasonable`
  line `opportunity of being heard shall be given to such person.`
  line
  line `(3) Any penalty imposed under this section shall be payable within a period of thirty days from the`
  line `date of issue of notice under sub-section (2).`
  line
  line `(4) Where the asset reconstruction company fails to pay the penalty within the specified period under`
  line `sub-section (3), the adjudicating authority shall, by an order, cancel its registration:`
  line
  line `Provided that an opportunity of being heard shall be given to such asset reconstruction company`
  line `before cancellation of registration.`
  line
  line `(5) No complaint shall be filed against any person in default in any court pertaining to any failure`
  line `under sub-section (1) in respect of which any penalty has been imposed and recovered by the Reserve`
  line `Bank under this section.`
  line
  line `(6) Where any complaint has been filed against a person in default in the court having jurisdiction no`
  line `proceeding for imposition of penalty against that person shall be taken under this section.`
  line
  line `Explanation.--For the purposes of this section and sections 30B, 30C and 30D,--`
  line
  line `(i) "adjudicating authority" means such officer or a committee of officers of the Reserve Bank,`
  line `designated as such from time to time, by notification, by the Central Board of Reserve Bank;`
  line
  line `(ii) "person in default" means the asset reconstruction company or any person which has`
  line `committed any failure, contravention or default under this Act and any person incharge of such`
  line `company or such other person, as the case may be, shall be liable to be proceeded against and`
  line `punished under section 33 for such failure or contravention or default committed by such company or`
  line person.]
obj_root_law_sections_30_b:
  sectionId (20685)
  sectionNo 30B
  orderNo 46
  title `Appeal against penalties.`
  content obj_root_law_sections_30_b_content
  footnotes `1. Ins. by Act 44 of 2016, s. 21 (w.e.f. 1-9-2016).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20685&sectionno=30B&orderno=46&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_30_b_content:
  string
  line `^1[30B. Appeal against penalties.--A person in default, aggrieved by an order passed under`
  line `sub-section (4) of section 30A, may, within a period of thirty days from the date on which such order is`
  line `passed, prefer an appeal to the Appellate Authority:`
  line
  line `Provided that the Appellate Authority may entertain an appeal after the expiry of the said period of`
  line `thirty days, if it is satisfied that there was sufficient cause for not filing it within such period.]`
obj_root_law_sections_30_c:
  sectionId (20686)
  sectionNo 30C
  orderNo 47
  title `Appellate Authority.`
  content obj_root_law_sections_30_c_content
  footnotes `1. Ins. by Act 44 of 2016, s. 21 (w.e.f. 1-9-2016).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20686&sectionno=30C&orderno=47&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_30_c_content:
  string
  line `^1[30C. Appellate Authority.--(1) The Central Board of Reserve Bank may designate such officer or`
  line `committee of officers as it deems fit to exercise the power of Appellate Authority.`
  line
  line `(2) The Appellate Authority shall have power to pass such order as it deems fit after providing a`
  line `reasonable opportunity of being heard to the person in default.`
  line
  line `(3) The Appellate Authority may, by an order stay the enforcement of the order passed by the`
  line `adjudicating authority under section 30A, subject to such terms and conditions, as it deems fit.`
  line
  line `(4) Where the person in default fails to comply with the terms and conditions imposed by order under`
  line `sub-section (3) without reasonable cause, the Appellate Authority may dismiss the appeal.]`
obj_root_law_sections_30_d:
  sectionId (20687)
  sectionNo 30D
  orderNo 48
  title `Recovery of penalties.`
  content obj_root_law_sections_30_d_content
  footnotes `1. Ins. by Act 44 of 2016, s. 21 (w.e.f. 1-9-2016).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20687&sectionno=30D&orderno=48&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_30_d_content:
  string
  line `^1[30D. Recovery of penalties.--(1) Any penalty imposed under section 30A shall be recovered as a`
  line `"recoverable sum" and shall be payable within a period of thirty days fromthe date on which notice demanding payment of the recoverable sum is served upon the person in default and, in the case of failure`
  line `of payment by such person within such period, the Reserve Bank may, for the purpose of recovery,--`
  line
  line `(a) debit the current account, if any, of the person in default maintained with the Reserve Bank or`
  line `by liquidating the securities, if any, held to the credit of such person in the books of the Reserve`
  line Bank;
  line
  line `(b) issue a notice to the person from whom any amount is due to the person in default, requiring`
  line `such person to deduct from the amount payable by him to the person in default, such amount`
  line `equivalent to the amount of the recoverable sum, and to make payment of such amount to the Reserve`
  line Bank.
  line
  line `(2) Save as otherwise provided in sub-section (4), a notice issued under clause (b) of sub-section (1)`
  line `shall be binding on every person to whom it is issued, and, where such notice is issued to a post office,`
  line `bank or an insurance company, it shall not be necessary to produce any pass book, deposit receipt, policy`
  line `or any other document for the purpose of any entry or endorsement thereof before payment is made,`
  line `notwithstanding any rule, practice or requirement to the contrary.`
  line
  line `(3) Any claim in respect of any amount, arising after the date of issue of notice under sub-section (1)`
  line `shall be void as against the demand contained in such notice.`
  line
  line `(4) Any person, to whom the notice is sent under sub-section (1), objects to such notice by a`
  line `statement on oath that the sum demanded or any part thereof is not due to the person in default or that he`
  line `does not hold any money for or on account of the person in default, then nothing contained in this section`
  line `shall be deemed to require, such person to pay such sum or part thereof, as the case may be.`
  line
  line `(5) Where it is found that statement made by the person under sub-section (4) is false in material`
  line `particulars, such person shall be personally liable to the Reserve Bank to the extent of his own liability to`
  line `the person in default on the date of the notice, or to the extent of the recoverable sum payable by the`
  line `person in default to the Reserve Bank, whichever is less.`
  line
  line `(6) The Reserve Bank may, at any time, amend or revoke any notice issued under sub-section (1) or`
  line `extend the time for making the payment in pursuance of such notice.`
  line
  line `(7) The Reserve Bank shall grant a receipt for any amount paid to it in compliance with a notice`
  line `issued under this section and the person so paying shall be fully discharged from his liability to the person`
  line `in default to the extent of the amount so paid.`
  line
  line `(8) Any person discharging any liability to the person in default after the receipt of a notice under this`
  line `section shall be personally liable to the Reserve Bank--`
  line
  line `(a) to the extent of his own liability to the person in default so discharged; or`
  line
  line `(b) to the extent of the recoverable sum payable by the person in default to the Reserve Bank,`
  line `whichever is less.`
  line
  line `(9) Where the person to whom the notice is sent under this section, fails to make payment in`
  line `pursuance thereof to the Reserve Bank, he shall be deemed to be the person in default in respect of the`
  line `amount specified in the notice and action or proceedings may be taken or instituted against him for the`
  line `realisation of the amount in the manner provided in this section.`
  line
  line `(10) The Reserve Bank may enforce recovery of recoverable sum through the principal civil court`
  line `having jurisdiction in the area where the registered office or the head office or the principal place of`
  line `business of the person in default or the usual place of residence of such person is situated as if the notice`
  line `issued by the Reserve Bank were a decree of the Court.`
  line
  line `(11) No recovery under sub-section (10) shall be enforced, except on an application made to the`
  line `principal civil court by an officer of the Reserve Bank authorised in this behalf certifying that the person`
  line `in default has failed to pay the recoverable sum.]`
obj_root_law_sections_31:
  sectionId (20688)
  sectionNo (31)
  orderNo 49
  title `Provisions of this Act not to apply in certain cases.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20688&sectionno=31&orderno=49&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_31_content:
  string
  line `The provisions of this Act shall not apply`
  line to--
  line
  line `(a) a lien on any goods, money or security given by or under the Indian Contract Act, 1872 (9 of`
  line `1872) or the Sale of Goods Act, 1930 (3 of 1930) or any other law for the time being in force;`
  line
  line `(b) a pledge of movables within the meaning of section 172 of the Indian Contract Act, 1872 (9 of`
  line `1872);`
  line
  line `(c) creation of any security in any aircraft as defined in clause (1) of section 2 of the Aircraft Act,`
  line `1934 (24 of 1934);`
  line
  line `(d) creation of security interest in any vessel as defined in clause (55) of section 3 of the`
  line `Merchant Shipping Act, 1958 (44 of 1958);`
  line
  line `^1** * * *`
  line
  line `(f) any rights of unpaid seller under section 47 of the Sale of Goods Act, 1930 (3 of 1930);`
  line
  line `(g) ^2[any properties not liable to attachment (excluding the properties specifically charged with`
  line `the debt recoverable under this Act)]or sale under the first proviso to sub-section (1) of section 60 of`
  line `the Code of Civil Procedure, 1908 (5 of 1908);`
  line
  line `(h) any security interest for securing repayment of any financial asset not exceeding one lakh`
  line rupees;
  line
  line `(i) any security interest created in agricultural land;`
  line
  line `(j) any case in which the amount due is less than twenty per cent. of the principal amount and`
  line `interest thereon.`
obj_root_law_sections_31_footnotes:
  string
  line `1. Omitted by Act 44 of 2016, s. 22 (w.e.f. 1-9-2016).`
  line
  line `2. Subs. by Act 30 of 2004, s. 17, for "any properties not liable to attachment" (w.e.f. 11-11-2004).`
obj_root_law_sections_31_a:
  sectionId (20689)
  sectionNo 31A
  orderNo 50
  title `Power to exempt a class or classes of banks or financial institutions.`
  content obj_root_law_sections_31_a_content
  footnotes obj_root_law_sections_31_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20689&sectionno=31A&orderno=50&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_31_a_content:
  string
  line `^1[31A. Power to exempt a class or classes of banks or financial institutions.--(1)The Central`
  line `Government may, by notification in the public interest, direct that any of the provisions of this Act,--`
  line
  line `(a) shall not apply to such class or classes of banks or financial institutions; or`
  line
  line `(b) shall apply to the class or classes of banks or financial institutions with such exceptions,`
  line `modifications and adaptations, as may be specified in the notification.`
  line
  line `^2[(2) A copy of every notification proposed to be issued under sub-section (1), shall be laid in draft`
  line `before each House of Parliament, while it is in session, for a total period of thirty days, and if, both`
  line
  line `Houses agree in disapproving the issue of notification or both Houses agree in making any modification`
  line `in the notification, the notification shall not be issued or, as the case may be, shall be issued only in such`
  line `modified form as may be agreed upon by both the Houses.`
  line
  line `(3) In reckoning any such period of thirty days as is referred to in sub-section (2), no account shall be`
  line `taken of any period during which the House referred to in sub-section (2) is prorogued or adjourned for`
  line `more than four consecutive days.`
  line
  line `(4) The copies of every notification issued under this section shall, as soon as may be after it has been`
  line `issued, be laid before each House of Parliament.]]`
obj_root_law_sections_31_a_footnotes:
  string
  line `1. Ins. by Act 1 of 2013, s. 11 (w.e.f. 15-1-2013).`
  line
  line `2. Subs. by Act 44 of 2016, s. 23, for sub-section (2) (w.e.f. 1-9-2016).`
obj_root_law_sections_32:
  sectionId (20690)
  sectionNo (32)
  orderNo 51
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20690&sectionno=32&orderno=51&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_32_content:
  string
  line `No suit, prosecution or other legal proceedings shall`
  line `lie against ^1[the Reserve Bank or the Central Registry or any secured creditor or any of its officers] for`
  line `anything done or omitted to be done in good faith under this Act.`
obj_root_law_sections_32_footnotes:
  string
  line `1. Subs. by Act 44 of 2016, s. 24, for "any secured creditor or any of his officers or manager exercising any of the rights of the`
  line `secured creditor or borrower" (w.e.f. 1-9-2016).`
obj_root_law_sections_33:
  sectionId (20691)
  sectionNo (33)
  orderNo 52
  title `Offences by companies.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20691&sectionno=33&orderno=52&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_33_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed was incharge of, and was responsible`
  line `to, the company, for the conduct of the business of the company, as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act, if he proves that the offence was committed without his knowledge or`
  line `that he had exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of the offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (20692)
  sectionNo (34)
  orderNo 53
  title `Civil court not to have jurisdiction.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20692&sectionno=34&orderno=53&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_34_content:
  string
  line `No civil court shall have jurisdiction to entertain any suit`
  line `or proceeding in respect of any matter which a Debts Recovery Tribunal or the Appellate Tribunal is`
  line `empowered by or under this Act to determine and no injunction shall be granted by any court or other`
  line `authority in respect of any action taken or to be taken in pursuance of any power conferred by or under`
  line `this Act or under the Recovery of Debts Due to Banks and Financial Institutions Act, 1993 (51 of 1993).`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (20693)
  sectionNo (35)
  orderNo 54
  title `The provisions of this Act to override other laws.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20693&sectionno=35&orderno=54&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_35_content:
  string
  line `The provisions of this Act shall have effect,`
  line `notwithstanding anything inconsistent therewith contained in any other law for the time being in force or`
  line `any instrument having effect by virtue of any such law.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (20694)
  sectionNo (36)
  orderNo 55
  title Limitation.
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20694&sectionno=36&orderno=55&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_36_content:
  string
  line `No secured creditor shall be entitled to take all or any of the measures under`
  line `sub-section (4) of section 13, unless his claim in respect of the financial asset is made within the period of`
  line `limitation prescribed under the Limitation Act, 1963 (36 of 1963).`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (20695)
  sectionNo (37)
  orderNo 56
  title `Application of other laws not barred.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20695&sectionno=37&orderno=56&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_37_content:
  string
  line `The provisions of this Act or the rules made thereunder`
  line `shall be in addition to, and not in derogation of, the Companies Act, 1956 (1 of 1956), the Securities Contracts (Regulation) Act, 1956 (42 of 1956), the Securities and Exchange Board of India Act, 1992`
  line `(15 of 1992), the Recovery of Debts Due to Banks and Financial Institutions Act, 1993 (51 of 1993) or`
  line `any other law for the time being in force.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (20696)
  sectionNo (38)
  orderNo 57
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20696&sectionno=38&orderno=57&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_38_content:
  string
  line `(1) The Central Government may, by`
  line `notification and in the Electronic Gazette as defined in clause (s) of section 2 of the Information`
  line `Technology Act, 2000 (21 of 2000), make rules for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `^1[(a) other business or commercial rights of similar nature under clause (t) of section 2;]`
  line
  line `^2[(aa)] the form and manner in which an application may be filed under sub-section (10) of`
  line `section 13;`
  line
  line `(b) the manner in which the rights of a secured creditor may be exercised by one or more of his`
  line `officers under sub-section (12) of section 13;`
  line
  line `^3[(ba) the fee for making an application to the Debts Recovery Tribunal under sub-section (1) of`
  line `section 17;`
  line
  line `(bb) the form of making an application to the Appellate Tribunal under sub-section (6) of`
  line `section 17;`
  line
  line `(bc) the fee for preferring an appeal to the Appellate Tribunal under sub-section (1) of section`
  line 18;]
  line
  line `^1[(bca) the manner of integration of records of various registration systems with the records of`
  line `Central Registry under sub-section (1) of section 20A;`
  line
  line `(bcb) the terms and conditions of delegation of powers by the Central Government to the Reserve`
  line `Bank under section 20B;]`
  line
  line `(c) the safeguards subject to which the records may be kept under sub-section (2) of section 22;`
  line
  line `(d) the manner in which the particulars of every transaction of securitisation shall be filed under`
  line `section 23 and fee for filing such transaction;`
  line
  line `^1[(da) the form for registration of different types of security interests and fee thereof under`
  line `sub-section (3) of section 23;]`
  line
  line `(e) the fee for inspecting the particulars of transactions kept under section 22 and entered in the`
  line `Central Register under sub-section (1) of section 26;`
  line
  line `(f) the fee for inspecting the Central Register maintained in electronic form under sub-section (2)`
  line `of section 26;`
  line
  line `^1[(fa) the form and the manner for filing particulars of transactions under sub-section (2) of`
  line `section 26B;`
  line
  line `(fb) the form and manner of filing attachment orders with the Central Registry and the date under`
  line `sub-section (4) of section 26B;`
  line
  line `(fc) the form and manner of filing particulars of attachment order with the Central Registry and`
  line `the fee under sub-section (5) of section 26B;]`
  line
  line `(g) any other matter which is required to be, or may be, prescribed, in respect of which provision`
  line `is to be, or may be, made by rules.`
  line
  line `(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each House`
  line `of Parliament, while it is in session, for a total period of thirty days which may be comprised in one`
  line `session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_38_footnotes:
  string
  line `1. Ins. by Act 44 of 2016, s. 25 (w.e.f. 1-9-2016).`
  line
  line `2. Clause (a) renumbered as clause (aa) by s. 25, ibid. (w.e.f. 1-9-2016).`
  line
  line `3. Ins. by Act 30 of 2004, s. 18 (w.e.f. 11-11-2004).`
obj_root_law_sections_39:
  sectionId (20697)
  sectionNo (39)
  orderNo 58
  title `Certain provisions of this Act to apply after Central Registry is set up or cause to be set up.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20697&sectionno=39&orderno=58&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_39_content:
  string
  line `The provisions of sub-sections (2), (3) and (4) of section 20 and sections 21, 22, 23, 24, 25, 26 and`
  line `27 shall apply after the Central Registry is set up or cause to be set up under sub-section (1) of section 20.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (20698)
  sectionNo (40)
  orderNo 59
  title `Power to remove difficulties.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20698&sectionno=40&orderno=59&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_40_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of a period of two years from`
  line `the commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (20699)
  sectionNo (41)
  orderNo 60
  title `Amendments to certain enactments.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20699&sectionno=41&orderno=60&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_41_content:
  string
  line `The enactments specified in the Schedule shall be`
  line `amended in the manner specified therein.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (20700)
  sectionNo (42)
  orderNo 61
  title `Repeal and saving.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00037_200254_1517807324604&sectionId=20700&sectionno=42&orderno=61&orgactid=AC_CEN_2_11_00037_200254_1517807324604
obj_root_law_sections_42_content:
  string
  line `(1) The Securitisation and Reconstruction of Financial Assets and`
  line `Enforcement of Security Interest (Second) Ordinance, 2002 (Ord. 3 of 2002) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_42_footnotes:
  string
  line
