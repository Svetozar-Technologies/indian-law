obj_root_law:
  slug the-securitisation-and-reconstruction-of-financial-assets-and-enforcement-of-security-interest-act-2002
  handle (2006)
  collectionHandle 123456789/1362
  title `The Securitisation and Reconstruction of Financial Assets and Enforcement of Security Interest Act, 2002`
  actNumber (54)
  enactmentDate 2002-12-17
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2006`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `वित्तीय आस्तितयों का प्रतिभूतिकरण और पुनर्गठनतथा प्रतिभूति हित का प्रवर्तन अधिनियम, 2002`
  actYear (2002)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to regulate securitisation and reconstruction of financial assets and enforcement of security interest and to provide for a Central database of security interests created on property rights, and for matters connected therewith or incidental thereto.`
  enforcementDate 21-06-2002
  notification undefined
  fetchedAt `2026-05-09T09:32:15.230Z`
