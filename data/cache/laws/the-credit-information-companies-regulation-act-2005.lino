  orderNo 18
  title `Page 18`
  content obj_root_law_translations_hi_sections_18_content
  footnotes obj_root_law_translations_hi_sections_18_footnotes
  sourcePage 18
obj_root_law_translations_hi_sections_18_content:
  string
  line 16
  line अनुसूची
  line `( िारा 34 देविए )`
  line कवतपयअविवनयवमवतयोंकासंशोिन
  line `िाग 1`
  line `िारतीयररजिवबैंकअविवनयम, 1934`
  line `(1934 का 2 )`
  line `िारा 45 ङ कीउपिारा (2) मेंिंर् ( ग ) केपश्चा त्वनम्न विवितअंत:स्था वपतकरें ––`
  line `“( घ ) प्रत् य यविषयक जानकारीकंपनी ( विवनयमन ) अविवन यम, 2005 केअिीनककसीप्रत्य यविषयकसूचनाका प्र`
  line `कटन। ”।`
  line `िाग 2`
  line `बैंक कारीविवनयमन अविवनयम, 19 49`
  line `(19 49 का 10 )`
  line `1. िारा 19 कीउपिारा (3) केपश्चा त्वनम्न विवितअंत:स्था वपतकरें ––`
  line `“(4) उपिारा (1) केिंर् ( ग ) मेंजैसाउपबंवितहैउसके वसिायबैंककारीकंपनीकोई समनुषंगीकंपनीबनाकर प्रत्`
  line `य यविषयकजानकारी कंपनी ( विवनयमन ) अविवनयम, 2005 केअनुसारप्रत्य यविषयकजानकारीसंबंिीकारबारकरने`
  line `केविएसमनुषंगीकंपनीबनासकेगी। ”।`
  line `2. िारा 28 में “ इस िाराकेअिीनउन्हें अविप्राप्त ककसीजानकारीकोऐसेसमेककतप्ररूपमेंप्र कावशतकरसकेंगेजोिह`
  line `िीकसमझे ”, केस्था नपरवनम्न विवितरिें ––`
  line `“( क ) इसअविवनयमकेअिीनउन्हें अविप्राप्त ककसीजानकारीकोऐसेसमेककतप्ररूपमेंवजसेिहिीकसमझे;`
  line `( ि ) प्रत् य यविषयकजानकारीकंपनी ( विवनयमन ) अविवनयम, 2005 केअिीनप्रकटकीगईककसीप्रत्य यविषयक`
  line `जानकारीकोऐसीरीवतमेंवजसेिेउवचतसमझें,प्रकावशतकरसकेगा। ”।`
  line `िाग 3`
  line `राज्यवित्तीयवनगम अविवनयम, 19 51`
  line `(19 51 का 63 )`
  line `िारा 4 0 की उपिारा ( 3 ) केपश्चा त्,वनम्न विवितअंत:स्था वपतकरें ––`
  line `“(4) इसिाराकीकोईबातप्रत्य यविषयकजानकारीकंपनी ( विवनय मन ) अविवनयम, 2005 केअिीनप्रकटकी`
  line `गईप्रत्य यविषयकजानकारीकोिागूनहींहोगी। ”।`
  line `िाग 4`
  line `िारतीय स् टे ट बैंकअविवनयम, 19 55`
  line `(19 55 का 23 )`
  line `िारा 44 कीउपिारा (2) केपश्चा त्,वनम्न विवितअंत:स्था वपतकरें ––`
  line `“( 3 ) इसिाराकीकोईबातप्रत्य यविषयकजानकारीकंपनी ( विवनयमन ) अविवनयम, 2005 केअिीनप्रकटकी`
  line `गईप्रत्य यविषयकजानकारीकोिागूनहींहोगी। ”।`
  line `िाग 5`
  line `िारतीय स् टे ट बैंक ( समनुषंगीबैंक ) अविवनयम, 19 5 9`
  line `(19 59 का 38 )`
  line `िारा 52 कीउपिारा (2) केपश्चा त्,वनम्न विवितअंत:स्था वपतकरें ––`
obj_root_law_translations_hi_sections_18_footnotes:
  string
  line
obj_root_law_translations_hi_sections_19:
  kind page
  sectionId pdf-page-19
  sectionNo (19)
