obj_root_law_sections_1:
  sectionId (48219)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Naval and Aircraft Prize Act, 1971.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48219&sectionno=1&orderno=1&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (48220)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48220&sectionno=2&orderno=2&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "aircraft" has the meaning assigned to it in clause (ii) of section 4 of the Air Force`
  line `Act, 1950 (45 of 1950);`
  line
  line `(b) "aircraft papers" includes all books, passes, charter parties, bills of lading, customs receipts,`
  line `manifests, certificates, licences, lists, tickets, notes, letters and other documents and writings`
  line `delivered up or found on board a captured aircraft;`
  line
  line `(c) "Armed Forces" means the Army, Navy and Air Force or any part of any one or more of them`
  line `and includes any other armed force in the service of, or employed with, the Army, Navy or Air Force`
  line `during hostilities;`
  line
  line `(d) "goods" includes all such things as may be subject to adjudication as prize, but in the case of a`
  line `naval prize does not include any aircraft or boat unless the aircraft or boat is a part of the cargo of a`
  line ship;
  line
  line `(e) "Prize Court" means a prize court established under section 3;`
  line
  line `(f) "Indian citizen" includes a company registered in India and having its principal place of`
  line `business in India;`
  line
  line `(g) "military aircraft" means any aircraft belonging to the Armed Forces and includes any armed`
  line `aircraft in the service of the Armed Forces and any other aircraft used as a transport or auxiliary or in`
  line `any other way for the purpose of prosecuting or aiding hostilities;`
  line
  line `(h) "prize" means anything which, subject to this Act and the rules made thereunder, may be`
  line `subjected to adjudication and includes a ship or an aircraft and goods carried therein, irrespective of`
  line `whether the ship is captured at sea or seized in port or whether the aircraft is on or over land or sea at`
  line `the time of capture or seizure;`
  line
  line `(i) "ship" includes a vessel and a boat with the tackle, furniture and apparel of the ship, vessel or`
  line boat;
  line
  line `(j) "ship-of-war" means any ship belonging to the Armed Forces and includes any armed ship in`
  line `the service of the Armed Forces and any other ship used as transport or auxiliary or in any other way`
  line `for the purpose of prosecuting or aiding hostilities;`
  line
  line `(k) "ship papers" includes all books, passes, sea briefs, charter parties, bills of lading, customs`
  line `receipts, manifests, certificates, licences, lists, tickets, notes, letters and other documents and writings`
  line `delivered up or found on board a ship captured at sea or seized in port.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (48221)
  sectionNo (3)
  orderNo 3
  title `Establishment of Prize Courts.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48221&sectionno=3&orderno=3&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_3_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, constitute from time to time as many Prize Courts as the Central Government may determine to`
  line `exercise the powers and discharge the functions conferred on a Prize Court by this Act and every such`
  line `Prize Court shall exercise jurisdiction within the local limits of such area or areas as may be specified by`
  line `the Central Government in the said notification.`
  line
  line `(2) Every Prize Court shall consist of such one or more than one member as the Central Government`
  line `may from time to time deem it necessary to appoint.`
  line
  line `(3) A person shall not be qualified for appointment as a member of a Prize Court unless he is a citizen`
  line `of India and has been or is qualified to be appointed as a Judge of a High Court.`
  line
  line `(4) Subject to the provisions of section 18, the conditions of service of a member of a Prize Court`
  line `shall be such as the Central Government may by order determine.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (48222)
  sectionNo (4)
  orderNo 4
  title `Jurisdiction of Prize Courts in prize cases.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48222&sectionno=4&orderno=4&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_4_content:
  string
  line `(1) Notwithstanding anything contained in any`
  line `other law for the time being in force, every Prize Court shall have exclusive jurisdiction in respect of each`
  line `prize and each proceeding for the condemnation of property as prize, whether such prize is taken before`
  line `or after the commencement of this Act, if the prize is--`
  line
  line `(a) brought into or seized within the territory of India;`
  line
  line `(b) brought into or seized within a locality in the temporary or permanent possession of, or`
  line `occupied by, the Armed Forces of the Union; or`
  line
  line `(c) appropriated for the use of the Central Government,`
  line
  line `and is brought within the territorial jurisdiction of that Prize Court:`
  line
  line `Provided that in the case of a Naval prize, the Prize Court shall have jurisdiction only if the prize`
  line `captured or seized is brought to a port or place lying within the territorial jurisdiction of that Prize Court.`
  line
  line `(2) Every Prize Court shall also have exclusive jurisdiction in respect of a prize in which the prize`
  line property--
  line
  line `(a) is lost or entirely destroyed; or`
  line
  line `(b) cannot be brought in for adjudication because of its nature and condition.`
  line
  line `(3) Without prejudice to the generality of the powers conferred by sub-section (1) , a Prize Court shall`
  line `take cognizance of and judicially proceed upon all manners of captures, seizures, prizes and reprisals of`
  line `all ships, vessels, aircrafts and goods that are captured or seized, and shall hear and determine the same,`
  line `and in accordance with this Act and rules made thereunder, shall adjudge and condemn all such ships,`
  line `vessels, aircrafts and goods belonging to any country or State or the nationals, citizens or subjects thereof,`
  line `as may be captured or seized as prize during a war or as a measure of reprisal during an armed conflict or`
  line `in the exercise of the right of self-defence.`
  line
  line `(4) Notwithstanding anything contained in this section, the Prize Court may in respect of any matter`
  line `for which no provision or insufficient provision is made, by or under this Act, apply the principles of the`
  line `International Law regulating that matter.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (48223)
  sectionNo (5)
  orderNo 5
  title `Transfer of cases.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48223&sectionno=5&orderno=5&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_5_content:
  string
  line `(1) Where proceedings are pending in any Prize Court against any ship,`
  line `aircraft or goods, the Prize Court may, at any stage of the proceedings, on application being made by the`
  line `proper officer of the Central Government and upon being satisfied that the proceedings so far as they`
  line `relate to the ship, aircraft or goods, or any part thereof, would be more conveniently conducted in another`
  line `Prize Court, make an order remitting the proceedings or the proceedings so far as they relate to the ship,`
  line `aircraft or goods, or any part of the goods, as the case may be, to such other Prize Court.`
  line
  line `(2) Where any proceedings have been so remitted to another Prize Court, that other Prize Court shall`
  line `have the same jurisdiction to deal with the matter as if the subject matter of those proceedings had`
  line `originally been seized within its jurisdiction or brought within its jurisdiction after capture or seizure, as`
  line `the case may be, and any order made or action taken in those proceedings before the order of remission`
  line `shall be deemed to have been made or taken by or in that Court.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (48224)
  sectionNo (6)
  orderNo 6
  title Appeals.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48224&sectionno=6&orderno=6&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_6_content:
  string
  line `(1) Any person aggrieved by an order or decree of the Prize Court may prefer an appeal`
  line `to the Central Government within a period of ninety days from the date on which such order or decree has`
  line `been made.`
  line
  line `(2) The provisions of sections 5 and 12 of the Limitation Act, 1963 (36 of 1963), shall so far as may`
  line `be, apply for computation of the period specified in sub-section (1).`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (48225)
  sectionNo (7)
  orderNo 7
  title `General powers of Prize Courts.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48225&sectionno=7&orderno=7&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_7_content:
  string
  line `(1) A Prize Court shall, for the purposes of this Act, have the`
  line `same powers as are vested in a Civil Court while trying a suit under the Code of Civil Procedure, 1908`
  line `(5 of 1908), in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of persons and examining them on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) receiving evidence on affidavits;`
  line
  line `(d) requisitioning any public record or copies thereof from any court or office;`
  line
  line `(e) issuing commissions for the examination of witnesses or documents;`
  line
  line `(f) any other matter which may be prescribed by rules.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), every Prize Court shall have the power to`
  line enforce--
  line
  line `(a) any order or decree of another Prize Court passed in a prize proceeding under this Act;`
  line
  line `(b) any order of the Central Government passed in a prize appeal under section 6.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (48226)
  sectionNo (8)
  orderNo 8
  title `Procedure on capture of prize.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48226&sectionno=8&orderno=8&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_8_content:
  string
  line `(1) Every ship and every aircraft taken as prize and brought into`
  line `port or to a place within the jurisdiction of a Prize Court shall forthwith and without bulk broken, be`
  line `delivered to the Marshal of the Court.`
  line
  line `(2) If there is no such Marshal then the ship or aircraft shall be in like manner delivered to such`
  line `person as the Central Government may appoint in this behalf.`
  line
  line `(3) The ship or aircraft shall, subject to the orders of the Court, remain in the custody of the Marshal,`
  line `or the person appointed under sub-section (2).`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (48227)
  sectionNo (9)
  orderNo 9
  title `Ship and aircraft papers to be brought in Registry.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48227&sectionno=9&orderno=9&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_9_content:
  string
  line `(1) The captors shall with all convenient`
  line `speed after the ship or aircraft is brought into port or to a place within the jurisdiction of a Prize Court`
  line `bring the ship papers or the aircraft papers, as the case may be, into the Registry of the Prize Court.`
  line
  line `(2) The commanding officer or the captain of the capturing ship or aircraft or the commanding officer`
  line `of the capturing force, or any other officer or person seizing the ship or aircraft at any port or aerodrome`
  line `or any officer designated by the commanding officer or his superior authority as a Prize Officer or such`
  line `other officer or person who was present at the capture and saw the ship papers or aircraft papers delivered`
  line `up or found on board shall make oath that they are brought in as they were taken without fraud, addition,`
  line `or subduction or alteration or else shall account on oath to the satisfaction of the Prize Court for the`
  line `absence or altered condition of the ship papers or aircraft papers or any of them.`
  line
  line `(3) Where no ship papers or aircraft papers are delivered up or found on board the captured ship or`
  line `captured aircraft, the commanding officer or the captain of the capturing ship or aircraft or the`
  line `commanding officer of the capturing force or any other officer or person seizing the ship or aircraft or the`
  line `Prize Officer or such other officer or person who was present at the capture shall make an oath to that`
  line effect.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (48228)
  sectionNo (10)
  orderNo 10
  title Goods.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48228&sectionno=10&orderno=10&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_10_content:
  string
  line `The provisions of sections 8 and 9 relating to ships and aircraft shall, so far as may be,`
  line `extend and apply to goods taken as prize on board a ship or aircraft and the Prize Court may direct such`
  line `goods to be unladen, inventoried and warehoused.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (48229)
  sectionNo (11)
  orderNo 11
  title Preemption.
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48229&sectionno=11&orderno=11&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_11_content:
  string
  line `Where a ship of a foreign State passing the seas or an aircraft of a foreign State,`
  line `laden with military or victualling stores intended to be carried to any place under the control of an enemy`
  line `is taken in circumstances making it subject to adjudication as prize, and is brought under the control of`
  line `the Government of India, and the purchase of such stores for the service of the Central Government`
  line `appears to the said Government expedient without the condemnation thereof in a Prize Court, then the`
  line `Central Government may purchase on account or for the service of the Central Government all or any of`
  line `such stores.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (48230)
  sectionNo (12)
  orderNo 12
  title `Prize proceedings not to apply to enemy warships and military aircraft.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48230&sectionno=12&orderno=12&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_12_content:
  string
  line `Nothing in this Act`
  line `shall apply to a ship-of-war or military aircraft of the enemy or any other ship or aircraft owned by the`
  line `enemy whether or not registered in the territory of the enemy or goods carried therein and no proceedings`
  line `of prize shall be necessary for the condemnation of such ship-of-war or military aircraft or other ship or`
  line `aircraft or goods carried therein.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (48231)
  sectionNo (13)
  orderNo 13
  title `Capture to belong to Central Government.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48231&sectionno=13&orderno=13&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_13_content:
  string
  line `(1) Subject to the provisions of sub-section (2), all`
  line `prizes captured by the Armed Forces of the Union and condemned where necessary in the Prize Court`
  line `shall be the exclusive property of the Central Government.`
  line
  line `(2) The Central Government may, at its discretion, out of the proceeds of the prize, make a grant of`
  line `such sum of money as it deems fit to the benevolent funds of the Armed Forces of the Union.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (48232)
  sectionNo (14)
  orderNo 14
  title `Prize salvage.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48232&sectionno=14&orderno=14&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_14_content:
  string
  line `(1) Where any ship or goods or aircraft belonging to an Indian citizen, after`
  line `being taken as prize by the enemy is or are retaken from the enemy, the same shall be restored by decree`
  line `of a Prize Court to the owner on his paying to the Central Government as prize salvage one-eighth part of`
  line `the value of the prize to be decreed and ascertained by the Prize Court or such sum not exceeding`
  line `one-eighth part of the estimated value of the prize as may be agreed upon between the owner and the`
  line `Central Government and approved by the order of the Prize Court:`
  line
  line `Provided that where the recapture is made in the circumstances of special difficulty or danger, the`
  line `Prize Court may if it thinks fit award to the Central Government as prize salvage a larger part than`
  line `one-eighth but not exceeding in any case one-fourth part of the value of the prize:`
  line
  line `Provided further that where a ship or aircraft after being so taken is set forth or used by the enemy as`
  line `a ship-of-war or military aircraft, the aforesaid provision for restitution shall not apply and subject to such`
  line `compensation to the owner as the Prize Court may determine, the ownership of such ship or aircraft shall`
  line `vest in the Central Government.`
  line
  line `(2) Where a ship belonging to any Indian citizen, after being taken as prize, is retaken from the`
  line `enemy, such ship may, with the consent of the recaptors, prosecute her voyage and it will not be`
  line `necessary for the Central Government to proceed to adjudication till her return to a port in India.`
  line
  line `(3) The master or owner of the ship or his agent may, with the consent of the Central Government,`
  line `unload and dispose of the goods on board the ship before adjudication.`
  line
  line `(4) In case the ship does not return within six months to a port in India, the Central Government may`
  line `nevertheless institute proceedings against the ship or goods in a Prize Court and the Prize Court may`
  line `thereupon award prize salvage as aforesaid and may enforce payment thereof.`
  line
  line `(5) The provisions of sub-sections (2), (3) and (4) shall mutatis mutandis apply also to an aircraft`
  line `belonging to any Indian citizen which, after being taken as prize, is retaken from the enemy.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (48233)
  sectionNo (15)
  orderNo 15
  title `Offences in respect of prize.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48233&sectionno=15&orderno=15&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_15_content:
  string
  line `Every person who is guilty of a prize offence, that is to say, an`
  line `offence which if committed by a person subject to naval law would be punishable under section 63,`
  line `section 64, section 65, section 66 or section 67 of the Navy Act, 1957 (62 of 1957), shall be punished`
  line `with imprisonment which may extend to two years or with fine or both.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (48234)
  sectionNo (16)
  orderNo 16
  title `Indemnity against legal proceedings.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48234&sectionno=16&orderno=16&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_16_content:
  string
  line `(1) Notwithstanding anything contained in any other law`
  line `for the time being in force, no suit, prosecution or other legal proceedings shall lie against any officer of`
  line `the Armed Forces of the Union or any other person for anything which is in good faith done or intended`
  line `to be done in pursuance of this Act or any rules made thereunder.`
  line
  line `(2) Save as otherwise expressly provided under this Act, no suit or other legal proceedings shall lie`
  line `against the Central Government for any damage caused or likely to be caused by anything in good faith`
  line `done or intended to be done in pursuance of this Act or any rules made thereunder.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (48235)
  sectionNo (17)
  orderNo 17
  title `Power to make rules.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by Act 20 of 1983, s. 2, for certain words (w.e.f. 5-3-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48235&sectionno=17&orderno=17&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_17_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for regulating the practice and procedure of a Prize Court and for generally carrying out the`
  line `purposes of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may provide for all or any`
  line `of the following matters, namely:--`
  line
  line `(a) the institution of cases, issue and service of writs, summons and other processes, and entering`
  line `appearance and making of claims;`
  line
  line `(b) affidavits concerning ship papers or aircraft papers and other affidavits to be or which may be`
  line `made in a Prize Court or for the purpose of proceedings in a Prize Court;`
  line
  line `(c) pleadings, particulars, discovery and inspection of documents and facts, evidence and hearing;`
  line
  line `(d) issue of warrants for arrest of prize, and detention of prize;`
  line
  line `(e) sale, appraisement, safe custody and inspection of prize;`
  line
  line `(f) bail and release;`
  line
  line `(g) requisition by Central Government of ships, aircraft or goods in the custody of a Prize Court;`
  line
  line `(h) appointment of assessors and their fees;`
  line
  line `(i) enforcement and execution of decrees and orders;`
  line
  line `(j) stay of proceedings;`
  line
  line `(k) costs of or incidental to any proceedings in the Prize Court and as to the fees to be charged in`
  line `respect of proceedings therein and as to the taking of security of costs;`
  line
  line `(l) procedure for hearing appeals and other matters pertaining to appeals;`
  line
  line `(m) appointment, duties and conduct of the officers of a Prize Court and costs, charges and`
  line `expenses to be allowed to petitioners therein;`
  line
  line `(n) the manner in which and the conditions subject to which the right of visit, search, detention or`
  line `capture of any ship or aircraft or goods thereon may be exercised and the penalty for impeding the`
  line `exercise of any such right;`
  line
  line `(o) the manner in which any such ship or aircraft or goods seized by or under the authority of any`
  line `officer of the Armed Forces of the Union shall be kept in custody or disposed of;`
  line
  line `(p) the conditions for declaring any ship or aircraft or cargo thereon as hostile and for`
  line `condemnation thereof;`
  line
  line `(q) the manner in which a ship or aircraft recaptured from the enemy may be disposed of;`
  line
  line `(r) the conditions subject to which a right of unhindered passage may be allowed to a ship or`
  line `aircraft within the territory of India on the outbreak of hostilities or an armed conflict on the basis of`
  line reciprocity;
  line
  line `(s) any other matter which may be, or is required to be, prescribed by rules.`
  line
  line `(3) All rules made under this section shall be laid, as soon as may be, after they are made, before each`
  line `house of Parliament while it is in session for a total period of thirty days, which may be comprised in one`
  line `or ^1[in two or more successive sessions, and if, before the expiry of the session immediately following the`
  line `session or the successive sessions aforesaid] both Houses agree in making any modification in the rules or`
  line `both Houses agree that the rules should not be made, the rules shall thereafter have effect only in such`
  line `modified form or be of no effect, as the case may be; so however that any such modification or annulment`
  line `shall be without prejudice to the validity of anything previously done under those rules.`
obj_root_law_sections_18:
  sectionId (48236)
  sectionNo (18)
  orderNo 18
  title `Dissolution of Prize Courts.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48236&sectionno=18&orderno=18&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_18_content:
  string
  line `The Central Government may at any time when there is no prize`
  line `proceeding pending before a Prize Court dissolve that Prize Court, and make such further orders as to the`
  line `custody of the records of that Court as may be considered necessary.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (48237)
  sectionNo (19)
  orderNo 19
  title Repeals.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48237&sectionno=19&orderno=19&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_19_content:
  string
  line `The Naval Prize Act, 1864, the Naval Agency and Distribution Act, 1864, the Prize`
  line `Courts Act, 1894, the Prize Courts Procedure Act, 1914, the Prize Courts Act, 1915, the Naval Prize`
  line `Act, 1918, the Prize Act, 1939, in so far as they apply in India are hereby repealed.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (48238)
  sectionNo (20)
  orderNo 20
  title Savings.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00005_197159_1517807320658&sectionId=48238&sectionno=20&orderno=20&orgactid=AC_CEN_28_38_00005_197159_1517807320658
obj_root_law_sections_20_content:
  string
  line `Nothing in this Act shall--`
  line
  line `(a) give to the officers and seamen of the Indian Naval ships or officers and airmen of the Indian`
  line `Military aircraft or to any other person concerned in the capture of the prize any right or claim in or to`
  line `any ships, aircraft or goods taken as prize or the proceeds thereof; or`
  line
  line `(b) affect the operation of any existing treaty or convention with any foreign State; or`
  line
  line `(c) take away or abridge the powers of the Central Government to enter into any treaty or`
  line `convention with any foreign State containing any stipulation that the Central Government may deem`
  line `appropriate concerning any matter to which this Act relates.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_translations:
