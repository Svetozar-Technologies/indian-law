obj_root_law:
  slug the-food-safety-and-standards-act-2006
  handle (2027)
  collectionHandle 123456789/1362
  title `The Food Safety and Standards Act, 2006`
  actNumber (34)
  enactmentDate 2006-08-23
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2027`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `खाद्य सुरक्षा और मानक अधिनियम, 2006`
  actYear (2006)
  ministry `Ministry of Health and Family Welfare`
  department `Department of Health and Family Welfare`
  longTitle `An Act to consolidate the laws relating to food and to establish the Food Safety and Standards Authority of India for laying down science based standards for articles of food and to regulate their manufacture, storage, distribution, sale and import, to ensure availability of safe and wholesome food for human consumption and for matters connected therewith or incidental thereto.`
  enforcementDate 28-05-2008
  notification `28th May, 2008 (ss. 3 and 30), vide notification No. S.O. 1246(E), dated 28th May, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 28th August, 2008 (s. 90), vide notification No. S.O. 2127(E), dated 28th August, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 18th November, 2008 (ss. 16, 17, 18, 81, 82, 83, 84, 85, 86, 92 and 93), vide notification No. S.O. 2678(E), dated 18th November, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 9th March, 2009 (ss. 11, 12, 13, 14 and 15), vide notification No. S.O. 650(E), dated 9th March, 2009, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-10T14:16:40.609Z`
  translations obj_root_law_translations
