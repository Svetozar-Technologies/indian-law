  (str slug) (str the-food-safety-and-standards-act-2006)
  (str handle) (str 2027)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Food Safety and Standards Act, 2006`)
  (str actNumber) (str 34)
  (str enactmentDate) (str 2006-08-23)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2027`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `खाद्य सुरक्षा और मानक अधिनियम, 2006`)
  (str actYear) (str 2006)
  (str ministry) (str `Ministry of Health and Family Welfare`)
  (str department) (str `Department of Health and Family Welfare`)
  (str longTitle) (str `An Act to consolidate the laws relating to food and to establish the Food Safety and Standards Authority of India for laying down science based standards for articles of food and to regulate their manufacture, storage, distribution, sale and import, to ensure availability of safe and wholesome food for human consumption and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 28-05-2008)
  (str notification) (str `28th May, 2008 (ss. 3 and 30), vide notification No. S.O. 1246(E), dated 28th May, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 28th August, 2008 (s. 90), vide notification No. S.O. 2127(E), dated 28th August, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 18th November, 2008 (ss. 16, 17, 18, 81, 82, 83, 84, 85, 86, 92 and 93), vide notification No. S.O. 2678(E), dated 18th November, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 9th March, 2009 (ss. 11, 12, 13, 14 and 15), vide notification No. S.O. 650(E), dated 9th March, 2009, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-10T14:16:40.609Z`)
