obj_root_law_sections_1:
  sectionId (2791)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2791&sectionno=1&orderno=1&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National ^1[Institutes] of Design Act,`
  line 2014.
  line
  line `(2) It shall come into force on such date ^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for "Institute" (w.e.f. 13-1-2020).`
  line `2 16th September, 2014 vide notification No. S.O. 2393(E), dated 16th September, 2014, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (2792)
  sectionNo (2)
  orderNo 2
  title `Declaration of certain institutions as institutions of national importance.`
  content `^1[Whereas the objects of the institutions mentioned in the Schedule, are such as to make them institutions of national importance, it is hereby declared that each such Institute is an institution of national importance].`
  footnotes `1. Subs. by Act 38 of 2019, s. 4, for section 2 (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2792&sectionno=2&orderno=2&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_3:
  sectionId (2793)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2793&sectionno=3&orderno=3&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Chairperson" means the Chairperson of the Governing Council nominated under clause (a)`
  line `of section 11;`
  line
  line `(b) "Dean", in relation to any Institute campus, means the Dean of such Institute campus;`
  line
  line `(c) "design" means a rational, logical and sequential innovative process for the purpose of`
  line `transferring culture to viable products and services and for providing a competitive edge to products`
  line `and services, and includes industrial design, communication design, textile and apparel design,`
  line `lifestyle design, experiential design, exhibition design, craft and traditional sector design;`
  line
  line `^1[(d) "Director", in relation to any Institute, means the Director of such Institute as appointed under section 18;]`
  line
  line `^2[(e) "Fund", in relation to any Institute, means the Fund of such Institute as maintained under`
  line `section 23;]`
  line
  line `^3[(f) "Governing Council", in relation to any Institute, means the Governing Council of such`
  line `Institute as constituted under section 11;]`
  line
  line `^4[(g) "Institute" means any of the institutions mentioned in column (4) of the Schedule;]`
  line
  line `^5[(h) "Institute campus" means the campus of an Institute as may be established by such Institute`
  line `at any place within India or outside India;]`
  line
  line `(i) "notification" means a notification published in the Official Gazette;`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^6[(k) "Registrar" in relation to any Institute, means the Registrar of such Institute as appointed`
  line `under section 20];`
  line
  line `^7[(ka) "Schedule" means the Schedule annexed to this Act;]`
  line
  line `^8[(l) "Senate", in relation to any Institute, means the Senate of such Institute;]`
  line
  line `^9[(m) "Society" means any of the societies registered under the Societies Registration Act, 1860`
  line `(21 of 1860), and mentioned in column (3) of the Schedule;]`
  line
  line `^10[(n) "Statutes" and "Ordinances", in relation to any Institute, mean the Statutes and the`
  line `Ordinances of such Institute made under this Act.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by s. 5, ibid., for clause (d) (w.e.f. 13-1-2020).`
  line `2. Subs. by s. 5, ibid., for clause (e) (w.e.f. 13-1-2020).`
  line `3. Subs. by s. 5, ibid., for clause (f) (w.e.f. 13-1-2020).`
  line `4. Subs. by s. 5, ibid., for clause (g) (w.e.f. 13-1-2020).`
  line `5. Subs. by s. 5, ibid., for clause (h) (w.e.f. 13-1-2020).`
  line `6. Subs. by Act 38 of 2019, s. 5, for clause (k) (w.e.f. 13-1-2020).`
  line `7. Ins. by s. 5, ibid. (w.e.f. 13-1-2020).`
  line `8. Subs. by s. 5, ibid., for clause (l) (w.e.f. 13-1-2020).`
  line `9. Subs. by s. 5, ibid., for clause (m) (w.e.f. 13-1-2020).`
  line `10. Subs. by s. 5, ibid., for clause (n) (w.e.f. 13-1-2020).`
obj_root_law_sections_4:
  sectionId (2794)
  sectionNo (4)
  orderNo 4
  title `Incorporation of Institute.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by s. 6, ibid., for section 4 (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2794&sectionno=4&orderno=4&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_4_content:
  string
  line `^1[(1) Each Institute shall be a body corporate by the same name as`
  line `as mentioned in column (4) of the Schedule.`
  line
  line `(2) Each Institute shall have perpetual succession and a common seal, with power, subject to the`
  line `provisions of this Act, to acquire, hold and dispose of property, both movable and immovable, and to`
  line `contract and shall, by the said name, sue or be sued.`
  line
  line `(3) The body corporate constituting each Institute shall consist of a Chairperson, Director and other`
  line `members of the Governing Council for the time being, of the Institute.`
  line
  line `(4) Any Institute may establish an Institute campus at such place within India or outside India, as it`
  line `may deem fit:`
  line
  line `Provided that each campus of the National Institute of Design, Ahmedabad, established before the`
  line `commencement of this Act, at Bengaluru in the State of Karnataka and at Gandhinagar in the State of`
  line `Gujarat, shall be deemed to be the Institute campus thereof.`
  line
  line `Explanation.--The reference in this sub-section to the commencement of this Act shall, in relation to`
  line `the National Institute of Design, Ahmedabad, be deemed to be the 16th day of September, 2014.]`
obj_root_law_sections_5:
  sectionId (2795)
  sectionNo (5)
  orderNo 5
  title `Effect of incorporation of the Institute.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2795&sectionno=5&orderno=5&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_5_content:
  string
  line `On and from the date of commencement of this`
  line Act,--
  line
  line `^1[(a) any reference to the Society mentioned in column (3) of the Schedule in any law or in any contract or other instrument shall be deemed as a reference to the corresponding Institute mentioned in column (4) thereof;];`
  line
  line `(b) all property, movable and immovable of, or belonging to, the Society, shall vest in the`
  line Institute;
  line
  line `(c) all the rights and liabilities of the Society shall be transferred to, and be, the rights and`
  line `liabilities of, the Institute;`
  line
  line `(d) any reference to any campus of the Institute, established before the commencement of this`
  line `Act, shall be deemed as a reference to that Institute campus;`
  line
  line `(e) every person employed by the Society, immediately before such commencement, shall hold`
  line `his office or service in the Institute including the Institute campuses, ^2*** by the same tenure, at the same`
  line `remuneration and upon the same terms and conditions and with the same rights and privileges as to`
  line `pension, leave, gratuity, provident fund and other matters as he would have held the same, if this Act`
  line `had not been enacted, and shall continue to be so, unless and until his employment is terminated or`
  line `until such tenure, remuneration, terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the Institute in accordance with the terms of the contract with the employee or, if no`
  line `provision is made therein in this behalf, on payment to him by the Institute of compensation`
  line `equivalent to three months' remuneration in the case of permanent employee and one months`
  line `remuneration in the case of other employee.`
  line
  line `^3[Explanation I.--The reference in this section to the commencement of this Act shall, in relation`
  line `to the National Institute of Design, Ahmedabad, be deemed to be the 16th day of September, 2014.`
  line
  line `Explanation II.--The reference in this section to the commencement of this Act shall, in relation`
  line `to the National Institutes of Design in the States of Madhya Pradesh, Assam, Haryana and Andhra`
  line `Pradesh, be construed as the reference to the date on which the provisions of the National Institute of`
  line `Design (Amendment) Act, 2019 comes into force.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by s. 7, ibid., for clause (a) (w.e.f. 13-1-2020).`
  line `2. The words "located at Bengaluru in the State of Karnataka and at Gandhinagar in the`
  line `State of Gujarat" omitted by Act 38 of 2019, s. 7 (w.e.f. 13-1-2020).`
  line `3. Ins. by s. 7, ibid. (w.e.f. 13-1-2020).`
obj_root_law_sections_6:
  sectionId (2796)
  sectionNo (6)
  orderNo 6
  title `Powers of Institute.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by s. 8, ibid., for "the Institute shall" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2796&sectionno=6&orderno=6&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_6_content:
  string
  line `(1) Subject to the provisions of this Act, the ^1[each Institute shall] exercise the`
  line `following powers and perform the following duties, namely:--`
  line
  line `(a) to provide for instructions, research and training in the areas or disciplines relating to design`
  line `and to nurture and promote quality and excellence thereof in such areas or disciplines;`
  line
  line `(b) to develop courses leading to graduate and post-graduate degrees, doctoral and post-doctoral`
  line `distinctions and research in all areas or disciplines relating to design;`
  line
  line `(c) to hold examinations and grant degrees, and diplomas and other academic distinctions or titles`
  line `in the areas or disciplines relating to design;`
  line
  line `(d) to confer honorary degrees, awards or other distinctions in the areas or disciplines relating to`
  line design;
  line
  line `(e) to institute and award fellowships, scholarships, exhibitions, prizes and medals;`
  line
  line `(f) to fix, demand and receive fees and other charges;`
  line
  line `(g) to establish, maintain and manage halls and hostels for the residence of the students;`
  line
  line `(h) to supervise and control the residence and regulate the discipline of students of the Institute`
  line `and to make arrangements for promoting their health, general welfare and cultural and corporate life;`
  line
  line `(i) to institute academic and other posts and to make appointments thereto (except in the case of`
  line `the Director);`
  line
  line `(j) to frame Statutes and Ordinances and to alter, modify or rescind the same;`
  line
  line `(k) to co-operate with educational or other institutions in any part of the world having objects`
  line `wholly or partly similar to those of the Institute by exchange of faculty members and scholars and`
  line `generally in such manner as may be conducive to their common objective;`
  line
  line `(l) to act as a nucleus for interaction between academia and industry by encouraging exchange of`
  line `designers and other technical staff between the Institute and the industry and by undertaking`
  line `sponsored and funded research as well as consultancy projects by the Institute;`
  line
  line `(m) to establish, equip and maintain workshops or laboratories or studios with modern machinery`
  line `and equipments in order to undertake scientific and technological research for creating good designs`
  line `for the production of goods and services and to provide funds for such works and for payment to any`
  line `person or persons engaged in service, training and research work whether in such workshop or`
  line `laboratory or studio;`
  line
  line `(n) to acquire any patent or licence relating to such invention, improvement or design or`
  line `standardisation marks whether for general or specific purposes;`
  line
  line `(o) to undertake consultancy in the areas or disciplines relating to design;`
  line
  line `(p) to deal with any property belonging to, or vested in, the Institute, in such manner as the`
  line `Institute may deem fit for advancing the objects of the Institute;`
  line
  line `(q) to receive gifts, grants, donations or benefactions from the Government and to receive`
  line `bequests, donations and transfers of movable or immovable properties from testators, donors or`
  line `transferors, as the case may be;`
  line
  line `(r) to encourage and improve education of persons who are engaged or are likely to be engaged in`
  line `the service, training or research activities by grant of loans, scholarships or other monetary assistance`
  line `or otherwise;`
  line
  line `(s) to prepare, print, publish, issue, acquire and circulate books, papers, periodicals, exhibits,`
  line `films, slides, gadgets, circulars and other literary undertakings, dealing with or having a bearing upon`
  line `the subject of industrial design and allied fields;`
  line
  line `(t) to establish, form and maintain museums, libraries and collections of literature and films,`
  line `slides, photographs, prototypes and other information relating to design and allied subjects;`
  line
  line `(u) to nominate designers, engineers (mechanical or electrical or civil), architects, craftsmen,`
  line `technicians or investigators to study in India or outside India in regard to the service, training and`
  line `research in such fields as the Institute may think fit;`
  line
  line `(v) to retain or employ skilled professional, technical advisers, consultants, workers or craftsmen`
  line `in connection with the objects of the Institute;`
  line
  line `(w) to encourage artisans, technicians and others with inventive skill to work out details and`
  line `specifications of processes, appliances and gadgets by giving awards, financial or technical`
  line assistance;
  line
  line `(x) to construct buildings and alter, extend, improve, repair, enlarge or modify and to provide and`
  line `equip the same with light, water, drainage, furniture, fittings and all other accessories;`
  line
  line `(y) ) to borrow and raise moneys, with or without security or on the security of a mortgage,`
  line `charge, or hypothecation or pledge of any of the movable or immovable properties belonging to the`
  line `Institute or in any other manner;`
  line
  line `(z) to do all such things as may be necessary, incidental or conducive to the attainment of all or`
  line `any of the objects of the Institute.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Institute shall not dispose of in any`
  line `manner any immovable property without the prior approval of the Visitor.`
obj_root_law_sections_7:
  sectionId (2797)
  sectionNo (7)
  orderNo 7
  title `Institute be open to all races, creeds and classes.`
  content obj_root_law_sections_7_content
  footnotes `1. Subs. by Act 38 of 2019, s. 9, for "The Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2797&sectionno=7&orderno=7&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_7_content:
  string
  line `(1) The ^1[Every Institute] shall be open to persons of`
  line `either sex and of whatever race, creed, caste or class, and no test or condition shall be imposed as to`
  line `religious belief or profession in admitting or appointing members, students, teachers or workers or in any`
  line `other connection whatsoever.`
  line
  line `(2) No bequest, donation or transfer of any property shall be accepted by the Institute, which in the`
  line `opinion of the Governing Council involves conditions or obligations opposed to the spirit and objects of`
  line `the Institute.`
obj_root_law_sections_8:
  sectionId (2798)
  sectionNo (8)
  orderNo 8
  title `Teaching at Institute.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 38 of 2019, s. 10, for "teaching at the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2798&sectionno=8&orderno=8&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_8_content:
  string
  line `All ^1[teaching at each of the Institutes] and the Institute campuses shall be conducted`
  line `by or in the name of the Institute in accordance with the Statutes and the Ordinances made in this behalf.`
obj_root_law_sections_9:
  sectionId (2799)
  sectionNo (9)
  orderNo 9
  title Visitor.
  content obj_root_law_sections_9_content
  footnotes `1. Subs. by s. 11, ibid., for "the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2799&sectionno=9&orderno=9&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_9_content:
  string
  line `(1) The President of India shall be the Visitor of ^1[each of the Institutes].`
  line
  line `(2) The Visitor may appoint one or more persons to review the work and progress of the Institute or`
  line `any Institute campus and to hold inquiries into the affairs thereof and to report thereon in such manner as`
  line `the Visitor may direct.`
  line
  line `(3) Upon receipt of any such report, the Visitor may take such action and issue such directions as he`
  line `considers necessary in respect of any of the matters dealt with in the report and the Institute shall be`
  line `bound to comply with such directions.`
obj_root_law_sections_10:
  sectionId (2800)
  sectionNo (10)
  orderNo 10
  title `Authorities of Institute.`
  content obj_root_law_sections_10_content
  footnotes `1. Subs. by s. 12, ibid., for "The following shall be the authorities of the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2800&sectionno=10&orderno=10&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_10_content:
  string
  line `^1[Each Institute shall have the following authorities] namely:--`
  line
  line `(a) the Governing Council,`
  line
  line `(b) a Senate, and`
  line
  line `(c) such other authorities as may be declared by the Statutes to be the authorities of the Institute.`
obj_root_law_sections_11:
  sectionId (2801)
  sectionNo (11)
  orderNo 11
  title `Governing Council.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by s. 13, ibid., for "The Governing Council shall consist of" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2801&sectionno=11&orderno=11&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_11_content:
  string
  line `^1[The Governing Council of every Institute shall consist of] the following members, namely:--`
  line
  line `(a) a Chairperson, who shall be an eminent academician, scientist or technologist or professional`
  line `or industrialist, to be nominated by the Visitor;`
  line
  line `(b) the Director, ex officio;`
  line
  line `(c) the Financial Adviser in the Ministry or Department of the Government of India dealing with`
  line `the National Institute of Design, ex officio;`
  line
  line `(d) the Joint Secretary, in the Ministry or Department in the Government of India dealing with the`
  line `National Institute of Design, ex officio;`
  line
  line `(e) one representative of the Ministry or Department of the Government of India not below the`
  line `rank of Joint Secretary dealing with Higher Education, to be nominated by the Secretary of that`
  line `Ministry or Department, ex officio;`
  line
  line `(f) one representative of the Ministry or Department of the Government of India not below the`
  line `rank of Joint Secretary dealing with Information Technology to be nominated by the Secretary of that`
  line `Ministry or Department, ex officio;`
  line
  line `(g) one representative from the State in which the Institute campus is located, to be nominated by`
  line `that State Government;`
  line
  line `(h) five professionals, one each from the fields of architecture, engineering, fine arts, mass media`
  line `and technology, to be nominated by the Central Government;`
  line
  line `(i) an outstanding Designer, to be nominated by the Visitor in consultation with the Central`
  line Government;
  line
  line `(j) a management expert, to be nominated by the Chairperson;`
  line
  line `(k) a representative of the Micro, Small and Medium Enterprises, to be nominated by the Central`
  line Government;
  line
  line `(l) three persons to be nominated by the Senate from amongst persons recommended by`
  line `companies, firms or individuals who have provided financial assistance or contribution to the`
  line `Institute:`
  line
  line `Provided that the threshold of financial assistance or contribution and other requirements to`
  line `qualify for such nomination shall be such as may be provided for in the Statutes; and`
  line
  line `(m) Dean of each Institute campus, ex officio.`
obj_root_law_sections_12:
  sectionId (2802)
  sectionNo (12)
  orderNo 12
  title `Term of office of, vacancies among, and allowances payable to Chairperson and other members of Governing Council.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2802&sectionno=12&orderno=12&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_12_content:
  string
  line `(1) The term of office of the Chairperson or any other member of the`
  line `Governing Council (other than an ex officio member) shall be three years from the date of his nomination.`
  line
  line `(2) Save as otherwise provided in this section, the term of office of an ex officio member shall`
  line `continue so long as he holds the office by virtue of which he is a member.`
  line
  line `(3) The term of office of a member of the Governing Council nominated to fill a casual vacancy shall`
  line `continue for the remainder of the term of the member in whose place he has been nominated.`
  line
  line `(4) Notwithstanding anything contained in this section, an outgoing member shall, unless the`
  line `Governing Council otherwise directs, continue in office until another person is nominated as a member in`
  line `his place.`
  line
  line `(5) The members of the Governing Council shall be entitled to such allowances, if any, from the`
  line `Institute as may be provided for in the Statutes but no member other than the persons referred to in`
  line `clauses (b) and (m) of section 11 shall be entitled to any salary by reason of this sub-section.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (2803)
  sectionNo (13)
  orderNo 13
  title `Meeting of Governing Council.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2803&sectionno=13&orderno=13&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_13_content:
  string
  line `The Governing Council shall meet at least four times in a year`
  line `at such place and time and observe such rules of procedure in regard to the transaction of business at its`
  line `meetings, as may be determined by the Governing Council.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (2804)
  sectionNo (14)
  orderNo 14
  title `Powers and functions of Governing Council.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2804&sectionno=14&orderno=14&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_14_content:
  string
  line `(1) Subject to the provisions of this Act, the`
  line `Governing Council shall be responsible for the general superintendence, direction and control of the`
  line `affairs of the Institute and shall exercise all the powers of the Institute not otherwise provided for by this`
  line `Act, the Statutes and the Ordinances, and shall have the power to review the acts of the Senate.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Governing Council shall––`
  line
  line `(a) take decisions on questions of policy relating to the administration and working of the`
  line Institute;
  line
  line `(b) take decision on the establishment of new Institute campus at any place in India or outside`
  line India;
  line
  line `(c) institute courses of study at the Institute;`
  line
  line `(d) institute academic and other posts and to make appointments thereto;`
  line
  line `(e) make Statutes;`
  line
  line `(f) consider and modify or cancel Ordinances;`
  line
  line `(g) consider and pass resolutions on the annual report, the annual accounts and the budget`
  line `estimates of the Institute including each of the Institute campuses for the next financial year, as it`
  line `thinks fit and submit them to the Central Government together with a statement of its development`
  line `plans; and`
  line
  line `(h) exercise such other powers and perform such other duties as may be conferred or imposed`
  line `upon it by this Act or the Statutes.`
  line
  line `(3) The Governing Council shall have power to appoint such committees as it considers necessary for`
  line `the exercise of its powers and the performance of its duties under this Act.`
  line
  line `(4) The Governing Council shall have the power to enter into arrangements with the Central`
  line `Government, State Governments and other public or private organisations or individuals in India or`
  line `outside India for securing and accepting endowments, grants, donations or gifts to the Institute on`
  line `mutually agreed terms and conditions:`
  line
  line `Provided that the conditions of such grant, donation or gift, if any, shall not be inconsistent or in`
  line `conflict with the nature or objects of the Institute and the provisions of this Act.`
  line
  line `(5) The Governing Council shall have the power to take over and acquire by purchase, gift or`
  line `otherwise from Government and other public bodies or private individuals willing to transfer movable and`
  line `immovable properties, endowments or other funds together with any attendant obligations and`
  line `engagements not inconsistent with the provisions of this Act.`
  line
  line `(6) The Governing Council may by specific resolution to this effect delegate to the Chairperson such`
  line `of its powers for the conduct of business, as it may deem necessary.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (2805)
  sectionNo (15)
  orderNo 15
  title Senate.
  content obj_root_law_sections_15_content
  footnotes `1. Subs. by Act 38 of 2019, s. 14, for "The Senate of the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2805&sectionno=15&orderno=15&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_15_content:
  string
  line `^1[The Senate of each Institute] shall consist of the following persons, namely:--`
  line
  line `(a) the Director, ex officio, who shall be the Chairman of the Senate;`
  line
  line `(b) Dean of each Institute campus, ex officio;`
  line
  line `(c) Senior Professors of the Institute and of the Institute campuses;`
  line
  line `(d) three persons, not being employees of the Institute, to be nominated by the Chairperson in`
  line `consultation with the Director, from amongst educationists of repute, one each from the fields of`
  line `science, engineering and humanities and at least one of them shall be a woman;`
  line
  line `(e) one alumnus of the Institute to be nominated by the Chairperson in consultation with the`
  line `Director; and`
  line
  line `(f) such other members of the staff as may be laid down in the Statutes.`
obj_root_law_sections_16:
  sectionId (2806)
  sectionNo (16)
  orderNo 16
  title `Functions of Senate.`
  content obj_root_law_sections_16_content
  footnotes `1. Subs. by s. 15, ibid., for "the Senate of the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2806&sectionno=16&orderno=16&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_16_content:
  string
  line `Subject to the provisions of this Act, the Statutes and the Ordinances, ^1[the`
  line `Senate an Institute] shall have the control and general regulation, and be responsible for the`
  line `maintenance of standards of instruction, education and examination in the Institute and shall exercise such`
  line `other powers and perform such other duties as may be conferred or imposed upon it by the Statutes.`
obj_root_law_sections_17:
  sectionId (2807)
  sectionNo (17)
  orderNo 17
  title `Functions, powers and duties of Chairperson.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2807&sectionno=17&orderno=17&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_17_content:
  string
  line `(1) The Chairperson shall ordinarily preside at`
  line `the meetings of the Governing Council and at the convocations of the Institute.`
  line
  line `(2) It shall be the duty of the Chairperson to ensure that the decisions taken by the Governing Council`
  line `are implemented.`
  line
  line `(3) The Chairperson shall exercise such other powers and perform such other duties as may be`
  line `assigned to him by this Act or the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (2808)
  sectionNo (18)
  orderNo 18
  title Director.
  content obj_root_law_sections_18_content
  footnotes `1. Subs. by s. 16, ibid., for "the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2808&sectionno=18&orderno=18&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_18_content:
  string
  line `(1) The Director of ^1[each of the Institutes] shall be appointed by the Central Government for a`
  line `tenure of five years in such manner and on such terms and conditions of service as may be prescribed.`
  line
  line `(2) The Director shall be appointed on the recommendations of the Selection Committee constituted`
  line `by the Central Government.`
  line
  line `(3) The Director shall be the principal executive officer of the Institute and shall be responsible for--`
  line
  line `(a) proper administration of the Institute and for imparting of instructions and maintenance of`
  line `discipline therein;`
  line
  line `(b) co-ordination of activities of all the Institute campuses;`
  line
  line `(c) examining the development plans of the Institute and each Institute campus and to approve`
  line `such of them as are considered necessary and also to indicate broadly the financial implications of`
  line `such approved plans; and`
  line
  line `(d) examining the annual budget estimates of the Institute and each Institute campus and to`
  line `recommend to the Central Government the allocation of funds for that purpose.`
  line
  line `(4) The Director shall exercise such other powers and perform such other duties as may be assigned to`
  line `him by this Act, Statutes and Ordinances.`
  line
  line `(5) The Director shall submit annual reports and accounts to the Governing Council.`
  line
  line `(6) The Central Government shall have the power to remove the Director before expiry of his tenure,`
  line `if it considers it appropriate to do so.`
obj_root_law_sections_19:
  sectionId (2809)
  sectionNo (19)
  orderNo 19
  title Dean.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2809&sectionno=19&orderno=19&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_19_content:
  string
  line `(1) The Dean of each Institute campus shall be appointed on such terms and conditions as`
  line `may be laid down by the Statutes and shall exercise such powers and perform such duties as may be`
  line `assigned to him by this Act or the Statutes or by the Director.`
  line
  line `(2) Without prejudice to the provisions of sub- section (1), the Dean of each Institute campus shall`
  line `look after all academic, administrative, research and other activities of the Institute campus in`
  line `consultation with the Director.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (2810)
  sectionNo (20)
  orderNo 20
  title Registrar.
  content obj_root_law_sections_20_content
  footnotes `1. Subs. by Act 38 of 2019, s. 17, for "Registrar of the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2810&sectionno=20&orderno=20&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_20_content:
  string
  line `(1) The ^1[Registrar of each Institute] shall be appointed on such terms and conditions as`
  line `may be laid down by the Statutes and shall be the custodian of records, the common seal, the funds of the`
  line `Institute and such other property of the Institute as the Governing Council shall commit to his charge.`
  line
  line `(2) The Registrar shall act as the Secretary of the Governing Council, the Senate and such committees`
  line `as may be prescribed by the Statutes.`
  line
  line `(3) The Registrar shall be responsible to the Director for the proper discharge of his functions.`
  line
  line `(4) The Registrar shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by this Act or the Statutes or by the Director.`
obj_root_law_sections_21:
  sectionId (2811)
  sectionNo (21)
  orderNo 21
  title `Powers and duties of other authorities and officers.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2811&sectionno=21&orderno=21&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_21_content:
  string
  line `The powers and duties of authorities and`
  line `officers, other than those hereinbefore mentioned, shall be determined by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (2812)
  sectionNo (22)
  orderNo 22
  title `Grants by Central Government.`
  content obj_root_law_sections_22_content
  footnotes `1. Subs. by s. 18, ibid., for "enabling the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2812&sectionno=22&orderno=22&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_22_content:
  string
  line `For the purpose of ^1[enabling an Institute] to discharge its`
  line `functions efficiently under this Act, the Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the Institute in each financial year such sums of money and in`
  line `such manner as it may think fit.`
obj_root_law_sections_23:
  sectionId (2813)
  sectionNo (23)
  orderNo 23
  title `Fund of Institute.`
  content obj_root_law_sections_23_content
  footnotes `1. Subs. by s. 19, ibid., for "The Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2813&sectionno=23&orderno=23&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_23_content:
  string
  line `(1) ^1[Every Institute] shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government;`
  line
  line `(b) all fees and other charges received by the Institute;`
  line
  line `(c) all moneys received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all moneys received by the Institute in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund shall be deposited in such banks or invested in such manner as`
  line `the Institute may, with the approval of the Central Government, decide.`
  line
  line `(3) The Fund shall be applied towards meeting the expenses of the Institute including expenses`
  line `incurred in the exercise of its powers and discharge of its duties under this Act.`
obj_root_law_sections_24:
  sectionId (2814)
  sectionNo (24)
  orderNo 24
  title `Setting up of Endowment Fund.`
  content obj_root_law_sections_24_content
  footnotes `1. Subs. by s. 20, ibid., for "the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2814&sectionno=24&orderno=24&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_24_content:
  string
  line `Notwithstanding anything contained in section 23, the`
  line `Central Government may direct ^1[any Institute] to--`
  line
  line `(a) set up an Endowment Fund and any other Fund for specified purpose; and`
  line
  line `(b) transfer money from its Fund to Endowment Fund or any other Fund.`
obj_root_law_sections_25:
  sectionId (2815)
  sectionNo (25)
  orderNo 25
  title `Accounts and audit.`
  content obj_root_law_sections_25_content
  footnotes `1. Subs. by s. 21, ibid., for "The Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2815&sectionno=25&orderno=25&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_25_content:
  string
  line `(1) ^1[Every Institute] shall maintain proper accounts and other relevant records`
  line `and prepare an annual statement of accounts, including the balance sheet, in such form as may be`
  line `prescribed, in accordance with such general directions as may be issued by the Central Government in`
  line `consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Institute shall be audited by the Comptroller and Auditor-General of India and`
  line `any expenditure incurred by him in connection with such audit shall be payable by the Institute to the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Institute shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India, generally has in connection`
  line `with the audit of the Government accounts, and, in particular, shall have the right to demand the`
  line `production of books, accounts, connected vouchers and other documents and papers and to inspect any of`
  line `the offices of the Institute.`
  line
  line `(4) The accounts of the Institute as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf, together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_26:
  sectionId (2816)
  sectionNo (26)
  orderNo 26
  title `Pension and provident fund.`
  content obj_root_law_sections_26_content
  footnotes `1. Subs. by Act 38 of 2019, s. 22, for "The Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2816&sectionno=26&orderno=26&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_26_content:
  string
  line `(1) ^1[Every Institute] shall constitute, for the benefit of its employees,`
  line `including the Director, such pension, insurance and provident funds as it may deem fit, in such manner`
  line `and subject to such conditions as may be laid down in the Statutes.`
  line
  line `(2) Where any provident fund has been constituted under sub-section (1), the Central Government`
  line `may declare that the provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to such fund as`
  line `if it were a Government provident fund.`
obj_root_law_sections_27:
  sectionId (2817)
  sectionNo (27)
  orderNo 27
  title `Appointment of staff.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2817&sectionno=27&orderno=27&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_27_content:
  string
  line `All appointments of the staff of ^1[an Institute], except that of the Director,`
  line `shall be made in accordance with the procedure laid down in the Statutes by--`
  line
  line `(a) the Governing Council, if the appointment is made on the academic staff in the post of ^2[Principal Designer] or Professor or above or if the appointment is made on the non-academic staff in any cadre,`
  line `the maximum of the pay-scale for which is the same or higher than that of ^2[Principal Designer] or`
  line `Professor; and`
  line
  line `(b) the Director, in any other case.`
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by s. 23, ibid., for "the Institute" (w.e.f. 13-1-2020).`
  line `2. Subs. by s. 23, ibid., for "Senior Designer" (w.e.f. 13-1-2020).`
obj_root_law_sections_28:
  sectionId (2818)
  sectionNo (28)
  orderNo 28
  title Statutes.
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2818&sectionno=28&orderno=28&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_28_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:––`
  line
  line `(a) conferment of honorary degrees;`
  line
  line `(b) formation of departments of teaching, establishment of workshops, laboratories and studios;`
  line
  line `(c) fees to be charged for courses of study in the Institute including Institute campus and for`
  line `admission to the examinations of degrees, diplomas and certificates of the Institute;`
  line
  line `(d) institution of fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(e) qualifications of teachers of the Institute;`
  line
  line `(f) classification, method of appointment and the determination of the terms and conditions of`
  line `service of officers, teachers and other staff of the Institute;`
  line
  line `(g) reservation of posts for the Scheduled Castes, the Scheduled Tribes and Other Backward`
  line `Classes of persons as may be determined by the Central Government;`
  line
  line `(h) constitution of pension, insurance and provident funds for the benefit of the officers, teachers`
  line `and other staff of the Institute;`
  line
  line `(i) constitution, powers and duties of the authorities of the Institute and Institute campuses;`
  line
  line `(j) establishment and maintenance of halls and hostels;`
  line
  line `(k) conditions of residence of students of the Institute and the levying of the fees for residence in`
  line `the halls and hostels and other charges;`
  line
  line `(l) manner of filling up of vacancies among members of the Governing Council;`
  line
  line `(m) allowances to be paid to the Chairperson and members of the Governing Council;`
  line
  line `(n) authentication of the orders and decisions of the Governing Council;`
  line
  line `(o) meetings of the Governing Council, Senate, or any Committee, the quorum at such meetings`
  line `and the procedure to be followed in the conduct of their business;`
  line
  line `(p) any other matter which by this Act is to be or may be prescribed by the Statutes.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (2819)
  sectionNo (29)
  orderNo 29
  title `Statutes how to be made.`
  content obj_root_law_sections_29_content
  footnotes `1. Subs. by Act 38 of 2019, s. 24, for "the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2819&sectionno=29&orderno=29&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_29_content:
  string
  line `(1) The first Statutes of ^1[each Institute] shall be framed by the`
  line `Governing Council with the previous approval of the Visitor and a copy of the same shall be laid as soon`
  line `as may be before each House of Parliament.`
  line
  line `(2) The Governing Council may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes in the manner hereinafter in this section provided.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require`
  line `the previous approval of the Visitor who may assent thereto or withhold assent therefrom or remit it to the`
  line `Governing Council for reconsideration.`
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
obj_root_law_sections_30:
  sectionId (2820)
  sectionNo (30)
  orderNo 30
  title Ordinances.
  content obj_root_law_sections_30_content
  footnotes `1. Subs. by s. 25, ibid., for "Ordinances of the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2820&sectionno=30&orderno=30&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_30_content:
  string
  line `Subject to the provisions of this Act and the Statutes, the ^1[Ordinances of each`
  line `Institute] may provide for all or any of the following matters, namely:--`
  line
  line `(a) admission of the students to the Institute including Institute campus;`
  line
  line `(b) reservation in admission to various courses or programmes of the Institute for the Scheduled`
  line `Castes, the Scheduled Tribes and Other Backward Classes;`
  line
  line `(c) courses of study to be laid down for all degrees, diplomas and certificates of the Institute;`
  line
  line `(d) conditions under which students shall be admitted to the degree, diploma and certificate`
  line `courses and to the examinations of the Institute and award of degrees, diplomas and certificates;`
  line
  line `(e) conditions for award of fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(f) conditions and mode of appointment and duties of examining body, examiners and`
  line moderators;
  line
  line `(g) conduct of examinations;`
  line
  line `(h) maintenance of discipline among the students of the Institute; and`
  line
  line `(i) any other matter which by this Act or the Statutes is to be or may be provided for by the`
  line Ordinances.
obj_root_law_sections_31:
  sectionId (2821)
  sectionNo (31)
  orderNo 31
  title `Ordinances how to be made.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2821&sectionno=31&orderno=31&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_31_content:
  string
  line `(1) Save as otherwise provided in this section, Ordinances shall`
  line `be made by the Senate.`
  line
  line `(2) All Ordinances made by the Senate shall have effect from such date as it may direct, but every`
  line `Ordinance so made shall be submitted, as soon as may be, to the Governing Council and shall be`
  line `considered by the Governing Council at its next meeting.`
  line
  line `(3) The Governing Council shall have power by resolution to modify or cancel any such Ordinance`
  line `and such Ordinance shall from the date of such resolution stand modified accordingly or cancelled, as the`
  line `case may be.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (2822)
  sectionNo (32)
  orderNo 32
  title `Arbitral Tribunal.`
  content obj_root_law_sections_32_content
  footnotes `1. Subs. by s. 26, ibid., for "between the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2822&sectionno=32&orderno=32&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_32_content:
  string
  line `(1) Any dispute arising out of a contract ^1[between an Institute] and any of its`
  line `employees shall, at the request of the employee concerned or at the instance of the Institute, be referred to`
  line `an Arbitral Tribunal consisting of one member appointed by the Institute, one member nominated by the`
  line `employee and an umpire appointed by the Visitor.`
  line
  line `(2) The decision of the Arbitral Tribunal shall be final and shall not be questioned in any court.`
  line
  line `(3) No suit or proceeding shall lie in any court in respect of any matter which is required by subsection`
  line `(1) to be referred to the Arbitral Tribunal.`
  line
  line `(4) The Arbitral Tribunal shall have power to regulate its own procedure.`
  line
  line `(5) Nothing in any law for the time being in force relating to arbitration shall apply to arbitration`
  line `under this section.`
obj_root_law_sections_33:
  sectionId (2823)
  sectionNo (33)
  orderNo 33
  title `Acts and proceedings not to be invalidated by vacancies, etc.`
  content obj_root_law_sections_33_content
  footnotes `1. Subs. by Act 38 of 2019, s. 27, for "the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2823&sectionno=33&orderno=33&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_33_content:
  string
  line `No act of ^1[any Institute] or`
  line `Governing Council or Senate or any other authority, set up under this Act or the Statutes, shall be invalid`
  line `merely by reason of--`
  line
  line `(a) any vacancy in, or defect in the constitution thereof; or`
  line
  line `(b) any defect in the election, nomination or appointment of a person acting as a member thereof;`
  line or
  line
  line `(c) any irregularity in its procedure not affecting the merits of the case.`
obj_root_law_sections_34:
  sectionId (2824)
  sectionNo (34)
  orderNo 34
  title `Sponsored schemes.`
  content obj_root_law_sections_34_content
  footnotes `1. Subs. by s. 28, ibid., for "the Institute receives" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2824&sectionno=34&orderno=34&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_34_content:
  string
  line `Notwithstanding anything contained in this Act, whenever ^1[an Institute`
  line `receives] funds from any Government, the University Grants Commission or any other agency including`
  line `industry sponsoring a research scheme or a consultancy assignment or a teaching programme or a Chaired`
  line `Professorship or a scholarship, etc., to be executed or endowed at the Institute,--`
  line
  line `(a) the amount received shall be kept by the Institute separately from the Fund of the Institute and`
  line `utilised only for that purpose; and`
  line
  line `(b) the staff required to execute the same shall be recruited in accordance with the terms and`
  line `conditions stipulated by the sponsoring organisations:`
  line
  line `Provided that any money remaining unutilised shall be transferred to the Endowment Fund set up`
  line `under section 24 of this Act.`
obj_root_law_sections_35:
  sectionId (2825)
  sectionNo (35)
  orderNo 35
  title `Power of Institute to grant degrees, etc.`
  content obj_root_law_sections_35_content
  footnotes `1. Subs. by s. 29, ibid., for "The Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2825&sectionno=35&orderno=35&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_35_content:
  string
  line `^1[Every Institute] shall have the power to grant degrees,`
  line `diplomas, certificates and other academic distinctions under this Act, which shall be equivalent to such`
  line `corresponding degrees, diplomas, certificates and other academic distinctions granted by any University`
  line `or Institute established or incorporated under any other law for the time being in force.`
obj_root_law_sections_36:
  sectionId (2826)
  sectionNo (36)
  orderNo 36
  title `Powers of Central Government to issue directions.`
  content obj_root_law_sections_36_content
  footnotes `1.Subs. by s. 30, ibid., for "to the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2826&sectionno=36&orderno=36&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_36_content:
  string
  line `The Central Government may give such`
  line `directions as it may deem necessary ^1[to any Institute] for effective administration of this Act and the`
  line `Institute shall comply with such directions.`
obj_root_law_sections_37:
  sectionId (2827)
  sectionNo (37)
  orderNo 37
  title `Institute to be public authority under Right to Information Act, 2005.`
  content obj_root_law_sections_37_content
  footnotes `1. Subs. by s. 31, ibid., for "the Institute" (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2827&sectionno=37&orderno=37&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_37_content:
  string
  line `The provisions of the`
  line `Right to Information Act, 2005 (22 of 2005) shall apply to ^1[every Institute], as if it were a public authority as`
  line `defined in clause (h) of section 2 of the Right to Information Act, 2005.`
obj_root_law_sections_38:
  sectionId (2828)
  sectionNo (38)
  orderNo 38
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2828&sectionno=38&orderno=38&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_38_content:
  string
  line `(1) The Central Government may, by`
  line `notification, make rules to carry out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:––`
  line
  line `(a) the manner of appointment of the Director and terms and conditions of his service under subsection`
  line `(1) of section 18;`
  line
  line `(b) the form and the manner in which the books of account of the Institute shall be maintained`
  line `under sub-section (1) of section 25;`
  line
  line `(c) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made by the Central Government shall be laid, as soon as may be after it is made,`
  line `before each House of Parliament, while it is in session, for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the session,`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (2829)
  sectionNo (39)
  orderNo 39
  title `Transitional provisions.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2829&sectionno=39&orderno=39&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_39_content:
  string
  line `Notwithstanding anything contained in this Act--`
  line
  line `(a) the ^1[Governing Council of an Institute] functioning as such, immediately before the`
  line `commencement of this Act, shall continue to so function until a new Governing Council is constituted`
  line `for the Institute under this Act, but on the constitution of a new Governing Council under this Act, the`
  line `members of the Governing Council holding office before such constitution shall cease to hold office;`
  line
  line `(b) the Policy and Planning Committee of the Society, functioning as such before the`
  line `commencement of this Act, shall be deemed to be the Senate constituted under this Act and continue`
  line `to so function until a new Senate is constituted for the Institute under this Act;`
  line
  line `(c) until the first Statutes and Ordinances are made under this Act, the rules and regulations,`
  line `instructions, guidelines and bye-laws of the Society, in force immediately before the commencement`
  line `of this Act, shall continue to apply to the Institute and Institute campuses ^2***, in so far as they are not inconsistent with the provisions of this Act.`
  line
  line `^3[ExplanationI.The reference in this section to the commencement of this Act shall, in relation to`
  line `the National Institute of Design, Ahmedabad, be deemed to be the 16th day of September, 2014.`
  line
  line `Explanation II.The reference in this section to the commencement of this Act shall, in relation to`
  line `the National Institutes of Design in the States of Madhya Pradesh, Assam, Haryana and Andhra Pradesh,`
  line `be construed as the reference to the date on which the provisions of the National Institute of Design`
  line `(Amendment) Act, 2019 comes into force.]`
obj_root_law_sections_39_footnotes:
  string
  line `1. Subs. by Act 38 of 2019, s. 32, for "Governing Council of the Institute" (w.e.f. 13-1-2020).`
  line `2. The words "located at Bengaluru or Gandhinagar, as the case may be" omitted by s. 32, ibid. (w.e.f. 13-1-2020).`
  line `3. Ins. by Act 38 of 2019, s. 33 (w.e.f. 13-1-2020).`
obj_root_law_sections_40:
  sectionId (2830)
  sectionNo (40)
  orderNo 40
  title `Statutes and Ordinances to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_40_content
  footnotes `1. Ins. by Act 38 of 2019, s. 33 (w.e.f. 13-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2830&sectionno=40&orderno=40&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_40_content:
  string
  line `(1) Every Statute or Ordinance made under this Act shall be published in the Official`
  line Gazette.
  line
  line `(2) Every Statute or Ordinance made under this Act shall be laid, as soon as may be after it is made,`
  line `before each House of Parliament, while it is in session, for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the Statute or Ordinance or both Houses agree that the Statute or Ordinance should not be`
  line `made, the Statute or Ordinance shall thereafter have effect only in such modified form or be of no effect,`
  line `as the case may be; so, however, that any such modification or annulment shall be without prejudice to`
  line `the validity of anything previously done under that Statute or Ordinance.`
  line
  line `(3) The power to make Statutes or Ordinances shall include the power to give retrospective effect`
  line `from a date not earlier than the date of commencement of this Act to Statutes or Ordinances or any of them but no retrospective effect shall be given to any Statute or Ordinance so as to prejudicially affect the`
  line `interests of any person to whom such Statutes or Ordinances may be applicable.`
  line
  line `^1[Explanation I.--The reference in this section to the commencement of this Act shall, in relation to`
  line `the National Institute of Design, Ahmedabad, be deemed to be the 16th day of September, 2014.`
  line
  line `Explanation II.--The reference in this section to the commencement of this Act shall, in relation to`
  line `the National Institutes of Design in the States of Madhya Pradesh, Assam, Haryana and Andhra Pradesh,`
  line `be construed as the reference to the date on which the provisions of the National Institute of Design`
  line `(Amendment) Act, 2019 comes into force.]`
obj_root_law_sections_41:
  sectionId (2831)
  sectionNo (41)
  orderNo 41
  title `Power to remove difficulties.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00007_201418_1517807327924&sectionId=2831&sectionno=41&orderno=41&orgactid=AC_CEN_11_61_00007_201418_1517807327924
obj_root_law_sections_41_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `or give such directions not inconsistent with the purposes of this Act, as appears to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of two years from the appointed day.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_41_footnotes:
  string
  line
