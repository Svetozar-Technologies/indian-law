  (str title) (str `The National Institutes of Design Act, 2014`)
  (str actNumber) (str 18)
  (str enactmentDate) (str 2014-07-17)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2132`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `राष्ट्रीय डिजाइन संस्थान अधिनियम, 2014`)
  (str actYear) (str 2014)
  (str ministry) (str `Ministry of Commerce and Industry`)
  (str department) (str `Department of Promotion of Industry and Internal Trade`)
  (str longTitle) (str `An Act to declare the institution known as the National Institute of Design, hmedabad, to be an institution of national importance for the promotion of quality and excellence in education,research and training in all disciplines relating to Design and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 16-09-2014)
  (str notification) (str `16th September, 2014 vide notification No. S.O. 2393(E), dated 16th September, 2014, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-08T21:48:41.373Z`)
