obj_root_law:
  slug the-national-institutes-of-design-act-2014
  handle (2132)
  collectionHandle 123456789/1362
  title `The National Institutes of Design Act, 2014`
  actNumber (18)
  enactmentDate 2014-07-17
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2132`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्ट्रीय डिजाइन संस्थान अधिनियम, 2014`
  actYear (2014)
  ministry `Ministry of Commerce and Industry`
  department `Department of Promotion of Industry and Internal Trade`
  longTitle `An Act to declare the institution known as the National Institute of Design, hmedabad, to be an institution of national importance for the promotion of quality and excellence in education,research and training in all disciplines relating to Design and for matters connected therewith or incidental thereto.`
  enforcementDate 16-09-2014
  notification `16th September, 2014 vide notification No. S.O. 2393(E), dated 16th September, 2014, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T21:48:41.373Z`
