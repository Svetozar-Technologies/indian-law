  (str handle) (str 1749)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Union Duties of Excise (Distribution) Act, 1979`)
  (str actNumber) (str 24)
  (str enactmentDate) (str 1979-05-20)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1749`)
  (str sources) obj_root_law_sources
