obj_root_law_sections_1:
  sectionId (35548)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. Subs. by Act 31 of 1995, s. 2, for "second report dated the 18th day of December, 1989" (w.e.f. 1-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_197924_1528449325673&sectionId=35548&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00041_197924_1528449325673
obj_root_law_sections_1_content:
  string
  line `^1(1) This Act may be called the Union Duties of Excise`
  line `(Distribution) Act, 1979.`
  line
  line `(2) It shall be deemed to have come into force on the 1st day of April, 1979.`
obj_root_law_sections_2:
  sectionId (35549)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_197924_1528449325673&sectionId=35549&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00041_197924_1528449325673
obj_root_law_sections_2_content:
  string
  line `^1[2. Definition.-- In this Act, the expression "distributable Union duties of excise" means ^2[fortyseven and a half per cent.] of the net proceeds of Union duties of excise, levied and collected under the`
  line `Central Excises and Salt Act, 1944 (1 of 1944) and any other law for the levy and collection of such duty,`
  line `unless the law earmarks the proceeds of the duty for any special purpose.`
  line
  line `Explanation.-- The expression "net proceeds" has the same meaning as in clause (1) of article 279 of`
  line `the Constitution.]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 17 of 1989, s. 3, for sections 2 and 3 (w.e.f. 1-4-1989).`
  line
  line `2. Subs. by Act 31 of 1995, s. 3, for "forty-five per cent." (w.e.f. 1-4-1995).`
obj_root_law_sections_3:
  sectionId (35554)
  sectionNo (3)
  orderNo 3
  title `Payment to States of sums equivalent to a part of the net proceeds of Union duties of excise and distribution of sums among them.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by s. 4, ibid., for section 3 (w.e.f. 1-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_197924_1528449325673&sectionId=35554&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00041_197924_1528449325673
obj_root_law_sections_3_content:
  string
  line `^1[3.Payment to States of sums equivalent to a part of the net proceeds of Union duties of excise`
  line `and distribution of sums among them.-- During the financial year commencing on the 1stday of`
  line `April, 1995,and each of the four succeeding financial years, there shall be paid, out of the Consolidated`
  line `Fund of India, to the States, sums equivalent to the distributable Union duties of excise levied and`
  line `collected in that year and,--`
  line
  line `(a)sixteen-nineteenth of the sums so payable during each such financial year shall be distributed to`
  line `each of the States specified in column (1)of Table I below in such percentage as is set out against it in`
  line `column (2)thereof; and`
  line
  line `(b)three-nineteenth of the sums so payable during each such financial year shallbe distributed to each`
  line `of the States specified in column (1)of Table II below in such percentage as is set out against it in column`
  line `(2)thereof with respect to that financial year:--`
  line
  line TABLEI/bt
  line `State Percentage`
  line
