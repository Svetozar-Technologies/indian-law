  (str hindiTitle) (str `संघ उत्‍पाद-शुल्‍क (वितरण) अधिनियम, 1979`)
  (str actYear) (str 1979)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Revenue`)
  (str longTitle) (str `An Act to provide for the payment out of the Consolidated Fund of India of sums equivalent to a part of the net proceeds of certain Union duties of excise to the States to which the law imposing the duty extends and for the distribution of those sums among those States in accordance with the principles recommended by the Finance Commission in its report dated the 25th day of November, 1994.`)
  (str enforcementDate) (str 01-04-1979)
