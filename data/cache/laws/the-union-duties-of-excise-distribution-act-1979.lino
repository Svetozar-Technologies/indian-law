obj_root_law:
  slug the-union-duties-of-excise-distribution-act-1979
  handle (1749)
  collectionHandle 123456789/1362
  title `The Union Duties of Excise (Distribution) Act, 1979`
  actNumber (24)
  enactmentDate 1979-05-20
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1749`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `संघ उत्‍पाद-शुल्‍क (वितरण) अधिनियम, 1979`
  actYear (1979)
  ministry `Ministry of Finance`
  department `Department of Revenue`
  longTitle `An Act to provide for the payment out of the Consolidated Fund of India of sums equivalent to a part of the net proceeds of certain Union duties of excise to the States to which the law imposing the duty extends and for the distribution of those sums among those States in accordance with the principles recommended by the Finance Commission in its report dated the 25th day of November, 1994.`
  enforcementDate 01-04-1979
  fetchedAt `2026-05-08T23:22:25.502Z`
  translations obj_root_law_translations
