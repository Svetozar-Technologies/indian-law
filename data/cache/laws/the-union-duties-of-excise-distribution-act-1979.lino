  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_197924_1528449325673&sectionId=35554&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00041_197924_1528449325673)
obj_root_law_sections_4:
  object
  (str sectionId) (str 35551)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Payment to be charged on the Consolidated Fund of India.`)
  (str content) (str `The expenditure on the payments
in pursuance of section 3 shall be charged on the Consolidated Fund of India.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_197924_1528449325673&sectionId=35551&sectionno=4&orderno=4&orgactid=AC_CEN_2_2_00041_197924_1528449325673)
obj_root_law_sections_5:
  object
  (str sectionId) (str 35552)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Power to make rules.`)
  (str content) (str `(1) The Central Government may, by notification in the Official Gazette,
make rules providing for the time at which and the manner in which, any payments under this Act are to
be made, for the making of adjustments between one financial year andanother and for
any other incidental or ancillary matters.

(2) Every rule made under this section shall be laid, as soon as may be after it is made, before each
House of Parliament, while it is in session, for a total period of thirty days which may be comprised in
one session or in two or more successive sessions, and if, before the expiry of the session immediately
following the session or the successive sessions aforesaid, both Houses agree in making any modification
in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only
in such modified form or be of no effect, as the case may be; so, however, that any such modification of
annulment shall be without prejudice to the validity of anything previously done under that rule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_197924_1528449325673&sectionId=35552&sectionno=5&orderno=5&orgactid=AC_CEN_2_2_00041_197924_1528449325673)
obj_root_law_sections_6:
  object
  (str sectionId) (str 35553)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str Repeal.)
  (str content) (str `The Union Duties of Excise (Distribution) Act, 1962 (3 of 1962), shall, as from the
1st day of April, 1979 stand repealed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_197924_1528449325673&sectionId=35553&sectionno=6&orderno=6&orgactid=AC_CEN_2_2_00041_197924_1528449325673)
