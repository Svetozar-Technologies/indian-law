obj_root_law_sections_1:
  sectionId (34544)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Post Office Cash Certificates Act, 1917.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00002_191718_1523342769327&sectionId=34544&sectionno=1&orderno=1&orgactid=AC_CEN_37_95_00002_191718_1523342769327
