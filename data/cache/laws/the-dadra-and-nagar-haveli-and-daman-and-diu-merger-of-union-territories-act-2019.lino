obj_root_law_sections_1:
  sectionId (49750)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49750&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Dadra and Nagar Haveli and`
  line `Daman and Diu (Merger of Union territories) Act, 2019.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 26th January, 2020, vide notification No. S.O. 4542(E), dated 19th December, 2019, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (49751)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49751&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires, ---`
  line
  line `(a) "appointed day^1" means the day on which the Central Government may, by notification in the`
  line `Official Gazette, appoint;`
  line
  line `(b) "existing Union territories" means the Union territories of Dadra and Nagar Haveli and`
  line `Daman and Diu as existing immediately before the appointed day;`
  line
  line `(c) "law" includes any enactment, Ordinance, regulation, order, bye-law, rule, scheme,`
  line `notification or other instrument having a force of law in the whole or in any part of the existing Union`
  line `territories immediately before the appointed day.`
obj_root_law_sections_2_footnotes:
  string
  line `1. 26th January, 2020,vide notification No. S.O. 4543(E), dated 19th December, 2019, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_3:
  sectionId (49752)
  sectionNo (3)
  orderNo 3
  title `Formation of Union territory of Dadra and Nagar Haveli and Daman and Diu.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49752&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_3_content:
  string
  line `On and from`
  line `the appointed day, there shall be formed a new Union territory to be known as the Union territory of`
  line `Dadra and Nagar Haveli and Daman and Diu comprising the territory of the existing Union territories,`
  line `namely:---`
  line
  line `Dadra and Nagar Haveli and Daman and Diu,`
  line
  line `and thereupon the said territories shall have ceased to form part of the existing Union territories.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (49753)
  sectionNo (4)
  orderNo 4
  title `Amendment of article 240 of Constitution.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49753&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_4_content:
  string
  line `In article 240 of the Constitution, in clause (1),--`
  line
  line `(i) for entry (c), the following entry shall be substituted, namely:--`
  line
  line `“(c) Dadra and Nagar Haveli and Daman and Diu;”;`
  line
  line `(ii) entry (d) shall be omitted.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (49754)
  sectionNo (5)
  orderNo 5
  title `Amendment of First Schedule to Constitution.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49754&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_5_content:
  string
  line `On and from the appointed day, in the First`
  line `Schedule to the Constitution, under the heading II. THE UNION TERRITORIES, for entries 4 and 5`
  line `and the corresponding entries relating thereto, the following shall be substituted, namely:---`
  line
  line Name
  line Extent
  line
  line `"4. Dadra and Nagar`
  line `Haveli and Daman`
  line `and Diu`
  line `The territory which immediately before the eleventh day of`
  line `August, 1961 was comprised in Free Dadra and Nagar Haveli`
  line `and the territories specified in section 4 of the Goa, Daman`
  line `and Diu Reorganisation Act, 1987 (18 of 1987).".`
  line .
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (49755)
  sectionNo (6)
  orderNo 6
  title `Allocation of seats in House of People.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49755&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_6_content:
  string
  line `On and from the appointed day, there shall be allocated`
  line `two seats to the Union territory of Dadra and Nagar Haveli and Daman and Diu in the House of the`
  line `People and the First Schedule to the Representation of the People Act, 1950 (43 of 1950) shall be deemed`
  line `to be amended accordingly.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (49756)
  sectionNo (7)
  orderNo 7
  title `Provisions as to sitting members.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49756&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_7_content:
  string
  line `(1) Every sitting members of the House of the People`
  line `representing any Parliamentary constituency, which, on the appointed day, by virtue of the provisions of`
  line `section 5, stands allotted, with or without alteration of boundaries, be deemed to have been elected to that`
  line `House by that constituency.`
  line
  line `Explanation.--For the purposes of this sub-section “parliamentary constituency” shall have the same`
  line `meaning as assigned to it in the Representation of the People Act, 1950 (43 of 1950).`
  line
  line `(2) The term of office of such members shall remain unaltered.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (49757)
  sectionNo (8)
  orderNo 8
  title `Extension of jurisdiction of High Court of Bombay.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49757&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_8_content:
  string
  line `On and from the appointed day, the`
  line `jurisdiction of the High Court of Bombay shall continue to extend to the Union territory of Dadra and`
  line `Nagar Haveli and Daman and Diu.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (49758)
  sectionNo (9)
  orderNo 9
  title `Land and goods.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49758&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_9_content:
  string
  line `Subject to the other provisions of this Part, all land and all stores, articles and`
  line `other goods held immediately before the appointed day, by the existing Union territories, shall, on and`
  line `from that day, vest in the Union territory of Dadra and Nagar Haveli and Daman and Diu.`
  line
  line `Explanation.--For the purposes of this section, the expression “land” includes immovable property of`
  line `every kind and any rights in or over such property and the expression “goods” does not include coins,`
  line `bank notes and currency notes.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (49759)
  sectionNo (10)
  orderNo 10
  title `Cash balances.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49759&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_10_content:
  string
  line `The total of the cash balances in all treasuries, the Reserve Bank of India, the`
  line `State Bank of India and any nationalised bank, of the existing Union territories immediately before the`
  line `appointed day shall be merged in the Union territory of Dadra and Nagar Haveli and Daman and Diu.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (49760)
  sectionNo (11)
  orderNo 11
  title `Arrears of tax.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49760&sectionno=11&orderno=11&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_11_content:
  string
  line `(1) The right to recover arrears of any tax or duty (including arrears of land`
  line `revenue) on any property situated in the existing Union territories shall vest in the Union territory of`
  line `Dadra and Nagar Haveli and Daman and Diu.`
  line
  line `(2) The right to recover arrears of any tax or duty, other than a tax or duty specified in sub-section (1),`
  line `shall belong to the Union territory of Dadra and Nagar Haveli and Daman and Diu.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (49761)
  sectionNo (12)
  orderNo 12
  title `Right to recover loans and advances.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49761&sectionno=12&orderno=12&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_12_content:
  string
  line `The right to recover any loans or advances made by the`
  line `existing Union territories before the appointed day to any local body, society, agriculturist or other person`
  line `shall belong to the Union territory of Dadra and Nagar Haveli and Daman and Diu.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (49762)
  sectionNo (13)
  orderNo 13
  title `Assets and liabilities of Union territory undertakings.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49762&sectionno=13&orderno=13&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_13_content:
  string
  line `The assets and liabilities relating to`
  line `any commercial undertaking of the existing Union territories shall vest in the Union territory of Dadra`
  line `and Nagar Haveli and Daman and Diu.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (49763)
  sectionNo (14)
  orderNo 14
  title `Refund of taxes collected in excess.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49763&sectionno=14&orderno=14&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_14_content:
  string
  line `The liability of the Union territory to refund--`
  line
  line `(a) any tax or duty on property, including land revenue collected in excess shall go to the Union`
  line `territory of Dadra and Nagar Haveli and Daman and Diu;`
  line
  line `(b) any other tax or duty collected in excess shall go to the Union territory of Dadra and Nagar`
  line `Haveli and Daman and Diu.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (49764)
  sectionNo (15)
  orderNo 15
  title `Provisions relating to All India Services.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49764&sectionno=15&orderno=15&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_15_content:
  string
  line `The members of each of the All India Services borne`
  line `on the existing Union territories cadre immediately before the appointed day shall continue to be in the`
  line `cadre of the same service of the existing Union territory in which they stand allocated before the`
  line `appointed day.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (49765)
  sectionNo (16)
  orderNo 16
  title `Provisions relating to other services.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49765&sectionno=16&orderno=16&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_16_content:
  string
  line `(1) Every person employed in connection with the affairs`
  line `of the existing Union territories and serving immediately before the appointed day in the existing Union`
  line `territories shall, on and from that day, --`
  line
  line `(a) continue to serve in connection with the affairs of the Union territory of Dadra and Nagar`
  line `Haveli and Daman and Diu; and`
  line
  line `(b) be deemed to be provisionally allotted to serve in connection with the affairs of the Union`
  line `territory of Dadra and Nagar Haveli and Daman and Diu:`
  line
  line `Provided that nothing in clause (b) shall apply to a person to whom the provisions of section 15`
  line `apply or to a person on deputation from any State.`
  line
  line `(2) As soon as may be, after the appointed day, the Central Government shall by general or special`
  line `order, determine whether every person referred to in clause (b) of sub-section (1) shall be finally allotted`
  line `for service in the Union territory of Dadra and Nagar Haveli and Daman and Diu and the date with effect`
  line `from which such allotment shall take effect or be deemed to have taken effect.`
  line
  line `(3) As soon as may be after the Central Government passes orders finally allotting an employee in`
  line `terms of sub-section (2), the Union territory of Dadra and Nagar Haveli and Daman and Diu shall take`
  line `steps to integrate the employee into the services under its control in accordance with such special or`
  line `general orders or instructions as may be issued by the Central Government from time to time in this`
  line behalf.
  line
  line `(4) The Central Government may, by order establish one or more Advisory Committees for the`
  line `purpose of assisting it in regard to ensuring of fair and equitable treatment to all persons affected by the`
  line `provisions of this section and proper consideration of any representations made by such persons:`
  line
  line `Provided that notwithstanding anything to the contrary contained in any law for the time being in`
  line `force, no representation shall be against any order passed by the competent authority on matters arising`
  line `out of the division and integration of services under this Act, on the expiry of three months from the date`
  line `of publication or service of such order, whichever is earlier:`
  line
  line `Provided further that, notwithstanding anything contained in the preceding proviso, the Central`
  line `Government may suo motu or otherwise and for reasons to be recorded, reopen any matter and pass such order thereon, as may appear to it to be appropriate if it is satisfied that it is necessary so to do, in order to`
  line `prevent any miscarriage of justice to any affected employee.`
  line
  line `(5) Nothing in this section shall be deemed to affect, on or after the appointed day, the operation of`
  line `the provisions of Chapter I of Part XIV of the Constitution in relation to the determination of the`
  line `conditions of service of persons serving in connection with the affairs of the Union territory of Dadra and`
  line `Nagar Haveli and Daman and Diu:`
  line
  line `Provided that the conditions of service applicable immediately before the appointed day to the case of`
  line `any person referred to in sub-section (1) or sub-section (2) shall not be varied to his disadvantage except`
  line `with the previous approval of the Central Government.`
  line
  line `(6) All services prior to the appointed day rendered by a person allotted under sub-section (2) in`
  line `connection with the affairs of the existing Union territories shall, for the purposes of the rules regarding`
  line `his conditions of service, be deemed to have been rendered in connection with the affairs of the Union`
  line `territory of Dadra and Nagar Haveli and Daman and Diu.`
  line
  line `(7) The provisions of this section other than clause (a) of sub-section (1) shall not apply in relation to`
  line `any person to whom the provisions of section 15 apply.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (49766)
  sectionNo (17)
  orderNo 17
  title `Extension of laws.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49766&sectionno=17&orderno=17&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_17_content:
  string
  line `All laws which immediately before the appointed day extend to, or are in`
  line `force in, existing Union territories shall, on and from the appointed day, continue to be in force in those`
  line `areas in respect of which they were in force immediately before that day.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (49767)
  sectionNo (18)
  orderNo 18
  title `Power to construe laws.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49767&sectionno=18&orderno=18&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_18_content:
  string
  line `Any court, tribunal or authority required or empowered to enforce any`
  line `law extended to the Union territory of Dadra and Nagar Haveli and Daman and Diu by section 17 may,`
  line `for the purpose of facilitating its application in relation to the Union territory of Dadra and Nagar Haveli`
  line `and Daman and Diu, construe the law in such manner, without affecting the substance, as may be`
  line `necessary or proper in regard to the matter before the court, tribunal or authority.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (49768)
  sectionNo (19)
  orderNo 19
  title `Power to adapt laws.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49768&sectionno=19&orderno=19&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_19_content:
  string
  line `For the purpose of facilitating the application of any law in relation to the`
  line `Union territory of Dadra and Nagar Haveli and Daman and Diu, the Central Government may, before the`
  line `expiration of two years from the appointed day, by order, make such adaptations and modifications of the`
  line `law, whether by way of repeal or amendment, as may be necessary or expedient, and thereupon every`
  line `such law shall have effect subject to the adaptations and modifications so made until altered, repealed or`
  line `amended by a competent Legislature or other competent authority.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (49769)
  sectionNo (20)
  orderNo 20
  title `Legal proceedings.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49769&sectionno=20&orderno=20&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_20_content:
  string
  line `Where, immediately before the appointed day, the existing Union territories`
  line `is a party to any legal proceedings with respect to any property, rights or liabilities transferred to the`
  line `Union territory of Dadra and Nagar Haveli and Daman and Diu under this Act, the Union territory of`
  line `Dadra and Nagar Haveli and Daman and Diu shall be deemed to be substituted for the existing Union`
  line `territories as a party to those proceedings, or added as a party thereto, as the case may be, and the`
  line `proceedings may continue accordingly.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (49770)
  sectionNo (21)
  orderNo 21
  title `Transfer of pending proceeding.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49770&sectionno=21&orderno=21&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_21_content:
  string
  line `(1) Every proceeding pending immediately before the`
  line `appointed day before any court (other than a High Court), tribunal, authority or officer in any area which`
  line `on that day falls within the existing Union territories shall, stand transferred to the corresponding court,`
  line `tribunal, authority or officer in the Union territory of Dadra and Nagar Haveli and Daman and Diu.`
  line
  line `(2) In this section,--`
  line
  line `(a) “proceeding” includes any suit, case or appeal; and`
  line
  line `(b) “corresponding court, tribunal, authority or officer”, in the Union territory of Dadra and Nagar`
  line `Haveli and Daman and Diu, means--`
  line
  line `(i) the court, tribunal, authority or officer in which, or before whom, the proceeding would`
  line `have laid if the proceeding had been instituted after the appointed day, or`
  line
  line `(ii) in case of doubt, such court, tribunal, authority or officer in that Union territory as may be`
  line `determined after the appointed day by the Administrator of the Union territory of Dadra and`
  line `Nagar Haveli and Daman and Diu, or before the appointed day by the existing Union territories,`
  line `to be the corresponding court, tribunal, authority or officer.`
  line
  line `Explanation.--For the purposes of this sub-section, “Administrator” means the administrator`
  line `appointed by the President under article 239 of the Constitution.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (49771)
  sectionNo (22)
  orderNo 22
  title `Effect of provisions inconsistent with other laws.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49771&sectionno=22&orderno=22&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_22_content:
  string
  line `The provisions of this Act shall have effect`
  line `notwithstanding anything inconsistent therewith contained in any other law for the time being in force.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (49772)
  sectionNo (23)
  orderNo 23
  title `Power to remove difficulties.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00078_201944_1576735558443&sectionId=49772&sectionno=23&orderno=23&orgactid=AC_CEN_3_20_00078_201944_1576735558443
obj_root_law_sections_23_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the President may, by order published in the Official Gazette, make such provisions, not`
  line `inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of three years from the appointed day.`
  line
  line `(2) Every order made under this section shall be laid before each House of Parliament.`
obj_root_law_sections_23_footnotes:
  string
  line
