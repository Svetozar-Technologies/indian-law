obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `पेट्रोलियम और प्र ाकृलिक गैस लिलियामक बोर्ड`
  line `अलिलियम, 2006`
  line _________
  line `िाराओं का क्र म`
  line _________
  line `ि ााराएं`
  line `अध्या य 1 प्र`
  line ारंलिक
  line `1. संलिप् ि िाम, लिस्िा र, प्र ारंि और िागू होिा।`
  line `2. पररिाषाएं।`
  line `अध्या य 2`
  line `पेट्रोलियम और प्र ाकृलिक गैस लिलियामक बोर्ड`
  line `3. बोर्ड की स् था पिा और लिगमि।`
  line `4. अध्य ि और अन्य सदस्यों की लियुलि के लिए अहडिाएं।`
  line `5. अध्य ि और अन्य सदस्यों की पदािलि, सेिा की शिें, आदद।`
  line `6. अध्य ि की शलि।`
  line `7. अध्य ि और दकसी अन्य सदस्य का पद से हटाया जािा।`
  line `8. बोर्ड के अलििेशि।`
  line `9. ररलि यों, आदद से बोर्ड की कायडिालहयों का अलिलिमान्य ि होिा।`
  line `10. बोर्ड के अलिकारी और अन्य कमडचारी।`
  line `अध्या य 3`
  line `बोर्ड के कृत्य और शलि यां`
  line `11. बोर्ड के कृत्य।`
  line `12. लशकायिों के संबंि में शलि यां और बोर्ड द्व ारा लििादों का समािाि।`
  line `13. बोर्ड की प्र दक्रया।`
  line `अध्या य 4`
  line `रलजस् ट्री करण और प्र ालिकरण`
  line `14. रलजस्ट र।`
  line `15. इकाइयों का रलजस् ट्री करण।`
  line `16. प्र ालिकरण।`
  line `17. प्र ालिकार के लिए आिेदि।`
  line `18. आिेदिों का प्र चार।`
  line `19. प्र ालिकार की मंजूरी।`
  line `20. सामान्य िालहत्र या ठेका िालहत्र और िगर या स् था िीय प्र ाकृलिक गैस लििरण िेटिकड की घोषणा करिा, लबछािा,`
  line `लिमाडण करिा, आदद।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line `ि ााराएं`
  line `21. प्र थम उपयोग का अलिकार, आदद।`
  line `22. पररिहि टैररफ।`
  line `23. प्र ालिकार का लििंबि या रद्दकरण।`
  line `अध्या य 5`
  line `लििादों का लिपटारा`
  line `24. बोर्ड द्व ारा लििादों का लिपटारा।`
  line `25. पररिाद फाइि करिा।`
  line `26. अन्िे षण करिे की शलि।`
  line `27. बोर्ड द्व ारा लिचार की जािे िािी बािें।`
  line `28. बोर्ड द्व ारा ददए गए लिदेशों के उल्िं घि के लिए लसलिि शालस्ि।`
  line `29. बोर्ड द्व ारा पाररि आदेश को लर्क्री समझा जािा।`
  line `अध्या य 6`
  line `अपीि अलिकरण को अपीिें`
  line `30. अपीि अलिकरण।`
  line `31. िकिीकी सदस्य (पेट्रोलियम और प्र ाकृलिक गैस)।`
  line `32. िकिीकी सदस्य (पेट्रोलियम और प्र ाकृलिक गैस) की सेिा के लिबंिि और शिें।`
  line `33. अपीि अलिकरण को अपीिें।`
  line `34. अपीि अलिकरण की प्र दक्रया और शलि यां।`
  line `35. अपीि अलिकरण की लियम बिािे की शलि।`
  line `36. अपीि अलिकरण द्व ारा पाररि आदेशों का लर्क्री के रू प में लिष्पा दिीय होिा।`
  line `37. उच्च िम न् या यािय को अपीि।`
  line `अध्या य 7`
  line `लित्त, िेखा और संपरीिा`
  line `38. केंद्रीय सरकार द्व ारा अिुदाि।`
  line `39. लिलि।`
  line `40. िेखा और संपरीिा।`
  line `41. िार्षडक ररपोटड और उसका संसद् के समि रखा जािा।`
  line `अध्या य 8`
  line `केंद्रीय सरकार की शलि`
  line `42. केंद्रीय सरकार की लिदेश देिे की शलि।`
  line `43. दकसी इकाई की सुलििाओं और कारबार पररसरों िथा फुटकर लिक्रय केंद्रों के लियंत्रण और प्र बंि का िोकलहि में ग्र हण`
  line `दकया जािा।`
  line `अध्या य 9`
  line `अपराि और दंर्`
  line `44. बोर्ड के लिदेशों के उल्िं घि के लिए दंर्।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line iii
  line िाराएं
  line `45. अपी ि अलिकरण के आदेशों के अिुपािि में जािबूझकर असफि रहिे के लिए शालस्ि।`
  line `46. अप्रालिकृि दक्रयाकिाप के लिए दंर्।`
  line `47. रलजस् ट्री करण के लबिा द्र लिि प्र ाकृलिक गैस टर्मडिि की स् था पिा या संचािि के लिए दंर्।`
  line `48. प्र ालिकार के लबिा सामान्य िालहत्र या ठेका िालहत्र लब छािे, लिर्मडि करिे, प्र चालिि करिे या लिस्िा र करिे के लिए दंर्।`
  line `49. सामान्य िालहत्र या ठेका िालहत्र को जािबूझकर िुकसाि पहंचािे के लिए दंर्।`
  line `50. कंपलियों द्व ारा अपराि।`
  line `अध्या य 10 प्र`
  line कीणड
  line `51. र् ाटा बैंक और सूचिा का रखा जािा।`
  line `52. इकाइयों की बाध्य िाएं।`
  line `53. केंद्रीय सरकार को लििरलणयां आदद का ददया जािा।`
  line `54. अध्य ि, सदस् यों आदद का िोक सेिक होिा।`
  line `55. सद्भािपूिडक की गई कारडिाई के लिए संरिण।`
  line `56. लसलिि न् या याियों को अलिकाररिा का ि होिा।`
  line `57. कलिपय अपरािों का संज्ञाि।`
  line `58. प्रत् या योजि।`
  line `59. करठिाइयों को दूर करिे के शलि।`
  line `60. केंद्रीय सरकार की लियम बिािे की शलि।`
  line `61. बोर्ड की लिलियम बिािे की शलि।`
  line `62. लियमों और लिलियमों का संसद् के समि रखा जािा।`
  line `63. संक्रमणकािीि व् य िस्था एं।`
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
  orderNo 4
  title `Page 4`
  content obj_root_law_translations_hi_sections_4_content
  footnotes obj_root_law_translations_hi_sections_4_footnotes
  sourcePage 4
obj_root_law_translations_hi_sections_4_content:
  string
  line `पेट्रोलियम और प्र ाकृलिक गैस लिलियामक बोर्ड`
  line `अलिलियम, 2006`
  line `( 2006 का अलिलियम संखयां क 19 )`
  line `[31 माचड, 2006]`
  line `पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस के पररष्क रण, प्र संस्क रण, िंर्ारकरण, पररिहि, लििरण,`
  line `लिपणि और लिक्रय का लजसके अंिगडि अपररष्कृ ि िेि और प्र ाकृलिक गैस का उत्पा दि िहीं है,`
  line `लिलियमि करिे, लजससे उपिो िा ओं और पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस से`
  line `संबंलिि लिलिर्दडष्ट दक्रयाकिाप में िगी हई इकाइयों के लहिों का संरिण दकया`
  line `जा सके और देश के सिी िागों में पेट्रोलियम, पेट्रोलियम उत्पा दों औ र प्र`
  line `ाकृलिक गैस का अलिरि िथा पयाडप्ि प्र दाय सुलिलच ि करिे और प्र`
  line `लिस्प िाडत्म क बाजारों का संप्रििडि करिे के लिए पेट्रोलियम`
  line `और प्र ाकृलिक गैस लिलियामक बोर्ड की स् था पिा`
  line `और उिसे संबंलिि या उिके आिुषंलगक`
  line `लिषयों का उपबंि`
  line `करिे के लिए`
  line अलिलियम
  line `िारि गणराज्य के सिािििें िषड में संसद् द्व ारा लिलि लिलखि रू प में यह अलिलियलमि हो: —`
  line `अध्या य 1 प्र`
  line ारंलिक
  line `1. संलिप्ि िाम, लिस्िा र, प्र ारंि और िागू होिा — ( 1 ) इस अलिलियम का संलिप् ि िाम पेट्रोलियम और प्र ाकृलिक गैस`
  line `लिलियामक बोर्ड अलिलियम, 2006 है।`
  line `( 2 ) इसका लिस्िा र संपूणड िारि पर है।`
  line `( 3 ) यह उस िारीख को प्र िृत्त होगा जो केन् द्री य सरकार, राजपत्र में अलिसूचिा द्व ारा, लियि करे:`
  line `परंिु इस अलिलियम के लिन् ि - लिन् ि उपबंिों के लिए लिन् ि - लिन् ि िारीखें लियि की जा सकेंगी और ऐसे दकसी उपबंि में इस`
  line `अलिलियम के प्र ारंि के प्र लि दकसी लिदेश का यह अथड िगाया जाएगा दक िह उस उपबंि के प्र िृत्त होिे के प्र लि लिदेश है।`
  line `( 4 ) यह, पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस के पररष्क रण, प्र संस्क रण, िंर्ारकरण, पररिहि, लििरण,`
  line `लिपणि और लिक्रय को, अपररष्कृ ि िेि और प्र ाकृलिक गैस के उत्पा दि को छोड़कर िागू होिा है।`
  line `2. पररिाषाएं — इस अलिलियम में, जब िक दक संदिड से अन्य था अपेलिि ि हो, —`
  line `(क) “ सहबद्ध आचार संलहिा ” से िारा 21 की उपिारा ( 1 ) के अिीि प्र ाकृलिक गैस के िंर्ारकरण, पारेषण,`
  line `लििरण, लिपणि और लिक्रय में िगी हई इकाइयों को शालसि करिे िािी आचार संलहिा अलिप्रेि है;`
  line `(ख) “ अपीि अलिकरण ” से िारा 30 में लिर्दड ष् ट अपीि अलिकरण अलिप्रेि है;`
  line `(ग) “ लियि ददि ” से िह िारीख अलिप्रेि है लजसको िारा 3 की उपिारा ( 1 ) के अिीि बोर्ड स् था लपि दकया`
  line `जािा है;`
  line `(घ) “ प्र ालिकृि इकाई ” से कोई ऐसी इकाई अलिप्रेि है —`
  line `(अ) जो बोर्ड द्व ारा िारा 15 के अिीि —`
  line `( i ) दकसी अलिसूलचि पेट्रोलियम, पेट्रोलियम उत्पा दों या प्र ाकृलिक गैस का लिपणि करिे; या`
  line `( ii ) द्र लिि प्र ाकृलिक गैस टर्मडििों को स् था लपि और प्र चालिि करिे के लिए रलजस् ट्री कृि है; या`
  line `(आ) जो बोर्ड द्व ारा िारा 16 के अिीि —`
  line `( i ) दकसी सामान्य िालहत्र या ठेका िालह त्र को लबछािे, लिर्मडि करिे, प्र चालिि करिे या`
  line `लिस्िा ररि करिे; या`
obj_root_law_translations_hi_sections_4_footnotes:
  string
  line
obj_root_law_translations_hi_sections_5:
  kind page
  sectionId pdf-page-5
  sectionNo (5)
  orderNo 5
  title `Page 5`
  content obj_root_law_translations_hi_sections_5_content
  footnotes obj_root_law_translations_hi_sections_5_footnotes
  sourcePage 5
obj_root_law_translations_hi_sections_5_content:
  string
  line 2
  line `( ii ) दकसी िगर या स् था िीय प्र ाकृलिक गैस लििरण िेटिकड को लबछािे, लिर्मडि करिे, प्र चालिि`
  line `करिे या लिस्िा ररि करिे,`
  line `के लिए प्र ालिकृि है;`
  line `( ङ ) “ स् ि ि: द्र लिि पेट्रोलि यम गैस ” से पेट्रोलियम से व् यु त् प न् ि कलिपय हल्के हाइड्रोकाबडिों का कोई लमश्रण अलिप्रेि`
  line `है जो सामान्य पररिेश िाप और िायुमंर्िीय दाब पर गैसीय है, ककंिु मध्य म दाब के प्र योग से सामान्य पररिेश िाप पर द्र ि`
  line `अिस्था में संघलिि हो जािा है, और जो यािों में ईं िि के रू प में उ पयोग के लिए ऐसे लिलिदेशों के अिुरूप है जो केंद्री य`
  line `सरकार द्व ारा, िारिीय मािक ब् यू रो के परामशड से समय - समय पर अलिसू लचि दक ए जाएं;`
  line `(च) “ बोर्ड ” से िारा 3 की उपिारा ( 1 ) के अिीि स् था लपि पेट्रोलियम और प्र ाकृलिक गैस लिलियामक बोर्ड`
  line `अलिप्रेि है;`
  line `(छ) “ िारिीय मािक ब् यू रो ” से िारिीय मािक ब् यू रो अलिलियम, 1986 ( 1986 का 63 ) की िा रा 3 के अिीि स्`
  line `था लपि िारिीय मािक ब् यू रो अलिप्रेि है;`
  line `(ज) “ अध्य ि ” से िारा 4 की उपिारा ( 1 ) के अिीि लियुि बोर्ड का अध्य ि अलिप्रेि है;`
  line `(झ) “ िगर या स् था िीय प्र ाकृलिक गैस लििरण िेटिकड ” से गै स पाइप िाइिों का अंिसंबंिी िेटिकड और सहयुि`
  line `उपस्क र अलिप्रेि है जो दकसी प्र पुंज प्र दाय उच्च दाब पारेषण मुखय स् था ि से मध्य म दाब लििरण लग्रर् को और ित्प चा ि्`
  line `घरेिू, औद्योलगक या िालणलज्य क पररसरों को और लिलिर्दडष्ट िौगोलिक िेत्रों में लस्थ ि सी ० ए ि ० जी ० केंद्रों को प्र ाकृलिक गैस प्र`
  line `दाय करिे िािे सेिा पाइपों से प्र ाकृलिक गैस का पररिहि करिे के लिए उपयोग दकया जािा है। स्`
  line `प ष् टी करण — इस खंर् के प्र योजिों के लिए “ उच्च दाब ” और “ मध्य म दाब ” पदों से ऐसा दाब अलिप्रेि है लजसे`
  line `केंद्रीय सरकार अलिसूचिा द्व ा रा, यथालस्थ लि, उच्च दाब या म ध् य म दाब लिलिर्दडष्ट करे;`
  line `( ञ ) “ सामान्य िालहत्र ” से एक से अलिक इकाइयों द्व ारा पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस के`
  line `पररिहि के लिए ऐसी पाइप िाइिें, अलिप्रेि हैं जो बोर्ड, िारा 20 की उपिारा ( 3 ) के अिीि अलििेदकारी खुिी पहंच के`
  line `आिार पर, समय - समय पर घोलषि या प्र ालिकृि करे, ककंिु उिमें लिि लिलखि प्र दाय करिे िािी पाइप िाइिें सलम लिि`
  line `िहीं हैं —`
  line `( i ) दकसी लिलिर्दडष्ट उपिोिा को पेट्रोलियम उत्पा द या प्र ाकृलिक गैस; या`
  line `( ii ) अपररष्कृ ि िेि। स्`
  line `प ष् टी करण — इस खंर् के प्र योजिों के लिए, दकसी ठेका िालहत्र को कोई सामान्य िालहत्र समझा जाएगा यदद —`
  line `( i ) ऐसे ठेका िालहत्र के पास फमड के साथ हई संलिदाओं से अलिक िमिा है; या`
  line `( ii ) फमड की संलिदा की अिलि समाप्ि हो गई है;`
  line `(ट) “ सी ० एि ० जी ० केंद्र ” से ऐसा िरण केंद्र अलिप्रेि है, जहां संपीलड़ि प्र ाकृलिक गैस के लिक्रय के लिए एक या`
  line `अलिक लििरण इकाइयों की व् य िस्था की गई है;`
  line `(ठ) “ संपीलड़ि प्र ाकृलिक गैस या सी ० एि ० जी ० ” से गैसीय लस्थ लि में 200 से 250 बार श्रे णी के बी च दाब िक लिशेष प्र`
  line `कार से संपीलड़ि यािों के लिए ईं िि के रू प में उपयोग की जािे िािी प्र ाकृलिक गैस अलिप्रेि है;`
  line `(र्) “ ठेका िालहत्र ” से फमड की संलिदाओं के अिुसरण में कम से कम एक िषड के लिए एक से अलिक इकाइयों द्व ा रा`
  line `पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस के पररिहि के लिए ऐसी पाइप िाइिें अलिप्रेि हैं जो बोर्ड द्व ारा`
  line `समय - समय पर िारा 20 की उपिारा ( 3 ) के अिीि घोलषि या प्र ालिकृि की जाएं;`
  line `(ढ) “ व् यौ हारी ” से अलिप्रेि है ऐसा कोई व् य लि, व् य लि यों का संगम, फमड, कंपिी या सहकारी सोसाइटी, चाहे िह`
  line `दकसी िी िाम से ज्ञ ाि हो या लिर्दडष्ट की जाए और लजसे मोटर लस्प ररट, उच्च गलि र् ीजि, श्रेष् ठ लमट्टी के िेि, स् ि ि: द्र लिि`
  line `पेट्रोलियम गैस या प्र ाकृलिक गैस का क्र य करिे, प्र ाप्ि करिे, िंर्ार करिे और लिक्रय करिे के लिए दकसी िेि कंपिी द्व ा रा`
  line `लियुि दकया गया हो;`
  line `(ण) “ लििरक ” से अलिप्रेि है ऐसा कोई व् य लि, व् य लि यों का संगम, फमड, कंपिी, सहकारी सोसाइटी, चाहे लजस`
  line `दकसी िी िाम से ज्ञ ाि हो या लिर्दडष्ट की जाए और लजसे लसिेन् र् रों में द्र लिि पेट्रोलियम गैस; क्र य करिे, प्र ाप्ि करिे, िंर्ार`
  line `करिे और उपिोिा ओं को लिक्रय करिे के लिए दकसी िेि कंपिी द्व ारा लियुि दकया गया हो;`
obj_root_law_translations_hi_sections_5_footnotes:
  string
  line
obj_root_law_translations_hi_sections_6:
  kind page
  sectionId pdf-page-6
  sectionNo (6)
  orderNo 6
  title `Page 6`
  content obj_root_law_translations_hi_sections_6_content
  footnotes obj_root_law_translations_hi_sections_6_footnotes
  sourcePage 6
obj_root_law_translations_hi_sections_6_content:
  string
  line 3
  line `(ि) “ इकाई ” से दकसी व् यौ हारी या लििरक से लिन् ि ऐसा कोई व् य लि, व् य लि यों का संगम, फमड, कंपिी या`
  line `सहकारी सोसाइटी, अलिप्रेि है चाहे िह दकसी िी िाम से ज्ञ ाि हो या लिर्दडष्ट की जाए, और पेट्रोलियम, पेट्रोलियम उत्पा दों`
  line `और प्र ाकृलिक गैस के पररष्क रण, प्र संस्क रण, िंर्ारकरण, पररिहि, लििरण, लिपणि, आयाि और लियाडि में िगी हई हो या`
  line `िगे रहिे के लिए आशलयि हो, लजसमें पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस के पररिहि के लिए पाइप िाइिें`
  line `लबछािा या िगर या स् था िीय प्र ाकृलिक गैस लििरण िेटिकड लबछािा, लिमाडण करिा, प्र चालिि करिा या लिस्िा ररि करिा,`
  line `कोई द्र लिि प्र ाकृलिक गैस टर्मडिि स् था लपि करिा और प्र चालिि क रिा िी सलम लिि है;`
  line `(थ) “ उत्पा दों का लिलिमय ” से संबद्ध इकाइयों द्व ारा दकए गए दकसी करार के अिुसार पेट्रो लियम उत्पा द का देिा`
  line `और िेिा अलिप्रेि है;`
  line `(द) “ उच्च गलि र् ीजि ” से अलिप्रेि है ऐसा कोई हाइड्रोकाबडि िेि (खलिज कोल्जा िेि और िारपीि प्र लिस्था पी को`
  line `छोड़कर) जो संपीड़ि ज् ि िि इंजिों में ईं िि के रू प में उपयोग के लिए ऐसे लिलिदेशों के अिुरूप हो जो केंद्रीय सरकार`
  line `िारिीय मािक ब् यू रो के परामशड से समय - स मय पर अलि सूलचि करे;`
  line `(ि) “ लमट्टी का िेि या श्रेष् ठ लमट्टी का िेि ” से अलिप्रेि है हाइड्रोकाबडिों का मध्य म आसुि लमश्रण जो ऐसे लि लिदेशों`
  line `के अिुरूप हो, जो केंद्रीय सरकार िारिीय मािक ब् यू रो के परामशड से, समय - स मय पर अलिसूलचि करे;`
  line `(ि) “ द्र लिि प्र ाकृलिक गैस टर्मडि ि ” से —`
  line `( i ) द्र लिि प्र ाकृलिक गैस प्र ाप्ि करिे के लिए,`
  line `( ii ) द्र लिि प्र ाकृलिक गैस का िंर्ारण करिे के लिए,`
  line `( iii ) द्र लिि प्र ाकृलिक गैस के पुि:गैसीकरण को समथड करिे के लिए, और`
  line `( iv ) सुलििाओं की सीमाओं के बाहर िक पुि: गैसीकृि द्र लिि प्र ाकृलिक गैस का पररिहि करिे के लिए,`
  line `अपेलिि सुलििाएं और अिसंरचिा अलिप्रेि हैं;`
  line `(प) “ द्र लिि पेट्रोलियम गैस ” से अलिप्रेि है हल्के हाइड्रोकाबडिों का कोई लमश्रण लज समें प्र ोपेि, आइसोब्यू टेि,`
  line `सामान्य ब् यू टेि, ब् यू टीिीि या ऐसा अन्य पदाथड अंिर्िडष्ट है जो सामान्य पररिेश िा प और िायुमंर्िीय दाब पर गैसीय है`
  line `ककंिु दाब के प्र योग से सामान्य पररिेश िाप पर द्र ि अिस्था में संघलिि हो सकिा हो और जो ऐसे लिलिदेशों के अिुरूप है जो`
  line `केंद्रीय सरकार द्व ारा िारिीय मािक ब् यू रो के परामशड से स मय - स मय पर अलिसूलचि दकए जाएं;`
  line `(फ) “ स् था िीय लििर ण इकाई ” से िगर या स् था िीय प्र ाकृलिक गैस लििरण िेटिकड को लबछािे, लिमाडण करिे, प्र`
  line `चालिि करिे या लिस्िा र करिे के लिए िारा 20 के अिीि बोर्ड द्व ारा प्र ालिकृि कोई इका ई अलिप्रेि है;`
  line `(ब ) “ लिपणि सेिा बाध्य िाओं ” से, —`
  line `( i ) अलिसूलचि पेट्रोलियम और पेट्रोलियम उत्पा दों की बाबि दूरस्थ िेत्रों में लिपणि अिसंरचिा और`
  line `फुटकर लिक्रय केंद्र को स् था लपि करिे की बाध्य िाएं;`
  line `( ii ) अलिसूलचि पेट्रोलियम और पेट्रोलियम उत्पा दों के न् यू ििम स् टा क को बिाए रखिे की बाध्य िाएं;`
  line `( iii ) उपिोिा ओं को प्र ाकृलिक गैस प्र दाय करिे के लिए दक सी स् था िीय लििरण इकाई की बाध्य िाएं;`
  line `( iv ) ऐसी अन्य बाध्य िाएं, जो लिलियमों द्व ारा लिलिर्दडष्ट की जाएं,`
  line `अलिप्रेि हैं;`
  line `(ि) “ अलिकिम फुटकर कीमि ” से दकसी इकाई द्व ारा लियि िह अलिकिम कीमि अलिप्रेि है लजस पर पेट्रोलियम,`
  line `पेट्रोलियम उत्पा द और प्र ाकृलिक गैस, फु टकर उपिोिा ओं को बेचे जो सकेंगे और लजसमें सिी कर, उपकर और उद्ग्रहण, चाहे`
  line `िे स् था िीय हों या अन्य था, और व् यौ हाररयों को संदेय िाड़ा या कमी शि िी सलम लिि हैं;`
  line `(म) “ सदस्य ” से िारा 4 की उपिारा ( 1 ) के अिीि लियुि दकया गया बोर्ड का कोई सदस्य अलिप्रेि है और लजसमें`
  line `सदस्य (लिलिक) और अध्य ि िी सलम लिि हैं;`
  line `(य) “ मोटर लस्प ररट ” से अलिप्रेि है कोई हाइड्रोकाबडि िेि (अपररष्कृ ि खलिज िेि को छोड़कर) लजसका स् फु लिंग ज्`
  line `ि िि इंजिों में ईं िि के रू प में उपयोग दकया जािा है, जो ऐसे लिलिदेशों के अिुरूप हैं, जो कें द्र ीय सरकार द्व ारा, िारिीय`
  line `मािक ब् यू रो के परामशड से समय - स मय पर अलिसूलचि दकए जाएं;`
  line `(यक) “ प्र ाकृलिक गैस ” से ऐसी गैस अलिप्रेि है जो बोर लछद्रों से अलिप्राप्ि की गई है और लजसमें मुखय ि:`
  line `हाइड्रोकाबडि है िथा इसके अंिगडि लिि लिलखि िी हैं —`
obj_root_law_translations_hi_sections_6_footnotes:
  string
  line
obj_root_law_translations_hi_sections_7:
  kind page
  sectionId pdf-page-7
  sectionNo (7)
  orderNo 7
  title `Page 7`
  content obj_root_law_translations_hi_sections_7_content
  footnotes obj_root_law_translations_hi_sections_7_footnotes
  sourcePage 7
obj_root_law_translations_hi_sections_7_content:
  string
  line 4
  line `( i ) द्र ि अिस्था में गैस, अथाडि् द्र लिि प्र ाकृलिक गैस और पुि:गैसीकृि द्र लिि प्र ाकृलिक गैस,`
  line `( ii ) संपीलड़ि प्र ाकृलिक गैस,`
  line `( iii ) अंिरराष् ट्री य पाइपिाइिों के माध्य म से आयालिि गैस लजसके अंिगडि सी ० एि ० जी ० या द्र लिि प्र`
  line `ाकृलिक गैस िी है,`
  line `( iv ) प्र ाकृलिक गैस के रू प में गैस हाइड्रेंटों से प्र ाप्ि गैस,`
  line `( v ) कोयिा संस्ि रों अथाडि् कोयिा संस्ि र लमथेि से अलिप्राप्ि लमथेि,`
  line `दकन्िु इसके अंिगडि ऐसे हाइड्रोकाबडिों के सहयो जि से उत्प न् ि हीलियम िहीं है;`
  line `(यख) “ अलिसूचिा ” से राजपत्र में प्र कालशि अलिसूचिा अलिप्रेि है और “ अलिसूलचि ” पद का उसके सजािीय अथड`
  line `िथा व् या करलणक रू पिेदों सलहि िदिुसार अथड िगाया जाएगा;`
  line `(यग) “ अलिसूलचि पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस ” से अलिप्रेि हैं ऐसे पेट्रोलियम, पेट्रोलि यम`
  line `उत्पा द और प्र ाकृलिक गैस लजन्हें केंद्रीय सरकार, अपिा यह स मािाि होिे के प चा ि् दक उिका प्र दाय बिाए रखिे या बढािे`
  line `के लिए या उिका साया पूणड लििरण और पयाडप्ि उपिब् ि िा सुलि लाचि करिे के लिए ऐसा क रिा आिय क या समीचीि`
  line `है, समय - समय पर अलिसूलचि करे;`
  line `(यघ) “ िेि कंपिी ” से कंपिी अलिलियम, 1956 ( 1956 का 1 ) के अिीि र लजस् ट्री कृि कंपिी अलिप्रेि है और इसमें`
  line `पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र ाकृलिक गैस से संबंलिि कोई दक्रयाकिाप करिे के लिए दकसी िी िाम से ज्ञ ाि या`
  line `लिर्दडष्ट व् य लि यों को कोई संगम, सोसाइटी या फमड सलम लिि है;`
  line `(य ङ ) “ पेट्रोलियम ” से अलिप्रेि है ऐसा कोई द्र ि हाइड्रोकाबडि या हाइड्रोकाबडिों का लमश्रण और कोई ज् ि ििशीि`
  line `लमश्रण (द्रि, लिस्को स या ठोस) लजसमें कोई द्र ि हाइड्रोकाबडि अंिर्िडष्ट हो, लजसमें अपररष्कृ ि िेि और द्र लिि पेट्रोलियम गैस`
  line `सलम लिि है और “ पेट्रोलियम उत्पा द ” पद से पेट्रोलियम से लिलिर्मड ि कोई उत्पा द अलिप्रेि होगा;`
  line `(यच) “ पाइपिाइि पहंच संकेिकी ” से िारा 11 के खंर् ( ङ ) के उपखंर् ( i ) के अिीि पाइपिाइिों िक िृिीय`
  line `पिकार की पहंच के लिए ढांचा स् था लपि करिे के लिए संकेिकी अलिप्रे ि है;`
  line `(यछ) “ लिलहि ” से इस अलिलियम के अिीि केंद्रीय सरकार द्व ारा बिाए गए लियमों द्व ारा लिलहि अलिप्रेि है;`
  line `(यज) “ लिलियम ” से इस अलिलियम के अिीि बोर्ड द्व ारा बिाए गए लिलियम अलिप्रेि हैं;`
  line `(यझ) “ अिरोिक व् या पाररक व् य िहार ” से ऐसा व् या पाररक व् य िहार अलिप्रेि है जो दकसी रीलि में प्र लियोलगिा का`
  line `लििारण करिे, उसको लिकृि करिे या लिबंलिि करिे का प्र िाि रखिा है या रख सकेगा और लिलशष्ट िया, —`
  line `( i ) जो उत्पा दि की िारा में पूंजी या संसाििों के बहाि में बािा र् ाििा हो, या`
  line `( ii ) जो पेट्रोलियम, पेट्रोलियम उत्पा दों या प्र ाकृलिक गैस या सेिाओं के संबंि में, उपिोिा ओं पर`
  line `अन्या यपूणड िागिों या लिबडन्ि िों को अलिरोलपि करिे के लिषय में ऐसी रीलि में कीमिों या पररदाि की`
  line `पररलस्थ लियों में घट बढ करिा हो या पूर्िड के बहाि पर प्र िाि र् ाििा हो;`
  line `(य ञ ) “ फुटकर लिक्रय केंद्र ” से अलिप्रेि है ऐसा िरण केंद्र जहां मोटर लस्प ररट, उच्च गलि र् ीजि, स् ि ि: द्र लि ि`
  line `पेट्रोलियम गैस या प्र ाकृलिक गैस के लिक्रय के लिए एक या अलिक लििरक पंपों का प्र बंि दकया गया है और इसमें द्र लिि`
  line `पेट्रोलियम गैस की लर्लस् ट्र ब् यू टरलशप या श्रेष् ठ लमट्टी के िेि या सी ० एि ० जी ० स् टे शिों की र् ीिरलशप सलम लिि है;`
  line `(यट) “ फुटकर सेिा बाध्य िाओं ” से व् यौ हाररयों और लििरकों की, अ लिसूलचि पेट्रोलियम, पेट्रोलियम उत्पा दों और प्र`
  line `ाकृलिक गैस, लजसमें सी ० एि ० जी ० सलम लिि हैं, का लिलिर्दडष्ट सपू णड कायड समय में उपिोिा ओं को प्र दाय और`
  line `लिलिर्दडष्ट िा लिटी, पररमाण िथा अलिकिम फुटकर कीमि के संप्रदशडि को बिाए रखिे के लिए बाध्य िाएं, और ऐसी`
  line `बाध्य िाएं, जो लिलियमों द्व ारा लिलिर्दडष्ट की जाएं, अलिप्रेि हैं;`
  line `(यठ) “ लियमों ” से केंद्रीय सरकार द्व ारा इस अलिलियम के अिीि बिाए गए लियम अलिप्रेि हैं;`
  line `(यर्) “ सलचि ” से बोर्ड का सलचि अलिप्रेि है;`
  line `(यढ) सामान्य िालहत्र या ठेका िालहत्र या दकसी िगर या स् था िीय प्र ाकृलिक गैस लििरण िेटिकड के संबंि में`
  line `“ पररिहि दर ” से अलिप्रेि है पेट्रोलियम या पेट्रोलियम उत्पा दों या प्र ाकृलिक गैस के प्रत् ये क यूलिट को संचालिि करिे के लिए`
  line `ऐसी दर जो लिलियमों द्व ारा लियि की जाए।`
obj_root_law_translations_hi_sections_7_footnotes:
  string
  line
obj_root_law_translations_hi_sections_8:
  kind page
  sectionId pdf-page-8
  sectionNo (8)
  orderNo 8
  title `Page 8`
  content obj_root_law_translations_hi_sections_8_content
  footnotes obj_root_law_translations_hi_sections_8_footnotes
  sourcePage 8
obj_root_law_translations_hi_sections_8_content:
  string
  line 5
  line `अध्या य 2`
  line `पे ट्र ोलियम और प्र ाकृलिक गैस लिलियामक बोर्ड`
  line `3. बोर्ड की स् था पिा और लिगमि — ( 1 ) उस िारीख से, जो केंद्रीय सरकार, अलिसूचिा द्व ारा, लियि करे, इस अलिलियम के प्र`
  line `योजिों के लिए पेट्रोलियम और प्र ाकृलिक गैस लिलियामक बोर्ड के िाम से ज्ञ ाि, एक बोर्ड स् था लपि दकया जाएगा।`
  line `( 2 ) बोर्ड पूिोि िाम का एक लिगलमि लिकाय होगा लजसका शाि ि् उत्तरालिकार और सामान्य मुद्रा होगी और लजसे इस`
  line `अलिलियम के उपबंिों के अिीि रहिे हए जंगम और स् था िर दोिों ही प्र कार की संपलत्त का अजडि, िारण और व् य यि करिे िथा संलिदा`
  line `करिे की शलि होगी और िह उि िाम से िाद िाएगा या उसके लिरुद्ध िाद िाया जाएगा।`
  line `( 3 ) बोर्ड, केंद्रीय सरकार द्व ारा लियुि दकए जािे िािे एक अध्य ि, एक सदस्य (लिलिक) और िीि अन्य सदस्यों से लमिकर`
  line बिेगा।
  line `( 4 ) बोर्ड का मुखया िय िई ददल्िी में होगा और प्र ादेलशक कायाडिय, ऐसे स् था िों पर होंगे, जहां िोकलहि और कायड की महत्ता`
  line `को ध् या ि में रखिे हए, बोर्ड आिय क समझे।`
  line `4. अध्य ि और अन्य सदस्यों की लियुलि के लिए अहडिाएं — ( 1 ) केंद्रीय सरकार, बोर्ड के अध्य ि और अन्य सदस्यों की`
  line `लियुलि, पेट्रोलियम और प्र ाकृलिक गैस उद्यो ग, प्र बंि, लित्त, लिलि, प्र शासि या उ पिोिा मामिों के िेत्र में लिखया ि व् य लि यों में से`
  line `करेगी:`
  line `परंिु दकसी व् य लि को सदस्य (लिलिक) के रू प में ििी लियुि दकया जाएगा जब िक िह —`
  line `(क) दकसी उच्च न् या यािय का न् या यािीश होिे के लिए अर्हडि है; या`
  line `(ख) िारिीय लिलिक सेिा का सदस्य है और उसिे उस सेिा में श्रे णी I में कोई पद कम से कम िीि िषड के लिए`
  line `िारण दकया है।`
  line `( 2 ) केंद्रीय सरकार, बोर्ड के अध्य ि और अन्य सदस्यों का चयि करिे के प्र योजिों के लिए, और अपीि अलिकरण के िकिीकी`
  line `सदस्य (पेट्रोलियम और प्र ा कृलिक गैस) के रू प में, लियुि के लिए लिचार दकए जािे िािे व् य लि यों का पैिि िैयार करिे के लिए, एक`
  line `खोज सलमलि का गठि करेगी, जो लिि लिलखि से लमिकर बिेगी, —`
  line `( i ) सदस्य, योजिा आयोग में ऊजाड सेट र का िारसािक — अध्य ि`
  line `( ii ) सलचि, िारि सरकार, पेट्रो लियम और प्र ाकृलिक गैस मंत्रािय — सदस्य`
  line `( iii ) सलचि, िारि सरकार, लित्त मंत्रािय, आर्थडक कायड लििाग — सदस्य`
  line `( iv ) सलचि, िारि सरकार, िालणज्य और उद्योग मंत्रािय में िालणज्य का िारसािक — सदस्य, और`
  line `( v ) सलचि, िारि सरकार, लिलि कायड लििाग, लिलि और न् या य मं त्र ािय — सदस्य।`
  line `5. अध्य ि और अन्य सदस्यों की पदािलि, सेिा की शिें, आदद — ( 1 ) केंद्रीय सरकार, अध्य ि या अन्य सदस्य के रू प में दकसी व्`
  line `य लि को लियुि करिे से पूिड, अ पिा समािाि करेगी दक ऐसे व् य लि का कोई ऐसा लित्तीय या अन्य लहि िहीं है लजस से अध्य ि या`
  line `ऐसे अन्य सदस्य के रू प में उसके कृत्यों पर प्र लिकूि प्र िाि पड़िे की संिाि िा है।`
  line `( 2 ) अध्य ि और अन्य सदस्य, ऐसी िारीख से लजसको िे अपिे पद ग्र हण करिे हैं, पांच िषड की अिलि िक या ज ब िक िे`
  line `पैंसठ िषड की आयु प्र ाप्ि िहीं कर िेिे हैं, इ िमें से जो िी पूिडिर हो, उस हैलसयि में अपिे प द िारण करेंगे:`
  line `परंिु अध्य ि और अन्य सदस्य पुिर्िडयुलि के लिए पात्र िहीं होंगे। स्`
  line `प ष् टी करण — इस िारा के प्र योजिों के लिए, दकसी सदस्य की, अध्य ि के रू प में लियुलि को पुिर्िडयुलि िहीं मािा`
  line जाएगा।
  line `( 3 ) केंद्रीय सरकार, राज्य सरकार या केंद्रीय सरकार या राज्य सरकार के स् िा लमत्िा िीि या लियंत्रणािीि दकसी उपक्रम,`
  line `लिगम या कंपिी या दकसी अन्य गैर सरकारी या लिगलमि लिकाय में सेिारि कोई व् य लि, यथालस्थ लि, अध्य ि या अन्य सदस्य के रू प`
  line `में पदग्रहण करिे से पूिड ऐसी सेिा का पद त् या ग करेगा या सेिा से लििृत्त होगा।`
  line `( 4 ) अध्य ि और अन्य सदस्यों को संदेय िेिि और ित्ते िथा उिकी सेिा के अन्य लिबंिि और शिें ऐसी होंगी, जो लिलहि`
  line `की जाएं:`
  line `परंिु अध्य ि या दकसी अन्य सदस्य के ि िो िेिि औ र ित्तों में और ि ही सेिा के अन्य लिबंिि और शिों में, उिकी लियुलि`
  line `के प चा ि्, उिके लिए अिािकारी पररििडि दकए जाएंगे।`
obj_root_law_translations_hi_sections_8_footnotes:
