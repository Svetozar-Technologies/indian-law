  object
  (str title) (str `पेट्रोलियम और प्राकृतिक गैस विनियामक बोर्डअधिनियम, 2006`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2012/3/H2006-19.pdf`)
