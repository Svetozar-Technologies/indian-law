  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1724/3/H1978-14.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:49:26.872Z`)
