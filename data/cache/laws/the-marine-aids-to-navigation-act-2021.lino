  object
  (str slug) (str the-marine-aids-to-navigation-act-2021)
  (str handle) (str 17202)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Marine Aids to Navigation Act, 2021.`)
  (str actNumber) (str 20)
  (str enactmentDate) (str 2020-07-31)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/17202`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `नौचालन के लिए सामुद्रिक सहायता अधिनियम, 2021`)
  (str actYear) (str 2021)
  (str ministry) (str `Ministry of Ports, Shipping and Waterways`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the development, maintenance and management of aids to navigation in India; for training and certification of operator of aids to navigation, development of its historical, educational and cultural value; to ensure compliance with the obligation under the maritime treaties and international instruments to which India is a party and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 2020-03-31)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T15:21:46.243Z`)
  (str translations) obj_root_law_translations
