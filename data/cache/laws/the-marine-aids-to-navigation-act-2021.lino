obj_root_law_sections_1:
  sectionId (64626)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64626&sectionno=1&orderno=1&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Marine Aids to`
  line `Navigation Act, 2021.`
  line
  line `(2) It extends to the whole of India including the maritime zones of India as specified in the Territorial`
  line `Waters, Continental Shelf, Exclusive Economic Zone and Other Maritime Zones Act, 1976 (80 of 1976).`
  line
  line `(3) It shall come into force on such date^1 as the Central Government may, by notification in the Official`
  line `Gazette, appoint; and different dates may be appointed for different provisions of this Act and any`
  line `reference in any such provision to the commencement of this Act shall be construed as a reference to the`
  line `coming into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 31st March, 2022, vide notification No. S.O.1202(E), dated 17th March, 2022, see Gazette of India, Extraordinary, Part II, sec.`
  line `3 (ii).`
obj_root_law_sections_2:
  sectionId (64627)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64627&sectionno=2&orderno=2&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,—`
  line
  line `(a) “accredited training organisation” means any organisation which is accredited by the Central`
  line `Government under section 20 ;`
  line
  line `(b) “aid to navigation” means a device, system or service, external to vessels, designed and`
  line `operated to enhance safe and efficient navigation of individual vessels and vessel traffic, but shall not`
  line `be construed to include a reference to vessel traffic services, unless otherwise specified;`
  line
  line `(c) “Director General” means the Director General of Aids to Navigation appointed under`
  line `section 4;`
  line
  line `(d) “district” means an area demarcated as a district for the purposes of this Act under`
  line `sub-section (1) of section 4;`
  line
  line `(e) “general aid to navigation” means any aid to navigation, which the Central Government may, by`
  line `notification in the Official Gazette, declare to be a general aid to navigation for the purposes of this`
  line Act;
  line
  line `(f) “heritage lighthouse” means an aid to navigation designated as such under section 23;`
  line
  line `(g) “local aid to navigation” means any aid to navigation which is not a general aid to navigation;`
  line
  line `(h) “local authority” means a State Government or other person having superintendence and`
  line `management over a local aid to navigation;`
  line
  line `(i) “marine aids to navigation dues” means the dues levied under section 24;`
  line
  line `(j) “notification” means a notification published in the Official Gazette of India and the expression`
  line `“notify” with its grammatical variation and cognate expressions shall be construed accordingly;`
  line
  line `(k) “owner” means the owner of a vessel including its registered owner, a person to whom a share`
  line `in the vessel belongs, bareboat charterer, manager and operator of the vessel;`
  line
  line `(l) “port” means any port as defined in the Indian Ports Act, 1908 (15 of 1908);`
  line
  line `(m) “prescribed” means prescribed by rules made under this Act;`
  line
  line `(n) “proper officer” in relation to any functions to be performed under this Act, means the officer of`
  line `customs who is assigned those functions by the Central Board of Indirect Taxes and Customs`
  line `constituted under the Central Boards of Revenue Act, 1963 (54 of 1963), and includes any person`
  line `appointed by the Central Government to discharge the functions of a proper officer under this Act;`
  line
  line `(o) “rule” means rules made by the Central Government under this Act;`
  line
  line `(p) “ship” includes a sailing vessel;`
  line
  line `(q) “vessel” includes every description of water craft used or capable of being used in the marine`
  line `environment, such as ship, boat, sailing vessel, fishing vessel, submersible, semi-submersible,`
  line `hydrofoils, non-displacement crafts, amphibious crafts, wing-in-ground crafts, pleasure crafts, barges,`
  line `lighters, mobile offshore drilling units or mobile offshore units;`
  line
  line `(r) “vessel traffic service” means a service implemented under this Act to improve the safety and`
  line `efficiency of vessel traffic and to protect the environment`
  line
  line `(2) Words and expressions used but not defined in this Act, and defined in the Merchant Shipping Act,`
  line `1958 (44 of 1958), shall have the same meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (64628)
  sectionNo (3)
  orderNo 3
  title `Power to designate general aid to navigation.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64628&sectionno=3&orderno=3&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_3_content:
  string
  line `The Central Government may, by notification in`
  line `the Official Gazette, designate any aid to navigation to be a general aid to navigation.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (64629)
  sectionNo (4)
  orderNo 4
  title `Appointment of Director General, Deputy Director Generals and Directors.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64629&sectionno=4&orderno=4&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_4_content:
  string
  line `(1) The Central`
  line `Government shall, by notification in the Official Gazette, appoint,—`
  line
  line `(a) the Director General;`
  line
  line `(b) Deputy Director Generals; and`
  line
  line `(c) Directors for districts.`
  line
  line `(2) For the purposes of sub-section (1), the Central Government may demarcate such areas to be`
  line districts.
  line
  line `(3) Every officer appointed under sub-section (1) shall discharge his functions under the general`
  line `superintendence and control of the Director General.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (64630)
  sectionNo (5)
  orderNo 5
  title `Duties of Director General.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64630&sectionno=5&orderno=5&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_5_content:
  string
  line `The Director General shall advise the Central Government on`
  line `matters relating to aids to navigation and perform such other duties as may be prescribed by the Central`
  line `Government under this Act or in any other law for the time being in force.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (64631)
  sectionNo (6)
  orderNo 6
  title `Central Advisory Committee.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64631&sectionno=6&orderno=6&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_6_content:
  string
  line `(1) The Central Government shall, by notification in the Official`
  line `Gazette, appoint a Central Advisory Committee.`
  line
  line `(2) The Central Government shall consult the Central Advisory Committee in regard to—`
  line
  line `(a) the establishment or position of aids to navigation or of any works appertaining thereto; or`
  line
  line `(b) additions to or the alteration or removal of, any aid to navigation; or`
  line
  line `(c) variations to any aid to navigation or of the mode of use thereof; or`
  line
  line `(d) the cost of any proposal relating to aids to navigation; or`
  line
  line `(e) appointment of any sub-committee under sub-section (3); or`
  line
  line `(f) the making or alteration of any rules or rates of marine aids to navigation dues under this Act.`
  line
  line `(3) The Central Government may, if it deems necessary, appoint sub-committees for the purposes of`
  line `advising it in regard to any of the matters specified under this Act.`
  line
  line `(4) The Central Advisory Committee and the sub-committees referred to in sub-section (3) shall`
  line `consist of such persons representing the interests affected by this Act or having special knowledge of the`
  line `subject matter thereof.`
  line
  line `(5) The procedure and conduct of business of the Central Advisory Committee and the sub-committees`
  line `referred to in sub-section (3) shall be such as may be prescribed.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (64632)
  sectionNo (7)
  orderNo 7
  title `Proceedings of Central Advisory Committee not to be invalidated.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64632&sectionno=7&orderno=7&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_7_content:
  string
  line `No act or proceeding of`
  line `the Central Advisory Committee shall be invalidated merely by reason of—`
  line
  line `(a) any vacancy in, or any defect in its constitution; or`
  line
  line `(b) any defect in appointment of a person acting as its member; or`
  line 7
  line
  line `(c) any irregularity in its procedure not affecting the merits of the case.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (64633)
  sectionNo (8)
  orderNo 8
  title `Management of general aids to navigation.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64633&sectionno=8&orderno=8&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_8_content:
  string
  line `The development, maintenance and management of`
  line `all general aids to navigation shall be vested in the Central Government.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (64634)
  sectionNo (9)
  orderNo 9
  title `Powers of Central Government relating to aids to navigation.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64634&sectionno=9&orderno=9&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government,`
  line `shall have the following powers relating to the development, maintenance and management of general`
  line `aids to navigation, namely:—`
  line
  line `(a) establish and maintain aids to navigation;`
  line
  line `(b) add to, alter or remove any aid to navigation;`
  line
  line `(c) alter or vary any aid to navigation;`
  line
  line `(d) authorise to inspect any aid to navigation which may affect the safety of navigation;`
  line
  line `(e) authorise to enter any property, whether public or private, for the purposes of inspection of any`
  line `aid to navigation;`
  line
  line `(f) transport, or cause to be transported, any goods through any property, whether public or private,`
  line `for any purpose in connection with—`
  line
  line `(i) the maintenance of an aid to navigation; or`
  line
  line `(ii) the establishment of any aid to navigation;`
  line
  line `(g) acquire any land as may be necessary for the purposes of this Act—`
  line
  line `(i) to exercise its powers; or`
  line
  line `(ii) for the maintenance of works.`
  line
  line `(2) The Central Government shall, for the purposes of exercising its powers under sub-section (1),`
  line `authorise any of the officers referred to in sub-section (1) of section 4, by general or special order in`
  line writing
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (64635)
  sectionNo (10)
  orderNo 10
  title `Management of vessel traffic services.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64635&sectionno=10&orderno=10&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_10_content:
  string
  line `(1) The development, maintenance and management of`
  line `vessel traffic services shall be vested in the Central Government.`
  line
  line `(2) For the purposes of sub-section (1), the Central Government may, by order, authorise any person as`
  line `vessel traffic service provider.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (64636)
  sectionNo (11)
  orderNo 11
  title `Powers of Central Government relating to vessel traffic services.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64636&sectionno=11&orderno=11&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_11_content:
  string
  line `The Central Government,`
  line `shall have the following powers relating to the development, maintenance and management of vessel`
  line `traffic services, namely:—`
  line
  line `(a) declare and authorise vessel traffic service provider to operate a vessel traffic service within an`
  line `authorised area;`
  line
  line `(b) accredit and approve vessel traffic service training and certification;`
  line
  line `(c) establish and operate vessel traffic services, where it deems necessary;`
  line
  line `(d) add to or alter or require any person to add to or alter any aspect of a vessel traffic service.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (64637)
  sectionNo (12)
  orderNo 12
  title `Competent Authority for Vessel Traffic Services.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64637&sectionno=12&orderno=12&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_12_content:
  string
  line `(1) The Central Government shall, for the`
  line `purposes of exercising its powers under section 11, appoint a Competent Authority for Vessel Traffic`
  line `Services by notification in the Official Gazette.`
  line
  line `(2) The manner of appointment of the Competent Authority shall be such as may be prescribed.`
  line
  line `(3) The Competent Authority shall discharge such functions in such manner, as may be prescribed.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (64638)
  sectionNo (13)
  orderNo 13
  title `Standards for establishment and operation of vessel traffic services.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64638&sectionno=13&orderno=13&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_13_content:
  string
  line `The standards for`
  line `establishing and operating vessel traffic services in India shall be such, as may be prescribed.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (64639)
  sectionNo (14)
  orderNo 14
  title `Power to inspect local aids to navigation.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64639&sectionno=14&orderno=14&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_14_content:
  string
  line `(1) The Central Government may authorise any`
  line `officer referred to in sub-section (1) of section 4 in writing, to enter upon at any time and inspect any`
  line `local aid to navigation and make such inquiries in respect thereof or of the management thereof as such`
  line `officer thinks fit.`
  line
  line `(2) Every person having the charge of, or concerned in the management of, any local aid to navigation`
  line `shall furnish to the officer authorised under sub-section (1) to inspect such aid to navigation, all such`
  line `information as the officer may require.`
  line
  line `(3) Every local authority shall furnish to the Central Government all such returns and other`
  line `information in respect of the aids to navigation under its supervision and management, or of any of them,`
  line `as the Central Government may require.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (64677)
  sectionNo (15)
  orderNo 15
  title `Control of local aids to navigation by Central Government.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64677&sectionno=15&orderno=15&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_15_content:
  string
  line `(1) If the Central Government is`
  line `satisfied, after an inspection under section 14 or such other inquiry, that a direction under this sub-section`
  line `is necessary or expedient for the safety, or otherwise, in the interests of vessels, it may direct any local`
  line authority---
  line
  line `(a) to remove or discontinue or to refrain from moving or discontinuing any aid to navigation under`
  line `its superintendence and management or to make or refrain from making any variation in the character`
  line `or mode of use of any such aid to navigation; or`
  line
  line `(b) to erect, place or maintain, or to refrain from erecting, placing or maintaining any aid to`
  line `navigation within the local limits within which the local authority exercises its powers.`
  line
  line `(2) A local authority shall not erect, place, remove or discontinue any aid to navigation or vary the`
  line `character or mode of use of any aid to navigation, unless it has given to the Central Government at least`
  line `one months notice in writing of its intention so to do:`
  line
  line `Provided that, in cases of emergency, a local authority may take such action as it deems necessary and`
  line `shall give immediate notice of the same to the Central Government and, so far as is possible, to all vessels`
  line `approaching or in the vicinity of such aid to navigation.`
  line
  line `(3) If any local authority---`
  line
  line `(a) fails to comply with any direction made under sub-section (1); or`
  line
  line `(b) fails to exercise or perform, or exercises or performs in an improper, inefficient or unsuitable`
  line `manner, any power or duty relating to the superintendence or management of any aid to navigation`
  line `conferred or imposed upon it by or under any law for the time being in force; or`
  line
  line `(c) fails to make adequate financial provision for the performance of any such duty,`
  line
  line `the Central Government may, by order in writing, require such local authority to comply with the`
  line `direction, or to make arrangements to the satisfaction of that Government for the proper exercise of the`
  line `power or performance of the duty, or to make financial provision to the satisfaction of that Government`
  line `for the performance of the duty, as the case may be, within such period as it may specify.`
  line
  line `(4) If the local authority fails to comply with an order made under sub-section (3) within the specified`
  line `period or within such further time as the Central Government may allow, the Central Government may`
  line `exercise the power or perform the duty or make the requisite financial provision, as the case may be, and`
  line `the local authority shall be liable to reimburse to the Central Government any expenditure incurred by it`
  line `in so doing.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (64678)
  sectionNo (16)
  orderNo 16
  title `Management of local aids to navigation by Central Government.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64678&sectionno=16&orderno=16&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_16_content:
  string
  line `The Central Government`
  line `may, at the request of a local authority, undertake the superintendence and management of any local aids`
  line `to navigation on its behalf, and the local authority shall pay to the Central Government such sums to`
  line `defray the cost of superintendence and management, as may be agreed.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (64641)
  sectionNo (17)
  orderNo 17
  title `Power of Central Government to remove or alter obstructions to aids to navigation.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64641&sectionno=17&orderno=17&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_17_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette, specify restrictions on activities that`
  line `interfere with or obstruct the operation of any aid to navigation within the specified distance of such aid to`
  line navigation.
  line
  line `(2) Notwithstanding anything contained in any other law for the time being in force, where the`
  line `functioning of any aid to navigation or vessel traffic service is being obstructed, directly or indirectly, the`
  line `Central Government may, if it deems fit, issue such directions as may be necessary for the removal or`
  line `alteration of such obstruction.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (64679)
  sectionNo (18)
  orderNo 18
  title `Power of Central Government to train and certify operators of aids to navigation and vessel traffic services.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64679&sectionno=18&orderno=18&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_18_content:
  string
  line `(1) No person shall be allowed to operate or work on, including any ancillary activities`
  line `as may be prescribed, any aid to navigation in any place unless he holds a valid training certificate`
  line `certifying that such person has been trained in the operation of such aid to navigation.`
  line
  line `(2) No person shall be allowed to operate or work on, including any ancillary activities as may be`
  line `prescribed, a vessel traffic service in any place unless he holds a valid training certificate certifying that`
  line `such person has been trained in the operation of vessel traffic services.`
  line
  line `(3) A certificate of training issued under this Act shall be valid and effective throughout the territory of`
  line India.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (64643)
  sectionNo (19)
  orderNo 19
  title Certification.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64643&sectionno=19&orderno=19&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_19_content:
  string
  line `A certificate mentioned in sub-sections (1) and (2) of section 18 shall be issued by`
  line `an accredited training organisation referred to in section 20, in such form, subject to such conditions and`
  line `in such manner, as may be prescribed.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (64644)
  sectionNo (20)
  orderNo 20
  title `Accreditation of training organisations.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64644&sectionno=20&orderno=20&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_20_content:
  string
  line `(1) The Central Government shall accredit training`
  line `organisations for imparting training to, or conduct assessments of, persons in the operation of aids to`
  line `navigation and vessel traffic services.`
  line
  line `(2) The Central Government shall accredit such training organisations which meet the criteria, as may`
  line `be prescribed, for imparting training to trainees or conduct assessment of persons in the operation of aids`
  line `to navigation and vessel traffic services.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (64645)
  sectionNo (21)
  orderNo 21
  title `Marking of wrecks.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64645&sectionno=21&orderno=21&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_21_content:
  string
  line `The Central Government may, if considers necessary, give directions to any`
  line `officer referred to in sub-section (1) of section 4 to mark any wreck in such manner as may be prescribed.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (64646)
  sectionNo (22)
  orderNo 22
  title `Reimbursement for marking wrecks.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64646&sectionno=22&orderno=22&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_22_content:
  string
  line `The cost for marking the wreck shall be borne by or`
  line `recovered from the owner or the operator of such vessel in such manner as may be prescribed.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (64647)
  sectionNo (23)
  orderNo 23
  title `Power of Central Government to designate any aid to navigation as heritage lighthouse.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64647&sectionno=23&orderno=23&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_23_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette, designate any aid to navigation`
  line `under its control as a heritage lighthouse.`
  line
  line `(2) The Central Government shall develop the heritage lighthouses designated under sub-section (1),`
  line `in addition to their function as aids to navigation or otherwise, for educational, cultural and tourism`
  line `purposes, in such manner as may be prescribed.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (64648)
  sectionNo (24)
  orderNo 24
  title `Levy and collection of marine aids to navigation dues.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64648&sectionno=24&orderno=24&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_24_content:
  string
  line `(1) There shall be levied and collected`
  line `the marine aids to navigation dues, at such rates, as the Central Government may, by notification in the`
  line `Official Gazette, specify from time to time.`
  line
  line `(2) The marine aids to navigation dues levied under sub-section (1) shall be collected by the proper`
  line `officer in respect of every ship arriving at or departing from any port in India, from such person, in such`
  line `manner and at such time, as may be prescribed.`
  line
  line `(3) The proceeds of the marine aids to navigation dues collected shall be credited to the Consolidated`
  line `Fund of India in such manner as may be prescribed.`
  line
  line `(4) Every owner causing any ship to arrive at or depart from any port in India shall, self-assessing its`
  line `liability to pay dues, file a return before the proper officer in such form and manner, as may be prescribed.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (64649)
  sectionNo (25)
  orderNo 25
  title `Utilisation of marine aids to navigation dues.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64649&sectionno=25&orderno=25&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_25_content:
  string
  line `The marine aids to navigation dues levied under`
  line `this Act shall be utilised for fulfilling the obligations and carrying out the purposes of this Act.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (64650)
  sectionNo (26)
  orderNo 26
  title `Receipts relating to marine aids to navigation dues and their verification.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64650&sectionno=26&orderno=26&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_26_content:
  string
  line `(1) The owner`
  line `shall credit the marine aids to navigation dues into the account of the Central Government in such manner`
  line `as may be prescribed.`
  line
  line `(2) The payment of marine aids to navigation dues shall be verified by the proper officer in respect`
  line of.--
  line
  line `(a) the port at which the marine aids to navigation dues has been paid;`
  line
  line `(b) the amount of the payment;`
  line
  line `(c) the date on which the marine aids to navigation dues became payable; and`
  line
  line `(d) the name, tonnage and other proper description of the ship in respect of which the payment is`
  line made,
  line
  line `for the purpose of granting clearance.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (64651)
  sectionNo (27)
  orderNo 27
  title `Assessment of marine aids to navigation dues and ascertainment of tonnage.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64651&sectionno=27&orderno=27&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_27_content:
  string
  line `(1) The proper`
  line `officer to whom the return has been furnished under sub-section (4) of section 24 shall, after making or`
  line `causing to be made such inquiry as he thinks fit and after satisfying himself that the particulars stated in`
  line `the return are correct, by order, assess the amount of marine aids to navigation dues payable by the owner`
  line `or the master of the ship.`
  line
  line `(2) If the return has not been furnished to the proper officer under sub-section (4) of section 24, he`
  line `shall, after making or causing to be made such inquiry as he thinks fit, by order, assess the amount of`
  line `marine aids to navigation dues payable by the owner or the master of the ship.`
  line
  line `(3) For the purposes of levy of marine aids to navigation dues, the tonnage of a ship or sailing vessel`
  line `shall be reckoned as under the Merchant Shipping Act, 1958 (44 of 1958), for such dues payable on a`
  line `ship’s tonnage including the tonnage of any space added under the said Act to the tonnage of ships by`
  line `reason of such space being utilised for carrying cargo.`
  line
  line `(4) In order to ascertain the tonnage of any ship for the purpose of levying marine aids to navigation`
  line `dues, the proper officer may, if he deems it fit, require the production of any documents, the appearance`
  line `of any person and the inspection of any vessel, in such manner as may be prescribed.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (64652)
  sectionNo (28)
  orderNo 28
  title `Recovery of marine aids to navigation dues.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64652&sectionno=28&orderno=28&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_28_content:
  string
  line `(1) If the owner of any ship refuses or neglects to`
  line `pay the amount of marine aids to navigation dues payable under this Act in respect of the ship, the proper`
  line `officer may seize the ship along with its equipment or any part thereof, and detain the same until the`
  line `amount of the marine aids to navigation dues, together with the costs of the seizure and detention is paid.`
  line
  line `(2) If any part of such marine aids to navigation dues remains unpaid after the expiry of thirty days`
  line `following the date of the seizure, the proper officer may cause the ship or other thing seized to be sold,`
  line `and with the proceeds of the sale may satisfy the marine aids to navigation dues remaining unpaid,`
  line `together with the costs of the sale and shall repay the surplus, if any, to the person by whom the same`
  line `were payable.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (64653)
  sectionNo (29)
  orderNo 29
  title `Refusal of port clearance.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64653&sectionno=29&orderno=29&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_29_content:
  string
  line `The officer whose duty it is to grant a port clearance for any ship`
  line `shall not grant the port clearance until the amount of marine aids to navigation dues payable in respect of`
  line `the ship under this Act and of any fines imposed thereunder has been paid, or until security for the`
  line `payment thereof has been given to his satisfaction.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (64654)
  sectionNo (30)
  orderNo 30
  title `Determination of disputes as to liability for payment.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64654&sectionno=30&orderno=30&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_30_content:
  string
  line `If any dispute arises as to whether`
  line `marine aids to navigation dues, expenses or costs are payable in respect of any ship under this Act or as to`
  line `the amount of such dues, expenses or costs, such dispute shall, on an application made in this behalf by`
  line `either of the disputing parties, be heard and determined by a civil court having jurisdiction at the place`
  line `where the dispute arose.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (64655)
  sectionNo (31)
  orderNo 31
  title `Marine aids to navigation dues payable at one port recoverable at another.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64655&sectionno=31&orderno=31&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_31_content:
  string
  line `(1) If the master`
  line `of any ship in respect of which marine aids to navigation dues is payable at any port causes the ship to`
  line `leave such port without having paid such dues, the proper officer at that port may, by writing, require the`
  line `proper officer at any other port in India to which the ship may proceed, to recover the marine aids to`
  line `navigation dues remaining unpaid.`
  line
  line `(2) Any proper officer to whom such a requisition is directed, shall proceed to levy such sum as if it`
  line `were payable under this Act at the port at which he is the proper officer, and a certificate by the proper`
  line `officer at the port at which the marine aids to navigation dues first became payable, stating the amount`
  line `payable, shall be sufficient proof in any proceeding under this Act that such amount is payable.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (64656)
  sectionNo (32)
  orderNo 32
  title Exemption.
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64656&sectionno=32&orderno=32&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_32_content:
  string
  line `The Central Government may, by notification in the Official Gazette, exempt.--`
  line
  line `(a) any ship belonging to the Central Government or any State Government, which is not carrying`
  line `cargo or passengers for freight or fares; or`
  line
  line `(b) any other ship, or classes of ships or ships performing specified voyages,`
  line
  line `from the payment of marine aids to navigation dues either wholly or to such extent as may be specified in`
  line `that notification.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (64657)
  sectionNo (33)
  orderNo 33
  title `Refund of excess payments.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64657&sectionno=33&orderno=33&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_33_content:
  string
  line `Where the marine aids to navigation dues has been paid in respect`
  line `of any ship in excess of the amount payable under this Act, no claim to refund of such excess payment`
  line `shall be admissible, unless it is made within six months from the date of such payment.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (64658)
  sectionNo (34)
  orderNo 34
  title Fees.
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64658&sectionno=34&orderno=34&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_34_content:
  string
  line `The fees to be charged for providing assistance to ships for rendering special services to`
  line `vessels shall be at such rates as may be prescribed.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (64659)
  sectionNo (35)
  orderNo 35
  title `Receipt and expenditure.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64659&sectionno=35&orderno=35&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_35_content:
  string
  line `The Central Government shall cause to be maintained a separate`
  line `account of all amounts received by way of marine aids to navigation dues, expenses, costs and fines under`
  line `this Act and of all expenditure incurred for the purposes of this Act, and shall cause such account to be`
  line `laid before the Central Advisory Committee, as soon as possible after the close of each financial year.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (64660)
  sectionNo (36)
  orderNo 36
  title `Annual report.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64660&sectionno=36&orderno=36&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_36_content:
  string
  line `(1) The Central Government shall cause to be laid before the Central Advisory`
  line `Committee before the close of each financial year a statement of the estimated receipts under, and`
  line `expenditure for the purposes of this Act, during the forthcoming year.`
  line
  line `(2) The statement of estimated receipts and expenditure shall be prepared in consultation with the`
  line `Comptroller and Auditor-General of India, in such manner as may be prescribed.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (64661)
  sectionNo (37)
  orderNo 37
  title `Intentionally obstructing aids to navigation or vessel traffic services.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64661&sectionno=37&orderno=37&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_37_content:
  string
  line `(1) Whoever,`
  line `intentionally commits any act or omits to do any act, which results in obstruction of, or reduction in, or`
  line `limitation of, the effectiveness of, any aid to navigation or vessel traffic service, shall be liable to`
  line `imprisonment for a term which may extend up to six months or with fine which may extend up to one`
  line `lakh rupees, or with both.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no person shall be liable for punishment, if`
  line that.---
  line
  line `(a) act or omission was necessary to save a life or a vessel; and`
  line
  line `(b) such person took all reasonable steps to avoid the obstruction, reduction or limitation.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (64662)
  sectionNo (38)
  orderNo 38
  title `Negligently obstructing aids to navigation or vessel traffic services.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64662&sectionno=38&orderno=38&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_38_content:
  string
  line `(1) Whoever, negligently`
  line `commits any act or omits to do any act, which results in obstruction of, or reduction in, or limitation of,`
  line `the effectiveness of, any aid to navigation or vessel traffic service, shall be liable to imprisonment for a`
  line `term which may extend up to three months or with fine which may extend up to fifty thousand rupees, or`
  line `with both.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no person shall be liable for punishment, if`
  line that.
  line
  line `(a) act or omission was necessary to save a life or a vessel; and`
  line
  line `(b) such person took all reasonable steps to avoid the obstruction, reduction or limitation.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (64663)
  sectionNo (39)
  orderNo 39
  title `Intentionally destroying or damaging aids to navigation or vessel traffic services.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64663&sectionno=39&orderno=39&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_39_content:
  string
  line `(1)`
  line `Whoever, intentionally commits any act or omits to do any act, which results in damage to or destruction`
  line
  line `of any aid to navigation or vessel traffic service, shall be liable to imprisonment for a term which may`
  line `extend up to twelve months or with fine which may extend up to five lakh rupees, or with both.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no person shall be liable for punishment, if`
  line that
  line
  line `(a) act or omission was necessary to save a life or a vessel; and`
  line
  line `(b) such person took all reasonable steps to avoid the damage or destruction.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (64664)
  sectionNo (40)
  orderNo 40
  title `Negligently destroying or damaging aids to navigation or vessel traffic services.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64664&sectionno=40&orderno=40&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_40_content:
  string
  line `(1)`
  line `Whoever, negligently commits any act or omits to do any act, which results in damage to or destruction of`
  line `any aid to navigation or vessel traffic service, shall be liable to imprisonment for a term which may`
  line `extend up to six months or with fine which may extend up to one lakh rupees, or with both.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no person shall be liable for punishment, if`
  line that—
  line
  line `(a) act or omission was necessary to save a life or a vessel; and`
  line
  line `(b) such person took all reasonable steps to avoid the damage or destruction.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (64665)
  sectionNo (41)
  orderNo 41
  title `Causing damage to heritage lighthouse.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64665&sectionno=41&orderno=41&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_41_content:
  string
  line `(1) Whoever, commits any act or omits to do any act,`
  line `which results in damage to or destruction of any heritage lighthouse, shall be liable to imprisonment for a`
  line `term which may extend up to six months or with fine which may extend up to one lakh rupees, or with`
  line both.
  line
  line `(2) Notwithstanding anything contained in sub-section (1), no person shall be liable for punishment, if`
  line that.—
  line
  line `(a) act or omission was necessary to save a life or a vessel; and`
  line
  line `(b) such person took all reasonable steps to avoid the destruction, fouling, damage, reduction or`
  line limitation.
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (64666)
  sectionNo (42)
  orderNo 42
  title `Evading payment of marine aids to navigation dues.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64666&sectionno=42&orderno=42&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_42_content:
  string
  line `Every owner or master of a ship, who`
  line `evades or attempts to evade the payment of marine aids to navigation dues, expenses or costs payable in`
  line `respect of the ship under this Act, shall be liable for fine, which may extend up to five times the amount`
  line `of the sum so payable.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (64667)
  sectionNo (43)
  orderNo 43
  title `Noncompliance with directions of vessel traffic service provider.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64667&sectionno=43&orderno=43&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_43_content:
  string
  line `Every owner or master of`
  line `a ship, who fails to comply with any direction issued by a vessel traffic service provider relating to a`
  line `vessel traffic service under this Act, shall be liable to fine which may extend up to one lakh rupees.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (64668)
  sectionNo (44)
  orderNo 44
  title `Cognizance of offences.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64668&sectionno=44&orderno=44&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_44_content:
  string
  line `(1) No court shall take cognizance of any offence under this Act,`
  line `except upon a complaint in writing made by any officer authorised in this behalf by the Central`
  line Government.
  line
  line `(2) No court inferior to that of a Metropolitan Magistrate or a Judicial Magistrate of the first class shall`
  line `try any offence under this Act.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (64669)
  sectionNo (45)
  orderNo 45
  title `Place of trial and jurisdiction of court.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64669&sectionno=45&orderno=45&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_45_content:
  string
  line `Whoever, commits any offence under this Act or any`
  line `rules made thereunder, may ordinarily be inquired into and tried by a court within whose local`
  line jurisdiction—
  line
  line `(a) such offence was committed; or`
  line
  line `(b) such person may be found; or`
  line
  line `(c) in any court which the Central Government may, by notification, direct in this behalf; or`
  line
  line `(d) in any court in which he might be tried under any other law for time being in force.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (64670)
  sectionNo (46)
  orderNo 46
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64670&sectionno=46&orderno=46&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_46_content:
  string
  line `(1) The Central Government may, after previous`
  line `publication, make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:—`
  line
  line `(a) duties of the Director General under section 5;`
  line
  line `(b) procedure and conduct of business of Central Advisory Committee and sub-committees`
  line `constituted under sub-section (5) of section 6;`
  line
  line `(c) manner of appointment of the Competent Authority under sub-section (2) and its functions`
  line `under sub-section (3), of section 12;`
  line
  line `(d) standards for establishment and operation of vessel traffic services under section 13;`
  line
  line `(e) ancillary activities relating to aids to navigation under sub-section (1) and ancillary activities`
  line `relating to vessel traffic services under sub-section (2), of section 18;`
  line
  line `(f) form and manner of certificate, to be issued and the conditions subject to which such certificate`
  line `is to be issued by the accredited training organisation and validated by the Director General under`
  line `section 19;`
  line
  line `(g) criteria for accreditation of training organisation under sub-section (2) of section 20;`
  line
  line `(h) manner of marking wrecks under section 21;`
  line
  line `(i) manner of recovering cost from the owner of the vessel for marking the wreck under section 22;`
  line
  line `(j) development of heritage lighthouses designated under sub-section (2) of section 23;`
  line
  line `(k) manner of, collection of marine aids to navigation dues by proper officer levied under subsection (2) and crediting the proceeds of the dues so collected under sub-section (3), of section 24;`
  line
  line `(l) form and manner of filing return under sub-section (4) of section 24;`
  line
  line `(m) manner of payment of marine aids to navigation dues to the Central Government under subsection (1) of section 26;`
  line
  line `(n) manner of production of documents, appearance of any person and inspection of any vessel by`
  line `proper officer under sub-section (4) of section 27;`
  line
  line `(o) rates of fees for special services under section 34;`
  line
  line `(p) form and manner of statement of estimated receipts and expenditure to be prepared in`
  line `consultation with the Comptroller and Auditor-General of India under sub-section (2) of section 36;`
  line
  line `(q) any other matter which is required to be, or may be, prescribed, for the purposes of carrying out`
  line `the purposes of this Act.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (64671)
  sectionNo (47)
  orderNo 47
  title `Delegation of powers by Central Government.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64671&sectionno=47&orderno=47&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_47_content:
  string
  line `The Central Government may delegate to any`
  line `of its officers all or any of the functions and powers conferred upon it under this Act.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (64672)
  sectionNo (48)
  orderNo 48
  title `Power of Central Government to issue directions.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64672&sectionno=48&orderno=48&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_48_content:
  string
  line `(1) Notwithstanding anything contained in`
  line `this Act, the Director General shall, in the discharge of his functions and duties under this Act, be bound`
  line `by such directions on questions of policy as the Central Government may give to him in writing from`
  line `time to time.`
  line
  line `(2) The decision of the Central Government whether a question is one of policy or not shall be final.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_48_a:
  sectionId (105606)
  sectionNo 48A
  orderNo 49
  title `Power of Director-General appointed under Merchant Shipping Act, 2025 to issue directions.`
  content obj_root_law_sections_48_a_content
  footnotes `1. Ins. by Act 24 of 2025, s. 325 (w.e.f. 15-3-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=105606&sectionno=48A&orderno=49&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_48_a_content:
  string
  line `^1[48A. Power of Director-General appointed under Merchant Shipping Act, 2025 to issue`
  line `directions.---The Director-General appointed under the Merchant Shipping Act, 2025 may issue such`
  line `directions as may be necessary, to the Director General appointed under this Act for the purposes of`
  line `implementation of this Act.]`
obj_root_law_sections_49:
  sectionId (64673)
  sectionNo (49)
  orderNo 50
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64673&sectionno=49&orderno=50&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_49_content:
  string
  line `No suit, prosecution or other proceedings shall lie`
  line `against the Central Government or any officer appointed under this Act for anything done or in good faith`
  line `purporting to be done under this Act or the rules made thereunder.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (64674)
  sectionNo (50)
  orderNo 51
  title `Power to remove difficulties.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64674&sectionno=50&orderno=51&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_50_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (64675)
  sectionNo (51)
  orderNo 52
  title `Laying of rules and notifications before Parliament.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64675&sectionno=51&orderno=52&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_51_content:
  string
  line `Every rule made and every notification`
  line `issued under this Act shall be laid, as soon as may be after it is made or issued, before each House of`
  line `Parliament while it is in session for a total period of thirty days which may be comprised in one session or`
  line `in two or more successive sessions, and if, before the expiry of the session immediately following the`
  line `session or the successive sessions aforesaid, both Houses agree in making any modification in such rule,`
  line `or notification or both Houses agree that the rule, should not be made or the notification should not be`
  line `issued, the rule or notification shall thereafter have effect only in such modified form or be of no effect, as`
  line `the case may be; so, however, that any such modification or annulment shall be without prejudice to the`
  line `validity of anything previously done under that rule or notification.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (64676)
  sectionNo (52)
  orderNo 53
  title `Repeal and savings.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00003_202120_1648026775700&sectionId=64676&sectionno=52&orderno=53&orgactid=AC_CEN_198_0_00003_202120_1648026775700
obj_root_law_sections_52_content:
  string
  line `(1) The Lighthouse Act, 1927 (17 of 1927) is hereby repealed.`
  line
  line `(2) Notwithstanding the repeal of the Lighthouse Act, 1927 (17 of 1927) (herein referred to as the`
  line `repealed Act), —`
  line
  line `(a) any notification, rule, regulation, bye-law, order or exemption issued, made or granted under the`
  line `repealed Act shall, until revoked, have effect as if it had been issued, made or granted under the`
  line `provisions of this Act;`
  line
  line `(b) any office established or created, officer appointed and anybody elected or constituted under the`
  line `repealed Act shall continue and shall be deemed to have been established, created, appointed, elected,`
  line `or constituted, as the case may be, under this Act;`
  line
  line `(c) any document referring to the repealed Act shall be construed as referring to this Act or to the`
  line `provision of this Act;`
  line
  line `(d) any fine levied under the repealed Act may be recovered as if it had been levied under this Act;`
  line
  line `(e) any offence committed under the repealed Act may be prosecuted and punished as if it had been`
  line `committed under this Act;`
  line
  line `(f) any proceeding pending before any court under the repealed Act may be tried or disposed of`
  line `under the corresponding provisions of this Act;`
  line
  line `(g) the officers appointed under the provisions of the repealed Act and continuing during the`
  line `commencement of this Act shall continue as if they have been appointed under this Act;`
  line
  line `(h) any person appointed under or by virtue of the repealed Act shall be deemed to have been`
  line `appointed to that office under or by virtue of this Act;`
  line
  line `(i) any inspection, investigation or inquiry ordered to be done under the provisions of the repealed`
  line `Act shall continue to be proceeded with as if such inspection, investigation or inquiry was ordered to`
  line `be done under the corresponding provisions of this Act.`
obj_root_law_sections_52_footnotes:
  string
  line
