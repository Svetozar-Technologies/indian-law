obj_root_law_sections_2:
  sectionId (42401)
  sectionNo (2)
  orderNo 2
  title `Limits of ordinary original civil jurisdiction.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00030_191915_1523343136342&sectionId=42401&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00030_191915_1523343136342
obj_root_law_sections_2_content:
  string
  line `The ordinary original civil jurisdiction of the`
  line `High Court of Judicature at Fort William in Bengal shall be exercised within the limits set out in the`
  line Schedule;
  line
  line `Provided that nothing in this Act shall affect any suit or other legal proceeding pending in any Court`
  line `at the date of the commencement of this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
