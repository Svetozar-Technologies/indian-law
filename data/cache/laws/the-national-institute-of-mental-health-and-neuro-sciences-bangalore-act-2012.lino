obj_root_law_sections_1:
  sectionId (6348)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6348&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Institute of Mental`
  line `Health and Neuro-Sciences, Bangalore Act, 2012.`
  line
  line `(2) It shall come into force on such date ^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1 29th November, 2013, vide notification No S.O. 3534(E), dated 29th November, 2013 see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (6349)
  sectionNo (2)
  orderNo 2
  title `Declaration of National Institute of Mental Health and Neuro-Sciences, Bangalore, as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6349&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the National Institute of Mental Health and`
  line `Neuro-Sciences, Bangalore are such as to make the institution one of national importance, it is hereby`
  line `declared that the National Institute of Mental Health and Neuro-Sciences, Bangalore is an institution of`
  line `national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (6350)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6350&sectionno=3&orderno=3&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Fund" means the Fund of the Institute referred to in section 17;`
  line
  line `(b) "Governing Body" means the Governing Body of the Institute;`
  line
  line `(c) "Institute" means the institution known as the National Institute of Mental Health and NeuroSciences,`
  line `Bangalore, incorporated under this Act;`
  line
  line `(d) "member" means a member of the Institute;`
  line
  line `(e) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(f) "specified" means specified by regulations made under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (6351)
  sectionNo (4)
  orderNo 4
  title `Incorporation of Institute.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6351&sectionno=4&orderno=4&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_4_content:
  string
  line `The National Institute of Mental Health and Neuro-Sciences,`
  line `Bangalore, an Institute registered under the Karnataka Societies Registration Act, 1960 (Karnataka Act,`
  line `XVII of 1960) on the 27th day of December, 1974, is hereby constituted a body corporate by the name`
  line `aforesaid and as such body corporate, it shall have perpetual succession and a common seal with power,`
  line `subject to the provisions of this Act, to acquire, hold and dispose of property and to contract and shall, by`
  line `that name, sue and be sued.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (6352)
  sectionNo (5)
  orderNo 5
  title `Composition of Institute.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6352&sectionno=5&orderno=5&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_5_content:
  string
  line `(1) The Institute shall consist of the following members, namely:--`
  line
  line `(a) the Minister of Health and Family Welfare, ex officio;`
  line
  line `(b) the Minister of Health and Family Welfare (Medical Education), Government of Karnataka,`
  line `ex officio;`
  line
  line `(c) Secretary to the Government of India in the Ministry or Department of Health and Family`
  line `Welfare, ex officio;`
  line
  line `(d) the Director of the Institute, ex officio;`
  line
  line `(e) Secretary to the Government of India or his nominee (not below the rank of Joint Secretary)`
  line `Ministry of Finance, Department of Expenditure, ex officio;`
  line
  line `(f) Secretary to the Government of India or his nominee (not below the rank of Joint Secretary) in`
  line `the Department of Higher Education, Ministry of Human Resource Development, ex officio;`
  line
  line `(g) the Director-General of Health Services, Government of India, ex officio;`
  line
  line `(h) the Vice-Chancellor of Rajiv Gandhi University of Health Sciences, Karnataka, ex officio;`
  line
  line `(i) the Chief Secretary to the Government of Karnataka or his nominee who shall not be below`
  line `the rank of Secretary to that Government;`
  line
  line `(j) seven persons of whom one shall be a non-medical scientist representing the Indian Sciences`
  line `Congress Association, and, one each from biological; behavioural and physical sciences, of repute,`
  line `from any University to be nominated by the Central Government in such manner as may be`
  line prescribed;
  line
  line `(k) four representatives of medical faculties of Indian Universities, of whom one shall be from the`
  line `National Institute of Mental Health and Neuro-Sciences, to be nominated by the Central Government`
  line `in such manner as may be prescribed;`
  line
  line `(l) three Members of Parliament of whom two shall be elected from among themselves by the`
  line `members of the House of the People and one from among themselves by the members of the Council`
  line `of States.`
  line
  line `(2) It is hereby declared that the office of member of the Institute shall not disqualify its holder for`
  line `being chosen as, or for being, a member of either House of Parliament.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (6353)
  sectionNo (6)
  orderNo 6
  title `Term of office of and vacancies among members.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6353&sectionno=6&orderno=6&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_6_content:
  string
  line `(1) Save as otherwise provided in this`
  line `section, the term of office of a member shall be five years from the date of his nomination or election.`
  line
  line `(2) The term of office of a member elected under clause (l) of sub-section (1) of section 5 shall come`
  line `to an end as soon as he becomes a Minister or Minister of State or Deputy Minister or the Speaker or the`
  line `Deputy Speaker of the House of the People or the Deputy Chairman of the Council of States or ceases to`
  line `be a member of the House from which he was elected.`
  line
  line `(3) The term of office of an ex officio member shall continue so long as he holds the office by virtue`
  line `of which he is such a member.`
  line
  line `(4) The term of office of a member nominated or elected to fill a casual vacancy shall continue for the`
  line `remainder of the term of the member in whose place he is nominated or elected.`
  line
  line `(5) An outgoing member other than a member elected under clause (l) of sub-section (1) of section 5`
  line `shall continue in office until another person is nominated as a member in his place or for a period of three`
  line `months, whichever is earlier:`
  line
  line `Provided that the Central Government shall nominate a member in place of an outgoing member`
  line `within the said period of three months.`
  line
  line `(6) An outgoing member shall be eligible for re-nomination or re-election.`
  line
  line `(7) A member may resign his office by writing under his hand addressed to the Central Government`
  line `but he shall continue in office until his resignation is accepted by that Government.`
  line
  line `(8) The manner of filling vacancies among members shall be such as may be prescribed.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (6354)
  sectionNo (7)
  orderNo 7
  title `Powers and functions of President.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6354&sectionno=7&orderno=7&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_7_content:
  string
  line `(1) There shall be a President of the Institute who shall be`
  line `nominated by the Central Government from amongst the members other than the Director of the Institute.`
  line
  line `(2) The President shall exercise such powers and discharge such functions as are laid down in this Act`
  line `or as may be prescribed.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (6355)
  sectionNo (8)
  orderNo 8
  title `Vice-President of Institute.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6355&sectionno=8&orderno=8&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_8_content:
  string
  line `There shall be a Vice-President of the Institute who shall be`
  line `nominated by the Central Government from amongst the members other than the Director of the Institute.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (6356)
  sectionNo (9)
  orderNo 9
  title `Allowances of President, Vice-President and other members.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6356&sectionno=9&orderno=9&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_9_content:
  string
  line `The President, Vice-President`
  line `and other members shall receive such allowances from the Institute as may be prescribed.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (6357)
  sectionNo (10)
  orderNo 10
  title `Meetings of Institute.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6357&sectionno=10&orderno=10&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_10_content:
  string
  line `The Institute shall hold its first meeting at such time and place as may be`
  line `appointed by the Central Government and shall observe such rules of procedure in regard to the`
  line `transaction of business at the first meeting as may be laid down by that Government, and thereafter, the`
  line `Institute shall meet at such times and places and observe such rules of procedure in regard to the`
  line `transaction of business at its meetings as may be specified.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (6358)
  sectionNo (11)
  orderNo 11
  title `Governing Body and other committees of Institute.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6358&sectionno=11&orderno=11&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_11_content:
  string
  line `(1) There shall be a Governing Body of`
  line `the Institute which shall be constituted by the Institute in such manner as may be specified:`
  line
  line `Provided that the number of persons who are not members of the Institute shall not exceed one-third`
  line `of the total membership of the Governing Body.`
  line
  line `(2) The Governing Body shall be the executive committee of the Institute and shall exercise such`
  line `powers and discharge such functions as the Institute may specify in this behalf.`
  line
  line `(3) The President of the Institute shall be the Chairperson of the Governing Body and as Chairperson`
  line `thereof he shall exercise such powers and discharge such functions as may be specified.`
  line
  line `(4) The procedure to be followed in the exercise of its powers and discharge of its functions by the`
  line `Governing Body, and the term of office of, and the manner of filling vacancies among the members of the`
  line `Governing Body shall be such as may be specified.`
  line
  line `(5) Subject to such control and restrictions as may be prescribed, the Institute may constitute as many`
  line `standing committees and as many ad hoc committees as it thinks fit for exercising any power or`
  line `discharging any function of the Institute or for inquiring into, or reporting or advising upon, any matter`
  line `which the Institute may refer to them.`
  line
  line `(6) The Chairperson and members of the Governing Body and the Chairperson and the members of a`
  line `standing committee or an ad hoc committee shall receive such allowances, as may be specified.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (6359)
  sectionNo (12)
  orderNo 12
  title `Staff of Institute.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6359&sectionno=12&orderno=12&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_12_content:
  string
  line `(1) There shall be a chief executive officer of the Institute who shall be`
  line `designated as the Director of the Institute and shall, subject to such rules as may be prescribed, be`
  line `appointed by the Institute:`
  line
  line `Provided that the first Director of the Institute shall be appointed by the Central Government.`
  line
  line `(2) The Director shall hold office for a term of five years from the date on which he enters upon his`
  line `office or until he attains the age of sixty-five years, whichever is earlier.`
  line
  line `(3) The Director shall act as the Secretary to the Institute as well as the Governing Body.`
  line
  line `(4) The Director shall exercise such powers and discharge such functions as may be specified or as`
  line `may be delegated to him by the Institute or the President of the Institute or the Governing Body or the`
  line `Chairperson of the Governing Body.`
  line
  line `(5) Subject to such rules as may be prescribed, the Institute may appoint such number of other`
  line `officers and employees as may be necessary for the exercise of its powers and discharge of its functions`
  line `and the designations and grades of other officers and employees shall be such as may be specified.`
  line
  line `(6) Subject to such rules as may be prescribed, the Director and other officers and employees of the`
  line `Institute shall be entitled to such salary and allowances and shall be governed by such conditions of`
  line `service in respect of leave, pension, provident fund and other matters as may be specified.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (6360)
  sectionNo (13)
  orderNo 13
  title `Objects of Institute.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6360&sectionno=13&orderno=13&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_13_content:
  string
  line `The objects of the Institute shall be--`
  line
  line `(a) to develop patterns of teaching in undergraduate and postgraduate medical education in all its`
  line `branches with a focus on mental health, neuro-sciences and allied specialities so as to demonstrate a`
  line `high standard of medical education;`
  line
  line `(b) to bring together, as far as may be, in one place educational facilities of the highest order for`
  line `the training of personnel in all important branches of health activity;`
  line
  line `(c) to attain self-sufficiency in postgraduate medical education to meet the country's needs for`
  line `specialists and medical teachers, particularly in the field of mental health, neuro-sciences and allied`
  line specialities;
  line
  line `(d) to evolve innovative strategies to offer diagnostic and comprehensive therapeutic service`
  line `facilities in the field of mental health and neuro-sciences, utilising the advances in information`
  line technology;
  line
  line `(e) to make an in-depth study and research in the field of mental health, neuro-sciences and allied`
  line specialities.
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (6361)
  sectionNo (14)
  orderNo 14
  title `Functions of Institute.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6361&sectionno=14&orderno=14&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_14_content:
  string
  line `With a view to the promotion of the objects specified in section 13, the`
  line `Institute may--`
  line
  line `(a) provide for undergraduate and postgraduate teaching in the science of modern medicine and`
  line `other allied sciences including physical and biological sciences;`
  line
  line `(b) provide facilities for research in the various branches of such sciences;`
  line
  line `(c) provide for the teaching of humanities;`
  line
  line `(d) conduct experiments in new methods of medical education, both undergraduate and`
  line `postgraduate, in order to arrive at high standard of such education;`
  line
  line `(e) specify courses and curricula for both undergraduate and postgraduate studies;`
  line
  line `(f) notwithstanding anything contained in any other law for the time being in force, establish and`
  line maintain,--
  line
  line `(i) one or more medical institutions with different departments staffed and equipped to`
  line `undertake education and conduct research in different subjects,`
  line
  line `(ii) one or more well equipped hospitals to provide clinical services,`
  line
  line `(iii) nursing colleges staffed and equipped for the training of nurses,`
  line
  line `(iv) rural and urban health centres which will form centres for the field training of the medical`
  line `and nursing students of the Institute, and`
  line
  line `(v) other institutions for the training of different types of health workers such as`
  line `physiotherapists, occupational therapists and medical technicians of various kinds;`
  line
  line `(g) trained teachers from different medical colleges in India;`
  line
  line `(h) hold examinations and grant such degrees, diplomas and other academic distinctions and titles`
  line `in undergraduate and postgraduate medical, nursing and allied specialities education as may be laid`
  line `down in the regulations;`
  line
  line `(i) induct and appoint persons as professors, readers, lecturers and in posts of other description in`
  line `accordance with regulations;`
  line
  line `(j) receive grants from the Government and gifts, donations, benefactions, bequests and transfers`
  line `of properties, both movable and immovable, from donors, benefactors, testators or transferors, as the`
  line `case may be;`
  line
  line `(k) deal with any property belonging to, or vested in, the Institute in any manner which is`
  line `considered necessary for promoting the objects specified in section 12;`
  line
  line `(l) demand and receive with the prior approval of the Central Government such fees and other`
  line `charges as may be specified;`
  line
  line `(m) construct quarters for its staff and allot such quarters to the staff in accordance with such`
  line `regulations as may be made in this behalf;`
  line
  line `(n) borrow money, with the prior approval of the Central Government, on the security of the`
  line `property of the Institute;`
  line
  line `(o) do all such other acts and things as may be necessary in furtherance of the objects specified in`
  line `section 13.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (6362)
  sectionNo (15)
  orderNo 15
  title `Vesting of property.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6362&sectionno=15&orderno=15&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_15_content:
  string
  line `(1) The properties of the National Institute of Mental Health and NeuroSciences,`
  line `Bangalore, registered under the Karnataka Societies Registration Act, 1960 (Katnataka Act`
  line `XVII of 1960) shall, on the date of commencement of this Act, vest in the Institute.`
  line
  line `(2) All income and property of the Institute shall be applied towards the promotion of the objects`
  line `thereof as set forth in this Act.`
  line
  line `(3) No portion of the income and property of the Institute shall be paid or transferred, directly or`
  line `indirectly, by way of profit to the persons, who at any time, or have been members of the Institute:`
  line
  line `Provided that nothing herein contained shall prevent the payment of remuneration and other`
  line `allowances to any member thereof or other persons for the services rendered to the Institute.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (6363)
  sectionNo (16)
  orderNo 16
  title `Payment to Institute.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6363&sectionno=16&orderno=16&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_16_content:
  string
  line `The Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the Institute in each financial year such sums of money and in`
  line `such manner as may be considered necessary for the exercise of its powers and discharge of its functions`
  line `under this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (6364)
  sectionNo (17)
  orderNo 17
  title `Fund of Institute.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6364&sectionno=17&orderno=17&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_17_content:
  string
  line `(1) The Institute shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government and the State Government of Karnataka;`
  line
  line `(b) all fees and other charges received by the Institute;`
  line
  line `(c) all moneys received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all moneys received by the Institute in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund shall be deposited in such banks or invested in such manner as`
  line `the Institute may, with the approval of the Central Government, decide.`
  line
  line `(3) The Fund shall be applied towards meeting the expenses of the Institute including expenses`
  line `incurred in the exercise of its powers and discharge of its functions under section 14.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (6365)
  sectionNo (18)
  orderNo 18
  title `Budget of Institute.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6365&sectionno=18&orderno=18&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_18_content:
  string
  line `The Institute shall prepare in such form and at such time every year a`
  line `budget in respect of the financial year next ensuing showing the estimated receipts and expenditure of the`
  line `Institute and shall forward to the Central Government such number of copies thereof as may be`
  line prescribed.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (6366)
  sectionNo (19)
  orderNo 19
  title `Accounts and audit.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6366&sectionno=19&orderno=19&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_19_content:
  string
  line `(1) The Institute shall maintain proper accounts and other relevant records`
  line `and prepare an annual statement of accounts including the balance-sheet in such form as the Central`
  line `Government may prescribe, and in accordance with such general directions as may be issued by that`
  line `Government, in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Institute shall be audited by the Comptroller and Auditor-General of India and`
  line `any expenditure incurred by him in connection with such audit shall be payable by the Institute to the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Institute shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line `Institute as well as of the institutions established and maintained by it.`
  line
  line `(4) The accounts of the Institute as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before both the`
  line `Houses of Parliament.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (6367)
  sectionNo (20)
  orderNo 20
  title `Annual report.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6367&sectionno=20&orderno=20&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_20_content:
  string
  line `The Institute shall prepare for every year a report of its activities during that`
  line `year and submit the report to the Central Government in such form and on or before such date as may be`
  line `prescribed and a copy of this report shall be laid before both Houses of Parliament within one month of its`
  line receipt.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (6368)
  sectionNo (21)
  orderNo 21
  title `Pension and provident funds.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6368&sectionno=21&orderno=21&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_21_content:
  string
  line `(1) The Institute shall constitute for the benefit of its officers,`
  line `teachers and other employees in such manner and subject to such conditions as may be specified such`
  line `pension and provident funds as it may deem fit.`
  line
  line `(2) Where any such pension or provident fund has been constituted, the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to, such fund as if it`
  line `were a Government Provident Fund.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (6369)
  sectionNo (22)
  orderNo 22
  title `Authentication of orders and instruments of Institute.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6369&sectionno=22&orderno=22&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_22_content:
  string
  line `All orders and decisions of the`
  line `Institute shall be authenticated by the Director or any other member authorised by the Institute in this`
  line `behalf and all other instruments shall be authenticated by the signature of the Director or such officers as`
  line `may be authorised by the Institute.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (6370)
  sectionNo (23)
  orderNo 23
  title `Acts and proceedings not to be invalidated by vacancies, etc.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6370&sectionno=23&orderno=23&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_23_content:
  string
  line `No act done or proceeding`
  line `taken by the Institute, Governing Body or any standing or ad hoc committee under this Act shall be`
  line `questioned on the ground merely of the existence of any vacancy in, or defect in the constitution of the`
  line `Institute, Governing Body or such standing or ad hoc committee.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (6371)
  sectionNo (24)
  orderNo 24
  title `Grant of medical degrees, diplomas, etc., by Institute.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6371&sectionno=24&orderno=24&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_24_content:
  string
  line `Notwithstanding anything contained in`
  line `any other law for the time being in force, the Institute shall have the power to grant medical and nursing`
  line `degrees, diplomas, certificates and other academic distinctions and titles under this Act.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (6372)
  sectionNo (25)
  orderNo 25
  title `Recognition of medical qualifications granted by Institute.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6372&sectionno=25&orderno=25&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_25_content:
  string
  line `Notwithstanding anything`
  line `contained in the Indian Medical Council Act, 1956 (102 of 1956), the Rehabilitation Council of India Act,`
  line `1992 (34 of 1992), the Indian Nursing Council Act, 1947 (48 of 1947) and the University Grants`
  line `Commission Act, 1956 (3 of 1956), the medical degrees, diplomas, nursing degrees and certificates`
  line `granted by the Institute under this Act shall be recognised medical qualifications for the purposes of the`
  line `Acts aforesaid and shall be deemed to be included in the Schedule to the respective Acts.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (6373)
  sectionNo (26)
  orderNo 26
  title `Control by Central Government.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6373&sectionno=26&orderno=26&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_26_content:
  string
  line `The Institute shall carry out such directions as may be issued`
  line `to it from time to time by the Central Government for the efficient administration of this Act.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (6374)
  sectionNo (27)
  orderNo 27
  title `Resolution of differences.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6374&sectionno=27&orderno=27&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_27_content:
  string
  line `If in, or in connection with, the exercise of its powers and discharge`
  line `of its functions by the Institute under this Act, any dispute or difference arises between the Institute and`
  line `the Central Government, the decision of the Central Government thereon shall be final.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (6375)
  sectionNo (28)
  orderNo 28
  title `Returns and information.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6375&sectionno=28&orderno=28&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_28_content:
  string
  line `The Institute shall furnish to the Central Government such reports,`
  line `returns and other information as that Government may require from time to time.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (6376)
  sectionNo (29)
  orderNo 29
  title `Transfer of service of existing employees.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6376&sectionno=29&orderno=29&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_29_content:
  string
  line `Subject to the provisions of this Act, every person`
  line `who is employed in the National Institute of Mental Health and Neuro-Sciences, Bangalore, immediately`
  line `before the commencement of this Act, shall, on and from such commencement, become an employee of`
  line `the Institute and shall hold his office or service therein by the same tenure, at the same remuneration and`
  line `upon the same terms and conditions and with the same rights and privileges as to pension, leave, gratuity,`
  line `provident fund and other matters as he would have held the same on the date of commencement of this`
  line `Act if this Act had not been passed, and shall continue to do so unless and until his employment is`
  line `terminated or until such tenure, remuneration and terms and conditions are duly altered by regulations:`
  line
  line `Provided that the tenure, remuneration and terms and conditions of service of any such person shall`
  line `not be altered to his disadvantage without the previous approval of the Central Government.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (6377)
  sectionNo (30)
  orderNo 30
  title `Power to make rules.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6377&sectionno=30&orderno=30&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_30_content:
  string
  line `(1) The Central Government may in consultation with the Institute by`
  line `notification in the Official Gazette, make rules to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of nomination of members under clauses (j) and (k) of sub-section (1) of section`
  line 5;
  line
  line `(b) the manner of filling vacancies of members under sub-section (8) of section 6;`
  line
  line `(c) the powers and functions to be exercised and discharged by the President of the Institute under`
  line `sub-section (2) of section 7;`
  line
  line `(d) the allowances to be paid to the President and other members of the Institute under section 9;`
  line
  line `(e) the control and restrictions in relation to the constitution of standing and ad hoc committees`
  line `under sub-section (5) of section 11;`
  line
  line `(f) appointment of Director and other officers and employees and salaries and allowances and`
  line `other conditions of service of the Director and other officers and employees of the Institute under`
  line `section 12;`
  line
  line `(g) the form in which, and the time at which, the budgets and reports shall be prepared by the`
  line `Institute under section 18;`
  line
  line `(h) the form of annual statement of accounts including balance-sheet under sub-section (1) of`
  line `section 19;`
  line
  line `(i) the form of annual report under section 20;`
  line
  line `(j) any other matter which has to be or may be prescribed by rules.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (6378)
  sectionNo (31)
  orderNo 31
  title `Power to make regulations.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6378&sectionno=31&orderno=31&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_31_content:
  string
  line `(1) The Institute with the previous approval of the Central`
  line `Government, may by notification in the Official Gazette, make regulations consistent with this Act and`
  line `the rules made thereunder to carry out the purposes of this Act, and without prejudice to the generality of`
  line `this power, such regulations may provide for--`
  line
  line `(a) the summoning and holding of meetings, other than the first meeting, of the Institute, the time`
  line `and place where such meetings are to be held and the conduct of business at such meetings under`
  line `section 10;`
  line
  line `(b) the manner of constituting the Governing Body and standing and ad hoc committees, the term`
  line `of office of, and the manner of filling vacancies therein, the allowances to be paid to the members and`
  line `the procedure to be followed by the Governing Body; standing and ad hoc committees in the conduct`
  line `of their business, exercise of their power, discharge of their function under section 11;`
  line
  line `(c) the powers and duties of the Director of the Institute under sub-section (4), the designations`
  line `and grades of other officers and employees under sub-section (5) and other conditions of service`
  line `under sub-section (6) of section 12;`
  line
  line `(d) the power of the Institute under section 14, to specify--`
  line
  line `(i) courses and curricula for undergraduate and postgraduate studies under clause (e);`
  line
  line `(ii) hold examination and grant degrees, diplomas, certificates and other academic`
  line `distinctions and titles under clause (h);`
  line
  line `(iii) the professorships, readerships, lecturerships and other posts which may be instituted and`
  line `persons who may be appointed to such posts under clause (i);`
  line
  line `(iv) the management of the properties of the Institute under clauses (k) and (m);`
  line
  line `(v) the fees and other charges which may be demanded and received by the Institute under`
  line `clause (l);`
  line
  line `(e) the manner in which, and the conditions subject to which, pension and provident funds may be`
  line `constituted for the benefit of officers, teachers and other employees of the Institute under sub-section`
  line `(1) of section 21;`
  line
  line `(f) any other matter for which under this Act provisions may be made by regulations.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the first regulations under this Act shall be`
  line `made by the Central Government; and any regulations so made may be altered or rescinded by the`
  line `Institute in exercise of its powers under sub-section (1).`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (6379)
  sectionNo (32)
  orderNo 32
  title `Laying of rules and regulations before Parliament.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6379&sectionno=32&orderno=32&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_32_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (6380)
  sectionNo (33)
  orderNo 33
  title `Power to remove difficulties.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_201238_1517807327843&sectionId=6380&sectionno=33&orderno=33&orgactid=AC_CEN_12_13_00023_201238_1517807327843
obj_root_law_sections_33_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as may appear to it to be necessary for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of the period of two years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_33_footnotes:
  string
  line
