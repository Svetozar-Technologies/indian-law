obj_root_law_sections_40:
  sectionId (49368)
  sectionNo (40)
  orderNo 59
  title `Rules, regulations and notifications to laid before Parliament.`
  content obj_root_law_sections_40_content
  footnotes `1. Ins. by s. 31, ibid. (w.e.f. 17-11-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00003_195923_1517807321587&sectionId=49368&sectionno=40&orderno=59&orgactid=AC_CEN_22_29_00003_195923_1517807321587
obj_root_law_sections_40_content:
  string
  line `^1[40. Rules, regulations and notifications to laid before Parliament.--Every rule and every`
  line `regulation made and every notification issued under this Act shall be laid, as soon as may be after it is`
  line `made or issued, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule, regulation or notification, or both Houses agree that the rule,`
  line `regulation or notification should not be made or issued, the rule, regulation or notification shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule, regulation or notification.]`
