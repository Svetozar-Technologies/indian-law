obj_root_law_sections_1:
  sectionId (9542)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9542&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Family Courts Act,`
  line 1984.
  line
  line `(2) It extends to the whole of India ^1***`
  line
  line `(3) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint, and different dates may be appointed for different States.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" Omitted by the Jammu and Kashmir Reorganization (Adaptation of`
  line `Central Laws) Order, 2020, vide notification No. S.O. 1123(E) dated (18-3-2020) and vide Union Territory of Ladakh`
  line `Reorganisation (Adaptation of Central Laws) Order, 2020, notification No. S.O. 3774(E), dated (23-10-2020).`
  line
  line `2. This Act shall come into force in--`
  line
  line `(i) Union territory of Andaman and Nicobar Islands on 19th November, 1986,vide notification No. 79/22/86, dated 19th`
  line `November, 1986, Gazette of India, Extra., Pt. II, Section 1.`
  line
  line `(ii) Madhya Pradesh on 19thNovember, 1986, vide notification No. 79/6/86, dated 14th November, 1986, Gazette of India,`
  line `Extra., Pt. II, Section 1`
  line
  line `(iii) Uttar Pradesh on 2ndOctober, 1986, vide notification No. 79/11/86-Jus., dated 4th September, 1986, Gazette of India,`
  line `Pt. II, Section 1`
  line
  line `(iv) Delhi on 19th November, 1986,vide notification No. S.O. 863(E), dater 18th November, 1986, Gazette of India, Extra.,`
  line `Pt. II, Section 3 (ii).`
  line
  line `(v) Maharashtra on 1st December, 1986, vide notification No. S.O. 944(E), dated 5th December, 1986, Gazette of India,`
  line `Extra., Pt. II, Section 3(ii).`
  line
  line `(vi) Karnataka on 25th May, 1987, vide notification No. G.S.R. 685(E), dated 15th May, 1987, Gazette of India, Extra., Pt. II,`
  line `Section 3(i).`
  line
  line `(vii) Orissa on 1st May, 1989, vide notification No. S.O. 321(E), dated 27th April, 1989, Gazette of India, Extra, Pt. II,`
  line `Section 3(ii).`
  line
  line `(viii) Kerala on 21st October, 1989, vide notification No. 79/5/86, dated 17th October, 1989, Gazette of India, Extra., Pt. II,`
  line `Section 1.`
  line
  line `(ix) Goa on 16th April, 1990, vide notification No. S.O. 328(E), dated 12th April, 1990, Gazette of India, Extra., Pt. II,`
  line `Section 3(ii).`
  line
  line `(x) Union territory of Pondicherry on 1st May, 1987, vide notification No. G.S.R. 459 (E), dated 29th April, 1987, Gazette of`
  line `India, Extra, Pt. II, Section 3(i).`
  line
  line `(xi) West Bengal on 1st November, 1991, vide notification No. 79/12/86-Jus., dated 1st November, 1991, Gazette of India,`
  line `Extra., Pt. II, Section 1 (E).`
  line
  line `(xii) Assam on 2nd October, 1991, vide notification No. 79/2/86Jus., dated 30th November, 1991, Gazette of India, Extra.,`
  line `Pt. II, Section 1 (E).`
  line
  line `(xiii) Bihar on 10th December, 1991, vide notification No. S.O. 838(E), dated 6th December, 1991, Gazette of India, Extra.,`
  line `Pt. II, Section 3(ii).`
  line
  line `(xiv) Manipur on 3rd February, 1992, vide notification No. S.O. 91(E), dated 30th January, 1992, Gazette of India, Extra., Pt.`
  line `II, Section 3(ii).`
  line
  line `(xv) Haryana on 2nd November, 1992, vide notification No. S.O. 784(E), dated 23th October, 1992, Gazette of India, Extra.,`
  line `Pt. II, Section 3(i).`
  line
  line `(xvi) Andhra Pradesh on 15th February, 1995, vide notification No. S.O. 92(E), dated 6th February, 1995, Gazette of India,`
  line `Extra.. Part II, Section 3 (ii).`
  line
  line `(xvii) Gujarat on 1st January, 2000, vide notification No. S.O. 1268(E), dated 20nd December, 1999, Gazette of India, Extra.,`
  line `Pt. II, Section 3 (ii).`
  line
  line `(xviii) Union territory of Daman and Diu on 10th October, 2003, vide notification No. S.O. 1161 (E), dated 14th October,`
  line `2003, Gazette of India, Extra., Pt. II, Section 3 (ii).`
obj_root_law_sections_2:
  sectionId (9543)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9543&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Judge" means the Judge or, as the case may be, the Principal Judge, Additional Principal`
  line `Judge or other Judge of a Family Court;`
  line
  line `(b) "notification" means a notification published in the Official Gazette;`
  line
  line `(c) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(d) "Family Court" means a Family Court established under section 3;`
  line
  line `(e) all other words and expressions used but not defined in this Act and defined in the Code of`
  line `Civil Procedure, 1908 (5 of 1908) shall have the meanings respectively assigned to them in that`
  line Code.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (9544)
  sectionNo (3)
  orderNo 3
  title `Establishment of Family Courts.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9544&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_3_content:
  string
  line `(1) For the purpose of exercising the jurisdiction and powers`
  line `conferred on a Family Court by this Act, the State Government, after consultation with the High Court,`
  line `and by notification,—`
  line
  line `(a) shall, as soon as may be after the commencement of this Act, established for every area in the`
  line `State comprising of city or town whose population exceeds one million, a Family Court;`
  line
  line `(b) may establish Family Courts for such other areas in the State as it may deem necessary.`
  line
  line `(2) The State Government shall, after consultation with the High Court, specify, by notification, the`
  line `local limits of the area to which the jurisdiction of a Family Court shall extend and may, at any time,`
  line `increase, reduce or alter such limits.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (9545)
  sectionNo (4)
  orderNo 4
  title `Appointment of Judges.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9545&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_4_content:
  string
  line `(1) The State Government may, with the concurrence of the High`
  line `Court, appoint one or more persons to be the Judge or Judges of a Family Court.`
  line
  line `(2) When a Family Court consists of more than one Judge,—`
  line
  line `(a) each of the Judges may exercise all or any of the powers conferred on the Court by this Act or`
  line `any other law for the time being in force;`
  line
  line `(b) the State Government may, with the concurrence of the High Court, appoint any of the Judges`
  line `to be the Principal Judge and any other Judge to be the Additional Principal Judge;`
  line
  line `(c) the Principal Judge may, from time to time, make such arrangements as he may deem fit for`
  line `the distribution of the business of the Court among the various Judges thereof;`
  line
  line `(d) the Additional Principal Judge may exercise the powers of the Principal Judge in the event of`
  line `any vacancy in the office of the Principal Judge or when the Principal Judge is unable to discharge his`
  line `functions owing to absence, illness or any other cause.`
  line
  line `(3) A person shall not be qualified for appointment as a Judge unless he—`
  line
  line `(a) has for at least seven years held a judicial office in India or the office of a Member of a`
  line `Tribunal or any post under the Union or a State requiring special knowledge of law; or`
  line
  line `(b) has for at least seven years been an advocate of a High Court or of two or more such Courts in`
  line `succession; or`
  line
  line `(c) possesses such other qualifications as the Central Government may, with the concurrence of`
  line `the Chief Justice of India, prescribe.`
  line
  line `(4) In selecting persons for appointment as Judges,—`
  line
  line `(a) every endeavour shall be made to ensure that persons committed to the need to protect and`
  line `preserve the institution of marriage and to promote the welfare of children and qualified by reason of`
  line `their experience and expertise to promote the settlement of disputes by conciliation and counselling`
  line `are selected; and`
  line
  line `(b) preference shall be given to women.`
  line
  line `(5) No person shall be appointed as, or hold the office of, a Judge of a Family Court after he has`
  line `attained the age of sixty-two years.`
  line
  line `(6) The salary or honorarium and other allowances payable to, and the other terms and conditions of`
  line `service of, a Judge shall be such as the State Government may, in consultation with the High Court,`
  line prescribe.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (9546)
  sectionNo (5)
  orderNo 5
  title `Association of social welfare agencies, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9546&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_5_content:
  string
  line `The State Government may, in consultation with the`
  line `High Court, provide, by rules, for the association, in such manner and for such purposes and subject to`
  line `such conditions as may be specified in the rules, with a Family Court of—`
  line
  line `(a) institutions or organisations engaged in social welfare or the representatives thereof;`
  line
  line `(b) persons professionally engaged in promoting the welfare of the family;`
  line
  line `(c) persons working in the field of social welfare; and`
  line
  line `(d) any other person whose association with a Family Court would enable it to exercise its`
  line `jurisdiction more effectively in accordance with the purposes of this Act.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (9547)
  sectionNo (6)
  orderNo 6
  title `Counsellors, officers and other employees of Family Courts.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9547&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_6_content:
  string
  line `(1) The State Government shall,`
  line `in consultation with the High Court, determine the number and categories of counsellors, officers and`
  line `other employees required to assist a Family Court in the discharge of its functions and provide the Family`
  line `Court with such counsellors, officers and other employees as it may think fit.`
  line
  line `(2) The terms and conditions of association of the counsellors and the terms and conditions of service`
  line `of the officers and other employees, referred to in sub-section (1), shall be such as may be specified`
  line `by rules made by the State Government.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (9548)
  sectionNo (7)
  orderNo 7
  title Jurisdiction.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9548&sectionno=7&orderno=7&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the other provisions of this Act, a Family Court shall—`
  line
  line `(a) have and exercise all the jurisdiction exercisable by any district court or any subordinate civil`
  line `court under any law for the time being in force in respect of suits and proceedings of the nature`
  line `referred to in the Explanation; and`
  line
  line `(b) be deemed, for the purposes of exercising such jurisdiction under such law, to be a district`
  line `court or, as the case may be, such subordinate civil court for the area to which the jurisdiction of the`
  line `Family Court extends.`
  line
  line `Explanation.—The suits and proceedings referred to in this sub-section are suits and proceedings of`
  line `the following nature, namely:—`
  line
  line `(a) a suit or proceeding between the parties to a marriage for a decree of nullity of marriage`
  line `(declaring the marriage to be null and void or, as the case may be, annulling the marriage) or`
  line `restitution of conjugal rights or judicial separation or dissolution of marriage;`
  line
  line `(b) a suit or proceeding for a declaration as to the validity of a marriage or as to the matrimonial`
  line `status of any person;`
  line
  line `(c) a suit or proceeding between the parties to a marriage with respect to the property of the`
  line `parties or of either of them;`
  line
  line `(d) a suit or proceeding for an order or injunction in circumstance arising out of a marital`
  line relationship;
  line
  line `(e) a suit or proceeding for a declaration as to the legitimacy of any person;`
  line
  line `(f) a suit or proceeding for maintenance;`
  line
  line `(g) a suit or proceeding in relation to the guardianship of the person or the custody of, or access`
  line `to, any minor.`
  line
  line `(2) Subject to the other provisions of this Act, a Family Court shall also have and exercise—`
  line
  line `(a) the jurisdiction exercisable by a Magistrate of the first class under Chapter IX (relating to`
  line `order for maintenance of wife, children and parents) of the Code of Criminal Procedure, 1973 (2 of`
  line `1974); and`
  line
  line `(b) such other jurisdiction as may be conferred on it by any other enactment.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (9549)
  sectionNo (8)
  orderNo 8
  title `Exclusion of jurisdiction and pending proceedings.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9549&sectionno=8&orderno=8&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_8_content:
  string
  line `Where a Family Court has been`
  line `established for any area,—`
  line
  line `(a) no district court or any subordinate civil court referred to in sub-section (1) of section 7 shall,`
  line `in relation to such area, have or exercise any jurisdiction in respect of any suit or proceeding of the`
  line `nature referred to in the Explanation to that sub-section;`
  line
  line `(b) no magistrate shall, in relation to such area, have or exercise any jurisdiction or powers under`
  line `Chapter IX of the Code of Criminal Procedure, 1973 (2 of 1974);`
  line
  line `(c) every suit or proceeding of the nature referred to in the Explanation to sub-section (1) of`
  line `section 7 and every proceeding under Chapter IX of the Code of Criminal Procedure, 1973 (2 of`
  line `1974),—`
  line
  line `(i) which is pending immediately before the establishment of such Family Court before any`
  line `district court or subordinate court referred to in that sub-section or, as the case may be, before any`
  line `magistrate under the said Code; and`
  line
  line `(ii) which would have been required to be instituted or taken before such Family Court if,`
  line `before the date on which such suit or proceeding was instituted or taken, this Act had come into`
  line `force and such Family Court had been established,`
  line
  line `shall stand transferred to such Family Court on the date on which it is established.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (9550)
  sectionNo (9)
  orderNo 9
  title `Duty of Family Court to make efforts for settlement.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9550&sectionno=9&orderno=9&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_9_content:
  string
  line `(1) In every suit or proceeding,`
  line `endeavour shall be made by the Family Court in the first instance, where it is possible to do so consistent`
  line `with the nature and circumstances of the case, to assist and persuade the parties in arriving at a settlement`
  line `in respect of the subject-matter of the suit or proceeding and for this purpose a Family Court may, subject`
  line `to any rules made by the High Court, follow such procedure as it may deem fit.`
  line
  line `(2) If, in any suit or proceeding, at any stage, it appears to the Family Court that there is a reasonable`
  line `possibility of a settlement between the parties, the Family Court may adjourn the proceedings for such`
  line `period as it thinks fit to enable attempts to be made to effect such a settlement.`
  line
  line `(3) The power conferred by sub-section (2) shall be in addition to, and not in derogation of, any other`
  line `power of the Family Court to adjourn the proceedings.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (9551)
  sectionNo (10)
  orderNo 10
  title `Procedure generally.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9551&sectionno=10&orderno=10&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_10_content:
  string
  line `(1) Subject to the other provisions of this Act and the rules, the`
  line `provisions of the Code of Civil Procedure, 1908 (5 of 1908) and of any other law for the time being in`
  line `force shall apply to the suits and proceedings [other than the proceedings under Chapter IX of the Code of`
  line `Criminal Procedure, 1973 (2 of 1974)] before a Family Court and for the purposes of the said provisions`
  line `of the Code, a Family Court shall be deemed to be a civil court and shall have all the powers of such`
  line court.
  line
  line `(2) Subject to the other provisions of this Act and the rules, the provisions of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974) or the rules made thereunder, shall apply to the proceedings under Chapter`
  line `IX of that Code before a Family Court.`
  line
  line `(3) Nothing in sub-section (1) or sub-section (2) shall prevent a Family Court from laying down its`
  line `own procedure with a view to arrive at a settlement in respect of the subject-matter of the suit or`
  line `proceedings or at the truth of the facts alleged by the one party and denied by the other.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (9552)
  sectionNo (11)
  orderNo 11
  title `Proceedings to be held in camera.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9552&sectionno=11&orderno=11&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_11_content:
  string
  line `In every suit or proceedings to which this Act applies, the`
  line `proceedings may be held in camera if the Family Court so desires and shall be so held if either party so`
  line desires.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (9553)
  sectionNo (12)
  orderNo 12
  title `Assistance of medical and welfare experts.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9553&sectionno=12&orderno=12&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_12_content:
  string
  line `In every suit or proceedings, it shall be open to a`
  line `Family Court to secure the services of a medical expert or such person (preferably a woman where`
  line `available), whether related to the parties or not, including a person professionally engaged in promoting`
  line `the welfare of the family as the Court may think fit, for the purposes of assisting the Family Court in`
  line `discharging the functions imposed by this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (9554)
  sectionNo (13)
  orderNo 13
  title `Right to legal representation.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9554&sectionno=13&orderno=13&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_13_content:
  string
  line `Notwithstanding anything contained in any law, no party to a`
  line `suit or proceeding before a Family Court shall be entitled, as of right, to be represented by a legal`
  line `practitioner:`
  line
  line `Provided that if the Family Court considers it necessary in the interest of justice, it may seek the`
  line `assistance of a legal expert as amicus curiae.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (9555)
  sectionNo (14)
  orderNo 14
  title `Application of Indian Evidence Act, 1872.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9555&sectionno=14&orderno=14&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_14_content:
  string
  line `A Family Court may receive as evidence any`
  line `report, statement, documents, information or matter that may, in its opinion, assist it to deal effectually`
  line `with a dispute, whether or not the same would be otherwise relevant or admissible under the Indian`
  line `Evidence Act, 1872 (1 of 1872).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (9556)
  sectionNo (15)
  orderNo 15
  title `Record of oral evidence.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9556&sectionno=15&orderno=15&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_15_content:
  string
  line `In suits or proceedings before a Family Court, it shall not be`
  line `necessary to record the evidence of witnesses at length, but the Judge, as the examination of each witness`
  line `proceeds, shall, record or cause to be recorded, a memorandum of the substance of what the witness`
  line `deposes, and such memorandum shall be signed by the witness and the Judge and shall form part of the`
  line record.
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (9557)
  sectionNo (16)
  orderNo 16
  title `Evidence of formal character on affidavit.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9557&sectionno=16&orderno=16&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_16_content:
  string
  line `(1) The evidence of any person where such`
  line `evidence is of a formal character, may be given by affidavit and may, subject to all just exceptions, be`
  line `read in evidence in any suit or proceeding before a Family Court.`
  line
  line `(2) The Family Court may, if it thinks fit, and shall, on the application of any of the parties to the suit`
  line `or proceeding summon and examine any such person as to the facts contained in his affidavit.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (9558)
  sectionNo (17)
  orderNo 17
  title Judgment.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9558&sectionno=17&orderno=17&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_17_content:
  string
  line `Judgment of a Family Court shall contain a concise statement of the case, the point`
  line `for determination, the decision thereon and the reasons for such decision.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (9559)
  sectionNo (18)
  orderNo 18
  title `Execution of decrees and orders.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9559&sectionno=18&orderno=18&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_18_content:
  string
  line `(1) A decree or an order [other than an order under Chapter`
  line `IX of the Code of Criminal Procedure, 1973 (2 of 1974)], passed by a Family Court shall have the same`
  line `force and effect as a decree or order of a civil court and shall be executed in the same manner as is`
  line `prescribed by the Code of Civil Procedure, 1908 (5 of 1908) for the execution of decrees and orders.`
  line
  line `(2) An order passed by a Family Court under Chapter IX of the Code of Criminal Procedure, 1973 (2`
  line `of 1974) shall be executed in the manner prescribed for the execution of such order by that Code.`
  line
  line `(3) A decree or order may be executed either by the Family Court which passed it or by the other`
  line `Family Court or ordinary civil court to which it is sent for execution.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (9560)
  sectionNo (19)
  orderNo 19
  title Appeal.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9560&sectionno=19&orderno=19&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_19_content:
  string
  line `^1(1) Save as provided in sub-section (2) and notwithstanding anything contained in the`
  line `Code of Civil Procedure,1908 (5 of 1908) or in the Code of Criminal Procedure, 1973 (2 of 1974) or in`
  line `any other law, an appeal shall lie from every judgment or order, not being an interlocutory order, of a`
  line `Family Court to the High Court both on facts and on law.`
  line
  line `(2) No appeal shall lie from a decree or order passed by the Family Court with the consent of the`
  line parties^2
  line `[or from an order passed under Chapter IX of the Code of Criminal Procedure, 1973 (2 of 1974):`
  line
  line `Provided that nothing in this sub-section shall apply to any appeal pending before a High Court or`
  line `any order passed under Chapter IX of the Code of Criminal Procedure, 1973 (2 of 1974) before the`
  line `commencement of the Family Courts (Amendment) Act, 1991 (59 of 1991).]`
  line
  line `(3) Every appeal under this section shall be preferred within a period of thirty days from the date of`
  line `the judgment or order of a Family Court.`
  line
  line ^2
  line `[(4) The High Court may, of its own motion or otherwise, call for and examine the record of any`
  line `proceeding in which the Family Court situate within its jurisdiction passed an order under Chapter IX of`
  line `the Code of Criminal Procedure, 1973 (2 of 1974) for the purpose of satisfying itself as to the correctness,`
  line `legality or propriety of the order, not being an interlocutory order, and as to the regularity of such`
  line proceeding.]
  line
  line ^3
  line `[(5)] Except as aforesaid, no appeal or revision shall lie to any court from any judgment, order or`
  line `decree of a Family Court.`
  line
  line ^4
  line *****
obj_root_law_sections_19_footnotes:
  string
  line `1. Subs. by Act 59 of 1991, s. 2, for "Appeals" (w.e.f 28-12-1991).`
  line
  line `2. Ins. by s.2, ibid. (w.e.f. 28-12-1991).`
  line
  line `3. Sub-section (4) renumbered as sub-section (5) thereof by s. 2, ibid. (w.e.f. 28-12-1991).`
  line
  line `4. Sub-section (6) by the Jammu and Kashmir Reorganization (Adaptation of Central Laws) Order, 2020, vide notification No.`
  line `S.O. 1123(E) dated (18-3-2020) and vide Union Territory of Ladakh Reorganisation (Adaptation of Central Laws) Order,`
  line `2020, notification No. S.O. 3774(E), dated (23-10-2020).`
obj_root_law_sections_20:
  sectionId (9561)
  sectionNo (20)
  orderNo 20
  title `Act to have overriding effect.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9561&sectionno=20&orderno=20&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_20_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force or in any instrument`
  line `having effect by virtue of any law other than this Act.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (9562)
  sectionNo (21)
  orderNo 21
  title `Power of High Court to make rules.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9562&sectionno=21&orderno=21&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_21_content:
  string
  line `(1) The High Court may, by notification in the Official`
  line `Gazette, make such rules as it may deem necessary for carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:—`
  line
  line `(a) normal working hours of Family Courts and holding of sittings of Family Courts on holidays`
  line `and outside normal working hours;`
  line
  line `(b) holding of sittings of Family Courts at places other than their ordinary places of sitting;`
  line
  line `(c) efforts which may be made by, and the procedure which may be followed by, a Family Court`
  line `for assisting and persuading parties to arrive at a settlement.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (9563)
  sectionNo (22)
  orderNo 22
  title `Power of the Central Government to make rules.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9563&sectionno=22&orderno=22&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_22_content:
  string
  line `(1) The Central Government may, with the`
  line `concurrence of the Chief Justice of India, by notification, make rules prescribing the other qualifications`
  line `for appointment of a Judge referred to in clause (c) of sub-section (3) of section 4.`
  line
  line `(2) Every rule made under this Act by the Central Government shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (9564)
  sectionNo (23)
  orderNo 23
  title `Power of the State Government to make rules.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00019_198466_1517807326692&sectionId=9564&sectionno=23&orderno=23&orgactid=AC_CEN_3_3_00019_198466_1517807326692
obj_root_law_sections_23_content:
  string
  line `(1) The State Government may, after`
  line `consultation with the High Court, by notification, make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the provisions of sub-section (1) such rules`
  line `may provide for all or any of the following matters, namely:--`
  line
  line `(a) the salary or honorarium and other allowances payable to, and the other terms and conditions`
  line `of Judges under sub-section (6) of section 4;`
  line
  line `(b) the terms and conditions of association of counsellors and the terms and conditions of service`
  line `of the officers and other employees referred to in section 6;`
  line
  line `(c) payment of fees and expenses (including travelling expenses) of medical and other experts and`
  line `other persons referred to in section 12 out of the revenues of the State Government and the scales of`
  line `such fees and expenses;`
  line
  line `(d) payment of fees and expenses to legal practitioners appointed under section 13 as amicus`
  line `curiae out of the revenues of the State Government and the scales of such fees and expenses;`
  line
  line `(e) any other matter which is required to be, or may be, prescribed or provided for by rules.`
  line
  line `(3) Every rule made by a State Government under this Act shall be laid, as soon as may be after it is`
  line `made, before the State Legislature.`
obj_root_law_sections_23_footnotes:
  string
  line
