  object
  (str title) (str `सशस्‍त्र बल (पंजाब और चंडीगढ़) विशेष शक्‍तियां अधिनियम, 1983`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1843/5/H1983-34.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:27:39.230Z`)
