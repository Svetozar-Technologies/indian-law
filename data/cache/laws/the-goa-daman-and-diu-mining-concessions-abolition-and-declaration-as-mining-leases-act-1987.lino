obj_root_law:
  object
  (str slug) (str the-goa-daman-and-diu-mining-concessions-abolition-and-declaration-as-mining-leases-act-1987)
  (str handle) (str 1884)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Goa, Daman and Diu Mining Concessions (Abolition and Declaration as Mining Leases) Act, 1987`)
  (str actNumber) (str 16)
  (str enactmentDate) (str 1987-05-23)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1884`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `गोवा, दमण और दीव खनन रियायत (उत्‍सादन और खनन पट्टा के रूप में घोषणा) अधिनियम,1987`)
  (str actYear) (str 1987)
  (str ministry) (str `Ministry of Mines`)
  (str longTitle) (str `An Act to provide for the abolition of the mining concessions in operation in the Union territory of Goa, Daman and Diu and specified in the First and the Second Schedules, and for the declaration of such mining concessions as mining leases under the Mines and Minerals (Regulation and Development) Act, 1957 with a view to the regulation of the mines to which such concessions relate and for the development of minerals under the control of the Union and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 23-05-1987)
