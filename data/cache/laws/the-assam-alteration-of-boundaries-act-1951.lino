obj_root_law_sections_1:
  object
  (str sectionId) (str 39148)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Assam (Alteration of Boundaries) Act, 1951.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00001_195147_1517807317243&sectionId=39148&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00001_195147_1517807317243)
obj_root_law_sections_2:
  object
  (str sectionId) (str 39149)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Alteration of the boundaries of Assam.`)
  (str content) (str `On and from the commencement of this Act, the
territory of the State of Assam shall cease to comprise the strip of territory specified in the Schedule,
which shall be ceded to the Government of Bhutan, and the boundaries of the state of Assam shall be
deemed to have been altered accordingly.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00001_195147_1517807317243&sectionId=39149&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00001_195147_1517807317243)
obj_root_law_sections_3:
  object
  (str sectionId) (str 39150)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Amendment of the First Schedule to the Constitution.`)
  (str content) (str `In the first paragraph of Part A of the
First Schedule to the Constitution, under the heading "TERRITORIES OF STATES", after the words
"Assam Tribal Areas", the following words shall be inserted, namely:—

"but shall not include the territories specified in the Schedule to the Assam (Alteration of
Boundaries) Act, 1951".`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00001_195147_1517807317243&sectionId=39150&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00001_195147_1517807317243)
