obj_root_law_sections_1:
  sectionId (39148)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Assam (Alteration of Boundaries) Act, 1951.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00001_195147_1517807317243&sectionId=39148&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00001_195147_1517807317243
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39149)
  sectionNo (2)
  orderNo 2
  title `Alteration of the boundaries of Assam.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00001_195147_1517807317243&sectionId=39149&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00001_195147_1517807317243
obj_root_law_sections_2_content:
  string
  line `On and from the commencement of this Act, the`
  line `territory of the State of Assam shall cease to comprise the strip of territory specified in the Schedule,`
  line `which shall be ceded to the Government of Bhutan, and the boundaries of the state of Assam shall be`
  line `deemed to have been altered accordingly.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39150)
  sectionNo (3)
  orderNo 3
  title `Amendment of the First Schedule to the Constitution.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00001_195147_1517807317243&sectionId=39150&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00001_195147_1517807317243
obj_root_law_sections_3_content:
  string
  line `In the first paragraph of Part A of the`
  line `First Schedule to the Constitution, under the heading "TERRITORIES OF STATES", after the words`
  line `"Assam Tribal Areas", the following words shall be inserted, namely:—`
  line
  line `"but shall not include the territories specified in the Schedule to the Assam (Alteration of`
  line `Boundaries) Act, 1951".`
obj_root_law_sections_3_footnotes:
  string
  line
