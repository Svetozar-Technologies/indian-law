obj_root_law_sections_1:
  sectionId (11970)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11970&sectionno=1&orderno=1&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Sree Chitra Tirunal Institute for`
  line `Medical Sciences and Technology, Trivandrum, Act, 1980.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st March, 1981, vide notification No. G.S.R. 254(E), dated 17th February, 1981, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3 (i).`
obj_root_law_sections_2:
  sectionId (11971)
  sectionNo (2)
  orderNo 2
  title `Declaration of the Sree Chitra Tirunal Medical Centre Society for Advanced Studies in Specialities, Trivandrum, as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11971&sectionno=2&orderno=2&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the Sree`
  line `Chitra Tirunal Medical Centre Society for Advanced Studies in Specialities, Trivandrum, in the State of`
  line `Kerala, are such as to make the institution one of national importance, it is hereby declared that the`
  line `institution, known as the Sree Chitra Tirunal Medical Centre Society for Advanced Studies in`
  line `Specialities, Trivandrum, is an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (11972)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11972&sectionno=3&orderno=3&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Chairman" means the Chairman of the Governing Body;`
  line
  line `(b) "Director" means the Director of the Institute;`
  line
  line `(c) "Fund" means the Fund of the Institute referred to in section 16;`
  line
  line `(d) "Governing Body" means the Governing Body of the Institute;`
  line
  line `(e) "Institute" means the institution known as the Sree Chitra Tirunal Institute for Medical`
  line `Sciences and Technology, Trivandrum, incorporated under this Act;`
  line
  line `(f) "member" means a member of the Institute;`
  line
  line `(g) "President" means the President of the Institute;`
  line
  line `(h) "regulation" means a regulation made by the Institute;`
  line
  line `(i) "rule" means a rule made by the Central Government.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (11973)
  sectionNo (4)
  orderNo 4
  title `Incorporation of Institute.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11973&sectionno=4&orderno=4&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_4_content:
  string
  line `The Sree Chitra Tirunal Medical Centre Society for Advanced`
  line `Studies in Specialities, Trivandrum, is hereby constituted a body corporate by the name of Sree Chitra`
  line `Tirunal Institute for Medical Sciences and Technology, Trivandrum, and as such body corporate, it shall`
  line `have perpetual succession and a common seal with power, subject to the provisions of this Act, to`
  line `acquire, hold and dispose of property and to contract, and shall, by that name, sue and be sued.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (11974)
  sectionNo (5)
  orderNo 5
  title `Composition of Institute.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11974&sectionno=5&orderno=5&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_5_content:
  string
  line `The Institute shall consist of the following members, namely:--`
  line
  line `(a) the Vice-Chancellor of the Kerala University, ex officio;`
  line
  line `(b) the Director-General of Health Services, Government of India, ex officio;`
  line
  line `(c) the Director, ex officio;`
  line
  line `(d) four members to be nominated by the Central Government to represent respectively the`
  line `Departments or, as the case may be, Ministries of that Government dealing with Science and`
  line `Technology, Health, Finance and Education;`
  line
  line `(e) two members to be nominated by the Government of the State of Kerala to represent`
  line `respectively the Departments or, as the case may be, Ministries of that Government dealing with`
  line `Planning, Science and Technology and Health;`
  line
  line `(f) three scientists of whom two shall be medical scientists and one shall be a social scientist, to`
  line `be nominated by the Central Government in the manner prescribed by rules;`
  line
  line `(g) three scientists representing engineering and technology to be nominated by the Central`
  line `Government in the manner prescribed by rules;`
  line
  line `(h) the Head of the Biomedical Technology Wing of the Institute, ex officio;`
  line
  line `(i) three representatives of the medical faculties of Indian Universities to be nominated by the`
  line `Central Government in the manner prescribed by rules; and`
  line
  line `(j) three members of Parliament of whom two shall be elected from among themselves by the`
  line `members of the House of the People and one from among themselves by the members of the Council`
  line `of States.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (11975)
  sectionNo (6)
  orderNo 6
  title `Term of office of and vacancies among members.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11975&sectionno=6&orderno=6&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_6_content:
  string
  line `(1) Save as otherwise provided in this`
  line `section, the term of office of a member shall be five years from the date of his nomination or election.`
  line
  line `(2) The term of office of a member elected under clause (j) of section 5 shall come to an end as soon`
  line `as he ceases to be a member of the House from which he was elected.`
  line
  line `(3) The term of office of an ex officio member shall continue so long as he holds the office by virtue`
  line `of which he is such a member.`
  line
  line `(4) The term of office of a member nominated or elected to fill a casual vacancy shall continue for the`
  line `remainder of the term of the member in whose place he is nominated or elected.`
  line
  line `(5) An outgoing member other than a member elected under clause (j) of section 5 shall, unless the`
  line `Central Government otherwise directs, continue in office until another person is nominated as a member`
  line `in his place.`
  line
  line `(6) An outgoing member shall be eligible for re-nomination or reelection.`
  line
  line `(7) A member may resign his office by writing under his hand addressed to the Central Government`
  line `but he shall continue in office until his resignation is accepted by that Government.`
  line
  line `(8) The manner of filling vacancies among members shall be such as may be prescribed by rules.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (11976)
  sectionNo (7)
  orderNo 7
  title `President of Institute.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11976&sectionno=7&orderno=7&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_7_content:
  string
  line `(1) There shall be a President of the Institute who shall be nominated by`
  line `the Central Government from among the members other than the Director.`
  line
  line `(2) The President shall exercise such powers and discharge such functions as are laid down in this Act`
  line `or as may be prescribed by rules or regulations.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (11977)
  sectionNo (8)
  orderNo 8
  title `Allowances of President and members.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11977&sectionno=8&orderno=8&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_8_content:
  string
  line `The President and other members shall receive such`
  line `allowances, if any, from the Institute as may be prescribed by rules.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (11978)
  sectionNo (9)
  orderNo 9
  title `Meetings of Institute.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11978&sectionno=9&orderno=9&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_9_content:
  string
  line `The Institute shall hold its first meeting at such time and place as may be`
  line `appointed by the Central Government and shall observe such rules of procedure in regard to the`
  line `transaction of business at the first meeting as may be laid down by that Government; and thereafter the`
  line `Institute shall meet at such times and places and observe such rules of procedure in regard to the`
  line `transaction of business at its meetings as may be prescribed by regulations`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (11979)
  sectionNo (10)
  orderNo 10
  title `Governing Body and other committees of Institute.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11979&sectionno=10&orderno=10&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_10_content:
  string
  line `(1) There shall be a Governing Body of`
  line `the Institute which shall be constituted by the Institute in such manner as may be prescribed by`
  line `regulations:`
  line
  line `Provided that the number of persons who are not members of the Institute shall not exceed one-third`
  line `of the total membership of the Governing Body.`
  line
  line `(2) The Governing Body shall be the Executive Committee of the Institute and shall exercise such`
  line `powers and discharge such functions as the Institute may, by regulations made in this behalf, confer or`
  line `impose upon it.`
  line
  line `(3) The President shall be the Chairman of the Governing Body and as Chairman thereof shall`
  line `exercise such powers and discharge such functions as may be prescribed by regulations.`
  line
  line `(4) The procedure to be followed in the exercise of its powers and discharge of its functions by the`
  line `Governing Body, and the term of office of, and the manner of filling vacancies among, the members of`
  line `the Governing Body shall be such as may be prescribed by regulations.`
  line
  line `(5) Subject to such control and restrictions as may be prescribed by rules, the Institute may constitute`
  line `as many standing committees and as many ad hoc committees as it thinks fit for exercising any power or`
  line `discharging any function of the Institute or for inquiring into, or reporting or advising upon, any matter`
  line `which the Institute may refer to them.`
  line
  line `(6) The Chairman and members of the Governing Body and Chairman and members of a standing`
  line `committee or an ad hoc committee shall receive such allowances, if any, as may be prescribed by`
  line regulations.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (11980)
  sectionNo (11)
  orderNo 11
  title `Staff of Institute.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11980&sectionno=11&orderno=11&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_11_content:
  string
  line `(1) There shall be a chief executive officer of the Institute who shall be`
  line `designated as the Director of the Institute and shall, subject to such rules as may be made in this behalf,`
  line `be appointed by the Institute:`
  line
  line `Provided that the first Director of the Institute shall be appointed by the Central Government.`
  line
  line `(2) The Director shall act as the Secretary to the Institute as well as the Governing Body.`
  line
  line `(3) The Director shall exercise such powers and discharge such functions as may be prescribed by`
  line `regulations or as may be delegated to him by the Institute or the President or by the Governing Body or`
  line `the Chairman.`
  line
  line `(4) Subject to such rules as may be made in this behalf, the Institute may appoint such number of`
  line `other officers and employees as may be necessary for the exercise of its powers and discharge of its`
  line `functions and may determine the designations and grades of such other officers and employees.`
  line
  line `(5) Subject to such rules as may be made in this behalf, the Director and other officers and employees`
  line `of the Institute shall be entitled to such salary and allowances and shall be governed by such conditions of`
  line `service in respect of leave, pension, gratuity, provident fund and other matters as may be prescribed by`
  line `regulations made in this behalf.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (11981)
  sectionNo (12)
  orderNo 12
  title `Objects of Institute.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11981&sectionno=12&orderno=12&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_12_content:
  string
  line `The objects of the Institute shall be--`
  line
  line `(a) to promote biomedical engineering and technology;`
  line
  line `(b) to provide and demonstrate high standards of patient care in advanced medical`
  line `specialities; and`
  line
  line `(c) to develop post-graduate training programmes of the highest quality in advanced medical`
  line `specialities and biomedical engineering and technology.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (11982)
  sectionNo (13)
  orderNo 13
  title `Functions of Institute.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11982&sectionno=13&orderno=13&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_13_content:
  string
  line `With a view to the promotion of the objects specified in section 12, the`
  line `Institute may,--`
  line
  line `(a) provide for post-graduate teaching in the science of modern medicine and other allied`
  line `sciences, including physical and biological sciences;`
  line
  line `(b) provide facilities for research in the various branches of such sciences;`
  line
  line `(c) conduct experiments in integrated methods of post-graduate medical and technological`
  line `education in order to arrive at satisfactory standards of such education;`
  line
  line `(d) prescribe courses and curricula for post-graduate studies;`
  line
  line `(e) provide for post-graduate teaching and training in biomedical sciences and technology;`
  line
  line `(f) notwithstanding anything contained in any other law for the time being in force, establish and`
  line maintain--
  line
  line `(i) one or more well equipped hospitals; and`
  line
  line `(ii) one or more centers for research and development in biomedical technology;`
  line
  line `(g) hold examinations and grant such degrees, diplomas and other academic distinctions and titles`
  line `in post-graduate medical education and biomedical technology as may be laid down in the`
  line regulations;
  line
  line `(h) institute and appoint persons to professorships, readerships, lecturerships and posts of any`
  line `description in accordance with the regulations;`
  line
  line `(i) receive grants from the Governments and gifts, donations, benefactions, bequests and transfers`
  line `of properties, both movable and immovable, from donors, benefactors, testators or transferors, as the`
  line `case may be;`
  line
  line `(j) deal with any property belonging to, or vested in, the Institute in any manner which is`
  line `considered necessary for promoting the objects specified in section l2;`
  line
  line `(k) demand and receive such fees and other charges as may be prescribed by regulations; and`
  line
  line `(l) do all other acts and things as may be necessary to further the objects specified in section 12.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (11983)
  sectionNo (14)
  orderNo 14
  title `Vesting of property.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11983&sectionno=14&orderno=14&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_14_content:
  string
  line `All properties which had vested in the Sree Chitra Tirunal Medical Centre`
  line `Society for Advanced Studies in Specialities, Trivandrum, immediately before the commencement of this`
  line `Act, shall, on and from such commencement, vest in the Institute.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (11984)
  sectionNo (15)
  orderNo 15
  title `Payment to Institute.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11984&sectionno=15&orderno=15&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_15_content:
  string
  line `The Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the Institute in each financial year such sums of money and in`
  line `such manner as may be considered necessary by that Government for the exercise of its powers and`
  line `discharge of its functions under this Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (11985)
  sectionNo (16)
  orderNo 16
  title `Fund of Institute.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11985&sectionno=16&orderno=16&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_16_content:
  string
  line `(1) The Institute shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government and the Government of Kerala;`
  line
  line `(b) all fees and other charges received by the Institute;`
  line
  line `(c) all moneys received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all moneys received by the Institute in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund shall be deposited in such banks or invested in such manner as`
  line `the Institute may, with the approval of the Central Government, decide.`
  line
  line `(3) The Fund shall be applied towards meeting the expenses of the Institute including expenses`
  line `incurred in the exercise of its powers and discharge of its functions under section 13.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (11986)
  sectionNo (17)
  orderNo 17
  title `Budget of Institute.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11986&sectionno=17&orderno=17&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_17_content:
  string
  line `The Institute shall prepare, in such form and at such time every year, as`
  line `may be prescribed by rules, a budget in respect of the financial year next ensuing showing the estimated`
  line `receipts and expenditure of the Institute and shall forward to the Central Government such number of`
  line `copies thereof as may be prescribed by rules`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (11987)
  sectionNo (18)
  orderNo 18
  title `Accounts and audit.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11987&sectionno=18&orderno=18&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_18_content:
  string
  line `(1) The Institute shall maintain proper accounts and other relevant records`
  line `and prepare an annual statement of accounts including the balance-sheet in such form as the Central`
  line `Government may, by rules, prescribe, and in accordance with such general directions as may be issued by`
  line `that Government, in consultation with the Comptroller and Auditor General of India.`
  line
  line `(2) The accounts of the Institute shall be audited by the Comptroller and Auditor-General of India and`
  line `any expenditure incurred by him in connection with such audit shall be payable by the Institute to the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Institute shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line `Institute as well as of the institutions established and maintained by it.`
  line
  line `(4) The accounts of the Institute as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before both`
  line `Houses of Parliament.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (11988)
  sectionNo (19)
  orderNo 19
  title `Annual report.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11988&sectionno=19&orderno=19&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_19_content:
  string
  line `The Institute shall prepare for every year a report of its activities during that`
  line `year and submit the report to the Central Government in such form and on or before such date as may be`
  line `prescribed by rules and a copy of the report shall be laid, as soon as may be after it is received, before`
  line `both Houses of Parliament`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (11989)
  sectionNo (20)
  orderNo 20
  title `Pension and provident funds.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11989&sectionno=20&orderno=20&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_20_content:
  string
  line `(1) The Institute shall constitute for the benefit of its officers,`
  line `teachers and other employees in such manner and subject to such conditions as may be prescribed by`
  line `regulations, such pension and provident funds as it may deem fit.`
  line
  line `(2) Where any such pension or provident fund has been constituted, the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925, (19 of 1925) shall apply to such fund as if it`
  line `were a Government Provident Fund.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (11990)
  sectionNo (21)
  orderNo 21
  title `Authentication of orders and instruments of Institute.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11990&sectionno=21&orderno=21&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_21_content:
  string
  line `All orders and decisions of the`
  line `Institute shall be authenticated by the signature of the President or any other member authorised by the`
  line `Institute in this behalf, and all other instruments shall be authenticated by the signature of the Director or`
  line `any other officer of the Institute authorised in like manner in this behalf.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (11991)
  sectionNo (22)
  orderNo 22
  title `Acts and proceedings not to be invalidated by vacancies, etc.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11991&sectionno=22&orderno=22&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_22_content:
  string
  line `No act done or proceeding`
  line `taken by the Institute, Governing Body or any standing or ad hoc committee under this Act shall be`
  line `questioned on the ground merely of the existence of any vacancy in, or defect in the constitution of, the`
  line `Institute, Governing Body or such standing or ad hoc committee.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (11992)
  sectionNo (23)
  orderNo 23
  title `Grant of medical degrees, diplomas, etc., by Institute.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11992&sectionno=23&orderno=23&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_23_content:
  string
  line `Notwithstanding anything contained in`
  line `any other law for the time being in force, the Institute shall have power to grant medical degrees,`
  line `diplomas and other academic distinctions and titles under this Act.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (11993)
  sectionNo (24)
  orderNo 24
  title `Recognition of medical qualifications granted by Institute.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11993&sectionno=24&orderno=24&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_24_content:
  string
  line `Notwithstanding anything`
  line `contained in the Indian Medical Council Act, 1956 (102 of 1956), the medical degrees and diplomas`
  line `granted by the Institute under this Act shall be recognised medical qualifications for the purposes of that`
  line `Act and shall be deemed to be included in the First Schedule to that Act.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (11994)
  sectionNo (25)
  orderNo 25
  title `Control by Central Government.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11994&sectionno=25&orderno=25&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_25_content:
  string
  line `The Institute shall carry out such directions as may be issued`
  line `to it from time to time by the Central Government for the efficient administration of this Act.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (11995)
  sectionNo (26)
  orderNo 26
  title `Disputes between Institute and Central Government.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11995&sectionno=26&orderno=26&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_26_content:
  string
  line `If in, or in connection with, the`
  line `exercise of its powers and discharge of its functions by the Institute under this Act, any dispute arises`
  line `between the Institute and the Central Government, the decision of the Central Government on such`
  line `dispute shall be final`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (11996)
  sectionNo (27)
  orderNo 27
  title `Returns and information.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11996&sectionno=27&orderno=27&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_27_content:
  string
  line `The Institute shall furnish to the Central Government such reports,`
  line `returns and other information as that Government may require from time to time.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (11997)
  sectionNo (28)
  orderNo 28
  title `Transfer of service of existing employees.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11997&sectionno=28&orderno=28&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_28_content:
  string
  line `Subject to the provisions of this Act, every person`
  line `who was employed in the Sree Chitra Tirunal Medical Centre Society for Advanced Studies in`
  line `Specialities, Trivandrum, immediately before the commencement of this Act shall, on and from such`
  line `commencement, become an employee of the Institute and shall hold his office or service therein by the`
  line `same tenure, at the same remuneration and upon the same terms and conditions and with the same rights`
  line `and privileges as to leave, pension, gratuity, provident fund and other matters as he would have held the`
  line `same on the date of commencement of this Act if this Act had not been passed, and shall continue to do`
  line `so unless and until his employment is terminated or until such tenure, remuneration and terms and`
  line `conditions are duly altered by regulations:`
  line
  line `Provided that the tenure, remuneration and terms and conditions of service of any such person shall`
  line `not be altered to his disadvantage without the previous approval of the Central Government.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (11998)
  sectionNo (29)
  orderNo 29
  title `Continuance of facilities at Institute.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11998&sectionno=29&orderno=29&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_29_content:
  string
  line `The Institute shall continue to provide facilities to the`
  line `Government and people of the State of Kerala and the Central Government and such facilities shall not, in`
  line `any respect, be less favourable to the said Governments and people than what were being provided to`
  line `them before the commencement of this Act and shall be made available for such period and upon such`
  line `terms and conditions (including those relating to any contributions to be made for the provision of such`
  line `facilities) as may be agreed upon between the Institute, the Government of the State of Kerala and the`
  line `Central Government.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (11999)
  sectionNo (30)
  orderNo 30
  title `Power to remove difficulties.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=11999&sectionno=30&orderno=30&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_30_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, within a period of three years from the commencement of this Act, by`
  line `order published in the Official Gazette, make such provisions or give such directions not inconsistent with`
  line `the provisions of this Act, as appears to it to be necessary or expedient for removing the difficulty.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (12000)
  sectionNo (31)
  orderNo 31
  title `Power to make rules.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=12000&sectionno=31&orderno=31&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_31_content:
  string
  line `(1) The Central Government, after consultation with the Institute, may,`
  line `by notification in the Official Gazette, make rules to carry out the purposes of this Act:`
  line
  line `Provided that consultation with the Institute shall not be necessary on the first occasion of the making`
  line `of rules under this section, but the Central Government shall take into consideration any suggestions`
  line `which the Institute may make in relation to the amendment of such rules after they are made.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of nomination of members under clauses (f), (g) and (i) of section 5;`
  line
  line `(b) the manner of filling vacancies among members under section 6;`
  line
  line `(c) the powers and functions to be exercised and discharged by the President under`
  line `sub-section (2) of section 7;`
  line
  line `(d) the allowances, if any, to be paid to the President and other members under section 8;`
  line
  line `(e) the control and restrictions in relation to the constitution of standing and ad hoc committees`
  line `under sub-section (5) of section 10;`
  line
  line `(f) the appointment of the Director under sub-section (1) of section 11;`
  line
  line `(g) the number of officers and employees that may be appointed by the Institute and the manner`
  line `of such appointment under sub-section (4) of section 11;`
  line
  line `(h) the salaries and allowances to be paid to the Director and other officers and employees of the`
  line `Institute under sub-section (5) of section 11;`
  line
  line `(i) the form in which, and the time at which, the budget shall be prepared by the Institute and the`
  line `number of copies thereof to be forwarded to the Central Government under section 17;`
  line
  line `(j) the form in which an annual statement of accounts including the balance-sheet shall be`
  line `prepared by the Institute under sub-section (1) of section 18;`
  line
  line `(k) the form in which and the date before which, the report of the activities of the Institute shall`
  line `be submitted to the Central Government under section 19;`
  line
  line `(l) the form and manner in which reports, returns and other information are to be furnished by the`
  line `Institute to the Central Government under section 27;`
  line
  line `(m) any other matter which has to be or may be prescribed by rules.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (12001)
  sectionNo (32)
  orderNo 32
  title `Power to make regulations.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=12001&sectionno=32&orderno=32&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_32_content:
  string
  line `(1) The Institute may, with the previous approval of the Central`
  line `Government, make regulations consistent with this Act and the rules made thereunder to carry out the`
  line `purposes of this Act, and without prejudice to the generality of this power, such regulations may provide`
  line for--
  line
  line `(a) the powers and functions to be exercised and discharged by the President under`
  line `sub-section (2) of section 7;`
  line
  line `(b) the summoning and holding of meetings, other than the first meeting, of the Institute under`
  line `section 9, the time and place where such meetings are to be held, the conduct of business at such`
  line `meetings and the number of members necessary to form a quorum;`
  line
  line `(c) the manner of constituting the Governing Body and standing and ad hoc committees under`
  line `section 10, the term of office of, and the manner of filling vacancies among, the members of the`
  line `Governing Body and standing and ad hoc committees;`
  line
  line `(d) the powers and functions to be exercised and discharged by the Governing Body and the`
  line `Chairman under sub-sections (2) and (3) of section 10;`
  line
  line `(e) the allowances, if any, to be paid to the Chairman and the members of the Governing Body`
  line `and of standing and ad hoc committees under sub-section (6) of section 10;`
  line
  line `(f) the procedure to be followed by the Governing Body and standing and ad hoc committees`
  line `in the conduct of their business, exercise of their powers and discharge of their functions under`
  line `section 10;`
  line
  line `(g) the powers and functions to be exercised and discharged by the Director under sub-section (3)`
  line `of section 11;`
  line
  line `(h) the tenure of office, salaries and allowances and other conditions of service of the Director`
  line `and other officers and employees of the Institute including teachers appointed by the Institute under`
  line `sub-section (5) of section 11;`
  line
  line `(i) the management of the properties of the Institute under section 13;`
  line
  line `(j) the degrees, diplomas and other academic distinctions and titles which may be granted by the`
  line `Institute under clause (g) of section 13;`
  line
  line `(k) the professorships, readerships, lecturerships and other posts which may be instituted and`
  line `persons who may be appointed to such professorships, readerships, lecturerships and other posts`
  line `under clause (h) of section 13;`
  line
  line `(l) the fees and other charges which may be demanded and received by the Institute under`
  line `clause (k) of section 13;`
  line
  line `(m) the manner in which, and the conditions subject to which, pension and provident funds may`
  line `be constituted for the benefit of officers, teachers and other employees of the Institute under`
  line `sub-section (1) of section 20;`
  line
  line `(n) matters relating to tenure of office, remuneration and terms and conditions of service of the`
  line `persons referred to in section 28;`
  line
  line `(o) any other matter for which under this Act provisions may be made by regulations.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the first regulations under this Act shall be`
  line `made by the Central Government; and any regulations so made may be altered or rescinded by the`
  line `Institute in exercise of its power under sub-section (1).`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (12002)
  sectionNo (33)
  orderNo 33
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_72_00002_198052_1517807326343&sectionId=12002&sectionno=33&orderno=33&orgactid=AC_CEN_12_72_00002_198052_1517807326343
obj_root_law_sections_33_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `श्री चित्रा तिरुनल आयुर्विज्ञान और प्रौद्योगिकी संस्थान, त्रिवेन्द्रम, अधिनियम, 1980`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1825/3/H1980-52.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T12:44:25.772Z`
