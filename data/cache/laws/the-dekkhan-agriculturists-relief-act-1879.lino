  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00099_187917_1663829896037&sectionId=68375&sectionno=61&orderno=61&orgactid=AC_CEN_5_5_00099_187917_1663829896037)
obj_root_law_sections_62:
  object
  (str sectionId) (str 68425)
  (str sectionNo) (str 62)
  (str orderNo) (int 62)
  (str title) (str `Exemption of instruments to which the Government or any officer of the Government is a party.`)
  (str content) (str `Nothing in this Act shall be deemed to require any instrument, to which the
Government or any officer of the Government in his official capacity is a party, to be executed
before a Village-registrar^2

[* * *]`)
  (str footnotes) (str `1. The words "or any Society registered under the Co-operative Credit Societies Act, 1904" inserted by Bom. Act 1 of 1910
were repealed by Bom. Act 1 of 1912.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00099_187917_1663829896037&sectionId=68425&sectionno=62&orderno=62&orgactid=AC_CEN_5_5_00099_187917_1663829896037)
