  line
obj_root_law_sections_56:
  sectionId (68423)
  sectionNo (56)
  orderNo 56
  title `Instruments executed by agriculturist not to be deemed valid unless executed before a Villageregistrar.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00099_187917_1663829896037&sectionId=68423&sectionno=56&orderno=56&orgactid=AC_CEN_5_5_00099_187917_1663829896037
obj_root_law_sections_56_content:
  string
  line `No instrument which purports to create, modify, transfer, evidence or`
  line `extinguish an obligation for the payment of money or a charge upon any property, or to be a`
  line `conveyance or lease, and which is executed after this Act comes into force by an agriculturist`
  line `residing in any local area for which a Village-registrar has been appointed, shall be admitted in`
  line `evidence for any purpose by any person having by law or consent of parties authority to receive`
  line `evidence, or shall be acted upon by any such person or by any public officer, unless such`
  line `instrument is written by, or under the superintendence of, and is attested by, a Village-registrar:`
  line
  line `Provided that nothing herein contained shall prevent the admission of any instrument in`
  line `evidence in any criminal proceeding, ^1]or apply to any instrument which is executed by an`
  line `agriculturist merely as a surety,] ^2[or to any instrument required by Section 17 of the ^3Indian`
  line `Registration Act, 1877 (3 of 1877), to be registered under that Act.]`
  line
  line `[* * *]`
obj_root_law_sections_56_footnotes:
  string
  line `1. Ins. by Act 23 of 1881, s. 12.`
  line
  line `2. Ins. by Act 23 of 1886, s. 9.`
  line
  line `3. See now the Indian Registration Act, 1908 (16 of 1908).`
