obj_root_law_sections_60:
  sectionId (68424)
  sectionNo (60)
  orderNo 60
  title `Registration under this Act to be deemed equivalent to registration under Indian Registration Act, 1877.`
  content obj_root_law_sections_60_content
  footnotes `1. See now the Indian Registration Act, 1908 (16 of 1908),`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00099_187917_1663829896037&sectionId=68424&sectionno=60&orderno=60&orgactid=AC_CEN_5_5_00099_187917_1663829896037
obj_root_law_sections_60_content:
  string
  line `Every instrument executed and registered in accordance with the`
  line `foregoing provisions shall be deemed to have been duly registered under the provisions of`
  line `the ^1Indian Registration Act, 1877 (3 of 1877); and no instrument which ought to have been`
  line `executed before a Village-registrar but has been otherwise executed shall be registered by any`
  line `officer acting under the said Act, or in any public office, or shall be authenticated by any public`
  line officer.
  line
  line `[* * *]`
obj_root_law_sections_61:
  sectionId (68375)
  sectionNo (61)
  orderNo 61
  title [Repealed.].
  content `[Rep. by the State of Bombay, with effect from the 27th May, 1950 by the Bombay Agricultural Debtors' Relief Act, 1947 (Bom. 28 of 1947), s. 56 was amended. Hence the part applicable to that State only has not been reproduced.`
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00099_187917_1663829896037&sectionId=68375&sectionno=61&orderno=61&orgactid=AC_CEN_5_5_00099_187917_1663829896037
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (68425)
  sectionNo (62)
  orderNo 62
  title `Exemption of instruments to which the Government or any officer of the Government is a party.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00099_187917_1663829896037&sectionId=68425&sectionno=62&orderno=62&orgactid=AC_CEN_5_5_00099_187917_1663829896037
obj_root_law_sections_62_content:
  string
  line `Nothing in this Act shall be deemed to require any instrument, to which the`
  line `Government or any officer of the Government in his official capacity is a party, to be executed`
  line `before a Village-registrar^2`
  line
  line `[* * *]`
obj_root_law_sections_62_footnotes:
  string
  line `1. The words "or any Society registered under the Co-operative Credit Societies Act, 1904" inserted by Bom. Act 1 of 1910`
  line `were repealed by Bom. Act 1 of 1912.`
