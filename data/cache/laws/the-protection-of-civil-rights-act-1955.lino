obj_root_law_sections_1:
  sectionId (36687)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36687&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called ^1`
  line `[the Protection of Civil`
  line `Rights Act], 1955.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for "the Untouchability (Offences) Act" (w.e.f. 19-11-1976).`
  line
  line `2. 1st June, 1955, vide notification No. S.R.O. 1109(E), dated the 23rd May, 1955, see Gazette of India, 1955, Extraordinary`
  line `Part II, s. 3.`
obj_root_law_sections_2:
  sectionId (36688)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36688&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line ^1
  line `[(a) "civil rights" means any right accruing to a person by reason of the abolition of`
  line `"untouchability" by article 17 of the Constitution;]`
  line
  line ^2
  line `[(aa)] "hotel" includes a refreshment room, a boarding house, a lodging house, a coffee house`
  line `and a cafe;`
  line
  line ^3
  line `[(b) "place" includes a house, building and other structure and premises; and also includes a tent,`
  line `vehicle and vessel;]`
  line
  line `(c) "place of public entertainment" includes any place to which the public are admitted and in`
  line `which an entertainment is provided or field.`
  line
  line `Explanation.—"Entertainment" includes any exhibition performance, game, sport and any other`
  line `form of amusement;`
  line
  line `(d) "place of public worship" means a place, by whatever name known, which is used as a place`
  line `of public religious worship or which is dedicated generally to, or is used generally by persons`
  line `professing any religion or belonging to any religious denomination or any section thereof, for the`
  line `performance of any religious service, or for offering prayers therein, ^4`
  line `[and includes—`
  line
  line `(i) all lands and subsidiary shrines appurtenant or attached to any such place;`
  line
  line `(ii) a privately owned place of worship which is, in fact, allowed by the owner thereof to be`
  line `used as a place of public worship; and`
  line
  line `(iii) such land or subsidiary shrine appurtenant to such privately owned place of worship as is`
  line `allowed by the owner thereof to be used as a place of public religious worship;]`
  line
  line ^5
  line `[(da) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(db) "Scheduled Castes" has the meaning assigned to it in clause (24) of article 366 of the`
  line Constitution;]
  line
  line `(e) "shop" means any premises where goods are sold either wholesale or by retail or both`
  line `wholesale and by retail ^6`
  line `[and includes—`
  line
  line `(i) any place from where goods are sold by a hawker or vendor or from a mobile van or cart;`
  line
  line `(ii) a laundry and a hair cutting saloon;`
  line
  line `(iii) any other place where services are rendered to customers].`
obj_root_law_sections_2_footnotes:
  string
  line `1. Ins. by Act 106 of 1976, s. 4 (w.e.f. 19-11-1976).`
  line
  line `2. Clause (a) relettered as clause (aa) by s. 4, ibid. (w.e.f. 19-11-1976).`
  line
  line `3. Subs. by s. 4, ibid., for clause (b) (w.e.f. 19-11-1976).`
  line
  line `4. Subs. by s. 4, ibid., for certain words (w.e.f. 19-11-1976).`
  line
  line `5. Ins. by Act 106 of 1976, s. 4 (w.e.f. 19-11-1976).`
  line
  line `6. Subs. by s. 4, ibid., for certain words (w.e.f. 19-11-1976).`
obj_root_law_sections_3:
  sectionId (36689)
  sectionNo (3)
  orderNo 3
  title `Punishment for enforcing religious disabilities.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36689&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_3_content:
  string
  line `Whoever on the ground of "untouchability"`
  line `prevents any person—`
  line
  line `(a) from entering any place of public worship which is open to other persons professing the same`
  line `religion ^1`
  line `* * * or any section thereof, as such person; or`
  line
  line `(b) from worshipping or offering prayers or performing any religious service in any place of`
  line `public worship, or bathing in, or using the waters of, any sacred tank, well, spring or water-course`
  line ^2
  line `[river or lake or bathing at any ghat of such tank, water-course, river or lake] in the same manner and`
  line `and to the same extent as is permissible to the other persons professing the same religion ^1`
  line `* * * or any`
  line `section thereof, as such person,`
  line
  line ^3
  line `[shall be punishable with imprisonment for a term of not less than one month and not more than six`
  line `months and also with fine which shall be not less than one hundred rupees and not more than five hundred`
  line rupees].
  line
  line `Explanation.—For the purposes of this section and section 4 persons professing the Buddhist, Sikh or`
  line `Jaina religion or persons professing the Hindu religion in any of its forms or developments including`
  line `Virashaivas, Lingayats, Adivasis, followers of Brahmo, Prarthana, Arya Samaj and the Swaminarayan`
  line `Sampraday shall be deemed to be Hindus.`
obj_root_law_sections_3_footnotes:
  string
  line `1. The words "or belonging to the same religious denomination" omitted by s. 5, ibid. (w.e.f. 19-11-1976).`
  line `2. Ins. by s. 5, ibid. (w.e.f. 19-11-1976).`
  line `3. Subs. by s. 5, ibid., for certain words (w.e.f. 19-11-1976).`
obj_root_law_sections_4:
  sectionId (36690)
  sectionNo (4)
  orderNo 4
  title `Punishment for enforcing social disabilities.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36690&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_4_content:
  string
  line `Whoever on the ground of "untouchability"`
  line `enforces against any person any disability with regard to—`
  line
  line `(i) access to any shop, public restaurant, hotel or place of public entertainment; or`
  line
  line `(ii) the use of any utensils, and other articles kept in any public restaurant, hotel, dharamshala,`
  line `sarai or musafirkhana for the use of the general public or of ^1`
  line `[any section thereof]; or`
  line
  line `(iii) the practice of any profession or the carrying on of any occupation, trade or`
  line `business ^2`
  line `[or employment in any job]; or`
  line
  line `(iv) the use of, or access to, any river, stream, spring, well, tank, cistern, water-tap or other`
  line `watering place, or any bathing ghat, burial or cremation ground, any sanitary convenience, any road, or passage, or any other place of public resort which other members of the public, or ^3`
  line `[any section`
  line `thereof], have a right to use or have access to; or`
  line
  line `(v) the use of, or access to, any place used for a charitable or a public purpose maintained wholly`
  line `or partly out of State funds or dedicated to the use of the general public or ^3`
  line `[any section thereof]; or`
  line
  line `(vi) the enjoyment of any benefit under a charitable trust created for the benefit of the general`
  line `public or of ^3`
  line `[any section thereof]; or`
  line
  line `(vii) the use of, or access to, any public conveyance; or`
  line
  line `(viii) the construction, acquisition, or occupation of any residential premises in any locality,`
  line `whatsoever; or`
  line
  line `(ix) the use of any dharamshala, sarai or musafirkhana which is open to the general public, or`
  line `to ^3`
  line `[any section thereof]; or`
  line
  line `(x) the observance of any social or religious custom, usage or ceremony or ^4`
  line `[taking part in, or`
  line `taking out, any religious, social or cultural procession]; or`
  line
  line `(xi) the use of jewellery and finery,`
  line
  line ^5
  line `[shall be punishable with imprisonment for a term of not less than one month and not more than six`
  line `months and also with fine which shall be not less than one hundred rupees and not more than five hundred`
  line rupees].
  line
  line ^6
  line `[Explanation.—For the purposes of this section, "enforcement of any disability" includes any`
  line `discrimination on the ground of "untouchability".]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by s. 6, ibid., for certain words (w.e.f. 19-11-1976).`
  line
  line `2. Ins. by s. 6, ibid. (w.e.f. 19-11-1976).`
  line
  line `3. Subs. by Act 106 of 1976, s. 6, for certain words (w.e.f. 19-11-1976).`
  line
  line `4. Subs. by s. 6, ibid., for "taking part in any religious procession" (w.e.f. 19-11-1976).`
  line
  line `5. Subs. by s. 6, ibid., for certain words (w.e.f. 19-11-1976).`
  line
  line `6. Ins. by s. 6, ibid. (w.e.f. 19-11-1976).`
obj_root_law_sections_5:
  sectionId (36691)
  sectionNo (5)
  orderNo 5
  title `Punishment for refusing to admit person to hospitals, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36691&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_5_content:
  string
  line `Whoever on the ground of`
  line `"untouchability"—`
  line
  line `(a) refuses admission to any person to any hospital, dispensary, educational institution or any`
  line `hostel ^1`
  line `***, if such hospital, dispensary, educational institution or hostel is established or maintained`
  line `for the benefit of the general public or any section thereof; or`
  line
  line `(b) does any act which discriminates against any such person after admission to any of the`
  line `aforesaid institutions,`
  line
  line ^2
  line `[shall be punishable with imprisonment for a term of not less than one month and not more than six`
  line `months and also with fine which shall be not less than one hundred rupees and not more than five hundred`
  line rupees].
obj_root_law_sections_5_footnotes:
  string
  line `1. The words "attached thereto" omitted by s. 7, ibid. (w.e.f. 19-11-1976).`
  line
  line `2. Subs. by s. 7, ibid., for certain words (w.e.f. 19-11-1976).`
obj_root_law_sections_6:
  sectionId (36692)
  sectionNo (6)
  orderNo 6
  title `Punishment for refusing to sell goods or render services.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by s. 8, ibid., for certain words (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36692&sectionno=6&orderno=6&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_6_content:
  string
  line `Whoever on the ground of`
  line `"untouchability" refuses to sell any goods or refuses to render any service to any person at the same time`
  line `and place and on the same terms and conditions at or which such goods are sold or services are rendered`
  line `to other persons in the ordinary course of business ^1`
  line `[shall be punishable with imprisonment for a term of`
  line `not less than one month and not more than six months and also with fine which shall be not less than one`
  line `hundred rupees and not more than five hundred rupees].`
obj_root_law_sections_7:
  sectionId (36708)
  sectionNo (7)
  orderNo 7
  title `Punishment for other offences arising out of "untouchability".`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36708&sectionno=7&orderno=7&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_7_content:
  string
  line `(1) Whoever—`
  line
  line `(a) prevents any person from exercising any right accruing to him by reason of the abolition of`
  line `“untouchability” under Article 17 of the Constitution; or`
  line
  line `(b) molests, injures, annoys, obstructs or causes or attempts to cause obstruction to any person in`
  line `the exercise of any such right or molests, injures, annoys or boycotts any person by reason of his`
  line `having exercised any such right; or`
  line
  line `(c) by words, either spoken or written, or by signs or by visible representations or otherwise,`
  line `incites or encourages any person or class of persons or the public generally to practice`
  line `“untouchability” in any form whatsoever; ^1`
  line [or]
  line
  line ^1
  line `[(d) insults or attempts to insult, on the ground of “untouchability”, a member of a Scheduled`
  line Caste;]
  line
  line ^2
  line `[shall be punishable with imprisonment for a term of not less than one month and not more than six`
  line `months, and also with fine which shall be not less than one hundred rupees and not more than five`
  line `hundred rupees].`
  line
  line ^3
  line `[Explanation I ].—A person shall be deemed to boycott another person who—`
  line
  line `(a) refuses to let to such other person or refuses to permit such other person, to use or occupy any`
  line `house or land or refuses to deal with, work for hire for, or do business with, such other person or to`
  line `render to him or receive from him any customary service, or refuses to do any of the said things on`
  line `the terms on which such things would be commonly done in the ordinary course of business; or`
  line
  line `(b) abstains from such social, professional or business relations as he would ordinarily maintain`
  line `with such other person.`
  line
  line ^1
  line `[Explanation II.—For the purpose of clause (c) a person shall be deemed to incite or encourage the`
  line `practice of “untouchability”—`
  line
  line `(i) if he, directly or indirectly, preaches “untouchability” or its practice in any form; or`
  line
  line `(ii) if he justifies, whether on historical, philosophical or religious grounds or on the ground of`
  line `any tradition of the caste system or on any other ground, the practice of “untouchability” in any`
  line form.]
  line
  line ^1
  line `[(1A) Whoever commits any offence against the person or property of any individual as a repraisal or`
  line `revenge for his having exercised any right accruing to him by reason of the abolition of “untouchability”`
  line `under article 17 of the Constitution, shall, where the offence is punishable with imprisonment for a term`
  line `exceeding two years, be punishable with imprisonment for a term which shall not be less than two years`
  line `and also with fine.]`
  line
  line `(2) Whoever—`
  line
  line `(i) denies to any person belonging to his community or any section thereof any right or privilege`
  line `to which such person would be entitled as a member of such community or section, or`
  line
  line `(ii) takes any part in the ex-communication of such person, on the ground that such person has`
  line `refused to practice “untouchability” that such person has done any act in furtherance of the objects of`
  line `this Act,`
  line
  line `[shall be punishable with imprisonment for a term of not less than one month and not more than six`
  line `months and also with fine which shall be not less than one hundred rupees and not more than five hundred`
  line rupees.]
obj_root_law_sections_7_footnotes:
  string
  line `1. Ins. by Act 106 of 1976, s. 9, (w.e.f. 19-11-1976).`
  line
  line `2. Subs. by s. 9, ibid., for certain words (w.e.f. 19-11-1976).`
  line
  line `3. The existing Explanation renumbered as Explanation I by s. 9, ibid., (w.e.f 19-11-1976).`
obj_root_law_sections_7_a:
  sectionId (36711)
  sectionNo 7A
  orderNo 8
  title `Unlawful compulsory labour when to be deemed to be a practice of "untouchability".`
  content obj_root_law_sections_7_a_content
  footnotes `1. Ins. by s. 10, ibid. (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36711&sectionno=7A&orderno=8&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_7_a_content:
  string
  line `^1[7A. Unlawful compulsory labour when to be deemed to be a practice of "untouchability".—(1)`
  line `(1) Whoever compels any person, on the ground of "untouchability", to do any scavenging or sweeping or to remove any carcass or to flay any animal, or to remove the umbilical cord or to do any other job of a`
  line `similar nature shall be deemed to have enforced a disability arising out of "untouchability".`
  line
  line `(2) Whoever is deemed under sub-section (1) to have enforced a disability arising out of`
  line `"untouchability" shall be punishable with imprisonment for a term which shall not be less than three`
  line `months and not more than six months and also with fine which shall not be less than one hundred rupees`
  line `and not more than five hundred rupees.`
  line
  line `Explanation.—For the purposes of this section, "compulsion" includes a threat of social or economic`
  line boycott.]
obj_root_law_sections_8:
  sectionId (36710)
  sectionNo (8)
  orderNo 9
  title `Cancellation or suspension of licences in certain cases.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36710&sectionno=8&orderno=9&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_8_content:
  string
  line `When a person who is convicted of an`
  line `offence under section 6 holds any licence under any law for the time being in force in respect of any`
  line `profession, trade, calling or employment in relation to which the offence is committed, the court trying`
  line `the offence may without prejudice to any other penalty to which such person may be liable under that`
  line `section, direct that the licence shall stand cancelled or be suspended for such period as the court may`
  line `deem fit, and every order of the court so cancelling or suspending a licence shall have effect as if it had`
  line `been passed by the authority competent to cancel or suspend the licence under any such law.`
  line
  line `Explanation.--In this section, "licence" includes a permit or a permission.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (36694)
  sectionNo (9)
  orderNo 10
  title `Resumption or suspension of grants made by Government.`
  content obj_root_law_sections_9_content
  footnotes `1. Ins. by Act 106 of 1976, s. 11, ibid. (w.e.f. 19-11-1976)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36694&sectionno=9&orderno=10&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_9_content:
  string
  line `Where the manager or trustee of a`
  line `place of public worship ^1`
  line `[for any educational institution or hostel] which is in receipt of a grant of land or`
  line `money from the Government is convicted of an offence under this Act and such conviction is not reversed`
  line `or quashed in any appeal or revision, the Government may, if in its opinion the circumstances of the case`
  line `warrant such a course, direct the supension or resumption of the whole or any part of such grant.`
obj_root_law_sections_10:
  sectionId (36695)
  sectionNo (10)
  orderNo 11
  title `Abetment of offence.`
  content obj_root_law_sections_10_content
  footnotes `1. Ins. by s. 12, ibid. (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36695&sectionno=10&orderno=11&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_10_content:
  string
  line `Whoever abets any offence under this Act shall be punishable with the`
  line `punishment provided for the offence.`
  line
  line ^1
  line `[Explanation.— A public servant who wilfully neglects the investigation of any offence punishable`
  line `under this Act shall be deemed to have abetted an offence punishable under this Act.]`
obj_root_law_sections_10_a:
  sectionId (36696)
  sectionNo 10A
  orderNo 12
  title `Power of State Government to impose collective fine.`
  content obj_root_law_sections_10_a_content
  footnotes `1. Ins. by s. 13, ibid. (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36696&sectionno=10A&orderno=12&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_10_a_content:
  string
  line `^1[10A. Power of State Government to impose collective fine—.(1) If, after an inquiry in the`
  line `prescribed manner, the State Government is satisfied that the inhabitants of an area are concerned in, or`
  line `abetting the commission of, any offence punishable under this Act, or harbouring persons concerned in`
  line `the commission of such offence or failing to render all the assistance in their power to discover or`
  line `apprehend the offender or offenders or suppressing material evidence of the commission of such offence,`
  line `the State Government may, by notification in the Official Gazette, impose a collective fine on such`
  line `inhabitants and apportion such fine amongst the inhabitants who are liable collectively to pay it, and such`
  line `apportionment shall be made according to the State Government's judgment of the respective means of`
  line `such inhabitants and in making any such apportionment the State Government may assign a portion of`
  line `such fine to a Hindu undivided family to be payable by it:`
  line
  line `Provided that the fine apportioned to an inhabitant shall not be realised until the petition, if any, filed`
  line `by him under sub-section (3), is disposed of.`
  line
  line `(2) The notification made under sub-section (1) shall be proclaimed in the area by beat of drum or in`
  line `such other manner as the State Government may think best in the circumstances to bring the imposition of`
  line `the collective fine to the notice of the inhabitants of the said area.`
  line
  line `(3) (a) Any person aggrieved by the imposition of the collective fine under sub-section (1)or by the`
  line `order of apportionment, may, within the prescribed period, file a petition before the State Government or`
  line `such other authority as that Government may specify in this behalf for being exempted from such fine or`
  line `for modification of the order or apportionment:`
  line
  line `Provided that no fee shall be charged for filing such petition.`
  line
  line `(b) The State Government or the authority specified by it shall, after giving to the petitioner a`
  line `reasonable opportunity of being heard, pass such order as it may think fit:`
  line
  line `Provided that the amount of the fine exempted or reduced under this section shall not be realisable`
  line `from any person, and the total fine imposed on the inhabitants of an area under sub-section (1) shall be`
  line `deemed to have been reduced to that extent.`
  line
  line `(4) Notwithstanding anything contained in sub-section (3), the State Government may exempt the`
  line `victims of any offence punishable under this Act or any person who does not, in its opinion, fall within`
  line `the category of persons specified in sub-section (1), from the liability to pay the collective fine imposed`
  line `under sub-section (1) or any portion thereof.`
  line
  line `(5) The portion of collective fine payable by any person (including a Hindu undivided family) may be`
  line `recovered in the manner provided by the Code of Criminal Procedure, 1973 (2 of 1974), for the recovery`
  line `of fines imposed by a Court as if such portion were a fine imposed by a Magistrate.]`
obj_root_law_sections_11:
  sectionId (36697)
  sectionNo (11)
  orderNo 13
  title `Enhanced penalty on subsequent conviction.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 106 of 1976, s. 14, for certain words (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36697&sectionno=11&orderno=13&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_11_content:
  string
  line `Whoever having already been convicted of an`
  line `offence under this Act or of an abetment of such offence is again convicted of any such offence or`
  line `abetment, ^1`
  line `[shall, on conviction, be punishable—`
  line
  line `(a) for the second offence, with imprisonment for a term of not less than six months and not more`
  line `than one year, and also with fine which shall be not less than two hundred rupees and not more than`
  line `five hundred rupees;`
  line
  line `(b) for the third offence or any offence subsequent to the third offence with imprisonment for a`
  line `term of not less than one year and not more than two years, and also with fine which shall be not less`
  line `than five hundred rupees and not more than one thousand rupees].`
obj_root_law_sections_12:
  sectionId (36698)
  sectionNo (12)
  orderNo 14
  title `Presumption by Courts in certain cases.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36698&sectionno=12&orderno=14&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_12_content:
  string
  line `Where any act constituting an offence under this Act`
  line `is committed in relation to a member of a Scheduled Caste ^1`
  line `***, the Court shall presume, unless the`
  line `contrary is proved, that such act was committed on the ground of "untouchability".`
obj_root_law_sections_12_footnotes:
  string
  line `1. The words, brackets and figures "as defined in clause (24) of article 366 of the Constitution" omitted by s. 15, ibid.`
  line `(w.e.f. 19-11-1976).`
obj_root_law_sections_13:
  sectionId (36699)
  sectionNo (13)
  orderNo 15
  title `Limitation of Jurisdiction of Civil Courts.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36699&sectionno=13&orderno=15&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_13_content:
  string
  line `(1) No Civil Court shall entertain or continue any`
  line `suit or proceeding or shall pass any decree or order if the claim involved in such suit or proceeding or if`
  line `the passing of such decree or order or if such execution would in any way be contrary to the provisions of`
  line `this Act.`
  line
  line `(2) No Court shall, in adjudicating any matter or executing any decree or order, recognise any custom`
  line `or usage imposing any disability on any person on the ground of "untouchability".`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (36700)
  sectionNo (14)
  orderNo 16
  title `Offences by companies.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36700&sectionno=14&orderno=16&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_14_content:
  string
  line `(1) If the person committing an offence under this Act is a company,`
  line `every person who at the time the offence was committed was in charge of, and was responsible to the`
  line `company for the conduct of the business of the company, shall be deemed to be guilty of the offence and`
  line `shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he exercised all`
  line `due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed with the consent of any director or manager, secretary or other officer of the company, such`
  line `director, manager, secretary or other officer shall also be deemed to be guilty of that offence and shall be`
  line `liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.—For the purposes of this section,—`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director" in relation to a firm means a partner in the firm.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_14_a:
  sectionId (36701)
  sectionNo 14A
  orderNo 17
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_14_a_content
  footnotes `1. Ins. by Act 106 of 1976, s. 16 (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36701&sectionno=14A&orderno=17&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_14_a_content:
  string
  line ^1
  line `[14A. Protection of action taken in good faith.--(1) No suit, prosecution or other legal proceeding`
  line `shall lie against the Central Government or a State Government for anything which is in good faith done`
  line `or intended to be done under this Act.`
  line
  line `(2) No suit or other legal proceeding shall lie against the Central Government or a State Government`
  line `for any damage caused or likely to be caused by anything which is in good faith done or intended to be`
  line `done under this Act.]`
obj_root_law_sections_15:
  sectionId (36702)
  sectionNo (15)
  orderNo 18
  title `Offences to be cognizable and triable summarily.`
  content obj_root_law_sections_15_content
  footnotes `1. Subs. by s. 17, ibid., for s. 15 (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36702&sectionno=15&orderno=18&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_15_content:
  string
  line `^1[15. Offences to be cognizable and triable summarily.—(1) Notwithstanding anything contained`
  line `in the Code of Criminal Procedure, 1973 (2 of 1974), every offence punishable under this Act shall be`
  line `cognizable and every such offence, except where its punishable with imprisonment for a minimum term`
  line `exceeding three months, may be tried summarily by a Judicial Magistrate of the first class or in a`
  line `metropolitan area by a Metropolitan Magistrate in accordance with the procedure specified in the said`
  line Code.
  line
  line `(2) Notwithstanding anything contained in the Code of Criminal Procedure, 1973 (2 of 1974), when`
  line `any public servant is alleged to have committed the offence of abetment of an offence punishable under`
  line `this Act, while acting or purporting to act in the discharge of his official duty, no Court shall take`
  line `cognizance of such offence of abetment except with the previous sanction—`
  line
  line `(a) of the Central Government, in the case of a person employed in connection with the affairs of`
  line `the Union; and`
  line
  line `(b) of the State Government, in the case of a person employed in connection with the affairs of a`
  line State.
obj_root_law_sections_15_a:
  sectionId (36709)
  sectionNo 15A
  orderNo 19
  title `Duty of State Government to ensure that the rights accruing from the abolition of "untouchability" may be availed of by the concerned persons.`
  content obj_root_law_sections_15_a_content
  footnotes obj_root_law_sections_15_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36709&sectionno=15A&orderno=19&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_15_a_content:
  string
  line `(1) Subject to such rules as the`
  line `Central Government may make in this behalf, the State Government shall take such measures as may be`
  line `necessary for ensuring that the rights arising from the abolition of "untouchability" are made available to,`
  line `and are availed of by the persons subjected to any disability arising out of "untouchability".`
  line
  line `(2) In particular, and without prejudice to the generality of the provisions of sub-section (1), such`
  line `measures may include—`
  line
  line `(i) the provision of adequate facilities, including legal aid, to the persons subjected to any`
  line `disability arising out of "untouchability" to enable them to avail themselves of such rights;`
  line
  line `(ii) the appointment of officers for initiating or exercising supervision over prosecutions for the`
  line `contravention of the provisions of this Act;`
  line
  line `(iii) the setting up of special courts for the trial of offences under this Act;`
  line
  line `(iv) the setting up of Committees at such appropriate levels as the State Government may think fit`
  line `to assist the State Government in formulating or implementing such measures;`
  line
  line `(v) provision for a periodic survey of the working of the provisions of this Act with a view to`
  line `suggesting measures for the better implementation of the provisions of this Act;`
  line
  line `(vi) the identification of the areas where persons are under any disability arising out of`
  line `"untouchability" and adoption of such measures as would ensure the removal of such disability from`
  line `such areas.`
  line
  line `(3) The Central Government shall take such steps as may be necessary to coordinate the measures`
  line `taken by the State Governments under sub-section (1).`
  line
  line `(4) The Central Government shall, every year, place on the Table of each House of Parliament, a`
  line `report on the measures taken by itself and by the State Governments in pursuance of the provisions of this`
  line section.]
obj_root_law_sections_15_a_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (36704)
  sectionNo (16)
  orderNo 20
  title `Act to override other laws.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36704&sectionno=16&orderno=20&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_16_content:
  string
  line `Save as otherwise expressly provided in this Act, the provisions of`
  line `this Act shall have effect notwithstanding anything inconsistent therewith contained in any other law for`
  line `the time being in force, or any custom or usage or any instrument having effect by virtue of any such law`
  line `or any decree or order of any Court or other authority.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_16_a:
  sectionId (36705)
  sectionNo 16A
  orderNo 21
  title `Probation of Offenders Act, 1958, not to apply to persons above the age of fourteen years.`
  content obj_root_law_sections_16_a_content
  footnotes `1. Ins. by Act 106 of 1976, s. 18 (w.e.f. 19-11-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36705&sectionno=16A&orderno=21&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_16_a_content:
  string
  line ^1
  line `[16A. Probation of Offenders Act, 1958, not to apply to persons above the age of fourteen`
  line `years.—The provisions of the Probation of Offenders Act, 1958 (20 of 1958), shall not apply to any`
  line `person above the age of fourteen years who is found guilty of having committed any offence punishable`
  line `under this Act.]`
obj_root_law_sections_16_b:
  sectionId (36706)
  sectionNo 16B
  orderNo 22
  title `Power to make rules.`
  content obj_root_law_sections_16_b_content
  footnotes obj_root_law_sections_16_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36706&sectionno=16B&orderno=22&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_16_b_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, make rules to carry out the provisions of this Act.`
  line
  line `(2) Every rule made by the Central Government under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament while it is in session for a total period of thirty days which may`
  line `be comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule.]`
obj_root_law_sections_16_b_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (36707)
  sectionNo (17)
  orderNo 23
  title Repeal.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00002_195522_1517807318156&sectionId=36707&sectionno=17&orderno=23&orgactid=AC_CEN_5_23_00002_195522_1517807318156
obj_root_law_sections_17_content:
  string
  line `The enactments specified in the Schedule are hereby repealed to the extent to which`
  line `they or any of the provisions contained therein correspond or are repugnant to this Act or to any of the`
  line `provisions contained therein.`
obj_root_law_sections_17_footnotes:
  string
  line
