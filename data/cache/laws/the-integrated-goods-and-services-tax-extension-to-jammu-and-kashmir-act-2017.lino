obj_root_law_sections_1:
  sectionId (35448)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_201727_1517807328026&sectionId=35448&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00041_201727_1517807328026
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Integrated Goods and Services Tax`
  line `(Extension to Jammu and Kashmir) Act, 2017.`
  line
  line `(2) It shall be deemed to have come into force on the 8th day of July, 2017.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (35449)
  sectionNo (2)
  orderNo 2
  title `Extension and amendment of Integrated Goods and Services Tax Act, 2017.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_201727_1517807328026&sectionId=35449&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00041_201727_1517807328026
obj_root_law_sections_2_content:
  string
  line `The Integrated Goods and Services`
  line `Tax Act, 2017 (13 of 2017) (hereinafter referred to as the principal Act) and all rules, notifications, schemes and orders`
  line `made thereunder by the Central Government are hereby extended to, and shall be in force in, the State of Jammu and`
  line Kashmir*.
  line
  line `(2) With effect from the date of commencement of this Act, in the principal Act, in section 1, in sub-section (2), the`
  line `words except the State of Jammu and Kashmir* shall be omitted.`
obj_root_law_sections_2_footnotes:
  string
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_3:
  sectionId (35450)
  sectionNo (3)
  orderNo 3
  title `Repeal and saving.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00041_201727_1517807328026&sectionId=35450&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00041_201727_1517807328026
obj_root_law_sections_3_content:
  string
  line `(1) The Integrated Goods and Services Tax (Extension to Jammu and Kashmir) Ordinance`
  line `(Ord. 4 of 2017) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be deemed to`
  line `have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
