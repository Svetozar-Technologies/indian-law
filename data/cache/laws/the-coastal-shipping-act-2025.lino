obj_root_law:
  object
  (str slug) (str the-coastal-shipping-act-2025)
  (str handle) (str 22146)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Coastal Shipping Act, 2025`)
  (str actNumber) (str 20)
  (str enactmentDate) (str 2025-08-09)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/22146`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (undefined)
  (str actYear) (str 2025)
  (str ministry) (str `Ministry of Ports, Shipping and Waterways`)
  (str department) (undefined)
  (str longTitle) (str `An Act to consolidate and amend the law relating to regulation of coastal shipping, promote coasting trade and encourage domestic participation therein, to ensure that India is equipped with a coastal fleet, owned and operated by the citizens of India for its national security and commercial needs, and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (undefined)
  (str notification) (undefined)
