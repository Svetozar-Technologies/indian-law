  slug the-coastal-shipping-act-2025
  handle (22146)
  collectionHandle 123456789/1362
  title `The Coastal Shipping Act, 2025`
  actNumber (20)
  enactmentDate 2025-08-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/22146`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (2025)
  ministry `Ministry of Ports, Shipping and Waterways`
  department undefined
  longTitle `An Act to consolidate and amend the law relating to regulation of coastal shipping, promote coasting trade and encourage domestic participation therein, to ensure that India is equipped with a coastal fleet, owned and operated by the citizens of India for its national security and commercial needs, and for matters connected therewith or incidental thereto.`
  enforcementDate undefined
  notification undefined
