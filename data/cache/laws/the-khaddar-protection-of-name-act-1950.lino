obj_root_law_sections_1:
  sectionId (36320)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00005_195078_1517807321750&sectionId=36320&sectionno=1&orderno=1&orgactid=AC_CEN_20_25_00005_195078_1517807321750
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Khaddar (Protection of Name) Act, 1950.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
obj_root_law_sections_1_footnotes:
  string
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (36321)
  sectionNo (2)
  orderNo 2
  title `The words Khaddar and Khadi to be trade description`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00005_195078_1517807321750&sectionId=36321&sectionno=2&orderno=2&orgactid=AC_CEN_20_25_00005_195078_1517807321750
obj_root_law_sections_2_content:
  string
  line `The words "Khaddar" and`
  line `"Khadi", whether in Hindi or in any other Indian language or in English, when applied to any woven`
  line `material, shall be deemed to be a trade description within the meaning of the Indian Merchandise Marks`
  line `Act, 1889 (40 of 1889), indicating that such material is cloth woven on handlooms in India from cotton,`
  line `silk or woolen yarn hand-spun in India or from a mixture of any two or all of such yarns.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (36322)
  sectionNo (3)
  orderNo 3
  title Repealed.
  content `[Repealed].--Rep. by the Repealing and Amending Act, 1957 (36 of 1957) s. 2 and First Schedule.`
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00005_195078_1517807321750&sectionId=36322&sectionno=3&orderno=3&orgactid=AC_CEN_20_25_00005_195078_1517807321750
obj_root_law_sections_3_footnotes:
  string
  line
