  (str title) (str Repealed.)
  (str content) (str `[Repealed].--Rep. by the Repealing and Amending Act, 1957 (36 of 1957) s. 2 and First Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00005_195078_1517807321750&sectionId=36322&sectionno=3&orderno=3&orgactid=AC_CEN_20_25_00005_195078_1517807321750)
