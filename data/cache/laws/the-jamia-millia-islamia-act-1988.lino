obj_root_law_sections_1:
  sectionId (23343)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23343&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Jamia Millia Islamia Act, 1988.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 26th December, 1988, vide notifications No. S.O. 1195(E), dated 21st December, 1988, See Gazette of India, Extraordinary,`
  line `part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (23344)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23344&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the contest otherwise`
  line requires,--
  line
  line `(a) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(b) "Amir-i-Jamia (Chancellor)" and "Shaikh-ul-Jamia (Vice-Chancellor)" mean, respectively,`
  line `the Amir-i-Jamia (Chancellor) and Shaikh-ul-Jamia (Vice-Chancellor) of the University;`
  line
  line `(c) "Anjuman (Court)" means the Anjuman (Court) of the University;`
  line
  line `(d) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(e) "Department" means a Department of Studies, and includes a Centre of Studies and Research;`
  line
  line `(f) "employee" means any person appointed by the University, and includes teachers and other`
  line `staff of the University;`
  line
  line `(g) "Faculty" means a Faculty of the University;`
  line
  line `(h) "Hall" means a unit of residence or of corporate life for the students of the University;`
  line
  line `(i) "Institution" means an Academic Institution, established or maintained by the University;`
  line
  line `(j) "Majlis-i-Muntazimah (Executive Council)" means the Majlis-i-Muntazimah`
  line `(Executive Council) of the University;`
  line
  line `(k) "Majlis-i-Talimi (Academic Council)" means the Majlis-i-Talimi (Academic Council) of the`
  line University;
  line
  line `(l) "Principal" means the head of an Institution, School or Polytechnic and includes where there is`
  line `on Principal, the person for the time being duly appointed to act as Principal, and, in the absence of`
  line `the Principal or acting Principal, a Vice-Principal duly appointed as such;`
  line
  line `(m) "Statutes", "Ordinances" and "Regulations" mean, respectively, the Statutes, Ordinances and`
  line `Regulations of the University for the time being in force;`
  line
  line `(n) "teachers of the University" means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instruction or conducting research in the University and are`
  line `designated as teachers by the Ordinances;`
  line
  line `(o) "University" means the educational institution known as "Jamia Millia Islamia" founded in`
  line `1920 during the Khilafat and Non-Co-operation Movements in response to Gandhiji's call for a`
  line `boyctt of all Government-sponsored educational institutions which was subsequently registered in`
  line `1939 as Jamia Millia Islamia Society, and declared in 1962 as an institution deemed to be a University under section 3 of the University Grants Commission Act, 1956 (3 of 1956), and which is`
  line `incorporated as a University under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (23345)
  sectionNo (3)
  orderNo 3
  title `The University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23345&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established a University by the name of the Jamia Millia`
  line Islamia.
  line
  line `(2) The headquarters of the University shall be at New Delhi.`
  line
  line `(3) The persons holding office as Amir-i-Jamia (Chancellor) and Shaikh-ul-Jamia (Vice-Chancellor)`
  line `and the members of the Anjuman (Court), the Majlis-i-Muntazimah (Executive Council) and the`
  line `Majlis-i-Talimi (Academic Council) of the University, for the time being, shall be a body corporate by the`
  line `name of the Jamia, Millia Islamia and shall have perpetual succession and a common seal and shall sue`
  line `and be sued by that name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (23346)
  sectionNo (4)
  orderNo 4
  title `Dissolution of the Jamia Millia Islamia Society and transfer of all property to the University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23346&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_4_content:
  string
  line `On and from the commencement of this Act,--`
  line
  line `(i) the Society known as the Jamia Millia Islamia Society, Delhi, shall be dissolved, and all`
  line `property, movable or immovable, and all rights, powers and privileges of the said Society shall be`
  line `transferred to and vest in the University and shall be applied to the objects and purposes for which the`
  line `University is established;`
  line
  line `(ii) all debts, liabilities and obligations of the said Society shall be transferred to the University`
  line `and shall thereafter be discharged and satisfied by it;`
  line
  line `(iii) all references in any enactment to the said Society shall be construed as references to the`
  line University;
  line
  line `(iv) any will, deed or other documents, whether made or executed before or after the`
  line `commencement of this Act, which contains any bequest, gift or trust in favour of the said Society`
  line `shall be construed as if the University was therein named instead of the Society;`
  line
  line `(v) subject to any orders which the Majlis-i-Muntazimah (Executive Council) may make, the`
  line `buildings which belonged to the Jamia Millia Islamia, Delhi, shall continue to be known and`
  line `designated by the names and style as they were known and designated immediately before the`
  line `commencement of this Act;`
  line
  line `(vi) subject to the provisions of this Act, every person employed immediately before the`
  line `commencement of this Act in the Jamia Millia Islamia, Delhi, shall hold such employment in the`
  line `University by the same tenure and on the same terms and conditions and with the same rights and`
  line `privileges as to pension and gratuity as he would have held under the Jamia Millia Islamia, Delhi, if`
  line `this Act had not been passed.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (23347)
  sectionNo (5)
  orderNo 5
  title `Objects of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23347&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_5_content:
  string
  line `The objects of the University shall be to disseminate and advance`
  line `knowledge by providing instructional, research and extension facilities in such branches of learning as it`
  line `may deem fit and the University shall endeavour to provide to students and teachers the necessary`
  line `atmosphere and facilities for the promotion of--`
  line
  line `(i) innovations in education leading to restructuring of courses, new methods of teaching and`
  line `learning, and integral development of personality;`
  line
  line `(ii) studies in various disciplines;`
  line
  line `(iii) inter-disciplinary students;`
  line
  line `(iv) national integration, secularism and international understanding.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (23348)
  sectionNo (6)
  orderNo 6
  title `Powers of the University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23348&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_6_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provisions for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to promote the study of the religions, philosophy and culture of India;`
  line
  line `(iii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing, on persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(iv) to organise and to undertake extra-mural studies, extension services and other measures for`
  line `the promotion of adult education;`
  line
  line `(v) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(vi) to provide, instruction, including correspondence and such other courses, to such persons as`
  line `are not members of the University, as it may determine;`
  line
  line `(vii) to institute Principalships, Professorships, Readerships, Lecturerships and other teaching or`
  line `academic posts required by the University and to appoint persons to such Principalships,`
  line `Professorships, Readerships, Lecturerships or other posts;`
  line
  line `(viii) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(ix) to appoint persons working in any other University or organisation as teachers of the`
  line `University for a specified period;`
  line
  line `(x) to co-operate, collaborate or associate with any other University or authority or institution in`
  line `such manner and for such purposes as the University may determine;`
  line
  line `(xi) to establish and maintain Schools, Institutions and such Centres, Specialised Laboratories or`
  line `other units for research and instructions as are, in the opinion of the University, necessary for the`
  line `furtherance of its objects;`
  line
  line `(xii) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xiii) to establish and maintain Halls for the students of the University;`
  line
  line `(xiv) to make provision for research and advisory services, and for that purpose to enter into such`
  line `arrangements with other institutions or bodies as the University may deem necessary;`
  line
  line `(xv) to declare a Centre, an Institution, a Department, a School as an autonomous Centre,`
  line `Institution, Department or school, as the case may be, in accordance with the Statutes;`
  line
  line `(xvi) to determine standards for admission into the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xvii) to demand and receive payment of fees and other charges;`
  line
  line `(xviii) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xix) to make special arrangements in respect of woman students as the University may consider`
  line desirable;
  line
  line `(xx) to regulate and enforce discipline among the employees and students of the University and`
  line `take such disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxi) to make arrangements for promoting the health and general welfare of the employees of the`
  line University;
  line
  line `(xxii) to receive donations and to acquire, hold, manage and dispose of any property, movable or`
  line `immovable, including trust and endowment properties for the purposes of the University;`
  line
  line `(xxiii) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University;`
  line
  line `(xxiv) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of the objects of the University.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (23349)
  sectionNo (7)
  orderNo 7
  title `University open to all classes, castes and creed.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23349&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_7_content:
  string
  line `The University shall be open to persons of`
  line `either sex and of whatever race, creed, caste or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person any test whatsoever of religious belief or profession in order to entitle him to be`
  line `admitted therein as a teacher or student, or to hold any office therein or to graduate thereat:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making`
  line `appropriate provisions for reservation for the Scheduled Castes, the Scheduled Tribes, the physically`
  line `handicapped persons and women.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (23350)
  sectionNo (8)
  orderNo 8
  title `The Visitor.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23350&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_8_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor shall have the right to cause an inspection to be made by such person or persons as he`
  line `may direct, of the University, its buildings, laboratories and equipment, and of any Centre, Department,`
  line `Institution or School maintained by the University and also of the examinations, teaching and other work`
  line `conducted or done by the University and to cause an inquiry to be made in like manner in respect of any`
  line `matter connected with the administration or finances of the University, Centre, Department, Institution or`
  line School.
  line
  line `(3) The Visitor shall, in every case, given notice to the University of his intention to cause an`
  line `inspection or inquiry to be made, and the University shall, on receipt of such notice, have the right to`
  line `make, within thirty days from the date of receipt of the notice or such other period as the Visitor may`
  line `determine, such representations to the Visitor, as it may consider necessary.`
  line
  line `(4) After considering the representations, if any, made by the University, the Visitor may cause to be`
  line `made such inspection or inquiry as is referred to in sub-section (2).`
  line
  line `(5) Where any inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative who shall have the right to present and be heard at such inspection`
  line `or inquiry.`
  line
  line `(6) The Visitor may, if the inspection or inquiry is made in respect of the University or any Centre,`
  line `Department, Institution or School maintained by it, address the Shaikh-ul-Jamia (Vice-Chancellor) with`
  line `reference to the result of such inspection or inquiry, and the Shaikh-ul-Jamia (Vice-Chancellor) shall`
  line `communicate to the Majlis-i-Muntazimah (Executive Council) the views of the Visitor with such advice`
  line `as the Visitor may offer upon the action to be taken thereon.`
  line
  line `(7) Where the Majlis-i-Muntazimah (Executive Council) does not, within a reasonable time, take`
  line `action to the satisfaction of the Visitor, the Visitor, may, after considering any explanation furnished or`
  line `representation made by the Majlis-i-Muntazimah (Executive Council) issue such directions as he may`
  line `think fit and the Majlis-i-Muntazimah (Executive Council), shall comply with such directions.`
  line
  line `(8) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in writing,`
  line `annul any proceeding of the University which is not in conformity with this Act, the Statutes or the`
  line `Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the University to show cause why`
  line `such an order should not be made, and, if any cause is shown within a reasonable time, he shall consider`
  line `the same.`
  line
  line `(9) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (23351)
  sectionNo (9)
  orderNo 9
  title `Officers of the University.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23351&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_9_content:
  string
  line `The following shall be the officers of the University:--`
  line
  line `(i) the Amir-i-Jamia (Chancellor);`
  line
  line `(ii) the Shaikh-ul-Jamia (Vice-Chancellor);`
  line
  line `(iii) the Naib Shaikh-ul-Jamia (Pro-Vice-Chancellor);`
  line
  line `(iv) the Musajjil (Registrar);`
  line
  line `(v) the Deans of Faculties;`
  line
  line `(vi) the Dean of Students' Welfare;`
  line
  line `(vii) the Finance Officer; and`
  line
  line `(viii) such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (23352)
  sectionNo (10)
  orderNo 10
  title `The Amir-i-Jamia (Chancellor).`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23352&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_10_content:
  string
  line `(1) The Amir-i-Jamia (Chancellor) shall be elected by the`
  line `Anjuman (Court) in such manner as may be prescribed by the Statutes.`
  line
  line `(2) The Amir-i-Jamia (Chancellor) shall, by virtue of his office, be the Head of the University.`
  line
  line `(3) The Amir-i-Jamia (Chancellor) shall, if present, preside at the Convocation of the University held`
  line `for conferring degrees.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (23353)
  sectionNo (11)
  orderNo 11
  title `The Shaikh-ul-Jamia (Vice-Chancellor).`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23353&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_11_content:
  string
  line `(1) The Shaikh-ul-Jamia (Vice-Chancellor) shall be`
  line `appointed by the Visitor in such manner as may be prescribed by the Statutes.`
  line
  line `(2) The Shaikh-ul-Jamia (Vice-Chancellor) shall be the principal executive and academic officer of`
  line `the University, and shall exercise general supervision and control over the affairs of the University and`
  line `give effect to the decision of all the authorities of the University.`
  line
  line `(3) The Shaikh-ul-Jamia (Vice-Chancellor) may, if he is of opinion that immediate action is necessary`
  line `on any matter, exercise any power conferred on any authority of the University by or under this Act and`
  line `shall report to such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been taken, it`
  line `may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Shaikh-ul-Jamia (Vice-Chancellor) under this sub-section shall have the right to appeal against`
  line `such action to the Majlis-i-Muntazimah (Executive Council) within three months from the date on which`
  line `decision on such action is communicated to him, and thereupon the Majlis-i-Muntaiimah`
  line `(Executive Council) may confirm, modify or reverse the action taken by the Shaikh-ul-Jamia`
  line `(Vice-Chancellor).`
  line
  line `(4) The Shaikh-ul-Jamia (Vice-Chancellor) shall exercise such other powers and perform such other`
  line `functions as may be prescribed by the Statutes or Ordinances.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (23354)
  sectionNo (12)
  orderNo 12
  title `The Naib Shaikh-ul-Jamia (Pro-Vice-Chancellor).`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23354&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_12_content:
  string
  line `The Naib Shaikh-ul-Jamia`
  line `(Pro-Vice-Chancellor) shall be appointed in such manner, and shall exercise such powers and perform`
  line `such duties as may be prescribed by the Statutes.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (23355)
  sectionNo (13)
  orderNo 13
  title `The Musajjil (Registrar).`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23355&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_13_content:
  string
  line `(1) The Musajjil (Registrar) shall be appointed in such manner as`
  line `may be prescribed by the Statutes.`
  line
  line `(2) The Musajjil (Registrar) shall have the power to enter into agreements, sign documents and`
  line `authenticate records on behalf of the University and shall exercise such other powers and perform such`
  line `other duties as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (23356)
  sectionNo (14)
  orderNo 14
  title `Deans of Faculties.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23356&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_14_content:
  string
  line `Every Dean of a Faculty shall be appointed in such manner and shall`
  line `exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (23357)
  sectionNo (15)
  orderNo 15
  title `The Finance Officer.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23357&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_15_content:
  string
  line `The Finance Officer shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (23358)
  sectionNo (16)
  orderNo 16
  title `Other officers.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23358&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_16_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (23359)
  sectionNo (17)
  orderNo 17
  title `Authorities of the University.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23359&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_17_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(i) the Anjuman (Court);`
  line
  line `(ii) the Majlis-i-Muntazimah (Executive Council);`
  line
  line `(iii) the Majlis-i-Talimi (Academic Council);`
  line
  line `(iv) the Majlis-i-Maliyat (Finance Committee);`
  line
  line `(v) the Faculties;`
  line
  line `(vi) the Planning Board; and`
  line
  line `(vii) such other authorities as may be declared by the Statutes to be authorities of the University.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (23360)
  sectionNo (18)
  orderNo 18
  title `The Anjuman (Court).`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23360&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_18_content:
  string
  line `(1) The constitution of the Anjuman (Court) and the term of office of`
  line `its members shall be prescribed by the Statutes.`
  line
  line `(2) Subject to the provisions of this Act, the Anjuman (Court) shall have the following powers and`
  line `functions, namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the University`
  line `and the audit report on such accounts;`
  line
  line `(c) to advise the Visitor in respect of any matter which may be referred to it for advice; and`
  line
  line `(d) to perform such other functions as may be prescribed by this Act or Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (23361)
  sectionNo (19)
  orderNo 19
  title `The Majlis-i-Muntazimah (Executive Council).`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23361&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_19_content:
  string
  line `(1) The Majlis-i-Muntazimah`
  line `(Executive Council) shall be the principal executive body of the University.`
  line
  line `(2) The constitution of the Majlis-i-Talim (Academic Council), the term of office of its members and`
  line `its powers and duties shall be prescribed by the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (23362)
  sectionNo (20)
  orderNo 20
  title `The Majlis-i-Talimi (Academic Council).`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23362&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_20_content:
  string
  line `(1) The Majlis-i-Talimi (Academic Council) shall`
  line `be the principal academic body of the University and shall, subject to the provisions of this Act, the`
  line `Statutes and Ordinances co-ordinate and exercise general supervision over the academic policies of the`
  line University.
  line
  line `(2) The constitution of the Majlis-i-Talimi (Academic Council), the term of office of its members and`
  line `its powers and duties shall be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (23363)
  sectionNo (21)
  orderNo 21
  title `The Planning Board.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23363&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_21_content:
  string
  line `(1) The Planning Board shall be the principal planning body of the`
  line University.
  line
  line `(2) The constitution of the Planning Board, term of office of its members and its powers and duties`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (23364)
  sectionNo (22)
  orderNo 22
  title `Other authorities of the University.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23364&sectionno=22&orderno=22&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_22_content:
  string
  line `The constitution, powers and functions of the Faculties`
  line `and of such other authorities as may be declared by the Statutes to be authorities of the University, shall`
  line `be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (23365)
  sectionNo (23)
  orderNo 23
  title `Power to make Statutes.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23365&sectionno=23&orderno=23&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_23_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all`
  line `or any of the following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of the authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the election and continuance in office of the members of the said authorities, filling of`
  line `vacancies of members, and all other matters relating to those authorities for which it may be`
  line `necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers of the University and other academic staff and their emoluments;`
  line
  line `(e) the appointment of teachers and other academic staff working in any other University or`
  line `Institution for a specific period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provision for pension, insurance and`
  line `provident fund, the manner of termination of service and disciplinary actions;`
  line
  line `(g) the principles governing seniority of service of employees;`
  line
  line `(h) the procedure for arbitration in case of disputes between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Majlis-i-Muntazimah (Executive Council) by any employee or`
  line `student against the action of any officer or authority of the University;`
  line
  line `(j) the establishment and recognition of the students union or association of teachers, academic`
  line `staff or other employees;`
  line
  line `(k) the participation of the students in the affairs of the University;`
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(n) the institutions of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(o) the maintenance of discipline among the students;`
  line
  line `(p) the establishment and abolition of Faculties, Departments, Centres and Schools;`
  line
  line `(q) the delegation of powers vested in the authorities or officers of the University; and`
  line
  line `(r) all other matters which by this Act are to be, or may be, prescribed by the Statutes`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (23366)
  sectionNo (24)
  orderNo 24
  title `Statutes how to be made.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23366&sectionno=24&orderno=24&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_24_content:
  string
  line `(1) The first Statutes are those set out in the Schedule.`
  line
  line `(2) The Majlis-i-Muntazimah (Executive Council) may, from time to time, make new or additional`
  line `Statutes referred to in sub-section (1):`
  line
  line `Provided that the Majlis-i-Muntazimah (Executive Council), shall not make, amend or repeal any`
  line `Statute affecting the status, powers or constitution of any authority of the University until such authority`
  line `has been given an opportunity of expressing an opinion in writing on the proposed changes, and any`
  line `opinion so expressed shall be considered by Majlis-i-Muntazimah (Executive Council).`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require`
  line `the assent of the Visitor who may assent thereto or withhold assent or remit to the Majlis-i-Muntazimah`
  line `(Executive Council) for consideration.`
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may make new or`
  line `additional Statutes or amend or repeal the Statutes referred to in sub-section (1) during the period of three`
  line `years immediately after the commencement of this Act.`
  line
  line `(6) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may direct the`
  line `University to make provisions in the Statutes in respect of any matter specified by him and if the`
  line `Majlis-i-Muntazimah (Executive Council) is unable to implement such a direction within sixty days of its`
  line `receipt, the Visitor may, after considering the reasons, if any, communicated by the Majlis-i-Muntazimah`
  line `(Executive Council) for its inability to comply with such direction make or amend the Statutes suitably.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (23367)
  sectionNo (25)
  orderNo 25
  title `Power to make Ordinances.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23367&sectionno=25&orderno=25&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_25_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees, diplomas and certificates of the University;`
  line
  line `(f) the conditions for the award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(g) the conduct of examinations, including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing of special courses of studies for them;`
  line
  line `(j) the appointment and emoluments of employees other than those for whom provision has been`
  line `made in the Statutes;`
  line
  line `(k) the establishment of Centres of Studies, Boards of Studies, Inter-disciplinary Studies, Special`
  line `Centres, Specialised Laboratories and other Committees;`
  line
  line `(l) the manner of co-operation and collaboration with other Universities and authorities including`
  line `learned bodies or associations;`
  line
  line `(m) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(n) the remuneration to be paid to the examiners, moderators, invigilators and tabulators;`
  line
  line `(o) such other terms and conditions of service of teachers and other academic staff as are not`
  line `prescribed by the Statutes;`
  line
  line `(p) the management of institutions established by the University; and`
  line
  line `(q) all other matters which by this Act or the Statutes may be prescribed by the Ordinances.`
  line
  line `(2) The regulations and by-laws in force immediately before the commencement of this Act shall be`
  line `the first Ordinances of the University and may be repealed or amended at any time by the`
  line `Majlis-i-Muntazimah (Executive Council).`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (23368)
  sectionNo (26)
  orderNo 26
  title `Power to make Regulations.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23368&sectionno=26&orderno=26&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_26_content:
  string
  line `The authorities of the University may make Regulations`
  line `consistent with this Act, the Statutes and the Ordinances for the conduct of their own business, and that of`
  line `the Committees appointed by them and not provided for by this Act, the Statutes or the Ordinances in the`
  line `manner prescribed by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (23369)
  sectionNo (27)
  orderNo 27
  title `Annual report.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23369&sectionno=27&orderno=27&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_27_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Majlis-i-Muntazimah (Executive Council) and shall be submitted to the Anjuman (Court) on or after`
  line `such date as may be prescribed by the Statutes and the Anjuman (Court) shall consider the report in its`
  line `annual meeting.`
  line
  line `(2) The Anjuman (Court) shall submit the annual report to the Visitor along with its comments, if`
  line any.
  line
  line `(3) A copy of the annual report as submitted to the Visitor shall also be submitted to the Central`
  line `Government, which shall, as soon as may be, cause the same to be laid before both the Houses of`
  line Parliament.
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (23370)
  sectionNo (28)
  orderNo 28
  title `Annual accounts.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23370&sectionno=28&orderno=28&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_28_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be`
  line `prepared under the directions of the Majlis-i-Muntazimah (Executive Council) and shall, once at least`
  line `every year and at intervals of not more than fifteen months, be audited by the Comptroller and`
  line `Auditor-General of India or by such persons as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts, together with the audit report thereon, shall be submitted to the`
  line `Anjuman (Court) and the Visitor along with the observations of the Majlis-i-Muntazimah`
  line `(Executive Council).`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Anjuman (Court) and the observations of the Anjuman (Court), if any, shall, after being considered by the`
  line `Majlis-i-Muntazimah (Executive Council), be submitted to the Visitor.`
  line
  line `(4) A copy of the annual accounts, together with the audit report as submitted to the Visitor, shall also`
  line `be submitted to the Central Government which shall, as soon as may be, cause the same to be laid before`
  line `both the Houses of Parliament.`
  line
  line `(5) The audited annual accounts after having been laid before both the Houses of Parliament, shall be`
  line `published in the Gazette of India.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (23371)
  sectionNo (29)
  orderNo 29
  title `Conditions of services of employees.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23371&sectionno=29&orderno=29&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_29_content:
  string
  line `(1) Every employee of the University shall be appointed`
  line `under a written contract, which shall be lodged with the University and a copy of which shall be furnished`
  line `to the employee concerned.`
  line
  line `(2) Any dispute arising out of a contract between the University and any of the employees shall at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Majlis-i-Muntazimah (Executive Council), one member nominated by the employee concerned and an`
  line `umpire appointed by the Visitor.`
  line
  line `(3) The decision of the Tribunal of Arbitration referred to in sub-section (2), shall be final, and no suit`
  line `shall lie in any civil court in respect of the matters decided by the Tribunal.`
  line
  line `(4) Every request made by the employee under sub-section (2), shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration Act, 1940 (10 of 1940).`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (23372)
  sectionNo (30)
  orderNo 30
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23372&sectionno=30&orderno=30&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_30_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders of resolution of the Shaikh-ul-Jamia (Vice-Chancellor), Discipline Committee or Examination`
  line `Committee, as the case may be, and who has been debarred from appearing at the examinations of the`
  line `University for more than one year, may, within ten days of the date of receipt of such orders or copy of`
  line `such resolution by him, appeal to Majlis-i-Muntazimah (Executive Council) and the Majlis-i-Muntazimah`
  line `(Executive Council) may confirm, modify or reverse the decision of the Shaikh-ul-Jamia`
  line `(Vice-Chancellor) or the concerned Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of`
  line `sub-sections (2), (3) and (4) of section 29 shall as far as may be, apply to a reference made under this`
  line sub-section.
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (23373)
  sectionNo (31)
  orderNo 31
  title `Right to appeal.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23373&sectionno=31&orderno=31&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_31_content:
  string
  line `Every employee or student of the University shall, notwithstanding anything`
  line `contained in this Act, have a right to appeal within such time as may be prescribed by the Statutes, to the`
  line `Majlis-i-Muntazimah (Executive Council), against the decision of any officer or authority of the`
  line `University and thereupon the Majlis-i-Muntazimah (Executive Council) may confirm, modify or reverse`
  line `the decision appealed against.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (23374)
  sectionNo (32)
  orderNo 32
  title `Provident and pension funds.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23374&sectionno=32&orderno=32&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_32_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such pension or provident fund or provide such insurance schemes as it may deem fit in such`
  line `manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or pension fund has been so constituted, the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund as if it`
  line `were a Government provident fund.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (23375)
  sectionNo (33)
  orderNo 33
  title `Disputes as to constitution of University authorities and bodies.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23375&sectionno=33&orderno=33&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_33_content:
  string
  line `If any question arises as to`
  line `whether any person has been duly elected or appointed as, or is entitled to be, a member of any authority`
  line `or other body of the University, the matter shall be referred to the Visitor whose decision thereupon shall`
  line `be final.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (23376)
  sectionNo (34)
  orderNo 34
  title `Constitution of Committees.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23376&sectionno=34&orderno=34&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_34_content:
  string
  line `Where any authority of the University is given power by this Act`
  line `or the Statutes to appoint Committees, such Committees shall, save as otherwise provided, consist of the`
  line `members of the authority concerned and of such other persons (if any) as the authority in each case may`
  line `think fit.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (23377)
  sectionNo (35)
  orderNo 35
  title `Filling of casual vacancies.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23377&sectionno=35&orderno=35&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_35_content:
  string
  line `All casual vacancies among the members`
  line `(other than ex officio members) of any authority or other body of the University shall be filled, as soon as`
  line `conveniently may be, by the person or body who appointed, elected or co-opted the members whose place`
  line `has become vacant and the person appointed, elected or co-opted to a casual vacancy shall be a member`
  line `of such authority or body for the residue of the term for which the person whose place he fills would have`
  line `been a member.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (23378)
  sectionNo (36)
  orderNo 36
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23378&sectionno=36&orderno=36&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_36_content:
  string
  line `No act or`
  line `proceedings of any authority or other body of the University shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (23379)
  sectionNo (37)
  orderNo 37
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23379&sectionno=37&orderno=37&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_37_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or employee of the University for anything which is in good faith done or intended to be done`
  line `in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (23380)
  sectionNo (38)
  orderNo 38
  title `Mode of proof of University record.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23380&sectionno=38&orderno=38&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_38_content:
  string
  line `A copy of any receipt, application, notice, order,`
  line `proceeding, resolution of any authority or Committee of the University, or other documents in possession`
  line `of the University, or any entry in any register duly maintained by the University, if certified by the`
  line `Musajjil (Registrar), shall be received as prima facie evidence of such receipt, application, notice, order,`
  line `proceeding or resolution, documents or the existence of entry in the register and shall be admitted as`
  line `evidence of the matters and transaction therein where the original thereof would, if produced, have been`
  line `admissible in evidence, notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872)`
  line `or in any other law for the time being in force.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (23381)
  sectionNo (39)
  orderNo 39
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23381&sectionno=39&orderno=39&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_39_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act, shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act shall be laid as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (23382)
  sectionNo (40)
  orderNo 40
  title `Power to remove difficulties.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23382&sectionno=40&orderno=40&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_40_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order published in the Official Gazette, make such provisions, not`
  line `inconsistent with the provisions of this Act as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (23383)
  sectionNo (41)
  orderNo 41
  title `Transitional provisions.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00022_198858_1517807325657&sectionId=23383&sectionno=41&orderno=41&orgactid=AC_CEN_9_30_00022_198858_1517807325657
obj_root_law_sections_41_content:
  string
  line `(1) The Anjuman (Court), the Majlis-i-Muntazimah (Executive`
  line `Council), the Majlis-i-Talimi (Academic Council), the Majlis-i-Maliyat (Finance Committee) and`
  line `Faculties of the University shall, as soon as may be, after the commencement of this Act, be constituted in`
  line `accordance with the provisions of this Act and until so constituted, the Anjuman (Court), the`
  line `Majlis-i-Muntazimah (Executive Council), the Majlis-i-Talimi (Academic Council), the Majlis-i-Maliyat`
  line `(Finance Committee) and Faculties of the Jamia Millia Islamia functioning immediately before such`
  line `commencement, shall continue to exercise all the powers and perform all the functions of such authority`
  line `under this Act.`
  line
  line `(2) The Amir-i-Jamia (Chancellor), the Shaikh-ul-Jamia (Vice-Chancellor), the Musajjil (Registrar),`
  line `Deans of Faculties, Heads of the Departments, Principals of Institutions, other officers and employees of`
  line `the Jamia Millia Islamia holding office immediately before the commencement of this Act, shall, on and`
  line `from such commencement, continue to hold their respective offices by the same tenure and upon the same`
  line `terms and conditions as they held it immediately before such commencement.`
  line
  line `(3) Anything done or any action taken or any degree or other academic distinction conferred by the`
  line `Jamia Millia Islamia before the commencement of this Act shall, notwithstanding any change made by`
  line `this Act in the constitution of the Anjuman (Court), the Majlis-i-Muntazimah (Executive Council), the`
  line `Majlis-i-Talimi (Academic Council), the Majlis-i-Maliyat (Finance Committee), Faculties and other`
  line `officers be valid, as if such thing was done, action taken, or degree or academic distinction conferred`
  line `under this Act.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
