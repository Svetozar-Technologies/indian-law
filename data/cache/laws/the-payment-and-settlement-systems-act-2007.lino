  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00005_200751_1517807326929&sectionId=32502&sectionno=34&orderno=36&orgactid=AC_CEN_2_33_00005_200751_1517807326929
obj_root_law_sections_34_content:
  string
  line Nothing
  line `contained in this Act shall apply to stock exchanges or the clearing corporations of the stock exchanges.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_34_a:
  sectionId (32503)
  sectionNo 34A
  orderNo 37
  title `Act to apply to designated trade repository and issuer.`
  content obj_root_law_sections_34_a_content
  footnotes `1. Ins. by Act 18 of 2015, s. 5 (w.e.f. 1-6-2015).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00005_200751_1517807326929&sectionId=32503&sectionno=34A&orderno=37&orgactid=AC_CEN_2_33_00005_200751_1517807326929
obj_root_law_sections_34_a_content:
  string
  line `^1[34A. Act to apply to designated trade repository and issuer.--(1) The provisions of this Act`
  line `shall apply to, or in relation to, a designated trade repository or issuer, as they apply to, or in relation to,`
  line `payment systems to the extent applicable, subject to the modification that, throughout this Act, unless the`
  line `context otherwise requires,--`
  line
  line `(a) references to a "payment system" or "system provider" shall be construed as references to a`
  line `"designated trade repository" or "issuer", as the case may be;`
  line
  line `(b) references to "commencement of this Act" shall be construed with reference to--`
  line
  line `(i) a designated trade repository, as references to the date on which a trade repository is`
  line `specified by the Reserve Bank as a designated trade repository; and`
  line
  line `(ii) an issuer, as references to commencement of the Payment and Settlement Systems`
  line `(Amendment) Act, 2015 (18 of 2015).`
  line
  line `(2) The Reserve Bank may, on an application by a designated trade repository or otherwise, permit or`
  line `direct the designated trade repository to provide such other services as are deemed necessary from time to`
  line time.
  line
  line `Explanation.--For the purposes of this section, the expression "designated trade repository" shall`
  line `mean a trade repository or a class of trade repositories, as may be specified by the Reserve Bank from`
  line `time to time.]`
obj_root_law_sections_34_b:
  sectionId (50605)
  sectionNo 34B
  orderNo 38
  title `Powers of Reserve Bank not to apply to International Financial Services Centre`
  content obj_root_law_sections_34_b_content
  footnotes `1. Ins. by Act 50 of 2019, s. 33 and the second Schedule (w.e.f. 1-10-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00005_200751_1517807326929&sectionId=50605&sectionno=34B&orderno=38&orgactid=AC_CEN_2_33_00005_200751_1517807326929
obj_root_law_sections_34_b_content:
  string
  line `^1[34B. Powers of Reserve Bank not to apply to International Financial Services Centre.--`
  line `Notwithstanding anything contained in any other law for the time being in force, the powers exercisable`
  line `by the Reserve Bank under this Act,--`
  line
  line `(a) shall not extend to an International Financial Services Centre set up under sub-section (1) of`
  line `section 18 of the Special Economic Zones Act, 2005 (28 of 2005);`
  line
  line `(b) shall be exercisable by the International Financial Services Centres Authority established`
  line `under sub-section (1) of section 4 of the International Financial Services Centres Authority Act, 2019,`
  line
  line `in so far as regulation of financial products, financial services and financial institutions that are permitted`
  line `in the International Financial Services Centres are concerned.]`
obj_root_law_sections_35:
  sectionId (32504)
  sectionNo (35)
  orderNo 39
  title `Certain persons deemed to be public servants.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00005_200751_1517807326929&sectionId=32504&sectionno=35&orderno=39&orgactid=AC_CEN_2_33_00005_200751_1517807326929
obj_root_law_sections_35_content:
  string
  line `Every officer of the Reserve Bank who has`
  line `been entrusted with any power under this Act, shall be deemed to be a public servant within the meaning`
  line `of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (32505)
  sectionNo (36)
  orderNo 40
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00005_200751_1517807326929&sectionId=32505&sectionno=36&orderno=40&orgactid=AC_CEN_2_33_00005_200751_1517807326929
obj_root_law_sections_36_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `the Central Government, the Reserve Bank, or any officer thereof for any damage caused or likely to be`
  line `caused by anything which is in good faith done or intended to be done in pursuance of this Act, any`
  line `regulations, order or direction made or given thereunder.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (32506)
  sectionNo (37)
  orderNo 41
  title `Power to remove difficulties.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00005_200751_1517807326929&sectionId=32506&sectionno=37&orderno=41&orgactid=AC_CEN_2_33_00005_200751_1517807326929
obj_root_law_sections_37_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provision is`
  line `not inconsistent with the provisions of this Act as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of a period of two years from`
  line `the commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (32507)
  sectionNo (38)
  orderNo 42
  title `Power of Reserve Bank to make regulations.`
  content obj_root_law_sections_38_content
  footnotes `1. Subs. by the Finance Act 2017, s. 153, for "Committee constituted under sub-section (2)"`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00005_200751_1517807326929&sectionId=32507&sectionno=38&orderno=42&orgactid=AC_CEN_2_33_00005_200751_1517807326929
obj_root_law_sections_38_content:
  string
  line `(1) The Reserve Bank may, by notification,`
  line `make regulations consistent with this Act to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing provision, such regulations`
  line `may provide for all or any of the following matters, namely:--`
  line
  line `(a) the powers and functions of the ^1[Board referred to in sub-section (2)], the time and venue of`
  line `its meetings and the procedure to be followed by it at its meetings (including the quorum at such`
  line `meetings) under sub-section (4) of section 3;`
  line
  line `(b) the form and manner in which an application for authorisation for commencing or carrying on`
  line `a payment system shall be made and the fees which shall accompany such application under subsection (2) of section 5;`
  line
  line `(c) the form in which an authorisation to operate a payment system under this Act shall be issued`
  line `under sub-section (2) of section 7;`
  line
  line `(d) the format of payment instructions and other matters relating to determination of standards to`
  line `be complied with by the payment systems under sub-section (1) of section 10;`
  line
  line `(e) the intervals, at which and the form and manner in which the information or returns required`
  line `by the Reserve Bank shall be furnished under section 12;`
  line
  line `(f) such other matters as are required to be, or may be, prescribed.`
  line
  line `(2) Any regulation made under this section shall have effect from such earlier or later date (nor earlier`
  line `than the date of commencement of this Act) as may be specified in the regulation.`
  line
  line `(3) Every regulation shall, as soon as may be after it is made by the Reserve Bank, be forwarded to`
  line `the Central Government and that Central Government shall cause a copy of the same to be laid before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the regulation, or both Houses agree that the regulation should not be made, the regulation shall,`
  line `thereafter, have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that regulation.`
