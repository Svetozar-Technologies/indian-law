obj_root_law_sections_1:
  sectionId (46503)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46503&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Government Savings ^1[Promotion] Act, 1873.`
  line
  line `Local extent.--It extends to ^2[the whole of India`
  line `^3* * * * *].`
  line
  line `^4* * * * *`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 115, ibid., for "Banks" (w.e.f. 1-4-2018).`
  line
  line `2. Subs. by the A.O.1950, for "all the Provinces of India" which had been subs, by the A. O. 1948, for "the whole of British`
  line `India".`
  line
  line `3. The words "except the State of Jammu anti Kashmir" which were subs. by Act 3 of 1951, for "except Part B States" omitted`
  line `by Act 62 of 1956, s. 2 and Sch.`
  line
  line `4. The commencement clause rep. by Act 16 of 1874, s. 1 and Sch., Pt. I.`
obj_root_law_sections_2:
  sectionId (46504)
  sectionNo (2)
  orderNo 2
  title Omitted.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46504&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_2_content:
  string
  line `2. [Act not to apply to deposits in Anchal Savings Bank.Omitted by the Finance Act, 2018 (13 of`
  line `2018), s. 117 (w.e.f. 1-4-2018).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (46505)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 13 of 2018, s. 118, for section 3 (w.e.f. 1-4-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46505&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_3_content:
  string
  line `^1[3. Definitions.--In this Act, unless the context otherwise requires,--`
  line
  line `(a) "account" means an account opened under any of the Savings Schemes;`
  line
  line `(b) "administrator" means an administrator as defined in clause (a) of section 2 of the Indian`
  line `Succession Act, 1925 (39 of 1925);`
  line
  line `(c) "Authorised Officer" means--`
  line
  line `(i) in the case of a Post Office Savings Bank, an officer authorised by the Director General`
  line `Posts; and`
  line
  line `(ii) in the case of State Bank of India or a banking company or any other company or`
  line `institution, an officer so authorised by State Bank of India or that banking company or that other`
  line `company or that institution, as the case may be;`
  line
  line `(d) "banking company" means a banking company as defined in clause (c) of section 5 of the`
  line `Banking Regulation Act, 1949 (10 of 1949);`
  line
  line `(e) "depositor" means an individual by whom, or on whose behalf money has been deposited in a`
  line `Government Savings Bank and deposit means the money so deposited;`
  line
  line `(f) "executor" means an executor as defined in clause (c) of section 2 of the Indian Succession`
  line `Act, 1925 (39 of 1925);`
  line
  line `(g) "Government Savings Bank" means--`
  line
  line `(i) a Post Office Savings Bank; or`
  line
  line `(ii) State Bank of India or a banking company, or any other company or institution, as the`
  line `Central Government may, by notification in the Official Gazette, specify for the purposes of this`
  line Act;
  line
  line `(h) "guardian", in relation to a minor or a person of unsound mind means--`
  line
  line `(i) either of the parents;`
  line
  line `(ii) where neither parent is alive or where neither or the only living parent is incapable of`
  line `acting as such, a person entitled under the law for the time being in force to have the care of the`
  line `property of a minor or a person of unsound mind, as the case may be;`
  line
  line `(iii) legal guardian appointed by a court;`
  line
  line `(i) "minor" means a person who has not attained the age of majority under the Indian Majority`
  line `Act, 1875 (9 of 1875);`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(k) "Savings Schemes" means the Government Savings Schemes, including Savings Certificates`
  line `and Public Provident Fund Scheme, listed in the Schedule;`
  line
  line `(l) "Schedule" means the Schedule annexed to this Act.]`
obj_root_law_sections_3_a:
  sectionId (50284)
  sectionNo 3A
  orderNo 4
  title `Framing of Savings Schemes.`
  content obj_root_law_sections_3_a_content
  footnotes `1. Subs. by Act 13 of 2018, s. 118, for section 3 (w.e.f. 1-4-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=50284&sectionno=3A&orderno=4&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Framing of Savings Schemes.--(1) The Central Government may, by notification in the Official`
  line `Gazette, frame new Savings Schemes or amend or discontinue existing Savings Schemes to promote`
  line `household savings in the country.`
  line
  line `(2) The Central Government may, by notification in the Official Gazette, include or omit or amend`
  line `Savings Schemes in the Schedule.`
  line
  line `(3) The notification referred to in sub-section (1) may include any or all of the following provisions,`
  line `depending on the design of such Scheme, namely:--`
  line
  line `(a) the persons who shall be eligible to make deposit in a Savings Scheme;`
  line
  line `(b) the terms and conditions subject to which deposit may be made;`
  line
  line `(c) the manner of calculation, frequency of payment and rate of interest payable on the deposit;`
  line
  line `(d) the maximum and minimum limits of deposit;`
  line
  line `(e) premature closure, withdrawal of deposit, grant of loans against deposit and transfer of`
  line deposit;
  line
  line `(f) any other provision depending on the purpose and design of the Savings Scheme.]`
obj_root_law_sections_3_b:
  sectionId (50285)
  sectionNo 3B
  orderNo 5
  title `Deposit by minor.`
  content obj_root_law_sections_3_b_content
  footnotes `1. Subs. by Act 13 of 2018, s. 118, for section 3 (w.e.f. 1-4-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=50285&sectionno=3B&orderno=5&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_3_b_content:
  string
  line `^1[3B. Deposit by minor.--(1) A minor who has attained the age of ten years may open and operate an`
  line `account in the Government Savings Bank, if so permitted under a Savings Scheme.`
  line
  line `(2) Subject to the provisions of sub-section (1), the guardian of a minor may open and operate an`
  line `account on behalf of the minor, till he becomes a major.]`
obj_root_law_sections_4:
  sectionId (46506)
  sectionNo (4)
  orderNo 6
  title `Nomination by depositor.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46506&sectionno=4&orderno=6&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_4_content:
  string
  line `^1[4. Nomination by depositor.--^2[(1) The depositors shall designate one or more individuals, as`
  line `nominee or nominees, who shall be entitled, in the event of the death of the depositor of a single account,`
  line `or all the depositors of a joint account, as the case may be, to receive the sum due, as an owner or a`
  line `trustee, and to the extent, as may be specified by the depositor at the time of making nomination:`
  line
  line `Provided that if the depositor is a minor or a person of unsound mind, the nominee shall be`
  line `designated by the guardian.]`
  line
  line `(2) Any nomination referred to in sub-section (1) shall become void if the nominee predeceases, or`
  line `where there are two or more nominees, all the nominees predecease;`
  line `the depositor.`
  line
  line `(3) Where the nominee is a minor it shall be lawful for the depositor to appoint in the`
  line `prescribed manner any person to receive the deposit in the event of his death during the minority of`
  line `the nominee.`
  line
  line `^3[(4) The transfer of deposit, if permitted under a Savings Scheme, shall automatically cancel a`
  line `nomination previously made.]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 45 of 1959, s. 3, for the former s. 4.`
  line
  line `2. Subs. by Act 13 of 2018, s. 119, for sub-section (1) (w.e.f. 1-4-2018).`
  line
  line `3. Ins. by Act 13 of 2018, s. 119 (w.e.f. 1-4-2018).`
obj_root_law_sections_4_a:
  sectionId (46507)
  sectionNo 4A
  orderNo 7
  title `Payment on death of depositor.`
  content obj_root_law_sections_4_a_content
  footnotes obj_root_law_sections_4_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46507&sectionno=4A&orderno=7&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_4_a_content:
  string
  line `^1[4A. Payment on death of depositor.--(1) If a depositor dies and there is in force at the`
  line `time of the death of the depositor a nomination in favour of any person, the deposit shall be paid`
  line `to the nominee.`
  line
  line `(2) Where the nominee is a minor, the deposit shall be paid--`
  line
  line `(a) in any case where a person has been appointed to receive it under sub-section (3) of section 4,`
  line `to that person; and`
  line
  line `(b) where there is no such person, to the guardian of the minor for the use of the minor.`
  line
  line `(3) Where a deposit is payable to two or more nominees and either or any of them is dead, the deposit`
  line `shall be paid to the surviving nominee or nominees.`
  line
  line `^2[(3A) Where the deposit belongs to a minor or to a person of unsound mind who dies and there is no`
  line `nominee immediately before the date of commencement of Part I of Chapter VIII of the Finance Act,`
  line `2018, the deposit shall be paid to the guardian.]`
  line
  line `(4) If a depositor dies and there is no nomination in force at the time of his death and probate`
  line `of his will or letters of administration of his estate or a succession certificate granted under the`
  line `Indian Succession Act, 1925 (39 of 1925), is not within three months of the death of the`
  line `depositor produced to the ^3[Authorised Officer of the Government Savings Bank in which the`
  line `deposit is, then--`
  line
  line `(a) if the deposit does not exceed ^4[such limit as may be prescribed] the ^3[Authorised Officer]`
  line
  line `may pay the same to any person appearing to him to be entitled to receive it or to administer the estate`
  line `of the ^5[deceased in accordance with such procedure as may be prescribed.]`
  line
  line `^6* * * * *`
  line
  line `^7* * * * *]`
obj_root_law_sections_4_a_footnotes:
  string
  line `1. Subs. by Act 45 of 1959, s. 3, for the former s. 4.`
  line
  line `2. Ins. by s. 120, ibid. (w.e.f. 1-4-2018).`
  line
  line `3. Subs. by s. 116, ibid., for "Secretary" (w.e.f. 1-4-2018).`
  line
  line `4. Subs. by Act 56 of 1985, s. 2, for "five thousand rupees".`
  line
  line `5. Subs. by Act 13 of 2018, s. 120, for "deceased; and" (w.e.f. 1-4-2018).`
  line
  line `6. Clause (b) omitted by s. 120, ibid. (w.e.f. 1-4-2018).`
  line
  line `7. Sub-section (5) omitted by s. 120, ibid. (w.e.f. 1-4-2018).`
obj_root_law_sections_5:
  sectionId (46508)
  sectionNo (5)
  orderNo 8
  title `Payment to be discharge.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46508&sectionno=5&orderno=8&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_5_content:
  string
  line `^1[Any payment made in accordance with the foregoing`
  line `provisions of this Act] shall be a full discharge from all further liability in respect of the money s o`
  line paid
  line
  line `Saving of right of executor.-- ^2[Nothing] herein contained precludes any executor or`
  line `administrator, or other representative of the deceased, from recovering from the person`
  line `receiving the same the amount remaining in his hands after deducting the amount of all debts`
  line `or other demands lawfully paid or discharged by him in due course of administration.`
  line
  line `Saving of right of creditor.--^3[Every creditor] or claimant against the estate of the deceased`
  line `may recover his debt or claim out of the money paid under this Act, ^4*** to any person, and remaining`
  line `in his hands unadministered, in the same manner and to the same extent as ^5[if that person had obtained]`
  line `letters of administration of the estate of the deceased.`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs, by Act 45 of 1959, s. 4 for "Such paymentic".`
  line
  line `2. Subs. by Act 13 of 2018, s. 121, for "But nothing" (w.e.f. 1-4-2018).`
  line
  line `3. Subs. by Act 13 of 2018, s. 121, for "And any creditor" (w.e.f. 1-4-2018).`
  line
  line `4. Of the words "or the said Act No. 26 of 1855" the words "the said" were omitted by Act 12 of 1891, s. 2 and Sch. I, Pt. I, and`
  line `the remaining words by Act 45 of 1959, s. 4.`
  line
  line `5. Subs. by Act 13 of 2018, s. 121, for "if the latter had obtained" (w.e.f. 1-4-2018).`
obj_root_law_sections_6:
  sectionId (46509)
  sectionNo (6)
  orderNo 9
  title `Security for due administration.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46509&sectionno=6&orderno=9&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_6_content:
  string
  line `The ^1[Authorised Officer] of ^2[a Government Savings`
  line `Bank] may take such security as he thinks necessary from any person ^3[to whom he pays any`
  line `money under sub-section (4) of section 4A] for the due administration of the money so paid,`
  line `and he may assign the said security to any person interested in such administration.`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 13 of 2018, s. 116, for "Secretary" (w.e.f. 1-4-2018).`
  line `2. Subs. by s. 122, ibid., for certain words (w.e.f. 1-4-2018).`
  line `3. Subs. by Act 45 of 1959, s. 5, for "to whom he pays any money under section 4".`
obj_root_law_sections_7:
  sectionId (46510)
  sectionNo (7)
  orderNo 10
  title `Power to administer oath.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46510&sectionno=7&orderno=10&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_7_content:
  string
  line `For the purpose of ascertaining the right of the person`
  line `claiming to be entitled as aforesaid, the ^1[Authorised Officer] of ^2[a Government Savings Bank]`
  line `may take evidence on oath or affirmation according to the law^3`
  line `for the time being relating to oaths`
  line `oaths and affirmations.`
  line
  line `Penalty for false statements.--Any person who, upon such oath or affirmation, makes any`
  line `statement which is false, and which he either knows or believes to be false or does not believe to`
  line `be true, shall be deemed guilty of an offence under section 193 of the Indian Penal Code`
  line `(45 of 1860).`
obj_root_law_sections_7_footnotes:
  string
  line `1. Subs. by Act 13 of 2018, s. 116, for "Secretary" (w.e.f. 1-4-2018).`
  line
  line `2. Subs. by Act 13 of 2018, s. 123, for certain words (w.e.f. 1-4-2018).`
  line
  line `3. See the Indian Oaths Act, 1873 (10 of 1873).`
obj_root_law_sections_7_a:
  sectionId (50286)
  sectionNo 7A
  orderNo 11
  title `Power to call for information.`
  content obj_root_law_sections_7_a_content
  footnotes `1. Ins. by Act 13 of 2018, s. 124 (w.e.f. 1-4-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=50286&sectionno=7A&orderno=11&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_7_a_content:
  string
  line `^1[7A. Power to call for information--The Central Government through any designated authority,`
  line `may call for such information, documents and evidence as it may deem necessary, in relation to any`
  line `account, for carrying out the purposes of this Act.]`
obj_root_law_sections_8:
  sectionId (46511)
  sectionNo (8)
  orderNo 12
  title `Deposit when excluded in computing court fees.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46511&sectionno=8&orderno=12&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_8_content:
  string
  line `Where the amount of the deposit belonging to`
  line `the estate of a deceased depositor does not exceed ^1[the prescribed limit such amount shall be excluded`
  line `in computing the fee chargeable, under the Court-fees Act, 1870 (7 of 1870), on the probate, or letters of`
  line `administration, or certificate (if any), granted in respect of his property^2:`
  line
  line `Provided that the person claiming such probate or letters or certificate shall exhibit to the Court`
  line `authorised to grant the same a certificate of the amount of the deposit in any Government Savings`
  line `Bank belonging to the estate of the deceased. Such certificate shall be signed by the ^3[Authority`
  line `Officer] of such Bank, and the Court shall receive it as evidence of the said amount.`
obj_root_law_sections_8_footnotes:
  string
  line `1. Subs. by s. 125, ibid., for "three thousand rupees"`
  line `(w.e.f. 1-4-2018).`
  line
  line `2.Cf. the Savings Bank Act, 1828 (9 Geo. 4, c. 92), s. 40, now rep. by the Savings Banks Act, 1863 (26 and`
  line `27 Viet., c. 87).`
  line
  line `3. Subs. by Act 13 of 2018, s. 116, for "Secretary" (w.e.f. 1-4-2018).`
obj_root_law_sections_9:
  sectionId (46512)
  sectionNo (9)
  orderNo 13
  title `Act not to apply to deposits belonging to estates of European soldiers or deserters.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46512&sectionno=9&orderno=13&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_9_content:
  string
  line `[Act not to apply to deposits belonging to estates of European soldiers or deserters.] Rep. by the`
  line `Government Savings Banks (Amendment) Act, 1959 (45 of 1959), s. 7.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (46513)
  sectionNo (10)
  orderNo 14
  title `Payment of deposits to minor or guardian.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46513&sectionno=10&orderno=14&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_10_content:
  string
  line `Any deposit made by, ^1[or on behalf of, a`
  line `minor], may be paid to him personally, if he made the deposit, or to his guardian ^2[for the use of`
  line `such minor], if the deposit was made by any person other than the minor, together with the`
  line `interest accrued thereon.`
  line
  line `The ^3[receipt of the minor] or guardian, for money paid to him under this section, shall be a`
  line `sufficient discharge therefor.`
obj_root_law_sections_10_footnotes:
  string
  line `1. Subs. by Act 13 of 2018, s. 126, for d"or on behalf of, any minor" (w.e.f. 1-4-2018).`
  line
  line `2. Subs. by s. 126, ibid., for "for his use" (w.e.f. 1-4-2018).`
  line
  line `3. Subs. by s. 126, ibid., for "receipt of any minor" (w.e.f. 1-4-2018).`
obj_root_law_sections_11:
  sectionId (46514)
  sectionNo (11)
  orderNo 15
  title `Legalisation of like payments heretofore made.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46514&sectionno=11&orderno=15&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_11_content:
  string
  line `[Legalization of like payments heretofore made.] Rep. by the Government Savings Banks`
  line `(Amendment) Act, 1959 (45 of 1959), s. 7.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (46515)
  sectionNo (12)
  orderNo 16
  title `Payment of deposits belonging to lunatics.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46515&sectionno=12&orderno=16&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_12_content:
  string
  line `If any depositor becomes insane or otherwise`
  line `incapable of managing his affairs,`
  line
  line `and if such insanity or incapacity is proved to the satisfaction of the ^1[Authorised Officer] of the`
  line `^2[Government Savings Bank] in which his deposit may be,`
  line
  line `such ^1[Authorised Officer] may, from time to time, make payments out of the deposit to`
  line ^3[guardian],
  line
  line `and the receipt of ^4[such guardian], for money paid under this section, shall be a sufficient discharge`
  line therefor,
  line
  line `Where a committee or manager of the depositor’s estate has been duly appointed, ^5[payments shall be`
  line `be made t] such committee or manager.`
obj_root_law_sections_12_footnotes:
  string
  line `1. Subs. by Act 13 of 2018, s. 116, for "Secretary" (w.e.f. 1-4-2018).`
  line
  line `2. Subs. by s. 127, ibid., for "Bank" (w.e.f. 1-4-2018).`
  line
  line `3. Subs. by s. 127, ibid., for "any proper person" (w.e.f. 1-4-2018).`
  line
  line `4. Subs. by s. 127, ibid., for "such person" (w.e.f. 1-4-2018).`
  line
  line `5. Subs. by s. 127, ibid., for "nothing in this section authorises payments to any person other than" (w.e.f. 1-4-2018).`
obj_root_law_sections_12_a:
  sectionId (50287)
  sectionNo 12A
  orderNo 17
  title `Operation of account by differently abled persons.`
  content obj_root_law_sections_12_a_content
  footnotes `1. Ins. by s. 128, ibid. (w.e.f. 1-4-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=50287&sectionno=12A&orderno=17&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_12_a_content:
  string
  line `^1[12A. Operation of account by differently abled persons--.Any depositor who suffers from`
  line `physical infirmity, including blindness may operate and make a deposit through any literate individual`
  line `whom he authorises.]`
obj_root_law_sections_13:
  sectionId (46516)
  sectionNo (13)
  orderNo 18
  title Omitted.
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 45 of 1959, s. 8, for "the Indian Succession Act, 1865, section 4".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46516&sectionno=13&orderno=18&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_13_content:
  string
  line `[Payment of married women’s deposits.] Omitted by the Finance Act, 2018 (13 of 2018), s. 130`
  line `(w.e.f. 1-4-2018).`
obj_root_law_sections_14:
  sectionId (46517)
  sectionNo (14)
  orderNo 19
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46517&sectionno=14&orderno=19&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_14_content:
  string
  line `No suit or other legal proceeding shall lie against the`
  line `^1[Authorised Officer] or any other officer of the ^2[Central Government] in respect of anything which is in`
  line `good faith done or intended to be done under this Act.`
obj_root_law_sections_14_footnotes:
  string
  line `1. Subs. by Act 13 of 2018, s. 116, for "Secretary" (w.e.f. 1-4-2018).`
  line
  line `2 .Subs. by Act 13 of 2018, s. 131, for "Government" (w.e.f. 1-4-2018).`
obj_root_law_sections_14_a:
  sectionId (50288)
  sectionNo 14A
  orderNo 20
  title `Protection against attachment.`
  content obj_root_law_sections_14_a_content
  footnotes `1. Ins. by s. 132, ibid. (w.e.f. 1-4-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=50288&sectionno=14A&orderno=20&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_14_a_content:
  string
  line `^1[14A. Protection against attachment.--The amount standing to the credit of any depositor in the`
  line `Public Provident Fund Scheme shall not be liable to attachment under any decree or order of any court in`
  line `respect of any debt or liability incurred by the depositor.]`
obj_root_law_sections_15:
  sectionId (46518)
  sectionNo (15)
  orderNo 21
  title `Power to make rules.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=46518&sectionno=15&orderno=21&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_15_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, make rules for carrying out the purposes of this Act.`
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `^1* * * * *`
  line
  line `^2[(b) the conditions as to interest or discount relating to deposits generally, or any class of`
  line `deposits in particular;]`
  line
  line `(c) the non-accrual of interest on deposits when the maximum limits are exceeded and the`
  line `recovery of any interest paid in excess in the same manner as an arrear of land revenue or in any other`
  line manner;
  line
  line `(d) the persons to whom and the manner in which deposits may be paid;`
  line
  line `(e) the form of nominations, the manner in which, the persons in whose favour and the`
  line `conditions and restrictions subject to which, nominations may be made and the registration of`
  line nominations;
  line
  line `(f) the variation or cancellation of nominations;`
  line
  line `^3[(g) the fees that may be levied for discharge of any services under this Act;]`
  line `(h) the manner in which any person may be appointed for the purpose of subsection (3) of section`
  line 4;
  line
  line `^4[(i) the limit and procedure under clause (a) of sub-section (4) of section 4A;`
  line
  line `(j) the mode of making deposits, such as physical, electronic or through use of any other tools of`
  line `communication and information technology;`
  line
  line `(k) benchmark for interest rates on deposits with a view to ensure financial sustainability of`
  line `Savings Schemes;`
  line
  line `(l) amount to be excluded in computing the court fee chargeable under the Court-fees Act, 1870`
  line `(7 of 1870) for the purpose of section 8 of the Act;`
  line
  line `(m) mechanism for redressal of grievances and settlement of disputes;`
  line
  line `(n) any other matter which is required to be or may be, prescribed.]`
  line
  line `(3) Every rule made under this section shall be laid as soon as may be after it is made before each`
  line `House of Parliament while it is in session for a total period of thirty days which may be comprised in one`
  line `session or ^5[in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so however that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.]`
obj_root_law_sections_15_footnotes:
  string
  line `1. Clause (a) omitted by s. 133, ibid. (w.e.f. 1-4-2018).`
  line
  line `2. Subs. by s. 133, ibid., for clause (b) (w.e.f. 1-4-2018).`
  line
  line `3. Subs. by Act 13 of 2018, s. 133, for clause (g) (w.e.f. 1-4-2018).`
  line
  line `4. Subs. by s. 133, ibid., for clause (i) (w.e.f. 1-4-2018).`
  line
  line `5. Subs. by Act 20 of 1983, s. 2 and Sch. (w.e.f. 15-3-1984).`
obj_root_law_sections_16:
  sectionId (50289)
  sectionNo (16)
  orderNo 22
  title `Repeal and savings.`
  content obj_root_law_sections_16_content
  footnotes `1. Ins. by Act 13 of 2018, s. 134 (w.e.f. 1-4-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_187305_1523269408953&sectionId=50289&sectionno=16&orderno=22&orgactid=AC_CEN_2_11_00026_187305_1523269408953
obj_root_law_sections_16_content:
  string
  line `^1[16. Repeal and savings.--(1) The Government Savings Certificates Act, 1959 (46 of 1959) and the`
  line `the Public Provident Fund Act, 1968 (23 of 1968) are hereby repealed.`
  line
  line `(2) Notwithstanding such repeal and without prejudice to the provisions contained in the General`
  line `Clauses Act, 1897 (10 of 1897), with respect to repeals--`
  line
  line `(a) anything done or any action taken or purported to have been done or taken, including any rule,`
  line `notification, order or notice made or issued or any direction given under the repealed enactments shall`
  line `be deemed to have been done or taken under the corresponding provisions of this Act;`
  line
  line `(b) subject to the provisions of clause (a), any instrument executed or certificate issued, or`
  line `anything done under or in pursuance of any repealed enactment shall, if is in force at the`
  line `commencement of Part I of Chapter VIII of the Finance Act, 2018, continue to be in force in so far as`
  line `it could have been executed, or issued or done under or in pursuance of such Part, shall have effect as`
  line `if the same has been executed, issued or done under or in pursuance of the provisions contained in the`
  line `aforesaid Part;`
  line
  line `(c) all deposits made or accounts or certificates held under the repealed enactments shall be`
  line `deemed to be deposits or holdings in the Savings Scheme made under the corresponding provisions of`
  line `this Act; and`
  line
  line `(d) any proceeding under the repealed enactments pending immediately before the`
  line `commencement of Part I of Chapter VIII of the Finance Act, 2018 before any court shall, subject to`
  line `the provisions of this Act, continue to be heard and disposed of by the said court.`
  line
  line `(3) The repeal shall not prejudicially affect the interest of depositors who, before the commencement`
  line `of Part I of Chapter VIII of the Finance Act, 2018, made deposits or were issued certificates or made`
  line `contribution to any scheme under the repealed enactments.]`
