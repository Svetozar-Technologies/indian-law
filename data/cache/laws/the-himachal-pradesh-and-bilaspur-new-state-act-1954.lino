obj_root_law_sections_1:
  sectionId (48283)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 1st July, 1954, see Gazette of India, 1954, Extraordinary, Part II, s. 3.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48283&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Himachal Pradesh and`
  line `Bilaspur (New State) Act, 1954.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint in this behalf.`
obj_root_law_sections_2:
  sectionId (48284)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Clause (b) omitted by the A.O. (No. 3), 1956.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48284&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "article" means an article of the Constitution;`
  line
  line ^1
  line `* * * * * *`
  line
  line `(c) "existing States" mean the States specified as Bilaspur and Himachal Pradesh in Part C of`
  line `the First Schedule to the Constitution immediately before the commencement of this Act, and`
  line `"existing State" means either of the existing States;`
  line
  line `(d) "law" includes any enactment, ordinance, regulation, order, rule, scheme, notification,`
  line `bye-law or other instrument having the force of law in the whole or in any part of either of the`
  line `existing States;`
  line
  line `(e) "Order" means an order published in the Official Gazette;`
  line
  line `(f) "Parliamentary constituency" has the same meaning as in the Representation of the People`
  line `Act, 1950 (43 of 1950);`
  line
  line `(g) sitting member in relation to either House of Parliament or in relation to the Legislature`
  line `of the existing State of Himachal Pradesh, means a person who immediately before the`
  line `commencement of this Act is a member of that House or that Legislature, as the case may be.`
obj_root_law_sections_3:
  sectionId (48285)
  sectionNo (3)
  orderNo 3
  title `Formation of the new State of Himachal Pradesh.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48285&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_3_content:
  string
  line `As from the commencement of this Act`
  line `there shall be formed by uniting the existing States a new Part C State to be known as the State of`
  line `Himachal Pradesh (hereafter in this Act referred to as the "new State").—`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (48286)
  sectionNo (4)
  orderNo 4
  title `Amendment of the First Schedule to the Constitution.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48286&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_4_content:
  string
  line `In the First Schedule to the`
  line `Constitution, in Part C—`
  line
  line `(a) under the heading "Names of States"—`
  line
  line `(i) entry "3. Bilaspur" shall be omitted; and`
  line
  line `(ii) entries 4 to 10 shall be renumbered as entries 3 to 9 respectively;`
  line
  line `(b) under the heading "Territories of States", after the first paragraph the following paragraph`
  line `shall be inserted, namely:—`
  line
  line `"The territory of the State of Himachal Pradesh shall comprise the territories which`
  line `immediately before the commencement of the Himachal Pradesh and Bilaspur (New State)`
  line `Act, 1954 were comprised in the States of Bilaspur and Himachal Pradesh."`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (48287)
  sectionNo (5)
  orderNo 5
  title `Representation in the Council of States.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48287&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_5_content:
  string
  line `(1) There shall be allotted one seat to the new State`
  line `in the Council of States.`
  line
  line `(2) The sitting member of the Council of States representing the group of States comprising the`
  line `existing States shall on and from the commencement of this Act represent the new State in the`
  line `Council but the term of such sitting member shall remain unaltered, that is to say, shall expire on the`
  line `2nd of April, 1958.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (48288)
  sectionNo (6)
  orderNo 6
  title `Amendment of the Fourth Schedule to the Constitution.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48288&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_6_content:
  string
  line `In the Fourth Schedule to the`
  line `Constitution, in the Table of Seats relating to the representatives of States specified in Part C of the`
  line `First Schedule—`
  line
  line `(i) for entries 4 and 5, the entry "4. Himachal Pradesh......I" shall be substituted; and`
  line
  line `(ii) entries 6 to 10 shall be renumbered as entries 5 to 9 respectively.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (48289)
  sectionNo (7)
  orderNo 7
  title `Amendment of section 27A, Act 43 of 1950.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48289&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_7_content:
  string
  line `In section 27A of the Representation of the`
  line `People Act, 1950 (43 of 1950)—`
  line
  line `(i) in sub-section (5), for the word "Delhi" the words "Delhi, Himachal Pradesh" shall be`
  line `substituted; and`
  line
  line `(ii) sub-section (6) shall be omitted.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (48290)
  sectionNo (8)
  orderNo 8
  title `Representation in the House of the People.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48290&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_8_content:
  string
  line `Until other provision is made by law, there shall`
  line `be allotted 4 seats to the new State in the House of the People.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (48291)
  sectionNo (9)
  orderNo 9
  title `Amendment of the First Schedule, Act 43 of 1950.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48291&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_9_content:
  string
  line `In the First Schedule to the`
  line `Representation of the People Act, 1950 (43 of 1950), in the part relating to Para C States,—`
  line
  line `(i) entry 3 shall be omitted;`
  line
  line `(ii) entries 4 to 12 shall be renumbered as entries 3 to 11 respectively; and`
  line
  line `(iii) for the figure "3" in column 2 against Himachal Pradesh the figure "4" shall be`
  line substituted.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (48292)
  sectionNo (10)
  orderNo 10
  title `Parliamentary constituencies of the new State and their delimitation.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48292&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_10_content:
  string
  line `(1) The new State`
  line `shall, until other provision is made by law, consist of the following three Parliamentary constituencies`
  line `namely:—`
  line
  line `(i) the constituency of Bilaspur comprising the existing State of Bilaspur; and`
  line
  line `(ii) the two constituencies into which the existing State of Himachal Pradesh has been`
  line divided.
  line
  line `(2) The Delimitation of Parliamentary Constituencies (Part C States) Order, 1951, shall, until`
  line `other provision is made by law, have effect subject to the amendments made in the First Schedule.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (48293)
  sectionNo (11)
  orderNo 11
  title `Sitting members.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48293&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00023_195432_1517807321314
obj_root_law_sections_11_content:
  string
  line `(1) The sitting member of the House of the People representing the`
  line `existing State of Bilaspur shall on and from the commencement of this Act represent the Bilaspur`
  line `constituency of the new State and shall be deemed to have been elected to the House of the People by`
  line `that constituency.`
  line
  line `(2) Every sitting member of the House of the People representing a constituency of the existing`
  line `State of Himachal Pradesh shall, on and from the commencement of this Act, represent the`
  line `constituency of the same name in the new State and shall be deemed to have been elected to the`
  line `House of the People by that constituency.`
obj_root_law_sections_11_footnotes:
  string
  line
