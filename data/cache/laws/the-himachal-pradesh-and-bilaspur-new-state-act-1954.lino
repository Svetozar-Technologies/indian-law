  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48300&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00023_195432_1517807321314
