  (str sectionId) (str 48296)
  (str sectionNo) (str 14)
  (str orderNo) (int 14)
  (str title) (str [Repealed.].)
  (str content) (str `[Assembly constituencies of the new State and their delimitation.]. Rep., ibid.,`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48296&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00023_195432_1517807321314)
