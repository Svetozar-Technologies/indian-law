  object
  (str sectionId) (str 48297)
  (str sectionNo) (str 15)
  (str orderNo) (int 15)
  (str title) (str [Repealed.].)
  (str content) (str `[Members of Legislative Assembly.]. Rep., ibid.,`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00023_195432_1517807321314&sectionId=48297&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00023_195432_1517807321314)
