obj_root_law:
  object
  (str slug) (str the-juvenile-justice-care-and-protection-of-children-act-2015)
  (str handle) (str 2148)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Juvenile Justice (Care and Protection of Children) Act, 2015.`)
  (str actNumber) (str 02)
  (str enactmentDate) (str 2015-12-31)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2148`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `किशोर न्याय (बालको की देखरेख और संरक्षण)अधिनियम, 2015`)
  (str actYear) (str 2016)
  (str ministry) (str `Ministry of Women and Child Development`)
  (str department) (undefined)
  (str longTitle) (str `An Act to consolidate and amend the law relating to children alleged and found to be in conflict with law and children in need of care and protection by catering to their basic needs through proper care, protection, development, treatment, social re-integration, by adopting a child-friendly approach in the adjudication and disposal of matters in the best interest of children and for their rehabilitation through processes provided, and institutions and bodies established, herein under and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 15-01-2016)
  (str notification) (str `15th January, 2016, vide notification No. S.O. 110(E), dated 12th January, 2016, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T09:17:44.977Z`)
  (str translations) obj_root_law_translations
