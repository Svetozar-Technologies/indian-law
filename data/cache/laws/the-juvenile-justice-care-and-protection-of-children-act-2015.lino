obj_root_law:
  slug the-juvenile-justice-care-and-protection-of-children-act-2015
  handle (2148)
  collectionHandle 123456789/1362
  title `The Juvenile Justice (Care and Protection of Children) Act, 2015.`
  actNumber (02)
  enactmentDate 2015-12-31
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2148`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `किशोर न्याय (बालको की देखरेख और संरक्षण)अधिनियम, 2015`
  actYear (2016)
  ministry `Ministry of Women and Child Development`
  department undefined
  longTitle `An Act to consolidate and amend the law relating to children alleged and found to be in conflict with law and children in need of care and protection by catering to their basic needs through proper care, protection, development, treatment, social re-integration, by adopting a child-friendly approach in the adjudication and disposal of matters in the best interest of children and for their rehabilitation through processes provided, and institutions and bodies established, herein under and for matters connected therewith or incidental thereto.`
  enforcementDate 15-01-2016
  notification `15th January, 2016, vide notification No. S.O. 110(E), dated 12th January, 2016, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T09:17:44.977Z`
  translations obj_root_law_translations
