obj_root_law_sections_1:
  sectionId (6818)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Vice-President's Pension Act, 1997.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00015_199730_1517807323326&sectionId=6818&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00015_199730_1517807323326
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (6819)
  sectionNo (2)
  orderNo 2
  title `Pension to retiring Vice-Presidents.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00015_199730_1517807323326&sectionId=6819&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00015_199730_1517807323326
obj_root_law_sections_2_content:
  string
  line `(1) There shall be paid to every person who ceases to hold`
  line `office as Vice-President, either by the expiration of his term of office or by resignation of his office, a`
  line `pension ^1`
  line `[at the rate of fifty per cent. of the salary of the Vice-President] per month, for the remainder of`
  line `his life:`
  line
  line `Provided that such person shall not be entitled to receive any pension during the period he holds the`
  line `office of the Prime Minister, a Minister or any other office or becomes a Member of Parliament and is in`
  line `receipt of salary and allowances which are defrayed out of the Consolidated Fund of India or the`
  line `Consolidated Fund of a State.`
  line
  line ^2
  line `[(1A) The spouse of a person who dies–`
  line
  line `(a) while holding the office of Vice-President, or`
  line
  line `(b) after ceasing to hold office as Vice-President either by the expiration of his term of office or`
  line `by resignation of his office,`
  line
  line `shall be paid a family pension at the rate of fifty per cent. of pension as is admissible to a retiring`
  line `Vice-President, for the remainder of her life.]`
  line
  line `(2) Subject to any rules that may be made in this behalf, every such person shall, for the remainder of`
  line `his life, be entitled–`
  line
  line ^3
  line `[(a) to the use without payment of rent of such furnished residence (including its maintenance),`
  line `as the Central Government may determine from time to time;]`
  line
  line `(b) to the use of similar telephone facilities at his residence, as a member of Parliament is entitled`
  line `to under the provisions of the Salary, Allowances and Pension of Members of Parliament Act,`
  line `1954(30 of 1954);`
  line
  line ^4
  line `[(c) to secretarial staff consisting of a Private Secretary, an Additional Private Secretary, a`
  line `Personal Assistant and two Peons and office expenses not exceeding ^5`
  line `pninety thousand rupees[ per`
  line annum;[
  line
  line `(d) to the same facilities for himself as respects medical attendance and treatment and on the same`
  line `conditions as a retired President is entitled to under the provisions of the Presidents Emoluments and`
  line `Pension Act, 1951(30 of 1951);`
  line
  line `(e) to the same facilities for his spouse and minor children as respects medical attendance and`
  line `treatment and on the same conditions as the spouse of a retired President is entitled to under the`
  line `provisions of the Presidents Emoluments and Pension Act, 1951(30 of 1951);and`
  line
  line ^6
  line `[(f) to travel anywhere in India, accompanied by spouse or a companion or a relative, by the`
  line `highest class by air, rail or steamer;]`
  line
  line ^7
  line `[(3) Where any such person is re-elected to the office of Vice-President, he or his spouse shall not be`
  line `eligible to any benefit under this section for the period during which such person again holds such office.`
  line
  line `(4) Where any person being a Vice-President gets elected to the office of the President of India, he or`
  line `his spouse shall not be eligible to any benefit under this section.]`
obj_root_law_sections_2_footnotes:
  string
  line `1 Subs. by Act 29 of 2008, s. 2, for "of twenty thousand rupees" (w.e.f. 1-1-2006).`
  line
  line `2 Ins. by Act 23 of 2002, s. 2 (w.e.f. 5-7-2002).`
  line
  line `3 Subs. by Act 45 of 1999, s. 2, for clause (a) (w.e.f. 30-12-1999).`
  line
  line `4 Subs. by Act 29 of 2008, s. 2, for clause (c) (w.e.f. 30-12-2008).`
  line
  line `5 Subs. by Act 13 of 2018, s. 204, for "sixty thousand rupees" (w.e.f. 1-4-2018).`
  line
  line `6 Subs. by Act 45 of 1999, s. 2, for clause (f) (w.e.f. 30-12-1999).`
  line
  line `7 Ins. by s. 2, ibid. (w.e.f. 30-12-1999).`
obj_root_law_sections_3:
  sectionId (6820)
  sectionNo (3)
  orderNo 3
  title `Medical facilities to the family of deceased Vice-President.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00015_199730_1517807323326&sectionId=6820&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00015_199730_1517807323326
obj_root_law_sections_3_content:
  string
  line `Subject to any rules that may be`
  line `made in this behalf, the spouse of a person who dies while holding the office of Vice-President shall, for`
  line `the remainder of life, be entitled to medical attendance and treatment, free of charge.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_3_a:
  sectionId (6821)
  sectionNo 3A
  orderNo 4
  title `Free accommodation to spouse of Vice-President.`
  content obj_root_law_sections_3_a_content
  footnotes obj_root_law_sections_3_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00015_199730_1517807323326&sectionId=6821&sectionno=3A&orderno=4&orgactid=AC_CEN_5_24_00015_199730_1517807323326
obj_root_law_sections_3_a_content:
  string
  line ^1
  line `[3A. Free accommodation to spouse of Vice-President.– Subject to any rules that may be made in`
  line `this behalf, the spouse of a person who dies–`
  line
  line `(a) while holding the office of Vice-President, or`
  line
  line `(b) after ceasing to hold office as Vice-President either by the expiration or his term of office or`
  line `by resignation of his office,`
  line
  line `shall be entitled to the use of ^2`
  line `[furnished residence (including its maintenance)] without payment of`
  line `licence fee, for the remainder of her life.]`
obj_root_law_sections_3_a_footnotes:
  string
  line `1 Ins. by Act 23 of 2002, s. 3 (w.e.f.5-7-2002).`
  line
  line `2 Subs. by Act 29 of 2008, s. 3, for "unfurnished residence" (w.e.f. 30-12-2008).`
obj_root_law_sections_4:
  sectionId (6822)
  sectionNo (4)
  orderNo 5
  title `Pension to be charged on the Consolidated Fund of India.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00015_199730_1517807323326&sectionId=6822&sectionno=4&orderno=5&orgactid=AC_CEN_5_24_00015_199730_1517807323326
obj_root_law_sections_4_content:
  string
  line `Any sum payable under this Act`
  line `shall be charged on the Consolidated Fund of India.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (6823)
  sectionNo (5)
  orderNo 6
  title `Power to make rules.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00015_199730_1517807323326&sectionId=6823&sectionno=5&orderno=6&orgactid=AC_CEN_5_24_00015_199730_1517807323326
obj_root_law_sections_5_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) Every rule made by the Central Government under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament, while it is in session for a total period of thirty days which may`
  line `be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (6824)
  sectionNo (6)
  orderNo 7
  title `Power to remove difficulties.`
  content obj_root_law_sections_6_content
  footnotes `1. Ins. by s. 4, ibid.(w.e.f. 30-12-2008).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00015_199730_1517807323326&sectionId=6824&sectionno=6&orderno=7&orgactid=AC_CEN_5_24_00015_199730_1517807323326
obj_root_law_sections_6_content:
  string
  line ^1
  line `[6. Power to remove difficulties.-- (1) If any difficulty arises in giving effect to the provisions of this`
  line `this Act as amended by the Vice-President's Pension (Amendment) Act, 2008 (29 of 2008), the Central`
  line `Government may, by order, do anything not inconsistent with such provisions for the purpose of`
  line `removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiration of two years from the date on which`
  line `this Act comes into force.`
  line
  line `(2) Every order made under sub-section (1) shall be laid before each House of Parliament.]`
