obj_root_law_sections_1:
  sectionId (39857)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the State of Mizoram Act, 1986.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39857&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39858)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39858&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Administrator" means the administrator appointed by the President under Article 239 of the`
  line Constitution;
  line
  line `(b) "appointed day"^1 means the day which the Central Government may, by notification in the`
  line `Official Gazette, appoint;`
  line
  line `(c) "article" means an article of the Constitution;`
  line
  line `(d) "Election Commission" means the Election Commission appointed by the President under`
  line `Article 324;`
  line
  line `(e) "existing Union territory of Mizoram" means the Union territory of Mizoram as existing`
  line `immediately before the appointed day;`
  line
  line `(f) "law" includes any enactment, ordinance, regulation, order, bye-law, rule, scheme, notification`
  line `or other instrument having, immediately before the appointed day, the force of law in the whole or`
  line `any part of the existing Union territory of Mizoram;`
  line
  line `(g) "sitting member", in relation to either House of Parliament or of the Legislative Assembly of`
  line `the existing Union territory of Mizoram, means a person who, immediately before the appointed day,`
  line `is a member of that House or that Assembly;`
  line
  line `(h) "treasury" includes a sub-treasury.`
obj_root_law_sections_2_footnotes:
  string
  line `1. 20th February, 1987, vide notification No. S.O. 72(E), dated 11th February, 1987, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_3:
  sectionId (39859)
  sectionNo (3)
  orderNo 3
  title `Establishment of the State of Mizoram.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39859&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_3_content:
  string
  line `On and from the appointed day, there shall be`
  line `established a new State, to be known as the State of Mizoram, comprising the territories which immediately`
  line `before that day were comprised in the existing Union territory of Mizoram.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39860)
  sectionNo (4)
  orderNo 4
  title [Repealed].
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39860&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_4_content:
  string
  line `[Amendment of First Schedule to the Constitution].—Rep. by the Repealing and Amending Act,`
  line `2001 (30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39861)
  sectionNo (5)
  orderNo 5
  title [Repealed].
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39861&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_5_content:
  string
  line `[Amendment of Fourth Schedule to the Constitution].—Rep. by the Repealing and Amending Act,`
  line `2001 (30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39862)
  sectionNo (6)
  orderNo 6
  title `Allocation of sitting member.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39862&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_6_content:
  string
  line `(1) On and from the appointed day, the sitting member of the`
  line `Council of States representing the existing Union territory of Mizoram shall be deemed to have been duly`
  line `elected under clause (4) of article 80 to fill the seat allotted to the State of Mizoram in that Council.`
  line
  line `(2) The term of office of such sitting member shall remain unaltered.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (39863)
  sectionNo (7)
  orderNo 7
  title [Repealed].
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39863&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_7_content:
  string
  line `[Amendment of section 27A of Act 43 of 1950].—Rep. by the Repealing and Amending Act, 2001`
  line `(30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (39864)
  sectionNo (8)
  orderNo 8
  title `Allocation of seat in the existing House of the People.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39864&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_8_content:
  string
  line `(1) On and from the appointed day, the`
  line `allocation of seats to the State of Mizoram in the House of the People and the number of seats to be reserved`
  line `for the Scheduled Tribes of that State shall be one; and the First Schedule to the Representation of the`
  line `People Act, 1950 (43 of 1950), shall be deemed to be amended, accordingly.`
  line
  line `(2) On and from the appointed day, the parliamentary constituency of the existing Union territory of`
  line `Mizoram shall be deemed to be the parliamentary constituency of the State of Mizoram and the Delimitation`
  line `of Parliamentary and Assembly Constituencies Order, 1976, shall be construed accordingly.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (39865)
  sectionNo (9)
  orderNo 9
  title `Provision as to sitting member.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39865&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_9_content:
  string
  line `The sitting member of the House of the People representing the`
  line `constituency which, on the appointed day, by virtue of the provisions of section 8 becomes the constituency`
  line `of the State of Mizoram, shall be deemed to have been elected under sub-clause (a) of clause (1) of`
  line `article 81 to the House of the People by that constituency.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (39866)
  sectionNo (10)
  orderNo 10
  title `Provision as to Legislative Assembly.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39866&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_10_content:
  string
  line `On and from the appointed day, the total number of seats`
  line `in the Legislative Assembly of the State of Mizoram to be filled by persons, chosen by direct election from`
  line `assembly constituencies shall be forty; and the Second Schedule to the Representation of the People`
  line `Act, 1950 (43 of 1950), shall be deemed to be amended accordingly.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (39867)
  sectionNo (11)
  orderNo 11
  title `Delimitation of constituencies.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39867&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_11_content:
  string
  line `(1) The Election Commission shall, before the appointed day,`
  line `and in the manner herein provided, distribute the seats assigned to the Legislative Assembly of the State of`
  line `Mizoram under section 10 to single-member territorial constituencies and delimit them, having regard to`
  line `the provisions of the Constitution and to the following provisions, namely:—`
  line
  line `(a) all constituencies shall, as far as practicable, be geographically compact areas, and in delimiting`
  line `them regard shall be had to physical features, existing boundaries of administrative units, facilities of`
  line `communication and public convenience; and`
  line
  line `(b) constituencies in which seats are reserved for the Scheduled Tribes shall, as far as practicable, be`
  line `located in areas where the proportion of their population to the total population is the largest.`
  line
  line `(2) For the purpose of assisting it in the performance of its functions under sub-section (1) the Election`
  line `Commission shall associate with itself as associate members,—`
  line
  line `(a) the sitting member of the House of the People referred to in section 9; and`
  line
  line `(b) such six of the members of the Legislative Assembly of the existing Union territory of`
  line `Mizoram as the Speaker thereof may nominate:`
  line
  line `Provided that none of the associate members shall have a right to vote or to sign any decision of the`
  line `Election Commission.`
  line
  line `(3) If owing to death or resignation, the office of an associate member falls vacant, it shall be filled, if`
  line `practicable, in accordance with the provisions of sub-section (2).`
  line
  line `(4) The Election Commission shall—`
  line
  line `(a) publish its proposals for the delimitation of constituencies together with the dissenting proposals,`
  line `if any, of any associate member who desires publication thereof, in the Official Gazette and in`
  line `such other manner as the Commission may consider fit, together with a notice inviting objections and suggestions in relation to the proposals and specifying a date on or after which the proposals will be`
  line `further considered by it;`
  line
  line `(b) consider all objections and suggestions which may have been received by it before the date so`
  line specified;
  line
  line `(c) after considering all objections and suggestions which may have been received by it before the`
  line `date so specified, determine by one or more orders the delimitation of constituencies and cause such`
  line `order or orders to be published in the Official Gazette; and upon such publication, the order or orders`
  line `shall have the full force of law and shall not be called in question in any Court.`
  line
  line `(5) As soon as may be after such publication, every such order relating to assembly constituencies`
  line `shall be laid before the Legislative Assembly of the existing Union territory of Mizoram.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (39868)
  sectionNo (12)
  orderNo 12
  title `Power of Election Commission to maintain delimitation orders up-to-date.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39868&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_12_content:
  string
  line `(1) The Election`
  line `Commission may, from time to time, by notification in the Official Gazette,—`
  line
  line `(a) correct any printing mistake in any order made under section 11 or any error arising therein from`
  line `inadvertent slip or omission;`
  line
  line `(b) where the boundaries or name of any territorial division mentioned in any such order are or is`
  line `altered, make such amendments as appear to it to be necessary or expedient for bringing such order`
  line up-to-date.
  line
  line `(2) Every notification under this section relating to an assembly constituency shall be laid, as soon as`
  line `may be after it is issued, before the Legislative Assembly of the existing Union territory of Mizoram.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (39869)
  sectionNo (13)
  orderNo 13
  title [Repealed].
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00054_198634_1517807327034&sectionId=39869&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00054_198634_1517807327034
obj_root_law_sections_13_content:
  string
  line `[Amendment of Scheduled Castes Orders].—Rep. by the Repealing and Amending Act, 2001`
  line `(30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_13_footnotes:
  string
  line
