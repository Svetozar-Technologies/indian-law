  (str content) (str `[Interpretation-clause. Number. Gender.]--Rep. by Repealing and Amending Act, 1914 (10 of
1914), s. 3 and Sch. II.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67612&sectionno=24&orderno=25&orgactid=AC_CEN_5_5_00079_186323_1659589575506)
