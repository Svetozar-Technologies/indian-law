obj_root_law_sections_1:
  sectionId (67589)
  sectionNo (1)
  orderNo 1
  title `Provision for inquiry into claims to land, or objections to sale of same.`
  content obj_root_law_sections_1_content
  footnotes `1. Subs. by the A.O. 1937 for "Govt.Dbqts`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67589&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_1_content:
  string
  line `When any claim shall`
  line `be preferred to any waste land proposed to be sold, or otherwise dealt with, on account of ^1[the State`
  line `Government], or when any objection shall be taken to the sale or other disposition of such land, the`
  line `Collector of the District in which such land is situate, or other Officer performing the duties of a Collector`
  line `of Land Revenue in such District by whatever name his Office is designated, shall, if the claim or`
  line `objection be preferred within the period mentioned in the advertisement to be issued for the sale or other`
  line `disposition of such land, which period shall not be less than three months, proceed to make an enquiry`
  line `into the claim or objection.`
obj_root_law_sections_2:
  sectionId (67590)
  sectionNo (2)
  orderNo 2
  title `Procedure in such cases.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67590&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_2_content:
  string
  line `The Collector or other Officer as aforesaid, shall call upon the claimant`
  line `or objector to produce any evidence or documents, upon which he may rely in proof of his claim or`
  line `objection ; and after considering the same, and making any further enquiry that may appear proper, shall`
  line `dispose of the case by an order for the admission or rejection of the claim or objection ; and if the land is`
  line `proposed to be sold, for the sale of the same subject to any condition or reservation which, to such`
  line `Collector or other Officer as aforesaid, shall appear to be proper. If the land is ordered to be sold subject`
  line `to any condition or reservation, such condition or reservation shall be notified to intending purchasers at`
  line `the time of sale.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (67591)
  sectionNo (3)
  orderNo 3
  title `Pending enquiry, sale &c., to be postponed.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67591&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_3_content:
  string
  line `Pending an enquiry into any claim or objection`
  line `under the last preceding Section, the Collector or other Officer as aforesaid shall postpone the sale or`
  line `other disposition of the land ;`
  line
  line `and, if he shall order that such claim or objection be rejected, he shall further postpone the sale or`
  line `other disposition of the land, to allow the claimant or objector to contest the order of rejection in the`
  line `manner hereinafter provided.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (67613)
  sectionNo (4)
  orderNo 4
  title `Sale to be stopped if claim appear to be established,but may afterwards be proceededwith`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67613&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_4_content:
  string
  line `If the Collector or other officer as aforesaid shall consider the claim or objection to be established,`
  line `and that the sale or other disposition of the land should not take place, he shall stop the sale or other`
  line `disposition of the land:`
  line
  line `but such sale or other disposition of the land may afterwards be proceeded with, if, on an order`
  line `issued by the Local Government to try to claim or objection, as provided in section VI of this Act, the`
  line `claimant or objector shall fail to establish the same.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (67593)
  sectionNo (5)
  orderNo 5
  title `Procedure after passing of order in the case, Report to Revenue Board, Decision of Board.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67593&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_5_content:
  string
  line If
  line `the Collector or other Officer as aforesaid shall order that the claim or objection be rejected, or that the`
  line `land be sold subject to any condition or reservation, or that it be otherwise dealt with, he shall cause a`
  line `copy of such order to be delivered to the claimant or objector ;`
  line
  line `order when final.--and if such claimant or objector shall not, within one week from the delivery of`
  line `such copy, or within such further time as the Collector or other Officer as aforesaid, for any special reason`
  line `to be recorded, shall see fit to grant, give notice in writing to such Collector or other Officer as aforesaid,`
  line `that he intends to contest such order, the order shall be final.`
  line
  line `Report to Board.--If the claimant or objector shall, within the time allowed, give such notice, the`
  line `Collector or other Officer as aforesaid shall immediately make a report to the ^1[Board of Revenue, or`
  line `other] superior Revenue Authority ;`
  line
  line `^2[to which he is immediately subordinate] and shall forward with`
  line `such Report a copy of his order, stating fully all the circumstances of the case, and the evidence adduced`
  line `in support, or otherwise, of the claim or objection;`
  line
  line `Decision of Board.--and such ^3[Board, or other] authority, on the receipt of such Report, and after`
  line `calling for any further information which it may consider necessary, may confirm, modify or reverse, the`
  line `order of the Collector or other officer as aforesaid.`
  line
  line `If the Board or other Authority as aforesaid confirm the order of the Collector or other Officer as`
  line `aforesaid, or modify such order in such to manner as to leave any part of such order in force adverse to`
  line `the claimant or objector, the Collector or other Officer as aforesaid shall certify such order to the Court`
  line `constituted as hereinafter provided;.`
  line
  line `and such Court shall forthwith give notice to the claimant or objector; and if such claimant or`
  line `objector ;.`
  line
  line `and if such claimant or objector shall not, ^4[within thirty days from the delivery of such notice from`
  line `the Court], institute a suit in such Court to establish his claim or objection, the order of the ^5[Board or`
  line `other] authority aforesaid shall be final..`
obj_root_law_sections_5_footnotes:
  string
  line `1. The words "Board of Revenue or other" rep. by Act 4 of 1914, Schedule, Pt. I.`
  line
  line `2. Ins., ibid.,`
  line
  line `3. The words "Board or other" rep., ibid.`
  line
  line `4. The words "within thirty days from the delivery of such notice from the Court" rep. by Act 9 of 1871. For Limitation, see`
  line `now the Indian Limitation Act, 1908 (9 of 1908).`
  line
  line `5. The words "Board or other" rep., by Act 4 of 1914, Schedule, Pt. I.`
obj_root_law_sections_6:
  sectionId (67614)
  sectionNo (6)
  orderNo 6
  title `Local Government may, with in Twelve months, order suit to be brought to try claim admitted by Collector`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67614&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_6_content:
  string
  line `The Local Government may, within twelve months after the date on which the`
  line `claim of any claimant of waste land, or the objection of any objector, as aforesaid, shall have been`
  line `admitted under this Act by the Collector or other Officer as aforesaid, direct a suit to be brought to try the`
  line `claim or objection of the claimant or objector, in a Court constituted as hereinafter provided.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (67595)
  sectionNo (7)
  orderNo 7
  title `Special Court for trying claims.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67595&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_7_content:
  string
  line `For the investigation and trial of claims under this Act, the`
  line `Local Government shall constitute, in every District in which there may be any waste lands capable of`
  line `being sold, or otherwise dealt with, on account of Government, a Court consisting of an uneven number`
  line `of persons, not less than three; of whom the Judge of the District, or the Officer presiding in the principal`
  line `Civil Court of original jurisdiction in the District, by whatever name his office may be designated, shall`
  line `be one. Any one or more of the members of which such Court shall consist shall have power to make all`
  line `such orders in the case as may be necessary prior to the hearing of the suit: Provided that, whenever the`
  line `Collector, or other Officer, by whom the original enquiry was held, is the fficer presiding in the principal`
  line `Civil Court of original Jurisdiction in the District, such Officer shall not be a member of such Court.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (67596)
  sectionNo (8)
  orderNo 8
  title `Noticeof constitution of special Courts. Claims not cognizable in otherCourts.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67596&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_8_content:
  string
  line `Whenever any Court is constituted under this Act, notice thereof shall be given by a written`
  line `proclamation, copies of which shall be affixed in the several Courts, and in the offices of the several`
  line `Collectors and Magistrates of the District: and from the date of the issue of such proclamation, no other`
  line `Court shall be competent to entertain any claim or objection, belonging to the class of claims or`
  line `objections for the trial and determination of which such Court is constituted.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (67597)
  sectionNo (9)
  orderNo 9
  title `Special Court where to be held.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67597&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_9_content:
  string
  line `The Courts constituted under this Act shall be held at such`
  line `place, or places, within the limits of their respective jurisdictions, as shall be considered most convenient.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (67615)
  sectionNo (10)
  orderNo 10
  title `Plaintiff and defendant in suit under section V, Proviso, Plaintiff and defendant in suits under section VI.`
  content obj_root_law_sections_10_content
  footnotes `1. subs. By the A.O. 1937 for "Govt."`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67615&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_10_content:
  string
  line `In every suit instituted under Section V of this Act, the claimant of the waste land, or objector to the`
  line `sale or other disposition of such land, shall appear as plaintiff; and the Collector, or other Officer`
  line `aforesaid, shall appear as defendant on the part of ^1[The State Government]`
  line `Either party may appear by pleader or by agent.`
  line
  line `Proviso.--Provided that if such other officer as aforesaid be the presiding officer of the principal Civil`
  line `Court of original jurisdiction in the district, the Local Government shall appoint some other Officer to`
  line `appear as defendant in the case on its behalf.`
  line
  line `In any suit ordered to be instituted by the Local Government under section VI of this Act,`
  line `^1[the State Government], by any officer, to be appointed for the purpose, shall appear as plaintiff; and the`
  line `claimant or objector as aforesaid shall appear as defendant.`
obj_root_law_sections_12:
  sectionId (67600)
  sectionNo (12)
  orderNo 13
  title `Procedure before hearing of suit.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67600&sectionno=12&orderno=13&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_12_content:
  string
  line `The Court shall fix a day for the appearance of the`
  line `parties, and for the hearing of the suit, of which due notice shall be given to the parties or their agents;`
  line `and on the day so fixed, the parties or their agents shall bring their witnesses into Court, together with any`
  line `documents on which they may intend to rely in support of their respective statements. If either party`
  line `require the assistance of the Court to procure the attendance of a witness on such day, he shall apply to`
  line `the Court in sufficient time, before the day fixed for the hearing of the suit; and the Court shall issue a`
  line `subpoena requiring such witness to attend the Court on that day It shall be competent to the Court to`
  line `require the personal attendance of the claimant of the waste land, or objector, as aforesaid, on the day`
  line `fixed for the hearing, or at any subsequent stage of the suit.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (67599)
  sectionNo (11)
  orderNo 13
  title `proceedings regulated by Civil Procedure Code.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67599&sectionno=11&orderno=13&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_11_content:
  string
  line `In suits instituted under this Act, except as hereinafter provided, the`
  line `proceedings shall be regulated, so far as they can be, by the Code of Civil Procedure.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (67601)
  sectionNo (13)
  orderNo 14
  title `Procedure on hearing.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67601&sectionno=13&orderno=14&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_13_content:
  string
  line `On the day fixed for the hearing of the suit, or as soon after as may be`
  line `practicable, the Court shall proceed to examine the claimant of the waste land, or the objector, or his`
  line `agent (when his personal attendance is not required), and the witnesses of the parties; and upon such`
  line `examination, and after inspecting the documents of the parties, and making any further enquiry that may`
  line `appear necessary, shall proceed to pass such order in the case as it may consider just and proper.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (67602)
  sectionNo (14)
  orderNo 15
  title `No appeal or revision.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67602&sectionno=14&orderno=15&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_14_content:
  string
  line `No appeal shall lie from any decision or order passed under this Act,`
  line `nor shall any such decision or order be open to revision.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (67603)
  sectionNo (15)
  orderNo 15
  title `Reference of question of law, &c., to High Court &c. , Such reference obligatory in certain cases.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67603&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_15_content:
  string
  line `If, on the trial of any suit under this Act, any question of to law, or of usage having the force of`
  line `law, or the construction of a document affecting the merits of the case, shall arise, on which the Court`
  line `shall entertain reasonable doubts, the Court may, either of its own motion, or on the application of any of`
  line `the parties to the suit, draw up a statement of the case and submit it, with its own opinion, for the opinion`
  line `of the High Court of Judicature, or of the highest Civil Court of Appeal and Revision in the territory in`
  line `which the land is situate: Provided that it shall be the duty of every Court held under this Act, to make`
  line `such reference to such High Court, or Court of Appeal, if, in any suit under this Act, any question shall`
  line `arise involving any principle of general importance, or the rights of a class.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (67604)
  sectionNo (16)
  orderNo 16
  title `Court may proceed notwithstanding reference.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67604&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_16_content:
  string
  line `The Court may proceed in the case`
  line `notwithstanding a reference to the High Court, or other highest Civil Court of Appeal as aforesaid; and`
  line `may pass an order contingent upon the opinion of the High Court, or other Court as aforesaid, on the point`
  line `referred; but no final order for the sale or other disposition of the land in question in the suit, or for the`
  line `admission or rejection of any claim or objection which shall be before the Court in such suit, shall be`
  line `passed, until the receipt of the order of the said High Court, or highest Civil Court of Appeal.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (67605)
  sectionNo (17)
  orderNo 17
  title `Records of cases where to be deposited.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67605&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_17_content:
  string
  line `The record of cases disposed of by Courts`
  line `constituted under this Act, shall be deposited amongst the records of the principal Civil Court of original`
  line `jurisdiction in the District in which the property in dispute is situate.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (67616)
  sectionNo (18)
  orderNo 18
  title `Limitation as to claims to land sold or dealt with.Provision for such claims if preferred with in time.`
  content obj_root_law_sections_18_content
  footnotes `1. Subs. by the A.O. 1937 for "Govt.".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67616&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_18_content:
  string
  line `No claim to any land, or to compensation or damages in respect of any land, sold or otherwise dealt with on account of ^1[the State Government] as waste land, shall be received after the`
  line `expiration of three years from the date on which such land shall have been delivered by`
  line `the Government to the purchaser, or otherwise dealt with.`
  line
  line `If within three years after any lands have been delivered by the Government to the purchaser, or`
  line `otherwise dealt with, any claimant or objector shall prefer a claim to the land so delivered, or otherwise`
  line `dealt with, or an objection to such sale, or to compensation or damages in respect thereof, in the Court`
  line `constituted under this Act for the District in which the land is situate; and shall show good and sufficient`
  line `reason for not having preferred his claim or objection to the Collector or other Officer as aforesaid, within`
  line `the period limited under Section I of this Act; such Court shall file the claim or objection, making the`
  line `claimant or objector plaintiff, and the Collector of the District or other Officer as aforesaid (with the like`
  line `provision as aforesaid if such other Officer be the presiding officer of the principal Civil Court of original`
  line `jurisdiction in the District), the defendant in the suit;`
  line
  line `and the foregoing provisions of this Act shall be applicable to the trial and determination of the suit.`
  line
  line `The report of the Officer employed to give delivery, or to take possession, on the part of ^1[the State`
  line `Government], of the land sold or otherwise dealt with, shall be conclusive evidence as to the date on`
  line `which such delivery was made, or possession was taken.`
obj_root_law_sections_19:
  sectionId (67607)
  sectionNo (19)
  orderNo 19
  title `If claim established, possession not to be given, but compensation.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67607&sectionno=19&orderno=19&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_19_content:
  string
  line `In any case in which the`
  line `land has been sold, if the Court shall be of opinion that the claim of the claimant is established, the Court`
  line `shall not award the claimant possession of the land in dispute; but shall order him to receive from`
  line `^1[the State Government] Treasury, by way of compensation, a sum equal to the price at which the land`
  line `was sold, in addition to the costs of suit.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (67608)
  sectionNo (20)
  orderNo 20
  title `When land has not been absolutely sold, or has been otherwise dealt with.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67608&sectionno=20&orderno=20&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_20_content:
  string
  line `If the land shall`
  line `have been sold subject to any condition reservation, or shall not have been sold, but shall have been`
  line `otherwise dealt with on account of the ^1[the State Government[, and the Court shall be of opinion that the`
  line `claim to such land, or the objection of an objector, is established, the Court shall award the claimant or`
  line `objector to receive such sum, in respect of his interest in such land, as shall be awarded in that behalf`
  line `under the provisions of 3Act VI of 1857 (for the acquisition of lands for public purposes).`
  line `and thereupon the State Government shall proceed under the said Act to obtain an award of the value`
  line `of such interest.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (67609)
  sectionNo (21)
  orderNo 21
  title `Award under the two last Sections to be in full satisfaction.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67609&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_21_content:
  string
  line `An award under any of the`
  line `provisions of the two last preceding Sections shall be in full satisfaction of the claim of the claimant or`
  line `objector; and shall bar any future claim on his part, in respect to the land in suit resting on the same cause`
  line `of action, or on a cause of action which existed prior to the date of the sale or other disposition of the land`
  line `on account of ^1[the State Government].`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (67617)
  sectionNo (22)
  orderNo 22
  title `Government not barred from awarding compensation for land absolutely sold, though claim be not preferred in time.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67617&sectionno=22&orderno=22&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_22_content:
  string
  line `Nothing in this Act shall be held to prevent ^1[the State Government]`
  line `from awarding, to any claimant of waste land sold on account of Government, on proof to the satisfaction`
  line `of the State Government of the claim of such claimant (notwithstanding that he may not have preferred`
  line `his claim either to the Collector or other Officer as aforesaid, or to the proper Court constituted under this`
  line `Act, within the period prescribed by this Act), such amount as compensation for the said land, within the`
  line `limit as to amount mentioned in Section XIX of this Act, if the land have been sold not subject to any`
  line `condition or reservation, as to such State Government may seem proper.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (67611)
  sectionNo (23)
  orderNo 23
  title `Compensation for land sold subject to condition, if claim proved, though not preferred in time.`
  content obj_root_law_sections_23_content
  footnotes `1. Subs. by the A.O. 1937 for "Govt.".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67611&sectionno=23&orderno=23&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_23_content:
  string
  line `If the land have been sold subject to any condition or reservation, or have been otherwise disposed`
  line `of, on account of ^1[the State Government], and any claim to such land, or objection to the sale or other`
  line `disposition of the land, shall be proved to the satisfaction of the ^1[the State Government], although not`
  line `preferred to the Collector or other Officer as aforesaid, or to the Court constituted under this Act, within`
  line `the period prescribed by this Act, ^1[the State Government] may award to such claimant or objector such`
  line `amount as to such State Government may appear to be the value of the interest of such claimant or`
  line `objector in such land.`
obj_root_law_sections_23_a:
  sectionId (75134)
  sectionNo 23A
  orderNo 24
  title `Exercise of power of the State Government by the Board of Revenue or the Financial Commissioner.`
  content obj_root_law_sections_23_a_content
  footnotes obj_root_law_sections_23_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=75134&sectionno=23A&orderno=24&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_23_a_content:
  string
  line
obj_root_law_sections_23_a_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (67612)
  sectionNo (24)
  orderNo 25
  title `Interpretation. Number. Gender.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00079_186323_1659589575506&sectionId=67612&sectionno=24&orderno=25&orgactid=AC_CEN_5_5_00079_186323_1659589575506
obj_root_law_sections_24_content:
  string
