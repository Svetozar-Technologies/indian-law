  object
  (str slug) (str the-waste-lands-claims-act-1863)
  (str handle) (str 19035)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The WASTE-LANDS (CLAIMS) ACT, 1863`)
  (str actNumber) (str 23)
  (str enactmentDate) (str 1863-03-10)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/19035`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बंजर भूमि (दावे) अधिनियम,1863`)
  (str actYear) (str 1863)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of States`)
  (str longTitle) (str `WHEREAS it is expedient to make special provision for the speedy adjudication of claims which may be preferred to waste lands proposed to be sold, or otherwise dealt with, on account of Government, and of objections taken to the sale or other disposition of such lands ; It is enacted as follows.`)
  (str fetchedAt) (str `2026-05-08T19:24:57.952Z`)
