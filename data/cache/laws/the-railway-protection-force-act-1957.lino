  (str slug) (str the-railway-protection-force-act-1957)
  (str handle) (str 1450)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Railway Protection Force Act, 1957`)
  (str actNumber) (str 23)
  (str enactmentDate) (str 1957-08-29)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1450`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `रेल संरक्षण बल अधिनियम, 1957`)
  (str actYear) (str 1957)
  (str ministry) (str `Ministry of Railways`)
  (str longTitle) (str `An Act to provide for the constitution and regulation of an armed Force of the Union for the better protection and security of railway property, passenger area and passengers and for matters connected therewith.`)
  (str enforcementDate) (str 10-09-1959)
  (str notification) (str `10th September 1959, vide notification No. 58-security/16/9, dated 10-9-1959, see Gazette of India, Extraordinary, Part II, s. 1. Extended to Goa, Daman and Diu with modifications, by Reg. 12 of 1962, s. 3 and Schedule. The Act comes into force in Pondicherry on 1-10-1963, s. 3 and Schedule I. Extended to and brought into force in Dadra and Nagar Haveli (w.e.f. 1-7-1965) by Reg. 6 of 1963, s. 2 and Schedule I.`)
  (str fetchedAt) (str `2026-05-09T00:31:19.547Z`)
