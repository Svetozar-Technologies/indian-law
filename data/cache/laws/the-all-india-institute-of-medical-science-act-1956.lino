obj_root_law_sections_1:
  sectionId (5372)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5372&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the ^1[All-India Institutes of Medical`
  line `Sciences] Act, 1956.`
  line
  line `(2) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for All-India Institute of Medical Sciences (w.e.f. 16-7-2012).`
  line
  line `2. 15th November, 1956, vide notification No. S. R. O. 2688, dated 6th November, 1956, see Gazette of India, Extraordinary,`
  line `Part II, s. 3.`
obj_root_law_sections_2:
  sectionId (5373)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5373&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise, requires,--`
  line
  line `^1[(a) "corresponding Institute" means the Institutes referred to in column (3) of the Table given`
  line `under section 27A;`
  line
  line `(aa) "existing Institute" means the All-India Institute of Medical Sciences,--`
  line
  line `(i) established under sub-section (1) of section 3, before the commencement of the All-India`
  line `Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012); and`
  line
  line `(ii) located at New Delhi, as required under section 12 as it stood before such`
  line commencement;
  line
  line `(ab) "Fund" means the Fund of the Institute referred to in section 16;`
  line
  line `(b) 'Governing Body' means the Governing Body of the Institute;`
  line
  line `(c) Institute means the All-India Institute of Medical Sciences established under section 3 ^2[and`
  line `includes the corresponding Institutes and other Institutes which may be established on and after the`
  line `commencement of the All-India Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012)] ;`
  line
  line `(d) 'member' means a member of the Institute;`
  line
  line `(e) 'regulation' means a regulation made by the Institute;`
  line
  line `(f) 'rules' means a rule made by the Central Government.`
  line
  line `^2[(g) "society" means the society referred to in column (2) of the Table given under section 27A.]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 37 of 2012, s. 4, for clause (a) (w.e.f. 16-7-2012).`
  line `2. Ins. by s. 4, ibid. (w.e.f. 16-7-2012).`
obj_root_law_sections_3:
  sectionId (5374)
  sectionNo (3)
  orderNo 3
  title `Establishment and incorporation of the Institute.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5374&sectionno=3&orderno=3&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_3_content:
  string
  line `(1) With effect from such date as the`
  line `Central Government may, by notification in the Official Gazette, appoint in this behalf, there shall be`
  line `established for the purposes of this Act an institution to be called the All India Institute of Medical`
  line `Sciences:`
  line
  line `^1[Provided that the Central Government may, on and after the commencement of the All-India`
  line `Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), establish by notification in the`
  line `Official Gazette, such other All-India Institutes of Medical Sciences at such places as it may specify in the`
  line `said notification in addition to the existing Institute and the corresponding Institutes.]`
  line
  line `(2)`
  line `^2[Every Institute] shall be a body corporate by the name aforesaid having perpetual succession and`
  line `a common seal, with power to acquire, hold and dispose of property, both movable and immovable, and`
  line `to contract, and shall by the said name sue and be sued.`
obj_root_law_sections_3_footnotes:
  string
  line `1. The proviso ins. by s. 5, ibid. (w.e.f. 16-7-2012).`
  line
  line `2. Subs. by Act 37 of 2012, s. 5, for "The Institute" (w.e.f. 16-7-2012).`
obj_root_law_sections_4:
  sectionId (5375)
  sectionNo (4)
  orderNo 4
  title `Composition of the Institute.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5375&sectionno=4&orderno=4&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_4_content:
  string
  line `^1[Every Institute] shall consist of the following members,`
  line `namely:--`
  line
  line `^2[(a) in the case of existing Institute, the Vice-Chancellor of the Delhi University,ex officio;`
  line
  line `(aa) in the case of every other Institute established on and after the commencement of the`
  line `All-India Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), the Vice-Chancellor of`
  line `a University situated in a State in which such Institute has been established after such commencement`
  line `and such Vice-Chancellor shall be nominated by the Central Government;]`
  line
  line `(b) the Director General of Health Services, Government of India, ex officio;`
  line
  line `(c) the Director of the Institute, ex officio;`
  line
  line `(d) two representatives of the Central Government to be nominated by that Government, one from`
  line `the Ministry of Finance and one from the Ministry of Education;`
  line
  line `(e) five persons of whom one shall be a non-medical scientist representing the Indian Science`
  line `Congress Association, to be nominated by the Central Government;`
  line
  line `(f) four representatives of the medical faculties of Indian Universities to be nominated by the`
  line `Central Government in the manner prescribed by rules; and`
  line
  line `(g) three members of Parliament of whom two shall be elected from among themselves by the`
  line `members of the House of the People and one from among themselves by the members of the Council`
  line `of States.`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by s. 6, ibid., for "The Institute" (w.e.f. 16-7-2012).`
  line
  line `2. Subs. by s. 6, ibid., for clause (a) (w.e.f. 16-7-2012).`
obj_root_law_sections_5:
  sectionId (5376)
  sectionNo (5)
  orderNo 5
  title `Declaration of Institutes as institution of national importance.`
  content obj_root_law_sections_5_content
  footnotes `1 Subs. by s. 7, ibid., for section 5 (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5376&sectionno=5&orderno=5&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_5_content:
  string
  line `^1[5. Declaration of Institutes as institution of national importance.--(1) It is hereby declared that`
  line `the existing Institute declared as an institution of national importance, before the commencement of the`
  line `All-India Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), under section 5 as it stood`
  line `before such commencement, shall continue to be an institution of national importance.`
  line
  line `(2) It is hereby declared that every corresponding Institute shall be an institution of national`
  line importance.
  line
  line `(3) It is hereby declared that every Institute established under the proviso to sub-section (1) of`
  line `section 3, on and after the commencement of the All-India Institute of Medical Sciences (Amendment)`
  line `Act, 2012 (37 of 2012), shall be an institution of national importance.]`
obj_root_law_sections_6:
  sectionId (5377)
  sectionNo (6)
  orderNo 6
  title `Term of office of, and vacancies among, members.`
  content obj_root_law_sections_6_content
  footnotes `1. Ins. by Act 33 of 2000, s. 2 (w.e.f. 25-8-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5377&sectionno=6&orderno=6&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_6_content:
  string
  line `(1) Save as otherwise provided in the`
  line `section, the term of office of a member shall be five years from the date of his nomination or election:`
  line
  line `Provided that the term of office of a member elected under clause (g) of section 4 shall come to an`
  line `end as soon as he ^1[becomes a Minister or Minister of State or Deputy Minister, or the Speaker or the`
  line `Deputy Speaker of the House of the People, or the Deputy Chairman of the Council of States or] ceases to`
  line `be a member of the House from which he was elected.`
  line
  line `(2) The term of office of an ex officio member shall continue so long as he holds the office in virtue of`
  line `which he is such a member.`
  line
  line `(3) The term of office of a member nominated or elected to fill a casual vacancy shall continue for the`
  line `remainder of the term of the member in whose place he is nominated or elected.`
  line
  line `(4) An outgoing member shall, unless the Central Government otherwise directs, continue in office`
  line `until another person is nominated or elected as a member in his place.`
  line
  line `(5) An outgoing member shall be eligible for re-nomination or re-election.`
  line
  line `(6) A member may resign his office by writing under his hand addressed to the Central Government`
  line `but he shall continue in office until his resignation is accepted by that Government.`
  line
  line `(7) The manner of filling vacancies among members shall be such as may be prescribed by rules.`
obj_root_law_sections_7:
  sectionId (5378)
  sectionNo (7)
  orderNo 7
  title `President of the Institute.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5378&sectionno=7&orderno=7&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_7_content:
  string
  line `(1) There shall be a ^1[President for every Institute] who shall be`
  line `nominated by the Central Government from among the members other than the Director of the Institute.`
  line
  line `^2[Provided that the President of the existing Institute shall also be the President of every`
  line `corresponding Institute and other Institutes established on and after the commencement of the All-India`
  line `Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), till such date the Central Government`
  line `nominates a separate President for every corresponding Institute and other Institutes established after such`
  line commencement.]
  line
  line `(2) The President shall exercise such powers and discharge such functions as are laid down in this Act`
  line `or as may be prescribed by rules or regulations.`
obj_root_law_sections_7_footnotes:
  string
  line `1 Subs. by Act 37 of 2012, s. 8, for President of the Institute (w.e.f. 16-7-2012).`
  line
  line `2 Ins. by s. 8, ibid. (w.e.f. 16-7-2012).`
obj_root_law_sections_8:
  sectionId (5379)
  sectionNo (8)
  orderNo 8
  title `Allowances of President and members.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5379&sectionno=8&orderno=8&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_8_content:
  string
  line `The President and members shall receive such`
  line `allowances, if any, ^1[from the Institute of which they are the President and members] as may be`
  line `prescribed by rules.`
  line
  line `^2[Provided that in case a person is a President of two or more Institutes, the allowances shall be borne`
  line `by the Institutes in such proportion as may be prescribed by rules.]`
obj_root_law_sections_8_footnotes:
  string
  line `1 Subs. by s. 9, ibid., for from the Institute (w.e.f. 16-7-2012).`
  line
  line `2 Ins. by s. 9, ibid. (w.e.f. 16-7-2012).`
obj_root_law_sections_9:
  sectionId (5380)
  sectionNo (9)
  orderNo 9
  title `Meetings of the Institute.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5380&sectionno=9&orderno=9&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_9_content:
  string
  line `^1[Every Institute shall] hold its first meeting at such time and place as`
  line `may be appointed by the Central Government and shall observe such rules of procedure in regard to the`
  line `transaction of business at the first meeting as may be laid down by that Government; and`
  line thereafter
  line `^2[every Institute shall meet] at such times and places and observe such rules of procedure in`
  line `regard to the transaction of business at its meetings as may be prescribed by regulation:`
  line
  line `^3[Provided that the provisions relating to holding of the first meeting shall not apply to the existing`
  line Institute.]
obj_root_law_sections_9_footnotes:
  string
  line `1. Subs. by s. 10, ibid., for "The Institute shall" (w.e.f. 16-7-2012).`
  line
  line `2. Subs. by s. 10, ibid., for "the Institute shall meet" (w.e.f. 16-7-2012).`
  line
  line `3. Ins. by s. 10, ibid. (w.e.f. 16-7-2012).`
obj_root_law_sections_10:
  sectionId (5381)
  sectionNo (10)
  orderNo 10
  title `Governing Body and other Committees of the Institute.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5381&sectionno=10&orderno=10&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_10_content:
  string
  line `(1) There shall be ^1[separate`
  line `Governing Body for every Institute which shall be constituted by such Institute] from among its members`
  line `in such manner as may be prescribed by regulations.`
  line
  line `^2[Provided that the Governing Body of the existing Institute, constituted before the commencement of`
  line `the All-India Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), shall be deemed to have`
  line `been constituted under this section.]`
  line
  line `(2) The Governing Body shall be the executive committee of 3[every Institute] and shall exercise`
  line `such powers and discharge such functions as 3[every Institute] may, by regulations made in this behalf,`
  line `confer or impose upon it.`
  line
  line `(3) The President of ^3[every Institute] shall be the Chairman of the Governing Body and as Chairman`
  line `thereof shall exercise such powers and discharge such functions as may be prescribed by regulations.`
  line
  line `(4) The procedure to be followed in the exercise of its powers and discharge of its functions by the`
  line `Governing Body, and the term of office of, and the manner of filling vacancies among, the members of`
  line `the Governing Body shall be such as may be prescribed by regulations.`
  line
  line `(5) Subject to such control and restrictions as may be prescribed by rules, ^4[every Institute may constitute] as many standing committees and as many ad hoc committees as it thinks fit for exercising any`
  line `power or discharging any ^5[functions of such Institute] or for inquiring into or reporting or advising upon,`
  line `any matter which the Institute may refer to them.`
  line
  line `(6) A standing committee shall consist exclusively of ^5[members of every Institute; but an ad hoc`
  line `committee may include persons who are not members of such Institute] but the number of such persons`
  line `shall not exceed one-half of its total membership.`
  line
  line `^7[Provided that the Standing Committee of the existing Institute constituted, before the`
  line `commencement of the All-India Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), shall`
  line `be deemed to have been constituted under this section.]`
  line
  line `(7) The Chairman and members of the Governing Body and the Chairman and members of a standing`
  line `committee or an ad hoc committee shall receive such allowances, if any, as may be prescribed by`
  line regulations.
obj_root_law_sections_10_footnotes:
  string
  line `1. Subs. by s. 11, ibid., for "a Governing Body of the Institute which shall be constituted by the Institute" (w.e.f. 16-7-2012).`
  line
  line `2. Ins. by s. 11, ibid. (w.e.f. 16-7-2012).`
  line
  line `3. Subs. by s. 11, ibid., for "the Institute" (w.e.f. 16-7-2012).`
  line
  line `4. Subs. by Act 37 of 2012, s. 11, for "the Institute may constitute" (w.e.f. 16-7-2012).`
  line
  line `5. Subs. by s. 11, ibid., for "functions of the Institute" (w.e.f. 16-7-2012).`
  line
  line `6. Subs. by s. 11, ibid., for certain words (w.e.f. 16-7-2012).`
  line
  line `7. Ins. by s. 11, ibid. (w.e.f. 16-7-2012)`
obj_root_law_sections_11:
  sectionId (5382)
  sectionNo (11)
  orderNo 11
  title `Staff of the Institute.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5382&sectionno=11&orderno=11&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_11_content:
  string
  line `(1) There shall be a ^1[chief executive officer of every Institute] who shall`
  line `be designated as the ^2[Director of such Institute] and shall, subject to such rules as may be made by the`
  line `Central Government in this behalf, be appointed by the Institute:`
  line
  line `^3[Provided that the first Director of every Institute (other than the existing Institute), established`
  line `on and after the commencement of the All-India Institute of Medical Sciences (Amendment)`
  line `Act, 2012 (37 of 2012), shall be appointed by the Central Government:`
  line
  line `Provided further that in case a Director of a society has been appointed by the Central Government`
  line `before the commencement of the All-India Institute of Medical Sciences (Amendment) Act, 2012, such`
  line `Director shall be deemed to be the first Director of the concerned corresponding Institute.]`
  line
  line `^4[(1A) The Director shall hold office for a term of five years from the date on which he enters upon`
  line `his office or until he attains the age of sixty-five years, whichever is earlier:`
  line
  line `Provided that any person holding office as a Director immediately before the commencement of the`
  line `All-India Institute of Medical Sciences and the Post-Graduate Institute of Medical Education and`
  line `Research (Amendment) Act, 2007 (42 of 2007), shall in so far as his appointment is inconsistent with the`
  line `provisions of this sub-section, cease to hold office on such commencement as such Director and shall be`
  line `entitled to claim compensation not exceeding three months' pay and allowances for the premature`
  line `termination of his office or of any contract of service.]`
  line
  line `(2) The Director shall act as the Secretary to the Institute as well as the Governing Body.`
  line
  line `(3) The Director shall exercise such powers and discharge such functions as may be prescribed by`
  line `regulations or as may be delegated to him by the Institute or the President of the Institute or by the`
  line `Governing Body or the Chairman of the Governing Body.`
  line
  line `(4) Subject to such rules as may be made by the Central Government in this behalf, the Institute may`
  line `appoint such number of other officers and employees as may be necessary for the exercise of its powers`
  line `and discharge of its functions and may determine the designations and grades of such other officers and`
  line employees.
  line
  line `(5) The Director and other officers and employees of the Institute shall be entitled to such salary and`
  line `allowances and shall be governed by such conditions of service in respect of leave, pension, provident`
  line `fund and other matters as may be prescribed by regulations made in this behalf.`
obj_root_law_sections_11_footnotes:
  string
  line `1 Subs. by s. 12, ibid., for "chief executive officer of the Institute" (w.e.f. 16-7-2012).`
  line `2 Subs. by s. 12, ibid., for "Director of the Institute" (w.e.f. 16-7-2012).`
  line `3 Subs. by s. 12, ibid., for the proviso (w.e.f. 16-7-2012).`
  line `4 Ins. by Act 42 of 2007, s. 2 (w.e.f. 30-11-2007).`
obj_root_law_sections_12:
  sectionId (5383)
  sectionNo (12)
  orderNo 12
  title `Location of the Institute.`
  content obj_root_law_sections_12_content
  footnotes `. Subs. by Act 37 of 2012, s. 13, for section 12 (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5383&sectionno=12&orderno=12&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_12_content:
  string
  line `^1[12. Location of the Institute. -- (1) The existing Institute shall be located at New Delhi.`
  line
  line `(2) All corresponding Institutes shall be located at the places mentioned in column (3) of the Table`
  line `given under section 27A.`
  line
  line `(3) All Institutes [other than the existing Institute and corresponding Institutes referred to in`
  line `sub-sections (1) and (2)] shall be located at such places as the Central Government may, by notification in`
  line `the Official Gazette, specify.]`
obj_root_law_sections_13:
  sectionId (5384)
  sectionNo (13)
  orderNo 13
  title `Objects of the Institute.`
  content obj_root_law_sections_13_content
  footnotes `1 Subs. by s. 14, ibid., for the Institute (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5384&sectionno=13&orderno=13&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_13_content:
  string
  line `The objects of ^1[every Institute] shall be--`
  line
  line `(a) to develop patterns of teaching in under-graduate and post-graduate medical education in all`
  line `its branches so as to demonstrate a high standard of medical education to all medical colleges and`
  line `other allied institutions in India;`
  line
  line `(b) to bring together in one place educational facilities of the highest order for the training of`
  line `personnel in all important branches of health activity; and`
  line
  line `(c) to attain self-sufficiency in post-graduate medical education.`
obj_root_law_sections_14:
  sectionId (5385)
  sectionNo (14)
  orderNo 14
  title `Functions of the Institute.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5385&sectionno=14&orderno=14&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_14_content:
  string
  line `With a view to promotion of the objects specified in`
  line `section 13, ^1[every Institute] may--`
  line
  line `(a) provide for under-graduate and post-graduate teaching in the science of modern medicine and`
  line `other allied sciences, including physical and biological sciences;`
  line
  line `(b) provide facilities for research in the various branches of such sciences;`
  line
  line `(c) provide for the teaching of humanities in the under graduate courses;`
  line
  line `(d) conduct experiments in new methods of medical education, both under graduate and`
  line `post-graduate, in order to arrive at satisfactory standards of such education;`
  line
  line `(e) prescribe courses and curricula for both under-graduate and post graduate studies;`
  line
  line `(f) notwithstanding anything contained in any other law for the time being in force, establish and`
  line maintain--
  line
  line `(i) one or more medical colleges with different departments, including a department of`
  line `preventive and social medicine, sufficiently staffed and equipped to undertake not only under`
  line `graduate medical education but also post-graduate medical education in different subjects;`
  line
  line `(ii) one or more well-equipped hospitals;`
  line
  line `(iii) a dental college with such institutional facilities for the practice of dentistry and for the`
  line `practical training of students as may be necessary;`
  line
  line `(iv) a nursing college sufficiently staffed and equipped for the training of nurses;`
  line
  line `(v) rural and urban health organisations which will form centers for the field training of the`
  line `medical, dental and nursing students of the Institute as well as for research into community health`
  line `problems; and`
  line
  line `(vi) other institutions for the training of different types of health workers, such as`
  line `physiotherapists, occupational therapists and medical technicians of various kinds;`
  line
  line `(g) train teachers for the different medical colleges in India;`
  line
  line `(h) hold examinations and grant such degrees, diplomas and other academic distinctions and titles`
  line `in under-graduate and post-graduate medical education as may be laid down in the regulations;`
  line
  line `(i) institute, and appoint persons to, professorships, readerships, lectureships and posts of any`
  line `description in accordance with regulations;`
  line
  line `(j) receive grants from the Government and gifts, donations, benefactions, bequests and transfers`
  line `of properties, both movable and immovable, from donors, benefactors, testators or transferors, as the`
  line `case may be;`
  line
  line `(k) deal with any property belonging to, or vested in, the Institute in any manner which is`
  line `considered necessary for promoting the objects specified in section 13;`
  line
  line `(l) demand and receive such fees and other charges as may be prescribed by regulations;`
  line
  line `^2[(m) construct quarters for its staff and allot such quarters to the staff in accordance with such`
  line `regulations as may be made in this behalf;`
  line
  line `(n) borrow money, with the prior approval of the Central Government, on the security of the`
  line `property of the Institute.]`
obj_root_law_sections_14_footnotes:
  string
  line `1 Subs. by s. 15, ibid., for the Institute (w.e.f. 16-7-2012).`
  line
  line `2 Ins. by Act 30 of 1987, s. 2 (w.e.f. 8-9-1987).`
obj_root_law_sections_15:
  sectionId (5386)
  sectionNo (15)
  orderNo 15
  title `Payment to the Institute.`
  content obj_root_law_sections_15_content
  footnotes `1 Subs. by Act 37 of 2012, s. 16, for "the Institute" (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5386&sectionno=15&orderno=15&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_15_content:
  string
  line `The Central Government may, under appropriation made by`
  line `Parliament by law in this behalf, pay to ^1[every Institute] in each financial year such sums of money and`
  line `in such manner as may be considered necessary by that Government for the exercise of its powers and`
  line `discharge of its functions under this Act.`
obj_root_law_sections_16:
  sectionId (5387)
  sectionNo (16)
  orderNo 16
  title `Fund of the Institute.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5387&sectionno=16&orderno=16&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_16_content:
  string
  line `(1)`
  line `^1[Every Institute shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government;`
  line
  line `(b) all fees and other charges received by the Institute;`
  line
  line `(c) all moneys received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all moneys received by the Institute in any other manner or from any other source.`
  line
  line `^2[Provided that the Fund maintained by the existing Institute and the society, before the`
  line `commencement of the All-India Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), shall`
  line `be deemed to be the Fund maintained under this section.]`
  line
  line `(2) All moneys credited to the Fund shall be deposited in such banks or invested in such manner as`
  line `the Institute may, with the approval of the Central Government, decide.`
  line
  line `(3) The fund shall be applied towards meeting the expenses of the Institute including expenses`
  line `incurred in the exercise of its powers and discharge of its functions under section 14.`
obj_root_law_sections_16_footnotes:
  string
  line `1 Subs. by s. 17, ibid., for "The Institute" (w.e.f. 16-7-2012).`
  line `2 Ins. by s. 17, ibid. (w.e.f. 16-7-2012).`
obj_root_law_sections_17:
  sectionId (5388)
  sectionNo (17)
  orderNo 17
  title `Budget of the Institute.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5388&sectionno=17&orderno=17&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_17_content:
  string
  line `^1[Every Institute shall prepare], in such form and at such time every`
  line `year as may be prescribed by rules, a budget in respect of the financial year next ensuing showing the`
  line `estimated receipts and ^1[expenditure of the concerned Institute] and shall forward to the Central`
  line `Government such number of copies thereof as may be prescribed by rules.`
obj_root_law_sections_17_footnotes:
  string
  line `1 Subs. by s. 18, ibid., for "The Institute shall prepare" (w.e.f. 16-7-2012).`
  line
  line `2 Subs. by s. 18, ibid., for "expenditure of the Institute" (w.e.f. 16-7-2012).`
obj_root_law_sections_18:
  sectionId (5389)
  sectionNo (18)
  orderNo 18
  title `Accounts and audit.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5389&sectionno=18&orderno=18&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_18_content:
  string
  line `(1)`
  line `^1[Every Institute] shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts, including the balance-sheet in such form as the`
  line `Central Government may by rules prescribe in consultation with the Comptroller and Auditor-General of`
  line India.
  line
  line `(2) The accounts of ^2[every Institute] shall be audited by the Comptroller and Auditor-General of`
  line `India and any expenditure incurred by him in connection with such audit shall be payable by ^2[every`
  line `Institute] to the Comptroller and Auditor General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of ^2[every Institute] shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller General of India has in connection with the audit of the`
  line `Government accounts and, in particular, shall have the right to demand the production of books, accounts,`
  line `connected vouchers and other documents and papers and to inspect the offices of ^2[every Institute] as well`
  line `as of the institutions established and maintained by it.`
  line
  line `(4) The accounts of ^2[every Institute] as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before both`
  line `Houses of Parliament.`
obj_root_law_sections_18_footnotes:
  string
  line `1 Subs. by s. 19, ibid., for "The Institute" (w.e.f. 16-7-2012).`
  line
  line `2 Subs. by Act 37 of 2012, s. 19, for "the Institute" (w.e.f. 16-7-2012).`
obj_root_law_sections_19:
  sectionId (5390)
  sectionNo (19)
  orderNo 19
  title `Annual Report.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by s. 19, ibid., for "The Institute" (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5390&sectionno=19&orderno=19&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_19_content:
  string
  line `^1[Every Institute] shall prepare for every year a report of its activities during`
  line `that year and submit the report to the Central Government in such form and on or before such date as may`
  line `be prescribed by rules and a copy of this report shall be laid before both Houses of Parliament within one`
  line `month of its receipt.`
obj_root_law_sections_20:
  sectionId (5391)
  sectionNo (20)
  orderNo 20
  title `Pension and provident funds.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5391&sectionno=20&orderno=20&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_20_content:
  string
  line `(1) ^1[Every Institute] shall constitute for the benefit of its`
  line `officers, teachers and other employees in such manner and subject to such conditions as may be`
  line `prescribed by regulations, such pension and provident funds as it may deem fit.`
  line
  line `^2[Provided that the pension and provident fund constituted by the existing Institute or society, before`
  line `the commencement of the All-India Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012),`
  line `shall be deemed to be the pension and provident fund under this section.]`
  line
  line `(2) Where any such pension or provident fund has been constituted the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund as if it`
  line `were a Government provident fund.`
obj_root_law_sections_20_footnotes:
  string
  line `1 Subs. by s. 20, ibid., for "The Institute" (w.e.f. 16-7-2012).`
  line
  line `2 Ins. by s. 20, ibid. (w.e.f. 16-7-2012).`
obj_root_law_sections_21:
  sectionId (5392)
  sectionNo (21)
  orderNo 21
  title `Authentication of the orders and instruments of the Institute.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5392&sectionno=21&orderno=21&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_21_content:
  string
  line `All orders and ^1[decisions of`
  line `every Institute] shall be authenticated by the signature of the President or any other member authorised by`
  line `the Institute in this behalf and all other instruments shall be authenticated by the signature of the Director`
  line `or any other ^2[officer of every Institute] authorised in like manner in this behalf.`
obj_root_law_sections_21_footnotes:
  string
  line `1 Subs. by s. 21, ibid., for "decisions of the Institute" (w.e.f. 16-7-2012).`
  line
  line `2 Subs. by s. 21, ibid., for "officer of the Institute" (w.e.f. 16-7-2012).`
obj_root_law_sections_22:
  sectionId (5393)
  sectionNo (22)
  orderNo 22
  title `Acts and proceedings not to be invalidated by vacancies, etc.`
  content obj_root_law_sections_22_content
  footnotes `1. Subs. by s. 22, ibid., for "the Institute" (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5393&sectionno=22&orderno=22&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_22_content:
  string
  line `No act done or proceeding`
  line `taken by ^1[every Institute], Governing Body or any standing or ad hoc committee under this Act shall be`
  line `questioned on the ground merely of the existence of any vacancy in, or defect in the constitution`
  line `of, ^2[every Institute], Governing Body or such standing or ad hoc committee.`
obj_root_law_sections_23:
  sectionId (5394)
  sectionNo (23)
  orderNo 23
  title `Recognition of Medical, dental and nursing qualifications granted by the Institute.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5394&sectionno=23&orderno=23&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_23_content:
  string
  line `^1[23. Recognition of Medical, dental and nursing qualifications granted by the`
  line `Institute.-- Notwithstanding anything contained in the Indian Medical Council Act, 1956 (102 of 1956),`
  line `the Dentists Act, 1948 (16 of 1948) and the Indian Nursing Council Act, 1947 (48 of 1947), the medical,`
  line `dental or nursing degrees or diplomas, as the case may be, granted by ^2[every Institute] under this Act`
  line `shall be recognised--`
  line
  line `(a) medical qualifications for the purpose of the Indian Medical Council Act, 1956 (102 of 1956)`
  line `and shall be deemed to be included in the First Schedule to that Act;`
  line
  line `(b) dental qualifications for the purpose of the Dentists Act, 1948 (16 of 1948) and shall be`
  line `deemed to be included in the Scheduled to that Act; and`
  line
  line `(c) nursing qualifications for the purpose of the Indian Nursing Council Act, 1947(48 of 1947)`
  line `and shall be deemed to be included in the Schedule to that Act.]`
obj_root_law_sections_23_footnotes:
  string
  line `1 Subs. by Act 24 of 2002, s. 2, for section 23 (w.e.f. 24-5-2002).`
  line `2 Subs. by s. 22, ibid., for "the Institute" (w.e.f. 16-7-2012).`
obj_root_law_sections_24:
  sectionId (5395)
  sectionNo (24)
  orderNo 24
  title `Grant of medical, dental or nursing degrees, diplomas, etc., by the Institute.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5395&sectionno=24&orderno=24&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_24_content:
  string
  line `^1[24. Grant of medical, dental or nursing degrees, diplomas, etc., by the`
  line `Institute. -- Notwithstanding anything contained in any other law for the time being in force, ^2[every`
  line `Institute] shall have power to grant medical, dental or nursing degrees, diplomas and other academic`
  line `distinctions and title under this Act.]`
obj_root_law_sections_24_footnotes:
  string
  line `1 Subs. by Act 24 of 2002, s. 3, for section 24 (w.e.f. 24-5-2002).`
  line
  line `2 Subs. by Act 37 of 2012, s. 22, for "the Institute" (w.e.f. 16-7-2012).`
obj_root_law_sections_25:
  sectionId (5396)
  sectionNo (25)
  orderNo 25
  title `Control by Central Government.`
  content obj_root_law_sections_25_content
  footnotes `1 Subs. by s. 22, ibid., for "The Institute" (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5396&sectionno=25&orderno=25&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_25_content:
  string
  line `^1[Every Institute] shall carry out such directions as may be`
  line `issued to it from time to time by the Central Government for the efficient administration of this Act.`
obj_root_law_sections_26:
  sectionId (5397)
  sectionNo (26)
  orderNo 26
  title `Disputes between the Institute and the Central Government.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5397&sectionno=26&orderno=26&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_26_content:
  string
  line `If in, or in connection with, the`
  line `exercise of its powers and discharge of its functions by the Institute under this Act, any dispute arises`
  line `between the Institute and the Central Government, the decision of the Central Government on such`
  line `dispute shall be final.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (5398)
  sectionNo (27)
  orderNo 27
  title `Returns and information.`
  content obj_root_law_sections_27_content
  footnotes `1. Subs. by s. 22, ibid., for "The Institute" (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5398&sectionno=27&orderno=27&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_27_content:
  string
  line `^1[Every Institute] shall furnish to the Central Government such`
  line `reports, returns and other information as that Government may require from time to time.`
obj_root_law_sections_27_a:
  sectionId (5399)
  sectionNo 27A
  orderNo 28
  title `Incorporation of Institute registered as society under the Societies Registration Act, 1860.`
  content obj_root_law_sections_27_a_content
  footnotes `1. Ins. by s. 23, ibid. (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5399&sectionno=27A&orderno=28&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_27_a_content:
  string
  line `^1[27A. Incorporation of Institute registered as society under the Societies Registration`
  line `Act, 1860.--Each of the Institute, registered as society under the Societies Registration`
  line `Act, 1860 (21 of 1860) and mentioned in column (2) of the Table below shall be a body corporate having`
  line `perpetual succession and common seal and shall by its name mentioned in column (3) of that Table, sue`
  line `and be sued:`
  line
  line TABLE
  line
  line `LIST OF SOCIETIES INCORPORATED AS ALL-INDIA INSTITUTES OF MEDICAL SCIENCES`
  line
  line Serial
  line Number
  line `Society Corresponding Institute and place of its location`
  line
  line `(1) (2) (3)`
  line
  line `1. All-India Institute of Medical`
  line `Sciences, Bhopal`
