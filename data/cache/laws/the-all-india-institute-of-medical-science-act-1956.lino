obj_root_law_sections_27_b:
  sectionId (5400)
  sectionNo 27B
  orderNo 29
  title `Effect of incorporation of Institutes.`
  content obj_root_law_sections_27_b_content
  footnotes `1. Ins. by s. 23, ibid. (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5400&sectionno=27B&orderno=29&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_27_b_content:
  string
  line `^1[27B. Effect of incorporation of Institutes.-- (1) On and after the commencement of the All-India`
  line `Institute of Medical Sciences (Amendment) Act, 2012,--`
  line
  line `(a) any reference to a society in any law, other than this Act, or in any contract or other`
  line `instrument, shall be deemed as a reference to the corresponding Institute;`
  line
  line `(b) all property, movable and immovable, of or belonging to a society shall vest in the`
  line `corresponding Institute;`
  line
  line `(c) all the rights and liabilities of a society shall be transferred to, and be the rights and liabilities`
  line `of, the corresponding Institute;`
  line
  line `(d) subject to the provisions of this Act, every person (including Director, officers and other`
  line `employees) who is employed in the society, immediately before the commencement of the All-India`
  line `Institute of Medical Sciences (Amendment) Act, 2012 (37 of 2012), shall, on and after such`
  line `commencement, become an employee of the corresponding Institute and shall hold his office or`
  line `service therein by the same tenure, at the same remuneration and upon the same terms and conditions`
  line `and with the same rights and privileges as to pension, leave, gratuity, provident fund and other`
  line `matters as he would have held the same on the date of the commencement of the All-India Institute of`
  line `Medical Sciences (Amendment) Act, 2012 (37 of 2012), as if the said Act had not been promulgated,`
  line `and shall continue to do so unless and until his employment is terminated or until such tenure,`
  line `remuneration and terms and conditions are duly altered by regulations:`
  line
  line `Provided that the tenure, remuneration and terms and conditions of service of any such person`
  line `shall not be altered to his disadvantage without the previous approval of the Central Government;`
  line
  line `(e) the Governing Body of every society, shall, from the date of constitution of the Governing`
  line `Body under sub-section (1) of section 10, stand dissolved and no chairperson or other person shall be`
  line `entitled to any compensation for the premature termination of the term of his office or of any contract`
  line `of service;`
  line
  line `(f) all committees (including Standing Committee, if any) of the society shall stand dissolved;`
  line
  line `(g) any examination conducted by the existing Institute for admission of candidates for award of`
  line `medical degrees and diplomas by such society shall be valid examination and be deemed to have been`
  line `conducted by the corresponding Institute.`
  line
  line `(2) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947) or in any`
  line `other law for the time being in force, absorption of any employee by the corresponding Institutes in its`
  line `regular service under this section shall not entitle such employee to any compensation under this Act or`
  line `any other law and no such claim shall be entertained by any court, tribunal or other authority.]`
obj_root_law_sections_27_c:
  sectionId (5401)
  sectionNo 27C
  orderNo 30
  title `Provisions of this Act to apply to societies incorporated into All-India Institutes of Medical Science under section 27A.`
  content obj_root_law_sections_27_c_content
  footnotes `1. Ins. by s. 23, ibid. (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5401&sectionno=27C&orderno=30&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_27_c_content:
  string
  line `^1[27C. Provisions of this Act to apply to societies incorporated into All-India Institutes of Medical`
  line `Science under section 27A.-- All provisions of this Act shall, mutatis mutandis, apply to the societies,`
  line `referred to in column (2) of the Table given under section 27A, incorporated into All-India Institutes of`
  line `Medical Sciences referred to in column (3) of the said Table.]`
obj_root_law_sections_27_d:
  sectionId (5402)
  sectionNo 27D
  orderNo 31
  title `Power to make transitory provisions for Institutes (other than existing Institute).`
  content obj_root_law_sections_27_d_content
  footnotes `1. Ins. by s. 23, ibid. (w.e.f. 16-7-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5402&sectionno=27D&orderno=31&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_27_d_content:
  string
  line `^1[27D. Power to make transitory provisions for Institutes (other than existing Institute).-- (1) The`
  line `Central Government may, if it is of the opinion that certain measures are required for speedy and effective`
  line `functioning of corresponding Institutes (other than the existing Institute), by notification in the Official`
  line `Gazette, specify such measures as it may consider necessary for the smooth and effective functioning of`
  line `such Institutes:`
  line
  line `Provided that no such notification shall be issued under this section, after the expiry of a period of`
  line `two years from the date of commencement of the All-India Institute of Medical Sciences (Amendment)`
  line `Act, 2012 (37 of 2012).`
  line
  line `(2) Every notification issued under this section shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament.]`
obj_root_law_sections_28:
  sectionId (5403)
  sectionNo (28)
  orderNo 32
  title `Power to make rules.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5403&sectionno=28&orderno=32&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_28_content:
  string
  line `(1) The Central Government, after consultation with ^1[all the Institutes],`
  line `may, by notification in the Official Gazette, make rules to carry out the purposes of this Act:`
  line
  line `Provided that consultation with the Institute shall not be necessary on the first occasion of the making`
  line `of rules under this section, but the Central Government shall take into consideration any suggestions`
  line `which the Institute may make in relation to the amendment of such rules after they are made.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of nomination of members under clause (f) of section 4;`
  line
  line `^2[(aa) the proportion of allowances of the President to be borne by the Institutes under the proviso`
  line `to section 8;]`
  line
  line `(b) the control and restrictions in relation to the constitution of standing and ad hoc committees`
  line `under sub-section (5) of section 10;`
  line
  line `(c) the conditions of service of, the procedure to be followed by, and the manner of filling`
  line `vacancies among, members of ^3[every Institute];`
  line
  line `(d) the powers and functions to be exercised and discharged by the President of the Institute;`
  line
  line `(e) the allowances, if any, to be paid to the President and members of the Institute;`
  line
  line `(f) the number of officers and employees that may be appointed by the Institute and the manner of`
  line `such appointment;`
  line
  line `(g) the form in which and the time at which the budget and reports shall be prepared by the`
  line `Institute and the number of copies thereof to be forwarded to the Central Government;`
  line
  line `(h) the form and manner in which returns and information are to be furnished by the Institute to`
  line `the Central Government;`
  line
  line `(i) any other matter which has to be or may be prescribed by rules.`
  line
  line `^4[(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.]`
obj_root_law_sections_28_footnotes:
  string
  line `1 Subs. by Act 37 of 2012, s. 24, for "the Institute" (w.e.f. 16-7-2012).`
  line
  line `2 Ins. by Act 37 of 2012, s. 24 (w.e.f. 16-7-2012).`
  line
  line `3 Subs. by s. 24, ibid., for "the Institute" (w.e.f. 16-7-2012).`
  line
  line `4 Subs. by Act 4 of 1986, s. 2 and the Schedule, for sub-section (3) (w.e.f. 15-5-1986).`
obj_root_law_sections_29:
  sectionId (5404)
  sectionNo (29)
  orderNo 33
  title `Power to make regulations.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00016_195625_1517807324129&sectionId=5404&sectionno=29&orderno=33&orgactid=AC_CEN_12_13_00016_195625_1517807324129
obj_root_law_sections_29_content:
  string
  line `^1[Every Institute] ^2[, with the previous approval of the Central`
  line `Government, may, by notification in the Official Gazette] make regulations consistent with this Act and`
  line `the rules made thereunder to carry out the purposes of this Act, and without prejudice to the generality of`
  line `this power, such regulations may provide for--`
  line
  line `(a) the summoning and holding of meetings other than the first meeting of the Institute, the time`
  line `and place where such meetings are to be held, the conduct of business at such meetings and the`
  line `number of members necessary to form a quorum;`
  line
  line `(b) the manner of constituting the Governing Body and standing and ad hoc committees, the term`
  line `of office of, and the manner of filling vacancies among, the members of, the Governing Body and`
  line `standing and ad hoc committees;`
  line
  line `(c) the powers and functions to be exercised and discharged by the President of the Institute and`
  line `the Chairman of the Governing Body.`
  line
  line `(d) the allowances, if any, to be paid to the Chairman and the members of the Governing Body`
  line `and of standing and ad hoc committees;`
  line
  line `(e) the procedure to be followed by the Governing Body and standing and ad hoc committees in`
  line `the conduct of their business, exercise of their powers and discharge of their functions;`
  line
  line `(f) the tenure of office, salaries and allowances and other conditions of service of the Director and`
  line `other officers and employees of the Institute including teachers appointed by the Institute;`
  line
  line `(g) the powers and duties of the Chairman of the Governing Body;`
  line
  line `(h) the powers and duties of the Director and other officers and employees of the Institute;`
  line
  line `(i) the management of the properties of the Institute;`
  line
  line `(j) the degrees, diplomas and other academic distinctions and titles which may be granted by the`
  line Institute;
  line
  line `(k) the professorships, readerships, lecturerships and other posts which may be instituted and`
  line `persons who may be appointed to such professorships, readership, lecturerships and other posts;`
  line
  line `(l) the fees and other charges which may be demanded and received by the Institute;`
  line
  line `(m) the manner in which, and the conditions subject to which, pension and provident funds may`
  line `be constituted for the benefit of officers, teachers and other employees of the Institute;`
  line
  line `(n) any other matter for which under this Act provisions may be made by regulations.`
  line
  line `^3[Provided that the regulations made by the existing Institute, before the commencement of the`
  line `All-India Institute of Medical Sciences (Amendment) Act, 2012, shall continue to be the regulations made`
  line `under this section until such regulations are amended or rescinded by the existing Institute in accordance`
  line `with the provisions of this section.]`
  line
  line `(2) Until the Institute is established under this Act, any regulation which may be made under`
  line `sub-section (1) may be made by the Central Government, and any regulation so made may be altered or`
  line `rescinded by the Institute in exercise of its powers under sub-section (1).`
  line
  line `^4[Provided that every corresponding Institute shall, within three months of the date of the`
  line `commencement of the All-India Institute of Medical Sciences (Amendment) Act, 2012, make`
  line regulations.]
  line
  line `^4[(3) Every regulation made under this section shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the regulation or both Houses agree that the regulation should not be made, the regulation shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that regulation.]`
obj_root_law_sections_29_footnotes:
  string
  line `1. Subs. by Act 37 of 2012, s. 25, for "The Institute" (w.e.f. 16-7-2012).`
  line
  line `2. Subs. by Act 4 of 1986, s. 2 and the Schedule, for "may, with the previous approval of the Central Government"`
  line `(w.e.f. 15-5-1986).`
  line
  line `3. Ins. by Act 37 of 2012, s. 25 (w.e.f. 16-7-2012).`
  line
  line `4. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
