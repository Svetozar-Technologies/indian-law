  (str slug) (str the-land-ports-authority-of-india-act-2010)
  (str handle) (str 2105)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Land Ports Authority of India Act, 2010`)
  (str actNumber) (str 31)
  (str enactmentDate) (str 2010-08-31)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2105`)
  (str sources) obj_root_law_sources
