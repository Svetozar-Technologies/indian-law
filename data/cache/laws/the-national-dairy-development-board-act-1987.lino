obj_root_law:
  object
  (str slug) (str the-national-dairy-development-board-act-1987)
  (str handle) (str 1913)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Dairy Development Board Act, 1987`)
  (str actNumber) (str 37)
  (str enactmentDate) (str 1987-09-15)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1913`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `राष्‍ट्रीय डेरी विकास बोर्ड अधिनियम,1987`)
  (str actYear) (str 1987)
  (str ministry) (str `Ministry of Agriculture and Farmers Welfare`)
  (str department) (str `Department of Animal Husbandry and Dairying`)
  (str longTitle) (str `An Act to declare the institution known as the National Dairy Development Board in the State of Gujarat to be an institution of national importance and to provide for its incorporation and for the vesting in that body corporate of the undertakings of the Indian Dairy Corporation with a view to provide for the administration and the carrying on of the functions to be performed by the body corporate more effectively throughout the country and for matters connected therewith and incidental thereto.`)
  (str enforcementDate) (str 12-10-1987)
  (str notification) (str `12th October, 1987, vide notification No. S.O. 898(E), dated 12th October, 1987, see Gazette of India, Extraordinary, Part II, sec. 3(i).`)
