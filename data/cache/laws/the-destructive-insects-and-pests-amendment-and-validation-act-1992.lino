  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00012_199212_1673603282507&sectionId=72568&sectionno=1&orderno=1&orgactid=AC_CEN_23_31_00012_199212_1673603282507
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Destructive Insects and Pests`
  line `(Amendment and Validation) Act, 1992.`
  line
  line `(2) It shall be deemed to have come into force on the 27th day of October, 1989.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (72569)
  sectionNo (2)
  orderNo 2
  title `Amendment of section 3 of Act 2 of 1914.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00012_199212_1673603282507&sectionId=72569&sectionno=2&orderno=2&orgactid=AC_CEN_23_31_00012_199212_1673603282507
obj_root_law_sections_2_content:
  string
  line `[Amendment of section 3 of Act 2 of 1914.]---Rep. by the Repealing and Amending Act, 2001`
  line `(30 of 2001), s. 2 and Sch. (w.e.f. 3-9-2001).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (72570)
  sectionNo (3)
  orderNo 3
  title Validation.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00012_199212_1673603282507&sectionId=72570&sectionno=3&orderno=3&orgactid=AC_CEN_23_31_00012_199212_1673603282507
obj_root_law_sections_3_content:
  string
  line `(1) Notwithstanding any judgment, decree or order of any court, tribunal or other`
  line authority,--
  line
  line `(i) the notification No.S.O.867(E), dated the 27th October, 1989 issued under sub-section (1) of`
  line `the section 3 of the principal Act, and`
  line
  line `(ii) any fees levied or collected or purported to have been levied or collected for making an`
  line `application for a permit to import, or for making inspection, fumigation, disinfection, disinfestation or`
  line `supervision of, any article or class of articles or any insect or class of insects under the principal Act`
  line `or the said notification,`
  line `shall, for all purposes, be deemed to be and to have always been validly issued or, as the case may be,`
  line `levied or collected in accordance with the provisions of section 3 of the principal Act as amended by this`
  line `Act, and accordingly--`
  line
  line `(a) no suit or other proceeding shall be maintained or continued in any court for the refund of any`
  line `fees so collected;`
  line
  line `(b) no court or other authority shall enforce any decree or order directing the refund of any fees so`
  line collected;
  line
  line `(c) any fees levied or purported to have been levied but not collected, may be recovered under the`
  line `principal Act as amended by this Act; and`
  line
  line `(d) anything done or any action taken or purported to have been done or taken under or for the`
  line `purposes of the principal Act shall be deemed to have been validly done or taken in accordance with`
  line `law as if the provisions of section 3 of the principal Act, as amended by this Act, had been in force at`
  line `all material times.`
  line
  line `(2) For the removal of doubts, it is hereby declared that nothing in sub-section (1) shall be construed`
  line `as preventing any person--`
  line
  line `(a) from questioning in accordance with the provisions of the principal Act, as amended by this`
  line `Act, or the notification issued under section 3 of the principal Act, the levy or collection of such fees;`
  line or
  line
  line `(b) from claiming refund of any fees paid by him in excess of the amount due from him under the`
  line `principal Act, as amended by this Act, or the said notification.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (72571)
  sectionNo (4)
  orderNo 4
  title `Repeal and saving.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00012_199212_1673603282507&sectionId=72571&sectionno=4&orderno=4&orgactid=AC_CEN_23_31_00012_199212_1673603282507
obj_root_law_sections_4_content:
  string
  line `(1) The Destructive Insects and Pests (Amendment and Validation)`
  line `Ordinance, 1992 (Ord. 4 of 1992) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the principal Act, as`
  line `amended by the said Ordinance, shall be deemed to have been done or taken under the principal Act, as`
  line `amended by this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
