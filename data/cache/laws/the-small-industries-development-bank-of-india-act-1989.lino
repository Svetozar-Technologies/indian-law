obj_root_law:
  slug the-small-industries-development-bank-of-india-act-1989
  handle (1943)
  collectionHandle 123456789/1362
  title `The Small Industries Development Bank of India Act, 1989`
  actNumber (39)
  enactmentDate 1989-10-25
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1943`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भारतीय लघु उद्योग विकास बैंक अधिनियम, 1989`
  actYear (1989)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to establish the Small Industries Development Bank of India as the principal financial institution for the promotion, financing and development of industry in the small-scale sector and to co-ordinate the functions of the institutions engaged in the promotion, financing or developing industry in the small-scale sector and for matters connected therewith or incidental thereto.`
  enforcementDate 07-03-1990
  notification `7th March, 1990, vide notification No. S.O. 197(E), dated 7th March, 1990, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T21:27:40.330Z`
  translations obj_root_law_translations
