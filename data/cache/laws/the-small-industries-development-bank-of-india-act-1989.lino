obj_root_law_sections_54:
  sectionId (20769)
  sectionNo (54)
  orderNo 69
  title `Power to remove difficulties.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00035_198939_1517807323587&sectionId=20769&sectionno=54&orderno=69&orgactid=AC_CEN_2_11_00035_198939_1517807323587
obj_root_law_sections_54_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, in consultation with the Development Bank, by order, do anything, not`
  line `inconsistent with such provisions, for the purpose of removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiration of three years from the date on which`
  line `this Act receives the assent of the President.`
obj_root_law_sections_54_footnotes:
  string
  line
