  (str slug) (str the-small-industries-development-bank-of-india-act-1989)
  (str handle) (str 1943)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Small Industries Development Bank of India Act, 1989`)
  (str actNumber) (str 39)
  (str enactmentDate) (str 1989-10-25)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1943`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भारतीय लघु उद्योग विकास बैंक अधिनियम, 1989`)
  (str actYear) (str 1989)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Financial Services`)
  (str longTitle) (str `An Act to establish the Small Industries Development Bank of India as the principal financial institution for the promotion, financing and development of industry in the small-scale sector and to co-ordinate the functions of the institutions engaged in the promotion, financing or developing industry in the small-scale sector and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 07-03-1990)
  (str notification) (str `7th March, 1990, vide notification No. S.O. 197(E), dated 7th March, 1990, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
