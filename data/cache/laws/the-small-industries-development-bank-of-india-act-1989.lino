obj_root_law_translations_hi_sections_23:
  kind page
  sectionId pdf-page-23
  sectionNo (23)
  orderNo 23
  title `Page 23`
  content obj_root_law_translations_hi_sections_23_content
  footnotes obj_root_law_translations_hi_sections_23_footnotes
  sourcePage 23
obj_root_law_translations_hi_sections_23_content:
  string
  line 23
  line `पहली अिुसूची`
  line `[ िारा 36(3) देविए ]`
  line `विश्ि सिीयता और गोपिीयता की घोषणा`
  line `मैं,............................................ घोषणा करता हं कक मैं ऐसे कततव्यों का विष्िा पूितक, सच्चा ई से तथा अपिे सिो त्त म`
  line `कौशल और योग्य ता से विष्पा दि और पालि करूंगा वजसका मुझसे भारतीय लघु उद्योग विकास बैंक के ( यथावस्थ वत )`
  line `विदेशक,................................... सवमवत के सदस्य, संपरीिक, अविकारी, अन्य कमतचारी के रू प में ककया जािा अपेवित है और जो`
  line `उक्त बैंक में या उसके संबंि में मेरे द्व ारा िाररत पद या ओहदे से उवचत रू प से संबंवित है।`
  line `मैं यह भी घोषणा करता हं कक मैं भारतीय ल घु उद्योग विकास बैंक के कायतक लापों से या उक्त बैंक के साथ व् य िहार करिे`
  line `िाले ककसी व् य वक् त के कायतकलापों से संबंवित कोई जािकारी ऐसे ककसी व् य वक् त को, जो उसका विवि क रू प से हकदार िहीं है, संसूवचत`
  line `िहीं करूंगा और संसूवचत िहीं होिे दूंगा तथा ऐसे व् य वक् त को उक्त बैंक की या उसके कब्जे में की तथा उक्त बैंक के कारबार से या उक्त`
  line `बैंक के साथ व् य िहार करिे िाले व् य वक् त के कारबार से संबंवित कक न् हीं बवहयों या दस्ता िे जों का विरीिण िहीं करिे दूंगा और उसकी`
  line `उि तक पहुंच िहीं होिे दूंगा।`
  line `(हस्ता िर)`
  line `मेरे समि हस्ता िररत।`
  line `1 * * * * * * *`
  line ______
  line `1 200 1 के अविवियम सं ० 30 की िारा 53 औ र पहली अिुसूची द्व ारा विरवसत।`
obj_root_law_translations_hi_sections_23_footnotes:
  string
  line
