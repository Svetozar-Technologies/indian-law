obj_root_law_sections_10_content:
  string
  line `10. [Causal Vacancies in office of Managing Director.]--Omitted by the Small Industries`
  line `Development Bank of India (Amendment) Act, 2000 (7of 2000) s. 6 (w.e.f. 27-3-2000).`
obj_root_law_sections_10_footnotes:
