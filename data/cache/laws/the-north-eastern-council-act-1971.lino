obj_root_law_sections_1:
  sectionId (31820)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31820&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the North-Eastern Council`
  line `Act, 1971.`
  line
  line `(2) It shall come into force on such date^1`
  line `, being a date not earlier than the day appointed under`
  line `clause (b) of section 2 of the North-Eastern Areas (Reorganisation) Act, 1971 (81 of 1971), as the Central`
  line `Government may, by notification in the Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1stAugust, 1972, vide notification No. G.S.R. 359(E), dated 25th July, 1972, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (31821)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31821&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Council" means the North-Eastern Council set up under section 3;`
  line
  line `^1[(b) "north-eastern area" means the area comprising the States of Arunachal Pradesh, Assam,`
  line `Manipur, Meghalaya, Mizoram,^2[Nagaland, Sikkim and Tripura]];`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 69 of 1986, s. 45, for clauses (b) and (c) (w.e.f. 20-2-1987).`
  line
  line `2. Subs. by Act 68 of 2002, s. 2, for "Nagaland and Tripura" (w.e.f. 26-6-2003).`
obj_root_law_sections_3:
  sectionId (31822)
  sectionNo (3)
  orderNo 3
  title `Setting up and composition of the North-Eastern Council.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31822&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_3_content:
  string
  line `^1[(1) There shall be a Council to be`
  line `called the North-Eastern Council which shall consist of the following members, namely:--`
  line
  line `(i) the person or persons for the time being holding the office of the Governor of the States;`
  line
  line `(ii) the Chief Ministers of the States of Arunachal Pradesh, Assam, Manipur, Meghalaya,`
  line `Mizoram, Nagaland, Sikkim and Tripura:`
  line
  line `Provided that, if there is no Council of Ministers in any State referred to in clause (b), the`
  line `President may nominate not more than one person to represent such State in the Council for so long`
  line `as there is no Council of Ministers in such State;`
  line
  line `(iii) three members to be nominated by the President.]`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the President may, if he deems it`
  line `necessary so to do, nominate a Union Minister to be a member of the Council.`
  line
  line `^2[(3) The President shall nominate the Chairman of the Council.]`
  line
  line `(4) The President may, if he deems it necessary so to do, nominate another member of the Council to`
  line `act as Vice-Chairman of the Council.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for sub-section (1) (w.e.f. 26-6-2003).`
  line
  line `2. Subs. by s. 3, ibid., for sub-section (3) (w.e.f. 26-6-2003).`
obj_root_law_sections_4:
  sectionId (31823)
  sectionNo (4)
  orderNo 4
  title `Functions of the Council.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31823&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_4_content:
  string
  line `^1[(1) The Council shall function as a regional planning body for the`
  line `north-eastern area.`
  line
  line `(2) While formulating the regional plans for the north-eastern area, the Council shall give priority to`
  line `schemes and projects which will benefit two or more States:`
  line
  line `Provided that in case or Sikkim, the Council shall formulate specific projects and schemes for that`
  line `State including the review of implementation of such projects and schemes.]`
  line
  line `(3) The Council shall--`
  line
  line `(a) review, from time to time, the implementation of the projects and schemes included in the`
  line `regional plan and recommend measures for effecting co-ordination among the Governments of the`
  line `States concerned in the matter of implementation of such projects and schemes;`
  line
  line `(b) where a project or scheme is intended to benefit two or more States, recommend the manner`
  line `in which,--`
  line
  line `(i) such project or scheme may be executed or implemented and managed or maintained; or`
  line
  line `(ii) the benefits therefrom may be shared; or`
  line
  line `(iii) the expenditure thereon may be incurred;`
  line
  line `^2* * * * *`
  line
  line `(d) recommend to the Government of the State concerned or to the Central Government the`
  line `undertaking of necessary surveys and investigation of projects in any State represented in the Council`
  line `to facilitate consideration of the feasibility of including new projects in the regional plan.`
  line
  line `(4) The Council shall review from time to time the measures taken by the States represented in the`
  line `Council for the maintenance of security and public order therein and recommend to the Governments of`
  line `the States concerned further measures necessary in this regard.`
  line
  line `^3[(5) The Council shall have such power as may be delegated to it by the Central Government.]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by s. 4, ibid., for sub-sections (1) and (2) (w.e.f. 26-6-2003).`
  line
  line `2. Clause (c) omitted by Act 68 of 2002, s. 4 (w.e.f. 26-6-2003).`
  line
  line `3. Ins. by s. 4, ibid. (w.e.f. 26-6-2003).`
obj_root_law_sections_5:
  sectionId (31824)
  sectionNo (5)
  orderNo 5
  title `Meetings of the Council.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by s. 5, ibid., for "The Council shall meet at such times" (w.e.f. 26-6-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31824&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_5_content:
  string
  line `(1) ^1[The Council shall meet at least twice in a year at such times] as`
  line `the Chairman of the Council may appoint in this behalf and shall, subject to the other provisions of this`
  line `section, observe such rules of procedure in regard to transaction of business at its meetings as it may lay`
  line `down from time to time.`
  line
  line `(2) The Chairman or in his absence the Vice-Chairman, if any, or in the absence of both the Chairman`
  line `and the Vice-Chairman, any other member chosen by the members present from amongst themselves,`
  line `shall preside at a meeting of the Council.`
  line
  line `(3) The proceedings of every meeting of the Council shall be forwarded to the Central Government`
  line `and also to the Government of each State represented on the Council.`
obj_root_law_sections_6:
  sectionId (31825)
  sectionNo (6)
  orderNo 6
  title `Nomination of certain officers to attend the meetings of the Council.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by s. 6, ibid., for "and Planning" (w.e.f. 26-6-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31825&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_6_content:
  string
  line `In order to assist the`
  line `Council in the discharge of its functions, each of the Ministries of the Central Government dealing with`
  line `matters relating to Defence, Finance, Home Affairs ^1[Planning and the Department of Development of`
  line `North-Eastern Region] shall nominate an officer to attend the meetings of the Council.`
obj_root_law_sections_7:
  sectionId (31826)
  sectionNo (7)
  orderNo 7
  title `Officers and staff of the Council.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31826&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_7_content:
  string
  line `(1) The Council shall have a secretarial staff consisting of a`
  line `Secretary, a Planning Adviser, a Financial Adviser and a Security Adviser and such other officers and`
  line `employees as the Central Government may, by order, determine.`
  line
  line `(2) The secretarial staff of the Council shall function under the direction, supervision and control of`
  line `the Chairman of the Council.`
  line
  line `(3) The office of the Council shall be located at such place as may be determined by the Council.`
  line
  line `(4) The administrative expenses of the said office, including the salaries and allowances payable to, or`
  line `in respect of, members of the secretarial staff of the Council, shall be borne by the Central Government`
  line `out of the moneys provided by Parliament for the purpose.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (31827)
  sectionNo (8)
  orderNo 8
  title Repeal.
  content `The North-Eastern Council Act, 1970 (26 of 1970) is hereby repealed.`
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00013_197184_1517807319796&sectionId=31827&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00013_197184_1517807319796
obj_root_law_sections_8_footnotes:
  string
  line
