obj_root_law_translations_hi:
  object
  (str title) (str `पूर्वोत्तर परिषद् अधिनियम, 1971`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1580/2/hH1971-84.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T12:57:09.841Z`)
  (str pageCount) (int 2)
