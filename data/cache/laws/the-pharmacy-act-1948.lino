obj_root_law_sections_1:
  sectionId (21203)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21203&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Pharmacy Act, 1948.`
  line
  line `^1[(2) It extends to the whole of India ^2***.]`
  line
  line `(3) It shall come into force at once, but Chapters III, IV and V shall take effect in a particular State`
  line `from such date ^3*** as the State Government may, by notification in the Official Gazette, appoint in this`
  line `behalf:`
  line
  line `^4[Provided that where on account of the territorial changes brought about by the reorganisation of`
  line `States on the 1st day of November, 1956, Chapters III, IV and V have effect only in a part of a State, the`
  line `said Chapters shall take effect in the remaining part of that State from such date as the State Government`
  line `may in like manner appoint.]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 24 of 1959, s. 2, for sub-section (2) (w.e.f. 1-5-1960).`
  line
  line `2. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule`
  line `(w.e.f. 31-10-2019).`
  line
  line `3. The words "not later than three years from the commencement of this Act," omitted by s. 2, ibid. (w.e.f. 1-5-1960).`
  line
  line `4. Ins. by s. 2, ibid. (w.e.f. 1-5-1960).`
obj_root_law_sections_2:
  sectionId (21204)
  sectionNo (2)
  orderNo 2
  title Interpretation.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21204&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context,--`
  line
  line `(a) "agreement" means an agreement entered into under section 20;`
  line
  line `(b) "approved" means approved by the Central Council under section 12 or section 14;`
  line
  line `^1[(c) "Central Council" means the Pharmacy Council of India constituted under section 3;`
  line
  line `(d) "Central Register" means the register of pharmacists maintained by the Central Council under`
  line `section 15A;`
  line
  line `(da) "Executive Committee" means the Executive Committee of the Central Council or of the`
  line `State Council, as the context may require;`
  line
  line `(e) "Indian University" means a University within the meaning of section 3 of the University`
  line `Grants Commission Act, 1956 (3 of 1956), and includes such other institutions, being institutions`
  line `established by or under a Central Act, as the Central Government may, by notification in the Official`
  line `Gazette, specify in this behalf;]`
  line
  line `^2[(f) "medical practitioner" means a person--`
  line
  line `(i) holding a qualification granted by an authority specified or notified under section 3 of the`
  line `Indian Medical Degrees Act, 1916 (7 of 1916), or specified in the Schedules to the Indian`
  line `Medical Council Act, 1956 (102 of 1956); or`
  line
  line `(ii) registered or eligible for registration in a medical register of a State meant for the`
  line `registration of persons practising the modern scientific system of medicine; or`
  line
  line `(iii) registered in a medical register of a State, who, although not falling within sub-clause (i)`
  line `or sub-clause (ii) is declared by a general or special order made by the State Government in this`
  line `behalf as a person practising the modern scientific system of medicine for the purposes of this`
  line `Act; or`
  line
  line `(iv) registered or eligible for registration in the register of dentists for a State under the`
  line `Dentists Act, 1948 (16 1948); or`
  line
  line `(v) who is engaged in the practice of veterinary medicine and who possesses qualifications`
  line `approved by the State Government;]`
  line
  line `(g) "prescribed" means in Chapter II prescribed by regulations made under section 18, and`
  line `elsewhere prescribed by rules made under section 46;`
  line
  line `^3[(h) "register" means a register of pharmacists prepared and maintained under Chapter IV;`
  line
  line `(i) "registered pharmacist" means a person whose name is for the time being entered in the`
  line `register of the State in which he is for the time being residing or carrying on his profession or`
  line `business of pharmacy;`
  line
  line `(j) "State Council" means a State Council of Pharmacy constituted under section 19, and includes`
  line `a Joint State Council of Pharmacy constituted in accordance with an agreement under section 20;`
  line
  line `(k) "University Grants Commission" means the University Grants Commission established under`
  line `section 4 of the University Grants Commission Act,1956 (3 of 1956).]`
  line
  line ^4*****
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 70 of 1976, s. 2, for clauses (c), (d) and (e) (w.e.f. 1-9-1976).`
  line
  line `2. Subs. by Act 24 of 1959, s. 3, for clause (f) (w.e.f. 1-5-1960).`
  line
  line `3. Subs. by Act 70 of 1976, s. 2, for clauses (h), (i) and (j) (w.e.f. 1-9-1976).`
  line
  line `4. Omitted by Act 24 of 1959, s. 3 (w.e.f. 1-5-1960).`
obj_root_law_sections_3:
  sectionId (21205)
  sectionNo (3)
  orderNo 3
  title `Constitution and composition of Central Council.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21205&sectionno=3&orderno=3&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_3_content:
  string
  line `The Central Government shall, as soon as`
  line `may be, constitute a Central Council consisting of the following members, namely:--`
  line
  line `(a) six members, among whom there shall be at least one teacher of each of the subjects,`
  line `pharmaceutical chemistry, pharmacy, pharmacology and pharmacognosy elected by the ^1[University`
  line `Grants Commission] from among persons on the teaching staff of an Indian University or a College`
  line `affiliated thereto which grants a degree or diploma in pharmacy;`
  line
  line `(b) six members, of whom at least ^2[four] shall be person possessing a degree or diploma in, and`
  line `practising pharmacy or pharmaceutical chemistry, nominated by the Central Government;`
  line
  line `(c) one member elected from amongst themselves by the members of the Medical Council of`
  line India;
  line
  line `(d) the Director General, Health Services, ex officio or if he is unable to attend any meeting, a`
  line `person authorised by him in writing to do so;`
  line
  line `^3[(dd) the Drugs Controller, India, ex officio or if he is unable to attend any meeting, a person`
  line `authorised by him in writing to do so;]`
  line
  line `(e) the Director of the Central Drugs Laboratory, ex officio;`
  line
  line `^4[(f) a representative of the University Grants Commission and a representative of the All India`
  line `Council for Technical Education;]`
  line
  line `(g) one member to represent each ^5*** State elected ^6[from amongst themselves] by the members`
  line `of each State Council, who shall be a registered pharmacist;`
  line
  line `(h) one member to represent each ^5*** State nominated by ^7[the] State Government, who shall be ^8*** a registered pharmacist:`
  line
  line `^9[Provided that for five years from the date on which the Pharmacy (Amendment) Act, 1976`
  line `(70 of 1976), comes into force the Government of each Union territory shall, instead of electing a`
  line `member under clause (g), nominate one member, being a person eligible for registration under`
  line `section 31, to represent that territory.]`
  line
  line ^10*****
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 70 of 1976, s. 3, for "authority known as the Inter-University Board" (w.e.f. 1-9-1976).`
  line
  line `2. Subs. by s. 3, ibid., for "three" (w.e.f. 1-9-1976).`
  line
  line `3. Ins. by Act 24 of 1959, s. 4 (w.e.f. 1-5-1960).`
  line
  line `4 Subs. by Act 70 of 1976, s. 3, for clause (f) (w.e.f. 1-9-1976).`
  line
  line `5. The word and letter "Part A" omitted by the Adaptation of Laws (No. 3) Order, 1956.`
  line
  line `6. Ins. by Act 70 of 1976, s. 3 (w.e.f. 1-9-1976).`
  line
  line `7. Subs. by the Adaptation of Laws (No. 3) Order, 1956, "each such".`
  line
  line `8. The words "either a registered medical practitioner or" omitted by Act 70 of 1976, s. 3 (w.e.f. 1-9-1976).`
  line
  line `9. Subs. by s. 3, ibid., for the proviso (w.e.f. 1-9-1976).`
  line
  line `10. The Explanation omitted by s. 3, ibid. (w.e.f. 1-9-1976).`
obj_root_law_sections_4:
  sectionId (21206)
  sectionNo (4)
  orderNo 4
  title `Incorporation of Central Council.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21206&sectionno=4&orderno=4&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_4_content:
  string
  line `The Council constituted under section 3 shall be a body`
  line `corporate by the name of the Pharmacy Council of India, having perpetual succession and a common seal,`
  line `with power to acquire and hold property both movable and immovable, and shall by the said name sue`
  line `and be sued.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (21207)
  sectionNo (5)
  orderNo 5
  title `President and Vice-President of Central Council.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21207&sectionno=5&orderno=5&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_5_content:
  string
  line `(1) The President and Vice-President of the`
  line `Central Council shall be elected by the members of the said Council from among themselves.`
  line
  line ^1*****
  line
  line `(2) ^2[The President] or Vice-President shall hold office as such for a term not exceeding five years`
  line `and not extending beyond the expiry of his term as member of the Central Council, but subject to his`
  line `being a member of the Central Council, he shall be eligible for re-election:`
  line
  line `^3[Provided that if his term of office as a member of the Central Council expires before the expiry of`
  line `the full term for which he is elected as President or Vice-President, he shall, if he is re-elected or renominated`
  line `as a member of the Central Council, continue to hold office as President or Vice-President for`
  line `the full term for which he is elected to such office.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. The proviso omitted by Act 24 of 1959, s. 5 (w.e.f. 1-5-1960).`
  line
  line `2. Subs. by Act 7 of 1976, s. 4, for "An elected President" (w.e.f. 1-9-1976).`
  line
  line `3. Added by s. 4, ibid. (w.e.f. 1-9-1976).`
obj_root_law_sections_6:
  sectionId (21208)
  sectionNo (6)
  orderNo 6
  title `Mode of elections.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21208&sectionno=6&orderno=6&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_6_content:
  string
  line `Elections under this Chapter shall be conducted in the prescribed manner and`
  line `where any dispute arises regarding any such election it shall be referred to the Central Government whose`
  line `decision shall be final.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (21209)
  sectionNo (7)
  orderNo 7
  title `Term of office and casual vacancies.`
  content obj_root_law_sections_7_content
  footnotes `1. The words "other than a nominated President" omitted ibid., s. 5 (w.e.f. 1-9-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21209&sectionno=7&orderno=7&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of this section, a nominated`
  line `or elected member ^1*** shall hold office for a term of five years from the date of his nomination or`
  line `election or until his successor has been duly nominated or elected, whichever is longer.`
  line
  line `(2) A nominated or elected member may at any time resign his membership by writing under his hand`
  line `addressed to the President, and the seat of such member shall thereupon become vacant.`
  line
  line `(3) A nominated or elected member shall be deemed to have vacated his seat if he is absent without`
  line `excuse, sufficient in the opinion of the Central Council, from three consecutive meetings of the Central`
  line `Council or if he is elected under clause (a), (c) or (g) of section 3, if he ceases to be a member of the`
  line `teaching staff, Medical Council of India or a registered pharmacist, as the case may be.`
  line
  line `(4) A casual vacancy in the Central Council shall be filled by fresh nomination or election, as the case`
  line `may be, and the person nominated or elected to fill the vacancy shall hold office only for the remainder of`
  line `the term for which the member whose place he takes was nominated or elected.`
  line
  line `(5) No act done by the Central Council shall be called in question on the ground merely of the`
  line `existence of any vacancy in, or any defect in the constitution of, the Central Council.`
  line
  line `(6) Members of the Central Council shall be eligible for re- nomination or re-election.`
obj_root_law_sections_8:
  sectionId (21210)
  sectionNo (8)
  orderNo 8
  title `Staff, remuneration and allowances.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 70 of 1976, s. 6, for section 8 (w.e.f. 1-9-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21210&sectionno=8&orderno=8&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_8_content:
  string
  line `^1[8. Staff, remuneration and allowances.--The Central Council shall--`
  line
  line `(a) appoint a Registrar who shall act as the Secretary to that Council and who may also, if`
  line `deemed expedient by that Council, act as the Treasurer thereof;`
  line
  line `(b) appoint such other officers and servants as that Council deems necessary to enable it to carry`
  line `out its functions under this Act;`
  line
  line `(c) require and take from the Registrar, or any other officer or servant, such security for the due`
  line `performance of his duties as that Council may consider necessary; and`
  line
  line `(d) with the previous sanction of the Central Government, fix--`
  line
  line `(i) the remuneration and allowances to be paid to the President, Vice-President, and other`
  line `members of that Council,`
  line
  line `(ii) the pay and allowances and other conditions of service of officers and servants of that`
  line Council.]
obj_root_law_sections_9:
  sectionId (21211)
  sectionNo (9)
  orderNo 9
  title `The executive committee.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21211&sectionno=9&orderno=9&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_9_content:
  string
  line `(1) The Central Council shall, as soon as may be, constitute an`
  line `Executive Committee consisting of the President (who shall be Chairman of the Executive Committee)`
  line `and Vice-President, ex officio, and five other members elected by the Central Council from amongst its`
  line members.
  line
  line `(2) A member of the Executive Committee shall hold office as such until the expiry of his term of`
  line `office as member of the Central Council, but, subject to his being a member of the Central Council, he`
  line `shall be eligible for re-election.`
  line
  line `(3) In addition to the powers and duties conferred and imposed upon it by this Act the Executive`
  line `Committee shall exercise and discharge such powers and duties as may be prescribed.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_9_a:
  sectionId (21212)
  sectionNo 9A
  orderNo 10
  title `Other Committees.`
  content obj_root_law_sections_9_a_content
  footnotes `1. Ins. by s. 7, ibid. (w.e.f. 1-9-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21212&sectionno=9A&orderno=10&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_9_a_content:
  string
  line `^1[9A. Other Committees.--(1) The Central Council may constitute from among its members other`
  line `committees for such general or special purposes as that Council may deem necessary and for such periods`
  line `not exceeding five years as it may specify, and may co-opt for a like period persons, who are not`
  line `members of the Central Council, as members of such committees.`
  line
  line `(2) The remuneration and allowances to be paid to the members of such committees shall be fixed by`
  line `the Central Council with the previous sanction of the Central Government.`
  line
  line `(3) The business before such committees shall be conducted in accordance with such regulations as`
  line `may be made under this Act.]`
obj_root_law_sections_10:
  sectionId (21213)
  sectionNo (10)
  orderNo 11
  title `Education Regulations.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21213&sectionno=10&orderno=11&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_10_content:
  string
  line `(1) Subject to the provisions of this section, the Central Council may,`
  line `subject to the approval of the Central Government, make regulations, to be called the Education`
  line `Regulations, prescribing the minimum standard of education required for qualification as a pharmacist.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, the Education`
  line `Regulations may prescribe--`
  line
  line `(a) the nature and period of study and of practical training to be undertaken before admission to`
  line `an examination;`
  line
  line `(b) the equipment and facilities to be provided for students undergoing approved courses of study;`
  line
  line `(c) the subjects of examination and the standards therein to be attained;`
  line
  line `(d) any other conditions of admission to examinations.`
  line
  line `(3) Copies of the draft of the Education Regulations and of all Subsequent amendments thereof shall`
  line `be furnished by the Central Council to all State Governments, and the Central Council shall before`
  line `submitting the Education Regulations or any amendment thereof, as the case may be, to the Central`
  line `Government for approval under sub-section (1) take into consideration the comments of any State`
  line `Government received within three months from the furnishing of the copies as aforesaid.`
  line
  line `(4) The Education Regulations shall be published in the Official Gazette and in such other manner as`
  line `the Central Council may direct.`
  line
  line `(5) The Executive Committee shall from time to time report to the Central Council on the efficacy of`
  line `the Education Regulations and may recommend to the Central Council such amendments thereof as it`
  line `may think fit.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (21214)
  sectionNo (11)
  orderNo 12
  title `Application of Education Regulations to States.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21214&sectionno=11&orderno=12&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_11_content:
  string
  line `At any time after the constitution of the State`
  line `Council under Chapter III and after consultation with the State Council, the State Government may, by`
  line `notification in the Official Gazette, declare that the Education Regulations shall take effect in the`
  line `State:`
  line
  line `Provided that where no such declaration has been made, the Education Regulations shall take effect in`
  line `the State on the expiry of three years from the date of the constitution of the State Council.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (21215)
  sectionNo (12)
  orderNo 13
  title `Approved courses of study and examinations.`
  content obj_root_law_sections_12_content
  footnotes `1. The words "of India" omitted by the A.O. 1950.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21215&sectionno=12&orderno=13&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_12_content:
  string
  line `(1) Any authority in a State ^1*** which`
  line `conducts a course of study for pharmacists may apply to the Central Council for approval of the course,`
  line `and the Central Council, if satisfied, after such enquiry as it thinks fit to make, that the said course of`
  line `study is in conformity with the Education Regulations, shall declare the said course of study to be an`
  line `approved course of study for the purpose of admission to an approved examination for pharmacists.`
  line
  line `(2) Any authority in a State ^1*** which holds an examination in pharmacy may apply to the Central`
  line `Council for approval of the examination, and the Central Council, if satisfied, after such enquiry as it`
  line `thinks fit to make, that the said examination is in conformity with the Education Regulations, shall`
  line `declare the said examination to be an approved examination for the purpose of qualifying for registration`
  line `as a pharmacist under this Act.`
  line
  line `(3) Every authority in the States ^1*** which conducts an approved course of study or holds an`
  line `approved examination shall furnish such information as the Central Council may, from time to time,`
  line `require as to the courses of study and training and examination to be undergone, as to the ages at which`
  line `such courses of study and examination are required to be undergone and generally as to the requisites for`
  line `such courses of study and examination.`
obj_root_law_sections_13:
  sectionId (21216)
  sectionNo (13)
  orderNo 14
  title `Withdrawal of approval.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21216&sectionno=13&orderno=14&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_13_content:
  string
  line `(1) Where the Executive Committee reports to the Central Council`
  line `that an approved course of study or an approved examination does not continue to be in conformity with`
  line `the Education Regulations, the Central Council shall give notice to the authority concerned of its intention`
  line `to take into consideration the question of withdrawing the declaration of approval accorded to the course`
  line `of study or examination, as the case may be, and the said authority shall within three months from the`
  line `receipt of such notice forward to the Central Council through the State Government such representation in`
  line `the matter as it may wish to make.`
  line
  line `(2) After considering any representation which may be received from the authority concerned and any`
  line `observations thereon which the State Government may think fit to make, the Council may declare that the`
  line `course of study or the examination shall be deemed to be approved only when completed or passed, as the`
  line `case may be, before a specified date.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (21217)
  sectionNo (14)
  orderNo 15
  title `Qualifications granted outside the territories to which this Act extends.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21217&sectionno=14&orderno=15&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_14_content:
  string
  line `The Central`
  line `Council, if it is satisfied that any qualification in pharmacy granted by an authority outside the ^1[territories`
  line `to which this Act extends], affords a sufficient guarantee of the requisite skill and knowledge, may`
  line `declare such qualification to be an approved qualification for the purpose of qualifying for registration`
  line `under this Act, and may for reasons appearing to it sufficient at any time declare that such qualification shall be deemed ^2[subject to such additional conditions, if any, as may be specified by the Central`
  line `Council,] to be approved only when granted before or after a specified date:`
  line
  line `Provided that no person other than a ^3[citizen of India] possessing such qualification shall be deemed`
  line `to be qualified for registration unless by the law and practice of the State or country in which the`
  line `qualification is granted, persons of Indian origin holding such qualification are permitted to enter and`
  line `practise the profession of pharmacy.`
obj_root_law_sections_14_footnotes:
  string
  line `1. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Part A States and Part C States"`
  line
  line `2. Ins. by Act 70 of 1976, s. 8 (w.e.f. 1-9-1976).`
  line
  line `3. Subs. by the A.O. 1950, for "British subject of Indian domicile".`
obj_root_law_sections_15:
  sectionId (21218)
  sectionNo (15)
  orderNo 16
  title `Mode of declarations.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21218&sectionno=15&orderno=16&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_15_content:
  string
  line `All declarations under section 12, section 13 or section 14 shall be made`
  line `by resolution passed at a meeting of the Central Council, and shall have effect as soon as they are`
  line `published in the Official Gazette.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_15_a:
  sectionId (21219)
  sectionNo 15A
  orderNo 17
  title `The Central Register.`
  content obj_root_law_sections_15_a_content
  footnotes `1. Ins. by Act 70 of 1976, s. 9 (w.e.f. 1-9-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21219&sectionno=15A&orderno=17&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_15_a_content:
  string
  line `^1[15A. The Central Register.--(1) The Central Council shall cause to be maintained in the`
  line `prescribed manner a register of pharmacists to be known as the Central Register, which shall contain the`
  line `names of all persons for the time being entered in the register for a State.`
  line
  line `(2) Each State Council shall supply to the Central Council five copies of the register for the State as`
  line `soon as may be after the first day of April of each year, and the Registrar of each State Council, shall`
  line `inform the Central Council, without delay, all additions to, and other amendments in, the register for the`
  line `State made from time to time.`
  line
  line `(3) It shall be the duty of the Registrar of the Central Council to keep the Central Register in`
  line `accordance with the orders made by the Central Council, and from time to time to revise the Central`
  line `Register and publish it in the Gazette of India.`
  line
  line `(4) The Central Register shall be deemed to be public document within the meaning of the Indian`
  line `Evidence Act, 1872 (1 of 1872) and may be proved by the production of a copy of the Register as`
  line `published in the Gazette of India.]`
obj_root_law_sections_15_b:
  sectionId (21220)
  sectionNo 15B
  orderNo 18
  title `Registration in the Central Register.`
  content obj_root_law_sections_15_b_content
  footnotes `1. Ins. by Act 70 of 1976, s. 9 (w.e.f. 1-9-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21220&sectionno=15B&orderno=18&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_15_b_content:
  string
  line `^1[15B. Registration in the Central Register.--The Registrar of the Central Council shall, on receipt`
  line `of the report of registration of a person in the register for a State, enter his name in the Central Register.]`
obj_root_law_sections_16:
  sectionId (21221)
  sectionNo (16)
  orderNo 19
  title Inspection.
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21221&sectionno=16&orderno=19&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_16_content:
  string
  line `(1) The Executive Committee may appoint such number of Inspectors as it may`
  line `deem requisite for purposes of this Chapter.`
  line
  line `(2) An Inspector may--`
  line
  line `(a) inspect any institution which provides an approved course of study;`
  line
  line `(b) attend at any approved examination;`
  line
  line `(c) inspect any institution whose authorities have applied for the approval of its course of study or`
  line `examination under this Chapter, and attend at any examination of such institution.`
  line
  line `(3) An Inspector attending at any examination under sub-section (2) shall not interfere with the`
  line `conduct of the examination, but he shall report to Executive Committee on the sufficiency of every`
  line `examination he attends and on any other matter in regard to which the Executive Committee may require`
  line `him to report.`
  line
  line `(4) The Executive Committee shall forward a copy of every such report to the authority or institution`
  line `concerned, and shall also forward a copy together with any comments thereon which the said authority or`
  line `institution may have made, to the Central Government and to the Government of the State in which the`
  line `authority or institution is situated.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (21222)
  sectionNo (17)
  orderNo 20
  title `Information to be furnished.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21222&sectionno=17&orderno=20&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_17_content:
  string
  line `(1) The Central Council shall furnish copies of its minutes and of`
  line `the minutes of the Executive Committee and an annual report of its activities ^1*** to the Central`
  line Government.
  line
  line `(2) The Central Government may publish in such manner as it may think fit any report, ^2[or copy],`
  line `furnished to it under this section or under section 16.`
obj_root_law_sections_17_footnotes:
  string
  line `1. The words "together with an abstract of its accounts" omitted by s. 10, ibid. (w.e.f. 1-9-1976).`
  line
  line `2. Subs. by Act 70 of 1976, s. 10, for copy or abstract (w.e.f. 1-9-1976).`
obj_root_law_sections_17_a:
  sectionId (21223)
  sectionNo 17A
  orderNo 21
  title `Accounts and audit.`
  content obj_root_law_sections_17_a_content
  footnotes `1. Ins. by s. 11, ibid. (w.e.f. 1-9-1976).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21223&sectionno=17A&orderno=21&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_17_a_content:
  string
  line `^1[17A. Accounts and audit.--(1) The Central Council shall maintain proper accounts and other`
  line `relevant records and prepare an annual statement of accounts, in accordance with such general directions`
  line `as may be issued and in such form as may be specified by the Central Government in consultation with`
  line `the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Central Council shall be audited annually by the Comptroller and AuditorGeneral`
  line `of India or any person authorised by him in this behalf and any expenditure incurred by him or`
  line `any person so authorised in connection with such audit shall be payable by the Central Council to the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person authorised by him in connection`
  line `with the audit of the accounts of the Central Council shall have the same rights and privileges and`
  line `authority in connection with such audit as the Comptroller and Auditor-General of India has in connection`
  line `with the audit of Government accounts, and in particular, shall have the right to demand the production of`
  line `books of accounts, connected vouchers and other documents and papers.`
  line
  line `(4) The accounts of the Central Council as certified by the Comptroller and Auditor-General of India`
  line `or any person authorised by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Council which shall forward the same with its comments to the Central`
  line Government.]
obj_root_law_sections_18:
  sectionId (21224)
  sectionNo (18)
  orderNo 22
  title `Power to make regulations.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21224&sectionno=18&orderno=22&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_18_content:
  string
  line `(1) The Central Council may, with the approval of the Central`
  line `Government, ^1[by notification in the Official Gazette,] make regulations consist with this Act to carry out`
  line `the purposes of this Chapter.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for--`
  line
  line `^2[(a) the management of the property of the Central Council;]`
  line
  line `(b) the manner in which elections under this Chapter shall be conducted;`
  line
  line `(c) the summoning and holding of meetings of the Central Council, the times and places at which`
  line `such meetings shall be held, the conduct of business thereat and the number of members necessary to`
  line `constitute a quorum;`
  line
  line `(d) the functions of the Executive Committee, the summoning and holding meetings thereof, the`
  line `times and places at which such meetings shall be held, and the number of members necessary to`
  line `constitute a quorum;`
  line
  line `(e) the powers and duties of the President and Vice-President;`
  line
  line `(f) the qualifications, the term of office and the powers and duties of the ^3[Registrar, Secretary],`
  line `Inspectors and other officers and servants of the Central Council, including the amount and nature of`
  line `the security to be furnished by the ^4[Registrar or any other officer or servant].`
  line
  line `^5[(g) the manner in which the Central Register shall be maintained and given publicity;`
  line
  line `(h) constitution and functions of the committees other than Executive Committee, the summoning`
  line `and holding of meetings thereof, the time and place at which such meetings shall be held, and the`
  line `number of members necessary to constitute the quorum.]`
  line
  line `^6[(i) the manner of holding inquiry and imposing penalty under sub-section (1) of section 43A;`
  line
  line `(j) the form and manner of preferring appeal under sub-section (2) of section 43A.]`
  line
  line `(3) Until regulations are made by the Central Council under this section, the President may, with the`
  line `previous sanction of the Central Government, make such regulations under this section, including those to`
  line `provide for the manner in which the first elections to the Central Council shall be conducted, as may be`
  line `necessary for carrying into effect the provisions of this Chapter, and any regulations so made may be`
  line `altered or rescinded by the Central Council in exercise of its powers under this section.`
  line
  line `^7[(4) Every regulation made under this Act, shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the regulation or both Houses agree that the regulation should not be made, the regulation shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that regulation.]`
obj_root_law_sections_18_footnotes:
  string
  line `1. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
  line
  line `2. Subs. by Act 70 of 1976, s. 12, for clause (a) (w.e.f. 1-9-1976).`
  line
  line `3. Subs. by s. 12, ibid., for "Secretary" (w.e.f. 1-9-1976).`
  line
  line `4. Subs. by s. 12, ibid., for "Treasurer" (w.e.f. 1-9-1976).`
  line
  line `5. Ins. by s. 12, ibid. (w.e.f. 1-9-1976).`
  line
  line `6. Ins. by Act 18 of 2023, s. 2 and Schedule (w.e.f. 31-12-2024)`
  line
  line `7. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
obj_root_law_sections_19:
  sectionId (21225)
  sectionNo (19)
  orderNo 23
  title `Constitution and composition of State Councils.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21225&sectionno=19&orderno=23&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_19_content:
  string
  line `Except where a Joint State Council is`
  line `constituted in accordance with an agreement made under section 20, the State Government shall`
  line `constitute a State Council consisting of the following members, namely:--`
  line
  line `(a) six members, elected from amongst themselves by registered pharmacists of the State;`
  line
  line `(b) five members, of whom at least ^1[three] shall be persons possessing a prescribed degree or`
  line `diploma in pharmacy or pharmaceutical chemistry or ^2[registered pharmacists], nominated by the`
  line `State Government;`
  line
  line `(c) one member elected from amongst themselves by the members of each Medical Council or the`
  line `Council of Medical Registration of the State, as the case may be;`
  line
  line `(d) the chief administrative medical officer of the State ex-officio or if he is unable to attend any`
  line `meeting, a person authorised by him in writing to do so;`
  line
  line `^3[(dd) the officer-in-charge of drugs control organisation of the State under the 5[Drugs and`
  line `Cosmetics Act, 1940 (23 of 1940)], ex officio or if he is unable to attend any meeting, a person`
  line `authorised by him in writing to do so;]`
  line
  line `(e) the Government Analyst under the ^4[Drugs and Cosmetics Act, 1940 (23 of 1940)], ex officio,`
  line `or where there is more than one, such one as the State Government may appoint in this behalf:`
  line
  line `Provided that where an agreement is made under clause (b) of sub-section (1) of section 20, the`
  line `agreement may provide that the State Council to serve the needs of the other participating States also shall`
  line `be augmented by not more than two members, of whom at least one shall at all times be a person`
  line `possessing a prescribed degree or diploma in pharmacy or pharmaceutical chemistry or a ^5[registered`
  line `pharmacist], nominated by the Government of each of the said other participating States, and where the`
  line `agreement so provides, the composition of the State Council shall be deemed to be augmented`
  line accordingly.
obj_root_law_sections_19_footnotes:
  string
  line `1. Subs. by Act 70 of 1976, s. 13, for "two" (w.e.f. 1-9-1976).`
  line
  line `2. Subs. by s. 13, ibid., for "members of the pharmaceutical profession" (w.e.f. 1-9-1976).`
  line
  line `3. Ins. by Act 24 of 1959, s. 7 (w.e.f. 1-5-1960).`
  line
  line `4. Subs. by Act 70 of 1976, s. 13, for "Drugs Act, 1940 (23 of 1940)" (w.e.f. 1-9-1976).`
  line
  line `5. Subs. by s. 13, ibid., for "member of the pharmaceutical profession" (w.e.f. 1-9-1976).`
obj_root_law_sections_20:
  sectionId (21226)
  sectionNo (20)
  orderNo 24
  title `Inter-State agreements.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21226&sectionno=20&orderno=24&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_20_content:
  string
  line `(1) Two or more State Governments may enter into an agreement to be`
  line `in force for such period and to be subject to renewal for such further periods, if any, as may be specified`
  line `in the agreement, to provide--`
  line
  line `(a) for the constitution of a Joint State Council for all the participating States, or`
  line
  line `(b) that the State Council of one State shall serve the needs of the other participating States.`
  line
  line `(2) In addition to such matters as are in this Act specified, an agreement under this section may--`
  line
  line `(a) provide for the apportionment between the participating States of the expenditure in`
  line `connection with the State Council or Joint State Council;`
  line
  line `(b) determine which of the participating State Governments shall exercise the several functions of`
  line `the State Government under this Act, and the references in this Act to the State Government shall be`
  line `construed accordingly;`
  line
  line `(c) provide for consultation between the participating State Governments either generally or with`
  line `reference to particular matters arising under this Act;`
  line
  line `(d) make such incidental and ancillary provisions, not inconsistent with this Act, as may be`
  line `deemed necessary or expedient for giving effect to the agreement.`
  line
  line `(3) An agreement under this section shall be published in the Official Gazettes of the participating`
  line States.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (21227)
  sectionNo (21)
  orderNo 25
  title `Composition of Joint State Councils.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21227&sectionno=21&orderno=25&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_21_content:
  string
  line `(1) A Joint State Council shall consist of the following`
  line `members, namely:--`
  line
  line `(a) such number of members, being not less than three and not more than five as the agreement`
  line `shall provide elected from amongst themselves by the registered pharmacists of each of the`
  line `participating States;`
  line
  line `(b) such number of members, being not less than two and not more than four as the agreement`
  line `shall provide, nominated by each participating State Government;`
  line
  line `(c) one member elected from amongst themselves by the members of each Medical Council or the`
  line `Council of Medical Registration of each participating State, as the case may be;`
  line
  line `(d) the chief administrative medical officer of each participating State, ex officio, or if he is`
  line `unable to attend any meeting, a person authorised by him in writing to do so;`
  line
  line `^1[(dd) the officer-in-charge of drugs control organisation of each participating State under the`
  line `^2[Drugs and Cosmetics Act, 1940] (23 of 1940), ex officio, or if he is unable to attend any meeting, a`
  line `person authorised by him in writing to do so;]`
  line
  line `(e) the Government Analyst under the ^2[Drugs and Cosmetics Act, 1940 (23 of 1940)], of each`
  line `participating State, ex officio, or where there is more than one in any such State, such one as the State`
  line `Government may appoint in this behalf.`
  line
  line `(2) The agreement may provide that within the limits specified in clauses (a) and (b) of sub-section`
  line `(1), the number of members to be elected or nominated under those clauses may or may not be the same`
  line `in respect of each participating State.`
  line
  line `(3) Of the members nominated by each State Government under clause (b) of sub-section (1), ^3[more`
  line `than half] shall be persons possessing a prescribed degree or diploma in pharmacy or pharmaceutical`
  line `chemistry or ^4[registered pharmacists].`
obj_root_law_sections_21_footnotes:
  string
  line `1. Ins. by Act 24 of 1959, s. 8 (w.e.f. 1-5-1960).`
  line
  line `2. Subs. by Act 70 of 1976, s. 14, for "Drugs Act, 1940 (23 of 1940)" (w.e.f. 1-9-1976).`
  line
  line `3. Subs. by s. 14, ibid., for "at least half" (w.e.f. 1-9-1976).`
  line
  line `4. Subs. by s. 14, ibid., for "members of the pharmaceutical profession" (w.e.f. 1-9-1976).`
obj_root_law_sections_22:
  sectionId (21228)
  sectionNo (22)
  orderNo 26
  title `Incorporation of State Councils.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21228&sectionno=22&orderno=26&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_22_content:
  string
  line `Every State Council shall be a body corporate by such name`
  line `as may be notified by the State Government in the Official Gazette or, in the case of a Joint State Council,`
  line `as may be determined in the agreement, having perpetual succession and a common seal, with power to`
  line `acquire or hold property both, movable and immovable and shall by the said name sue and be sued.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (21229)
  sectionNo (23)
  orderNo 27
  title `President and Vice-President of State Council.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21229&sectionno=23&orderno=27&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_23_content:
  string
  line `(1) The President and Vice-President of the`
  line `State Council shall be elected by the members from amongst themselves:`
  line
  line `Provided that for five years from the first constitution of the State Council the President shall be a`
  line `person nominated by the State Government who shall hold office at the pleasure of the State Government`
  line `and where he is not already a member, shall be a member of the State Council in addition to the members`
  line `referred to in section 19 or section 21, as the case may be.`
  line
  line `(2) ^1[The President] or Vice-President shall hold office as such for a term not exceeding five years`
  line `and not extending beyond the expiry of his term as a member of the State Council, but subject to his being`
  line `a member of the State Council, he shall be eligible for re-election:`
  line
  line `^2[Provided that if his term of office as a member of the State Council expires before the expiry of the`
  line `full term for which he is elected as President or Vice-President, he shall, if he is re-elected or`
  line `re-nominated as a member of the State Council, continue to hold office for the full term for which he is`
  line `elected as President or Vice- President.]`
obj_root_law_sections_23_footnotes:
  string
  line `1. Subs. by Act 70 of 1976, s. 15, for "An elected President" (w.e.f. 1-9-1976).`
  line
  line `2. Added by s. 15, ibid. (w.e.f. 1-9-1976).`
obj_root_law_sections_24:
  sectionId (21230)
  sectionNo (24)
  orderNo 28
  title `Mode of elections.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21230&sectionno=24&orderno=28&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_24_content:
  string
  line `Elections under this Chapter shall be conducted in the prescribed manner,`
  line `and where any dispute arises regarding any such election, it shall be referred to the State Government`
  line `whose decision shall be final.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (21231)
  sectionNo (25)
  orderNo 29
  title `Term of office and casual vacancies.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21231&sectionno=25&orderno=29&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_25_content:
  string
  line `(1) Subject to the provisions of this section, a nominated`
  line `or elected member, other than a nominated President, shall hold office for a term of five years from the`
  line `date of his nomination or election or until his successor has been duly nominated or elected, whichever is`
  line longer.
  line
  line `(2) A nominated or elected member may at any time resign his membership by writing under his hand`
  line `addressed to the President, and the seat of such member shall thereupon become vacant.`
  line
  line `(3) A nominated or elected member shall be deemed to have vacated his seat if he is absent without`
  line `excuse sufficient in the opinion of the State Council from three consecutive meetings of the State Council,`
  line `or if he is elected under clause (a) or (c) of section 19 or 21, if he ceases to be a registered pharmacist or`
  line `ceases to be a member of the Medical Council or Council of Medical Registration of the State, as the case`
  line `may be.`
  line
  line `(4) A casual vacancy in the State Council shall be filled by fresh nomination or election, as the case`
  line `may be, and the person nominated or elected to fill the vacancy shall hold office only for the remainder of`
  line `the term for which the member whose place he takes was nominated or elected.`
  line
  line `(5) No act done by the State Council shall be called in question on the ground merely of the existence`
  line `of any vacancy in, or any defect in the constitution of, the State Council.`
  line
  line `(6) Members of the State Council shall be eligible for re-nomination or re-election.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (21232)
  sectionNo (26)
  orderNo 30
  title `Staff, remuneration and allowances.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21232&sectionno=26&orderno=30&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_26_content:
  string
  line `The State Council may, with the previous sanction of the`
  line `State Government,--`
  line
  line `(a) appoint a Registrar who shall also act as Secretary and, if so decided by the State Council,`
  line `Treasurer, of the State Council;`
  line
  line `(b) appoint such other officers and servants as may be required to enable the State Council to`
  line `carry out its functions under this Act;`
  line
  line `(c) fix the salaries and allowances and other conditions of service of the Secretary and other`
  line `officers and servants of the State Council;`
  line
  line `(d) fix the rates of allowances payable to members of the State Council:`
  line
  line `Provided that for the first four years from the first constitution of the State Council, the Registrar shall`
  line `be a person appointed by the State Government, who shall hold office during the pleasure of the State`
  line Government.
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_26_a:
  sectionId (21233)
  sectionNo 26A
  orderNo 31
  title Inspection.
  content obj_root_law_sections_26_a_content
  footnotes obj_root_law_sections_26_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21233&sectionno=26A&orderno=31&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_26_a_content:
  string
  line `^1[26A. Inspection.--(1) A State Council may, with the previous sanction of the State Government,`
  line `appoint Inspectors having the prescribed qualifications for the purposes of Chapters III, IV and V of this`
  line Act.
  line
  line `(2) An Inspector may--`
  line
  line `(a) inspect any premises where drugs are compounded or dispensed and submit a written report to`
  line `the Registrar;`
  line
  line `(b) enquire whether a person who is engaged in compounding or dispensing of drugs is a`
  line `registered pharmacist;`
  line
  line `(c) investigate any complaint made in writing in respect of any contravention of this Act and`
  line `report to the Registrar;`
  line
  line `(d) institute prosecution under the order of the Executive Committee of the State Council;`
  line
  line `(e) exercise such other powers as may be necessary for carrying out the purposes of Chapters III,`
  line `IV and V of this Act or any rules made thereunder.`
  line
  line `(3) Any person wilfully obstructing an Inspector in the exercise of powers conferred on him by or`
  line `under this Act or any rules made thereunder shall be ^2[liable to penalty which may extend to one lakh rupees]`
  line
  line `(4) Every Inspector shall be deemed to be a public servant within the meaning of section 21 of the`
  line `Indian Penal Code (45 of 1860).]`
obj_root_law_sections_26_a_footnotes:
  string
  line `1. Ins. by Act 70 of 1976, s. 16 (w.e.f. 1-9-1976).`
  line
  line `2. Subs. by Act 18 of 2023, s. 2 and Schedule for certain words (w.e.f. 31-12-2024).`
obj_root_law_sections_27:
  sectionId (21234)
  sectionNo (27)
  orderNo 32
  title `The Executive Committee.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21234&sectionno=27&orderno=32&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_27_content:
  string
  line `(1) The State Council shall, as soon as may be, constitute an`
  line `Executive Committee consisting of the President (who shall be Chairman of the Executive Committee)`
  line and
  line `Vice-President, ex officio, and such number of other members elected by the State Council from amongst`
  line `themselves as may be prescribed.`
  line
  line `(2) A member of the Executive Committee shall hold office as such until the expiry of his term of`
  line `office as member of the State Council, but, subject to his being a member of the State Council, he shall be`
  line `eligible for re-election.`
  line
  line `(3) In addition to the powers and duties conferred and imposed upon it by this Act, the Executive`
  line `Committee shall exercise and discharge such powers and duties as may be prescribed.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (21235)
  sectionNo (28)
  orderNo 33
  title `Information to be furnished.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21235&sectionno=28&orderno=33&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_28_content:
  string
  line `(1) The State Council shall furnish such reports, copies of its`
  line `minutes and of the minutes of the Executive Committee, and abstracts of its accounts to the State`
  line `Government as the State Government may from time to time require and copies thereof shall be sent to`
  line `the Central Council.`
  line
  line `(2) The State Government may publish, in such manner as it may think fit, any report, copy, abstract`
  line `or other information furnished to it under this section.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (21236)
  sectionNo (29)
  orderNo 34
  title `Preparation and maintenance of register.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21236&sectionno=29&orderno=34&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_29_content:
  string
  line `(1) As soon as may be after this Chapter has taken`
  line `effect in any State, the State Government shall cause to be prepared in the manner hereinafter provided a`
  line `register of pharmacists for the State.`
  line
  line `(2) The State Council shall as soon as possible after it is constituted assume the duty of maintaining`
  line `the register in accordance with the provisions of this Act.`
  line
  line `(3) The register shall include the following particulars, namely:--`
  line
  line `(a) the full name and residential address of the registered person;`
  line
  line `(b) the date of his first admission to the register;`
  line
  line `(c) his qualifications for registration;`
  line
  line `(d) his professional address, and if he is employed by any person, the name of such person;`
  line
  line `(e) such further particulars as may be prescribed.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (21237)
  sectionNo (30)
  orderNo 35
  title `Preparation of first register.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21237&sectionno=30&orderno=35&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_30_content:
  string
  line `(1) For the purpose of preparing the first register, the State`
  line `Government shall by notification in the Official Gazette constitute a Registration Tribunal consisting of`
  line `three persons, and shall also appoint a Registrar who shall act as Secretary of the Registration Tribunal.`
  line
  line `(2) The State Government shall, by the same or a like notification, appoint a date on or before which`
  line `application for registration, which shall be accompanied by the prescribed fee, shall be made to the`
  line
  line `Registration Tribunal.`
  line
  line `(3) The Registration Tribunal shall examine every application received on or before the appointed`
  line `date, and if it is satisfied that the applicant is qualified for registration under section 31, shall direct the`
  line `entry of the name of the applicant on the register.`
  line
  line `(4) The first register so prepared shall thereafter be published in such manner as the State`
  line `Government may direct, and any person aggrieved by a decision of the Registration Tribunal expressed or`
  line `implied in the register as so published may, within sixty days from the date of such publication, appeal to`
  line `an authority appointed by the State Government in this behalf by notification in the Official Gazette.`
  line
  line `(5) The Registrar shall amend the register in accordance with the decision of the authority appointed`
  line `under sub-section (4) and shall thereupon issue to every person whose name is entered in the register a`
  line `certificate of registration in the prescribed form.`
  line
  line `(6) Upon the constitution of the State Council, the register shall be given into its custody, and the`
  line `State Government may direct that all or any specified part of the application fees for registration in the`
  line `first register shall be paid to the credit of the State Council.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (21238)
  sectionNo (31)
  orderNo 36
  title `Qualifications for entry on first register.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21238&sectionno=31&orderno=36&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_31_content:
  string
  line `^1[A person who has attained the age of eighteen`
  line `years shall be entitled] on payment of the prescribed fee to have his name entered in the first register if he`
  line `resides, or carries on the business or profession of pharmacy, in the State and if he--`
  line
  line `(a) holds a degree or diploma in pharmacy or pharmaceutical chemistry or a chemist and druggist`
  line `diploma of an Indian University or a State Government, as the case may be, or a prescribed`
  line `qualification granted by an authority outside ^2*** India, or`
  line
  line `(b) holds a degree of an Indian University other than a degree in pharmacy or pharmaceutical`
  line `chemistry, and has been engaged in the compounding of drugs in a hospital or dispensary or other`
  line `place in which drugs are regularly dispensed on prescriptions of medical practitioners for a total`
  line `period of not less than three years, or`
  line
  line `(c) has passed an examination recognised as adequate by the State Government for compounders`
  line `or dispensers, or`
  line
  line `(d) has been engaged in the compounding of drugs in a hospital or dispensary or other place in`
  line `which drugs are regularly dispensed on prescriptions of medical practitioners for a total period of not`
  line `less than five years prior to the date notified under sub-section (2) of section 30.`
obj_root_law_sections_31_footnotes:
  string
  line `1. Subs. by Act 24 of 1959, s. 9, for "A person shall be entitled" (w.e.f. 1-5-1960).`
  line
  line `2. The words "the Provinces of" omitted by the A.O. 1950.`
obj_root_law_sections_32:
  sectionId (21239)
  sectionNo (32)
  orderNo 37
  title `Qualifications for subsequent registration.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00008_194808_1517807321458&sectionId=21239&sectionno=32&orderno=37&orgactid=AC_CEN_12_13_00008_194808_1517807321458
obj_root_law_sections_32_content:
  string
  line `(1) After the date appointed under sub-section (2)`
  line `of section 30 and before the Education Regulations have, by or under section 11, taken effect in the State,`
  line `^1[a person who has attained the age of eighteen years shall on payment of the prescribed fee] be entitled to`
  line `have his name entered in the register if he resides or carries on the business or profession of pharmacy in`
  line `the State and if he--`
  line
  line `(a) satisfies the conditions prescribed with the prior approval of the Central Council, or where no`
  line `conditions have been prescribed, the conditions entitling a person to have his name entered on the`
  line `first register as set out in section 31, or`
  line
  line `(b) is a registered pharmacist in another State, or`
  line
  line `(c) possesses a qualification approved under section 14:`
  line
  line `Provided that no person shall be entitled ^2[under clause (a) or clause (c)] to have his name entered on`
  line `the register unless he has passed a matriculation examination or an examination prescribed as being`
  line `equivalent to a matriculation examination.`
  line
  line `(2) After the Education Regulations have by or under section 11 taken effect in the State, a person`
  line `shall on payment of the prescribed fee be entitled to have his name entered on the register if he has`
  line `attained the age of ^3[eighteen years], if he resides, or carries on the business or profession of pharmacy, in`
  line `the State and if he has passed an approved examination or possesses a qualification approved under`
  line `section 14 ^4[or is a registered pharmacist in another State].`
obj_root_law_sections_32_footnotes:
  string
