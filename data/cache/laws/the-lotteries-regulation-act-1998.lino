obj_root_law_sections_1:
  sectionId (6733)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6733&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Lotteries (Regulation)`
  line `Act, 1998.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall be deemed to have come into force on the 2nd day of October, 1997.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (6734)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6734&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context,—`
  line
  line `(a) "bumper draw of a lottery" means a special draw of lottery conducted on or during any`
  line `festival or other special occasion wherein the prize money offered is greater than the prize money`
  line `offered in the case of other ordinary draw of lotteries;`
  line
  line `(b) "lottery" means a scheme, in whatever form and by whatever name called, for distribution of`
  line `prizes by lot or chance to those persons participating in the chances of a prize by purchasing tickets;`
  line
  line `(c) "prescribed" means prescribed by rules made under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (6735)
  sectionNo (3)
  orderNo 3
  title `Prohibition of lotteries.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6735&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_3_content:
  string
  line `Save as otherwise provided in section 4, no State Government shall`
  line `organise, conduct or promote any lottery.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (6736)
  sectionNo (4)
  orderNo 4
  title `Conditions subject to which lotteries may be organised, etc.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6736&sectionno=4&orderno=4&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_4_content:
  string
  line `A State Government may`
  line `organise, conduct or promote a lottery, subject to the following conditions, namely:—`
  line
  line `(a) prizes shall not be offered on any pre-announced number or on the basis of a single digit;`
  line
  line `(b) the State Government shall print the lottery tickets bearing the imprint and logo of the State in`
  line `such manner that the authenticity of the lottery ticket is ensured;`
  line
  line `(c) the State Government shall sell the tickets either itself or through distributors or selling`
  line agents;
  line
  line `(d) the proceeds of the sale of lottery tickets shall be credited into the public account of the State;`
  line
  line `(e) the State Government itself shall conduct the draws of all the lotteries;`
  line
  line `(f) the prize money unclaimed within such time as may be prescribed by the State Government or`
  line `not otherwise distributed, shall become the property of that Government;`
  line
  line `(g) the place of draw shall be located within the State concerned;`
  line
  line `(h) no lottery shall have more than one draw in a week;`
  line
  line `(i) the draws of all kinds of lotteries shall be conducted between such period of the day as may be`
  line `prescribed by the State Government;`
  line
  line `(j) the number of bumper draws of a lottery shall not be more than six in a calendar year;`
  line
  line `(k) such other conditions as may be prescribed by the Central Government.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (6737)
  sectionNo (5)
  orderNo 5
  title `Prohibition of sale of ticket in a State.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6737&sectionno=5&orderno=5&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_5_content:
  string
  line `A State Government may, within the State, prohibit the`
  line `sale of tickets of a lottery organised, conducted or promoted by every other State.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (6738)
  sectionNo (6)
  orderNo 6
  title `Prohibition of organisation, etc., of lottery.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6738&sectionno=6&orderno=6&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_6_content:
  string
  line `The Central Government may, by order published`
  line `in the Official Gazette, prohibit a lottery organised, conducted or promoted in contravention of the`
  line `provisions of section 4 or where tickets of such lottery are sold in contravention of the provisions of`
  line `section 5.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (6739)
  sectionNo (7)
  orderNo 7
  title Penalty.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6739&sectionno=7&orderno=7&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_7_content:
  string
  line `(1) Where a lottery is organised, conducted or promoted after the date on which this Act`
  line `receives the assent of the President, in contravention of the provisions of this Act, by any Department of`
  line `the State Government, the Head of the Department shall be punishable with rigorous imprisonment for a`
  line `term which may extend to two years or with fine or with both:`
  line
  line `Provided that nothing contained in this section shall render such Head of the Department liable to any`
  line `punishment if he proves that the contravention was committed without his knowledge or that he exercised`
  line `all due diligence to prevent the commission of such contravention.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where a contravention under this Act has`
  line `been committed by a Department of Government and it is proved that the contravention has been`
  line `committed with the consent or connivance of, or is attributable to any neglect on the part of, any officer,`
  line `other than the Head of the Department, such officer shall also be deemed to be guilty of that`
  line `contravention and shall be liable to be proceeded against and punished accordingly.`
  line
  line `(3) If any person acts as an agent or promoter or trader in any lottery organised, conducted or`
  line `promoted in contravention of the provisions of this Act or sells, distributes or purchases the ticket of such`
  line `lottery, he shall be punishable with rigorous imprisonment for a term which may extend to two years or`
  line `with fine or with both.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (6740)
  sectionNo (8)
  orderNo 8
  title `Offences to be cognizable and non-bailable.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6740&sectionno=8&orderno=8&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_8_content:
  string
  line `The offence under this Act shall be cognizable and`
  line non-bailable.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (6741)
  sectionNo (9)
  orderNo 9
  title `Offences by companies.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6741&sectionno=9&orderno=9&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_9_content:
  string
  line `(1) Where an offence under this Act has been committed by a company,`
  line `every person who at the time the offence was committed was incharge of, and was responsible to, the`
  line `company for the conduct of the business of the company, as well as the company, shall be deemed to be`
  line `guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to, any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of the offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.—For the purposes of this section,—`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (6742)
  sectionNo (10)
  orderNo 10
  title `Power to give directions.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6742&sectionno=10&orderno=10&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_10_content:
  string
  line `The Central Government may give directions to the State`
  line `Government as to carrying into execution in the State of any of the provisions of this Act or of any rule or`
  line `order made thereunder.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (6743)
  sectionNo (11)
  orderNo 11
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6743&sectionno=11&orderno=11&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_11_content:
  string
  line `(1) The Central Government may, by`
  line `notification in the Official Gazette, make rules to carry out the provisions of this Act.`
  line
  line `(2) Every rule made by the Central Government shall be laid, as soon as may be after it is made,`
  line `before each House of Parliament, while it is in session, for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule, or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (6744)
  sectionNo (12)
  orderNo 12
  title `Power of State Government to make rules.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6744&sectionno=12&orderno=12&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_12_content:
  string
  line `(1) The State Government may, by notification in`
  line `the Official Gazette, make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:—`
  line
  line `(a) time to be fixed for claiming prize money under clause (f) of section 4;`
  line
  line `(b) period to be fixed for draws of all lotteries under clause (i) of section 4; and`
  line
  line `(c) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made by the State Government under this section shall be laid, as soon as may be after`
  line `it is made, before each House of the State Legislature where it consists of two Houses, or where such`
  line `Legislature consists of one House, before that House.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (6745)
  sectionNo (13)
  orderNo 13
  title `Repeal and saving.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00017_199817_1517807323788&sectionId=6745&sectionno=13&orderno=13&orgactid=AC_CEN_5_24_00017_199817_1517807323788
obj_root_law_sections_13_content:
  string
  line `(1) The Lotteries (Regulation) Ordinance, 1998 (Ord. 6 of 1998), is hereby`
  line repealed.
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance, shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
