  (str title) (str `राज्यपाल (उपलब्धिऔयां, भत्ते और विशेषाधिकार) अधिनियम, 1982`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1838/2/H1982-43.pdf`)
