  (str slug) (str the-national-co-operative-development-corporation-act-1962)
  (str handle) (str 1462)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Co-operative Development Corporation Act, 1962`)
  (str actNumber) (str 26)
  (str enactmentDate) (str 1962-08-31)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1462`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `राष्‍ट्रीय सहकारी विकास निगम अधिनियम, 1962`)
  (str actYear) (str 1962)
  (str ministry) (str `Ministry of Agriculture and Farmers Welfare`)
  (str department) (str `Department of Agriculture, Cooperation and Farmers Welfare`)
  (str longTitle) (str `An Act to provide for the incorporation and regulation of a corporation for the purpose of planning and promoting programmes for the production, processing, marketing, storage, export and import of agricultural produce, foodstuffs industrial goods, livestock, certain other commodities and services on co-operative principles and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 14-03-1963)
  (str notification) (str `14th March, 1963, vide notification No. G.S.R. 456, dated 14th March, 1963, see Gazette of India, Extraordinary, Part II, sec. 3(i).`)
  (str fetchedAt) (str `2026-05-08T20:12:27.451Z`)
  (str translations) obj_root_law_translations
