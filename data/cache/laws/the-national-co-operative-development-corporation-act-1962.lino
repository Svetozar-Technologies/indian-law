obj_root_law:
  slug the-national-co-operative-development-corporation-act-1962
  handle (1462)
  collectionHandle 123456789/1362
  title `The National Co-operative Development Corporation Act, 1962`
  actNumber (26)
  enactmentDate 1962-08-31
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1462`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्‍ट्रीय सहकारी विकास निगम अधिनियम, 1962`
  actYear (1962)
  ministry `Ministry of Agriculture and Farmers Welfare`
  department `Department of Agriculture, Cooperation and Farmers Welfare`
  longTitle `An Act to provide for the incorporation and regulation of a corporation for the purpose of planning and promoting programmes for the production, processing, marketing, storage, export and import of agricultural produce, foodstuffs industrial goods, livestock, certain other commodities and services on co-operative principles and for matters connected therewith or incidental thereto.`
  enforcementDate 14-03-1963
  notification `14th March, 1963, vide notification No. G.S.R. 456, dated 14th March, 1963, see Gazette of India, Extraordinary, Part II, sec. 3(i).`
  fetchedAt `2026-05-08T20:12:27.451Z`
  translations obj_root_law_translations
