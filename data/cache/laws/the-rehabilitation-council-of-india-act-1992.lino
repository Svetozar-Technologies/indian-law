obj_root_law_sections_1:
  sectionId (18936)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00015_199234_1517807323807&sectionId=18936&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00015_199234_1517807323807
obj_root_law_sections_1_content:
  string
  line `^1[1. Short title and commencement.--(1) This Act may be called the Rehabilitation Council of India`
  line `Act, 1992.`
  line
  line `(2) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 38 of 2000, s. 2, for "the training of rehabilitation professionals and" (w.e.f. 4-9-2000).`
  line
  line `2. 31st July, 1993, vide notification No. S.O. 288(E), dated 28th April, 1993, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (18937)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00015_199234_1517807323807&sectionId=18937&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00015_199234_1517807323807
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Chairperson" means the Chairperson of the Council appointed under sub-section (3) of`
  line `section 3;`
  line
  line `(b) "Council" means the Rehabilitation Council of India constituted under section 3;`
  line
  line `^1[(c) "handicapped" means a person suffering from any disability referred to in clause (i) of`
  line `section 2 of the Persons With Disabilities (Equal Opportunities, Protection of Rights and Full`
  line `Participation) Act, 1995 (1 of 1996);]`
  line
  line `^2* * * * *`
  line
  line `(f) "member" means a member appointed under sub-section (3) of section 3 and includes the`
  line Chairperson;
  line
  line `(g) "Member-Secretary" means the Member-Secretary appointed under sub-section (1) of`
  line `section 8;`
  line
  line `(h) "mental retardation" means a condition of arrested or incomplete development of mind of a`
  line `person which is specially characterised by sub-normality of intelligence;`
  line
  line `(i) "notification" means a notification published in the Official Gazette;`
  line
  line `(j) "prescribed" means prescribed by regulations;`
  line
  line `(k) "recognised rehabilitation qualifications" means any of the qualifications included in the`
  line Schedule;
  line
  line `(l) "Register" means the Central Rehabilitation Register maintained under sub-section (1) of`
  line `section 23;`
  line
  line `(m) "regulations" means regulations made under this Act;`
  line
  line `^5[(ma) "rehabilitation" refers to a process aimed at enabling persons with disabilities to reach and`
  line `maintain their optimal physical, sensory, intellectual, psychiatric or social functional levels;]`
  line
  line `(n) "rehabilitation professionals" means--`
  line
  line `(i) audiologists and speech therapists;`
  line
  line `(ii) clinical psychologists;`
  line
  line `(iii) hearing aid and ear mould technicians;`
  line
  line `(iv) rehabilitation engineers and technicians;`
  line
  line `(v) special teachers for educating and training the handicapped;`
  line
  line `(vi) vocational counsellors, employment officers and placement officers dealing with`
  line handicapped;
  line
  line `(vii) multi-purpose rehabilitation therapists, technicians; or`
  line
  line `(viii) such other category of professionals as the Central Government may, in consultation`
  line `with the Council, notify from time to time;`
  line
  line `^4* * * * *`
  line
  line `^5[(1A) Words and expressions used and not defined in this Act but defined in the Persons With`
  line `Disabilities (Equal Opportunities, Protection of Rights and Full Participation) Act, 1995 (1 of 1996) shall`
  line `have the meanings respectively assigned to them in that Act.]`
  line
  line `(2) Any reference in this Act to any enactment or any provision thereof shall, in relation to an area in`
  line `which such enactment or such provision is not in force, be construed as a reference to the corresponding`
  line `law or the relevant provision of the corresponding law, if any, in force in that area.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 38 of 2000, s. 3, for clause (c) (w.e.f. 4-9-2000).`
  line
  line `2. Clauses (d) and (e) omitted by s. 3, ibid. (w.e.f. 4-9-2000).`
  line
  line `3. Ins. by s. 3, ibid. (w.e.f. 4-9-2000).`
  line
  line `4. Clause (o) omitted by Act 38 of 2000, s. 3 (w.e.f. 4-9-2000).`
  line
  line `5. Ins. by s. 3, ibid. (w.e.f. 4-9-2000).`
obj_root_law_sections_3:
  sectionId (18938)
  sectionNo (3)
  orderNo 3
  title `Constitution and incorporation of Rehabilitation Council of India.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by s. 4, ibid., for clauses (a) and (b) (w.e.f. 4-9-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00015_199234_1517807323807&sectionId=18938&sectionno=3&orderno=3&orgactid=AC_CEN_12_13_00015_199234_1517807323807
obj_root_law_sections_3_content:
  string
  line `(1) With effect from such`
  line `date as the Central Government may, by notification, appoint in this behalf, there shall be constituted for`
  line `the purposes of this Act a Council to be called the Rehabilitation Council of India.`
  line
  line `(2) The Council shall be a body corporate by the name aforesaid, having perpetual succession and a`
  line `common seal, with power, subject to the provisions of this Act, to acquire, hold and dispose of property,`
  line `both movable and immovable, and to contract and shall by the said name sue and be sued.`
  line
  line `(3) The Council shall consist of the following members, namely:--`
  line
  line `^1[(a) a Chairperson, from amongst the persons having experience in administration with`
  line `professional qualification in the field of rehabilitation, disabilities, and special education, to be`
  line `appointed by the Central Government;`
  line
  line `(b) such number of members not exceeding seven, as may be nominated by the Central`
  line `Government, to represent the Ministries of the Central Government dealing with matters relating to`
  line `persons with disabilities;]`
  line
  line `(c) one member to be appointed by the Central Government to represent the University Grants`
  line Commission;
  line
  line `(d) one member to be appointed by the Central Government to represent the Directorate General`
  line `of Indian Council of Medical Research;`
  line
  line `(e) two members to be appointed by the Central Government to represent the Ministry or`
  line `department of the States or the Union territories dealing with Social Welfare by rotation in`
  line `alphabetical order;`
  line
  line `(f) such number of members not exceeding six as may be appointed by the Central Government`
  line `from amongst the rehabilitation professionals working in voluntary organisations;`
  line
  line `(g) such number of members not exceeding four as may be appointed by the Central Government`
  line `from amongst the medical practitioners enrolled under the Indian Medical Council Act, 1956`
  line `(102 of 1956) and engaged in rehabilitation of the handicapped;`
  line
  line `(h) three Members of Parliament of whom two shall be elected by the House of the People and`
  line `one by the Council of States;`
  line
  line `(i) such number of members not exceeding three as may be nominated by the Central`
  line `Government from amongst the social workers who are actively engaged in assisting the disabled;`
  line
  line `(j) the Member-Secretary, ex officio.`
  line
  line `(4) The office of member of the Board shall not disqualify its holder for being chosen as, or for being,`
  line `a Member of either House of Parliament.`
obj_root_law_sections_4:
  sectionId (18939)
  sectionNo (4)
  orderNo 4
  title `Term of office of Chairperson and members.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00015_199234_1517807323807&sectionId=18939&sectionno=4&orderno=4&orgactid=AC_CEN_12_13_00015_199234_1517807323807
obj_root_law_sections_4_content:
  string
  line `(1) The Chairperson or a member shall hold`
  line `office for a term of two years from the date of his appointment or until his successor shall have been duly`
  line `appointed, whichever is longer.`
  line
  line `(2) A casual vacancy in the Council shall be filled in accordance with the provisions of section 3 and`
  line `the person so appointed shall hold office only for the remainder of the term for which the member in`
  line `whose place he was appointed would have held that office.`
  line
  line `(3) The Council shall meet at least once in each year at such time and place as may be appointed by`
  line `the Council and shall observe such rules of procedure in the transaction of business at a meeting as may`
  line `be prescribed.`
  line
  line `(4) The Chairperson or, if for any reason, he is unable to attend the meeting of the Council, any`
  line `member elected by the members present from amongst themselves at the meeting, shall preside at the`
  line meeting.
  line
  line `(5) All questions which come up before any meeting of the Council shall be decided by a majority of`
  line `votes of the members present and voting, and in the event of an equality of votes, the Chairperson, or in`
  line `his absence, the person presiding shall have a second or casting vote.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (18940)
  sectionNo (5)
  orderNo 5
  title Disqualifications.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00015_199234_1517807323807&sectionId=18940&sectionno=5&orderno=5&orgactid=AC_CEN_12_13_00015_199234_1517807323807
obj_root_law_sections_5_content:
  string
  line `No person shall be a member if he--`
  line
  line `(a) is, or becomes, of unsound mind or is so declared by a competent court; or`
  line
  line `(b) is, or has been, convicted of any offence which, in the opinion of the Central Government,`
  line `involves moral turpitude; or`
  line
  line `(c) is, or at any time has been, adjudicated as insolvent.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (18941)
  sectionNo (6)
  orderNo 6
  title `Vacation of office by members.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00015_199234_1517807323807&sectionId=18941&sectionno=6&orderno=6&orgactid=AC_CEN_12_13_00015_199234_1517807323807
obj_root_law_sections_6_content:
  string
  line `If a member--`
  line
  line `(a) becomes subject to any of the disqualifications mentioned in section 5; or`
  line
  line `(b) is absent without excuse, sufficient in the opinion of the Council, from three consecutive`
  line `meetings of the Council; or`
  line
  line `(c) ceases to be enrolled on the Indian Medical Register in the case of a member referred to in`
  line `clause (g) of sub-section (3) of section 3,`
  line
  line `his seat shall thereupon become vacant.`
obj_root_law_sections_6_footnotes:
  string
  line
