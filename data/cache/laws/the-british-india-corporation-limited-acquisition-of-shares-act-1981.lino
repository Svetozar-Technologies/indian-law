  (str slug) (str the-british-india-corporation-limited-acquisition-of-shares-act-1981)
  (str handle) (str 1790)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The British India Corporation Limited (Acquisition of Shares) Act, 1981`)
  (str actNumber) (str 29)
  (str enactmentDate) (str 1981-09-11)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1790`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `ब्रिटिश इंडिया कारपोरेशन लिमिटेड (शेयरों का अर्जन) अधिनियम, 1981`)
  (str actYear) (str 1981)
  (str ministry) (str `Ministry of Textiles`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the acquisition of certain shares of the British India Corporation Limited with a view to securing the proper management of the affairs of the Company and the continuity and development of the production of goods which are vital to the needs of the country and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 11-06-1981)
  (str notification) (undefined)
