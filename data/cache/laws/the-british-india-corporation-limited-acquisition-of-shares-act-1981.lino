obj_root_law_sections_1:
  sectionId (36218)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36218&sectionno=1&orderno=1&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the British India Corporation`
  line `Limited (Acquisition of Shares) Act, 1981.`
  line
  line `(2) It shall be deemed to have come into force on the 11th day of June, 1981.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (36219)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36219&sectionno=2&orderno=2&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means the 11th day of June, 1981;`
  line
  line `(b) "bank" means a banking company within the meaning of the Banking Regulation`
  line `Act, 1949 (10 of 1949);`
  line
  line `(c) "Commissioner" means the Commissioner of Payments appointed under section 6;`
  line
  line `(d) "Company" means British India Corporation Limited,being a company within the meaning of`
  line `the Companies Act, 1956 (1 of 1956), and having its registered office at Sutherland House, Kanpur,`
  line `in the State of Uttar Pradesh;`
  line
  line `(e) "notification" means a notification published in the Official Gazette;`
  line
  line `(f) "share" means a share, whether ordinary or preference, in the capital of the Company, and`
  line `includes a share pledged by any shareholder with any bank or other creditor, but does not include any`
  line `share in the capital of the Company held by--`
  line
  line `(i) the Central Government;`
  line
  line `(ii) any State Government;`
  line
  line `(iii) the State Bank of India, established under section 3 of the State Bank of India Act,1955`
  line `(23 of 1955), and its subsidiary banks;`
  line
  line `(iv) the Life Insurance Corporation of India, established under section 3 of the Life Insurance`
  line `Corporation Act, 1956 (31 of 1956);`
  line
  line `(v) the Unit Trust of India, established under section 3 of the Unit Trust of India Act, 1963`
  line `(52 of 1963);`
  line
  line `(vi) any corresponding new bank, within the meaning of the Banking Companies (Acquisition`
  line `and Transfer of Undertakings) Act, 1970 (5 of 1970);`
  line
  line `(vii) any corresponding new bank, within the meaning of the Banking Companies`
  line `(Acquisition and Transfer of Undertakings) Act,1980 (40 of 1980);`
  line
  line `(viii) any general insurance company nationalised by the General Insurance Business`
  line `(Nationalisation) Act, 1972 (57 of 1972);`
  line
  line `(g) "shareholder" means,--`
  line
  line `(i) a person who, immediately before the appointed day, was registered by the Company as`
  line `the holder of any share and includes his legal representative; or`
  line
  line `(ii) a person who, before the appointed day, had lodged with the Company a proper`
  line `instrument of transfer of any share in the form prescribed under section 108 of the Companies`
  line `Act, 1956 (1 of 1956), and executed in accordance with the provisions of that section; or`
  line
  line `(iii) a person who claims under a proper instrument of transfer of any share in the form`
  line `prescribed under section 108 of the Companies Act, 1956 (1 of 1956), and delivers such`
  line `instrument to the Commissioner, duly executed, on or before such date as the Central`
  line `Government may, by notification, specify in this behalf;`
  line
  line `(h) "specified date" means such date as the Central Government may, for the purpose of any`
  line `provision of this Act, by notification, specify and different dates may be specified for different`
  line `provisions of this Act;`
  line
  line `(i) words and expressions used herein and not defined but defined in the Companies Act,1956 (1`
  line `of 1956), have the meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (36220)
  sectionNo (3)
  orderNo 3
  title `Transfer and vesting of shares of the Company in the Central Government.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36220&sectionno=3&orderno=3&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_3_content:
  string
  line `(1) On the`
  line `appointed day, all the shares of the Company shall, by virtue of this Act, stand transferred to, and vest in,`
  line `the Central Government.`
  line
  line `(2) The Central Government shall be deemed, on and from the appointed day, to have been registered`
  line `in the Register of members of the Company as the holder of each share which stands transferred to, and`
  line `vested in, it by virtue of the provisions of sub-section(1).`
  line
  line `(3) All the shares which have vested in the Central Government under sub-section (1), shall, by force`
  line `of such vesting, be freed and discharged of all trusts, liabilities, obligations, mortgages, charges, liens and`
  line `other encumbrances affecting them, and any attachment, injunction or any decree or order of the court,`
  line `tribunal or other authority restricting the use of such shares in any manner, shall be deemed to have been`
  line withdrawn.
  line
  line `(4) For the removal of doubts, it is hereby declared that the provisions of sub-sections (1) and (2)`
  line `shall not be deemed to affect--`
  line
  line `(a) any right of the Company subsisting, immediately before the appointed day, against any`
  line `shareholder to recover from such shareholder any sum of money on the ground that the shareholder`
  line `has not paid or credited to the Company the whole or any part of the value of the shares held by him,`
  line `or on any other ground whatsoever; or`
  line
  line `(b) any right of the shareholder subsisting, immediately before the appointed day, against the`
  line `Company to receive any dividend or other payment due from the Company.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36221)
  sectionNo (4)
  orderNo 4
  title `Management of the Company.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36221&sectionno=4&orderno=4&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_4_content:
  string
  line `For the purpose of enabling the Company to function as a`
  line `Government company, the Central Government may, by notification, make such provisions (including`
  line `changes in the Board of Directors, and amendments in the memorandum and articles of association, of the`
  line `Company) as it may consider necessary and the provisions so made shall have effect notwithstanding`
  line `anything contained in the Companies Act, 1956 (1 of 1956).`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (36222)
  sectionNo (5)
  orderNo 5
  title `Payment of amounts.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36222&sectionno=5&orderno=5&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_5_content:
  string
  line `(1) For the transfer to, and vesting in, the Central Government, under`
  line `section 3, of the shares of the Company, there shall be given by the Central Government to the`
  line `shareholders of the Company, in cash and in the manner specified in section 7, an amount of rupees`
  line `twenty-two lakhs and sixty thousand.`
  line
  line `(2) The amount, referred to in sub-section (1), shall carry simple interest at the rate of four percent.`
  line `per annum for the period commencing on the appointed day and ending on the date on which payment of`
  line `such amount is made by the Central Government to the Commissioner.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36223)
  sectionNo (6)
  orderNo 6
  title `Appointment of Commissioner of Payments.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36223&sectionno=6&orderno=6&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_6_content:
  string
  line `(1) The Central Government shall, for the`
  line `purpose of disbursing the amounts payable to shareholders of the Company under section 5, by`
  line `notification, appoint a Commissioner of Payments.`
  line
  line `(2) The Central Government may appoint such other persons as it may think fit to assist the`
  line `Commissioner and thereupon the Commissioner may authorise one or more of such persons also to`
  line `exercise all or any of the powers exercisable by him under this Act, and different persons may be`
  line `authorised to exercise different powers.`
  line
  line `(3) Any person authorised by the Commissioner to exercise any of the powers exercisable by the`
  line `Commissioner may exercise those powers in the same manner and with the same effect as if they have`
  line `been conferred on that person directly by this Act, and not by way of authorisation.`
  line
  line `(4) The salaries and allowances of the Commissioner and other persons appointed under this section`
  line `shall be defrayed out of the Consolidated Fund of India.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (36224)
  sectionNo (7)
  orderNo 7
  title `Payment by the Central Government to the Commissioner.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36224&sectionno=7&orderno=7&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_7_content:
  string
  line `(1) The Central Government`
  line `shall, within thirty days from the specified date,pay, in cash, to the Commissioner, for payment to the`
  line `shareholders of the Company,--`
  line
  line `(a) an amount equal to the amount specified in sub-section (1) of section 5; and`
  line
  line `(b) an amount equal to the amount determined under sub-section (2) of section 5.`
  line
  line `(2) A deposit account shall be opened by the Central Government in favour of the Commissioner, in`
  line `the Public Account of India, and every amount paid under this Act to the Commissioner shall be`
  line `deposited by him to the credit of the said deposit account and the said deposit account shall be operated`
  line `by the Commissioner.`
  line
  line `(3) The interest accruing on the amount standing to the credit of the deposit account referred to in`
  line `sub-section (2), shall enure to the benefit of the shareholders of the Company.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (36225)
  sectionNo (8)
  orderNo 8
  title `Claims to be made to the Commissioner.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36225&sectionno=8&orderno=8&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_8_content:
  string
  line `(1) Every shareholder, having a claim in relation to`
  line `any share acquired by this Act, shall prefer such claim before the Commissioner within thirty days from`
  line `the specified date:`
  line
  line `Provided that if the Commissioner is satisfied that the claimant was prevented by sufficient cause`
  line `from preferring theclaim within the period of thirty days, he may entertain the claim within a further`
  line `period of thirty days and not thereafter.`
  line
  line `(2) Every shareholder of a preference share shall have a preferential claim with regard to the amount`
  line `paid by the Central Government to the Commissioner.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (36226)
  sectionNo (9)
  orderNo 9
  title `Examination of claims.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36226&sectionno=9&orderno=9&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_9_content:
  string
  line `On receipt of the claims made under section 8, the Commissioner shall`
  line `separately arrange the claims in relation to preference shares and in relation to the ordinary shares and`
  line `examine the claims in relation to each such share.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (36227)
  sectionNo (10)
  orderNo 10
  title `Admission or rejection of claims.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36227&sectionno=10&orderno=10&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_10_content:
  string
  line `(1) After examining the claims, the Commissioner shall fix a`
  line `certain date on or before which every claimant shall file the proof of his claim or be excluded from the`
  line `benefit of the disbursements made by the Commissioner.`
  line
  line `(2) Not less than fourteen days' notice of the date so fixed shall be given by advertisement in one`
  line `issue of daily newspaper in the English language and in one issue of such daily newspaper in the regional`
  line `language as the Commissioner may consider suitable, and every such notice shall call upon the claimant`
  line `to file the proof of his claim with the Commissioner within the time specified in the advertisement.`
  line
  line `(3) Every claimant, who fails to file the proof of his claim within the time specified by the`
  line `Commissioner, shall be excluded from the disbursements made by the Commissioner.`
  line
  line `(4) The Commissioner shall, after such investigation as may, in his opinion, be necessary, and after`
  line `giving the Company an opportunity of refuting the claim and after giving the claimant a reasonable`
  line `opportunity of being heard, in writing, admit or reject the claim in whole or in part.`
  line
  line `(5) The Commissioner shall have the power to regulate his own procedure in all matters arising out of`
  line `the discharge of his functions, including the place or places at which he will hold his sittings and shall, for`
  line `the purpose of making an investigation under this Act, have the same powers as are vested in a civil court`
  line `under the Code of Civil Procedure, 1908 (5 of 1908), while trying a suit, in respect of the following`
  line `matters, namely:--`
  line
  line `(a) the summoning and enforcing the attendance of any witness and examining him on oath;`
  line
  line `(b) the discovery and production of any document or other material object producible as`
  line evidence;
  line
  line `(c) the reception of evidence on affidavits;`
  line
  line `(d) the issuing of any commission for the examination of witnesses.`
  line
  line `(6) Any investigation before the Commissioner shall be deemed to be a judicial proceeding within the`
  line `meaning of sections 193 and 228 of the Indian Penal Code (45 of 1860) and the Commissioner shall be`
  line `deemed to be a civil court for the purposes of section 345 and Chapter XXVI of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974).`
  line
  line `(7) A claimant, who is dissatisfied with the decision of the Commissioner, may prefer an appeal`
  line `against the decision to the principal civil court of original jurisdiction within the local limits of whose`
  line `jurisdiction the registered office of the Company is situated.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (36228)
  sectionNo (11)
  orderNo 11
  title `Disbursement of money by the Commissioner to claimants.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36228&sectionno=11&orderno=11&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_11_content:
  string
  line `(1) After admitting a claim`
  line `under this Act, the amount due in respect of each share acquired by virtue of this Act shall be paid by the`
  line `Commissioner at the rate of rupees ten per preference share, and at the rate of fifty paise per ordinary`
  line `share to the person or persons to whom such sums are due, and on such payment, the liability of the`
  line `Central Government in respect of the share so acquired shall stand discharged.`
  line
  line `(2) The Commissioner shall also apportion amongst the share-holders, the amount paid to him by way`
  line `of interest under sub-section (3) of section 7, and such apportionment shall be made on the basis of the`
  line `amount due to each shareholder.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (36229)
  sectionNo (12)
  orderNo 12
  title `Undisbursed or unclaimed amount to be deposited to the general revenue account.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36229&sectionno=12&orderno=12&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_12_content:
  string
  line Any
  line `money paid to the Commissioner which remains undisbursed or unclaimed on the date immediately`
  line `preceding the date on which the office of the Commissioner is finally wound up, shall be transferred by`
  line `the Commissioner before his office is finally would up to the general revenue account of the Central`
  line `Government; but a claim to any money so transferred may be preferred to the Central Government by the`
  line `person entitled to such payment and shall be dealt with as if such transfer had not been made, the order, if`
  line `any, for payment of the claim being treated as an order for the refund of revenue.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (36230)
  sectionNo (13)
  orderNo 13
  title `Power of inspection.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36230&sectionno=13&orderno=13&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_13_content:
  string
  line `For the purposes of ascertaining whether any person claiming payment`
  line `under this Act is a shareholder, the Commissioner shall have the right to--`
  line
  line `(a) require any person, having the possession, custody or control, of any register or record of the`
  line `Company, to produce such register or record before the Commissioner,`
  line
  line `(b) require any person to make any statement or furnish any information which may be required`
  line `by the Commissioner.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (36231)
  sectionNo (14)
  orderNo 14
  title `Power of Commissioner to inquire into disputes as to amount.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36231&sectionno=14&orderno=14&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_14_content:
  string
  line `Where there is any dispute as`
  line `to the person or persons who are entitled to any amount payable under this Act (including any dispute as`
  line `to who are the legal representatives of any deceased claimant to the amount), the Commissioner may,`
  line `after making such inquiry as he may deem fit, make the payment to such person as appears to him to be`
  line `best entitled to receive the amount:`
  line
  line `Provided that if the Commissioner is unable to determine as to who is the person entitled to the`
  line `amount and considers that the matter could more appropriately be dealt with by the principal civil of`
  line `original jurisdiction within the local limits of whose jurisdiction the registered office of the Company is`
  line `situated, he may refer such dispute to the said court, whose decision thereon shall be final:`
  line
  line `Provided further that nothing contained herein shall affect the liability of any person, who may`
  line `receive the whole or any part of the amount allowed under this Act, to pay the same to the person lawfully`
  line `entitled thereto.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (36232)
  sectionNo (15)
  orderNo 15
  title `Deposit of amount in court.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36232&sectionno=15&orderno=15&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_15_content:
  string
  line `Where any dispute has been referred under section 14 by the`
  line `Commissioner to the civil court referred to therein, he shall deposit the amount in that court.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (36233)
  sectionNo (16)
  orderNo 16
  title `Act to have overriding effect.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36233&sectionno=16&orderno=16&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_16_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any law, other than this Act, or in any instrument having`
  line `effect by virtue of any law, other than this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (36234)
  sectionNo (17)
  orderNo 17
  title Penalties.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36234&sectionno=17&orderno=17&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_17_content:
  string
  line `If any person,--`
  line
  line `(a) makes any claim for any payment under this Act, knowing or having reason to believe that`
  line `such claim is false or without any basis; or`
  line
  line `(b) when required under this Act so to do,--`
  line
  line `(i) omits or fails to produce any register or record of the Company; or`
  line
  line `(ii) makes any statement of furnishes any information which is false in any material particular`
  line `and which he knows or believes to be false or does not believe to be true; or`
  line
  line `(c) makes any such statement as aforesaid in any book, account, record, register, return or other`
  line document,
  line
  line `he shall be punishable with imprisonment for a term which may extend to two years, or with fine which`
  line `may extend to two thousand rupees, or with both.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (36235)
  sectionNo (18)
  orderNo 18
  title `Offences by companies.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36235&sectionno=18&orderno=18&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_18_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who, at the time the offence was committed, was in charge of, and was`
  line `responsible to, the company for the conduct of the business of the company as well as the company, shall`
  line `be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed with the consent or connivance of, or is attributable to any neglect on the part of, any director,`
  line `manager, secretary or other officer, such director, manager, secretary or other officer shall be deemed to`
  line `be guilty of that offence and shall be liable to be proceeded against the punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (36236)
  sectionNo (19)
  orderNo 19
  title `Limitation of cognizance of offences.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36236&sectionno=19&orderno=19&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_19_content:
  string
  line `No court shall take cognizance of an offence punishable`
  line `under this Act, except with the previous sanction of the Central Government or of an officer authorised by`
  line `that Government in this behalf.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (36237)
  sectionNo (20)
  orderNo 20
  title `Power to make rules.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36237&sectionno=20&orderno=20&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_20_content:
  string
  line `(1) The Central Government may, by notification, make rules to carry`
  line `out the provisions of this Act.`
  line
  line `(2) Every rule made by the Central Government under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have affect only in such modified form or be no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (36238)
  sectionNo (21)
  orderNo 21
  title `Repeal and saving.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_20_25_00009_198129_1517807326125&sectionId=36238&sectionno=21&orderno=21&orgactid=AC_CEN_20_25_00009_198129_1517807326125
obj_root_law_sections_21_content:
  string
  line `(1) The British India Corporation (Acquisition of Shares) Ordinance, 1981`
  line `(5 of 1981), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the Ordinance so repealed`
  line `shall be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_21_footnotes:
  string
  line
