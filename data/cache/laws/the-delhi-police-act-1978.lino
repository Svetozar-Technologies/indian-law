obj_root_law_sections_1:
  sectionId (7224)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7224&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Delhi Police Act, 1978.`
  line
  line `(2) It extends to the whole of the Union territory of Delhi.`
  line
  line `(3) It shall be deemed to have come into force on the 1st day of July, 1978.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (7225)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7225&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Administrator" means the Administrator of Delhi appointed under article 239 of the`
  line Constitution;
  line
  line `(b) "cattle" includes elephants, camels, horses, asses, mules, sheep, goats and swine;`
  line
  line `(c) "competent authority", when used with reference to the exercise of any power or discharge of`
  line `any duty under the provisions of this Act, means the Commissioner of Police appointed under`
  line `section 6 or any other police officer specially empowered in that behalf by the Central Government;`
  line
  line `(d) "constable" means a police officer of the lowest grade;`
  line
  line `(e) "Corporation" means the Municipal Corporation of Delhi constituted under the Delhi`
  line `Municipal Corporation Act, 1957 (66 of 1957);`
  line
  line `(f) "Delhi" means the Union territory of Delhi;`
  line
  line `(g) "Delhi police" or "police force" means the police force referred to in section 3 and includes—`
  line
  line `(i) all persons appointed as special police officers under sub-section (1) of section 17 and`
  line `additional police officers appointed under section 18; and`
  line
  line `(ii) all other persons, by whatever name known, who exercise any police function in any part`
  line `of Delhi;`
  line
  line `(h) "eating house" means any place to which the public are admitted and where any kind of food`
  line `or drink is supplied for consumption on the premises by any person owning, or having any interest in,`
  line `or managing, such place and includes—`
  line
  line `(i) a refreshment room, boarding house or coffee house, or`
  line
  line `(ii) a shop where any kind of food or drink is supplied to the public for consumption in or`
  line `near such shop,`
  line
  line `but does not include a place of public entertainment;`
  line
  line `(i) "municipality" means the New Delhi Municipal Committee, the Cantonment Board or any`
  line `other municipal body, other than the Corporation, established by or under any law for the time being`
  line `in force in or in any part of Delhi;`
  line
  line `(j) "place" includes—`
  line
  line `(i) any building, tent, booth or other erection, whether permanent or temporary; and`
  line
  line `(ii) any area, whether enclosed or open;`
  line
  line `(k) "place of public amusement" means any place where music, singing, dancing or game or any`
  line `other amusement, diversion, or recreation or the means of carrying on the same is provided, to which`
  line `the public are admitted either on payment of money or with the intention that money may be collected`
  line `from those admitted and includes a race course, circus, theatre, music hall, billiard or bagatelle room,`
  line `gymnasium, fencing school, swimming pool or dancing hall;`
  line
  line `(l) "place of public entertainment" means a lodging house, boarding and lodging house or`
  line `residential hostel and includes any eating house or other place in which any kind of liquor or`
  line `intoxicating drug is supplied (such as a tavern or a shop where beer, spirit, arrack, toddy, ganja, bhang`
  line `or opium is supplied) to the public for consumption in or near such place;`
  line
  line `(m) "police officer" means any member of the Delhi police;`
  line
  line `(n) "prescribed" means prescribed by rules;`
  line
  line `(o) "public place" means any place to which the public have access, whether as of right or not,`
  line `and includes—`
  line
  line `(i) a public building and monument and precincts thereof; and`
  line
  line `(ii) any place accessible to the public for drawing water, washing or bathing or for purposes`
  line `of recreation;`
  line
  line `(p) "regulations" means regulations made under this Act;`
  line
  line `(q) "rules" means rules made under this Act;`
  line
  line `(r) "street" includes any highway, bridge, way over a causeway, viaduct or arch or any road, lane,`
  line `footway, square, court, alley or passage accessible to the public, whether or not it is a thoroughfare;`
  line
  line `(s) "subordinate ranks" means members of the police force of and below the rank of the`
  line Inspector;
  line
  line `(t) "vehicle" means any carriage, cart, van, dray, truck, handcart or other conveyance of any`
  line `description and includes a bicycle, tricycle, a rickshaw, a motor vehicle, a vessel or an aeroplane.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (7226)
  sectionNo (3)
  orderNo 3
  title `One police force for the whole of Delhi.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7226&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_3_content:
  string
  line `There shall be one police force for the whole of Delhi`
  line `and all officers and subordinate ranks of the police force shall be liable for posting to any branch of the`
  line `force including the Delhi Armed Police.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (7227)
  sectionNo (4)
  orderNo 4
  title `Superintendence of police force to vest in the Administrator.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7227&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_4_content:
  string
  line `The superintendence of the`
  line `Delhi police throughout Delhi shall vest in, and be exercisable by the Administrator and any control,`
  line `direction or supervision exercisable by any officer over any member of the police force shall be`
  line `exercisable subject to such superintendence.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (7228)
  sectionNo (5)
  orderNo 5
  title `Constitution of police force.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7228&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_5_content:
  string
  line `Subject to the provisions of this Act,—`
  line
  line `(a) the Delhi police shall consist of such number in the several ranks and have such organisation`
  line `and such powers, functions and duties as the Administrator may, by general or special order,`
  line `determine; and`
  line
  line `(b) the recruitment to, and the pay, allowances and all other conditions of service of the members`
  line `of, the Delhi police shall be such as may be prescribed:`
  line
  line `Provided that nothing in clause (b) shall apply to the recruitment to, and the pay, allowances and`
  line `other conditions of service of the members of the Indian Police Service or the Delhi, Andaman and`
  line `Nicobar Islands Police Service.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (7229)
  sectionNo (6)
  orderNo 6
  title `Commissioner of Police.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7229&sectionno=6&orderno=6&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_6_content:
  string
  line `For the direction and supervision of the police force in Delhi, the`
  line `Administrator shall appoint a Commissioner of Police who shall exercise and perform such powers and`
  line `duties and perform such functions as are specified by or under this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (7230)
  sectionNo (7)
  orderNo 7
  title `Additional Commissioner of Police.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7230&sectionno=7&orderno=7&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_7_content:
  string
  line `(1) The Administrator may appoint one or more Additional`
  line `Commissioners of Police for the purposes of this Act.`
  line
  line `(2) The Additional Commissioner of Police shall—`
  line
  line `(a) assist the Commissioner of Police in the exercise of his powers and the performance of his`
  line `duties in such manner and to such extent, and`
  line
  line `(b) exercise such powers and perform such duties of the Commissioner of Police and within such`
  line `local limits,`
  line
  line `as the Administrator may, by general or special order, specify.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (7231)
  sectionNo (8)
  orderNo 8
  title `Deputy, Additional Deputy and Assistant Commissioners of Police.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7231&sectionno=8&orderno=8&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_8_content:
  string
  line `(1) The Administrator`
  line `may appoint one or more Deputy Commissioners of Police or Additional Deputy Commissioners of`
  line `Police or Assistant Commissioners of Police for the purposes of this Act.`
  line
  line `(2) Without prejudice to the other provisions of this Act and subject to any general or special orders`
  line `made by the Administrator in this behalf, every Deputy Commissioner of Police or Additional Deputy`
  line `Commissioner of Police or Assistant Commissioner of Police shall, under the orders of the Commissioner`
  line `of Police, exercise such of the powers (except the power to make regulations) and perform such of the`
  line `duties of the Commissioner of Police and within such local limits as may be specified in such orders.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (7232)
  sectionNo (9)
  orderNo 9
  title `Appointment of Principals of Police training institutions.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7232&sectionno=9&orderno=9&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_9_content:
  string
  line `(1) (a) The Administrator shall`
  line `appoint a police officer not below the rank of a Deputy Commissioner of Police to be the Principal of the`
  line `Police Training School for Delhi.`
  line
  line `(b) The Commissioner of Police may by general or special order assign to the Principal of the Police`
  line `Training School such powers and duties as he may deem fit for the proper functioning of that School.`
  line
  line `(2) (a) The Administrator may establish a Police Training College for Delhi and appoint a police`
  line `officer of appropriate rank to be the Principal of such College.`
  line
  line `(b) The Commissioner of Police may by general or special order assign to the Principal of the Police`
  line `Training College such powers and duties as he may deem fit for the proper administration of that College.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (7233)
  sectionNo (10)
  orderNo 10
  title `Constitution of police districts, sub-divisions and police stations.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7233&sectionno=10&orderno=10&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_10_content:
  string
  line `Subject to the control of`
  line `the Administrator, the Commissioner of Police shall`
  line
  line `(a) constitute police districts within Delhi;`
  line
  line `(b) divide such police districts into police sub-divisions and specify the police stations comprised`
  line `in each such sub-division; and`
  line
  line `(c) define the limits and extent of such police districts, police sub-divisions and police stations.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (7234)
  sectionNo (11)
  orderNo 11
  title `Officers in charge of police districts, police sub-divisions and police stations.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7234&sectionno=11&orderno=11&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_11_content:
  string
  line `(1) Each`
  line `police district shall be under the charge of a Deputy Commissioner of Police who may be assisted in the`
  line `discharge of his duties by one or more Additional Deputy Commissioners of Police.`
  line
  line `(2) Each police sub-division shall be under the charge of an Assistant Commissioner of Police and`
  line `each police station shall be under the charge of an Inspector of Police.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (7235)
  sectionNo (12)
  orderNo 12
  title `Appointment of subordinate ranks.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7235&sectionno=12&orderno=12&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_12_content:
  string
  line `Subject to such general or special orders in writing as the`
  line `Administrator may make in this behalf,—`
  line
  line `(a) Inspectors of Police may be appointed by the Additional Commissioner of Police; and`
  line
  line `(b) Sub-Inspectors of Police and other officers of subordinate rank may be appointed by the`
  line `Deputy Commissioners of Police, Additional Deputy Commissioners of Police, Principal of the`
  line `Police Training College or of the Police Training School, or any other police officer of equivalent`
  line rank.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (7236)
  sectionNo (13)
  orderNo 13
  title `Certificate of appointment.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7236&sectionno=13&orderno=13&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_13_content:
  string
  line `(1) Every police officer of the rank of Inspector and below shall on`
  line `enrolment receive a certificate of appointment.`
  line
  line `(2) The certificate shall be issued under the seal of such officer, and shall be in such form, as the`
  line `Administrator may, by general or special order, specify.`
  line
  line `(3) A certificate of appointment shall become null and void when the person named therein ceases to`
  line `belong to the Delhi police or shall remain inoperative during the period such person is suspended from the`
  line `Delhi police.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (7237)
  sectionNo (14)
  orderNo 14
  title `Effect of suspension of police officer.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7237&sectionno=14&orderno=14&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_14_content:
  string
  line `The powers, functions and privileges vested in a police`
  line `officer shall remain suspended while such police officer is under suspension from office:`
  line
  line `Provided that notwithstanding such suspension such person shall not cease to be a police officer and`
  line `shall continue to be subject to the control of the same authorities to which he would have been subject if`
  line `he had not been under suspension.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (7238)
  sectionNo (15)
  orderNo 15
  title `General powers of Commissioner of Police.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7238&sectionno=15&orderno=15&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_15_content:
  string
  line `The Commissioner of Police shall direct and`
  line `regulate all matters of arms, drill, exercise, observation of persons and events, mutual relations,`
  line `distribution of duties, study of laws, orders and modes of proceedings and all matters of executive detail`
  line `or the fulfilment of their duties by the police force under him.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (7239)
  sectionNo (16)
  orderNo 16
  title `Power of Commissioner of Police to investigate and regulate matters of police accounts.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7239&sectionno=16&orderno=16&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_16_content:
  string
  line `The Commissioner of Police shall have the authority to investigate and regulate all matters of account`
  line `connected with the Delhi police and all persons concerned shall be bound to give him reasonable aid and`
  line `facilities in conducting such investigations and to conform to his orders consequent thereto.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (7240)
  sectionNo (17)
  orderNo 17
  title `Special police officers.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7240&sectionno=17&orderno=17&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_17_content:
  string
  line `(1) The Commissioner of Police may, at any time, by a written order,`
  line `signed by himself and sealed with his own seal, appoint any able bodied male person not less than`
  line `eighteen years of age, whom he considers fit, to be a special police officer to assist the Delhi police on`
  line `any occasion, when he has reason to apprehend the occurrence of any riot or grave disturbance of the`
  line `peace in any area and he is of opinion that the ordinary police force is not sufficient for the protection of`
  line `persons residing, and for the security of property, within such area.`
  line
  line `(2) The Commissioner of Police shall publish the names of special police officers appointed under`
  line `this section in such manner as may be prescribed.`
  line
  line `(3) Any person objecting to the appointment of any person as such special police officer may send his`
  line `reasons for such objection to the Commissioner of Police within fifteen days of such appointment and the`
  line `Commissioner may accept such objection and cancel the appointment of such officer or, after giving to`
  line `the objector an opportunity to be heard, reject the objection.`
  line
  line `(4) Every special police officer appointed under this section shall, on appointment,—`
  line
  line `(a) receive a certificate of appointment in such form as may be specified by the Administrator in`
  line `this behalf;`
  line
  line `(b) have the same powers, privileges and immunities and perform the same duties and be subject`
  line `to the same authorities as an ordinary police officer.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (7241)
  sectionNo (18)
  orderNo 18
  title `Additional police officers.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7241&sectionno=18&orderno=18&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_18_content:
  string
  line `Where additional police officers are required to be deputed under`
  line `section 38, section 39 or section 40 the Commissioner of Police may appoint such number of additional`
  line `police officers as he considers necessary and every such additional police officer shall, on appointment,—`
  line
  line `(a) receive a certificate of appointment in such form as may be specified by the Administrator in`
  line `this behalf;`
  line
  line `(b) have such of the powers, privileges and immunities and perform such of the duties of a police`
  line `officer as are specifically mentioned in the certificate; and`
  line
  line `(c) be subject to the same authorities as an ordinary police officer of the same or similar rank or`
  line grade.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (7242)
  sectionNo (19)
  orderNo 19
  title `Framing of regulations for administration of the police.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7242&sectionno=19&orderno=19&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_19_content:
  string
  line `Subject to the orders of the`
  line `Administrator, the Commissioner of Police may make regulations not inconsistent with this Act or any`
  line `other law for the time being in force`
  line
  line `(a) regulating the inspection of the police force by his subordinates;`
  line
  line `(b) determining the description and quantity of arms, accoutrements, clothing and other`
  line `necessaries to be furnished to the police;`
  line
  line `(c) prescribing the places of residence of members of the police force;`
  line
  line `(d) for institution, management and regulation of any police fund for any purpose connected with`
  line `police administration;`
  line
  line `(e) regulating the distribution, movements and location of the police;`
  line
  line `(f) assigning duties to police officers of all ranks and grades, and prescribing the manner in`
  line `which, and the conditions subject to which they shall exercise and perform their respective powers`
  line `and duties;`
  line
  line `(g) regulating the collection and communication by the police of intelligence and information;`
  line
  line `(h) generally, for the purpose of rendering the police efficient and preventing abuse or neglect of`
  line `their duties.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (7243)
  sectionNo (20)
  orderNo 20
  title `Commissioner of Police may call for returns.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7243&sectionno=20&orderno=20&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_20_content:
  string
  line `The Commissioner of Police may call for such`
  line `returns, reports and statements on any subject connected with the prevention and detection of crime, the`
  line `maintenance of order and the performance of the duties of his subordinates as such subordinates may be`
  line `able to furnish to him.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (7244)
  sectionNo (21)
  orderNo 21
  title `Powers of punishment.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7244&sectionno=21&orderno=21&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_21_content:
  string
  line `(1) Subject to the provisions of article 311 of the Constitution and the`
  line `rules, the Commissioner of Police, Additional Commissioner of Police, Deputy Commissioner of Police,`
  line `Additional Deputy Commissioner of Police, Principal of the Police Training College or of the Police`
  line `Training School or any other officer of equivalent rank, may award to any police officer of subordinate`
  line `rank any of the following punishments, namely:—`
  line
  line `(a) dismissal;`
  line
  line `(b) removal from service;`
  line
  line `(c) reduction in rank;`
  line
  line `(d) forfeiture of approved service;`
  line
  line `(e) reduction in pay;`
  line
  line `(f) withholding of increment; and`
  line
  line `(g) fine not exceeding one months pay.`
  line
  line `(2) Subject to the rules—`
  line
  line `(a) any police officer specified in sub-section (1) may award the punishment of censure to any`
  line `police officer of subordinate rank;`
  line
  line `(b) the Assistant Commissioner of Police may award the punishment of censure to police officers`
  line `of, or below, the rank of Sub-Inspectors of Police;`
  line
  line `(c) any police officer of, and above, the rank of Inspector may award punishment drill not`
  line `exceeding fifteen days or fatigue duty or any other punitive duty to constables.`
  line
  line `(3) Nothing in sub-section (1) or sub-section (2) shall affect any police officers liability for`
  line `prosecution and punishment for any offence committed by him.`
  line
  line `(4) The Commissioner of Police, Additional Commissioner of Police, Deputy Commissioner of`
  line `Police, Additional Deputy Commissioner of Police, Principal of the Police Training College or of the`
  line `Police Training School, Assistant Commissioner of Police, or any other police officer of equivalent rank`
  line `may suspend any police officer of subordinate rank who is reasonably suspected to be guilty of`
  line `misconduct, pending an investigation or enquiry into such misconduct.`
  line
  line `(5) An Inspector of Police may suspend any police officer below the rank of Sub-Inspector of Police,`
  line `who is reasonably suspected to be guilty of misconduct, pending an investigation or enquiry into such`
  line misconduct.
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (7245)
  sectionNo (22)
  orderNo 22
  title `Procedure for awarding punishments.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7245&sectionno=22&orderno=22&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_22_content:
  string
  line `When any officer passes an order of awarding a`
  line `punishment of dismissal, removal from service, reduction in rank, forfeiture of service, reduction in pay,`
  line `withholding of increments or fine, he shall record such order or cause the same to be recorded together`
  line `with the reasons therefor, in accordance with the rules.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (7246)
  sectionNo (23)
  orderNo 23
  title `Appeal from orders of punishment.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7246&sectionno=23&orderno=23&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_23_content:
  string
  line `An appeal against any order of punishment passed against`
  line `a police officer under section 21 or the rules thereunder not being an order of punishment under`
  line `clause(c) of sub-section (2) of that section shall lie—`
  line
  line `(a) where the order is passed by the Commissioner of Police, to the Administrator;`
  line
  line `(b) where the order is passed by an Additional Commissioner of Police, to the Commissioner of`
  line Police;
  line
  line `(c) where the order is passed by a Deputy Commissioner of Police, Additional Deputy`
  line `Commissioner of Police, Principal of the Police Training College or School, Assistant Commissioner`
  line `of Police or any other officer of equivalent rank, to the Additional Commissioner of Police.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (7247)
  sectionNo (24)
  orderNo 24
  title `Police officers to be deemed to be always on duty and to be liable to employment in any part of Delhi.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7247&sectionno=24&orderno=24&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_24_content:
  string
  line `Every police officer not on leave or under suspension shall for all purposes of this Act be`
  line `deemed to be always on duty and any police officer or any number or body of police officers allocated for`
  line `duty in any part of Delhi may, if the Commissioner of Police so directs, at any time, be employed on`
  line `police duty in any other part of Delhi for so long as the services of the police officer or number or body of`
  line `police officers may be required in such other part of Delhi.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (7248)
  sectionNo (25)
  orderNo 25
  title `Circumstances under which police officer of subordinate rank may resign.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7248&sectionno=25&orderno=25&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_25_content:
  string
  line `(1) Resignation`
  line `of any police officer of subordinate rank may be accepted only by the officer empowered to appoint (the`
  line `officer so empowered to appoint being hereafter in this section referred to as the appointing authority)`
  line `officers of such subordinate rank.`
  line
  line `(2) A police officer of subordinate rank who intends to resign from police service shall give to the`
  line `appointing authority notice in writing to that effect and shall not be permitted to withdraw himself from`
  line `duty unless he has been granted permission to resign by such authority and two months have elapsed from`
  line `the date on which he tendered his resignation:`
  line
  line `Provided that the appointing authority may at his discretion, permit a Head Constable or a constable`
  line `to withdraw himself from duty on his crediting to the Government two months pay in lieu of notice.`
  line
  line `(3) A Head Constable or a constable who has agreed to serve for any specific period may not be`
  line `permitted to resign before the expiry of that period.`
  line
  line `(4) Inspectors, Sub-Inspectors or Assistant Sub-Inspectors of Police, whose appointments involve`
  line `training at any Police Training College or Police Training School may not be permitted to resign within`
  line `three years from the date of their successfully completing the training.`
  line
  line `(5) No police officer of subordinate rank whose resignation has been accepted by the appointing`
  line `authority shall be permitted to withdraw from duty until he has fully discharged all debts, due from him as`
  line `such police officer to Government or to any police fund and has surrendered his certificate of appointment, arms, accoutrements, uniform and all other Government property in his possession and has`
  line `also rendered a complete account of all Government money and property for which he is responsible.`
  line
  line `(6) Notwithstanding anything contained in this section if any police officer of subordinate rank`
  line `tenders his resignation on medical grounds and produces a certificate signed by the police surgeon or any`
  line `other medical officer authorised by the Administrator in this behalf declaring him to be unfit by reason of`
  line `disease or mental or physical incapacity for further service in the police, the appointing authority shall`
  line `forthwith permit him to withdraw from duty on his discharging, or giving a satisfactory security for the`
  line `payment of, any debt due from him as such police officer to Government or to any police fund:`
  line
  line `Provided that he shall forthwith return the certificate of appointment, arms, accoutrements, uniform`
  line `and all other Government property in his possession before he is permitted to withdraw from duty.`
  line
  line `(7) If any such police officer of subordinate rank resigns or withdraws himself from the duties of his`
  line `office in contravention of this section, he shall be liable on the orders of the appointing authority to forfeit`
  line `all arrears of pay then due to him in addition to the penalty to which he may be liable under section 22 or`
  line `any other law for the time being in force.`
  line
  line `(8) Every such police officer on leaving the service in the Delhi police as aforesaid shall be given by`
  line `the appointing authority a Discharge Certificate in such form as may be prescribed.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (7249)
  sectionNo (26)
  orderNo 26
  title `Certificate, arms, etc., to be delivered by person ceasing to be a police officer.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7249&sectionno=26&orderno=26&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_26_content:
  string
  line `(1) Every`
  line `person who for any reason ceases to be a police officer shall forthwith deliver to the officer empowered`
  line `by the Commissioner of Police, the Additional Commissioner of Police, Deputy Commissioner of Police,`
  line `Principal of the Police Training College or of the Police Training School, Additional Deputy`
  line `Commissioner of Police or any other officer of equivalent rank to whom such officer is subordinate, to`
  line `receive the same, his certificate of appointment and the arms, accoutrements, clothing and other`
  line `accessories which have been provided to him for the performance of duties and functions connected with`
  line `his office.`
  line
  line `(2) (a) Any Metropolitan Magistrate and, for special reasons which shall be recorded in writing at the`
  line `time, the Commissioner of Police, Additional Commissioner of Police, Principal of the Police Training`
  line `College or of the Police Training School or a Deputy Commissioner, Additional Deputy Commissioner or`
  line `an Assistant Commissioner of Police may issue a warrant to search for and seize wherever they be found,`
  line `any certificate, arms, accoutrements, clothing or other accessories not delivered under sub-section (1).`
  line
  line `(b) Every warrant so issued shall be executed by a police officer or, if the Metropolitan Magistrate or`
  line `the police officer issuing the warrant so directs, by any other person in the same manner as if it were a`
  line `warrant for a search issued under the Code of Criminal Procedure, 1973 (2 of 1974).`
  line
  line `(3) Nothing in this section shall apply in relation to any article which under the orders of the`
  line `Commissioner of Police has become the property of the person to whom the same was provided.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (7250)
  sectionNo (27)
  orderNo 27
  title `Occupation of, and liability to vacate, premises provided for police officers.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7250&sectionno=27&orderno=27&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_27_content:
  string
  line `(1) A police`
  line `officer occupying any premises provided by the Commissioner of Police for his residence shall—`
  line
  line `(a) occupy the same subject to such terms and conditions as may, by general or special order, be`
  line `specified by the Commissioner of Police; and`
  line
  line `(b) notwithstanding anything contained in any law for the time being in force, vacate the same on`
  line `his ceasing to be a police officer or whenever the Commissioner of Police or any officer authorised by`
  line `the Administrator in this behalf considers it, for reasons to be recorded in writing, necessary and`
  line `expedient to require him to do so.`
  line
  line `(2) If any person who is bound or required under sub-section (1) to vacate any premises fails to do so,`
  line `the Administrator or the officer authorised in this behalf by the Administrator may order such person to`
  line `vacate the premises and may direct any police officer with such assistance as may be necessary to enter`
  line `upon the premises and remove therefrom any person found therein and to take possession of the premises`
  line `and deliver the same to any person specified in the direction.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (7251)
  sectionNo (28)
  orderNo 28
  title `Power to make regulations for regulating traffic and for preservation of order in public places, etc.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7251&sectionno=28&orderno=28&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_28_content:
  string
  line `(1) The Commissioner of Police may, by notification in the Official Gazette, make`
  line `regulations to provide for all or any of the following matters, namely:`
  line
  line `(a) licensing and controlling persons offering themselves for employment, outside railway`
  line `stations and other places where passengers arrive, for the carriage of passengers baggages and fixing`
  line `and providing for the enforcement of a scale of charges for the labour of such persons so employed;`
  line
  line `(b) regulating traffic of all kinds in streets and other public places, and the use of streets and other`
  line `public places by persons riding, driving, cycling, walking or leading or accompanying cattle, so as to`
  line `prevent danger, obstruction or inconvenience to the public;`
  line
  line `(c) regulating the conditions under which vehicles may remain standing in streets and other public`
  line `places, and the use of streets as halting places for vehicles or cattle;`
  line
  line `(d) specifying the number and position of lights to be used on vehicles in streets and the hours`
  line `between which such lights should be used;`
  line
  line `(e) licensing, controlling or prohibiting the erection, exhibition, fixation or retention of any sign,`
  line `device or representation for the purpose of advertisement, which is visible against the sky from some`
  line `point in any street and is hoisted or held aloft over any land, building or structure at such height as`
  line `may be specified in the regulations, having regard to the traffic in the vicinity, and the likelihood of`
  line `such sign, device or representation at that height being a distraction, or causing obstruction, to such`
  line traffic;
  line
  line `(f) specifying certain hours of the day during which cattle shall not be driven, or, as the case may`
  line `be, driven only in accordance with such regulations, along the streets, or along certain specified`
  line streets;
  line
  line `(g) regulating the leading, driving, conducting or conveying of any elephant or wild or dangerous`
  line `animal through or in any street;`
  line
  line `(h) regulating and controlling the manner and mode of conveying timber, scaffold poles, ladders,`
  line `iron girders, beams or bars, boilers or other unwieldy articles through the streets, and the route and`
  line `hours for such conveyance;`
  line
  line `(i) licensing, controlling or, in order to prevent obstruction, inconvenience, annoyance, risk,`
  line `danger or damage to the residents or passengers in the vicinity, prohibiting the carrying in streets and`
  line `public places of gunpowder or any other explosive substance;`
  line
  line `(j) prohibiting, except along certain specified streets and during specified hours and subject to`
  line `such conditions as may be specified in that behalf, the exposure or movement in any street of persons`
  line `or animals suffering from contagious or infectious diseases, the carcasses of animals or parts of such`
  line `carcasses or corpses of persons deceased;`
  line
  line `(k) specifying certain hours of the day during which ordure or offensive matter or objects shall`
  line `not be taken from or into houses or buildings in certain streets or conveyed through such streets`
  line `except in accordance with such regulations;`
  line
  line `(l) setting apart places for slaughtering animals, the cleaning of carcasses or hides, the deposit of`
  line `noxious or offensive matter and for obeying calls of nature;`
  line
  line `(m) in cases of existing or apprehended epidemic or infectious disease of men or animals, the`
  line `cleanliness and disinfection of premises by the occupier thereof and residents therein and the`
  line `segregation and management of the persons or animals diseased or supposed to be diseased, as may`
  line `have been directed or approved by the Administrator, with a view to prevent the disease or check the`
  line `spread thereof;`
  line
  line `(n) directing the closing or disuse, wholly or for certain purposes, or limiting to certain purposes`
  line `only, the use of any source, supply or receptacle of water and providing against pollution of the same`
  line `or of the water therein;`
  line
  line `(o) licensing, controlling or, in order to prevent obstruction, inconvenience, annoyance, risk,`
  line `danger or damage to the residents or passengers in the vicinity, prohibiting the playing of music, the`
  line `beating of drums, tom-toms or other instruments and the blowing or sounding of horns or other noisy`
  line `instruments in or near streets or other public places;`
  line
  line `(p) regulating the conduct of or behaviour or action of persons constituting assemblies and`
  line `processions on or along the streets and specifying in the case of processions, the routes by which, the`
  line `order in which, and the times at which, the same may pass;`
  line
  line `(q) prohibiting the hanging or placing of any cord or pole across a street or part thereof, or the`
  line `making of a projection or structure so as to obstruct traffic or the free access of light and air;`
  line
  line `(r) prohibiting, except in accordance with such regulations, the placing of building materials or`
  line `other articles or the fastening or detention of any horse or other animals in any street or public place;`
  line
  line `(s) licensing, controlling or, in order to prevent obstruction, inconvenience, annoyance, risk,`
  line `danger or damage to the residents or passengers in the vicinity, prohibiting`
  line
  line `(i) the illumination of streets and public places and the exteriors of building abutting thereon`
  line `by persons other than servants of Government or Corporation or other Municipal officers duly`
  line `authorised in that behalf,`
  line
  line `(ii) the blasting of rock or making excavations in or near streets or public places,`
  line
  line `(iii) the using of loudspeaker in or near any public place or in any place of public`
  line entertainment;
  line
  line `(t) closing certain streets or places temporarily, in cases of danger from ruinous buildings or other`
  line `cause, with such exceptions as shall appear reasonable;`
  line
  line `(u) guarding against injury to person and property in the construction, repair and demolition of`
  line `buildings, platforms and other structures from which danger may arise to passengers, neighbours or`
  line `the public;`
  line
  line `(v) prohibiting the setting of fire to or burning of any straw or other matter, or lighting a bonfire`
  line `or wantonly discharging a fire-arm or air-gun, or letting off or throwing a fire work or, sending up a`
  line `fire balloon or rocket in or upon a street or within fifty feet of a street or building or the putting up of`
  line `any post or other thing on the side of or across a street for the purpose of affixing thereto lamps or`
  line `other contrivances for illumination except in accordance with regulations in this behalf;`
  line
  line `(w) regulating the hours during which and the manner in which any place for the disposal of the`
  line `dead, any dharmashala, village-gate or other place of public resort may be used, so as to secure the`
  line `equal and appropriate application of its advantages and accommodation and to maintain orderly`
  line `conduct amongst those who resort thereto;`
  line
  line `(x) (i) licensing or controlling places of public amusement or public entertainment;`
  line
  line `(ii) prohibiting the keeping of places of public amusement or public entertainment or assembly, in`
  line `order to prevent obstruction, inconvenience, annoyance, risk, danger or damage to the residents or`
  line `passengers in the vicinity; and`
  line
  line `(iii) regulating the means of entrance and exit at places of public amusement or public`
  line `entertainment or assembly and providing for the maintenance of public order and the prevention of`
  line `disturbance thereat;`
  line
  line `(y) (i) licensing or controlling in the interest of public order, decency or morality or in the interest`
  line `of the general public (with such exceptions as may be specified in such regulations), musical,`
  line `dancing, mimetic or theatrical or other performances for public amusement, including melas;`
  line
  line `(ii) regulating in the interest of public order, decency or morality or in the interest of the general`
  line `public, the employment of artists and the conduct of the artists and the audience at such`
  line performances;
  line
  line `(iii) prior scrutiny of such performance and of the scripts in respect thereof, if any, and granting`
  line `of suitability certificate therefor subject to conditions, if any, by a Board appointed by the`
  line `Administrator for the purpose, either for the whole of Delhi or for the area concerned or by an`
  line `Advisory Committee constituted by the Commissioner of Police (the members of the Board or the`
  line `Advisory Committee being persons who in the opinion of the Administrator or, as the case may be,`
  line `the Commissioner, possess knowledge of, or experience in, literature, the theatre and other matters`
  line `relevant to such scrutiny), provision for appeal against the order or decision of the Board or the`
  line `Advisory Committee to an appellate authority, its appointment or constitution, its procedure and other`
  line `matters ancillary thereto, and the fees (whether in the form of court-fee stamps or otherwise) to be`
  line `charged for the scrutiny of such performances or scripts, for applications for obtaining such`
  line `certificates and for issuing duplicates thereof and in respect of such appeals and any such`
  line `performances and of the scripts in respect thereof granted suitability certificate by any State shall be`
  line `exempted from this section;`
  line
  line `(iv) regulating the hours during which and the places at which such performances may be given;`
  line
  line `(z) regulating or prohibiting the sale of any ticket or pass for admission, by whatever name called,`
  line `to a place of public amusement;`
  line
  line `(za) registration of eating houses, including granting a certificate of registration in each case,`
  line `which shall be deemed to be a written permission required and obtained under this Act for keeping`
  line `the eating house, and annual renewal of such registration within a specified period;`
  line
  line `(zb) prescribing the procedure in accordance with which any licence or permission sought to be`
  line `obtained or required under this Act should be applied for and fixing the fees to be charged for any`
  line `such licence or permission:`
  line
  line `Provided that nothing in this section and no licence or certificate of registration granted under any`
  line `regulation made thereunder shall authorise any person to import, export, transport, manufacture, sell or`
  line `possess any liquor, or intoxicating drug, in respect of which a licence, permit, pass or authorisation is`
  line `required under any law relating to prohibition which is for the time being in force.`
  line
  line `(2) The power to make regulations under clause (b) of sub-section (1) shall be subject to the control`
  line `of the Administrator and the power to make regulations under the other clauses of that sub-section shall`
  line `be subject to the previous sanction of the Administrator.`
  line
  line `(3) The power of making regulations under this section shall be subject to the condition of the`
  line `regulations being made, after previous publication and for the purposes of section 23 of the General`
  line `Clauses Act, 1897 (10 of 1897) such regulations shall be deemed to be rules; and every regulation made,`
  line `under this section, shall also be published in the locality affected thereby by affixing copies thereof in`
  line `conspicuous places near to the building, structure, work or place, as the case may be, to which the same`
  line `specially relates or by proclaiming the same by the beating of drum or by advertising the same in such`
  line `local newspapers in Hindi, Urdu and English, or in two or more of these languages, as the Commissioner`
  line `of Police may deem fit, or by any two or more of these means, or by any other means he may think`
  line `suitable:`
  line
  line `Provided that any such regulation may be made without previous publication if the Commissioner of`
  line `Police is satisfied that circumstances exist which render it necessary that such regulation should be`
  line `brought into force at once.`
  line
  line `(4) If any regulation made under this section relates to any matter with respect to which there is a`
  line `provision in any law, rule or bye-law of the Corporation or of any other municipal or local authority in`
  line `relation to public health, convenience or safety of the locality such regulation shall be subject to such law,`
  line `rule or bye-law.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (7252)
  sectionNo (29)
  orderNo 29
  title `Power to give directions to the public.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7252&sectionno=29&orderno=29&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_29_content:
  string
  line `The Commissioner of Police and, subject to the orders,`
  line `if any, made by the Commissioner of Police, every police officer not inferior in rank to an Inspector, may`
  line `from time to time as occasion may arise, but not so as to contravene any regulation made under section 28`
  line `or any law, rule, or bye-law referred to in sub-section (4) of that section, give all such orders either orally`
  line `or in writing as may be necessary to—`
  line
  line `(a) direct the conduct of, and behaviour or action of persons constituting processions or`
  line `assemblies on or along streets;`
  line
  line `(b) specify the routes by which and the times at which any such processions may pass or shall not`
  line pass;
  line
  line `(c) prevent obstructions—`
  line
  line `(i) on the occasion of all processions and assemblies; and`
  line
  line `(ii) in the neighbourhood of all places of worship during the time of worship; and`
  line
  line `(iii) in all cases when any street or public place or place of public resort may be thronged or`
  line `liable to be obstructed;`
  line
  line `(d) keep order on, and in, all streets, and at, and within, public bathing and washing places, fairs,`
  line `temples, mosques, gurdwaras, churches and all other places of public resort or public worship;`
  line
  line `(e) regulate and control the playing of music, singing or the beating of drums, tom-toms and other`
  line `instruments and the blowing or sounding of horns or other noisy instruments in, and near, any street`
  line `or public place;`
  line
  line `(f) regulate and control the use of loudspeakers in residential areas, streets, near any public places`
  line `and places of public amusement or public entertainment; or`
  line
  line `(g) make reasonable orders consequential to, and in furtherance of, any order made under this`
  line section.
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (7253)
  sectionNo (30)
  orderNo 30
  title `Power to prohibit certain acts for prevention of disorder.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7253&sectionno=30&orderno=30&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_30_content:
  string
  line `(1) The Commissioner of Police`
  line `may, whenever and for such time as he shall consider necessary for the preservation of public peace or`
  line `public safety, by notification publicly promulgated or addressed to individuals, prohibit, in relation to the`
  line `whole of Delhi or any part thereof,—`
  line
  line `(a) the carrying of arms, cudgels, swords, spears, bludgeons, guns, knives, sticks or lathis, or any`
  line `other article, which is capable of being used for causing physical violence;`
  line
  line `(b) the carrying of any corrosive substance or explosives;`
  line
  line `(c) the carrying, collection or preparation of stones or other missiles or instruments or means of`
  line `casting or impelling missiles;`
  line
  line `(d) the exhibition of persons or corpses;`
  line
  line `(e) the public utterance of cries, singing of songs or playing of music; or`
  line
  line `(f) the delivery of harangues, the use of gestures or mimetic representations, and the preparation,`
  line `exhibition or dissemination of pictures, symbols, placards or any other subject or thing which may, in`
  line `the opinion of the Commissioner of Police, offend against decency or morality or undermine the`
  line `security of the State.`
  line
  line `(2) If any person goes armed with any such article as is referred to in clause (a) of sub-section (1) or`
  line `carries any corrosive substance or explosive or missile or instrument in contravention of any prohibition`
  line `under that sub-section, the article, corrosive substance or explosive or missile shall be liable to be seized`
  line `from him by any police officer.`
  line
  line `(3) The Commissioner of Police may, by notification publicly promulgated, prohibit any assembly or`
  line `procession whenever and for such time as he considers such prohibition to be necessary for the`
  line `preservation of the public order.`
  line
  line `(4) No notification promulgated under sub-section (3) shall remain in force for more than fifteen days`
  line `from the promulgation thereof:`
  line
  line `Provided that if the Administrator considers it necessary so to do for the preservation of the public`
  line `order, he may, by order published in the Official Gazette, direct that such notification shall remain in`
  line `force for such further period not exceeding six months from the date on which it would have, but for such`
  line `order, expired as he may specify in the said order.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (7254)
  sectionNo (31)
  orderNo 31
  title `Police to provide against disorder, etc., at places of public amusement or public assembly or meeting.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7254&sectionno=31&orderno=31&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_31_content:
  string
  line `(1) For the purpose of preventing serious disorder or breach of the law or manifest and`
  line `imminent danger to the persons assembled at any place of public amusement or at any assembly or`
  line `meeting to which the public are invited or which is open to the public, any police officer of the rank of`
  line `Assistant Sub-Inspector and above, present at such place of public amusement, or such assembly or`
  line `meeting, may subject to such rules, regulations and orders as may have been lawfully made, give such`
  line `reasonable directions as to the mode of admission of the public to, and for securing the peaceful and`
  line `lawful conduct of the proceedings and the maintenance of the public safety at, such place of amusement`
  line `or such assembly or meeting as he thinks necessary and all persons shall be bound to conform to every`
  line `such reasonable direction.`
  line
  line `(2) Every police officer shall have free access to every place of public amusement, assembly or`
  line `meeting for the purpose of giving effect to the provisions of sub-section (1) and to any direction made`
  line thereunder.
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (7255)
  sectionNo (32)
  orderNo 32
  title `Power to prohibit, etc., continuance of music, sound or noise.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7255&sectionno=32&orderno=32&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_32_content:
  string
  line `(1) If the Commissioner of`
  line `Police is satisfied from the report of an officer in charge of a Police Station, or other information received`
  line `by him, that it is necessary to do so in order to prevent annoyance, disturbance, discomfort or injury, or`
  line `risk of annoyance, disturbance, discomfort or injury, to the public or to any person who dwells, or`
  line `occupies property, in the vicinity, he may, by written order, issue such directions as he may consider`
  line `necessary to any person for preventing, prohibiting, controlling or regulating—`
  line
  line `(a) the incidence or continuance in any street, open space or any other premises of—`
  line
  line `(i) any vocal or instrumental music;`
  line
  line `(ii) sounds caused by the playing, beating, clashing, blowing or use in any manner`
  line `whatsoever of any instrument, appliance or apparatus or contrivance which is capable of`
  line `producing or reproducing sound; or`
  line
  line `(iii) use of loudspeaker or other apparatus for amplifying any musical or other sound at such`
  line `pitch or volume as may cause disturbance to others, or`
  line
  line `(b) the carrying on, in any premises, of any trade, avocation or operation resulting in or attended`
  line `with noise:`
  line
  line `Provided that no directions shall be issued to any person under clause (b) without giving to such`
  line `person an opportunity of being heard in the matter.`
  line
  line `(2) The Commissioner of Police may, either on his own motion or on the application of any person`
  line `aggrieved by an order made under sub-section (1), either rescind, modify or alter any such order:`
  line
  line `Provided that before any such application is disposed of, the Commissioner of Police shall afford to`
  line `the applicant an opportunity of appearing, before him either in person or by counsel and showing cause`
  line `against the order and shall, if he rejects any such application either wholly or in part, record the reasons`
  line `for such rejection.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (7256)
  sectionNo (33)
  orderNo 33
  title `Issue of order of prevention of riot, etc.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7256&sectionno=33&orderno=33&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_33_content:
  string
  line `(1) In order to prevent or suppress any riot or grave`
  line `disturbance of peace, the Commissioner of Police may temporarily close or take possession of any`
  line `building or other place and may exclude all or any persons therefrom, or may allow access thereto to such`
  line `persons only and on such terms as he shall deem expedient and all persons concerned shall be bound to`
  line `conduct themselves in accordance with such orders as the Commissioner of Police may make and notify`
  line `in exercise of his powers under this section.`
  line
  line `(2) If the lawful occupant of such building or place suffers any loss or injury by reason of the action`
  line `taken under sub-section (1), he shall be entitled, on an application made therefor to the competent`
  line `authority within one month from the date of such action, to receive reasonable compensation for such loss`
  line `or injury, unless such action was in the opinion of such competent authority rendered necessary either by`
  line `the use to which such building or place was put, or intended to be put, or by the misconduct of persons`
  line `having access thereto.`
  line
  line `(3) In the event of any dispute in relation to the amount of compensation payable under`
  line `sub-section (2) or the person to whom such amount shall be payable, the matter shall be referred by the`
  line `competent authority to the District Collector whose decision thereon shall be final.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (7257)
  sectionNo (34)
  orderNo 34
  title `Maintenance of order at religious or ceremonial display, etc.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7257&sectionno=34&orderno=34&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_34_content:
  string
  line `(1) In any case of an actual or`
  line `intended religious or ceremonial or corporate display or exhibition or organised assemblage in any street`
  line `or public place, as to which or the conduct of, or participation in, which, it shall appear to the competent`
  line `authority that a dispute or contention exists, which is likely to lead to grave disturbance of the peace, the`
  line `competent authority may give such orders as to the conduct of the persons concerned towards each other`
  line `and towards the public as it shall deem necessary and reasonable under the circumstances, regard being`
  line `had to the apparent legal rights and to any established practice of the parties and of the persons interested`
  line `and all persons concerned shall obey such orders.`
  line
  line `(2) Every such order shall be published in the locality or place wherein it is to operate.`
  line
  line `(3) Every order under sub-section (1) shall be subject to any judgment, decree, injunction or order`
  line `made by a court having jurisdiction, and shall be rescinded or altered on its being made to appear to the`
  line `competent authority that such order is inconsistent with a judgment, decree, injunction or order of such`
  line court.
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (7258)
  sectionNo (35)
  orderNo 35
  title `Commissioner of Police may take special measures to prevent outbreak of epidemic disease at fairs, etc.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7258&sectionno=35&orderno=35&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_35_content:
  string
  line `(1) Whenever it shall appear to the Commissioner of Police that any place in Delhi (being`
  line `a place where on account of a pilgrimage, fair or other such occurrence, large bodies of persons have`
  line `assembled or are likely to assemble) is visited or likely to be visited with an outbreak of any epidemic`
  line `disease, he may in consultation with the Corporation or municipality within the local limits of the`
  line `jurisdiction whereof such place is situated take such special measures and may by a public notice`
  line `prescribe such regulations to be observed by residents of the said place and persons present thereat or`
  line `repairing thereto or returning therefrom as he deems necessary to prevent the outbreak of such disease or`
  line `the spread thereof.`
  line
  line `(2) The expenses incurred by the Commissioner of Police in respect of the arrangements for sanitation and the preservation of order at or about the place of assembly referred to in sub-section (1) may be recovered from the Corporation or the municipality concerned.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (7259)
  sectionNo (36)
  orderNo 36
  title `Power to reserve street or other public place for public purpose and power to authorise erecting of barriers in streets.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7259&sectionno=36&orderno=36&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_36_content:
  string
  line `(1) The Commissioner of Police may, by public notice, temporarily`
  line `reserve for any public purpose any street or other public place and prohibit persons from entering the area`
  line `so reserved, except on such conditions as may be specified by him.`
  line
  line `(2) The Commissioner of Police may, whenever in his opinion such action is necessary,—`
  line
  line `(a) authorise such police officer as he thinks fit to erect barriers on any street for the purpose of`
  line `stopping temporarily vehicles driven on such street so as to satisfy himself that the provisions of any`
  line `law for the time being in force have not been contravened in respect of any such vehicle or by the`
  line `driver or the person in charge of such vehicle; and`
  line
  line `(b) make such orders as he deems fit for regulating the use of such barriers.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (7260)
  sectionNo (37)
  orderNo 37
  title `Power to make regulations prohibiting disposal of the dead except at places set apart.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7260&sectionno=37&orderno=37&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_37_content:
  string
  line `(1)`
  line `The Commissioner of Police may, from time to time, make regulations prohibiting the disposal of the`
  line `dead, whether by cremation, burial or otherwise at places other than those set apart for such purpose:`
  line
  line `Provided that no such regulations shall be made in respect of any area for which places have not been`
  line `so set apart:`
  line
  line `Provided further that the Commissioner of Police or any officer authorised by him in this behalf may,`
  line `in his discretion, on an application made to him by any person, grant to such person permission to dispose`
  line `of the corpse of any deceased person at any place other than a place so set apart, if in his opinion such`
  line `disposal is not likely to cause obstruction to traffic or disturbance of the public peace or is not`
  line `objectionable for any other reason.`
  line
  line `(2) Any regulations made under sub-section (1) shall specify the places set apart for the disposal of`
  line `the dead of different communities or sections of communities.`
  line
  line `(3) All such regulations shall be deemed to be rules for the purposes of section 23 of the General`
  line `Clauses Act, 1897 (10 of 1897) and shall be subject to the conditions of previous publication and the date`
  line `to be specified under clause (3) of that section shall not be earlier than two months from the date on which`
  line `the draft of the proposed regulations is published.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (7261)
  sectionNo (38)
  orderNo 38
  title `Employment of additional police to keep peace.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7261&sectionno=38&orderno=38&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_38_content:
  string
  line `(1) The Commissioner of Police may, on the`
  line `application of any person, depute any additional number of police to keep the peace, to preserve order, to`
  line `enforce any of the provisions of this Act or of any other law in respect of any particular class or classes of`
  line `offences or to perform any other duties imposed on the police at any place in Delhi.`
  line
  line `(2) Such additional police shall be employed at the cost (which shall be determined by the`
  line `Commissioner of Police in accordance with the rules made in this behalf) of the person making the`
  line `application, but shall be subject to the orders of the police authorities and shall be employed for such`
  line `period as the Commissioner of Police considers necessary.`
  line
  line `(3) If the person upon whose application such additional police are employed shall at any time make a`
  line `written requisition to the Commissioner of Police for the withdrawal of the said police, he shall be`
  line `relieved from the cost thereof at the expiration of such period not exceeding one week from the date of`
  line `the delivery of such requisition as the Commissioner of Police shall determine.`
  line
  line `(4) Where there is any dispute as to the amount to be paid by way of cost, the Commissioner of Police`
  line `shall, on an application made in that behalf by the aggrieved party, refer the matter to the District`
  line `Collector, whose decision thereon shall be final.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (7262)
  sectionNo (39)
  orderNo 39
  title `Employment of additional police in cases of special danger to public peace.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7262&sectionno=39&orderno=39&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_39_content:
  string
  line `(1) If in the`
  line `opinion of the Administrator any area in Delhi is in a disturbed or dangerous condition or the conduct of`
  line `the inhabitants or of any particular section or the class of the inhabitants of such area renders it expedient`
  line `to employ temporarily additional police in the area, he may, by notification in the Official Gazette,`
  line `specify the area (hereafter in this section referred to as the disturbed area) in which, and the period for`
  line `which, the additional police shall be employed and thereupon the Commissioner of Police shall depute`
  line `such number of additional police officers as he considers necessary, in the disturbed area:`
  line
  line `Provided that the period so specified may be extended by the Administrator from time to time, if in`
  line `his opinion it is necessary so to do in the interests of the public.`
  line
  line `(2) On the issue of a notification under sub-section (1), the Administrator may require the District`
  line `Collector, or any other authority specified by the Administrator, to recover, whether in whole or in part,`
  line `the cost of such additional police generally from all persons who are inhabitants of the disturbed area or`
  line `specially from any particular section or class of such persons, and in such proportion as the Administrator`
  line `may direct.`
  line
  line `(3) It shall be lawful for the Administrator to exempt, by order in writing, and for sufficient reasons,`
  line `any person from liability to bear any portion of the cost of such additional police.`
  line
  line `Explanation.—In this section and in section 41, the expression inhabitants, when used in relation to`
  line `any disturbed area, includes persons who themselves or by their agents or servants occupy or hold land or`
  line `other immovable property within such area and landlords who themselves or by their agents or servants`
  line `collect rent from holders or occupants of land in such area notwithstanding that they do not actually reside`
  line therein.
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (7263)
  sectionNo (40)
  orderNo 40
  title `Employment of additional police at large work and when apprehension regarding behaviour of employees exists.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7263&sectionno=40&orderno=40&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_40_content:
  string
  line `(1) Whenever it appears to the Administrator or to the competent authority that—`
  line
  line `(a) any large work which is being carried on or any public amusement which is being conducted`
  line `in any place is likely to impede the traffic or to attract a large number of people; or`
  line
  line `(b) the behaviour or a reasonable apprehension of the behaviour of the persons employed on any`
  line `railway, canal or other public work, or in or upon any manufactory or other commercial concern,`
  line `under construction or in operation at any place necessitates the employment of additional police at`
  line `such place,`
  line
  line `the Administrator, or the competent authority, as the case may be, may depute such number of additional`
  line `police to the said place for so long as the necessity to employ the additional police shall appear to the`
  line `Administrator or the competent authority to continue.`
  line
  line `(2) Such additional police shall be employed at the cost of the person by whom the work, public`
  line `amusement, manufactory or concern is being constructed, conducted or carried on and the said person`
  line `shall pay the costs therefor at such rates as the Administrator or the competent authority, as the case may`
  line `be, shall from time to time require.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (7264)
  sectionNo (41)
  orderNo 41
  title `Compensation for injury caused by unlawful assembly how recoverable.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7264&sectionno=41&orderno=41&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_41_content:
  string
  line `(1) When any loss`
  line `or damage is caused to any property or when death results or grievous hurt is caused to any person or`
  line `persons, by anything done in the prosecution of the common object of an unlawful assembly, the`
  line `Administrator may, by notification in the Official Gazette, specify the area (hereafter in this section called`
  line `the "disturbed area") in which, and the date on which or the period during which, such unlawful assembly`
  line `was, in his opinion, held.`
  line
  line `(2) On the issue of a notification under sub-section (1), the District Collector may, after such inquiry`
  line `as he deems necessary, determine the amount of the compensation which, in his opinion, should be paid`
  line `to any person or persons in respect of the loss or damage or death or grievous hurt aforesaid.`
  line
  line `(3) The amount of the compensation shall be deemed to be a fine imposed under this section, and`
  line `shall be payable by the inhabitants of the disturbed area.`
  line
  line `(4) It shall be lawful for the District Collector to exempt, by order in writing and for sufficient`
  line `reasons, any person from liability to pay any portion of the compensation amount.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (7265)
  sectionNo (42)
  orderNo 42
  title `Dispute in regard to cost of deputing additional police or compensation under section 41.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7265&sectionno=42&orderno=42&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_42_content:
  string
  line `In the event of any dispute relating to the cost payable under section 39 or section 40 or the compensation`
  line `determined under section 41 or the person or persons or the section or class of persons by whom or the`
  line `proportion in which such cost or compensation should be paid, the matter shall be referred by the`
  line `Collector, or the Administrator or the competent authority, as the case may be, on an application made in`
  line `that behalf by the aggrieved party, to the Chief Metropolitan Magistrate, whose decision thereon shall be`
  line final.
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (7266)
  sectionNo (43)
  orderNo 43
  title `Recovery of amount payable under section 38, 39, 40 or 41.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7266&sectionno=43&orderno=43&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_43_content:
  string
  line `Any amount payable under`
  line `section 38, section 39, section 40 or section 41 shall be recovered in the same manner as if it were an`
  line `arrear of land revenue.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (7267)
  sectionNo (44)
  orderNo 44
  title `Collector to award compensation.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7267&sectionno=44&orderno=44&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_44_content:
  string
  line `(1) Amounts payable under section 38, section 39,`
  line `section 40 or section 41 shall, when recovered, be credited to the Government.`
  line
  line `(2) The District Collector shall pay, from the amounts recovered by him as compensation payable`
  line `under section 41, such amount as he deems just and proper by way of compensation to any person who`
  line `has suffered loss or damage to property or grievous hurt or to the legal heirs of any person who died, by`
  line `reason of anything done in the prosecution of the common object of the unlawful assembly.`
  line
  line `(3) No compensation shall be paid under this section, except when a claim has been made therefor`
  line `within forty-five days from the date of the notification referred to in sub-section (1) of section 41 and the`
  line `District Collector is satisfied that the claimant, where the claim is by the person who suffered the loss,`
  line `damage or grievous hurt, or the deceased, where the claim is by the legal heirs of such deceased, has been`
  line `free from blame in connection with the occurrence which led to the loss, damage, grievous hurt or death.`
  line
  line `(4) The compensation payable to any person under sub-section (2) shall not in any way be capable of`
  line `being assigned or charged or be liable to attachment or to pass to any person other than the person entitled`
  line `to it by operation of law, nor shall any claim be set off against the same.`
  line
  line `(5) No civil suit shall be maintainable in respect of any loss, damage or grievous hurt for which`
  line `compensation has been granted under this section.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (7268)
  sectionNo (45)
  orderNo 45
  title `Recovery of amounts payable under sections 39 and 41.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7268&sectionno=45&orderno=45&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_45_content:
  string
  line `Without prejudice to the provisions`
  line `contained in section 43, all amounts payable under section 39 or section 41 shall be recoverable in the`
  line `manner provided in sections 421 and 422 of the Code of Criminal Procedure, 1973 (2 of 1974), as if each`
  line `such amount were a fine imposed on an offender by a court.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (7269)
  sectionNo (46)
  orderNo 46
  title `Dispersal of gangs and bodies of persons.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7269&sectionno=46&orderno=46&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_46_content:
  string
  line `Whenever it appears to the Commissioner of Police`
  line `that the movement or encampment of any gang or body of persons in any part of Delhi is causing or is`
  line `calculated to cause danger to person or property or alarm or reasonable suspicion that unlawful designs`
  line `are entertained by such gang or body of persons or by members thereof, the Commissioner of Police may,`
  line `by order addressed to the persons appearing to be the leaders or chief men of such gang or body of`
  line `persons and published by announcement or beat of drums, or otherwise as the Commissioner of Police`
  line `thinks fit direct the members of such gang or body of persons—`
  line
  line `(a) to so conduct themselves as shall seem necessary in order to prevent violence and alarm; or`
  line
  line `(b) to disperse and to remove themselves beyond the limits of Delhi, or any part thereof, within`
  line `such time as the Commissioner of Police shall specify and not to enter Delhi or the part thereof, as the`
  line `case may be, from which they were directed to remove themselves.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (7270)
  sectionNo (47)
  orderNo 47
  title `Removal of persons about to commit offences.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7270&sectionno=47&orderno=47&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_47_content:
  string
  line `Whenever it appears to the Commissioner of`
  line Police—
  line
  line `(a) that the movements or acts of any person are causing or are calculated to cause alarm, danger`
  line `or harm to person or property; or`
  line
  line `(b) that there are reasonable grounds for believing that such person is engaged or is about to be`
  line `engaged in the commission of an offence involving force or violence or an offence punishable under`
  line `Chapter XII, Chapter XVI, Chapter XVII or Chapter XXII of the Indian Penal Code (45 of 1860) or`
  line `under section 290 or sections 489A to 489E (both inclusive) of that Code or in the abetment of any`
  line `such offence; or`
  line
  line `(c) that such person—`
  line
  line `(i) is so desperate and dangerous as to render his being at large in Delhi or in any part thereof`
  line `hazardous to the community; or`
  line
  line `(ii) has been found habitually intimidating other persons by acts of violence or by show of`
  line `force; or`
  line
  line `(iii) habitually commits affray or breach of peace or riot, or habitually makes forcible`
  line `collection of subscription or threatens people for illegal pecuniary gain for himself or for`
  line `others; or`
  line
  line `(iv) has been habitually passing indecent remarks on women and girls, or teasing them by`
  line overtures;
  line
  line `and that in the opinion of the Commissioner of Police witnesses are not willing to come forward to give`
  line `evidence in public against such person by reason of apprehension on their part as regards the safety of`
  line `their person or property, the Commissioner of Police may, by order in writing duly served on such person,`
  line `or by beat of drum or otherwise as he thinks fit, direct such person to so conduct himself as shall seem`
  line `necessary in order to prevent violence and alarm or to remove himself outside Delhi or any part thereof,`
  line `by such route and within such time as the Commissioner of Police may specify and not to enter or return`
  line `to Delhi or part thereof, as the case may be, from which he was directed to remove himself.`
  line
  line `Explanation.—A person who during a period within one year immediately preceding the`
  line `commencement of an action under this section has been found on not less than three occasions to have`
  line `committed or to have been involved in any of the acts referred to in this section shall be deemed to have`
  line `habitually committed that act.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (7271)
  sectionNo (48)
  orderNo 48
  title `Removal of persons convicted of certain offences.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7271&sectionno=48&orderno=48&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_48_content:
  string
  line `If a person has been convicted—`
  line
  line `(a) of an offence under Chapter XII, Chapter XVI or Chapter XVII of the Indian Penal`
  line `Code (45 of 1860); or`
  line
  line `(b) of an offence under section 3 or section 4 of the Delhi Public Gambling`
  line `Act, 1955 (Delhi Act 9 of 1955), or under section 12 of that Act in so far as it relates to satta`
  line `gambling or on two or more occasions under any other provision of that Act (including section 12 of`
  line `that Act in so far as it does not relate to satta gambling); or`
  line
  line `(c) of any offence under the Suppression of Immoral Traffic in Women and Girls`
  line `Act, 1956 (104 of 1956); or`
  line
  line `(d) of any offence under section 25, section 26, section 27, section 28 or section 29 of the Arms`
  line `Act, 1959 (54 of 1959); or`
  line
  line `(e) of any offence under section 135 of the Customs Act, 1962 (52 of 1962); or`
  line
  line `(f) of any offence under section 61, section 63 or section 66 of the Punjab Excise`
  line `Act, 1955 (Punjab Act No. 18 of 1955), as in force in Delhi; or`
  line
  line `(g) on two or more occasions of an offence under—`
  line
  line `(i) the Opium Act, 1878 (1 of 1878); or`
  line
  line `(ii) the Dangerous Drugs Act, 1930 (2 of 1930); or`
  line
  line `(iii) the Drugs and Cosmetics Act, 1940 (23 of 1940); or`
  line
  line `(iv) section 11 of the Bombay Prevention of Begging Act, 1959 (Bombay Act`
  line `No. 10 of 1960), as in force in Delhi; or`
  line
  line `(h) on three or more occasions of an offence under section 105 or section 107 of this Act,`
  line
  line `the Commissioner of Police may, if he has reason to believe that such person is likely again to engage`
  line `himself in the commission of any of the offences referred to in this section, by order in writing, direct`
  line `such person to remove himself beyond the limits of Delhi or any part thereof, by such route and within`
  line `such time as the Commissioner of Police may specify and not to enter or return to Delhi or any part`
  line `thereof, as the case may be, from which he was directed to remove himself.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (7272)
  sectionNo (49)
  orderNo 49
  title `Period of operation of orders under section 46, 47 or 48.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7272&sectionno=49&orderno=49&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_49_content:
  string
  line `Any direction made under`
  line `section 46, section 47 or seclion 48 not to enter Delhi or any part thereof, shall be for such period as may`
  line `be specified therein, and shall in no case exceed a period of two years from the date on which it was`
  line made.
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (7273)
  sectionNo (50)
  orderNo 50
  title `Hearing to be given before order under section 46, 47 or 48 is passed.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7273&sectionno=50&orderno=50&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_50_content:
  string
  line `(1) Before an order`
  line `under section 46, section 47 or section 48 is made against any person, the Commissioner of Police shall`
  line `by notice in writing inform him of the general nature of the material allegations against him and give him`
  line `a reasonable opportunity of tendering an explanation regarding them.`
  line
  line `(2) If such person makes an application for the examination of any witness to be produced by him, the`
  line `Commissioner of Police shall grant such application and examine such witness, unless for reasons to be`
  line `recorded in writing, the Commissioner of Police is of opinion that such application is made for the`
  line `purpose of causing vexation or delay.`
  line
  line `(3) Any written explanation put in by such person shall be filed with the record of the case.`
  line
  line `(4) Such person shall be entitled to be represented in the proceeding before the Commissioner of`
  line `Police by a counsel.`
  line
  line `(5) (a) The Commissioner of Police may for the purpose of securing the attendance of any person`
  line `against whom any order is proposed to be made under section 46, section 47 or section 48 require such`
  line `person, by order in writing, to appear before him and to furnish a security bond with or without sureties`
  line `for attendance during the inquiry.`
  line
  line `(b) The provisions of sections 119 to 124 (both inclusive) of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974), shall, so far as may be, apply in relation to the order under clause (a) to`
  line `furnish security bond.`
  line
  line `(6) Without prejudice to the foregoing provisions, the Commissioner of Police, while issuing notice to`
  line `any person under sub-section (1) may issue a warrant for his arrest and the provisions of sections 70 to 89`
  line `(both inclusive) of the Code of Criminal Procedure, 1973 (2 of 1974), shall, so far as may be, apply in`
  line `relation to such warrant.`
  line
  line `(7) The provisions of section 445, section 446, section 447 or section 448 of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974), shall, so far as may be, apply in relation to all bonds executed under this`
  line section.
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (7274)
  sectionNo (51)
  orderNo 51
  title `Appeal against orders under section 46, 47 or 48.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7274&sectionno=51&orderno=51&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_51_content:
  string
  line `(1) Any person aggrieved by an order made`
  line `under section 46, section 47 or section 48 may appeal to the Administrator within thirty days from the`
  line `date of the service of such order on him.`
  line
  line `(2) An appeal under this section shall be preferred in duplicate in the form of a memorandum, setting`
  line `forth concisely the grounds of objection to the order appealed against, and shall be accompanied by that`
  line `order or a certified copy thereof.`
  line
  line `(3) On receipt of such appeal, the Administrator may, after giving a reasonable opportunity to the`
  line `appellant to be heard either personally or by a counsel and after such further inquiry, if any, as he may`
  line `deem necessary, confirm, vary or set aside the order appealed against:`
  line
  line `Provided that the order appealed against shall remain in force pending the disposal of the appeal,`
  line `unless the Administrator otherwise directs.`
  line
  line `(4) The Administrator shall make every endeavour to dispose of an appeal under this section within a`
  line `period of three months from the date of receipt of such appeal.`
  line
  line `(5) In calculating the period of thirty days provided for an appeal under this section, the time taken for`
  line `obtaining a certified copy of the order appealed against, shall be excluded.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (7275)
  sectionNo (52)
  orderNo 52
  title `Finality of order in certain cases.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7275&sectionno=52&orderno=52&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_52_content:
  string
  line `An order passed by the Commissioner of Police under`
  line `section 46, section 47 or section 48 or the Administrator under section 51 shall not be called in question`
  line `in any court except on the ground—`
  line
  line `(a) that the Commissioner of Police or the Administrator, as the case may be, had not followed`
  line `the procedure laid down in sub-section (1), sub-section (2) or sub-section (4) of section 50 or in`
  line `section 51, as the case may be; or`
  line
  line `(b) that there was no material before the Commissioner of Police or the Administrator, as the case`
  line `may be, upon which he could have based his order; or`
  line
  line `(c) in the case of an order made under section 47 or an order in appeal therefrom to the`
  line `Administrator under section 51, the Commissioner of Police or the Administrator, as the case may be,`
  line `was not of the opinion that witnesses were unwilling to come forward to give evidence in public`
  line `against the person against whom such order has been made.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (7276)
  sectionNo (53)
  orderNo 53
  title `Procedure on failure of person to leave the area and his entry therein after removal.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7276&sectionno=53&orderno=53&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_53_content:
  string
  line `If a`
  line `person to whom a direction has been issued under section 46, section 47 or section 48 to remove himself`
  line `from Delhi or any part thereof—`
  line
  line `(a) fails to remove himself as directed; or`
  line
  line `(b) having so removed himself enters Delhi or any part thereof within the period specified in the`
  line `order, otherwise than with the permission in writing of the Commissioner of Police under section 54,`
  line
  line `the Commissioner of Police may cause him to be arrested and removed in police custody to such place`
  line `outside Delhi or any part thereof as the Commissioner of Police may in each case specify.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (7277)
  sectionNo (54)
  orderNo 54
  title `Temporary permission to enter and consequences of non-observance of conditions of such permission.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7277&sectionno=54&orderno=54&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_54_content:
  string
  line `(1) The Commissioner of Police or any other police officer specially empowered by the`
  line `Administrator in that behalf may, by order in writing, permit any person, in respect of whom an order`
  line `under section 46, section 47 or section 48 has been made, to return to Delhi or any part thereof, from`
  line `which he was directed to remove himself, for such temporary period and subject to such conditions as`
  line `may be specified in such order and may require him to execute a bond with or without surety for the due`
  line `observance of the conditions imposed.`
  line
  line `(2) The Commissioner of Police may at any time revoke any such permission.`
  line
  line `(3) Any person who with such permission returns to Delhi or any part thereof shall observe the`
  line `conditions imposed, and at the expiry of the temporary period for which he was permitted to return, or on`
  line `the revocation of such permission before the expiry of such temporary period, shall remove himself`
  line `outside Delhi or any part thereof, as the case may be, and shall not return thereto within the unexpired`
  line `portion of the period specified in the original order made under section 46, section 47 or section 48`
  line `without a fresh permission.`
  line
  line `(4) If such person fails to observe any of the conditions imposed, or to remove himself accordingly or`
  line `having so removed himself enters or returns to Delhi or any part thereof, as the case may be, without fresh`
  line `permission, the Commissioner of Police may cause him to be arrested and removed in police custody to`
  line `such place outside Delhi or part thereof as the Commissioner of Police may in each case specify.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (7278)
  sectionNo (55)
  orderNo 55
  title `Taking measurements and photographs, etc., of persons against whom an order under section 46, 47 or 48 is made.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7278&sectionno=55&orderno=55&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_55_content:
  string
  line `Every person against whom an order has been made under section 46,`
  line `section 47 or section 48 shall, if so required by the Commissioner of Police, allow his measurements and`
  line `photograph to be taken by a police officer in the prescribed manner.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (7279)
  sectionNo (56)
  orderNo 56
  title `Resistance to the taking of measurements, etc.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7279&sectionno=56&orderno=56&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_56_content:
  string
  line `(1) If any person as aforesaid when required to`
  line `allow his measurements or photograph to be taken resists or refuses to allow the taking of such`
  line `measurements or photograph, it shall be lawful to use all necessary means to secure the taking thereof.`
  line
  line `(2) Resistance to or refusal to allow the taking of measurements or photographs under this Act shall`
  line `be deemed to be an offence under section 186 of the Indian Penal Code (45 of 1860).`
  line
  line `(3) Where an order under section 46, section 47 or section 48 is set aside in appeal, all measurements`
  line `and photographs (including negatives) taken under this section shall be destroyed or made over to the`
  line `person against whom such order is made.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (7280)
  sectionNo (57)
  orderNo 57
  title `Banning of use of dress, etc., resembling uniform of armed forces.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7280&sectionno=57&orderno=57&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_57_content:
  string
  line `(1) If the Administrator is`
  line `satisfied that the wearing in public, by any member of any body, or association or organisation, of any`
  line `dress or article of apparel resembling any uniform required to be worn by a member of the Armed Forces`
  line `of the Union or by a member of any police force or of any force constituted by or under any law for the`
  line `time being in force, is likely to prejudice the security of the State or the maintenance of public order, he`
  line `may, by a general or special order, prohibit or restrict the wearing, or display, in public of any such dress`
  line `or article or apparel by any member of such body or association or organisation.`
  line
  line `(2) Every general or special order under sub-section (1) shall be published in the manner prescribed`
  line `for the publication of a public notice under section 142.`
  line
  line `Explanation.—For the purposes of this section a dress or an article of apparel shall be deemed to be`
  line `worn or displayed in public if it is worn or displayed in any place to which the public have access.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (7281)
  sectionNo (58)
  orderNo 58
  title `Constitution of Defence Societies.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7281&sectionno=58&orderno=58&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_58_content:
  string
  line `(1) For the protection of persons, the security of property`
  line `and the public safety in any locality the Commissioner of Police may constitute voluntary bodies`
  line `(hereafter in this section referred to as Defence Societies) in the prescribed manner.`
  line
  line `(2) The Commissioner of Police or any officer of a Defence Society may at any time call up officers`
  line `subordinate to him or any member of a Defence Society for training or to discharge any of the duties`
  line `under this Act assigned to them.`
  line
  line `(3) Every officer or member of a Defence Society shall—`
  line
  line `(a) on appointment receive a certificate in such form as may be specified or approved by the`
  line `Administrator in this behalf; and`
  line
  line `(b) when called up for duty have the same powers, privileges and protection as are vested in a`
  line `police officer appointed under this Act.`
  line
  line `(4) Notwithstanding anything contained in any law for the time being in force, an officer or member`
  line `of a Defence Society shall not be disqualified for being chosen as, or for being, a member of—`
  line
  line `(a) the Delhi Metropolitan Council or the Municipal Corporation of Delhi; or`
  line
  line `(b) any other local authority,`
  line
  line `by reason of the fact that he is a member or officer of such Society.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (7282)
  sectionNo (59)
  orderNo 59
  title `Duty of police officer to enforce provisions of the Act.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7282&sectionno=59&orderno=59&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_59_content:
  string
  line `(1) It shall be the duty of every police`
  line `officer to ensure compliance with the provisions of this Act or any rule, regulation or order made`
  line `thereunder and for that purpose such police officer may,—`
  line
  line `(a) warn persons who from ignorance fail to comply with any provision of this Act or any rule,`
  line `regulation or order made thereunder;`
  line
  line `(b) require any person acting or about to act contrary to any provision of this Act or rule,`
  line `regulation or order made thereunder, to desist from so doing;`
  line
  line `(c) subject to the provisions of sub-sections (2) and (3), arrest any person contravening any`
  line `provision of this Act or any rule, regulation or order made threunder, where such contravention is an`
  line `offence punishable under this Act;`
  line
  line `(d) seize any object used, or about to be used, in contravening, or in contravention of, the`
  line `provisions of this Act or any rule, regulation or order made thereunder, where such contravention is`
  line `an offence punishable under this Act.`
  line
  line `(2) A police officer shall not arrest any person under clause (c) of sub-section (1) without a warrant`
  line `issued by a Metropolitan Magistrate, unless such person,—`
  line
  line `(a) has contravened any regulation made under clause (b) of sub-section (1) of section 28;`
  line
  line `(b) has contravened any order or notification made under section 29, sub-section (1) or`
  line `sub-section (2) of section 30, section 32, section 47, section 48 or sub-section (1) of section 57;`
  line
  line `(c) commits in the presence of such police officer an offence punishable under section 97,`
  line `sub-section (1) of section 108, clause (a), (b) or (c) of section 110 or sub-section (2) of section 113 in`
  line `respect of the contravention of any order made under section 33 or section 34;`
  line
  line `(d) has committed, or is reasonably suspected to have committed, an offence punishable under`
  line `section 100 in relation to any dwelling house, private premises or any other land or ground attached`
  line `thereto:`
  line
  line `Provided that the person in possession or having charge of that dwelling house, private premises`
  line `or land or ground complains of the commission of such offence;`
  line
  line `(e) has committed, or is reasonably suspected to have committed an offence punishable under`
  line `section 101, section 102 or clause (c) of sub-section (2) of section 113;`
  line
  line `(f) commits in his presence in any street or public place any non-cognizable offence punishable`
  line `under this Act or any rule or regulation made thereunder if such person—`
  line
  line `(i) after being warned by the police officer persists in committing such offence; or`
  line
  line `(ii) refuses to accompany the police officer to a police station on being required so to do.`
  line
  line `(3) The Commissioner of Police or any other police officer especially empowered in this behalf by`
  line `the Commissioner of Police may arrest without a warrant issued by a Metropolitan Magistrate any person`
  line `who has committed an offence punishable under section 92.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (7283)
  sectionNo (60)
  orderNo 60
  title `Other duties of a police officer.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7283&sectionno=60&orderno=60&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_60_content:
  string
  line `It shall be the duty of every police officer—`
  line
  line `(a) promptly to serve every summons and obey and execute every warrant or other order lawfully`
  line `issued to him by the competent authority and to comply with all lawful commands of his superior;`
  line
  line `(b) to the best of his ability, to obtain intelligence concerning the commission of cognizable`
  line `offences or designs to commit such offences and to lay such information and to take such other steps`
  line `consistent with law and with the orders of his superiors as shall be best calculated to bring offenders`
  line `to justice and to prevent the commission of cognizable and, within his view, of non-cognizable`
  line offences;
  line
  line `(c) to prevent to the best of his ability the commission of public nuisances;`
  line
  line `(d) to apprehend without unreasonable delay all persons whom he is legally authorised to`
  line `apprehend and for whose apprehension there is sufficient reason;`
  line
  line `(e) to aid any other police officer when called upon by such other police officer or in the case of`
  line `need in the discharge of the duty of such other police officer, in such ways as would be lawful and`
  line `reasonable on the part of the officer aided;`
  line
  line `(f) to prevent the breach of the public peace;`
  line
  line `(g) to afford every assistance within his power to disabled or helpless persons in the streets;`
  line
  line `(h) to take charge of intoxicated persons and of lunatics at large, who appear dangerous or`
  line `incapable or taking care of themselves;`
  line
  line `(i) to take prompt measures to procure necessary help for any person under arrest or in custody,`
  line `who is wounded or sick and whilst guarding or conducting any such person to have due regard to his`
  line condition;
  line
  line `(j) to arrange for the proper sustenance and shelter of every person who is under arrest or in`
  line custody;
  line
  line `(k) in conducting searches, to refrain from needless rudeness and the causing of unnecessary`
  line annoyance;
  line
  line `(l) in dealing with women and children, to act with strict regard to decency and with reasonable`
  line gentleness;
  line
  line `(m) to use his best endeavours to prevent any loss or damage by fire;`
  line
  line `(n) to use his best endeavours to avert any accident or danger to the public;`
  line
  line `(o) to regulate and control the traffic in the streets, to prevent obstructions therein and to the best`
  line `of his ability, to prevent the contravention of any rule, regulation or order made under this Act or any`
  line `other law in force for observance by the public in or near the streets;`
  line
  line `(p) to keep order in the streets and at and within public bathing and washing places, fairs, temples`
  line `and all other places of public resort and in the neighbourhood of places of public worship;`
  line
  line `(q) to regulate resort to public bathing and washing places and all other places of public resort, to`
  line `prevent overcrowding there and to the best of his ability, to prevent the contravention of any`
  line `regulation or order lawfully made for observance by the public at such place; and`
  line
  line `(r) to discharge such other duties as are imposed upon him by any law for the time being in force.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (7284)
  sectionNo (61)
  orderNo 61
  title `Power to enter places of public resort.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7284&sectionno=61&orderno=61&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_61_content:
  string
  line `Subject to the provisions of this Act and the rules,`
  line `regulations and orders made thereunder, every police officer may, for the purpose of discharging any of`
  line `the duties referred to in section 59 or section 60 enter without a warrant and inspect any place of public`
  line `resort which he has reason to believe is used as a place for the storing, sale or consumption of intoxicating`
  line `drinks or narcotics or a place for resort of loose and disorderly characters.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (7285)
  sectionNo (62)
  orderNo 62
  title `Power to search suspected persons in street, etc.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7285&sectionno=62&orderno=62&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_62_content:
  string
  line `When in a street or a place of public resort a`
  line `person is in possession or suspected to be in possession of any article which a police officer in good faith`
  line `suspects to be stolen property, such police officer may search such person and may require an account in`
  line `relation to any article found in his possession and should the account given by the possessor be manifestly`
  line `false or suspicious, may detain such article after giving to the possessor a receipt in the prescribed form`
  line `and report the facts to a Metropolitan Magistrate who shall thereupon proceed according to the provisions`
  line `of sections 457, 458 and 459 of the Code of Criminal Procedure, 1973 (2 of 1974).`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (7286)
  sectionNo (63)
  orderNo 63
  title `Emergency duties of police.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7286&sectionno=63&orderno=63&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_63_content:
  string
  line `(1) The Administrator may, by notification in the Official Gazette,`
  line `declare any specified service to be an essential service to the community.`
  line
  line `(2) A declaration made under sub-section (1) shall remain in force for one month in the first instance,`
  line `but may be extended from time to time by a like notification.`
  line
  line `(3) Upon a declaration being made under sub-section (1) and so long as it remains in force, it shall be`
  line `the duty of every police officer to obey any order given by any superior officer in relation to any`
  line `employment in connection with the service specified in the declaration.`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (7287)
  sectionNo (64)
  orderNo 64
  title `Superior police officer may himself perform duties imposed on a subordinate officer.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7287&sectionno=64&orderno=64&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_64_content:
  string
  line A
  line `police officer of a rank superior to that of a constable may perform any duty assigned by law or by a`
  line `lawful order to any officer subordinate to him, and in the case of any duty imposed on such subordinate, a`
  line `superior may aid, supplement, supersede, or prevent any action of such subordinate by his own action or`
  line `that of any person lawfully acting under his command or authority, whenever the same shall appear`
  line `necessary or expedient for giving more complete or convenient effect to the law or for avoiding any`
  line `infringement thereof.`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (7288)
  sectionNo (65)
  orderNo 65
  title `Persons bound to comply with the reasonable directions of police officer.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7288&sectionno=65&orderno=65&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_65_content:
  string
  line `(1) All persons`
  line `shall be bound to comply with the reasonable directions given by a police officer in the discharge of his`
  line `duties under this Act.`
  line
  line `(2) Where any person resists, refuses or fails to comply with any direction referred to in`
  line `sub-section (1), a police officer may, without prejudice to any other action that he may take under any`
  line `other provision of this Act or any other law for the time being in force, remove such person and either`
  line `produce him before a Metropolitan Magistrate or, in trivial cases, release him when the occasion which`
  line `necessitated the removal has ceased to exist:`
  line
  line `Provided that the person so removed shall in all cases be produced before the Metropolitan Magistrate`
  line `or released, as the case may be, within a period of twenty-four hours of such removal.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (7289)
  sectionNo (66)
  orderNo 66
  title `Police to take charge of unclaimed property.`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7289&sectionno=66&orderno=66&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_66_content:
  string
  line `(1) It shall be the duty of every police officer to`
  line `take temporary charge—`
  line
  line `(a) of all unclaimed property found by, or made over to, him; and`
  line
  line `(b) of all property found lying in any public street, if the owner or person in charge of such`
  line `property, on being directed to remove the same, refuses or fails to do so.`
  line
  line `(2) The police officer taking charge of the property under sub-section (1) shall furnish an inventory`
  line `thereof to the Commissioner of Police.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (7290)
  sectionNo (67)
  orderNo 67
  title `Procedure for disposal of property taken charge of under section 66.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7290&sectionno=67&orderno=67&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_67_content:
  string
  line `(1) Where any`
  line `property has been taken charge of under sub-section (1) of section 66, the Commissioner of Police shall`
  line `issue a proclamation specifying the articles of which such property consists and requiring that any person who may have a claim thereto shall appear before him or some other officer whom he authorises in this`
  line `behalf and establish his claim within six months from the date of such proclamation.`
  line
  line `(2) If the property, or any part thereof, is subject to speedy and natural decay or consists of livestock`
  line `or if the property appears to be of the value of less than fifty rupees, it may forthwith be sold by auction`
  line `under the orders of the Commissioner of Police and the net proceeds of such sale shall be dealt with in the`
  line `same manner as is hereinafter provided for the disposal of the said property.`
  line
  line `(3) Where any person who has a claim to the property is required by the proclamation under`
  line `sub-section (1) to appear before the other officer authorised by the Commissioner of Police in that behalf`
  line `and establish his claim, such officer shall forward the record of the proceedings before him with his`
  line `findings thereon to the Commissioner of Police.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (7291)
  sectionNo (68)
  orderNo 68
  title `Delivery of property to person entitled.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7291&sectionno=68&orderno=68&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_68_content:
  string
  line `(1) The Commissioner of Police on being satisfied of`
  line `the title of any claimant to the possession or administration of the property specified in the proclamation`
  line `issued under sub-section (1) of section 67 order the same to be delivered to him, after deduction or`
  line `payment of the expenses incurred by the Delhi police in the seizure and detention thereof.`
  line
  line `(2) The Commissioner of Police may, at his discretion, before making any order under`
  line `sub-section (1), take such security as he may think proper from the person to whom the said property is to`
  line `be delivered and nothing hereinbefore contained shall affect the right of any person to recover the whole`
  line `or any part of the same from the person to whom it may have been delivered pursuant to such order.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (7292)
  sectionNo (69)
  orderNo 69
  title `In default of claim, property to be at disposal of Government.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7292&sectionno=69&orderno=69&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_69_content:
  string
  line `(1) If no person establishes`
  line `his claim to such property within the period specified in the proclamation, the property, or such part`
  line `thereof as has not already been sold under sub-section (2) of section 67, may be sold by auction under the`
  line `orders of the Commissioner of Police and the proceeds thereof shall be credited to the Government.`
  line
  line `(2) If any claim is made to any proceeds credited under sub-section (1) to the Government and if such`
  line `claim is established, whether wholly or to any extent, to the satisfaction of the prescribed authority, the`
  line `Administrator shall pay to the claimant the amount determined in that behalf by the prescribed authority.`
  line
  line `(3) The form and manner in which claims may be made under sub-section (2) and the procedure for`
  line `dealing with such claims and all other matters connected therewith shall be such as may be prescribed.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (7293)
  sectionNo (70)
  orderNo 70
  title `Power of Central Government to authorise Commissioner of Police and certain other officers to exercise powers of District Magistrates and Executive Magistrates under the Code of Criminal Procedure, 1973.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7293&sectionno=70&orderno=70&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_70_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette`
  line `and subject to such conditions and limitations as may be specified therein, empower—`
  line
  line `(a) the Commissioner of Police to exercise and perform in relation to Delhi the powers and duties`
  line `of an Executive Magistrate and of a District Magistrate under such of the provisions of the Code of`
  line `Criminal Procedure, 1973 (2 of 1974), as may be specified in the notification;`
  line
  line `(b) any officer subordinate to the Commissioner of Police (not being an officer below the rank of`
  line `an Assistant Commissioner of Police) to exercise and perform in relation to such areas in Delhi as`
  line `may be specified in the notification the powers and duties of an Executive Magistrate under such of`
  line `the provisions of the said Code as may be specified in the notification.`
  line
  line `(2) Every officer subordinate to the Commissioner of Police shall, in the exercise and performance of`
  line `any powers and duties which he is empowered to exercise or perform under sub-section (1), be subject to`
  line `the general control of the Commissioner of Police in the same manner and to the same extent as an`
  line `Executive Magistrate appointed under section 20 of the said Code would be subject to the general control`
  line `of the District Magistrate appointed under that section.`
  line
  line `(3) The Commissioner of Police or any officer subordinate to him shall not be subject in the exercise`
  line `and performance of any powers and duties which he is empowered to exercise and perform under`
  line `sub-section (1), to the general control of the District Magistrate appointed under section 20 of the said`
  line Code.
  line
  line `(4) The provisions of this section shall have effect notwithstanding anything contained in the said`
  line Code.
obj_root_law_sections_70_footnotes:
  string
  line
obj_root_law_sections_71:
  sectionId (7294)
  sectionNo (71)
  orderNo 71
  title `Notifications under section 70 to be laid before Parliament.`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7294&sectionno=71&orderno=71&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_71_content:
  string
  line `Every notification made by the`
  line `Central Government under section 70 shall be laid, as soon as it is made, before each House of Parliament`
  line `while it is in session for a total period of thirty days which may be comprised in one session or in two or`
  line `more successive sessions and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the notification or both`
  line `Houses agree that the notification should not be made, the notification shall thereafter have effect only in`
  line `such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that notification.`
obj_root_law_sections_71_footnotes:
  string
  line
obj_root_law_sections_72:
  sectionId (7295)
  sectionNo (72)
  orderNo 72
  title `References to Judicial Magistrate of the first class in sections 108, 109 and 110 of the Code of Criminal Procedure, 1973 not to be construed as references to an Executive Magistrate.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7295&sectionno=72&orderno=72&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_72_content:
  string
  line `[References to Judicial Magistrate of the first class in sections 108, 109 and 110 of the Code of`
  line `Criminal Procedure, 1973 not to be construed as references to an Executive Magistrate.] Omitted by the`
  line `Code of Criminal Procedure (Amendment) Act, 1980 (63 of 1980), s. 9 (w.e.f. 23-9-1980).`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (7296)
  sectionNo (73)
  orderNo 73
  title `Powers with regard to offences under Act 59 of 1960.`
  content obj_root_law_sections_73_content
  footnotes obj_root_law_sections_73_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7296&sectionno=73&orderno=73&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_73_content:
  string
  line `(1) When in respect of an animal an`
  line `offence punishable under sub-section (1) of section 11 or section 12 of the Prevention of Cruelty to`
  line `Animals Act, 1960 has been committed, or when there is a reasonable ground for suspecting that such`
  line `offence has been committed, a police officer may—`
  line
  line `(a) take the animal to the Metropolitan Magistrate, or`
  line
  line `(b) if the accused person so requires, take the animal to a veterinary officer specified by general`
  line `or special order by the Administrator in this behalf:`
  line
  line `Provided that the police officer may, instead of taking the animal to a veterinary officer, take the`
  line `animal for detention in a dispensary, or in any suitable place approved by the Administrator by`
  line `general or special order and the animal shall thereupon be detained there until its production before a`
  line `Metropolitan Magistrate, or`
  line
  line `(c) take the animal to an infirmary appointed under section 35 of the said Act for treatment and`
  line `detention therein, pending direction of a Magistrate under sub-section (2) of that section, or`
  line
  line `(d) when the animal is in such physical condition that it cannot be taken to a veterinary officer or`
  line `a Metropolitan Magistrate, draw up a report of the condition of the animal in the presence of two or`
  line `more respectable persons describing such wound, sores, fractures, bruises, or other marks of injury as`
  line `may be found on the body of the animal:`
  line
  line `Provided that the police officer may take the animal for detention in a dispensary or any suitable place`
  line `approved by the Administrator by general or special order and the animal shall thereupon be detained`
  line `there until its production before a Metropolitan Magistrate.`
  line
  line `(2) Where an animal is detained in a dispensary, infirmary or other place under sub-section (1), the`
  line `animal shall be produced before a Metropolitan Magistrate with the least possible delay and in any case`
  line `within a period not exceeding three days from the date on which it was so detained.`
obj_root_law_sections_73_footnotes:
  string
  line
obj_root_law_sections_74:
  sectionId (7297)
  sectionNo (74)
  orderNo 74
  title `Powers of Metropolitan Magistrate to return animal to person from whose possession it was taken.`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7297&sectionno=74&orderno=74&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_74_content:
  string
  line `When the animal is brought before a Metropolitan Magistrate under section 73, the Magistrate`
  line `may direct the animal to be returned to the person from whose possession it was taken on such person`
  line `giving security to the satisfaction of the Metropolitan Magistrate binding himself to produce the animal`
  line `when required or may direct that the animal shall be sent for treatment and care to an infirmary and be`
  line `detained there as provided in section 35 of the Prevention of Cruelty to Animals Act, 1960 (59 of 1960)`
  line `or may make such order as he thinks fit regarding the disposal or custody or production of the animal.`
obj_root_law_sections_74_footnotes:
  string
  line
obj_root_law_sections_75:
  sectionId (7298)
  sectionNo (75)
  orderNo 75
  title `Veterinary officer to examine the animal.`
  content obj_root_law_sections_75_content
  footnotes obj_root_law_sections_75_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7298&sectionno=75&orderno=75&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_75_content:
  string
  line `The veterinary officer before whom an animal is`
  line `brought under section 73 shall with all convenient speed examine the same and draw up a report of such`
  line `examination and a copy of the report of such examination shall be delivered free of charge to the accused`
  line `person if he applies for it.`
obj_root_law_sections_75_footnotes:
  string
  line
obj_root_law_sections_76:
  sectionId (7299)
  sectionNo (76)
  orderNo 76
  title `Animal to be dealt with under Act 59 of 1960.`
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7299&sectionno=76&orderno=76&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_76_content:
  string
  line `When under section 73, a police officer takes`
  line `an animal for detention in a dispensary or infirmary or other place before its production before a`
  line `Metropolitan Magistrate or a Metropolitan Magistrate directs its further detention in an infirmary,`
  line `sub-sections (3) to (7) (both inclusive) of section 35 of the Prevention of Cruelty to Animals`
  line `Act, 1960 shall, as far as may be, apply in relation to the detention of animal (including the cost of`
  line `transport, maintenance and treatment of the animal) in the dispensary, infirmary or other place.`
obj_root_law_sections_76_footnotes:
  string
  line
obj_root_law_sections_77:
  sectionId (7300)
  sectionNo (77)
  orderNo 77
  title `Power of police officer to unsaddle animal or to unload it.`
  content obj_root_law_sections_77_content
  footnotes obj_root_law_sections_77_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7300&sectionno=77&orderno=77&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_77_content:
  string
  line `When a police officer in good`
  line `faith suspects that any animal being employed in any work or labour is, by reason of any sore, unfit to be`
  line `so employed, he may require the person in charge of such animal to unsaddle or unload it for the purpose`
  line `of ascertaining whether any sore exists and, if any person refuses to do so, such police officer may`
  line `himself unsaddle or unload the animal or may cause the same to be unsaddled or unloaded.`
obj_root_law_sections_77_footnotes:
  string
  line
obj_root_law_sections_78:
  sectionId (7301)
  sectionNo (78)
  orderNo 78
  title `Arrest without warrant in case of certain offences under Act 59 of 1960.`
  content obj_root_law_sections_78_content
  footnotes obj_root_law_sections_78_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7301&sectionno=78&orderno=78&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_78_content:
  string
  line `Any police officer`
  line `may arrest, without a warrant from a Magistrate, any person committing in his presence any offence`
  line `punishable under clauses (a) to (m) (both inclusive) of sub-section (1) of section 11 of the Prevention of`
  line `Cruelly to Animals Act, 1960.`
obj_root_law_sections_78_footnotes:
  string
  line
obj_root_law_sections_79:
  sectionId (7302)
  sectionNo (79)
  orderNo 79
  title `Provisions of Chapter to be in addition to the provisions of Act 59 of 1960.`
  content obj_root_law_sections_79_content
  footnotes obj_root_law_sections_79_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7302&sectionno=79&orderno=79&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_79_content:
  string
  line `The provisions`
  line `of this Chapter shall be in addition to, and not in derogation of, the provisions of the Prevention of`
  line `Cruelty to Animals Act, 1960.`
obj_root_law_sections_79_footnotes:
  string
  line
obj_root_law_sections_80:
  sectionId (7303)
  sectionNo (80)
  orderNo 80
  title `Disregarding the rules of the road.`
  content obj_root_law_sections_80_content
  footnotes obj_root_law_sections_80_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7303&sectionno=80&orderno=80&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_80_content:
  string
  line `No person shall—`
  line
  line `(a) when driving a vehicle along a street (except in cases of actual necessity or of some other`
  line `sufficient reason for deviation) fail to keep on the left side of such street and when passing any other`
  line `vehicle proceeding in the same direction fail to keep on the right side of such vehicle; or`
  line
  line `(b) leave in any street or public place insufficiently tended or secured any animal or vehicle.`
obj_root_law_sections_80_footnotes:
  string
  line
obj_root_law_sections_81:
  sectionId (7304)
  sectionNo (81)
  orderNo 81
  title `Causing obstruction or mischief by animal.`
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7304&sectionno=81&orderno=81&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_81_content:
  string
  line `No person shall cause obstruction, damage,`
  line `injury, danger, alarm or mischief in any street or public place—`
  line
  line `(i) by misbehaviour, negligence or ill-usage in the driving, management, treatment or care of any`
  line `animal or vehicle; or`
  line
  line `(ii) by driving any vehicle or animal laden with timber, poles or other unwieldy articles through a`
  line `street or public place contrary to any regulation made in that behalf.`
obj_root_law_sections_81_footnotes:
  string
  line
obj_root_law_sections_82:
  sectionId (7305)
  sectionNo (82)
  orderNo 82
  title `Exposing animal for hire, sale, etc.`
  content obj_root_law_sections_82_content
  footnotes obj_root_law_sections_82_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7305&sectionno=82&orderno=82&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_82_content:
  string
  line `No person shall in any street or public place expose for`
  line `hire or sale any animal or vehicle, clean any furniture or vehicle, or clean or groom any horse or other`
  line `animal except at such times and places as the competent authority permits, or shall train or break in any`
  line `horse or other animal or make any vehicle or any part of a vehicle or (except when as a result of any`
  line `accident repairing on the spot is unavoidable) repair any vehicle or part of a vehicle, or carry on therein`
  line `any manufacture or operation so as to be a serious impediment to traffic or serious annoyance to residents`
  line `in the vicinity or to the public.`
obj_root_law_sections_82_footnotes:
  string
  line
obj_root_law_sections_83:
  sectionId (7306)
  sectionNo (83)
  orderNo 83
  title `Causing any obstruction in a street.`
  content obj_root_law_sections_83_content
  footnotes obj_root_law_sections_83_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7306&sectionno=83&orderno=83&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_83_content:
  string
  line `No person shall cause obstruction in any street or`
  line `public place—`
  line
  line `(a) by allowing any animal or vehicle, which has to be loaded or unloaded, or take up or set down`
  line `passengers, to remain or stand in the street or the public place longer than may be necessary for such`
  line `purpose; or`
  line
  line `(b) by leaving any vehicle standing or fastening any cattle in the street or the public place; or`
  line
  line `(c) by using any part of a street or public place as a halting place for vehicles or cattle; or`
  line
  line `(d) by leaving any box, bale, package or other things whatsoever in or upon a street for an`
  line `unreasonable length of time or contrary to any regulation; or`
  line
  line `(e) by exposing anything for sale or setting out anything for sale in or upon any stall, booth,`
  line `board, cask, basket or in any other way whatsoever.`
obj_root_law_sections_83_footnotes:
  string
  line
obj_root_law_sections_84:
  sectionId (7307)
  sectionNo (84)
  orderNo 84
  title `Obstructing a footway.`
  content obj_root_law_sections_84_content
  footnotes obj_root_law_sections_84_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7307&sectionno=84&orderno=84&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_84_content:
  string
  line `No person shall drive, ride, load, propel or leave on any footway any`
  line `animal or vehicle other than a perambulator or fasten any animal in such a way that the animal can stand`
  line `across or upon such footway.`
obj_root_law_sections_84_footnotes:
  string
  line
obj_root_law_sections_85:
  sectionId (7308)
  sectionNo (85)
  orderNo 85
  title `Causing obstruction and annoyance by performances, etc.`
  content obj_root_law_sections_85_content
  footnotes obj_root_law_sections_85_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7308&sectionno=85&orderno=85&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_85_content:
  string
  line `No person shall, in contravention`
  line `of any regulation made by the Commissioner of Police,—`
  line
  line `(a) exhibit any mimetic, musical or other performances of such a nature as may attract crowds; or`
  line
  line `(b) carry or place bulky advertisements, pictures, figures or emblems in any street or public place,`
  line
  line `whereby any obstruction to passengers or annoyance to the residents in the vicinity may be occasioned.`
obj_root_law_sections_85_footnotes:
  string
  line
obj_root_law_sections_86:
  sectionId (7309)
  sectionNo (86)
  orderNo 86
  title `Doing offensive acts in or near a street or public place.`
  content obj_root_law_sections_86_content
  footnotes obj_root_law_sections_86_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7309&sectionno=86&orderno=86&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_86_content:
  string
  line `No person shall slaughter any animal,`
  line `clean a carcass or hide, or bathe or wash his person in or near to and within sight of a street or public`
  line `place, except at a place set apart for the purpose, so as to cause annoyance to the neighbouring residents`
  line `or to passers-by.`
obj_root_law_sections_86_footnotes:
  string
  line
obj_root_law_sections_87:
  sectionId (7310)
  sectionNo (87)
  orderNo 87
  title `Letting loose horse, etc., and suffering ferocious dogs to be at large.`
  content obj_root_law_sections_87_content
  footnotes obj_root_law_sections_87_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7310&sectionno=87&orderno=87&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_87_content:
  string
  line `No person shall in any`
  line `street or public place—`
  line
  line `(a) negligently let loose any horse or other animal, so as to cause danger, injury, alarm or`
  line `annoyance; or`
  line
  line `(b) suffer a ferocious dog to be at large without a muzzle; or`
  line
  line `(c) set on or urge a dog or other animal to attack, worry or put in fear any person or horse or other`
  line animal.
obj_root_law_sections_87_footnotes:
  string
  line
obj_root_law_sections_88:
  sectionId (7311)
  sectionNo (88)
  orderNo 88
  title `Bathing or washing in places not set apart for those purposes.`
  content obj_root_law_sections_88_content
  footnotes obj_root_law_sections_88_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7311&sectionno=88&orderno=88&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_88_content:
  string
  line `No person shall bathe or wash`
  line `in, or by the side of, a public well, tank or reservoir not set apart for such purpose by order of the`
  line `competent authority, or in, or by the side of, any pond, pool, aqueduct, part of a river, stream, nullah or`
  line `other source or means of water supply in which such bathing or washing is forbidden by order of the`
  line `competent authority.`
obj_root_law_sections_88_footnotes:
  string
  line
obj_root_law_sections_89:
  sectionId (7312)
  sectionNo (89)
  orderNo 89
  title `Defiling water in public wells, etc.`
  content obj_root_law_sections_89_content
  footnotes obj_root_law_sections_89_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7312&sectionno=89&orderno=89&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_89_content:
  string
  line `No person shall defile or cause to be defiled the water in`
  line `any public well, tank, reservoir, pond, pool, aqueduct or part of a river, stream, nullah or other source or`
  line `means of water supply, so as to render the same less fit for any purpose for which it is set apart by the`
  line `order of the competent authority.`
obj_root_law_sections_89_footnotes:
  string
  line
obj_root_law_sections_90:
  sectionId (7313)
  sectionNo (90)
  orderNo 90
  title `Obstructing bathers.`
  content obj_root_law_sections_90_content
  footnotes obj_root_law_sections_90_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7313&sectionno=90&orderno=90&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_90_content:
  string
  line `No person shall obstruct or incommode a person bathing at a place set`
  line `apart for the purpose by the order of the competent authority under section 88 by wilful intrusion or by`
  line `using such place for any purpose for which it is not so set apart.`
obj_root_law_sections_90_footnotes:
  string
  line
obj_root_law_sections_91:
  sectionId (7314)
  sectionNo (91)
  orderNo 91
  title `Behaving indecently in public.`
  content obj_root_law_sections_91_content
  footnotes obj_root_law_sections_91_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7314&sectionno=91&orderno=91&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_91_content:
  string
  line `No person shall wilfully and indecently expose his person in`
  line `any street or public place or place of public resort or within sight of, and in such manner as to be seen`
  line `from, any street or public place or place of public resort, whether from within any house or building or`
  line `not, or use indecent language or behave indecently or riotously or in a disorderly manner in a street or`
  line `public place or place of public resort or in any office, police station or station house.`
obj_root_law_sections_91_footnotes:
  string
  line
obj_root_law_sections_92:
  sectionId (7315)
  sectionNo (92)
  orderNo 92
  title `Obstructing or annoying passengers in the street.`
  content obj_root_law_sections_92_content
  footnotes obj_root_law_sections_92_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7315&sectionno=92&orderno=92&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_92_content:
  string
  line `No person shall wilfully push, press, hustle`
  line `or obstruct any passenger in a street or public place or by violent movements, menacing gestures, wanton`
  line `personal annoyance, screaming, shouting, wilfully frightening horses or cattle or otherwise, disturb the`
  line `public peace or order.`
obj_root_law_sections_92_footnotes:
  string
  line
obj_root_law_sections_93:
  sectionId (7316)
  sectionNo (93)
  orderNo 93
  title `Misbehaviour with intent to provoke a breach of the peace.`
  content obj_root_law_sections_93_content
  footnotes obj_root_law_sections_93_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7316&sectionno=93&orderno=93&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_93_content:
  string
  line `No person shall use in any street`
  line `or public place any threatening, abusive or insulting words or behaviour with intent to provoke a breach`
  line `of the peace or whereby a breach of the peace may be occasioned.`
obj_root_law_sections_93_footnotes:
  string
  line
obj_root_law_sections_94:
  sectionId (7317)
  sectionNo (94)
  orderNo 94
  title `Prohibition against flying kites, etc.`
  content obj_root_law_sections_94_content
  footnotes obj_root_law_sections_94_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7317&sectionno=94&orderno=94&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_94_content:
  string
  line `No person shall fly a kite or any other thing so as to cause`
  line `danger, injury or alarm to persons, animals or property.`
obj_root_law_sections_94_footnotes:
  string
  line
obj_root_law_sections_95:
  sectionId (7318)
  sectionNo (95)
  orderNo 95
  title `Committing nuisance in or near street, etc.`
  content obj_root_law_sections_95_content
  footnotes obj_root_law_sections_95_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7318&sectionno=95&orderno=95&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_95_content:
  string
  line `No person shall in or near to any street, public`
  line `place or place of public resort—`
  line
  line `(a) commit a nuisance by easing himself; or`
  line
  line `(b) having the care or custody of any child under seven years of age, suffer such child to commit`
  line `a nuisance as aforesaid; or`
  line
  line `(c) spit or throw any dust, ashes, refuse or rubbish so as to cause annoyance to any passer-by.`
obj_root_law_sections_95_footnotes:
  string
  line
obj_root_law_sections_96:
  sectionId (7319)
  sectionNo (96)
  orderNo 96
  title `Disregard of notice in public building.`
  content obj_root_law_sections_96_content
  footnotes obj_root_law_sections_96_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7319&sectionno=96&orderno=96&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_96_content:
  string
  line `No person shall, in any court, police station, police`
  line `office or building occupied by Government or building occupied by any local body, smoke, or spit in`
  line `contravention of a notice, by the competent authority in charge of such place, displayed in such court,`
  line `police station, police office or building.`
obj_root_law_sections_96_footnotes:
  string
  line
obj_root_law_sections_97:
  sectionId (7320)
  sectionNo (97)
  orderNo 97
  title `Penalties for offences under sections 80 to 96.`
  content obj_root_law_sections_97_content
  footnotes obj_root_law_sections_97_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7320&sectionno=97&orderno=97&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_97_content:
  string
  line `Any person who contravenes any of the`
  line `provisions of sections 80 to 96 (both inclusive) shall, on conviction, be punished with fine which may`
  line `extend to one hundred rupees, or, in default of payment of such fine, with imprisonment for a term not`
  line `exceeding eight days.`
obj_root_law_sections_97_footnotes:
  string
  line
obj_root_law_sections_98:
  sectionId (7321)
  sectionNo (98)
  orderNo 98
  title `Penalty for failure to keep in confinement cattle, etc.`
  content obj_root_law_sections_98_content
  footnotes obj_root_law_sections_98_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7321&sectionno=98&orderno=98&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_98_content:
  string
  line `(1) Whoever allows any cattle which`
  line `are his property or in his charge to stray in any street or to trespass upon any public or private property`
  line `shall on conviction be punished`
  line
  line `(a) for the first offence, with imprisonment for a term which may extend to one month, or with`
  line `fine which may extend to three hundred rupees, or with both; and`
  line
  line `(b) for the second or subsequent offence, with imprisonment for a term which may extend to six`
  line `months, or with fine which may extend to five hundred rupees, or with both.`
  line
  line `(2) The Metropolitan Magistrate trying an offence under sub-section (1) may order`
  line
  line `(a) that the accused shall pay such compensation not exceeding two hundred and fifty rupees as`
  line `such Magistrate considers reasonable to any person for any damage proved to have been caused to his`
  line `property or the produce of his land by the cattle under the control of the accused trespassing on his`
  line `land; and`
  line
  line `(b) that the cattle in respect of which the offence has been committed shall be forfeited to the`
  line Government.
  line
  line `(3) Any compensation awarded under sub-section (2) may be recovered as if it were a fine imposed`
  line `under this section.`
  line
  line `(4) It shall be the duty of every police officer and it shall be lawful for any other person to seize and`
  line `take to any cattle pound for confinement therein any cattle found straying in any street or trespassing`
  line `upon any private or public property.`
  line
  line `(5) Any fine imposed under this section may, without prejudice to any other means of recovery`
  line `provided by law, be recovered by sale of all or any of the cattle in respect of which the offence was`
  line `committed, whether they are the property of the person convicted of the offence or were only in his`
  line `charge when the offence was committed.`
  line
  line `(6) Notwithstanding anything contained in the Code of Criminal Procedure, 1973 (2 of 1974), the`
  line `offence punishable under this section shall be cognizable.`
obj_root_law_sections_98_footnotes:
  string
  line
obj_root_law_sections_99:
  sectionId (7322)
  sectionNo (99)
  orderNo 99
  title `Punishment for cruelty to animals.`
  content obj_root_law_sections_99_content
  footnotes obj_root_law_sections_99_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7322&sectionno=99&orderno=99&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_99_content:
  string
  line `Whoever in any place cruelly beats, goads, overworks,`
  line `ill-treats or tortures or causes, or procures to be cruelly beaten, goaded, overworked, ill-treated or`
  line `tortured, any animal shall, on conviction, be punished with imprisonment which may extend to one`
  line `month, or with fine which may extend to one hundred rupees, or with both.`
obj_root_law_sections_99_footnotes:
  string
  line
obj_root_law_sections_100:
  sectionId (7323)
  sectionNo (100)
  orderNo 100
  title `Wilful trespass.`
  content obj_root_law_sections_100_content
  footnotes obj_root_law_sections_100_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7323&sectionno=100&orderno=100&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_100_content:
  string
  line `Whoever without satisfactory excuse wilfully enters or remains in or upon`
  line `any dwelling-house or premises or land or ground attached thereto, or on any ground, building,`
  line `monument or structure belonging to Government or used for public purposes, or on any vehicle, shall, on`
  line `conviction, whether he causes any actual damage or not, be punished with imprisonment which may`
  line `extend to seven days or with fine which may extend to one hundred rupees, or with both.`
obj_root_law_sections_100_footnotes:
  string
  line
obj_root_law_sections_101:
  sectionId (7324)
  sectionNo (101)
  orderNo 101
  title `False alarm of fire or damage to fire alarm.`
  content obj_root_law_sections_101_content
  footnotes obj_root_law_sections_101_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7324&sectionno=101&orderno=101&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_101_content:
  string
  line `Whoever knowingly gives or causes to be given`
  line `a false alarm of fire to the fire brigade of the Government or the Corporation or a municipality or to any`
  line `officer or fireman thereof, whether by means of a street fire alarm, statement, message or otherwise, or`
  line `with intent to give such false alarm wilfully breaks the glass of, or otherwise damages, a street fire alarm,`
  line `shall, on conviction, be punished with imprisonment for a term which may extend to three months or with`
  line `fine which may extend to one hundred rupees, or with both.`
obj_root_law_sections_101_footnotes:
  string
  line
obj_root_law_sections_102:
  sectionId (7325)
  sectionNo (102)
  orderNo 102
  title `Being found under suspicious circumstances between sunset and sunrise.`
  content obj_root_law_sections_102_content
  footnotes obj_root_law_sections_102_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7325&sectionno=102&orderno=102&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_102_content:
  string
  line `Whoever is`
  line `found between sunset and sunrise—`
  line
  line `(a) armed with any dangerous instrument with intent to commit an offence; or`
  line
  line `(b) having his face covered, or otherwise disguised with intent to commit an offence; or`
  line
  line `(c) in any dwelling-house or other building, or on any vehicle, without being able satisfactorily to`
  line `account for his presence there; or`
  line
  line `(d) lying or loitering in any street, yard or other place, being a reputed thief and without being`
  line `able to give a satisfactory account of himself; or`
  line
  line `(e) having in his possession without lawful excuse (the burden of proving which excuse shall be`
  line `on such person) any implement of house breaking,`
  line
  line `shall, on conviction, be punished with imprisonment for a term which may extend to three months.`
obj_root_law_sections_102_footnotes:
  string
  line
obj_root_law_sections_103:
  sectionId (7326)
  sectionNo (103)
  orderNo 103
  title `Possession of property of which no satisfactory account can be given.`
  content obj_root_law_sections_103_content
  footnotes obj_root_law_sections_103_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7326&sectionno=103&orderno=103&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_103_content:
  string
  line `Whoever has in his`
  line `possession or conveys in any manner, or offers for sale or pawn, anything which there is reason to believe`
  line `is stolen property or property fraudulently obtained, shall, if he fails to account for such possession or act`
  line `to the satisfaction of the Metropolitan Magistrate, on conviction, be punished with imprisonment for a`
  line `term which may extend to three months or with fine which may extend to one hundred rupees, or with`
  line both.
obj_root_law_sections_103_footnotes:
  string
  line
obj_root_law_sections_104:
  sectionId (7327)
  sectionNo (104)
  orderNo 104
  title `Omission by pawn-brokers, etc., to report to police possession or tender of property suspected to be stolen.`
  content obj_root_law_sections_104_content
  footnotes obj_root_law_sections_104_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7327&sectionno=104&orderno=104&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_104_content:
  string
  line `Whoever being a pawn-broker, dealer in second hand property, or worker in`
  line `metals, or reasonably believed by the Commissioner of Police to be such a person, and having received`
  line `from a police officer written or printed information in relation to any property suspected to have been`
  line `transferred by any offence mentioned in section 410 of the Indian Penal Code (45 of 1860) or by any`
  line `offence punishable under section 417, section 418, section 419 or section 420 of the said Code, is found`
  line `in possession, or, after the receipt of such information, comes into possession or has an offer, either by`
  line `way of sale, pawn, exchange, or for custody, alteration or otherwise, howsoever, made to him, of property`
  line `answering the description contained in such information, shall, unless—`
  line
  line `(i) he forthwith gives information to the Commissioner of Police, or at a police station of such`
  line `possession or offers and takes all reasonable means to ascertain and to give information as aforesaid`
  line `of the name and address of the person from whom the possession or offer was received, or`
  line
  line `(ii) the property, being an article of common wearing apparel or otherwise, is incapable of`
  line `identification from the written or printed information given and has been in no way concealed after`
  line `the receipt of such information,`
  line
  line `on conviction, be punished with fine which may extend to fifty rupees in respect of each such article of`
  line `property so in his possession or offered to him.`
obj_root_law_sections_104_footnotes:
  string
  line
obj_root_law_sections_105:
  sectionId (7328)
  sectionNo (105)
  orderNo 105
  title `Melting, etc., of property referred to in section 104.`
  content obj_root_law_sections_105_content
  footnotes obj_root_law_sections_105_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7328&sectionno=105&orderno=105&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_105_content:
  string
  line `Whoever having received such`
  line `information as is referred to in section 104 alters, melts, defaces or puts away or causes or suffers to be`
  line `altered, melted, defaced or put away, without the previous permission of the police, any such property as`
  line `is referred to in that section shall, on proof that the same was stolen property within the meaning of`
  line `section 410 of the Indian Penal Code (45 of 1860) or property in respect of which any offence punishable`
  line `under section 417, section 418, section 419 or section 420 of the said Code has been committed, be`
  line `punished with imprisonment for a term which may extend to three years or with fine, or with both.`
obj_root_law_sections_105_footnotes:
  string
  line
obj_root_law_sections_106:
  sectionId (7329)
  sectionNo (106)
  orderNo 106
  title `Taking pledge from child.`
  content obj_root_law_sections_106_content
  footnotes obj_root_law_sections_106_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7329&sectionno=106&orderno=106&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_106_content:
  string
  line `Whoever takes from any child, not appearing to be above the age`
  line `of fourteen years, any article whatsoever as a pawn, pledge or security for any sum of money lent,`
  line `advanced or delivered to such child or without the knowledge and consent of the owner of the article buys`
  line `from such child any article whatsoever, shall, on conviction, be punished with fine which may extend to`
  line `one hundred rupees.`
obj_root_law_sections_106_footnotes:
  string
  line
obj_root_law_sections_107:
  sectionId (7330)
  sectionNo (107)
  orderNo 107
  title `Suffering disorderly conduct at places of public amusement, etc.`
  content obj_root_law_sections_107_content
  footnotes obj_root_law_sections_107_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7330&sectionno=107&orderno=107&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_107_content:
  string
  line `Whoever, being the`
  line `keeper of any place of public amusement or public entertainment, knowingly permits or suffers`
  line `drunkenness or other disorderly behaviour or any gambling whatsoever, in such place, shall, on`
  line `conviction, be punished with fine which may extend to one hundred rupees.`
obj_root_law_sections_107_footnotes:
  string
  line
obj_root_law_sections_108:
  sectionId (7331)
  sectionNo (108)
  orderNo 108
  title `Cheating at games and gambling in street.`
  content obj_root_law_sections_108_content
  footnotes obj_root_law_sections_108_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7331&sectionno=108&orderno=108&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_108_content:
  string
  line `(1) Whoever by any fraud or unlawful device or`
  line `malpractice in playing at or with cards, dice or other game or in taking part in the stakes or wagers, or in`
  line `betting on the sides or hands of the players, or in wagering on the event of any game, sports, pastime or`
  line `exercise, wins from any other person, for himself or any other or others, any sum of money or valuable`
  line `thing, shall be deemed to have committed the offence of cheating within the meaning of section 415 of`
  line `the Indian Penal Code (45 of 1860), and be liable to punishment accordingly.`
  line
  line `(2) Whoever assembles with others, or joins any assembly, in a street assembled for the purpose of`
  line `gambling or wagering shall, on conviction, be punished with fine which may extend to fifty rupees or`
  line `may be released after a due admonition.`
obj_root_law_sections_108_footnotes:
  string
  line
obj_root_law_sections_109:
  sectionId (7332)
  sectionNo (109)
  orderNo 109
  title `Penalty for disobedience to order under section 27.`
  content obj_root_law_sections_109_content
  footnotes obj_root_law_sections_109_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7332&sectionno=109&orderno=109&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_109_content:
  string
  line `Whoever contravenes, disobeys,`
  line `opposes, or fails to conform to an order under section 27 requiring him to vacate any premises, shall, on`
  line `conviction be punished with imprisonment which may extend to three months or with fine which may`
  line `extend to five hundred rupees or with both.`
obj_root_law_sections_109_footnotes:
  string
  line
obj_root_law_sections_110:
  sectionId (7333)
  sectionNo (110)
  orderNo 110
  title `Penalty for contravening regulations, etc., under section 28.`
  content obj_root_law_sections_110_content
  footnotes obj_root_law_sections_110_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7333&sectionno=110&orderno=110&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_110_content:
  string
  line `Save as provided in`
  line `section 112, whoever contravenes, or abets the contravention of, any regulation made under section 28 or`
  line `any of the conditions of a licence issued under such regulation shall, on conviction, be punished—`
  line
  line `(a) if the regulation was made under clause (b) of sub-section (1) of section 28 providing for the`
  line `prohibition of the sale, or exposure for sale, of any goods on any street or portion thereof so as to`
  line `cause obstruction to traffic or inconvenience to the public—`
  line
  line `(i) for the first offence, with imprisonment for a term which may extend to one month, or`
  line `with fine which may extend to two hundred rupees, or with both, and`
  line
  line `(ii) for any subsequent offence, with imprisonment for a term which may extend to six`
  line `months and with fine which may extend to five hundred rupees;`
  line
  line `(b) if the regulation was made under clause (d), (h), (i), or (j), sub-clause (i) or (ii) of clause (s) or`
  line `clause (v) of sub-section (1) of section 28, with imprisonment for a term which may extend to eight`
  line `days, or with fine which may extend to fifty rupees, or with both;`
  line
  line `(c) if the regulation was made under clause (o) or (p) of sub-section (1) of section 28, with fine`
  line `which may extend to two hundred rupees; and`
  line
  line `(d) if the regulation was made under any clause of sub-section (1) of section 28 and for the`
  line `contravention of which no penalty is provided under clause (a), (b) or (c) of this section, with fine`
  line `which may extend to fifty rupees.`
obj_root_law_sections_110_footnotes:
  string
  line
obj_root_law_sections_111:
  sectionId (7334)
  sectionNo (111)
  orderNo 111
  title `Liability of licensee of place of public amusement or entertainment for acts of servants.`
  content obj_root_law_sections_111_content
  footnotes obj_root_law_sections_111_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7334&sectionno=111&orderno=111&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_111_content:
  string
  line `The holder of a licence granted under this Act in respect of a place of public amusement or public`
  line `entertainment shall be responsible, as well as the actual offender for any offence under section 110`
  line `committed by his servant or other agent acting with his express or implied permission on his behalf as if`
  line `he himself had committed the same, unless he establishes that all due and reasonable precautions were`
  line `taken by him to prevent the commission of such offence.`
obj_root_law_sections_111_footnotes:
  string
  line
obj_root_law_sections_112:
  sectionId (7335)
  sectionNo (112)
  orderNo 112
  title `Penalty for not obtaining licence in respect of place of public entertainment or certificate of registration in respect of eating house or for not renewing such licence or certificate within prescribed period.`
  content obj_root_law_sections_112_content
  footnotes obj_root_law_sections_112_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7335&sectionno=112&orderno=112&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_112_content:
  string
  line `(1) Whoever fails to obtain a licence under this Act in respect of a place of public`
  line `entertainment or a certificate of registration thereunder in respect of any eating house, or to renew the`
  line `licence or the certificate, as the case may be, within the prescribed period shall, on conviction, be`
  line `punished with fine which may extend to fifty rupees.`
  line
  line `(2) Any court trying any such offence shall in addition direct that the person keeping the place of`
  line `public entertainment, or the eating house, in respect of which the offence has been committed shall close`
  line `such place, or eating house until he obtains a licence or fresh licence, or a certificate of registration or`
  line `fresh certificate of registration, as the case may be, in respect thereof and thereupon such person shall`
  line `forthwith comply with such direction.`
  line
  line `(3) If the person fails to comply with any such direction, he shall, on conviction, be punished with`
  line `imprisonment for a term which may extend to one month or with fine which may extend to two hundred`
  line `rupees or with both.`
  line
  line `(4) Without prejudice to any action taken under sub-section (3), on the failure of such person to`
  line `comply with the direction of the court, any police officer authorised by the Commissioner of Police, by an`
  line `order in writing, may take or cause to be taken such steps and use or cause to be used such force as may,`
  line `in the opinion of such officer, be reasonably necessary for securing compliance with the courts direction.`
obj_root_law_sections_112_footnotes:
  string
  line
obj_root_law_sections_113:
  sectionId (7336)
  sectionNo (113)
  orderNo 113
  title `Penalties for contravention of orders, etc., under sections 29, 30, 31, 32, 33 and 34.`
  content obj_root_law_sections_113_content
  footnotes obj_root_law_sections_113_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7336&sectionno=113&orderno=113&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_113_content:
  string
  line `(1) Whoever contravenes, disobeys, opposes or fails to conform to any order given by a police`
  line `officer under section 29 shall, on conviction, be punished with fine which may extend to two hundred`
  line rupees.
  line
  line `(2) Whoever contravenes a notification or an order made under section 30, section 32, section 33 or`
  line `section 34 or abets the contravention thereof shall, on conviction, be punished—`
  line
  line `(a) if the said notification or order was made under sub-section (1) of section 30 or under`
  line `section 33 or section 34, with imprisonment for a term which shall not be less than four months but`
  line `which may extend to one year, and shall also be liable to fine:`
  line
  line `Provided that the court may, for adequate and sufficient reasons to be mentioned in the judgment,`
  line `impose a sentence of imprisonment for a term of less than four months;`
  line
  line `(b) if the said order was made under sub-section (2) of section 30, with imprisonment for a term`
  line `which may extend to one month, or with fine which may extend to one hundred rupees, or with both;`
  line
  line `(c) if the said notification was made under sub-section (3) of section 30, with fine which may`
  line `extend to one hundred rupees; or`
  line
  line `(d) if the said order was made under section 32, with imprisonment for a term which may extend`
  line `to three months, or with fine which may extend to five hundred rupees, or with both.`
  line
  line `(3) Whoever opposes or fails to conform to any direction given by a police officer under section 31,`
  line `shall, on conviction, be punished with fine which may extend to two hundred rupees.`
obj_root_law_sections_113_footnotes:
  string
  line
obj_root_law_sections_114:
  sectionId (7337)
  sectionNo (114)
  orderNo 114
  title `Penalty for contravention of regulations, etc., made under sections 35, 36 and 37.`
  content obj_root_law_sections_114_content
  footnotes obj_root_law_sections_114_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7337&sectionno=114&orderno=114&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_114_content:
  string
  line `Whoever contravenes, or abets the contravention of, any regulation, notice or order made under`
  line `section 35, section 36 or section 37 shall, on conviction, be punished with imprisonment which may`
  line `extend to three months, or with fine which may extend to two hundred rupees, or with both.`
obj_root_law_sections_114_footnotes:
  string
  line
obj_root_law_sections_115:
  sectionId (7338)
  sectionNo (115)
  orderNo 115
  title `Penalty for contravention of directions under section 46, 47 or 48.`
  content obj_root_law_sections_115_content
  footnotes obj_root_law_sections_115_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7338&sectionno=115&orderno=115&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_115_content:
  string
  line `Whoever opposes or`
  line `fails to conform to any direction issued under section 46, section 47 or section 48 or abets the opposition`
  line `to, or the failure to conform to, any such direction shall, on conviction, be punished with imprisonment`
  line `which shall not be less than four months but which may extend to one year and shall also be liable to fine:`
  line
  line `Provided that the court may, for adequate and special reasons to be mentioned in the judgment,`
  line `impose a sentence of imprisonment for a term of less than four months.`
obj_root_law_sections_115_footnotes:
  string
  line
obj_root_law_sections_116:
  sectionId (7339)
  sectionNo (116)
  orderNo 116
  title `Penalty for entering without permission area from which a person is directed to remove himself or overstaying when permitted to return temporarily.`
  content obj_root_law_sections_116_content
  footnotes obj_root_law_sections_116_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7339&sectionno=116&orderno=116&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_116_content:
  string
  line `Without prejudice to the power to`
  line `arrest and remove a person in the circumstances, and in the manner provided in section 53, any person`
  line who—
  line
  line `(a) in contravention of a direction issued to him under section 46, section 47 or section 48 enters`
  line `or returns without permission to Delhi, or any part thereof, as the case may be, from which he was`
  line `directed to remove himself; or`
  line
  line `(b) enters or returns to Delhi or any part thereof with permission granted under sub-section (1) of`
  line `section 54, but fails, contrary to the provisions thereof, to remove himself outside such area at the`
  line `expiry of the temporary period for which he was permitted to enter or return or on the earlier`
  line `revocation of such permission, or having removed himself at the expiry of such temporary period or`
  line `on revocation of the permission, enters or returns thereafter, without fresh permission,`
  line
  line `shall, on conviction, be punished with imprisonment for a term which shall not be less than six months`
  line `but which may extend to two years and shall also be liable to fine:`
  line
  line `Provided that the court may, for adequate and special reasons to be mentioned in the judgment,`
  line `impose a sentence of imprisonment for a term of less than six months.`
obj_root_law_sections_116_footnotes:
  string
  line
obj_root_law_sections_117:
  sectionId (7340)
  sectionNo (117)
  orderNo 117
  title `Penalty for contravention of orders under section 57.`
  content obj_root_law_sections_117_content
  footnotes obj_root_law_sections_117_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7340&sectionno=117&orderno=117&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_117_content:
  string
  line `Whoever contravenes any order made`
  line `under section 57 shall, on conviction, be punished with imprisonment for a term which may extend to`
  line `three years, or with fine, or with both.`
obj_root_law_sections_117_footnotes:
  string
  line
obj_root_law_sections_118:
  sectionId (7341)
  sectionNo (118)
  orderNo 118
  title `Penalty for opposing or not complying with direction given under clause (b) of sub-section (1) of section 59.`
  content obj_root_law_sections_118_content
  footnotes obj_root_law_sections_118_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7341&sectionno=118&orderno=118&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_118_content:
  string
  line `Whoever opposes or fails forthwith to comply with any reasonable`
  line `requisition made by a police officer under clause (b) of sub-section (1) of section 59, or abets the`
  line `opposition thereto or failure to comply therewith, shall, on conviction, be punished with imprisonment for`
  line `a term which shall not be less than four months but which may extend to one year and shall also be liable`
  line `to fine:`
  line
  line `Provided that the court may, for adequate and special reasons to be mentioned in the judgment,`
  line `impose a sentence of imprisonment for a term of less than four months.`
obj_root_law_sections_118_footnotes:
  string
  line
obj_root_law_sections_119:
  sectionId (7342)
  sectionNo (119)
  orderNo 119
  title `Penalty for contravening directions under section 65.`
  content obj_root_law_sections_119_content
  footnotes obj_root_law_sections_119_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7342&sectionno=119&orderno=119&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_119_content:
  string
  line `Whoever opposes or fails to conform`
  line `to any direction given by any police officer under section 65 or abets the opposition or failure to conform`
  line `to such direction shall, on conviction, be punished with fine which may extend to fifty rupees.`
obj_root_law_sections_119_footnotes:
  string
  line
obj_root_law_sections_120:
  sectionId (7343)
  sectionNo (120)
  orderNo 120
  title `Dangerous performances.`
  content obj_root_law_sections_120_content
  footnotes obj_root_law_sections_120_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7343&sectionno=120&orderno=120&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_120_content:
  string
  line `(1) No person shall without the previous permission of the`
  line `Commissioner of Police and except in accordance with any conditions subject to which such permission`
  line `is granted, hold or give in any place which is likely to cause an assembly of persons, any performance in`
  line `which or during which he buries himself under ground or seals himself in any room or receptacle or other`
  line `thing, in such manner as to prevent all access of air to him and for such time as would ordinarily result in`
  line `death by suffocation.`
  line
  line `(2) If any person contravenes or attempts to contravene the provisions of sub-section (1), he shall, on`
  line `conviction, be punished with imprisonment for a term which may extend to one year or with fine, or with`
  line both.
  line
  line `(3) Notwithstanding anything contained in the Code of Criminal Procedure, 1973 (2 of 1974), the`
  line `offence punishable under this section shall be cognizable.`
obj_root_law_sections_120_footnotes:
  string
  line
obj_root_law_sections_121:
  sectionId (7344)
  sectionNo (121)
  orderNo 121
  title `Neglect or refusal to serve as special police officer.`
  content obj_root_law_sections_121_content
  footnotes obj_root_law_sections_121_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7344&sectionno=121&orderno=121&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_121_content:
  string
  line `(1) Any person, who having been`
  line `appointed to be a special police officer under section 17 shall without sufficient cause neglect or refuse to`
  line `serve as such or to obey any lawful order or direction that may be given to him for the performance of his`
  line `duties as such special police officer, shall, on conviction, be punished with fine which may extend to fifty`
  line rupees.
  line
  line `(2) Such punishment shall automatically cancel the certificate of appointment of such a special police`
  line officer.
obj_root_law_sections_121_footnotes:
  string
  line
obj_root_law_sections_122:
  sectionId (7345)
  sectionNo (122)
  orderNo 122
  title `Penalty for making false statement, etc., and for misconduct of police officers.`
  content obj_root_law_sections_122_content
  footnotes obj_root_law_sections_122_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7345&sectionno=122&orderno=122&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_122_content:
  string
  line `(a) Any`
  line `person who makes a false statement or uses a false document for the purpose of obtaining employment or`
  line `release from employment as a police officer, or`
  line
  line `(b) any police officer who—`
  line
  line `(i) is guilty of cowardice, or`
  line
  line `(ii) being a police officer of subordinate rank, resigns his office or withdraws himself from dutie`
  line `thereof in contravention of section 25, or`
  line
  line `(iii) is guilty of any wilful breach or neglect of any provision of law or of any rule or regulation or`
  line `any order which he is bound to observe or obey, or`
  line
  line `(iv) is guilty of any violation of duty for which no punishment is expressly provided by any other`
  line `law in force,`
  line
  line `shall, on conviction, be punished with imprisonment for a term which may extend to three months, or`
  line `with fine which may extend to one hundred rupees, or with both.`
  line
  line `Explanation.—A police Officer who being absent on leave fails without reasonable cause to report`
  line `himself for duty on the expiration of such leave shall, for the purpose of sub-clause (ii) of clause (b), be`
  line `deemed to withdraw himself from the duties of his office within the meaning of section 25.`
obj_root_law_sections_122_footnotes:
  string
  line
obj_root_law_sections_123:
  sectionId (7346)
  sectionNo (123)
  orderNo 123
  title `Penalty for failure to deliver up certificate of appointment or other article.`
  content obj_root_law_sections_123_content
  footnotes obj_root_law_sections_123_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7346&sectionno=123&orderno=123&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_123_content:
  string
  line `Any police`
  line `officer, who wilfully neglects or refuses to deliver up his certificate of appointment or of office or any`
  line `other article, in accordance with the provisions of sub-section (1) of section 26 shall, on conviction, be`
  line `punished with imprisonment for a term which may extend to one month, or with fine which may extend to`
  line `two hundred rupees, or with both.`
obj_root_law_sections_123_footnotes:
  string
  line
obj_root_law_sections_124:
  sectionId (7347)
  sectionNo (124)
  orderNo 124
  title `Vexatious entry, search, arrest, etc., by police officer.`
  content obj_root_law_sections_124_content
  footnotes obj_root_law_sections_124_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7347&sectionno=124&orderno=124&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_124_content:
  string
  line `Any police officer who`
  line
  line `(a) without lawful authority or reasonable cause enters or searches, or causes to be entered or`
  line `searched, any building, vessel, tent or place; or`
  line
  line `(b) vexatiously and unnecessarily seizes the property of any person; or`
  line
  line `(c) vexatiously and unnecessarily detains, searches or arrests any person; or`
  line
  line `(d) offers any unnecessary personal violence to any person in his custody; or`
  line
  line `(e) holds out any threat or promise not warranted by law,`
  line
  line `shall, for every such offence, on conviction, be punished with imprisonment for a term which may extend`
  line `to six months, or with fine which may extend to five hundred rupees, or with both.`
obj_root_law_sections_124_footnotes:
  string
  line
obj_root_law_sections_125:
  sectionId (7348)
  sectionNo (125)
  orderNo 125
  title `Penalty for vexatious delay in forwarding a person arrested.`
  content obj_root_law_sections_125_content
  footnotes obj_root_law_sections_125_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7348&sectionno=125&orderno=125&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_125_content:
  string
  line `Any police officer who`
  line `vexatiously and unnecessarily delays the forwarding of any person arrested to a Magistrate or to any other`
  line `authority to whom he is legally bound to forward such person, shall, on conviction, be punished with`
  line `imprisonment for a term which may extend to six months, or with fine which may extend to five hundred`
  line `rupees, or with both.`
obj_root_law_sections_125_footnotes:
  string
  line
obj_root_law_sections_126:
  sectionId (7349)
  sectionNo (126)
  orderNo 126
  title `Penalty for unauthorised use of police uniforms.`
  content obj_root_law_sections_126_content
  footnotes obj_root_law_sections_126_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7349&sectionno=126&orderno=126&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_126_content:
  string
  line `If any persons not being a member of the`
  line `Delhi police wears, without the permission of an officer authorised by the Administrator in this behalf by`
  line `general or special order, the uniform of the Delhi police or any dress having the appearance or bearing any of the distinctive marks of that uniform, he shall, on conviction, be punished with fine which may`
  line `extend to two hundred rupees.`
obj_root_law_sections_126_footnotes:
  string
  line
obj_root_law_sections_127:
  sectionId (7350)
  sectionNo (127)
  orderNo 127
  title `Power to make regulations regarding carrying weapons without authority.`
  content obj_root_law_sections_127_content
  footnotes obj_root_law_sections_127_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7350&sectionno=127&orderno=127&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_127_content:
  string
  line `(1) The`
  line `Commissioner of Police may, by notification in the Official Gazette, make regulations to provide that no`
  line `person, other than a member of the armed forces of the Union acting as such or a police officer, shall go`
  line `armed with any sword, spear, bludgeon, gun or other offensive weapon or with any explosive or corrosive`
  line `substance in any street or public place unless so authorised by such authority as may be specified in such`
  line regulations.
  line
  line `(2) Any regulation made under sub-section (1) may provide that any person who goes armed in`
  line `contravention of such regulation shall be liable to be disarmed by any police officer and the weapon or`
  line `substance so seized shall be forfeited to the Government, unless redeemed within two months by payment`
  line `of such fine, not exceeding five hundred rupees, as the Commissioner of Police imposes.`
obj_root_law_sections_127_footnotes:
  string
  line
obj_root_law_sections_128:
  sectionId (7351)
  sectionNo (128)
  orderNo 128
  title `Prosecution for certain offences against this Act to be in the discretion of Delhi police.`
  content obj_root_law_sections_128_content
  footnotes obj_root_law_sections_128_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7351&sectionno=128&orderno=128&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_128_content:
  string
  line `It shall not, except in obedience to a rule, regulation or order made by the Administrator or by`
  line `the Commissioner of Police, be incumbent on the Delhi police to prosecute for an offence punishable`
  line `under section 97, section 104, sub-section (1) of section 113, section 114, section 119 or section 121`
  line `when such offence has not occasioned serious mischief and has been promptly desisted from on a warning`
  line `being given.`
obj_root_law_sections_128_footnotes:
  string
  line
obj_root_law_sections_129:
  sectionId (7352)
  sectionNo (129)
  orderNo 129
  title `Summary disposal of certain cases.`
  content obj_root_law_sections_129_content
  footnotes obj_root_law_sections_129_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7352&sectionno=129&orderno=129&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_129_content:
  string
  line `(1) A court taking cognizance of an offence punishable`
  line `under section 97, or under clause (a), (b) or (c) of section 110 may state upon the summons to be served`
  line `on the accused person that he may, by a specified date, prior to the hearing of the charge plead guilty to`
  line `the charge by registered letter and remit to the court such sum not exceeding one hundred rupees in the`
  line `case of an offence punishable under section 97 and in any other case rupees fifty, as the court may`
  line specify.
  line
  line `(2) Where an accused person pleads guilty and remits the sum specified in the summons, under`
  line `sub-section (1), no further proceedings in respect of the offence shall be taken against him.`
obj_root_law_sections_129_footnotes:
  string
  line
obj_root_law_sections_130:
  sectionId (7353)
  sectionNo (130)
  orderNo 130
  title `Prosecution for offences under other enactments not affected.`
  content obj_root_law_sections_130_content
  footnotes obj_root_law_sections_130_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7353&sectionno=130&orderno=130&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_130_content:
  string
  line `Subject to the provisions`
  line `contained in section 300 of the Code of Criminal Procedure, 1973 (2 of 1974), nothing in this Act shall be`
  line `construed to prevent any person from being prosecuted and punished under any other law for anything`
  line `made punishable by this Act or from being prosecuted and punished under this Act for anything made`
  line `punishable under any other law.`
obj_root_law_sections_130_footnotes:
  string
  line
obj_root_law_sections_131:
  sectionId (7354)
  sectionNo (131)
  orderNo 131
  title `Offences by companies.`
  content obj_root_law_sections_131_content
  footnotes obj_root_law_sections_131_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7354&sectionno=131&orderno=131&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_131_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed, was in charge of, and was responsible`
  line `to, the company for the conduct of the business of the company, as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line z
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act, if he proves that the offence was committed without his knowledge or`
  line `that he exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or that the commission of the offence is attributable to, any neglect on the part of any`
  line `director, manager, secretary or other officer of the company, such director, manager, secretary or other`
  line `officer shall also be deemed to be guilty of that offence and shall be liable to be proceeded against and`
  line `punished accordingly.`
  line
  line `Explanation.—For the purposes of this section,—`
  line
  line `(a) "company" means a body corporate, and includes a firm or other association of`
  line `individuals; and`
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_131_footnotes:
  string
  line
obj_root_law_sections_132:
  sectionId (7355)
  sectionNo (132)
  orderNo 132
  title `Disposal of fees, rewards, etc.`
  content obj_root_law_sections_132_content
  footnotes obj_root_law_sections_132_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7355&sectionno=132&orderno=132&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_132_content:
  string
  line `All fees paid for licences or permissions granted under this`
  line `Act, and all sums paid for the service of processes by police officers and all rewards, forfeitures and`
  line `penalties or shares thereof, which are by law payable to police officers as informers shall, save in so far as`
  line `any such fees or sums belong under the provisions of any enactment for the time being in force to any`
  line `local authority be credited to the Government:`
  line
  line `Provided that with the sanction of the Administrator or under any rule made by the Administrator in`
  line `that behalf, the whole or any portion of any such reward, forfeiture or penalty may for special services, be`
  line `paid to a police officer or be divided amongst two or more police officers.`
obj_root_law_sections_132_footnotes:
  string
  line
obj_root_law_sections_133:
  sectionId (7356)
  sectionNo (133)
  orderNo 133
  title `Method of proving orders and notifications.`
  content obj_root_law_sections_133_content
  footnotes obj_root_law_sections_133_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7356&sectionno=133&orderno=133&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_133_content:
  string
  line `Any order or notification published or issued`
  line `by the Administrator or by the Commissioner of Police or any other police officer under any provision of`
  line `this Act, and the due publication or issue thereof may be proved by the production of a copy thereof in the`
  line `Official Gazette, or of a copy thereof signed by the Administrator or Commissioner of Police or other`
  line `police officer, as the case may be, and by him certified to be a true copy of an original published or issued`
  line `according to the provisions of this Act applicable thereto.`
obj_root_law_sections_133_footnotes:
  string
  line
obj_root_law_sections_134:
  sectionId (7357)
  sectionNo (134)
  orderNo 134
  title `Rules, regulations or orders not invalidated by defect of form or irregularity in procedure.`
  content obj_root_law_sections_134_content
  footnotes obj_root_law_sections_134_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7357&sectionno=134&orderno=134&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_134_content:
  string
  line `No rule, regulation, order, direction, adjudication, inquiry or notification made or published`
  line `and no act done under any provision of this Act or any rule or regulation made under this Act, or in`
  line `substantial conformity with the same, shall be deemed illegal, void, invalid or insufficient by reason of`
  line `any defect of form or any irregularity of procedure.`
obj_root_law_sections_134_footnotes:
  string
  line
obj_root_law_sections_135:
  sectionId (7358)
  sectionNo (135)
  orderNo 135
  title `Presumption in prosecutions for contravention of order made under section 46, 47 or 48.`
  content obj_root_law_sections_135_content
  footnotes obj_root_law_sections_135_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7358&sectionno=135&orderno=135&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_135_content:
  string
  line `Notwithstanding anything contained in any law for the time being in force, in a prosecution for an offence`
  line `for the contravention of an order made under section 46, section 47 or section 48 on the production of an`
  line `authentic copy of the order, it shall, until the contrary is proved by the accused, be presumed—`
  line
  line `(a) that the order was made by the authority competent under this Act to make it;`
  line
  line `(b) that the authority making the order was satisfied that the grounds on, or the purpose for, which`
  line `it was made existed, and that it was necessary to make the same; and`
  line
  line `(c) that the order was otherwise valid and in conformity with the provisions of this Act.`
obj_root_law_sections_135_footnotes:
  string
  line
obj_root_law_sections_136:
  sectionId (7359)
  sectionNo (136)
  orderNo 136
  title `Officers holding charges of, or succeeding to, vacancies competent to exercise powers.`
  content obj_root_law_sections_136_content
  footnotes obj_root_law_sections_136_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7359&sectionno=136&orderno=136&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_136_content:
  string
  line `Whenever in consequence of the office of the Commissioner of Police, Additional Commissioner of`
  line `Police or any police officer becoming vacant, any officer holds charge of the post of such Commissioner`
  line `of Police, Additional Commissioner of Police or other police officer or succeeds, either temporarily or`
  line `permanently, to that post, such officer shall be competent to exercise all the powers and perform all the`
  line `duties respectively conferred and imposed by or under this Act on the Commissioner of Police or on such`
  line `Additional Commissioner of Police or other police officer, as the case may be.`
obj_root_law_sections_136_footnotes:
  string
  line
obj_root_law_sections_137:
  sectionId (7360)
  sectionNo (137)
  orderNo 137
  title `Forfeiture of bond entered into by person under sub-section (1) of section 54.`
  content obj_root_law_sections_137_content
  footnotes obj_root_law_sections_137_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7360&sectionno=137&orderno=137&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_137_content:
  string
  line `If any`
  line `person permitted to enter or return to the area from which he was directed to remove himself under`
  line `sub-section (1) of section 54, fails to observe any condition imposed under that sub-section or by the bond`
  line `executed by him thereunder, his bond shall be forfeited and any person bound thereby shall pay the`
  line `penalty thereof or show cause to the satisfaction of the court why such penalty should not be paid.`
obj_root_law_sections_137_footnotes:
  string
  line
obj_root_law_sections_138:
  sectionId (7361)
  sectionNo (138)
  orderNo 138
  title `No police officer to be liable to penalty or damage for act done in good faith in pursuance of duty.`
  content obj_root_law_sections_138_content
  footnotes obj_root_law_sections_138_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7361&sectionno=138&orderno=138&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_138_content:
  string
  line `No police officer shall be liable to any penalty or to payment of any damages on account of an`
  line `act done in good faith in pursuance of or purported to be done in pursuance of any duty imposed or any`
  line `authority conferred on him by any provision of this Act or any other law for the time being in force or any`
  line `rule, regulation, order or direction made or given thereunder.`
obj_root_law_sections_138_footnotes:
  string
  line
obj_root_law_sections_139:
  sectionId (7362)
  sectionNo (139)
  orderNo 139
  title `No public servant liable as aforesaid for giving effect in good faith to any rule, regulation, order or direction issued with apparent authority.`
  content obj_root_law_sections_139_content
  footnotes obj_root_law_sections_139_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7362&sectionno=139&orderno=139&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_139_content:
  string
  line `No public servant or person duly appointed or`
  line `authorised shall be liable to any penalty or to payment of any damages for giving effect in good faith to--`
  line
  line `(a) any order or direction issued with apparent authority by the Administrator or by a person`
  line `empowered in that behalf under this Act; or`
  line
  line `(b) any rule or regulation made under this Act.`
  line
  line `Explanation.-- In this section, the expression "public servant" has the meaning assigned to it in`
  line `section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_139_footnotes:
  string
  line
obj_root_law_sections_140:
  sectionId (7363)
  sectionNo (140)
  orderNo 140
  title `Bar to suits and prosecutions.`
  content obj_root_law_sections_140_content
  footnotes obj_root_law_sections_140_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7363&sectionno=140&orderno=140&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_140_content:
  string
  line `(1) In any case of alleged offence by a police officer or other`
  line `person, or of a wrong alleged to have been done by such police officer or other person, by any act done`
  line `under colour of duty or authority or in excess of any such duty or authority, or wherein it shall appear to`
  line `the court that the offence or wrong if committed or done was of the character aforesaid, the prosecution or`
  line `suit shall not be entertained and if entertained shall be dismissed if it is instituted, more than three months`
  line `after the date of the act complained of:`
  line
  line `Provided that any such prosecution against a police officer or other person may be entertained by the`
  line `court, if instituted with the previous sanction of the Administrator, within one year from the date of the`
  line offence.
  line
  line `(2) In the case of an intended suit on account of such a wrong as aforesaid, the person intending to sue`
  line `shall give to the alleged wrongdoer not less than one months notice of the intended suit with sufficient`
  line `description of the wrong complained of, and if no such notice has been given before the institution of the`
  line `suit, it shall be dismissed.`
  line
  line `(3) The plaint shall set forth that a notice as aforesaid has been served on the defendant and the date`
  line `of such service and shall state what tender or amends, if any, has been made by the defendant and a copy`
  line `of the said notice shall be annexed to the plaint endorsed or accompanied with a declaration by the`
  line `plaintiff of the time and manner of service thereof.`
obj_root_law_sections_140_footnotes:
  string
  line
obj_root_law_sections_141:
  sectionId (7364)
  sectionNo (141)
  orderNo 141
  title `Licences and written permissions to specify conditions, etc., and to be signed.`
  content obj_root_law_sections_141_content
  footnotes obj_root_law_sections_141_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7364&sectionno=141&orderno=141&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_141_content:
  string
  line `(1) Any`
  line `licence or written permission granted under the provisions of this Act shall specify the period and locality`
  line `for which, and the conditions and restrictions subject to which, the same is granted, and shall be given`
  line `under the signature of the competent authority.`
  line
  line `(2) Any licence or written permission granted under this Act may at any time be suspended or`
  line `revoked by the competent authority if any of its conditions or restrictions are infringed or evaded by the`
  line `person to whom it has been granted, or if such person is convicted of any offence with respect to any`
  line `matter to which such licence or permission relates.`
  line
  line `(3) When any such licence or written permission is suspended or revoked, or when the period for`
  line `which the same was granted has expired, the persons to whom the same was granted shall, for all`
  line `purposes of this Act, be deemed to be without a licence or written permission, until the order for`
  line `suspending or revoking the same is cancelled, or until the same is renewed, as the case may be.`
  line
  line `(4) Every person to whom any such licence or written permission has been granted shall, while the`
  line `same remains in force, at all reasonable times, produce the same, if so required by a police officer.`
  line
  line `Explanation.—For the purposes of this section any such infringement or evasion by, or conviction of,`
  line `a servant or other agent acting on behalf of the person to whom the licence or written permission has been`
  line `granted shall be deemed to be infringement or evasion or, as the case may be, conviction of, the person to`
  line `whom such licence or written permission has been granted.`
obj_root_law_sections_141_footnotes:
  string
  line
obj_root_law_sections_142:
  sectionId (7365)
  sectionNo (142)
  orderNo 142
  title `Public notices how to be given.`
  content obj_root_law_sections_142_content
  footnotes obj_root_law_sections_142_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7365&sectionno=142&orderno=142&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_142_content:
  string
  line `Any notification which may be publicly promulgated, public`
  line `notice required to be given, order required to be notified publicly or proclamation required to be issued`
  line `under any of the provisions of this Act shall be in writing, under the signature of a competent authority`
  line `and shall be published in the locality to be affected thereby, by affixing copies thereof in conspicuous`
  line `public places, or by proclaiming the same with beat of drums or by advertising, the same in such local newspapers in Hindi, Urdu and English, as the competent authority may deem fit, or by any two or more`
  line `of these means and by any other means it may think suitable.`
obj_root_law_sections_142_footnotes:
  string
  line
obj_root_law_sections_143:
  sectionId (7366)
  sectionNo (143)
  orderNo 143
  title `Consent, etc., of a competent authority may be proved by writing under its signature.`
  content obj_root_law_sections_143_content
  footnotes obj_root_law_sections_143_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7366&sectionno=143&orderno=143&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_143_content:
  string
  line `Whenever under this Act, the doing or the omitting to do anything or the validity of anything depends`
  line `upon the consent, approval, declaration, opinion or satisfaction of the competent authority, a written`
  line `document signed by the competent authority, purporting to convey or set forth such consent, approval,`
  line `declaration, opinion or satisfaction shall be sufficient evidence thereof.`
obj_root_law_sections_143_footnotes:
  string
  line
obj_root_law_sections_144:
  sectionId (7367)
  sectionNo (144)
  orderNo 144
  title `Signature on notices, etc., may be stamped.`
  content obj_root_law_sections_144_content
  footnotes obj_root_law_sections_144_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7367&sectionno=144&orderno=144&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_144_content:
  string
  line `Every licence, written permission, notice or`
  line `other document, not being a summons or warrant or search warrant, required by this Act or by any rule or`
  line `regulation made thereunder, to bear the signature of the Commissioner of Police, shall be deemed to be`
  line `properly signed if it bears a facsimile of his signature stamped thereon.`
obj_root_law_sections_144_footnotes:
  string
  line
obj_root_law_sections_145:
  sectionId (7368)
  sectionNo (145)
  orderNo 145
  title `Persons interested may seek to annul, reverse or alter any rule or order.`
  content obj_root_law_sections_145_content
  footnotes obj_root_law_sections_145_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7368&sectionno=145&orderno=145&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_145_content:
  string
  line `(1) In the case of`
  line `any rule or order made by the Administrator under an authority conferred by this Act and requiring the`
  line `public or a particular class of persons to perform some duty or act, or to conduct or order themselves or`
  line `those under their control in a manner therein described, it shall be competent for any person interested to`
  line `apply to the Administrator by a memorial to annul, reverse, or alter the rule or order aforesaid on the`
  line `ground of its being unlawful, oppressive or unreasonable.`
  line
  line `(2) After such an application as aforesaid and rejection thereof wholly or in part or after the lapse of`
  line `four months without an answer to such application or a decision thereon published by the Administrator,`
  line `it shall be competent for the person interested and deeming the rule or order to be contrary to law to`
  line `institute a suit in the principal civil court of original jurisdiction against the Administrator for a`
  line `declaration that the rule or order is unlawful either wholly or in part.`
  line
  line `(3) Where in any suit instituted under sub-section (2) or on appeal therefrom, the court adjudges a`
  line `rule or order to be unlawful, the rule or order shall be annulled or so altered as to make it conformable to`
  line law.
obj_root_law_sections_145_footnotes:
  string
  line
obj_root_law_sections_146:
  sectionId (7369)
  sectionNo (146)
  orderNo 146
  title `Powers of Commissioner of Police under other Acts.`
  content obj_root_law_sections_146_content
  footnotes obj_root_law_sections_146_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7369&sectionno=146&orderno=146&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_146_content:
  string
  line `(1) The Commissioner of Police shall`
  line `exercise all powers and discharge all functions which may be exercised or discharged by a District`
  line `Magistrate under the Acts mentioned in Schedule I including the rules made thereunder.`
  line
  line `(2) The Commissioner of Police may authorise any Additional Commissioner of Police, Deputy`
  line `Commissioner of Police or Additional Deputy Commissioner of Police to exercise any of the powers or`
  line `discharge any of the functions of the Commissioner of Police mentioned in sub-section (1) in accordance`
  line `with the general or special orders of the Administrator.`
  line
  line `(3) The powers and functions of a District Magistrate under the Sarais Act, 1867 (22 of 1867), shall`
  line `be exercised and discharged by the Administrator or such officer as the Administrator may, by`
  line `notification in the Official Gazette, authorise in this behalf.`
obj_root_law_sections_146_footnotes:
  string
  line
obj_root_law_sections_147:
  sectionId (7370)
  sectionNo (147)
  orderNo 147
  title `Power to make rules.`
  content obj_root_law_sections_147_content
  footnotes obj_root_law_sections_147_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7370&sectionno=147&orderno=147&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_147_content:
  string
  line `(1) The Administrator may make rules for carrying out the purposes of`
  line `this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:—`
  line
  line `(a) recruitment to, and the pay, allowance and all other conditions of service of the members of,`
  line `the Delhi police under clause (b) of section 5;`
  line
  line `(b) the manner of publication, under sub-section (2) of section 17, by the Commissioner of Police,`
  line `of the names of special police officers appointed under that section;`
  line
  line `(c) awarding of any of the punishments referred to in sub-section (1) or sub-section (2) of`
  line `section 21 to any police officer of subordinate rank;`
  line
  line `(d) procedure for awarding punishments under section 22;`
  line
  line `(e) form of Discharge Certificate under sub-section (8) of section 25;`
  line
  line `(f) determination of the cost of employing additional police under sub-section (2) of section 38;`
  line
  line `(g) manner of taking measurements and photographs under section 55 of a person against whom`
  line `an order has been made under section 46, section 47 or section 48;`
  line
  line `(h) manner of constituting Defence Societies under sub-section (1) of section 58;`
  line
  line `(i) form of receipt to be given in respect of any article detained under section 62;`
  line
  line `(j) the authority to whose satisfaction claims are to be established under sub-section (2) of`
  line `section 69 and the form and manner in which claims may be made under that sub-section, the`
  line `procedure for dealing with such claims and all other matters connected therewith under`
  line `sub-section(3) of that section;`
  line
  line `(k) payment to any police officer or division among two or more police officers the whole or any`
  line `portion of any reward, forfeiture or penalty, under the proviso to section 132;`
  line
  line `(l) any other matter which has to be, or may be, prescribed, or provided for by rules, under this`
  line Act.
obj_root_law_sections_147_footnotes:
  string
  line
obj_root_law_sections_148:
  sectionId (7371)
  sectionNo (148)
  orderNo 148
  title `Notification of rules and regulations in the Official Gazette and laying of rules and regulations.`
  content obj_root_law_sections_148_content
  footnotes obj_root_law_sections_148_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7371&sectionno=148&orderno=148&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_148_content:
  string
  line `(1) Every rule and regulation made under this Act shall be made by notification in the`
  line `Official Gazette.`
  line
  line `(2) Every rule and regulation made under this Act shall be laid, as soon as may be after it is made,`
  line `before each House of Parliament, while it is in session, for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or regulation, as the case may be, or both Houses agree that the rule or regulation`
  line `should not be made, the rule or regulation shall thereafter have effect only in such modified form or be of`
  line `no effect, as the case may be; so, however, that any such modification or annulment shall be without`
  line `prejudice to the validity of anything previously done under that rule or regulation.`
  line
  line `(3) Every rule and regulation made under this Act shall also be laid before the Metropolitan Council`
  line `of Delhi.`
obj_root_law_sections_148_footnotes:
  string
  line
obj_root_law_sections_149:
  sectionId (7372)
  sectionNo (149)
  orderNo 149
  title `Cesser of operation of certain enactments and savings.`
  content obj_root_law_sections_149_content
  footnotes obj_root_law_sections_149_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7372&sectionno=149&orderno=149&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_149_content:
  string
  line `(1) On the commencement of this`
  line `Act the enactments specified in Schedule II shall cease to be in force in Delhi;`
  line
  line `Provided that—`
  line
  line `(i) all rules and standing orders made (including the Punjab Police Rules, as in force in Delhi),`
  line `appointments made, powers conferred, orders made or passed, directions and certificates issued,`
  line `consent, permit, permission or licence given, summons or warrants issued or served, persons arrested`
  line `or detained or discharged on bail or bond, search warrants issued, bonds forfeited and penalties`
  line `incurred under any such enactment shall, in so far as they are consistent with this Act, be deemed to`
  line `have been respectively made, conferred, passed, given, issued, served, arrested, detained, discharged,`
  line `forfeited or incurred under this Act;`
  line
  line `(ii) all references in any enactment to any of the provisions of the enactments so ceasing to be in`
  line `force shall, in relation to Delhi, be construed as references to the corresponding provisions of this Act.`
  line
  line `(2) The cesser of operation under sub-section (1) of an enactment specified in Schedule II shall`
  line `not affect—`
  line
  line `(a) the validity, invalidity, effect or consequence of anything done or suffered to be done`
  line `thereunder before the commencement of this Act;`
  line
  line `(b) any right, privilege, obligation or liability already acquired, accrued or incurred thereunder`
  line `before such commencement;`
  line
  line `(c) any penalty, forfeiture or punishment incurred or inflicted in respect of any act thereunder`
  line `before such commencement;`
  line
  line `(d) any investigation, legal proceeding or remedy in respect of such right, privilege, obligation,`
  line `liability, penalty, forfeiture or punishment; or`
  line
  line `(e) any legal proceeding thereunder pending in any court or before any officer immediately before`
  line `such commencement or anything done or suffered to be done in the course of such proceedings, and`
  line `any such proceeding or any appeal or revisional proceedings arising out of such proceeding shall,`
  line `save as otherwise expressly provided in section 150 be instituted, continued or disposed of, as the`
  line `case may be, as if this Act had not been enacted.`
obj_root_law_sections_149_footnotes:
  string
  line
obj_root_law_sections_150:
  sectionId (7373)
  sectionNo (150)
  orderNo 150
  title `Police force functioning in Delhi immediately before the commencement of this Act to be deemed to be police force constituted under this Act.`
  content obj_root_law_sections_150_content
  footnotes obj_root_law_sections_150_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7373&sectionno=150&orderno=150&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_150_content:
  string
  line `Without prejudice to the provisions contained`
  line `in section 149,`
  line
  line `(a) the police force functioning in Delhi immediately before the commencement of this Act`
  line `(hereafter in this section referred to as the existing police force) shall, on such commencement, be`
  line `deemed to be police force constituted under this Act and every member of the existing police force`
  line `holding the office mentioned in column (1) of Schedule III, immediately before such commencement,`
  line `shall be deemed to be appointed, on such commencement, to the office mentioned in the`
  line `corresponding entry in column (2) of that Schedule;`
  line
  line `(b) all proceedings (including proceedings by way of investigations) pending before any police`
  line `officer of the existing police force, immediately before the commencement of this Act shall on such`
  line `commencement be deemed to be proceedings pending before him in his capacity as the holder of the`
  line `office to which he is deemed to be appointed under clause (a) and shall be dealt with accordingly;`
  line
  line `(c) where any power or function which may be exercised or discharged under any law by a`
  line `District Magistrate or Executive Magistrate immediately before the commencement of this Act has`
  line `been conferred on the Commissioner of Police or any other police officer by or under this Act, all`
  line `proceedings in relation to or arising from the exercise of such power or the discharge of such function`
  line `pending immediately before such conferment before the District Magistrate, or the Executive`
  line `Magistrate, as the case may be, shall, on the conferment of such power or function on the`
  line `Commissioner of Police or other police officer stand transferred to the Commissioner of Police or`
  line `other police officer, as the case may be, and the officer to whom such proceedings stand so`
  line `transferred shall either proceed de novo or from the stage of such transfer.`
obj_root_law_sections_150_footnotes:
  string
  line
obj_root_law_sections_151:
  sectionId (7374)
  sectionNo (151)
  orderNo 151
  title `Power to remove difficulties.`
  content obj_root_law_sections_151_content
  footnotes obj_root_law_sections_151_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7374&sectionno=151&orderno=151&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_151_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act in consequence of the transition to the said provisions from the provisions of the enactments`
  line `mentioned in Schedule II, the Central Government may, by notification in the Official Gazette, make such`
  line `provisions as appear to it to be necessary or expedient for removing the difficulty:`
  line
  line `Provided that no such notification shall be issued after the expiry of two years from the`
  line `commencement of this Act.`
  line
  line `(2) Every notification issued under this section shall, as soon as may be after it is issued, be laid`
  line `before each House of Parliament.`
obj_root_law_sections_151_footnotes:
  string
  line
obj_root_law_sections_152:
  sectionId (7375)
  sectionNo (152)
  orderNo 152
  title `Repeal and saving.`
  content obj_root_law_sections_152_content
  footnotes obj_root_law_sections_152_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00020_197834_1517807325264&sectionId=7375&sectionno=152&orderno=152&orgactid=AC_CEN_5_23_00020_197834_1517807325264
obj_root_law_sections_152_content:
  string
  line `(1) The Delhi Police Ordinance, 1978 (Ord. 2 of 1978) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the Ordinance so repealed`
  line `shall be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_152_footnotes:
  string
  line
