obj_root_law_sections_1:
  sectionId (43826)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes `1. The figures "1881" rep. by Act 12 of 1891, s. 2 and the First Schedule.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43826&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Presidency Small Cause Courts Act,`
  line `1882; and it shall come into force on the first day of July, 1882.`
  line
  line `But nothing herein contained shall affect the provisions of the Army Act, ^1`
  line `*** (44 & 45`
  line `Vict., c. 58) section 151, or the rights or liabilities of any person under any decree passed`
  line `before that day.`
obj_root_law_sections_2:
  sectionId (43827)
  sectionNo (2)
  orderNo 2
  title [Repealed.].
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43827&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_2_content:
  string
  line `[Repeal of enactments.]—Rep. by the Repealing Act, 1938 (1 of 1938), s. 2 and the`
  line Schedule.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (43828)
  sectionNo (3)
  orderNo 3
  title [Repealed.].
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43828&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_3_content:
  string
  line `[Amendment of Acts.]—Rep. by s. 2 and Schedule, ibid.`
  line 4.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (43829)
  sectionNo (4)
  orderNo 4
  title `“Small Cause Court” and “Registrar” defined.`
  content obj_root_law_sections_4_content
  footnotes `1. Added by Act 3 of 1899, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43829&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_4_content:
  string
  line `In this Act, "the Small Cause Court"`
  line `means the Court of Small Causes constituted under this Act in the town of Calcutta, Madras or Bombay,`
  line `as the case may be,`
  line ^1
  line `[and the expression "Registrar" includes a Deputy Registrar].`
obj_root_law_sections_5:
  sectionId (43830)
  sectionNo (5)
  orderNo 5
  title `Courts of Small Causes established.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43830&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_5_content:
  string
  line `There shall be in each of the towns of Calcutta,`
  line `Madras and Bombay a Court, to be called the Court of Small Causes of Calcutta, Madras or Bombay, as`
  line `the case may be.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (43831)
  sectionNo (6)
  orderNo 6
  title `Court to be deemed under superintendence, etc., of High Court.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43831&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_6_content:
  string
  line `The Small Cause Court`
  line `shall be deemed to be a Court subject to the superintendence of the High Court of Judicature at Fort.`
  line `William, Madras or Bombay, as the case may be, within the meaning of the Letters Patent,`
  line `respectively, dated the 28th day of December, 1865, for such High Courts, and within the meaning`
  line `of the ^1Code of Civil Procedure (14 of 1882) ^2`
  line `[and to be a court subordinate to the High Court`
  line `within the meaning of section 6 of the Legal Practitioners Act, 1879 (18 of 1879)], and the High`
  line `Court shall have, in respect of the Small Cause Court, the same powers as it has under the`
  line `twenty-fourth and twenty-fifth of Victoria, Chapter 104, section 15, in respect of Courts subject`
  line `to its appellate jurisdiction.`
obj_root_law_sections_6_footnotes:
  string
  line `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  line
  line `2. Ins. by Act 1 of 1895, s. 2.`
obj_root_law_sections_7:
  sectionId (43832)
  sectionNo (7)
  orderNo 7
  title `Appointment of Judges.`
  content obj_root_law_sections_7_content
  footnotes `1. Subs. by the A.O. 1937.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43832&sectionno=7&orderno=7&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_7_content:
  string
  line `^1[7. Appointment of Judges.—There shall be appointed from time to time a Chief Judge of the Small`
  line `Cause Court and as many other Judges as the State Government thinks fit.]`
obj_root_law_sections_8:
  sectionId (43833)
  sectionNo (8)
  orderNo 8
  title `Rank and precedence of Judges.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43833&sectionno=8&orderno=8&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_8_content:
  string
  line `The Chief Judge shall be the first of the Judges in rank and`
  line precedence.
  line
  line `The other Judges shall have rank and precedence as the State Government may, from time to time,`
  line direct.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_8_a:
  sectionId (43834)
  sectionNo 8A
  orderNo 9
  title `Performance of duties of absent Judge.`
  content obj_root_law_sections_8_a_content
  footnotes obj_root_law_sections_8_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43834&sectionno=8A&orderno=9&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_8_a_content:
  string
  line `^1[8A. Performance of duties of absent Judge.--(1) During any absence of the Chief Judge or`
  line `any Judge of the said Court, or during the period for which any Judge is acting as Chief Judge, the`
  line `State Government may appoint any person, having ^2[the requisite qualifications], to act as Chief`
  line `Judge or Judge of the said Court, as the case may be.`
  line
  line `(2) Every person so appointed shall be authorised to perform the duties of the Chief Judge or a`
  line `Judge of the said Court until the return of the absent Chief Judge or Judge, or of the Judge acting`
  line `as Chief Judge, or until the State Government sees cause to cancel the appointment of such acting`
  line `Chief Judge or Judges, as the case may be.]`
obj_root_law_sections_8_a_footnotes:
  string
  line `1. Subs. by Act 3 of 1899, s. 3, for section 8A.`
  line
  line `2. Subs. by the A.O. 1937.`
obj_root_law_sections_9:
  sectionId (43835)
  sectionNo (9)
  orderNo 10
  title `Procedure and practice of Small Cause Court.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43835&sectionno=9&orderno=10&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_9_content:
  string
  line `^1[9. Procedure and practice of Small Cause Court.--(1) The High Court may, from time to time, by`
  line `rules having the force of law,--`
  line
  line `(a) prescribe the procedure to be followed and the practice to be observed by the Small`
  line `Cause Court either in supersession of or in addition to any provisions which were prescribed`
  line `with respect to the procedure or practice of the Small Cause Court on or before the thirty-first`
  line `day of December, 1894, in or under this Act or any other enactment for the time being in`
  line `force; and`
  line
  line `^2[(aa) empower the Registrar to hear and dispose of undefended suits and interlocutory`
  line `applications or matters, and]`
  line
  line `(b) cancel or vary any such rule or rules.`
  line
  line `Rules made under this section may provide, among other matters, for the exercise by one or more of`
  line `the Judges of the Small Cause Court of any powers conferred on the Small Cause Court by this Act or any`
  line `other enactment for the time being in force.`
  line
  line `(2) The law, and any rules and declarations made, or purporting to be made, thereunder, with`
  line `respect to procedure or practice, in force or treated as in force in the Small Cause Court on the`
  line `thirty-first day of December, 1894, shall be in force, unless and until cancelled or varied by rules`
  line `made by the High Court under this section.]`
obj_root_law_sections_9_footnotes:
  string
  line `1. Subs. by Act 1 of 1895, s. 5, for section 9.`
  line
  line `2. Added by Act 3 of 1899, s. 4.`
obj_root_law_sections_10:
  sectionId (43836)
  sectionNo (10)
  orderNo 11
  title `Chief Judge to distribute business of Court.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43836&sectionno=10&orderno=11&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_10_content:
  string
  line `Subject to such rules, the Chief Judge may,`
  line `from time to time, make such arrangements as he thinks fit for the distribution of the business of`
  line `the Court among the various Judges thereof.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (43837)
  sectionNo (11)
  orderNo 12
  title `Procedure in case of difference of opinion.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43837&sectionno=11&orderno=12&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_11_content:
  string
  line `Save as hereinafter otherwise provided, when`
  line `two or more of the Judges sitting together differ on any question, the opinion of the majority shall`
  line `prevail; and if the Court is equally divided, the Chief Judge, if he is one of the Judges so differing,`
  line `or, in his absence, the Judge first in rank and precedence of the Judges so differing, shall have the`
  line `casting voice.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (43838)
  sectionNo (12)
  orderNo 13
  title `Seal to be used.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43838&sectionno=12&orderno=13&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_12_content:
  string
  line `The Small Cause Court shall use a seal of such form and dimensions as are for`
  line `the time being prescribed by the State Government.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (43839)
  sectionNo (13)
  orderNo 14
  title `Appointment of Registrar and other officers.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by the A.O. 1937, for s. 13.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43839&sectionno=13&orderno=14&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_13_content:
  string
  line `^1[13. Appointment of Registrar and other officers.—There shall be appointed an officer to be`
  line `called the Registrar of the Court who shall be the chief ministerial officer of the Court; there shall also be`
  line `appointed a Deputys Registrar and as many clerks, bailiffs and other ministerial officers as may be`
  line `necessary for the administration of justice by the Court and for the exercise and performance of the`
  line `powers and duties conferred and imposed on it by this Act or any other law for the time being in force.`
  line
  line `The Registrar and other officers so appointed shall exercise such powers and discharge such duties, of`
  line `a ministerial nature, as the Chief Judge may, from time to time, by rule direct.]`
obj_root_law_sections_14:
  sectionId (43840)
  sectionNo (14)
  orderNo 15
  title `Registrar may be invested with powers of a Judge in suits not exceeding twenty rupees.`
  content obj_root_law_sections_14_content
  footnotes `1. Added by Act 1 of 1895, S. 6.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43840&sectionno=14&orderno=15&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_14_content:
  string
  line `The State Government may invest the Registrar with the powers of a Judge under this Act for`
  line `the trial of suits in which the amount or value of the subject-matter does not exceed twenty rupees. And,`
  line `subject to the orders of the Chief Judge, any Judge of the Small Cause Court may, whenever he thinks fit,`
  line `transfer from his own file to the file of the Registrar any suit which the latter is competent to try.`
  line
  line ^1
  line `[Explanation.—For the purposes of this section an application for possession under section 41 shall`
  line `be deemed to be a suit.]`
obj_root_law_sections_15:
  sectionId (43841)
  sectionNo (15)
  orderNo 16
  title `Judge or other officer not to practise or trade.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43841&sectionno=15&orderno=16&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_15_content:
  string
  line `No Judge or other officer appointed`
  line `under this Act shall, during his continuance as such Judge or officer, either by himself or as a partner of`
  line `any other person, practise or act, either directly or indirectly, as an advocate, attorney, vakil or other legal`
  line `practitioner, or be concerned, either on his own account or for any other person, or as the partner of any`
  line `other person, in any trade or profession.`
  line
  line `Any such Judge or officer so practising, acting or concerned shall be deemed to have committed an`
  line `offence under section 168 of the Indian Penal Code (45 of 1860).`
  line
  line `Nothing herein contained shall be deemed to prohibit any such Judge or officer from being a member`
  line `of any company incorporated or registered under Royal Charter, Letters Patent, ^1`
  line `[Act of Parliament of the`
  line `United Kingdom or Central Act or Provincial Act or ^2`
  line `[State Act]].`
obj_root_law_sections_15_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for certain words.`
  line
  line `2. Subs. by the A.O. (No. 2) 1956, for "Act of the Legislature of a Part A State or a Part C State".`
obj_root_law_sections_16:
  sectionId (43925)
  sectionNo (16)
  orderNo 17
  title `Questions arising in suits, etc., under Act to he decided according to law administered by High Court.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43925&sectionno=16&orderno=17&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_16_content:
  string
  line `All questions, other than questions relating to procedure or practice,`
  line `which arise in suits or other proceedings under this Act in the Small Cause Court shall be dealt with and`
  line `determined according to the law for the time being administered by the High Court in the exercise of its`
  line `ordinary original civil jurisdiction.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (43843)
  sectionNo (17)
  orderNo 18
  title `Local limits of jurisdiction of Court.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43843&sectionno=17&orderno=18&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_17_content:
  string
  line `The local limits of the jurisdiction of each of`
  line `the Small Cause Courts shall be the local limits for the time being of the ordinary original civil`
  line `jurisdiction of the High Court.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (43844)
  sectionNo (18)
  orderNo 19
  title `Suits in which Court has jurisdiction.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43844&sectionno=18&orderno=19&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_18_content:
  string
  line `Subject to the exceptions in section 19,`
  line `the Small Cause Court shall have jurisdiction to try all suits of a civil nature—`
  line
  line `when the amount or value of the subject-matter does not exceed two thousand rupees; and—`
  line
  line `(a) the cause of action has arisen, either wholly or in part, within the local limits of the jurisdiction`
  line `of the Small Cause Court, and the leave of the Court has, for reasons to be recorded by it in writing,`
  line `been given before the institution of the suit; or`
  line
  line `(b) all the defendants, at the time of the institution of the suit, actually and voluntarily reside, or`
  line `carry on business, or personally work for gain, within such local limits; or`
  line
  line `(c) any of the defendants at the time of the institution of the suit, actually and voluntarily`
  line `resides, or carries on business, or personally works for gain, within such local limits, and either`
  line `the leave of the Court has been given before the institution of the suit, or the defendants who do`
  line `not reside, or carry on business, or personally work for gain, as aforesaid, acquiesce in such`
  line `institution:`
  line
  line ^1
  line `[Provided that where the cause of action has arisen wholly within the local limits aforesaid, and the`
  line `Court refuses to give leave for the institution of the suit, it shall record in writing its reason for such`
  line refusal.]
  line
  line `Explanation I.—When in any suit the sum claimed is, by a set-off admitted by both parties, reduced to`
  line `a balance not exceeding two thousand rupees, the Small Cause Court shall have jurisdiction to try such`
  line suit.
  line
  line `Explanation II.—Where a person has a permanent dwelling at one place and also a lodging at`
  line `another place for a temporary purpose only, he shall be deemed to reside at both places in respect of`
  line `any cause of action arising at the place where he has such temporary lodging.`
  line
  line `Explanation III.—A Corporation or Company shall be deemed to carry on business at its sole`
  line `or principal office in ^2`
  line `[India], or, in respect of any cause of action arising at any place where it`
  line `has also a subordinate office, at such place.`
obj_root_law_sections_18_footnotes:
  string
  line `1. Added by Act 1 of 1895, s. 7.`
  line
  line `2. Subs. by the A.O. (No. 2) 1956, for "a Part A State or a Part C State".`
obj_root_law_sections_18_a:
  sectionId (43845)
  sectionNo 18A
  orderNo 20
  title `Plaintiff may abandon suit against defendant resident out of jurisdiction.`
  content obj_root_law_sections_18_a_content
  footnotes `1. Added by Act 1 of 1895, s. 8.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43845&sectionno=18A&orderno=20&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_18_a_content:
  string
  line `^1[18A. Plaintiff may abandon suit against defendant resident out of jurisdiction.—The Small`
  line `Cause Court may allow a plaintiff at or before the first hearing of a suit in which a joint and several`
  line `liability is alleged on a cause of action arising either wholly or in part within the local limits of the`
  line `jurisdiction of the Court to abandon the suit as against any defendant who does not reside or carry on`
  line `business or personally work for gain within such local limits, and to sue for a decree against such`
  line `defendants only as do so reside, carry on business or personally work for gain.]`
obj_root_law_sections_19:
  sectionId (43846)
  sectionNo (19)
  orderNo 21
  title `Suits in which Court has no jurisdiction.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43846&sectionno=19&orderno=21&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_19_content:
  string
  line `The Small Cause Court shall have no jurisdiction`
  line in
  line
  line `(a) suits concerning the assessment or collection of the revenue;`
  line
  line `^1[(b) suits concerning any act done by or by order of the Central Government, ^2*** or the State`
  line Government;]
  line
  line `(c) suits concerning any act ordered or done by any Judge or judicial officer in the execution of his`
  line `office, or by any person in pursuance of any judgment or order of any Court or any such Judge or`
  line `judicial officer;`
  line
  line `(d) suits for the recovery of immovable property;`
  line
  line .
  line `(e) suits for the partition of immovable property;`
  line
  line `(f) suits for the foreclosure or redemption of a mortgage of immovable property;`
  line
  line `(g) suits for the determination of any other right to or interest in immovable property;`
  line
  line `(h) suits for the specific performance or rescission of contracts;`
  line
  line `(i) suits to obtain an injunction;`
  line
  line `(j) suits for the cancellation or rectification of instruments;`
  line
  line `(k) suits to enforce a trust;`
  line
  line `(l) suits for a general average loss and suits on policies of insurance on sea going vessels;`
  line
  line `(m) suits for compensation in respect of collisions on the high seas;`
  line
  line `(n) suits for compensation for the infringement of a patent, copyright or trade-mark;`
  line
  line `(o) suits for a dissolution of partnership or for an account of partnership-transactions;`
  line
  line `(p) suits for an account of property and its due administration under the decree of the Court;`
  line
  line `(q) suits for compensation for libel, slander, malicious prosecution, adultery or breach of promise`
  line `of marriage;`
  line
  line `(r) suits for the restitution of conjugal rights ^3`
  line `*** or for a divorce;`
  line
  line `(s) suits for declaratory decrees;`
  line
  line `(t) suits for possession of a hereditary office;`
  line
  line `(u) suits against Sovereign Princes or Ruling Chiefs, or against Ambassadors or Envoys of Foreign`
  line States;
  line
  line `(v) suits on any judgment of a High Court;`
  line
  line `(w) suits the cognizance whereof by the Small Cause Court is barred by any law for the time being`
  line `in force.`
obj_root_law_sections_19_footnotes:
  string
  line `1. Subs. by the A.O. 1937.`
  line
  line `2. The words "the Crown Representative" omitted by the A.O. 1950.`
  line
  line `3. The words "for the recovery of a wife" rep. by Act 10 of 1914, s. 3 and the Second Schedule`
obj_root_law_sections_19_a:
  sectionId (43847)
  sectionNo 19A
  orderNo 22
  title `Return of plaint.`
  content obj_root_law_sections_19_a_content
  footnotes obj_root_law_sections_19_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43847&sectionno=19A&orderno=22&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_19_a_content:
  string
  line `^1[19A. Return of plaint.—Whenever the Court finds that for want of jurisdiction it cannot`
  line `finally determine the question at issue in the suit, it may at any stage of the proceedings return the`
  line `plaint to be presented to a Court having jurisdiction to determine the question. When the Court so`
  line `returns a plaint, it shall comply with the provisions of the second paragraph of section 57 of the`
  line `^2Code of Civil Procedure (14 of 1882) and make such order with respect to costs as it may think`
  line `just, and the Court shall for the purposes of the Indian Limitation Act, 1877 (15 of 1877) be`
  line `deemed to have been unable to entertain the suit by reason of defect of jurisdiction. When a plaint`
  line `so returned is afterwards presented to a High Court, credit shall be given to the plaintiff for the`
  line `amount of the court-fee paid in the Small Cause Court in respect of the plaint in the levy of any`
  line `fees which according to the practice of the High Court are credited to the Government.]`
obj_root_law_sections_19_a_footnotes:
  string
  line `1. Added by Act 1 of 1895, s. 9.`
  line
  line `2. See now the relevant provision of the Code of Civil Procedure, 1908 (Act 5 of 1908).`
obj_root_law_sections_20:
  sectionId (43848)
  sectionNo (20)
  orderNo 23
  title `Court may by consent try suits beyond pecuniary limits of jurisdiction.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43848&sectionno=20&orderno=23&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_20_content:
  string
  line `When the`
  line `parties to a suit, which, if the amount or value of the subject-matter thereof did not exceed two`
  line `thousand rupees, would be cognizable by the Small Cause Court, have entered into an agreement in`
  line `writing that the Small Cause Court shall have jurisdiction to try such suit, the Court shall have`
  line `jurisdiction to try the same, although the amount or value of the subject-matter thereof may exceed`
  line `two thousand rupees.`
  line
  line `Every such agreement shall be filed in the Small Cause Court, and, when so filed, the parties to`
  line `it shall be subject to the jurisdiction of the Court, and shall be bound by its decision in such suit.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (43849)
  sectionNo (21)
  orderNo 24
  title `Suits by and against officers of Court.`
  content obj_root_law_sections_21_content
  footnotes `2. Ins. by Act 1 of 1895, s. 10.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43849&sectionno=21&orderno=24&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_21_content:
  string
  line `All suits to which an officer of the Small Cause`
  line `Court is, as such, a party, except suits in respect of property taken in execution of its process,`
  line `or the proceeds or value thereof ^1`
  line `[and all suits whereof the amount or value of the subjectmatter exceeds one thousand rupees] may be instituted in the High Court at the election of the`
  line `plaintiff as if this Act had not been passed.`
obj_root_law_sections_22:
  sectionId (43850)
  sectionNo (22)
  orderNo 25
  title `Costs when plaintiff sues in High Court in other cases cognizable by Small Cause Court.`
  content obj_root_law_sections_22_content
  footnotes `23. Subs. by s. 14, ibid., for "two thousand".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43850&sectionno=22&orderno=25&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_22_content:
  string
  line `If any suit cognizable by the Small Cause Court other than a suit to which section`
  line `21 applies, is instituted in the High Court, and if in such suit the plaintiff obtains, in the case`
  line `of a suit founded on contract, a decree for any matter of an amount or value less than ^1`
  line [one
  line `thousand] rupees, and in the case of any other suit a decree for any matter of an amount or`
  line `value of less than three hundred rupees, no costs shall be allowed to the plaintiff;`
  line
  line `and if in any such suit the plaintiff does not obtain a decree, the defendant shall be entitled to his costs as`
  line `between attorney and client.`
  line
  line `The foregoing rules shall not apply to any suit in which the Judge who tries the same certifies that it`
  line `was one fit to be brought in the High Court.`
obj_root_law_sections_23:
  sectionId (43926)
  sectionNo (23)
  orderNo 26
  title Repealed.
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43926&sectionno=23&orderno=26&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_23_content:
  string
  line `[Portions of Civil Procedure Code extending to Court.] Rep. by Presidency Small Cause`
  line `Courts Act 1 of 1895, s. 12.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (43927)
  sectionNo (24)
  orderNo 27
  title `No written statement except in cases of set-off.`
  content obj_root_law_sections_24_content
  footnotes `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43927&sectionno=24&orderno=27&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_24_content:
  string
  line `Except in cases of set-off under the`
  line `^1Code of Civil Procedure (14 of 1882), section 111, no written statement shall be received`
  line `unless required by the Court.`
obj_root_law_sections_25:
  sectionId (43852)
  sectionNo (25)
  orderNo 28
  title `Return of documents admitted in evidence.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43852&sectionno=25&orderno=28&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_25_content:
  string
  line `When a period of eight days from the`
  line `decision of a suit has expired without any application for a new trial or re-hearing of such`
  line `suit having been made, or when any such application has been made within such period and`
  line `such application has been refused, or the new trial or re-hearing (as the case may be) has`
  line `ended, any person, whether a party to the suit or not, desirous of receiving back any`
  line `document produced by him in the suit and placed on the record, shall, unless the document`
  line `is impounded under section 143 of the 3Code of Civil Procedure (14 of 1882), be entitled to`
  line `receive back the same:`
  line
  line `Provided that a document may be returned at any time before any of such events on such`
  line `terms as the Court may direct: provided also that no document shall be returned which, by`
  line `force of the decree, has become void or useless.`
  line
  line `On the return of a document which has been admitted in evidence, a receipt shall be`
  line `given, by the party receiving it, in a receipt-book to be kept for the purpose.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (43853)
  sectionNo (26)
  orderNo 29
  title `Compensation payable by plaintiff to defendant in certain cases.`
  content obj_root_law_sections_26_content
  footnotes `1Ins. by Act 4 of 1906, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43853&sectionno=26&orderno=29&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_26_content:
  string
  line `In any suit in which`
  line `the defendant appears and does not admit the claim, and the plaintiff does not obtain a decree for`
  line `the full amount of his claim, the Small Cause Court may in its discretion order the plaintiff to pay`
  line `to the defendant, by way of satisfaction for his trouble and attendance, such sum as it thinks fit.`
  line
  line `When any claim preferred, or objection made, under section 278 of the ^1Code of Civil`
  line `Procedure (14 of 1882), is disallowed, the Small Cause Court may in its discretion order the`
  line `person preferring or making such claim or objection to pay to the decree-holder, or to the`
  line `judgment-debtor, or to both by way of satisfaction as aforesaid, such sum or sums as it thinks`
  line fit.
  line
  line `And when any claim or objection is allowed the Court may award such compensation by way`
  line `of damages to the claimant or objector as it thinks fit; and the order of the Court awarding or refusing`
  line `such compensation—bar any suit in respect of injury caused by the attachment.`
  line
  line `Any order under this section may, in default of payment of the amount payable thereunder, be`
  line `enforced by the person in whose favour it is made against the person against whom it is made as if it were`
  line `a decree of the Court.`
obj_root_law_sections_27:
  sectionId (43854)
  sectionNo (27)
  orderNo 30
  title `Decree-holder to accompany officer executing warrant.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43854&sectionno=27&orderno=30&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_27_content:
  string
  line `Whenever the Small Cause`
  line `Court issues a warrant for the arrest of a judgment-debtor on the attachment of his property, the`
  line `decree-holder, or some other person on his behalf, shall accompany the officer of the Court`
  line `entrusted with the execution of such warrant, and shall point out to such officer the judgment-debtor`
  line `or the property to be attached, as the case may be.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (43928)
  sectionNo (28)
  orderNo 31
  title `Things attached to immovable property and removable by tenant to be deemed movable in execution.`
  content obj_root_law_sections_28_content
  footnotes `1. Ins. by Act 4 of 1906, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43928&sectionno=28&orderno=31&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_28_content:
  string
  line `When the judgment-debtor under any decree of the Small Cause Court is a tenant of`
  line `immovable property, anything attached to such property, and which he might before the termination of`
  line `his tenancy lawfully remove without the permission of his landlord, shall, for the purpose of the`
  line `execution of such decree ^1`
  line `and for the purpose of deciding all questions arising in the execution of`
  line `such decree], be deemed to be movable property, and may, if sold in such execution, be severed by the`
  line `purchaser, but shall not be removed by him from the property until he has done to the property`
  line `whatever the judgment-debtor would have been bound to do to it if he had removed such thing.`
obj_root_law_sections_29:
  sectionId (43856)
  sectionNo (29)
  orderNo 32
  title `Discharge of judgment-debtor on sufficient security.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43856&sectionno=29&orderno=32&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_29_content:
  string
  line `Whenever any judgment-debtor,`
  line `who has been arrested or whose property has been seized in execution of a decree of the Small`
  line `Cause Court, offers security to the satisfaction of such Court for payment of the amount which he`
  line `has been ordered to pay and the costs the Court may order him to be discharged or the property to`
  line `be released.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (43857)
  sectionNo (30)
  orderNo 33
  title `Court may in certain cases suspend execution of decree.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43857&sectionno=30&orderno=33&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_30_content:
  string
  line `Whenever it appears to the`
  line `Small Cause Court that any judgment-debtor under its decree is unable, from sickness, poverty or`
  line `other sufficient cause, to pay the amount of the decree, or, if such Court has ordered the same to be`
  line `paid in instalments, the amount of any instalment thereof, it may, from time to time, for such time`
  line `and upon such terms as it thinks fit, suspend the execution of such decree and discharge the debtor,`
  line `or make such order as it thinks fit.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (43858)
  sectionNo (31)
  orderNo 34
  title `Execution of decree of Small Cause Court by other Courts.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43858&sectionno=31&orderno=34&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_31_content:
  string
  line `If the judgment-debtor under`
  line `any decree of the Small Cause Court has not, within the local limits of its jurisdiction, movable`
  line `property sufficient to satisfy the decree, the Court may, on the application of the decree-holder, send`
  line `the decree for execution—`
  line
  line `(a) in the case of execution against immovable property situate within such local limits—^1`
  line `[to the`
  line `Madras City Civil Court or the High Court of Judicature at Fort William or Bombay, as the case may`
  line be];
  line
  line `(b) in all other cases—to any Civil Court within the local limits of whose jurisdiction such`
  line `judgment-debtor, or any movable or immovable property of such judgment-debtor, may be found.`
  line
  line `Procedure when decree transferred.—The procedure prescribed by the ^2Code of Civil Procedure`
  line `(14 of 1882) for the execution of decrees by Courts other than those which made them shall be the`
  line `procedure followed in such cases.`
obj_root_law_sections_31_footnotes:
  string
  line `1. Subs. by Act 7 of 1892, s. 12, for "to the high court".`
  line
  line `2. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
obj_root_law_sections_32:
  sectionId (43859)
  sectionNo (32)
  orderNo 35
  title `Minors may sue in certain cases as if of full age.`
  content obj_root_law_sections_32_content
  footnotes `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43859&sectionno=32&orderno=35&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_32_content:
  string
  line `Notwithstanding anything contained in the`
  line `^1Code of Civil Procedure (14 of 1882) as applied by this Act, any minor may institute a suit for any sum`
  line `of money, not exceeding five hundred rupees, which may be due to him under section 70 of the Indian Contract Act, 1872 (9 of 1872), for wages or piece work or for work as a servant, in the same manner as if`
  line `he were of full age.`
obj_root_law_sections_33:
  sectionId (43860)
  sectionNo (33)
  orderNo 36
  title `Power to delegate non-judicial duties.`
  content obj_root_law_sections_33_content
  footnotes `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43860&sectionno=33&orderno=36&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_33_content:
  string
  line `Any non-judicial or quasi-judicial act which the`
  line `^1Code of Civil Procedure (14 of 1882) as applied by this Act requires to be done by a Judge, and`
  line `any act which may be done by a Commissioner appointed to examine and adjust accounts under`
  line `section 394 of that Code as so applied, may be done by the Registrar of the Small Cause Court or`
  line `by such other officer of that Court as that Court may, from time to time, appoint in this behalf.`
  line
  line `The High Court may, from time to time, by rule, declare what shall be deemed to be non-judicial and`
  line `quasi-judicial acts within the meaning of this section.`
obj_root_law_sections_34:
  sectionId (43861)
  sectionNo (34)
  orderNo 37
  title `Registrar to hear and determine suits like a Judge.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43861&sectionno=34&orderno=37&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_34_content:
  string
  line `The suits cognizable by the Registrar`
  line `under section 14 shall be heard and determined by him in like manner in all respects as a Judge of the`
  line `Court might hear and determine the same:`
  line
  line `Proviso.—Provided that, subject to the control of the Chief Judge, any Judge of the Court may,`
  line `whenever he thinks fit, transfer to his own file any suit on the file of the Registrar.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (43862)
  sectionNo (35)
  orderNo 38
  title `Registrar may execute all decrees with the same powers as a Judge.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43862&sectionno=35&orderno=38&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_35_content:
  string
  line `The Registrar may`
  line `receive applications for the execution of decrees of any value passed by the Court, and may commit and`
  line `discharge judgment-debtors, and make any order in respect thereof which a Judge of the Court might`
  line `make under this Act.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (43863)
  sectionNo (36)
  orderNo 39
  title `Decrees and orders of Registrar to be subject to new trial as if made by a Judge.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43863&sectionno=36&orderno=39&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_36_content:
  string
  line Every
  line `decree and order made by the Registrar in any suit or proceeding shall be subject to the same provisions`
  line `in regard to new trial as if made by a Judge of the Court.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (43864)
  sectionNo (37)
  orderNo 40
  title `General finality of decrees and orders of Small Cause Court.`
  content obj_root_law_sections_37_content
  footnotes `1. Subs. by Act 1 of 1895, s. 13, for Chapter VI.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43864&sectionno=37&orderno=40&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_37_content:
  string
  line `^1[37. General finality of decrees and orders of Small Cause Court--Save as otherwise provided by`
  line `this Chapter or by any other enactment for the time being in force, every decree and order of the Small`
  line `Cause Court in a suit shall be final and conclusive.]`
obj_root_law_sections_38:
  sectionId (43865)
  sectionNo (38)
  orderNo 41
  title `New trial of contested cases.`
  content obj_root_law_sections_38_content
  footnotes `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43865&sectionno=38&orderno=41&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_38_content:
  string
  line `^1[38. New trial of contested cases.-- Where a suit has been contested, the Small Cause Court may,`
  line `on the application of either party, made within eight days from the date of the decree or order in the`
  line `suit (not being a decree passed under section 522 of the ^1Code of Civil Procedure (14 of 1882), order`
  line `a new trial to be held, or alter, set aside or reverse the decree or order, upon such terms as it thinks`
  line `reasonable, and may, in the meantime, stay the proceedings.`
  line
  line `Explanation.-- Every suit shall be deemed to be contested in which the decree is made otherwise than`
  line `by consent of or in default of appearance by the defendant.]`
obj_root_law_sections_39:
  sectionId (43866)
  sectionNo (39)
  orderNo 42
  title `Removal of certain causes into High Court.`
  content obj_root_law_sections_39_content
  footnotes `1. Subs. by Act 4 of 1906, s. 3, for sub-section (2).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43866&sectionno=39&orderno=42&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_39_content:
  string
  line `^1[39. Removal of certain causes into High Court.-- (1) In any suit instituted in a Small Cause`
  line `Court in which the amount of value of the subject-matter exceeds the sum of one thousand rupees,`
  line `the defendant or any one of the defendants may, before the day fixed by the summons for the`
  line `appearance of the defendant or within eight days after the service of the summons on him, whichever`
  line `period shall last expire, apply ex parte on an affidavit setting forth the facts on which he relies for his`
  line `defence to a Judge of the High Court for an order removing the cause into the High Court.`
  line
  line `^1[(2) Unless the Judge is of opinion that the application has been made solely for the purpose of delay,`
  line `the applicant shall be entitled to such order as of right:`
  line
  line `Provided that the removal directed by such order shall, unless the Judge otherwise directs, be`
  line `conditional upon the applicant giving security, to the approval of the Judge, within a reasonable time to be`
  line `prescribed in the order for the payment of the amount claimed and of the costs which may become`
  line `payable by him to the plaintiff in respect of the said suit.]`
  line
  line `(3) If the applicant fail or neglect to complete the required security (if any) within the prescribed time`
  line `(if any), the said order shall be discharged and the suit shall proceed in the Small Cause Court as if such`
  line `order had never been made.`
  line
  line `(4) If the plaintiff in any case which has been removed under this section into the High Court has`
  line `abandoned a portion of his claim in order to be able to bring the suit within the jurisdiction of a Small`
  line `Cause Court, he shall be permitted to revive the portion of his claim so abandoned.]`
obj_root_law_sections_40:
  sectionId (43867)
  sectionNo (40)
  orderNo 43
  title `Rules with respect to suits removed under the last foregoing section.`
  content obj_root_law_sections_40_content
  footnotes `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43867&sectionno=40&orderno=43&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_40_content:
  string
  line `^1[40. Rules with respect to suits removed under the last foregoing section.--(1) When a suit`
  line `has been removed into the High Court under the last foregoing section, it shall be heard and disposed of`
  line `by such Court in the exercise of its original jurisdiction, and the said Court shall have all the same powers`
  line `and jurisdiction in respect thereof as if it had been originally instituted such Court.`
  line
  line `(2) In every suit so removed as aforesaid the affidavit filed under section 39, sub-section (1), shall be`
  line `treated as a written statement of the defendant tendered under section 110 of the ^1Code of Civil Procedure`
  line `(14 of 1882), unless the Court shall otherwise order.`
  line
  line `(3) In every suit so removed as aforesaid credit shall be given to the plaintiff for the amount of the`
  line `court-fee paid in the Small Cause Court in respect of the plaint in the levy of any fees which according to`
  line `the practice of the High Court are payable to the Government.]`
obj_root_law_sections_41:
  sectionId (43868)
  sectionNo (41)
  orderNo 44
  title `Summons against person occupying property without leave.`
  content obj_root_law_sections_41_content
  footnotes `1. Subs. by Act 9 of 1912, s. 2, for "one".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43868&sectionno=41&orderno=44&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_41_content:
  string
  line `When any person has`
  line `had possession of any immovable property situate within the local limits of the Small Cause`
  line `Court's jurisdiction and of which the annual value at a rack-rent does not exceed`
  line `^1[two] thousand`
  line `rupees, as the tenant, or by permission, of another person, or of some person through whom such`
  line `other person claims,`
  line
  line `and such tenancy or permission has determined or been withdrawn,`
  line
  line `and such tenant or occupier or any person holding under or by assignment from him (hereinafter called`
  line `the occupant) refuses to deliver up such property in compliance with a request made to him in this behalf`
  line `by such other person,`
  line
  line `such other person (hereinafter called the applicant) may apply to the Small Cause Court for a`
  line `summons against the occupant, calling upon him to show cause, on a day therein appointed, why he`
  line `should not be compelled to deliver up the property.`
obj_root_law_sections_42:
  sectionId (43869)
  sectionNo (42)
  orderNo 45
  title `Service of summons.`
  content obj_root_law_sections_42_content
  footnotes `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43869&sectionno=42&orderno=45&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_42_content:
  string
  line `The summons shall be served on the occupant in the manner`
  line `provided by the ^1Code of Civil Procedure (14 of 1882) for the service of a summons on a defendant.`
obj_root_law_sections_43:
  sectionId (43870)
  sectionNo (43)
  orderNo 46
  title `Order for possession.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43870&sectionno=43&orderno=46&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_43_content:
  string
  line `If the occupant does not appear at the time appointed and show cause`
  line `to the contrary, the applicant shall, if the Small Cause Court is satisfied that he is entitled to apply under`
  line `section 41, be entitled to an order addressed to a bailiff of the Court directing him to give possession of`
  line `the property to the applicant on such day as the Court thinks fit to name in such order.`
  line
  line `Explanation.—If the occupant proves that the tenancy was created or permission granted by virtue of`
  line `a title which determined previous to the date of the application, he shall be deemed to have shown cause`
  line `within the meaning of this section.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (43871)
  sectionNo (44)
  orderNo 47
  title `Such order to justify bailiff entering on property and giving possession.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43871&sectionno=44&orderno=47&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_44_content:
  string
  line `Any such order`
  line `shall justify the bailiff to whom it is addressed in entering after the hour of six in the morning and before`
  line `the hour of six in the afternoon upon the property named therein, with such assistants, as he thinks`
  line `necessary, and giving possession of such property to the applicant: and no suit or prosecution shall be`
  line `maintainable against any Judge or officer of the Small Cause Court by whom any such order as aforesaid`
  line `was issued, or against any bailiff or other person by whom the same was executed, or by whom any such`
  line `summons as aforesaid was served, for the issue, execution or service of any such order or summons, by`
  line `reason only that the applicant was not entitled to the possession of the property.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (43872)
  sectionNo (45)
  orderNo 48
  title `Applicant, if entitled to possession, not to be deemed trespasser for any error in proceedings.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43872&sectionno=45&orderno=48&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_45_content:
  string
  line `When the applicant, at the time of`
  line `applying for any such order as aforesaid, was entitled to the possession of such property, neither he nor`
  line `any person acting in his behalf shall be deemed, on account of any error, defect or irregularity in the mode`
  line `of proceeding to obtain possession thereunder, to be a trespasser; but any person aggrieved may bring a`
  line `suit for the recovery of compensation for any damage which he has sustained by reason of such error,`
  line `defect or irregularity:`
  line
  line `when no such damage is proved, the suit shall be dismissed; and when such damage is proved but the`
  line `amount of the compensation assessed by the Court does not exceed ten rupees, the Court shall award to`
  line `the plaintiff no more costs than compensation, unless the Judge who tries the case certifies that in his`
  line `opinion full costs should be awarded to the plaintiff.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (43873)
  sectionNo (46)
  orderNo 49
  title `Liability of applicant obtaining order when not entitled.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43873&sectionno=46&orderno=49&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_46_content:
  string
  line `Nothing herein contained`
  line `shall be deemed to protect any applicant obtaining possession of any property under this Chapter from a`
  line `suit by any person deeming himself aggrieved thereby, when such applicant was not at the time of`
  line `applying for such order as aforesaid entitled to the possession of such property.`
  line
  line `Application for order in such case an act of trespass.—And when the applicant was not,`
  line `at the time of applying for any such order as aforesaid, entitled to the possession of such property, the`
  line `application for such order, though no possession is taken thereunder, shall be deemed to be an act of`
  line `trespass committed by the applicant against the occupant.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (43874)
  sectionNo (47)
  orderNo 50
  title `Stay of proceedings on occupant giving security to bring suit against applicant.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43874&sectionno=47&orderno=50&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_47_content:
  string
  line `Whenever on an application being made under section 41 the occupant binds himself, with`
  line `two sureties, in a bond for such amount as the Small Cause Court thinks reasonable, having regard to the`
  line `value of the property and the probable costs of the suit next hereinafter mentioned, to institute without`
  line `delay a suit in the High Court against the applicant for compensation for trespass and to pay all the costs`
  line `of such suit in case he does not prosecute the same or in case judgment therein is given for the applicant,`
  line `the Small Cause Court shall stay the proceedings on such application until such suit is disposed of.`
  line
  line `If the occupant obtains a decree in any such suit against the applicant, such decree shall supersede the`
  line `order (if any) made under section 43.`
  line
  line `Nothing contained in section 22 shall apply to suits under this section.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (43875)
  sectionNo (48)
  orderNo 51
  title `Proceedings to be regulated by Code of Civil Procedure.`
  content obj_root_law_sections_48_content
  footnotes `1. See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43875&sectionno=48&orderno=51&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_48_content:
  string
  line `In all proceedings under`
  line `this Chapter, the Small Cause Court shall, as far as may be and except as herein otherwise provided,`
  line `follow the procedure prescribed for a Court of first instance by the ^1Code of Civil Procedure (14 of 1882).`
obj_root_law_sections_49:
  sectionId (43876)
  sectionNo (49)
  orderNo 52
  title `Recovery of possession no bar to suit to try title.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43876&sectionno=49&orderno=52&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_49_content:
  string
  line `Recovery of the possession of any`
  line `immovable property under this Chapter shall be no bar to the institution of a suit in the High Court for`
  line `trying the title thereto.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (43877)
  sectionNo (50)
  orderNo 53
  title `Local extent of Chapter.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43877&sectionno=50&orderno=53&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_50_content:
  string
  line `This Chapter extends to every place`
  line `within the local limits of the ordinary original civil jurisdictions of the High Courts of Judicature`
  line `at Fort William, Madras and Bombay. But nothing contained in this Chapter applies—`
  line
  line `(a) to any rent due to Government;`
  line
  line `(b) to any rent which has been due for more than twelve months before the application mentioned`
  line `in section 53.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (43878)
  sectionNo (51)
  orderNo 54
  title `Appointment of bailiffs and appraisers.`
  content obj_root_law_sections_51_content
  footnotes `1. Subs. by the A.O. 1937, for section 51.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43878&sectionno=51&orderno=54&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_51_content:
  string
  line `^1[51. Appointment of bailiffs and appraisers.— Four or more persons shall be appointed`
  line `bailiffs and appraisers for the purposes of this Chapter.]`
obj_root_law_sections_52:
  sectionId (43879)
  sectionNo (52)
  orderNo 55
  title `Appointees to be public servants.`
  content obj_root_law_sections_52_content
  footnotes `1. Certain words omitted, ibid.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43879&sectionno=52&orderno=55&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_52_content:
  string
  line `The persons so appointed ^1`
  line `*** shall be deemed to be`
  line `public servants within the meaning of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_53:
  sectionId (43880)
  sectionNo (53)
  orderNo 56
  title `Application for distress-warrant.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43880&sectionno=53&orderno=56&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_53_content:
  string
  line `Any person claiming to be entitled to arrears of rent of`
  line `any house or premises to which this Chapter extends, or his duly constituted attorney, may apply to any`
  line `Judge of the Small Cause Court, or to the Registrar of the Small Cause Court, for such warrant as is`
  line `hereinafter mentioned.`
  line
  line `The application shall be supported by an affidavit or affirmation to the effect of the form (marked A)`
  line `in the Third Schedule hereto annexed.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (43881)
  sectionNo (54)
  orderNo 57
  title `Issue of distress-warrant.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43881&sectionno=54&orderno=57&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_54_content:
  string
  line `The Judge or Registrar may thereupon issue a warrant under his`
  line `hand and seal and returnable within six days, to the effect of the form (marked B) contained in the same`
  line `Schedule, addressed to any one of such bailiffs.`
  line
  line `The Judge or Registrar may at his discretion, upon personal examination of the person applying for`
  line `such warrant, decline to issue the same.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (43882)
  sectionNo (55)
  orderNo 58
  title `Time for distress.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43882&sectionno=55&orderno=58&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_55_content:
  string
  line `Every distress under this Chapter shall be made after sunrise and before`
  line `sunset, and not at any other time.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (43883)
  sectionNo (56)
  orderNo 59
  title `What places bailiff may force open.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43883&sectionno=56&orderno=59&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_56_content:
  string
  line `The bailiff directed to make the distress may force`
  line `open any stable, outhouse or other building, and may also enter any dwelling-house, the outer door of`
  line `which may be open, and may break open the door of any room in such dwelling-house for the purpose of`
  line `seizing property liable to be seized under this Chapter:`
  line
  line `Provided that he shall not enter or break open the door of any room appropriated for the zenana or`
  line `residence of woman, which by the usage of the country is considered private.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (43884)
  sectionNo (57)
  orderNo 60
  title `Property which may be seized.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43884&sectionno=57&orderno=60&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_57_content:
  string
  line `In pursuance of the warrant aforeasaid, the bailiff shall seize`
  line `the movable property found in or upon the house or premises mentioned in the warrant and belonging to`
  line `the person from whom the rent is claimed (hereinafter called the debtor), or such part thereof as may, in`
  line `the bailiff’s judgment, be sufficient to cover the amount of the said rent, together with the costs of the said`
  line `distress:`
  line
  line `Provided that the bailiff shall not seize—`
  line
  line `(a) things in actual use; or`
  line
  line `(b) tools and implements not in use, where there is other movable property in or upon the house or`
  line `premises sufficient to cover such amount and costs; or`
  line
  line `(c) the debtor’s necessary wearing apparel; or`
  line
  line `(d) goods in the custody of the law.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (43885)
  sectionNo (58)
  orderNo 61
  title `Impounding distress.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43885&sectionno=58&orderno=61&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_58_content:
  string
  line `The bailiff may impound or otherwise secure the property so seized`
  line `in or on the house or premises chargeable with the rent.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (43886)
  sectionNo (59)
  orderNo 62
  title Inventory.
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43886&sectionno=59&orderno=62&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_59_content:
  string
  line `On seizing any property`
  line `under section 57 the bailiff shall make an inventory of such property and shall give a notice in writing to`
  line `the effect of the form (marked C) in the Third Schedule hereto annexed to the debtor, or to any other`
  line `person upon his behalf in or upon the said house or premises.`
  line
  line `Copies of inventory and notice to be filed.—The bailiff shall, as soon as may be, file in the Small`
  line `Cause Court copies of the said inventory and notice.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (43887)
  sectionNo (60)
  orderNo 63
  title `Application to discharge or suspend warrant.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43887&sectionno=60&orderno=63&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_60_content:
  string
  line `The debtor or any other person`
  line `alleging himself to be the owner of any property seized under this Chapter, or the duly constituted`
  line `attorney of such debtor or other person, may, at any time within five days from such seizure, apply to any`
  line `Judge of the said Court to discharge or suspend the warrant, or to release a distrained article, and such`
  line `Judge may discharge or suspend such warrant or release such article accordingly, upon such terms as he`
  line `thinks just,`
  line
  line `and any of the Judges of the said Court may in his discretion give reasonable time to the debtor to pay`
  line `the rent due from him.`
  line
  line `Upon any such application, the costs attending it and attending the issue and execution of the warrant`
  line `shall be in the discretion of the Judge, and shall be paid as he directs.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (43888)
  sectionNo (61)
  orderNo 64
  title `Claim to goods distrained made by a stranger.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43888&sectionno=61&orderno=64&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_61_content:
  string
  line `If any claim is made to, or in respect`
  line `of, any property seized under this Chapter, or in respect of the proceeds or value thereof, by any person`
  line `not being the debtor, the Registrar of the Small Cause Court, upon the application of the bailiff who`
  line `seized the property, may issue a summons calling before the Court the claimant and the person who`
  line `obtained the warrant.`
  line
  line `And thereupon any suit which may have been brought in the High Court in respect of such claim shall`
  line `be stayed, and any Judge of the High Court, on proof of the issue of such summons and that the property`
  line `was so distrained, may order the plaintiff to pay the costs of all proceedings in such suit after the issue of`
  line `such summons.`
  line
  line `And a Judge of the Small Cause Court shall adjudicate upon such claim and make such order between`
  line `the parties in respect thereof and of the costs of the proceedings as he thinks fit;`
  line
  line `and such order shall be enforced as if it were an order made in a suit brought in such Court.`
  line
  line `The procedure in Small Cause Courts in cases under this section shall conform, as far as may be, to the`
  line `procedure in an ordinary suit in such Courts.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (43889)
  sectionNo (62)
  orderNo 65
  title `Power to award compensation to debtor or claimant.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43889&sectionno=62&orderno=65&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_62_content:
  string
  line `In any case under section 60`
  line `or section 61 the Judge by whom the case is heard may award such compensation by way of damages to`
  line `the applicant or claimant (as the case may be) as the Judge thinks fit,`
  line
  line `and may for that purpose make any inquiry he thinks necessary;`
  line
  line `and the order of the Judge awarding or refusing such compensation shall bar any suit for the recovery`
  line `of compensation for any damage caused by the distress.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (43890)
  sectionNo (63)
  orderNo 66
  title `Power to transfer to High Court cases involving more than one thousand rupees.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43890&sectionno=63&orderno=66&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_63_content:
  string
  line `In any case under section 60 or section 61, if the value of the subject-matter in dispute exceeds`
  line `one thousand rupees, the applicant of claimant may apply to the High Court to transfer the case to itself,`
  line `and the High Court, on being satisfied that it is expedient that the case should be disposed of by itself,`
  line `may direct the case to be transferred accordingly, and may thereupon alter or set aside any order passed in`
  line `the case by a Judge of the Small Cause Court, and may make such order therein as the High Court thinks`
  line fit.
  line
  line `Every application under this section shall be made within seven days from the date of the seizure of`
  line `the subject-matter in dispute.`
  line
  line `In granting applications under this section, the High Court may impose such terms as to`
  line `payment of, or giving security for, costs or otherwise as it thinks fit.`
  line
  line `The procedure in cases transferred under this section shall conform, as far as may be, to the`
  line `procedure in suits before the High Court in the exercise of its ordinary original civil jurisdiction;`
  line `and orders made under this section may be executed as if they were made in the exercise of such`
  line `jurisdiction, and every such order awarding or refusing compensation shall bar any suit for the`
  line `recovery of compensation for any damage caused by the distress which gave rise to the case`
  line `wherein such order was made.`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (43891)
  sectionNo (64)
  orderNo 67
  title Appraisement.
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43891&sectionno=64&orderno=67&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_64_content:
  string
  line `In default of any order to the contrary by a Judge of the Small Cause`
  line `Court or by the High Court, any two of the said bailiffs may, at the expiration of five days from a`
  line `seizure of property under this Chapter, appraise the property so seized, and give the debtor notice`
  line `in writing to the effect of the form (marked D) in the Third Schedule hereto annexed.`
  line
  line `Notice of sale.—The bailiffs shall file in the Small Cause Court a copy of every notice given under`
  line `this section.`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (43892)
  sectionNo (65)
  orderNo 68
  title Sale.
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43892&sectionno=65&orderno=68&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_65_content:
  string
  line `In default of any such order to the contrary, the`
  line `distrained property shall be sold on the day mentioned in such notice, and the said bailiffs shall,`
  line `on realizing the proceeds, pay over the amount thereof to the Registrar of the Small Cause Court;`
  line `and such amount shall be applied first in payment of the costs of the said distress and then in`
  line `satisfaction of the debt; and the surplus, if any, shall be returned to the debtor:`
  line
  line `Provided that the debtor may direct that the sale shall take place in any other manner, first giving`
  line `security for any extra costs thereby occasioned.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (43893)
  sectionNo (66)
  orderNo 69
  title `Costs of distresses.`
  content obj_root_law_sections_66_content
  footnotes `1. Second paragraph omitted by the A.O. 1937.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43893&sectionno=66&orderno=69&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_66_content:
  string
  line `No costs of any distress under this Chapter shall be taken or demanded`
  line `except those mentioned in the part (marked E) of the Third Schedule hereto annexed.`
  line
  line ^1
  line `* * * * *`
obj_root_law_sections_67:
  sectionId (43894)
  sectionNo (67)
  orderNo 70
  title `Account of costs and proceeds.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43894&sectionno=67&orderno=70&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_67_content:
  string
  line `The Registrar of the Small Cause Court shall keep a`
  line `book in which all sums received as costs upon distresses made under this Chapter, and all sums`
  line `paid as remuneration to the said bailiffs, and all contingent charges incurred in respect of such`
  line `distresses, shall be duly entered.`
  line
  line `He shall also enter in the said book all sums realised by sale of the property distrained and paid over`
  line `to landlords under the provisions of this Chapter.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (43895)
  sectionNo (68)
  orderNo 71
  title `Bar of distresses except under this Chapter.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43895&sectionno=68&orderno=71&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_68_content:
  string
  line `No distress shall be levied for arrears of rent`
  line `except under the provisions of this Chapter.`
  line
  line `Penalty for making illegal distresses. — and any person, except a bailiff appointed under`
  line `section 51, levying or attempting to levy any such distress, shall, on conviction before a`
  line `Presidency Magistrate, be liable to be punished with fine which may extend to five hundred`
  line `rupees and with imprisonment for a term which may extend to three months, in addition to any`
  line `other liability he may have incurred by his proceedings.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (43896)
  sectionNo (69)
  orderNo 72
  title `Reference when compulsory.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43896&sectionno=69&orderno=72&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_69_content:
  string
  line `^1[69. Reference when compulsory.--(1) If two or more judges of the Small Cause Court sit`
  line `together in any suit, or in any proceeding under Chapter VII of this Act, and differ in their`
  line `opinion as to any question of law or usage having the force of law or the construction of a`
  line `document, which construction may affect the merits, or`
  line
  line `if in any suit or in any such proceeding, in which the amount or value of the subject-matter exceeds`
  line `five hundred rupees, any such question arises upon which the Court entertains reasonable doubt, and`
  line `either party so requires,`
  line
  line `the Small Cause Court shall draw up a statement of the facts of the case and the point on which`
  line `there is a difference of opinion or on which doubt is entertained, and refer such statement with its`
  line `own opinion on the point for the opinion of the High Court; and the provisions of sections 619 to 621`
  line `of the ^2Code of Civil Procedure (14 of 1882), shall, so far as they are applicable, be deemed to apply`
  line `as if such reference had been made under section 617 of the said Code.`
  line
  line `(2) When the Small Cause Court refers any question for the opinion of the High Court as provided in`
  line `sub-section (1), it shall either reserve judgment or give judgment contingent upon such opinion.]`
obj_root_law_sections_69_footnotes:
  string
  line `1. Subs. by Act 4 of 1906, s. 4, for section 69.`
  line
  line `2. See Now the Code of Civil Procedure, 1908 (Act 5 of 1908).`
obj_root_law_sections_70:
  sectionId (43929)
  sectionNo (70)
  orderNo 73
  title `Security to be furnished on such reference by party against whom contingent judgment given.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43929&sectionno=70&orderno=73&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_70_content:
  string
  line `When judgment is given under section 69 contingent upon the opinion of the High Court, the`
  line `party against whom such judgment is given shall at once furnish security, to be approved by the`
  line `Small Cause Court, for the costs of the reference to the High Court and for the amount of such`
  line `judgment:`
  line
  line `Provided that no security for the amount of such judgment shall be required in any case in which the`
  line `Judge who tried the case has ordered such amount to be paid into Court, and the same has been paid`
  line accordingly.
  line
  line `If no such security given, party to be deemed to have submitted to judgment.—Unless such`
  line `security as aforesaid is at once furnished, the party against whom such contingent judgment has been`
  line `given shall be deemed to have submitted to the same.`
obj_root_law_sections_70_footnotes:
  string
  line
obj_root_law_sections_71:
  sectionId (43898)
  sectionNo (71)
  orderNo 74
  title Institution-fee.
  content obj_root_law_sections_71_content
  footnotes `1. The words and figures "section 38 or" rep. by Act 7 of 1896.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43898&sectionno=71&orderno=74&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_71_content:
  string
  line `A fee not exceeding--`
  line
  line `(a) when the amount or value of the subject-matter does not exceed five hundred rupees---the`
  line `sum of two annas in the rupee on such amount or value,`
  line
  line `(b) when the amount of value of the subject-matter exceeds five hundred rupees---the sum of`
  line `sixty-two rupees eight annas, and one anna in the rupee on the excess of such amount or value over`
  line `five hundred rupees,`
  line
  line `shall be paid on the plaint in every suit, and every application under ^1*** section 41; and no such plaint or`
  line `application shall be received until such fee has been paid.`
  line
  line `An additional fee of ten rupees shall be paid on the filing of every agreement under section 20.`
obj_root_law_sections_72:
  sectionId (43899)
  sectionNo (72)
  orderNo 75
  title `Fees for processes.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43899&sectionno=72&orderno=75&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_72_content:
  string
  line `The fees specified in the third and fourth columns of the Fourth`
  line `Schedule hereto annexed shall be paid previous to the issue in any suit or in any proceeding under`
  line `Chapter VII of this Act of the processes, to which the said columns respectively relate, by the`
  line `persons on whose behalf such processes are issued, when the amount or value of the subject-matter`
  line `exceeds the sum specified in the first column, but does not exceed the sum specified in the second`
  line `column of the said Schedule.`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (43900)
  sectionNo (73)
  orderNo 76
  title `Repayment of half-fees on settlement before hearing.`
  content obj_root_law_sections_73_content
  footnotes obj_root_law_sections_73_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43900&sectionno=73&orderno=76&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_73_content:
  string
  line `Whenever any such suit or`
  line `proceeding is settled by agreement of the parties before the hearing, half the amount of all fees paid up to`
  line `that time shall be repaid by the Small Cause Court to the parties by whom the same have been`
  line `respectively paid.`
obj_root_law_sections_73_footnotes:
  string
  line
obj_root_law_sections_74:
  sectionId (43901)
  sectionNo (74)
  orderNo 77
  title `Fees and costs of poor persons.`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43901&sectionno=74&orderno=77&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_74_content:
  string
  line `The Small Cause Court may, whenever it thinks fit, receive and`
  line `register suits instituted, and applications under section 41 made by poor persons, and may issue processes`
  line `on behalf of such persons, without payment or on a part-payment of the fees mentioned in sections 71 and`
  line 72.
obj_root_law_sections_74_footnotes:
  string
  line
obj_root_law_sections_75:
  sectionId (43902)
  sectionNo (75)
  orderNo 78
  title `Power to vary fees.`
  content obj_root_law_sections_75_content
  footnotes obj_root_law_sections_75_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43902&sectionno=75&orderno=78&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_75_content:
  string
  line `The State Government may from time to time, by notification in the Official`
  line `Gazette, vary amount of the fees payable under sections 71 and 72:`
  line
  line `Provided that the amount of such fees shall in no case exceed the amount prescribed by the said`
  line sections.
obj_root_law_sections_75_footnotes:
  string
  line
obj_root_law_sections_76:
  sectionId (43903)
  sectionNo (76)
  orderNo 79
  title `Expense of employing legal practitioners.`
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43903&sectionno=76&orderno=79&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_76_content:
  string
  line `The expense of employing an advocate, vakil,`
  line `attorney or other legal practitioner incurred by any party shall not be allowed as costs in any suit or in`
  line `any proceeding under Chapter VII of this Act, in the Small Cause Court, in which suit or proceeding`
  line `the amount or value of the subject-matter does not exceed twenty rupees, unless the-Court is of`
  line `opinion that the employment of such practitioner was under the circumstances reasonable.`
obj_root_law_sections_76_footnotes:
  string
  line
obj_root_law_sections_77:
  sectionId (43904)
  sectionNo (77)
  orderNo 80
  title `Sections 3, 5 and 25 of Court-fees Act, 1870, saved.`
  content obj_root_law_sections_77_content
  footnotes obj_root_law_sections_77_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43904&sectionno=77&orderno=80&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_77_content:
  string
  line `Nothing contained in this Chapter shall`
  line `affect the provisions of sections 3, 5 and 25 of the Court-fees Act, 1870 (7 of 1870).`
obj_root_law_sections_77_footnotes:
  string
  line
obj_root_law_sections_78:
  sectionId (43905)
  sectionNo (78)
  orderNo 81
  title [Repealed.].
  content `[Power to fine officers.] Rep. by the A.O. 1937.`
  footnotes obj_root_law_sections_78_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43905&sectionno=78&orderno=81&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_78_footnotes:
  string
  line
obj_root_law_sections_79:
  sectionId (43906)
  sectionNo (79)
  orderNo 82
  title `Default of bailiff or other officer in execution of order or warrant.`
  content obj_root_law_sections_79_content
  footnotes obj_root_law_sections_79_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43906&sectionno=79&orderno=82&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_79_content:
  string
  line `If any clerk, bailiff`
  line `or other inferior ministerial officer of the Small Cause Court who is employed as such in the`
  line `execution of any order or warrant, loses, by neglect, connivance or omission, an opportunity of`
  line `executing such order or warrant, he shall be liable, by order of the Chief Judge, on the application of`
  line `the person injured by such neglect, connivance or omission, to pay such sum, not exceeding in any`
  line `case the sum for which the said order or warrant was issued, as, in the opinion of the Chief Judge,`
  line `represents the amount of the damage sustained by such person thereby.`
obj_root_law_sections_79_footnotes:
  string
  line
obj_root_law_sections_80:
  sectionId (43907)
  sectionNo (80)
  orderNo 83
  title `Extortion or default of officers.`
  content obj_root_law_sections_80_content
  footnotes obj_root_law_sections_80_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43907&sectionno=80&orderno=83&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_80_content:
  string
  line `If any clerk, bailiff or other inferior ministerial officer of`
  line `the Small Cause Court is charged with extortion or misconduct while acting under colour of its`
  line `process, or with not duly paying or accounting for any money levied by him under its authority, the`
  line `Court may inquire into such charge, and may make such order for the repayment or payment of any`
  line `money so extorted, or of any money so levied as aforesaid, and of damages and costs, by such`
  line `officer, as it thinks fit.`
obj_root_law_sections_80_footnotes:
  string
  line
obj_root_law_sections_81:
  sectionId (43908)
  sectionNo (81)
  orderNo 84
  title `Court empowered to summon witnesses, etc.`
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43908&sectionno=81&orderno=84&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_81_content:
  string
  line `For the purposes of any inquiry under this`
  line `Chapter, the Small Cause Court shall have all the powers of summoning and enforcing the attendance`
  line `of witnesses and compelling the production of documents which it possesses in suits under this Act.`
obj_root_law_sections_81_footnotes:
  string
  line
obj_root_law_sections_82:
  sectionId (43909)
  sectionNo (82)
  orderNo 85
  title `Enforcement of order.`
  content obj_root_law_sections_82_content
  footnotes obj_root_law_sections_82_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43909&sectionno=82&orderno=85&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_82_content:
  string
  line `Any order under this Chapter for the payment or repayment of`
  line `money may, in default of payment of the amount payable thereunder, be enforced by the person to`
  line `whom such amount is payable as if the same were a decree of the Small Cause Court in his favour.`
obj_root_law_sections_82_footnotes:
  string
  line
obj_root_law_sections_83:
  sectionId (43910)
  sectionNo (83)
  orderNo 86
  title [Repealed.].
  content obj_root_law_sections_83_content
  footnotes obj_root_law_sections_83_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43910&sectionno=83&orderno=86&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_83_content:
  string
  line `[Procedure of Court in certain cases of contempt.] Rep. by the Repealing and Amending Act, 1914`
  line `(10 of 1914), s. 3 and the Second Schedule.`
obj_root_law_sections_83_footnotes:
  string
  line
obj_root_law_sections_84:
  sectionId (43911)
  sectionNo (84)
  orderNo 87
  title [Repealed.].
  content `[Record in such cases.] Rep. by s. 3 and the Second Schedule, ibid.`
  footnotes obj_root_law_sections_84_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43911&sectionno=84&orderno=87&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_84_footnotes:
  string
  line
obj_root_law_sections_85:
  sectionId (43912)
  sectionNo (85)
  orderNo 88
  title [Repealed.].
  content obj_root_law_sections_85_content
  footnotes obj_root_law_sections_85_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43912&sectionno=85&orderno=88&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_85_content:
  string
  line `[Procedure where Court considers that case should not be dealt with under section 83.] Rep. by`
  line `s. 3 and the Second Schedule, ibid.`
obj_root_law_sections_85_footnotes:
  string
  line
obj_root_law_sections_86:
  sectionId (43913)
  sectionNo (86)
  orderNo 89
  title [Repealed.].
  content `[Discharge of offender on submission or apology.] Rep. by s. 3 and the Second Schedule, ibid.`
  footnotes obj_root_law_sections_86_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43913&sectionno=86&orderno=89&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_86_footnotes:
  string
  line
obj_root_law_sections_87:
  sectionId (43914)
  sectionNo (87)
  orderNo 90
  title `Imprisonment or committal of person refusing to answer or produce document.`
  content obj_root_law_sections_87_content
  footnotes obj_root_law_sections_87_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43914&sectionno=87&orderno=90&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_87_content:
  string
  line `If any`
  line `witness before the Small Cause Court refuses to answer such questions as are put to him, or to produce`
  line `any document in his possession or power which the Court requires him to produce, and does not offer any`
  line `reasonable excuse for such refusal, the Court may sentence him to simple imprisonment, or commit him`
  line `to the custody of an officer of the Court, for any term not exceeding seven days, unless in the meantime`
  line `such person consents to answer such questions or to produce such document, as the case may be, after`
  line `which, in the event of his persisting in his refusal, he may be dealt with according to the provisions of`
  line `section ^1[480 or section 482 of Code of Criminal Procedure, 1898^2 (5 of 1898)].`
obj_root_law_sections_87_footnotes:
  string
  line `1. Subs. by Act 10 of 1914, s. 2 and the First Schedule.`
  line
  line `2. Now @I@see@/I@ Act 2 of 1974.`
obj_root_law_sections_88:
  sectionId (43915)
  sectionNo (88)
  orderNo 91
  title `Appeal from orders under section 87.`
  content obj_root_law_sections_88_content
  footnotes obj_root_law_sections_88_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43915&sectionno=88&orderno=91&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_88_content:
  string
  line `Any person deeming himself aggrieved by an order`
  line `under ^3*** section 87 may appeal to the High Court, and the provisions of the ^1[Code of Criminal`
  line `Procedure, 1898^2 (5 of 1898)], relating to appeal shall, so far as may be, apply to appeals under this`
  line section.
obj_root_law_sections_88_footnotes:
  string
  line `1. The words and figures "section 83 or" omitted by Act 10 of 1914, s. 3 and the Second Schedule.`
  line
  line `2. Subs. by Act 10 of 1914, s. 2 and the First Schedule`
  line
  line `3. Now see Act 2 of 1974.`
obj_root_law_sections_89:
  sectionId (43916)
  sectionNo (89)
  orderNo 92
  title `Persons by whom process may be served.`
  content obj_root_law_sections_89_content
  footnotes obj_root_law_sections_89_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43916&sectionno=89&orderno=92&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_89_content:
  string
  line `Notices to produce documents, summonses to`
  line `witnesses, and all other processes issued in the exercise of any jurisdiction conferred on the Small Cause`
  line `Court by this Act, except summonses to defendants and writs of execution, may, if the Court by general`
  line `or special order so directs, be served by such persons as the Court, from time to time, appoints in this`
  line behalf.
obj_root_law_sections_89_footnotes:
  string
  line
obj_root_law_sections_90:
  sectionId (43917)
  sectionNo (90)
  orderNo 93
  title `Registers and returns.`
  content obj_root_law_sections_90_content
  footnotes obj_root_law_sections_90_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43917&sectionno=90&orderno=93&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_90_content:
  string
  line `The Small Cause Court shall keep such registers, books and accounts,`
  line `and submit to the High Court such statements and returns, as may, subject to the approval of the State`
  line `Government, be prescribed by the High Court.`
obj_root_law_sections_90_footnotes:
  string
  line
obj_root_law_sections_91:
  sectionId (43918)
  sectionNo (91)
  orderNo 94
  title `Court to furnish records, etc., called for by State Government or High Court.`
  content obj_root_law_sections_91_content
  footnotes obj_root_law_sections_91_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43918&sectionno=91&orderno=94&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_91_content:
  string
  line `The Small`
  line `Cause Court shall comply with such requisitions as may, from time to time, be made by the State`
  line `Government or High Court for records, returns and statements in such form and manner as such`
  line `Government or Court, as the case may be, thinks fit.`
obj_root_law_sections_91_footnotes:
  string
  line
obj_root_law_sections_92:
  sectionId (43919)
  sectionNo (92)
  orderNo 95
  title `Holidays and vacations.`
  content obj_root_law_sections_92_content
  footnotes obj_root_law_sections_92_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43919&sectionno=92&orderno=95&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_92_content:
  string
  line `The Small Cause Court shall, at the commencement of each year,`
  line `draw up a list of holidays and vacations to he observed in the Court, and shall submit the same for the`
  line `approval of the State Government.`
  line
  line `Such list, when it has received such approval, shall be published in the Official Gazette, and the said`
  line `holidays and vacations shall be observed accordingly.`
obj_root_law_sections_92_footnotes:
  string
  line
obj_root_law_sections_93:
  sectionId (43920)
  sectionNo (93)
  orderNo 96
  title `Certain persons exempt from arrest by Court.`
  content obj_root_law_sections_93_content
  footnotes obj_root_law_sections_93_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43920&sectionno=93&orderno=96&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_93_content:
  string
  line `The President ^1***, the Governors of`
  line `^2[Madras], ^3[Bombay and ^4[West Bengal]], ^5*** ^6*** and the Chief Justice and Judges of the High Courts`
  line `^7***, shall not be liable to arrest by order of the Small Cause Court.`
obj_root_law_sections_93_footnotes:
  string
  line `1. The words "and Members of his Council" rep. by the A.O. 1948.`
  line
  line `2. Subs. by the A.O. 1948, for "Fort St. George".`
  line
  line `3. Subs. by Act 7 of 1912, s. 7 and the Schedule E, for "and Bombay".`
  line
  line `4. Subs. by A.O. 1948, for "Fort William in Bengal".`
  line
  line `5. The words "and the Members of their respective Councils" rep, by the A O.1937.`
  line
  line `6. The words "the Lieutenant-Governor of Bengal" omitted by Act 7 of 1912, s. 7 and the Schedule E.`
  line
  line `7. The words and letter "for Part A States" omitted by the A.O. (No. 2) 1956.`
obj_root_law_sections_94:
  sectionId (43921)
  sectionNo (94)
  orderNo 97
  title `No suit to lie upon decree of Court.`
  content `No suit shall lie on any decree of the Small Cause Court.`
  footnotes obj_root_law_sections_94_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43921&sectionno=94&orderno=97&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_94_footnotes:
  string
  line
obj_root_law_sections_95:
  sectionId (43922)
  sectionNo (95)
  orderNo 98
  title `Place of imprisonment.`
  content obj_root_law_sections_95_content
  footnotes obj_root_law_sections_95_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43922&sectionno=95&orderno=98&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_95_content:
  string
  line `Any person ordered by the Small Cause Court to be imprisoned may be`
  line `imprisoned in such place as the State Government, from time to time, appoints in this behalf.`
obj_root_law_sections_95_footnotes:
  string
  line
obj_root_law_sections_96:
  sectionId (43923)
  sectionNo (96)
  orderNo 99
  title `Tender in suit for anything done under Act.`
  content obj_root_law_sections_96_content
  footnotes obj_root_law_sections_96_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43923&sectionno=96&orderno=99&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_96_content:
  string
  line `If any person against whom any suit is brought for`
  line `anything purporting to be done by him under this Act, has before the institution of the suit, tendered`
  line `sufficient amends to the plaintiff, the plaintiff shall not recover.`
obj_root_law_sections_96_footnotes:
  string
  line
obj_root_law_sections_97:
  sectionId (43924)
  sectionNo (97)
  orderNo 100
  title `Limitation of prosecutions.`
  content obj_root_law_sections_97_content
  footnotes obj_root_law_sections_97_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00025_188215_1523272578725&sectionId=43924&sectionno=97&orderno=100&orgactid=AC_CEN_3_3_00025_188215_1523272578725
obj_root_law_sections_97_content:
  string
  line `All prosecutions for anything purporting to be done under this Act`
  line `must be commenced within three months after the offence was committed.`
obj_root_law_sections_97_footnotes:
  string
  line
obj_root_law_translations:
