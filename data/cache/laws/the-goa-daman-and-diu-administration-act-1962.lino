obj_root_law_sections_1:
  sectionId (26687)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26687&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Goa, Daman and Diu`
  line `(Administration) Act, 1962.`
  line
  line `(2) It shall be deemed to have come into force on the 5th day of March, 1962.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (26688)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26688&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Administrator" means the Administrator of Goa, Daman and Diu appointed by the President`
  line `under Article 239 of the Constitution;`
  line
  line `(b) "appointed day" means the twentieth day of December, 1961;`
  line
  line `(c) "Goa, Daman and Diu" means the Union territory of Goa, Daman and Diu.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (26689)
  sectionNo (3)
  orderNo 3
  title `Representation in the House of the People.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26689&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_3_content:
  string
  line `(1) There shall be allotted two seats to the Union`
  line `territory of Goa, Daman and Diu in the House of the People.`
  line
  line `(2) In the Representation of the People Act, 1950 (43 of 1950),—`
  line
  line `(a) in section 4, in sub-section (1), after the words '"to Dadra and Nagar Haveli", the words "to`
  line `Goa, Daman and Diu" shall be inserted;`
  line
  line `(b) in the First Schedule,—`
  line
  line `(i) after entry 22, the following entry shall be inserted, namely:—`
  line
  line `"23. Goa, Daman and Diu ..... 2";`
  line
  line `(ii) entries 23 and 24 shall be re-numbered as entries 24 and 25, respectively.`
  line
  line `(3) In the Representation of the People Act, 1951 (43 of 1951), in section 4, after the words "to`
  line `Dadra and Nagar Haveli", the words "to Goa, Daman and Diu" shall be inserted.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (26690)
  sectionNo (4)
  orderNo 4
  title `Officers and functionaries in relation to Goa, Daman and Diu.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26690&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_4_content:
  string
  line `Without prejudice to the`
  line `powers of the Central Government to appoint from time to time such officers and authorities as may be`
  line `necessary for the administration of Goa, Daman and Diu, all judges, magistrates and other officers and`
  line `authorities who, immediately before the commencement of this Act, were exercising lawful functions in`
  line `connection with the administration of Goa, Daman and Diu or any part thereof, shall, unless otherwise`
  line `directed at any time by the Central Government in relation to any such judge, magistrate or other officer`
  line `or authority, or until other provision is made by law, continue to exercise in connection with such`
  line `administration their respective functions in the same manner and to the same extent as before such`
  line `commencement with such altered designation, if any, as that Government may determine.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (26691)
  sectionNo (5)
  orderNo 5
  title `Continuance of existing laws and their adaptation.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26691&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_5_content:
  string
  line `(1) All laws in force immediately before`
  line `the appointed day in Goa, Daman and Diu or any part thereof shall continue to be in force therein until`
  line `amended or repealed by a competent Legislature or other competent authority.`
  line
  line `(2) For the purpose of facilitating the application of any such law in relation to the administration of`
  line `Goa, Daman and Diu as a Union territory and for the purpose of bringing the provisions of any such law`
  line `into accord with the provisions of the Constitution, the Central Government may, within two years from`
  line `the appointed day, by order, make such adaptations and modifications, whether by way of repeal`
  line `oramendment, as may be necessary or expedient and thereupon, every such law shall have effect subject`
  line `to the adaptations and modifications so made.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (26692)
  sectionNo (6)
  orderNo 6
  title `Power to extend enactments to Goa, Daman and Diu.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26692&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_6_content:
  string
  line `The Central Government may, by`
  line `notification in the Official Gazette, extend with such restrictions or modifications as it thinks fit to Goa,`
  line `Daman and Diu any enactment which is in force in a State at the date of the notification.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (26693)
  sectionNo (7)
  orderNo 7
  title Repealed.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26693&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_7_content:
  string
  line `[Extension of the jurisdiction of Bombay High Court to Goa, Daman and Diu.] Rep. by the`
  line `Goa, Daman and Diu Judicial Commissioner's Court (Declaration asHigh Court) Act, 1964 (16 of 1964),`
  line `section 8 (w.e.f.16-12-1964).`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (26697)
  sectionNo (8)
  orderNo 8
  title `Power to construe laws.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26697&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_8_content:
  string
  line `For the purpose of facilitating the application of any law in relation to`
  line `Goa, Daman and Diu, any Court or other authority may construe any such law in such manner not`
  line `affecting the substance, as may be necessary or proper to adapt it to the matter before the Court or other`
  line authority.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (26698)
  sectionNo (9)
  orderNo 9
  title `Validation of certain action and indemnity of officers for certain acts`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26698&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_9_content:
  string
  line `(1) All things done and`
  line `all action taken (including any acts of executive authority, proceedings, decrees and sentences) in or with`
  line `respect to Goa, Daman and Diu on or after the appointed day and before the commencement of this Act,`
  line `by the Administrator or any other officer, whether civil or military, or by any other person acting under`
  line `the orders of the Administrator or such officer, which have been done or taken in good faith in a`
  line `reasonable belief that they were necessary for the peace and good government of Goa, Daman and Diu`
  line `shall be as valid and operative as if they had been done or taken in accordance with law.`
  line
  line `(2) No suit or other legal proceeding whatsoever, whether civil or criminal, shall lie in any Court of`
  line `law against the Administrator or any other officer of Government; whether civil or military, or against`
  line `any other person acting under the orders of the Administrator or such other officer, for, or on account of,`
  line `or in respect of, anything done or any action taken in Goa, Daman and Diu or any part thereof on or after`
  line `the appointed day and before the commencement of this Act which has been done or taken in good faith`
  line `and in a reasonable belief that it was necessary for the peace and good government of Goa, Daman and`
  line `Diu:`
  line
  line `Provided that if any such suit on other legal proceeding has been instituted before the commencement`
  line `of this Act, it shall, on such commencement, abate.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (26699)
  sectionNo (10)
  orderNo 10
  title `Power to remove difficulties.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26699&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_10_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act or in connection with the administration of Goa, Daman and Diu, the Central Government may,`
  line `by order, make such further provision as appears to it to be necessary or expedient for removing the`
  line difficulty.
  line
  line `(2) Any order under sub-section (1) may be made so as to be retrospective to any date not earlier than`
  line `the appointed day.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (26701)
  sectionNo (11)
  orderNo 11
  title `Repeal and saving.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00029_196201_1517807321884&sectionId=26701&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00029_196201_1517807321884
obj_root_law_sections_11_content:
  string
  line `(1) The Goa, Daman and Diu (Administration) Ordinance, 1962 (2 of`
  line `1962), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken in exercise of any of the powers`
  line `conferred by or under the said Ordinance shall be deemed to have been done or taken in exercise of the`
  line `powers conferred by or under this Act.`
