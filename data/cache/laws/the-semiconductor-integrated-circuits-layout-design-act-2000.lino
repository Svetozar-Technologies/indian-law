  (str title) (str `अर्धचालक एकीकृत परिपथ अभिन्यासडिजाइन अधिनियम, 2000`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1998/3/H2000-37.pdf`)
