  title `Short title.`
  content `This Act may be called the Orissa Weights and Measures (Delhi Repeal) Act, 1958.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00006_195857_1517807318429&sectionId=47589&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00006_195857_1517807318429
