obj_root_law_sections_2:
  sectionId (47590)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00006_195857_1517807318429&sectionId=47590&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00006_195857_1517807318429
obj_root_law_sections_2_content:
  string
  line `In this Act,―`
  line
  line `(a) "Orissa Act" means the Orissa Weights and Measures Act, 1943 (Orissa Act 7 of 1943), as`
  line `extended to Delhi by notification under section 7 of the Delhi Laws Act, 1912 (13 of 1912);`
  line
  line `(b) "Rajasthan Act" means the Rajasthan Weights and Measures (Enforcement)`
  line `Act, 1958 (Rajasthan Act 32 of 1958), as extended to the Union territory of Delhi by notification`
  line `under section 2 of the Union Territories (Laws) Act, 1950 (30 of 1950).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47591)
  sectionNo (3)
  orderNo 3
  title `Repeal of Orissa Act.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00006_195857_1517807318429&sectionId=47591&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00006_195857_1517807318429
obj_root_law_sections_3_content:
  string
  line `On the date on which the Rajasthan Act or any provision contained`
  line `therein comes into force by virtue of a notification issued under sub-section (3) of section 1 of that Act in`
  line `the Union territory of Delhi or any part thereof in respect of any class of undertakings or any class of`
  line `goods, the Orissa Act or any provision contained therein, which is applicable to those undertakings or`
  line `goods in the said territory or part thereof, as the case may be, shall stand repealed:`
  line
  line `Provided that the repeal shall not affect—`
  line
  line `(a) the previous operation of the Act so repealed or anything duly done or suffered thereunder; or`
  line
  line `(b) any right, privilege, obligation or liability acquired, accrued or incurred under the Act so`
  line `repealed; or`
  line
  line `(c) any penalty, forfeiture or punishment incurred in respect of any offence committed against the`
  line `Act so repealed; or`
  line
  line `(d) any investigation, legal proceeding or remedy in respect of any such right, privilege,`
  line `obligation, liability, penalty, forfeiture or punishment as aforesaid;`
  line
  line `and any such investigation, legal proceeding or remedy may be instituted, continued or enforced and any`
  line `such penalty, forfeiture or punishment may be imposed, as if that Act had not been repealed.`
obj_root_law_sections_3_footnotes:
  string
  line
