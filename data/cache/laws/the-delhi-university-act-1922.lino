  (str title) (str `दिल्‍ली विश्‍वविद्यालय अधिनियम, 1922`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2374/3/H1922-8.pdf`)
  (str sourceKind) (str pdf)
