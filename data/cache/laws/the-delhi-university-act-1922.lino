obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (47697)
  sectionNo (21)
  orderNo 23
  title `The Executive Council.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47697&sectionno=21&orderno=23&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_21_content:
  string
  line `The Executive Council shall be the executive body of the`
  line `University and its constitution and the terms of office of its members, other than ex officio members,`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (47698)
  sectionNo (22)
  orderNo 24
  title [Omitted.].
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47698&sectionno=22&orderno=24&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_22_content:
  string
  line `[Powers and duties of the Executive Council.] Omitted by the Delhi University (Amendment)`
  line `Act, 1952 (5 of 1952), s. 14.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (47699)
  sectionNo (23)
  orderNo 25
  title `The Academic Council.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47699&sectionno=23&orderno=25&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_23_content:
  string
  line `The Academic Council shall be the academic body of the`
  line `University, and shall, subject to the provisions of this Act, the Statutes and the Ordinances, have the`
  line `control and general regulation, and be responsible for the maintenance, of standards of instruction,`
  line `education and examination within the University, and shall exercise such other powers and perform`
  line `such other duties as may be conferred or imposed upon it by the Statutes. It shall have the right to`
  line `advise the Executive Council on all academic matters. The constitution of the Academic Council and`
  line `the term of office of its members, other than ex officio members, shall be prescribed by the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (47700)
  sectionNo (24)
  orderNo 26
  title [Omitted.].
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47700&sectionno=24&orderno=26&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_24_content:
  string
  line `[The Faculties.] Omitted by the Delhi University (Amendment) Act, 1952 (5 of`
  line `1952), s. 14.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (47701)
  sectionNo (25)
  orderNo 27
  title `Powers and duties of authorities of the University.`
  content obj_root_law_sections_25_content
  footnotes `1. Subs. by s. 15, ibid., for section 25.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47701&sectionno=25&orderno=27&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_25_content:
  string
  line `^1[25. Powers and duties of authorities of the University.-- Subject to the provisions of this Act,`
  line `the constitution, powers and duties of the authorities of the University shall be provided for by the`
  line Statutes.]
obj_root_law_sections_26:
  sectionId (47702)
  sectionNo (26)
  orderNo 28
  title `University Boards.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47702&sectionno=26&orderno=28&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_26_content:
  string
  line `The University shall include a Residence, Health and Discipline Board`
  line `and such other Boards as may be prescribed by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (47703)
  sectionNo (27)
  orderNo 29
  title `Constitution, etc., of Boards to be prescribed by Ordinances.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47703&sectionno=27&orderno=29&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_27_content:
  string
  line `The constitution, powers`
  line `and duties of the Residence, Health and Discipline Board and of all other Boards of the University`
  line `shall he prescribed by the Ordinances.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (47704)
  sectionNo (28)
  orderNo 30
  title Statutes.
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47704&sectionno=28&orderno=30&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_28_content:
  string
  line `^1[28. Statutes.--Subject to the provisions of this Act, Statutes may provide for all or any of the`
  line `following matters, namely:--`
  line
  line `(a) the constitution, powers and duties of the Court, the Executive Council, the Academic`
  line `Council, the Finance Committee and such other bodies as may be deemed necessary to constitute`
  line `from time to time;`
  line
  line `(b) the election and continuance in office of the members of the said bodies, including the`
  line `continuance in office of the first members, and the filling of vacancies of members and all other`
  line `matters relative to those bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University;`
  line
  line `(d) the constitution of a pension or provident fund and the establishment of an insurance`
  line `scheme for the benefit of the officers, teachers and other employees of the University;`
  line
  line `(e) the conferment of honorary degrees;`
  line
  line `(f) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(g) the establishment and abolition of Faculties, Departments, Halls, Colleges and Institutions;`
  line
  line `(h) the conditions under which colleges and other institutions may be admitted to the privileges`
  line `of the University and the withdrawal of such privileges;`
  line
  line `^2[(hh) the extent of the autonomy which a college, declared as an autonomous college under`
  line `clause (9A) of section 4, may have and the matters in relation to which such autonomy may be`
  line exercised;
  line
  line `(hhh) the composition, powers and functions of College Administrative Councils;]`
  line
  line `(i) the institution of fellowships, scholarships, studentships, exhibitions, medals and prizes; and`
  line
  line `(j) all other matters which by this Act are or may be provided for by the Statutes.]`
obj_root_law_sections_28_footnotes:
  string
  line `1. Subs. by Act 5 of 1952, s. 16, for section 28.`
  line
  line `2. Ins. by Act 48 of 1972, s. 3 (w.e.f. 22-6-1972).`
obj_root_law_sections_29:
  sectionId (47724)
  sectionNo (29)
  orderNo 31
  title `Statutes how made.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47724&sectionno=29&orderno=31&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_29_content:
  string
  line `^1[(1) On the commencement of the Delhi University (Amendment)`
  line `Act, 1943 (24 of 1943), the Statutes of the University shall be those set out in the Schedule.]`
  line
  line `^2[(2) The Executive Council may, from time to time, make new or additional Statutes or may`
  line `amend or repeal the Statutes:`
  line
  line `Provided that the Executive Council shall not make, amend or repeal any Statute affecting the`
  line `status, powers or constitution of any authority of the University until such authority has been given`
  line `an opportunity of expressing an opinion in writing on the proposed changes, and any opinion so`
  line `expressed shall be considered by the Executive Council:`
  line
  line `Provided further that except with the prior concurrence of the Academic Council, the Executive`
  line `Council shall not make, amend or repeal any Statute affecting all or any of the following matters,`
  line `namely:--`
  line
  line `(i) the constitution, powers and duties of the Academic Council, and the other powers which`
  line `may be conferred, and duties which may be imposed, on the Academic Council;`
  line
  line `(ii) the authorities responsible for organizing recognised teaching in connection with the`
  line `University courses;`
  line
  line `(iii) the withdrawal of Degrees, Diplomas, Certificates and other academic distinctions;`
  line
  line `(iv) the establishment and abolition of Faculties, Departments, Halls, Colleges and Institutions;`
  line
  line `(v) the conditions under which Colleges and other Institutions may be admitted to the`
  line `privileges of the University and the withdrawal of such privileges;`
  line
  line `(vi) the institution of Fellowships, Scholarships, Studentships, Exhibitions, Medals and`
  line Prizes;
  line
  line `(vii) the extent of the autonomy which a College may have and the matters in relation to which`
  line `such autonomy may be exercised;`
  line
  line `(viii) the composition, powers and functions of College Administrative Councils; and`
  line
  line `(ix) the conditions on the fulfilment of which the teachers of Colleges and Institutions may be`
  line `recognised as teachers of the University.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall`
  line `require the previous approval of the Visitor who may sanction, disallow or return it to the Executive`
  line `Council for further consideration.]`
obj_root_law_sections_29_footnotes:
  string
  line `1. Subs. by Act 24 of 1943, s. 9, for sub-section (1).`
  line
  line `2. Subs. by Act 48 of 1972, s. 4, for sub-sections (2) to (6) (w.e.f. 22-6-1972).`
obj_root_law_sections_30:
  sectionId (47725)
  sectionNo (30)
  orderNo 32
  title Ordinances.
  content obj_root_law_sections_30_content
  footnotes `1. Subs. by Act 5 of 1952, s. 18, for sections 30 and 31.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47725&sectionno=30&orderno=32&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_30_content:
  string
  line `^1[30. Ordinances.--Subject to the provisions of this Act and the Statutes, the Ordinances may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the degrees, diplomas, certificates and other academic distinctions to be awarded by the`
  line `University, the qualifications for the same, and the means to be taken relating to the granting`
  line `and obtaining of the same;`
  line
  line `(d) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(e) the conditions of the award of fellowships, scholarships, studentships, exhibitions,`
  line `medals and prizes;`
  line
  line `(f) the conduct of examinations, including the terms of office and manner of appointment`
  line `and the duties of examining bodies, examiners and moderators;`
  line
  line `(g) the maintenance of discipline among the students of the University;`
  line
  line `(h) the conditions of residence of students at the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and`
  line `teaching of women students, and the prescribing for them of special courses of study;`
  line
  line `(j) the giving of religious instruction;`
  line
  line `(k) the emoluments and the terms and conditions of service of teachers of the`
  line University;
  line
  line `(l) the management of colleges and other institutions founded or maintained by the`
  line University;
  line
  line `(m) the supervision and inspection of colleges and other institutions admitted to privileges`
  line `of the University; and`
  line
  line `(n) all other matters which by this Act or the Statutes are to be or may be provided for by`
  line `the Ordinances.`
obj_root_law_sections_31:
  sectionId (47706)
  sectionNo (31)
  orderNo 33
  title `Ordinances how made.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47706&sectionno=31&orderno=33&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_31_content:
  string
  line `(1) The Ordinances of the University as in force immediately`
  line `before the commencement of the Delhi University (Amendment) Act, 1952 (5 of 1952), may be`
  line `amended, repealed or added to at any time by the Executive Council:`
  line
  line `Provided that--`
  line
  line `(i) no Ordinance shall be made affecting the conditions of residence or discipline of`
  line `students, except after consultation with the Academic Council;`
  line
  line `(ii) no Ordinance shall be made--`
  line
  line `(a) affecting the admission or enrolment of students or prescribing examinations to be`
  line `recognised as equivalent to the University examinations, or`
  line
  line `(b) affecting the conditions, mode of appointment or duties of examiners or the conduct or`
  line `standard of examinations or any course of study,`
  line `unless a draft of such Ordinance has been proposed by the Academic Council.`
  line
  line `(2) The Executive Council shall not have power to amend any draft proposed by the Academic`
  line `Council under the provisions of sub-section (1) but may reject the proposal or return the draft to the`
  line `Academic Council for reconsideration, either in whole or in part, together with any amendments`
  line `which the Executive Council may suggest.`
  line
  line `(3) Where the Executive Council has rejected the draft of an Ordinance proposed by the Academic`
  line `Council, the Academic Council may appeal to the Central Government and the Central Government`
  line `may, by order, direct that the proposed Ordinance shall be laid before the next meeting of the Court`
  line `for its approval and that pending such approval it shall have effect from such date as may be specified`
  line `in the order:`
  line
  line `Provided that if the Ordinance is not approved by the Court at such meeting, it shall cease to have`
  line effect.
  line
  line `(4) All Ordinances made by the Executive Council shall be submitted, as soon as may be, to the`
  line `Visitor and the Court, and shall be considered by the Court at its next meeting and the Court shall`
  line `have power, by a resolution passed by a majority of not less than two-thirds of the members voting, to`
  line `cancel any Ordinance made by the Executive Council, and such Ordinance shall from the date of such`
  line `resolution cease to have effect.`
  line
  line `(5) The Visitor may, by order, direct that the operation of any Ordinance shall be suspended until`
  line `he has had an opportunity of exercising his power of disallowance, and any order of suspension under`
  line `this sub-section shall cease to have effect on the expiration of one month from the date of such order`
  line `or on the expiration of fifteen days from the date of consideration of the Ordinance by the Court,`
  line `whichever period expires later.`
  line
  line `(6) The Visitor may, at any time after an Ordinance has been considered by the Court, signify to`
  line `the Executive Council his disallowance of such Ordinance, and from the date of receipt by the`
  line `Executive Council of intimation of such disallowance such Ordinance shall cease to have effect.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (47707)
  sectionNo (32)
  orderNo 34
  title Regulations.
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47707&sectionno=32&orderno=34&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_32_content:
  string
  line `(1) The authorities ^1* * * of the University may make Regulations consistent`
  line `with this Act, the Statutes, and the Ordinances--`
  line
  line `(a) laying down the procedure to be observed at their meetings and the number of members`
  line `required to form a quorum;`
  line
  line `(b) providing for all matters which by this Act, the Statutes or the Ordinances are to be`
  line `prescribed by Regulations; and`
  line
  line `(c) providing for all other matters solely concerning such authorities ^2[or Committees`
  line `appointed by them] and not provided for by this Act, the Statutes or the Ordinances.`
  line
  line `(2) Every authority of the University shall make Regulations providing for the giving of notice to`
  line `the members of such authority of the dates of meetings and of the business to be considered at`
  line `meetings, and for keeping of a record of the proceedings of meetings.`
  line
  line `(3) The Executive Council may direct the amendment, in such manner as it may specify,`
  line `of any Regulation made under this section or the annulment of any Regulation made under`
  line `sub-section (1):`
  line
  line `Provided that any authority or Board of the University which is dissatisfied with any such direction`
  line `may appeal to the ^3[Court], whose decision in the matter shall be final.`
  line
  line `^4(4) Every Statute, Ordinance or Regulation made under this Act shall be published in the`
  line `Official Gazette.`
  line
  line `(5) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the`
  line `expiry of the session immediately following the session or the successive sessions aforesaid, both`
  line `Houses agree in making any modification in the Statute, Ordinance or Regulation or both Houses`
  line `agree that the Statute, Ordinance or Regulation should not be made, the Statute, Ordinance or`
  line `Regulation shall thereafter have effect only in such modified form or be of no effect, as the case may`
  line `be; so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that the Statute, Ordinance or Regulation."`
obj_root_law_sections_32_footnotes:
  string
  line `1. The words "and the Board" omitted by Act 5 of 1952, s. 19.`
  line
  line `2. Subs. by s. 19, ibid., for "and Boards".`
  line
  line `3. Subs. by Act 5 of 1952, s. 19, for "Central Government".`
  line
  line `4. Ins. by Act 4 of 2005, s. 32 (w.e.f. 11-01-2005).`
obj_root_law_sections_33:
  sectionId (47708)
  sectionNo (33)
  orderNo 35
  title Residence.
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47708&sectionno=33&orderno=35&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_33_content:
  string
  line `Every student of the University ^1[(other than a student who pursues a course of`
  line `study by correspondence)[] shall reside in a College or a Hall, or under such conditions as may be`
  line `prescribed by ^2*** the Ordinances.`
obj_root_law_sections_33_footnotes:
  string
  line `1. Ins. by Act 61 of 1961, s. 4 (w.e.f. 1-2-1962).`
  line
  line `2. The words "the Statutes and" omitted by Act 5 of 1952, s. 20.`
obj_root_law_sections_34:
  sectionId (47709)
  sectionNo (34)
  orderNo 36
  title Colleges.
  content obj_root_law_sections_34_content
  footnotes `1. Subs. by Act 24 of 1943, s. 10, for sub-section (1).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47709&sectionno=34&orderno=36&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_34_content:
  string
  line `^1[(1) The Colleges shall be such as may, after the commencement of the Delhi`
  line `University (Amendment) Act, 1943 (24 of 1943); be recognised by the Executive Council in`
  line `accordance with this Act and the Statutes, but shall include all Colleges recognised at the`
  line `commencement of the said Act as Colleges of the University so long as such recognition continues.]`
  line
  line `(2) The conditions of residence in the Colleges shall be prescribed by the Ordinances, and every`
  line `College shall be subject to inspection by any member of the Residence, Health and Discipline Board`
  line `authorised in this behalf by the Board and by any officer of the University authorised in this behalf by`
  line `the Executive Council.`
obj_root_law_sections_35:
  sectionId (47710)
  sectionNo (35)
  orderNo 37
  title Halls.
  content obj_root_law_sections_35_content
  footnotes `1. Subs. by Act 5 of 1952, s. 21, for "Statutes".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47710&sectionno=35&orderno=37&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_35_content:
  string
  line `(1) The Halls shall be such as may be maintained by the University or approved and`
  line `recognised by the Executive Council on such general or special conditions as may be prescribed by`
  line `the Ordinances.`
  line
  line `(2) The wardens and superintending staff of the Halls shall be appointed in the manner`
  line `prescribed by the ^1[Ordinances].`
  line
  line `(3) The conditions of residence in the Halls shall be prescribed by the Ordinances, and every`
  line `Hall shall be subject to inspection by any member of the Residence, Health and Discipline Board`
  line `authorised in this behalf by the Board and by any officer of the University or other person`
  line `authorised in this behalf by the Executive Council.`
  line
  line `(4) The Executive Council shall have power to suspend or withdraw the recognition of any`
  line `Hall which is not conducted in accordance with the conditions prescribed by the Ordinances.`
