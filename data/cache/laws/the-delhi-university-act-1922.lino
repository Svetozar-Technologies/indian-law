obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (47713)
  sectionNo (38)
  orderNo 40
  title `Annual report.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47713&sectionno=38&orderno=40&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_38_content:
  string
  line `^1[(1)] The Annual report of the University shall be prepared under the`
  line `direction of the Executive Council, and shall be submitted to the Court on or before such date as may`
  line `be prescribed by the Statutes, and shall be considered by the Court at its annual meeting. The Court`
  line `may pass resolutions thereon and communicate the same to the Executive Council.`
  line
  line `^2(2) A copy of the annual report, as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line `Parliament."`
obj_root_law_sections_38_footnotes:
  string
  line `1. Section 38 renumbered as sub-section (1) thereof by Act 25 of 2008, s. 4 (w.e.f. 05-12-2008).`
  line `2. Ins. by s.4, ibid. (w.e.f. 05-12-2008).`
obj_root_law_sections_39:
  sectionId (47714)
  sectionNo (39)
  orderNo 41
  title `Audit of accounts.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47714&sectionno=39&orderno=41&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_39_content:
  string
  line `^1[39. Audit of accounts.-- (1) The accounts of the University shall, once at least in every year and`
  line `at intervals of not more than fifteen months, be audited by the Comptroller and Auditor-General of`
  line India.
  line
  line `(2) The accounts, when audited, shall be published in the Gazette of India, and a copy of the`
  line `accounts together with the audit report shall be submitted by the University to the Visitor.]`
  line
  line `^2[(3) A copy of the accounts, together with the audit report, shall also be submitted to the Central`
  line `Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line `Parliament."]`
obj_root_law_sections_39_footnotes:
  string
  line `1. Subs. by s. 23, ibid., for section 39.`
  line
  line `2. Ins. by Act 25 of 2008, s. 5. (w.e.f. 05-12-2008)`
