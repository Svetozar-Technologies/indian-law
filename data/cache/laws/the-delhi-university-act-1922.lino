obj_root_law_sections_16:
  sectionId (47692)
  sectionNo (16)
  orderNo 18
  title `Powers and duties of officers, etc.`
  content obj_root_law_sections_16_content
  footnotes `1. Subs. by s. 11, ibid., for section 16.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47692&sectionno=16&orderno=18&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_16_content:
  string
  line `^1[16. Powers and duties of officers, etc.-- Subject to the provisions of this Act, the powers and`
  line `duties of the officers of the University, the terms for which they shall hold office and the filling of`
  line `casual vacancies in such offices shall be provided for by the Statutes.]`
obj_root_law_sections_17:
  sectionId (47693)
  sectionNo (17)
  orderNo 19
  title `Authorities of the University.`
  content obj_root_law_sections_17_content
  footnotes `1. Ins. by Act 5 of 1952, s. 12.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47693&sectionno=17&orderno=19&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_17_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(i) the Court,`
  line
  line `(ii) the Executive Council,`
  line
  line `(iii) the Academic Council,`
  line
  line `^1[(iiia) the Finance Committee,]`
  line
  line `(iv) the Faculties, and`
  line
  line `(v) such other authorities as may be declared by the Statutes to be authorities of the University.`
obj_root_law_sections_18:
  sectionId (47694)
  sectionNo (18)
  orderNo 20
  title `The Court.`
  content obj_root_law_sections_18_content
  footnotes `1. Subs. by s. 13, ibid., for section 18.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00039_192208_1523344160352&sectionId=47694&sectionno=18&orderno=20&orgactid=AC_CEN_9_30_00039_192208_1523344160352
obj_root_law_sections_18_content:
  string
  line `^1[18. The Court.--The Court shall be the supreme authority of the University and shall have the`
  line `power to review the acts of the Executive Council and the Academic Council (save when these`
  line `authorities have acted in accordance with the powers conferred upon them under this Act, the Statutes`
  line `or the Ordinances) and shall exercise all the powers of the University not otherwise, provided for by`
  line `this Act or the Statutes.]`
obj_root_law_sections_19:
  sectionId (47695)
  sectionNo (19)
  orderNo 21
  title [Omitted.].
  content obj_root_law_sections_19_content
