  (str title) (str [Omitted.].)
  (str content) (str `[81. Stamping of piece goods, cotton yarn and thread.] Omitted by s. 7, ibid. (w.e.f. 8-7-2013).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00004_199947_1517807323972&sectionId=16873&sectionno=81&orderno=88&orgactid=AC_CEN_11_60_00004_199947_1517807323972)
obj_root_law_sections_82:
  object
