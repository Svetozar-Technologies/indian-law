obj_root_law_sections_91:
  sectionId (16883)
  sectionNo (91)
  orderNo 99
  title `Appeals to High Court.`
  content obj_root_law_sections_91_content
  footnotes `1. Subs. by Act 33 of 2021, s. 21, for “Appellate Board” (w.e.f. 4-4-2021).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00004_199947_1517807323972&sectionId=16883&sectionno=91&orderno=99&orgactid=AC_CEN_11_60_00004_199947_1517807323972
obj_root_law_sections_91_content:
  string
  line `(1) Any person aggrieved by an order or decision of the Registrar`
  line `under this Act, or the rules made thereunder may prefer an appeal to the ^1[High Court] within three`
  line `months from the date on which the order or decision sought to be appealed against is communicated to`
  line `such person preferring the appeal.`
  line
  line `(2) No appeal shall be admitted if it is preferred after the expiry of the period specified under`
  line `sub-section (1):`
  line
  line `Provided that an appeal may be admitted after the expiry of the period specified therefor, if the`
  line `appellant satisfies the ^1[High Court] that he had sufficient cause for not preferring the appeal within the`
  line `specified period.`
  line
  line `(3) An appeal to the ^1[High Court] shall be in the prescribed form and shall be verified in the`
  line `prescribed manner and shall be accompanied by a copy of the order or decision appealed against and by`
  line `such fees as may be prescribed.`
obj_root_law_sections_92:
  sectionId (16884)
  sectionNo (92)
  orderNo 100
  title `Procedure and powers of Appellate Board.`
  content `Omitted by The Tribunal Reforms Act, 2021 (33 of 2021), s. 21 (w.e.f. 4-4-2021).`
  footnotes obj_root_law_sections_92_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00004_199947_1517807323972&sectionId=16884&sectionno=92&orderno=100&orgactid=AC_CEN_11_60_00004_199947_1517807323972
