  (str content) (str `[82. Determination of character of textile goods by sampling.] Omitted by s. 7, ibid.
(w.e.f. 8-7-2013).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00004_199947_1517807323972&sectionId=16874&sectionno=82&orderno=89&orgactid=AC_CEN_11_60_00004_199947_1517807323972)
obj_root_law_sections_83:
  object
  (str sectionId) (str 16875)
  (str sectionNo) (str 83)
