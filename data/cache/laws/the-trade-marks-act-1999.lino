obj_root_law_sections_96_footnotes:
  string
  line
obj_root_law_sections_97:
  sectionId (16889)
  sectionNo (97)
  orderNo 105
  title `Procedure for application for rectification, etc., before High Court.`
  content obj_root_law_sections_97_content
  footnotes `1. Subs. by Act 33 of 2021, s. 21, for “Appellate Board” (w.e.f. 4-4-2021).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00004_199947_1517807323972&sectionId=16889&sectionno=97&orderno=105&orgactid=AC_CEN_11_60_00004_199947_1517807323972
obj_root_law_sections_97_content:
  string
  line `(1) An application`
  line `for rectification of the register made to the ^1[High Court] under section 57 shall be in such form as may`
  line `be prescribed.`
  line
  line `(2) A certified copy of every order or judgment of the ^1[High Court] relating to a registered trade`
  line `mark under this Act shall be communicated to the Registrar by the Board and the Registrar shall give`
  line `effect to the order of the Board and shall, when so directed, amend the entries in, or rectify, the register in`
  line `accordance with such order.`
obj_root_law_sections_98:
  sectionId (16890)
  sectionNo (98)
  orderNo 106
  title `Appearance of Registrar in legal proceedings.`
  content obj_root_law_sections_98_content
  footnotes obj_root_law_sections_98_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00004_199947_1517807323972&sectionId=16890&sectionno=98&orderno=106&orgactid=AC_CEN_11_60_00004_199947_1517807323972
obj_root_law_sections_98_content:
  string
  line `(1) The Registrar shall have the right to appear`
  line `and be heard--`
  line
  line `(a) in any legal proceedings before the ^1[High Court] in which the relief sought includes`
  line `alteration or rectification of the register or in which any question relating to the practice of the Trade`
  line `Marks Registry is raised;`
  line
  line `(b) in any appeal to the ^2[High Court] from an order of the Registrar on an application for registration of`
  line `a trade mark--`
  line
  line `(i) which is not opposed, and the application is either refused by the Registrar or is accepted`
  line `by him subject to any amendments, modifications, conditions or limitations, or`
  line
  line `(ii) which has been opposed and the Registrar considers that his appearance is necessary in`
  line `the public interest,`
  line
  line `and the Registrar shall appear in any case if so directed by the Board.`
  line
  line `(2) Unless the ^1[High Court] otherwise directs, the Registrar may, in lieu of appearing, submit a`
  line `statement in writing signed by him, giving such particulars as he thinks proper of the proceedings before`
  line `him relating to the matter in issue or of the grounds of any decision given by him affecting it, or of the`
  line `practice of the Trade Marks Registry in like cases, or of other matters relevant to the issues and within his`
  line `knowledge as Registrar, and such statement shall be evidence in the proceeding.`
obj_root_law_sections_98_footnotes:
  string
  line `1. Subs. by Act 33 of 2021, s. 21, for “Appellate Board” (w.e.f. 4-4-2021).`
  line
  line `2. Subs. by s. 21, ibid., for “Board” (w.e.f. 4-4-2021).`
obj_root_law_sections_99:
