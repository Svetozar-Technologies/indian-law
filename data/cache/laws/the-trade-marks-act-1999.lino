obj_root_law:
  slug the-trade-marks-act-1999
  handle (1993)
  collectionHandle 123456789/1362
  title `The Trade Marks Act, 1999`
  actNumber (47)
  enactmentDate 1999-12-30
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1993`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `व्‍यापार चिह्न अधिनियम, 1999`
  actYear (1999)
  ministry `Ministry of Commerce and Industry`
  department `Department of Promotion of Industry and Internal Trade`
  longTitle `An Act to amend and consolidate the law relating to trade marks, to provide for registration and better protection of trade marks for goods and services and for the prevention of the use of fraudulent marks.`
  enforcementDate 15-09-2003
  notification `15th September, 2003, vide notification No. S.O. 1048(E), dated 15th September, 2003, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T21:39:53.501Z`
  translations obj_root_law_translations
