obj_root_law_sections_1:
  sectionId (29786)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Andhra Pradesh Legislative Council Act, 2005.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00031_200601_1517807324932&sectionId=29786&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00031_200601_1517807324932
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (29787)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00031_200601_1517807324932&sectionId=29787&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00031_200601_1517807324932
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires, each of the words and expressions`
  line `used herein and not defined but defined in the Representation of the People Act, 1950 (43 of 1950), shall`
  line `have the same meaning as in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (29788)
  sectionNo (3)
  orderNo 3
  title `Creation of Legislative Council for Andhra Pradesh.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00031_200601_1517807324932&sectionId=29788&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00031_200601_1517807324932
obj_root_law_sections_3_content:
  string
  line `(1) As from such date^1as the President`
  line `may by order appoint, there shall be a Legislative Council for the State of Andhra Pradesh; and as from`
  line `that date, in sub-clause (a) of clause (1) of article 168, after the words "States of", the words "Andhra`
  line `Pradesh,", shall be inserted.`
  line
  line `(2) In the said Council, there shall be 90 seats of which--`
  line
  line `(a) the numbers to be filled by persons elected by the electorates referred to in sub-clauses (a), (b)`
  line `and (c) of clause (3) of article 171 shall be 31, 8 and 8 respectively;`
  line
  line `(b) the number to be filled by persons elected by the members of the Legislative Assembly of`
  line `Andhra Pradesh in accordance with the provisions of sub-clause (d) of the said clause shall be 31; and`
  line
  line `(c) the number to be filled by persons nominated by the Governor of Andhra Pradesh in`
  line `accordance with the provisions of sub-clause (e) of that clause shall be 12.`
  line
  line `(3) As soon as may be after the commencement of this Act, the President, after consultation with the`
  line `Election Commission, shall, by order, determine--`
  line
  line `(a) the constituencies into which the State of Andhra Pradesh shall be divided for the purpose of`
  line `elections to the said Council under each of the sub-clauses (a), (b) and (c) of clause (3) of article 171;`
  line
  line `(b) the extent of each constituency; and`
  line
  line `(c) the number of seats to be allotted to each constituency.`
  line
  line `(4) As soon as may be after such determination, steps shall be taken to constitute the said Council in`
  line `accordance with the provisions of this Act, the Representation of the People Act, 1950 (43 of 1950) and`
  line `the Representation of the People Act, 1951 (43 of 1951).`
obj_root_law_sections_3_footnotes:
  string
  line `1. 30th March, 2007, (Legislative Council for Andhra Pradesh come to existence), vide notification No. G.S.R. 262(E), dated`
  line `30th March, 2007, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_4:
  sectionId (29789)
  sectionNo (4)
  orderNo 4
  title `Amendment of Third Schedule and Fourth Schedule of Act 43 of 1950.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00031_200601_1517807324932&sectionId=29789&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00031_200601_1517807324932
obj_root_law_sections_4_content:
  string
  line `In the Representation`
  line `of the People Act, 1950,--`
  line
  line `(a) in the Third Schedule, before entry No. 2 relating to Bihar, the following entry shall be`
  line `inserted, namely:--`
  line
  line `"1. Andhra Pradesh 90 31 8 8 31 12";`
  line
  line `(b) in the Fourth Schedule, before the heading "BIHAR", the following heading and entries shall`
  line `be inserted, namely:--`
  line
  line `"ANDHRA PRADESH`
  line
  line `1. Municipal Corporations.`
  line
  line `2. Municipalities.`
  line
  line `3. Nagar Panchayats.`
  line
  line `4. Cantonment Boards.`
  line
  line `5. ZilaPraja Parishads.`
  line
  line `6. Mandal Praja Parishads.".`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (29790)
  sectionNo (5)
  orderNo 5
  title `Amendment of section 15A of Act 43 of 1951.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00031_200601_1517807324932&sectionId=29790&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00031_200601_1517807324932
obj_root_law_sections_5_content:
  string
  line `In section 15A of the Representation of the`
  line `People Act, 1951, for the words and figures "under the Legislative Councils Act, 1957" (37of 1957),`
  line `the words and figures "under the Andhra Pradesh Legislative Council Act, 2005" shall be substituted.`
obj_root_law_sections_5_footnotes:
  string
  line
