obj_root_law:
  slug the-coast-guard-act-1978
  handle (1734)
  collectionHandle 123456789/1362
  title `The Coast Guard Act, 1978`
  actNumber (30)
  enactmentDate 1978-08-18
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1734`
  sources obj_root_law_sources
