obj_root_law_sections_1:
  sectionId (23653)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23653&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Pondicherry University`
  line `Act, 1985.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 16th October, 1985, vide notification No. S.O. 751(E), dated 14th October, 1985, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (23654)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23654&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(d) "Chancellor" and "Vice-Chancellor" mean, respectively, the Chancellor and Vice-Chancellor`
  line `of the University;`
  line
  line `(e) "College" means a College maintained by, or admitted to the privileges of, the University;`
  line
  line `(f) "Court" means the Court of the University;`
  line
  line `(g) "Department" means a Department of Studies, and includes a Centre of Studies;`
  line
  line `(h) "Director" means any of the Directors referred to in clauses (3), (4) and (5) of section 11;`
  line
  line `(i) "employee" means any person appointed by the University, and includes teachers and other`
  line `staff of the University;`
  line
  line `(j) "Executive Council" means the Executive Council of the University;`
  line
  line `(k) "Hall" means a unit of residence or of corporate life for the students of the University, College`
  line `or Institution, provided, maintained or recognised by the University;`
  line
  line `(l) "Institution" means an academic institution, not being a College, maintained by, or admitted to`
  line `the privileges of the University;`
  line
  line `(m) "Principal" means the Head of a College or an Institution, and includes where there is no`
  line `Principal, the person for the time being duly appointed to act as Principal, and, in the absence of the`
  line `Principal or acting Principal, a Vice-Principal duly appointed as such;`
  line
  line `(n) "recognised institution" means an institution of higher learning recognised by the University;`
  line
  line `(o) "recognised teachers" means such persons as are recognised by the University for the purpose`
  line `of imparting instruction in a College or an Institution admitted to the privileges of the University;`
  line
  line `(p) "School" means a School of Studies of the University;`
  line
  line `(q) "Statutes", "Ordinances" and "Regulations" mean, respectively, the Statutes, Ordinances and`
  line `Regulations of the University for the time being in force;`
  line
  line `(r) "teachers of the University" means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instruction or conducting research in the University or in any College`
  line `or Institution maintained by the University and are designated as teachers by the Ordinances;`
  line
  line `(s) "University" means the Pondicherry University.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (23655)
  sectionNo (3)
  orderNo 3
  title `The University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23655&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established a University by the name of "Pondicherry`
  line `University".`
  line
  line `(2) The headquarters of the University shall be at Pondicherry and it may also establish campuses at`
  line `such other places within its jurisdiction as it may deem fit.`
  line
  line `(3) The first Chancellor and the first Vice-Chancellor and the first members of the Court, the`
  line `Executive Council and the Academic Council and all persons who may hereafter become such officers or`
  line `members, so long as they continue to hold such office or membership, are hereby constituted by a body`
  line `corporate by the name of "Pondicherry University".`
  line
  line `(4) The University shall have perpetual succession and a common seal and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (23656)
  sectionNo (4)
  orderNo 4
  title Objects.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23656&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_4_content:
  string
  line `The objects of the University shall be to disseminate and advance knowledge by`
  line `providing instructional and research facilities in such branches of learning as it may deem fit and by the`
  line `example of its corporate life, and, in particular, to make special provisions for studies in French and for`
  line `integrated courses for humanity and science in the educational programmes of the University and to take`
  line `appropriate measures for promoting inter-disciplinary studies and research in the University.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (23657)
  sectionNo (5)
  orderNo 5
  title `Powers of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23657&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_5_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(1) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provision for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(2) to provide for and organise studies in French;`
  line
  line `(3) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing, on persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(4) to organise and to undertake extra-mural studies and extension services;`
  line
  line `(5) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(6) to provide, instruction, including correspondence and such other courses, to such persons as`
  line `are not members of the University, as it may determine;`
  line
  line `(7) to institute Principalships, Professorships, Readerships, Lecturerships and other teaching or`
  line `academic posts required by the University and to appoint persons to such Principalships,`
  line `Professorships, Readerships, Lecturerships or other posts;`
  line
  line `(8) to recognise an Institution of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(9) to recognise persons for imparting instruction in any College or Institution admitted to the`
  line `privileges of the University;`
  line
  line `(10) to appoint persons working in any other university or organisation as teachers of the`
  line `University for a specified period;`
  line
  line `(11) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(12) to co-operate or collaborate or associate with any other university or authority or institution`
  line `of higher learning in such manner and for such purposes as the University may determine;`
  line
  line `(13) to establish such campuses, special centres, specialised laboratories or other units for`
  line `research and instruction as are, in the opinion of the University, necessary for the furtherance of its`
  line objects;
  line
  line `(14) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(15) to establish and maintain Colleges, Institutions and Halls;`
  line
  line `(16) to make provision for research and advisory services; and for that purpose to enter into such`
  line `arrangements with other institutions or bodies as the University may deem necessary;`
  line
  line `(17) to admit to its privileges Colleges and Institutions not maintaned by the University; to`
  line `withdraw all or any of those privileges in accordance with such conditions as may be prescribed by`
  line `the Statutes; and to recognise Halls not maintained by the University and to withdraw any such`
  line recognition;
  line
  line `(18) to declare a College, an Institution or a Department as an autonomous College or an`
  line `Institution or a Department, as the case may be;`
  line
  line `(19) to determine standards for admission into the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(20) to demand and receive payment of fees and other charges;`
  line
  line `(21) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(22) to make special arrangements in respect of women students as the University may consider`
  line desirable;
  line
  line `(23) to regulate and enforce discipline among the employees and students of the University and`
  line `take such disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(24) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(25) to receive donations and to acquire, hold, manage and dispose of any property, movable or`
  line `immovable, including trust and endowment properties for the purposes of the University;`
  line
  line `(26) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University;`
  line
  line `(27) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of the objects of the University.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (23658)
  sectionNo (6)
  orderNo 6
  title `Establishment of certain Schools.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23658&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_6_content:
  string
  line `The University shall also establish a School for studies in`
  line `Eastern and Western Thought to be known as "Sri Aurobindo School of Eastern and Western Thought"`
  line `and another School for studies in Tamil language and literature to be known as Subramania Bharati`
  line `School of Tamil Language and Literature.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (23659)
  sectionNo (7)
  orderNo 7
  title Jurisdiction.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23659&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_7_content:
  string
  line `(1) The jurisdiction of the University shall extend to the whole of the Union`
  line `territory of Pondicherry:`
  line
  line `Provided that the University may, at the request of the Administrator of the Union territory of the`
  line `Andaman and Nicobar Islands or of the Union territory of Lakshadweep and with the prior approval of`
  line `the Central Government, extend its jurisdiction to those territories.`
  line
  line `(2) No college or institution situated within the local limits of the jurisdiction of the University shall`
  line `be compulsorily affiliated to the University and affiliation shall be granted by the University only to such`
  line `colleges or institutions as may agree to accept the Statutes and Ordinances.`
  line
  line `(3) Any college or institution admitted to the privileges of the University shall cease to be associated`
  line `with, or be admitted to the privileges of, any other university.`
  line
  line `(4) No college or institution situated within the local limits of the jurisdiction of the University, but`
  line `not admitted to its privileges, shall be associated with, or be admitted to the privileges of, any other university except with the previous approval of the Administrator of the Union territory in which such`
  line `college or institution is situated.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (23660)
  sectionNo (8)
  orderNo 8
  title `University open to all classes, castes and creed.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23660&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_8_content:
  string
  line `(1) The University shall be open to persons of`
  line `either sex and of whatever race, creed, caste, or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person any test whatsoever of religious belief or profession in order to entitle him to be`
  line `admitted therein, as a teacher or student, or to hold any office therein, or to graduate thereat:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for the weaker sections of the people and, in particular, of the Scheduled Castes and the`
  line `Scheduled Tribes.`
  line
  line `(2) French nationals of Indian origin who have been permitted to long-term residence in the Union`
  line `territory of Pondicherry under the provisions of the Treaty of Cession shall also be eligible for admission`
  line `to the University.`
  line
  line `Explanation.--Treaty of Cession has the meaning assigned to it in the Pondicherry (Administration)`
  line `Act, 1962 (49 of 1962).`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (23661)
  sectionNo (9)
  orderNo 9
  title Visitor.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23661&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_9_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor shall have the right to cause an inspection to be made by such person or persons as he`
  line `may direct, of the University, its buildings, laboratories and equipment, and of any College or Institution`
  line `maintained by the University or admitted to its privileges; and also of the examinations, teaching and`
  line `other work conducted or done by the University and to cause an inquiry to be made in like manner in`
  line `respect of any matter connected with the administration or finances of the University, Colleges or`
  line Institutions.
  line
  line `(3) The Visitor shall, in every case, give notice of his intention to cause an inspection or inquiry to be`
  line made,--
  line
  line `(a) to the University, if such inspection or inquiry is to be made in respect of the University,`
  line `College or Institution maintained by it, or`
  line
  line `(b) to the management of the College or Institution, if the inspection or inquiry is to be made in`
  line `respect of a College or an Institution admitted to the privileges of the University,`
  line
  line `and the University or the management, as the case may be, shall have the right to make such`
  line `representations to the Visitor, as it may consider necessary.`
  line
  line `(4) After considering the representations, if any, made by the University or the management, as the`
  line `case may be, the Visitor may cause to be made such inspection or inquiry as is referred to in`
  line `sub-section (2).`
  line
  line `(5) Where any inspection or inquiry has been caused to be made by the Visitor, the University or the`
  line `management, as the case may be, shall be entitled to appoint a representative who shall have the right to`
  line `be present and be heard at such inspection or inquiry.`
  line
  line `(6) The Visitor may, if the inspection or inquiry is made in respect of the University or any College or`
  line `Institution maintained by it, address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry, and the Vice-Chancellor shall communicate to the Executive Council the views of the Visitor`
  line `with such advice as the Visitor may be pleased to offer upon the action to be taken thereon.`
  line
  line `(7) The Visitor may, if the inspection or inquiry is made in respect of any College or Institution`
  line `admitted to the privileges of the University, address the management concerned through the`
  line `Vice-Chancellor with reference to the result of such inspection or inquiry, his views thereon and such`
  line `advice as he may be pleased to offer upon the action to be taken thereon.`
  line
  line `(8) The Executive Council or the management, as the case may be, shall communicate through the`
  line `Vice-Chancellor to the Visitor such action, if any, as it proposes to take or has been taken upon the result`
  line `of such inspection or inquiry.`
  line
  line `(9) Where the Executive Council or the management does not, within a reasonable time, take action`
  line `to the satisfaction of the Visitor, the Visitor may, after considering any explanation furnished or`
  line `representation made by the Executive Council or management, issue such directions as he may think fit`
  line `and the Executive Council or management, as the case may be, shall comply with such directions.`
  line
  line `(10) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annul any proceeding of the University which is not in conformity with this Act, the Statutes or`
  line `Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the University to show cause why`
  line `such an order should not be made, and, if any cause is shown within a reasonable time, he shall consider`
  line `the same.`
  line
  line `(11) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (23662)
  sectionNo (10)
  orderNo 10
  title `Chief Rector.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23662&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_10_content:
  string
  line `The Administrator of the Union territory of Pondicherry shall be the Chief Rector`
  line `of the University.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (23663)
  sectionNo (11)
  orderNo 11
  title `Officers of the University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23663&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_11_content:
  string
  line `The following shall be the officers of the University:--`
  line
  line `(1) The Chancellor;`
  line
  line `(2) The Vice-Chancellor;`
  line
  line `(3) The Director of Studies, Educational Innovations and Rural Reconstruction;`
  line
  line `(4) The Director of Culture and Cultural Relations;`
  line
  line `(5) The Director of Physical Education, Sports, National Service and Students Welfare;`
  line
  line `(6) The Deans of Schools;`
  line
  line `(7) The Registrar;`
  line
  line `(8) The Finance Officer; and`
  line
  line `(9) Such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (23664)
  sectionNo (12)
  orderNo 12
  title `The Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23664&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_12_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the Head of the University.`
  line
  line `(3) The Chancellor shall, if present, preside at the convocations of the University held for conferring`
  line degrees.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (23665)
  sectionNo (13)
  orderNo 13
  title `The Vice-Chancellor.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23665&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_13_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University, and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been taken, it`
  line `may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to appeal against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated`
  line `to him and thereupon the Executive Council may confirm, modify or reverse the action taken by the`
  line Vice-Chancellor.
  line
  line `(4) The Vice-Chancellor shall exercise such other powers and perform such other functions as may be`
  line `prescribed by the Statutes or Ordinances.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (23666)
  sectionNo (14)
  orderNo 14
  title Directors.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23666&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_14_content:
  string
  line `The Directors shall be appointed in such manner and shall exercise such powers and`
  line `perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (23667)
  sectionNo (15)
  orderNo 15
  title `Deans of Schools.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23667&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_15_content:
  string
  line `Every Dean of a School shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (23668)
  sectionNo (16)
  orderNo 16
  title `The Registrar.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23668&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_16_content:
  string
  line `(1) The Registrar shall be appointed in such manner as may be prescribed by the`
  line Statutes.
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such other powers and perform such other duties as`
  line `may be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (23669)
  sectionNo (17)
  orderNo 17
  title `The Finance Officer.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23669&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_17_content:
  string
  line `The Finance Officer shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (23670)
  sectionNo (18)
  orderNo 18
  title `Other officers.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23670&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_18_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (23671)
  sectionNo (19)
  orderNo 19
  title `Authorities of the University.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23671&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_19_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(1) The Court;`
  line
  line `(2) The Executive Council;`
  line
  line `(3) The Academic Council;`
  line
  line `(4) The Boards of Schools;`
  line
  line `(5) The Planning Board; and`
  line
  line `(6) Such other authorities as may be declared by the Statutes to be authorities of the University.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (23672)
  sectionNo (20)
  orderNo 20
  title `The Court.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23672&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_20_content:
  string
  line `(1) The constitution of the Court and the term of office of its members shall be`
  line `prescribed by the Statutes.`
  line
  line `(2) Subject to the provisions of this Act, the Court shall have the following powers and functions,`
  line `namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the University`
  line `and the audit report on such accounts;`
  line
  line `(c) to advise the Visitor in respect of any matter which may be referred to it for advice; and`
  line
  line `(d) to perform such other functions as may be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (23673)
  sectionNo (21)
  orderNo 21
  title `The Executive Council.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23673&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_21_content:
  string
  line `(1) The Executive Council shall be the principal executive body of the`
  line University.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `duties shall be prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (23674)
  sectionNo (22)
  orderNo 22
  title `The Academic Council.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23674&sectionno=22&orderno=22&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_22_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and Ordinances, co-ordinate and`
  line `exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of its members and its powers and`
  line `duties shall be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (23675)
  sectionNo (23)
  orderNo 23
  title `The Planning Board.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23675&sectionno=23&orderno=23&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_23_content:
  string
  line `(1) There shall be constituted in the University, a Planning Board, which`
  line `shall be an authority of the University.`
  line
  line `(2) The constitution of the Planning Board, term of office of its members and its powers and duties`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (23676)
  sectionNo (24)
  orderNo 24
  title `Other authorities of the University.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23676&sectionno=24&orderno=24&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_24_content:
  string
  line `The constitution, powers and functions of the Boards of`
  line `Schools and of such other authorities, as may be declared by the Statutes to be authorities of the`
  line `University, shall be prescribed by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (23677)
  sectionNo (25)
  orderNo 25
  title `Power to make Statutes.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23677&sectionno=25&orderno=25&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_25_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all`
  line `or any of the following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of the authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the election and continuance in office of the members of the said authorities and bodies, the`
  line `filling of vacancies of members, and all other matters relative to those authorities and other bodies for`
  line `which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers of the University and other academic staff and their emoluments;`
  line
  line `(e) the appointment of teachers and other academic staff working in any other University or`
  line `organisation for a specified period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provision for pension, insurance and`
  line `provident fund, the manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing seniority of service of employees;`
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(j) the establishment and recognition of Students Union or associations of teachers, academic`
  line `staff or other employees;`
  line
  line `(k) the participation of students in the affairs of the University;`
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(n) the institution of fellowhips, scholarships, studentships, medals and prizes;`
  line
  line `(o) the maintenance of discipline among the students;`
  line
  line `(p) the establishment and abolition of Schools, Departments, Halls, Colleges and Institutions;`
  line
  line `(q) the conditions under which Colleges and Institutions may be admitted to the privileges of the`
  line `University and the withdrawal of such privileges;`
  line
  line `(r) the delegation of powers vested in the authorities or officers of the University; and`
  line
  line `(s) all other matters which by this Act are to be, or may be, provided by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (23678)
  sectionNo (26)
  orderNo 26
  title `Statutes how to be made.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23678&sectionno=26&orderno=26&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_26_content:
  string
  line `(1) The first Statutes are those set out in the Schedule.`
  line
  line `(2) The Executive Council may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Executive Council shall not make, amend or repeal any Statute affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Executive Council.`
  line
  line `(3) Every new Statute or addition to the Statute or any amendment or repeal of a Statute shall require`
  line `the assent of the Visitor who may assent thereto or withhold assent or remit to the Executive Council for`
  line consideration.
  line
  line `(4) A new Statute or a statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may make new or`
  line `additional Statutes or amend or repeal the Statutes referred to in sub-section (1) during the period of three`
  line `years immediately after the commencement of this Act:`
  line
  line `Provided that the Visitor may, on the expiry of the said period of three years, make, within one year`
  line `from the date of such expiry, such detailed Statutes as he may consider necessary and such detailed`
  line `Statutes shall be laid before both Houses of Parliament.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (23679)
  sectionNo (27)
  orderNo 27
  title Ordinances.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23679&sectionno=27&orderno=27&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_27_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the Ordinances may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(f) the conditions of award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(g) the conduct of examinations, including the term of office and of appointment and the duties of`
  line `examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing of special courses of studies for them;`
  line
  line `(j) the appointment and emoluments of employees other than those for whom provision has been`
  line `made in the Statutes;`
  line
  line `(k) the establishment of Centres of Studies, Boards of Studies, Special Centres, specialised`
  line `laboratories and other Committees;`
  line
  line `(l) the manner of co-operation and collaboration with other Universities and authorities including`
  line `learned bodies or associations;`
  line
  line `(m) the creation, composition and functions of any other body which is considered necssary for`
  line `improving the academic life of the University;`
  line
  line `(n) such other terms and conditions of service of teachers and other academic staff as are not`
  line `prescribed by the Statutes;`
  line
  line `(o) the management of Colleges and Institutions established by the University;`
  line
  line `(p) the supervision and management of Colleges and Institutions admitted to the privileges of the`
  line `University; and`
  line
  line `(q) all other matters which by this Act or the Statutes may be provided for by the Ordinances.`
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Central Government and the Ordinances so made may be amended, repealed or added to at any time by`
  line `the Executive Council in the manner prescribed by the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (23680)
  sectionNo (28)
  orderNo 28
  title Regulations.
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23680&sectionno=28&orderno=28&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_28_content:
  string
  line `The authorities of the University may make Regulations consistent with this Act,`
  line `the Statutes and the Ordinances for the conduct of their own business and that of the committees`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances in the manner`
  line `prescribed by the Statutes.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (23681)
  sectionNo (29)
  orderNo 29
  title `Annual report.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23681&sectionno=29&orderno=29&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_29_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Executive Council and shall be submitted to the Court on or after such date as may be prescribed by`
  line `Statutes and the Court shall consider the report in its annual meeting.`
  line
  line `(2) The Court shall submit the annual report to the Visitor along with its comments, if any.`
  line
  line `(3) A copy of the annual report, as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (23682)
  sectionNo (30)
  orderNo 30
  title `Annual accounts.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23682&sectionno=30&orderno=30&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_30_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be`
  line `prepared under the directions of the Executive Council and shall, once at least every year and at intervals`
  line `of not more than fifteen months, be audited by the Comptroller and Auditor-General of India.`
  line
  line `(2) The annual accounts when audited shall be published in the Gazette of India and a copy of the`
  line `accounts together with the report of the Comptroller and Auditor-General shall be submitted to the Court`
  line `and the Visitor along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Court and the observations of the Court, if any, shall, after being considered by the Executive Council, be`
  line `submitted to the Visitor.`
  line
  line `(4) A copy of the annual accounts, together with the report of the Comptroller and Auditor-General,`
  line `shall also be submitted to the Central Government, which shall, as soon as may be, cause the same to be`
  line `laid before both Houses of Parliament.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (23683)
  sectionNo (31)
  orderNo 31
  title `Conditions of service of employees.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23683&sectionno=31&orderno=31&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_31_content:
  string
  line `(1) Every employee shall be appointed under a written`
  line `contract which shall be lodged with the University and a copy of which shall be furnished to the employee`
  line concerned.
  line
  line `(2) Any dispute arising out of a contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Executive Council, one member nominated by the employee concerned and an umpire appointed by`
  line `the Visitor. The decision of the Tribnal shall be final, and no suit shall lie in any civil court in respect of`
  line `the matters decided by the Tribunal. Every such request shall be deemed to be a submission to arbitration`
  line `upon the terms of this section within the meaning of the Arbitration Act, 1940 (10 of 1940).`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (23684)
  sectionNo (32)
  orderNo 32
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23684&sectionno=32&orderno=32&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_32_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the case`
  line `may be, and who has been debarred from appearing at the examinations of the University for more than`
  line `one year, may, within ten days of the date of receipt of such orders or copy of such resolution by him,`
  line `appeal to the Executive Council and the Executive Council may confirm, modify or reverse the decision`
  line `of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of`
  line `sub-section (2) of section 31 shall, as far as may be, apply to a reference made under this sub-section.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (23685)
  sectionNo (33)
  orderNo 33
  title `Right to appeal.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23685&sectionno=33&orderno=33&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_33_content:
  string
  line `Every employee or student of the University or of a College or Institution`
  line `shall, notwithstanding anything contained in this Act, have a right to appeal within such time as may be`
  line `prescribed by the Statutes, to the Executive Council against the decision of any officer or authority of the`
  line `University or of the Principal or the management of any College or Institution, as the case may be, and`
  line `thereupon the Executive Council may confirm, modify or reverse the decision appealed against.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (23686)
  sectionNo (34)
  orderNo 34
  title `Provident and pension funds.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23686&sectionno=34&orderno=34&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_34_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such pension or provident fund or provide such insurance schemes as it may deem fit in such`
  line `manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or pension fund has been so constituted, the Central Government may`
  line `declare that the provision of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund, as if it`
  line `were a Government provident fund.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (23687)
  sectionNo (35)
  orderNo 35
  title `Disputes as to constitution of University authorities and bodies.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23687&sectionno=35&orderno=35&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_35_content:
  string
  line `If any question arises as to`
  line `whether any person has been duly elected or appointed as, or is entitled to be, a member of any authority`
  line `or other body of the University, the matter shall be referred to the Visitor whose decision thereon shall be`
  line final.
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (23688)
  sectionNo (36)
  orderNo 36
  title `Constitution of committees.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23688&sectionno=36&orderno=36&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_36_content:
  string
  line `Where any authority of the University is given power by this Act`
  line `or the Statutes to appoint committees, such committees shall, save as otherwise provided, consist of the`
  line `members of the authority concerned and of such other person (if any) as the authority in each case may`
  line `think fit.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (23689)
  sectionNo (37)
  orderNo 37
  title `Filling of casual vacancies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23689&sectionno=37&orderno=37&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_37_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `members) of any authority or other body of the University shall be filled, as soon as conveniently may be,`
  line `by the person or body who appointed, elected or co-opted the member whose place has become vacant`
  line `and the person appointed, elected or co-opted to a casual vacancy shall be a member of such authority or`
  line `body for the residue of the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (23690)
  sectionNo (38)
  orderNo 38
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23690&sectionno=38&orderno=38&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_38_content:
  string
  line `No act or`
  line `proceedings of any authority or other body of the University shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (23691)
  sectionNo (39)
  orderNo 39
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23691&sectionno=39&orderno=39&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_39_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or employee of the University for anything which is in good faith done or intended to be done`
  line `in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (23692)
  sectionNo (40)
  orderNo 40
  title `Mode of proof of University record.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23692&sectionno=40&orderno=40&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_40_content:
  string
  line `A copy of any receipt, application, notice, order,`
  line `proceeding, resolution of any authority or committee of the University, or other documents in possession`
  line `of the University, or any entry in any register duly maintained by the University, if certified by the`
  line `Registrar, shall be received as prima facie evidence of such receipt, application, notice, order, proceeding`
  line `or resolution, documents or the existence of entry in the register and shall be admitted as evidence of the`
  line `matters and transactions therein where the original thereof would, if produced, have been admissible in`
  line `evidence, notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872) or in any`
  line `other law for the time being in force.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (23693)
  sectionNo (41)
  orderNo 41
  title `Power to remove difficulties.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23693&sectionno=41&orderno=41&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_41_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order published in the Official Gazette, make such provisions, not`
  line `inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (23694)
  sectionNo (42)
  orderNo 42
  title `Transitional provisions.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23694&sectionno=42&orderno=42&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_42_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes,--`
  line
  line `(a) the first Chancellor and the first Vice-Chancellor shall be appointed by the Visitor and each of`
  line `the said officers shall hold office for a term of five years;`
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Visitor and each of`
  line `the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Court and the first Executive Council shall consist of not more than thirty members`
  line `and eleven members, respectively, who shall be nominated by the Visitor and shall hold office for a`
  line `term of three years;`
  line
  line `(d) the first Academic Council shall be constituted on the expiry of a period of six months from`
  line `the commencement of this Act and during the said period of six months, the powers of the Academic`
  line `Council shall be performed by the Planning Board constituted under section 23;`
  line
  line `(e) the first Academic Council shall consist of not more than twenty-one members, who shall be`
  line `nominated by the Visitor and shall hold office for a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment or nomination, as the case may be, by the Visitor, and the person so appointed or nominated`
  line `shall hold office for so long as the officer or member in whose place he is appointed or nominated would`
  line `have held office, if such vacancy had not occurred.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (23695)
  sectionNo (43)
  orderNo 43
  title `Completion of courses of studies in colleges and institutions affiliated to the University.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23695&sectionno=43&orderno=43&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_43_content:
  string
  line `Notwithstanding anything contained in this Act, or in the Statutes or the Ordinances, any student of a`
  line `college or institution, who, immediately before the admission of such college or institution to the`
  line `privileges of the Pondicherry University, was studying for a degree, diploma or certificate of the`
  line `University of Madras, the University of Calicut or the Andhra University, shall be permitted by the`
  line `Pondicherry University to complete his courses for that degree, diploma or certificate, as the case may be,`
  line `and the Pondicherry University and such college or institution shall provide for the instructions and`
  line `examination of such student in accordance with the syllabus of studies of the respective University.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (23696)
  sectionNo (44)
  orderNo 44
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00025_198553_1517807326790&sectionId=23696&sectionno=44&orderno=44&orgactid=AC_CEN_9_30_00025_198553_1517807326790
obj_root_law_sections_44_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.`
obj_root_law_sections_44_footnotes:
  string
  line
