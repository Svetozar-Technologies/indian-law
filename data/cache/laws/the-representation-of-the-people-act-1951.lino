obj_root_law_sections_1:
  sectionId (29491)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Representation of the People Act, 1951.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29491&sectionno=1&orderno=1&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (29492)
  sectionNo (2)
  orderNo 2
  title Interpretation.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29492&sectionno=2&orderno=2&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,`
  line
  line `(a) each of the expressions defined in section 2 or sub-section (1) of section 27 of the`
  line `Representation of the People Act, 1950 (43 of 1950), but not defined in this Act, shall have the same`
  line `meaning as in that Act;`
  line
  line `(b) "appropriate authority" means, in relation to an election to the House of the People or the`
  line `Council of States ^1***, the Central Government, and in relation to an election to the Legislative`
  line `Assembly or the Legislative Council of a State, the State Government;`
  line
  line `^2[(bb) "chief electoral officer" means the officer appointed under section 13A of the`
  line `Representation of the People Act, 1950 (43 of 1950);]`
  line
  line `(c) "corrupt practice" means any of the practices specified in section 123 ^3***;`
  line
  line `^4[(cc) "district election officer" means the officer designated or nominated under section 13AA of`
  line `the Representation of the People Act, 1950 (43 of 1950);]`
  line
  line `(d) "election" means an election to fill a seat or seats in either House of Parliament or in the`
  line `House or either House of the Legislature of a State ^5*** ^6***;`
  line
  line `^8[(e) "elector in relation to a constituency" means a person whose name is entered in the electoral`
  line `roll of that constituency for the time being in force and who is not subject to any of the`
  line `disqualifications mentioned in section 16 of the Representation of the People Act, 1950 (43 of 1950);]`
  line
  line `^9[(f) "political party" means an association or a body of individual citizens of India registered`
  line `with the Election Commission as a political party under section 29A;]`
  line
  line `(g) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^4[(h) "public holiday" means any day which is a public holiday for the purposes of section 25 of`
  line `the Negotiable Instruments Act, 1881 (26 of 1881);]`
  line
  line `^10[(i)] "sign", in relation to a person who is unable to write his name, means authenticate in such`
  line `manner as may be prescribed.`
  line
  line `^11* * * * *`
  line
  line `^12* * * * *`
  line
  line `(2) For the purposes of this Act, ^13*** a Parliamentary constituency, an Assembly constituency, a`
  line `Council constituency, a local authorities' constituency, a graduates' constituency and a teachers'`
  line `constituency shall each be treated as a constituency of a different class.`
  line
  line `(3) Any requirement under this Act that a notification, order, rule, declaration, notice or list issued or`
  line `made by any authority shall be published in the Official Gazette, shall, unless otherwise expressly`
  line `provided in this Act, be construed as a requirement that the notification, order, rule, declaration, notice or`
  line `list shall`
  line
  line `(a) where it is issued or made by the Central Government, be published in the Gazette of India;`
  line
  line `(b) where it is issued or made by a State Government, be published in the Official Gazette of the`
  line `State; and`
  line
  line `(c) where it is issued or made by any other authority, be published in the Gazette of India if it`
  line `relates to an election to, or membership of, either House of Parliament ^14*** and in the Official`
  line `Gazette of the State if it relates to an election to, or membership of, the House or either House of the`
  line `Legislature of a State.`
  line
  line `(4) Where, under any of the provisions of this Act, anything is to be prescribed, different provisions`
  line `may be made for different cases or classes of cases.`
  line
  line `^15* * * * *`
  line
  line `^16* * * * *`
  line
  line `^15* * * * *`
obj_root_law_sections_2_footnotes:
  string
  line `1. Certain words omitted by Act 103 of 1956, s. 66 (w.e.f. 1-1-1957).`
  line
  line `2. Ins. by Act 27 of 1956, s. 3 (w.e.f. 28-8-1956).`
  line
  line `3. The words and figures or section 124 omitted by s. 3, ibid. (w.e.f. 28-8-1956).`
  line
  line `4. Ins. by Act 47 of 1966, s. 15 (w.e.f. 14-12-1966).`
  line
  line `5. The words "other than the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95, 96 and the Fifth Schedule`
  line `(w.e.f. 31-10-2019).`
  line
  line `6. Certain words omitted by Act 58 of 1958, s. 14 (w.e.f. 30-12-1958).`
  line
  line `7. Subs. by Act 27 of 1956, s. 3, for clause (e) (w.e.f. 28-8-1956).`
  line
  line `8. Ins. by Act 1 of 1989, s. 3 (w.e.f. 15-6-1989).`
  line
  line `9. Clause (k) re-lettered as clause (i) of that section by Act 27 of 1956, s. 3 (w.e.f. 28-8-1956).`
  line
  line `10. Clause (j) omitted by the Adaptation of Laws (No. 2) order, 1956.`
  line
  line `11. Clause (k) omitted by Act 47 of 1966, s. 15 (w.e.f. 14-12-1966).`
  line
  line `12. The words "an electoral college constituency" omitted by Act 103 of 1956, s. 66 (w.e.f. 1-1-1957).`
  line
  line `13. The words "or the electoral college of union territory" omitted by s. 66, ibid. (w.e.f. 1-1-1957).`
  line
  line `14. Sub-section (5) and (7) omitted and sub-section (6) re-numbered as sub-section (5) by Act 27 of 1956, s. 3 (w.e.f. 28-8-1956).`
  line
  line `15. Sub-section (5) Omitted by Act 34 of 2019, s. 95 and the fifth Schedule (w.e.f. 31-10-2019).`
  line
  line `16. Sub-section (7) omitted by Act 27 of 1956, s. 3 (w.e.f. 28-8-1956).`
obj_root_law_sections_3:
  sectionId (29493)
  sectionNo (3)
  orderNo 3
  title `Qualification for membership of the Council of States.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29493&sectionno=3&orderno=3&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_3_content:
  string
  line `^1[3. Qualification for membership of the Council of States.] A person shall not be qualified to be`
  line `chosen as a representative of any State ^2`
  line `*** or Union territory in the Council of States unless he is an`
  line `elector for a Parliamentary constituency ^3`
  line `[in India]].`
obj_root_law_sections_3_footnotes:
  string
  line `1.. Subs. by the Adaptation of Laws (No. 2) order, 1956, for s. 3.`
  line
  line `2. The brackets and words omitted by Act 47 of 1966, s. 17 (w.e.f. 14-12-1966).`
  line
  line `3. Subs. by Act 40 of 2003, s. 2, for "in that State or territory" (w.e.f. 28-8-2003).`
obj_root_law_sections_4:
  sectionId (29494)
  sectionNo (4)
  orderNo 4
  title `Qualifications for membership of the House of the People.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29494&sectionno=4&orderno=4&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_4_content:
  string
  line `A person shall not be qualified to`
  line `be chosen to fill a seat in the House of the People ^1*** ^2***, unless--`
  line
  line `(a) in the case of a seal reserved for the Scheduled Castes in any State, he is a member of any of`
  line `the Scheduled Castes, whether of that State or of any other State, and is an elector for any`
  line `Parliamentary constituency;`
  line
  line `(b) in the case of a seat reserved for the Scheduled Tribes in any State (other than those in`
  line `the autonomous districts of Assam), he is a member of any of the Scheduled Tribes, whether of the`
  line `Slate or of any other State (excluding the tribal areas of Assam), and is an elector for any`
  line `Parliamentary constituency;`
  line
  line `(c) in the case of a seat reserved for the Scheduled Tribes in the autonomous districts of Assam,`
  line `he is a member of any of those Scheduled Tribes and is an elector for the Parliamentary constituency in which such seat is reserved or for any other Parliamentary constituency comprising any such`
  line `autonomous district; ^3***`
  line
  line `^4[(cc) in the case of the seat reserved for the Scheduled Tribes in the Union territory`
  line `of ^5[Lakshadweep], he is a member of any of those Scheduled Tribes and is an elector for the`
  line `Parliamentary constituency of that Union territory; ^6***]`
  line
  line `^7[(ccc) in the case of the seat allotted to the State of Sikkim, he is an elector for the Parliamentary`
  line `constituency for Sikkim;]`
  line
  line `(d) in the case of any other seat, he is an elector for any Parliamentary constituency.`
obj_root_law_sections_4_footnotes:
  string
  line `1. Certain words omitted by Act 49 of 1965, s. 5 (w.e.f. 22-12-1965).`
  line
  line `2. Certain words omitted by Act 29 of 1975, s. 12 (w.e.f. 15-8-1975).`
  line
  line `3. The word "and" omitted by Act 47 of 1966, s. 18 (w.e.f. 14-12-1966).`
  line
  line `4. Ins. by s. 18, ibid. (w.e.f. 14-12-1966).`
  line
  line `5. . Subs. by the Laccadive, Minicoy and Aminidivi Islands (alteration of Name) Adaptation of Laws Order, 1974 (w.e.f. 1-11-`
  line `1973).`
  line `6. The word "and" omitted by Act 10 of 1976, s. 2 and the Schedule (w.e.f. 9-9-1975).`
  line
  line `7. Ins. by s. 2 and the Schedule, ibid. (w.e.f. 9-9-1975).`
obj_root_law_sections_5:
  sectionId (29495)
  sectionNo (5)
  orderNo 5
  title `Qualifications for membership of a Legislative Assembly.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29495&sectionno=5&orderno=5&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_5_content:
  string
  line `A person shall not be qualified to`
  line `be chosen to fill a seat in the Legislative Assembly of a State unless—`
  line
  line `(a) in the case of a seat reserved for the Scheduled Castes or for the Scheduled Tribes of that`
  line `State, he is a member of any of those castes or of those tribes, as the case may be, and is an elector for`
  line `any Assembly constituency in that State;`
  line
  line `(b) in the case of a seat reserved for an autonomous district of Assam, ^1*** he is a member of a`
  line `^2[Scheduled Tribe of any autonomous district] and is an elector for the Assembly constituency in`
  line `which such seat or any other seat is reserved for that district; and`
  line
  line `(c) in the case of any other seat, he is an elector for any Assembly constituency in that State:`
  line
  line `^3[Provided that for the period referred to in clause (2) of article 371A, a person shall not be qualified`
  line `to be chosen to fill any seat allocated to the Tuensang district in the Legislative Assembly of Nagaland`
  line `unless he is a member of the regional council referred to in that article.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Certain words omitted by the North-Eastern Areas (Reorganisation) (Adaptation of Laws on Union Subjects) Order, 1974`
  line `(w.e.f. 21-1-1972).`
  line `2. Subs. by Act 47 of 1966, s. 19, for "Scheduled Tribe of that district" (w.e.f. 14-12-1966).`
  line `3. Ins. by Act 27 of 1962, s. 11 (w.e.f. 4-9-1962).`
obj_root_law_sections_5_a:
  sectionId (29496)
  sectionNo 5A
  orderNo 6
  title `Qualifications for membership of Legislative Assembly of Sikkim.`
  content obj_root_law_sections_5_a_content
  footnotes obj_root_law_sections_5_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29496&sectionno=5A&orderno=6&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_5_a_content:
  string
  line `^1[5A. Qualifications for membership of Legislative Assembly of Sikkim.^2[(1)] Notwithstanding`
  line `Notwithstanding anything contained in section 5, a person shall not be qualified to be chosen to fill a seat`
  line `in the Legislative Assembly of Sikkim (deemed to be the Legislative Assembly of that State duly`
  line `constituted under the Constitution) unless--`
  line
  line `(a) in the case of a seat reserved for Sikkimese of Bhutia-Lepcha origin, he is a person either of`
  line `Bhutia or Lepcha origin and is an elector for any Assembly constituency in the State other than the`
  line `constituency reserved for the Sanghas;`
  line
  line `(b) in the case of a seat reserved for Sikkimese of Nepal origin, he is a person of Nepali origin`
  line `and is an elector for any Assembly constituency in the State;`
  line
  line `(c) in the case of a seat reserved for Scheduled Castes, he is a member of any of the castes`
  line `specified in the Representation of Sikkim Subjects Act, 1974 and is an elector for any Assembly`
  line `constituency in the State; and`
  line
  line `(d) in the case of a seat reserved for Sanghas, he is an elector of the Sangha constituency.]`
  line
  line `^3[(2) Notwithstanding anything contained in section 5, a person shall not be qualified to be chosen to`
  line `fill a seat in the Legislative Assembly of the State of Sikkim, to be constituted at any time after the`
  line `commencement of the Representation of the People (Amendment) Act, 1980 (8 of 1980), unless--`
  line
  line `(a) in the case of a seat reserved for Sikkimese of Bhutia-Lepcha origin, he is a person either of`
  line `Bhutia or Lepcha origin and is an elector for any Assembly constituency in the State other than the`
  line `constituency reserved for the Sanghas;`
  line
  line `(b) in the case of a seat reserved for Scheduled Castes, he is a member of any of those castes in`
  line `the State of Sikkim and is an elector for any Assembly constituency in the State;`
  line
  line `(c) in the case of a seat reserved for Sanghas, he is an elector of the Sangha constituency; and`
  line
  line `(d) in the case of any other seat, he is an elector for any Assembly constituency in the State.`
  line
  line `Explanation.--In this sub-section "Bhutia" includes Chumbipa, Dopthapa, Dukpa, Kagatey, Sherpa,`
  line `Tibetan, Tromopa and Yolmo.]`
obj_root_law_sections_5_a_footnotes:
  string
  line `1. Ins. by Act 10 of 1976, s. 2 and the Schedule (w.e.f. 9-9-1975).`
  line `2. Section 5A re-numbered as sub-section (1) of that section by Act 8 of 1980, s. 3 (w.e.f. 1-9-1979).`
  line `3. Ins. by Act 8 of 1980, s. 3 (w.e.f. 1-9-1979).`
obj_root_law_sections_6:
  sectionId (29497)
  sectionNo (6)
  orderNo 7
  title `Qualifications for membership of a Legislative Council.`
  content obj_root_law_sections_6_content
  footnotes `1. The words "or the Rajpramukh, as the case may be" omitted by the Adaptation of Laws (No. 2) Order, 1956.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29497&sectionno=6&orderno=7&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_6_content:
  string
  line `(1) A person shall not be qualifled to`
  line `be chosen to fill a seat in the Legislative Council of a State to be filled by election unless he is an elector`
  line `for any Assembly constituency in that State.`
  line
  line `(2) A person shall not be qualified to be chosen to fill a seat in the Legislative Council of a State to be`
  line `filled by nomination by the Governor ^1*** unless he is ordinarily resident in the State.`
obj_root_law_sections_7:
  sectionId (29498)
  sectionNo (7)
  orderNo 8
  title Definitions.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29498&sectionno=7&orderno=8&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_7_content:
  string
  line `^1[7. Definitions.-- In this Chapter,--`
  line
  line `(a) "appropriate Government" means in relation to any disqualification for being chosen as or for`
  line `being a member of either House of Parliament, the Central Government, and in relation to any`
  line `disqualification for being chosen as or for being a member of the Legislative Assembly or Legislative`
  line `Council of a State, the State Government;`
  line
  line `(b) "disqualified" means disqualified for being chosen as, and for being, a member of either`
  line `House of Parliament or of the Legislative Assembly or Legislative Council of a State ^2[`
  line `under the`
  line `provisions of this Chapter, and on no other ground].`
obj_root_law_sections_7_footnotes:
  string
  line `1. Subs. by Act 47 of 1966, s. 20, for CHAPTER III (w.e.f. 14-12-1966).`
  line
  line `2. Ins. by Act 29 of 2013, s. 2 (w.e.f. 10-7-2013).`
obj_root_law_sections_8:
  sectionId (29499)
  sectionNo (8)
  orderNo 9
  title `Disqualification on conviction for certain offences.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29499&sectionno=8&orderno=9&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_8_content:
  string
  line `^1[(1) A person convicted of an offence`
  line `punishable under--`
  line
  line `(a) section 153A (offence of promoting enmity between different groups on ground of religion,`
  line `race, place of birth, residence, language, etc., and doing acts prejudicial to maintenance of harmony)`
  line `or section 171E (offence of bribery) or section 171F (offence of undue influence or personation at an`
  line `election) or sub-section (1) or sub-section (2) of section 376 or section 376A or section 376B or`
  line `section 376C or section 376D (offences relating to rape) or section 498A (offence of cruelty towards`
  line `a woman by husband or relative of a husband) or sub-section (2) or sub-section (3) of section 505`
  line `(offence of making statement creating or promoting enmity, hatred or ill-will between classes or`
  line `offence relating to such statement in any place of worship or in any assembly engaged in the`
  line `performance of religious worship or religious ceremonies) or the Indian Penal Code (45 of 1860); or`
  line
  line `(b) the Protection of Civil Rights Act, 1955 (22 of 1955), which provides for punishment for the`
  line `preaching and practice of untouchability, and for the enforcement of any disability arising`
  line `therefrom; or`
  line
  line `(c) section 11 (offence of importing or exporting prohibited goods) of the Customs`
  line `Act, 1962 (52 of 1962); or`
  line
  line `(d) sections 10 to 12 (offence of being a member of an association declared unlawful,`
  line `offence relating to dealing with funds of an unlawful association or offence relating to contravention`
  line `of an order made in respect of a notified place) of the Unlawful Activities (Prevention)`
  line `Act, 1967 (37 of 1967); or`
  line
  line `(e) the Foreign Exchange (Regulation) Act, 1973 (46 of 1973); or`
  line
  line `(f) the Narcotic Drugs and Psychotropic Substances Act, 1985 (61 of 1985); or`
  line
  line `(g) section 3 (offence of committing terrorist acts) or section 4 (offence of committing disruptive`
  line `activities) of the Terrorist and Disruptive Activities (Prevention) Act, 1987 (28 of 1987); or`
  line
  line `(h) section 7 (offence of contravention of the provisions of section 3 to 6) of the Religious`
  line `Institutions (Prevention of Misuse) Act, 1988 (41 of 1988); or`
  line
  line `(i) section 125 (offence of promoting enmity between classes in connection with the election) or`
  line `section 135 (offence of removal of ballot papers from polling stations) or section 135A (offence of`
  line `booth capturing) or clause (a) of sub-section (2) of section 136 (offence of Fraudulently defacing or`
  line `fraudulently destroying any nomination paper) of this Act; ^2[or]`
  line
  line `^2[(j) section 6 (offence of conversion of a place or worship) of the Places of Worship (Special`
  line `Provisions) Act 1991], ^3[or]`
  line
  line `^4[(k) section 2 (offence of insulting the Indian National Flag or the Constitution of India) or`
  line `section 3 (offence of preventing singing of National Anthem) of the Prevention of Insults to National`
  line `Honour Act, 1971 (69 of 1971) ^5[or];]`
  line
  line `^5[(l) the Commission of Sati (Prevention) Act, 1987 (3 of 1988); or`
  line
  line `(m) the Prevention of Corruption Act, 1988 (49 of 1988); or`
  line
  line `(n) the Prevention of Terrorism Act, 2002 (15 of 2002),]`
  line
  line `^6[shall be disqualified, where the convicted person is sentenced to--`
  line
  line `(i) only fine, for a period of six years from the date of such conviction;`
  line
  line `(ii) imprisonment, from the date of such conviction and shall continue to be disqualified for a`
  line `further period of six years since his release,]`
  line
  line `(2) A person convicted for the contravention of--`
  line
  line `(a) any law providing for the prevention of hoarding or profiteering; or`
  line
  line `(b) any law relating to the adulteration of food or drugs; or`
  line
  line `(c) any provisions of the Dowry Prohibition Act, ^7[1961 (28 of 1961);],`
  line
  line `^8* * * * *`
  line
  line `and sentenced to imprisonment for not less than six months, shall be disqualified from the date of such`
  line `conviction and shall continue to be disqualified for a further period of six years since his release.`
  line
  line `(3) A person convicted of any offence and sentenced to imprisonment for not less than two years`
  line `other than any offence referred to in sub-section (1) or sub-section (2)] shall be disqualified from the date`
  line `of such conviction and shall continue to be disqualified for a further period of six years since his release.]`
  line
  line `^9[(4)] Notwithstanding anything ^10[in sub-section (1), sub-section 2 and sub-section (3)] a`
  line `disqualification under either sub-section shall not, in the case of a person who on the date of the`
  line `conviction is a member of Parliament or the Legislature of a State, take effect until three months have`
  line `elapsed from that date or, if within that period an appeal or application for revision is brought in respect`
  line `of the conviction or the sentence, until that appeal or application is disposed of by the court.`
  line
  line `Explanation.--In this section--`
  line
  line `(a) "law providing for the prevention of hoarding or profiteering" means any law, or any order,`
  line `rule or notification having the force of law, providing for--`
  line
  line `(i) the regulation of production or manufacture of any essential commodity;`
  line
  line `(ii) the control of price at which any essential commodity may be brought or sold;`
  line
  line `(iii) the regulation of acquisition, possession, storage, transport, distribution, disposal, use or`
  line `consumption of any essential commodity;`
  line
  line `(iv) the prohibition of the withholding from sale of any essential commodity ordinarily kept`
  line `for sale;`
  line
  line `(b) "drug" has the meaning assigned to it in the Drugs and Cosmetics Act, 1940 (23 of 1940);`
  line
  line `(c) "essential commodity" has the meaning assigned to it in the Essential Commodities`
  line `Act, 1955 (10 of 1955);`
  line
  line `(d) "food" has the meaning assigned to it in the Prevention of Food Adulteration`
  line `Act, 1954 (37 of 1954).`
obj_root_law_sections_8_footnotes:
  string
  line `1. Subs. by Act 1 of 1989, s. 4, for sub-sections (1) and (2) (w.e.f. 15-3-1989).`
  line
  line `2. Ins. by Act 42 of 1991, s. 8 (w.e.f. 18-9-1991).`
  line
  line `3. Added by Act 21 of 1996, s. 3 (w.e.f. 1-8-1996).`
  line
  line `4. Ins. by s. 3, ibid. (w.e.f. 1-8-1996).`
  line
  line `5. Ins. by Act 9 of 2003, s. 2 (w.e.f. 7-1-2003).`
  line
  line `6. Subs. by s. 2, ibid., for "shall be disqualified" and ending with the words " gsuch conviction" (w.e.f. 7-1-2003).`
  line
  line `7. Subs. by s. 2, ibid., for "1961 (28 of 1961); or" (w.e.f. 7-1-2003).`
  line `8. Omitted by s. 2, ibid. (w.e.f. 7-1-2003).`
  line
  line `9. Sub-section (3) re-numbered as sub-section (4) by Act 1 of 1989, s. 4 (w.e.f. 15-3-1989).`
  line
  line `10. Subs. by s. 4, ibid., for "sub-section (1) and sub-section (2)" (w.e.f. 15-3-1989).`
  line
  line `*Struck down by the Supreme Court of India in case titled Lily Thomas Vs Union of India and Ors.`
obj_root_law_sections_8_a:
  sectionId (29500)
  sectionNo 8A
  orderNo 10
  title `Disqualification on ground of corrupt practices.`
  content obj_root_law_sections_8_a_content
  footnotes obj_root_law_sections_8_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29500&sectionno=8A&orderno=10&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_8_a_content:
  string
  line `^1[8A. Disqualification on ground of corrupt practices.—(1) The case of every person found guilty`
  line `of a corrupt practice by an order under section 99 shall be submitted, ^2[as soon as may be within a period`
  line `of three months from the date such order takes effect], by such authority as the Central Government may`
  line `specify in this behalf, to the President for determination of the question as to whether such person shall be`
  line `disqualified and if so, for what period:`
  line
  line `Provided that the period for which any person may be disqualified under this sub-section shall in no`
  line `case exceed six years from the date on which the order made in relation to him under section 99 takes`
  line effect.
  line
  line `(2) Any person who stands disqualified under section 8A of this Act as it stood immediately before`
  line `the commencement of the Election Laws (Amendment) Act, 1975 (40 of 1975), may, if the period of such`
  line `disqualification has not expired, submit a petition to the President for the removal of such disqualification`
  line `for the unexpired portion of the said period.`
  line
  line `(3) Before giving his decision on any question mentioned in sub-section (1) or on any petition`
  line `submitted under sub-section (2), the President shall obtain the opinion of the Election Commission on`
  line `such question or petition and shall act according to such opinion.]`
obj_root_law_sections_8_a_footnotes:
  string
  line `1. Subs. by Act 40 of 1975, s. 2, for section 8A (w.e.f. 6-8-1975).`
  line `2. Subs. by Act 41 of 2009, s. 4, for certain words (w.e.f. 1-2-2010).`
obj_root_law_sections_9:
  sectionId (29501)
  sectionNo (9)
  orderNo 11
  title `Disqualification for dismissal for corruption or disloyalty.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29501&sectionno=9&orderno=11&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_9_content:
  string
  line `(1) A person who having held an`
  line `office under the Government of India or under the Government of any State has been dismissed for`
  line `corruption or for disloyalty to the State shall be disqualified for a period of five years from the date of`
  line `such dismissal.`
  line
  line `(2) For the purposes of sub-section (1), a certificate issued by the Election Commission to the effect`
  line `that a person having held office under the Government of India or under the Government of a State, has or`
  line `has not been dismissed for corruption or for disloyalty to the State shall be conclusive proof of that fact:`
  line
  line `Provided that no certificate to the effect that a person has been dismissed for corruption or for`
  line `disloyalty to the State shall be issued unless an opportunity of being heard has been given to the said`
  line person.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_9_a:
  sectionId (29502)
  sectionNo 9A
  orderNo 12
  title `Disqualification for Government contracts, etc.`
  content obj_root_law_sections_9_a_content
  footnotes obj_root_law_sections_9_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29502&sectionno=9A&orderno=12&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_9_a_content:
  string
  line `A person shall be disqualified if, and for so`
  line `long as, there subsists a contract entered into by him in the course of his trade or business with the`
  line `appropriate Government for the supply of goods to, or for the execution of any works undertaken by, that`
  line Government.
  line
  line `Explanation.—For the purposes of this section, where a contract has been fully performed by the`
  line `person by whom it has been entered into with the appropriate Government, the contract shall be deemed`
  line `not to subsist by reason only of the fact that the Government has not performed its part of the contract`
  line `either wholly or in part.`
obj_root_law_sections_9_a_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (29503)
  sectionNo (10)
  orderNo 13
  title `Disqualification for office under Government company.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29503&sectionno=10&orderno=13&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_10_content:
  string
  line `A person shall be disqualified if,`
  line `and for so long as, he is a managing agent, manager or secretary of any company or corporation (other`
  line `than a co-operative society) in the capital of which the appropriate Government has not less than`
  line `twenty-five per cent. share.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_10_a:
  sectionId (29504)
  sectionNo 10A
  orderNo 14
  title `Disqualification for failure to lodge account of election expenses.`
  content obj_root_law_sections_10_a_content
  footnotes obj_root_law_sections_10_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29504&sectionno=10A&orderno=14&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_10_a_content:
  string
  line `If the Election`
  line `Commission is satisfied that a person`
  line
  line `(a) has failed to lodge an account of election expenses, within the time and in the manner required`
  line `by or under this Act; and`
  line
  line `(b) has no good reason or justification for the failure,`
  line
  line `the Election Commission shall, by order published in the Official Gazette, declare him to be disqualified`
  line `and any such person shall be disqualified for a period of three years from the date of the order.`
obj_root_law_sections_10_a_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (29505)
  sectionNo (11)
  orderNo 15
  title `Removal or reduction of period of disqualification.`
  content obj_root_law_sections_11_content
  footnotes `1. Ins. by Act 40 of 1975, s. 3 (w.e.f. 6-8-1975).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29505&sectionno=11&orderno=15&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_11_content:
  string
  line `The Election Commission may, for`
  line `reasons to be recorded, remove any disqualification under this Chapter ^1[(except under section 8A)] or`
  line `reduce the period of any such disqualification.`
obj_root_law_sections_11_a:
  sectionId (29506)
  sectionNo 11A
  orderNo 16
  title `Disqualification arising out of conviction and corrupt practices.`
  content obj_root_law_sections_11_a_content
  footnotes obj_root_law_sections_11_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29506&sectionno=11A&orderno=16&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_11_a_content:
  string
  line `^1[11A. Disqualification arising out of conviction and corrupt practices.-- ^2[(1)] If any person, after`
  line `the commencement of this Act,--`
  line
  line `^3*** is convicted of an offence punishable under section 171E or section 171F of the Indian Penal`
  line `Code (45 of 1860), or under section 125 or section 135 or clause (a) of sub-section (2) of section 136`
  line `of this Act, ^4***`
  line
  line `^5* * * * *`
  line
  line `he shall, for a period of six years from the date of the conviction or from the date on which the order takes`
  line `effect, be disqualified for voting at any election.`
  line
  line `^6[(2) Any person disqualified by a decision of the President under sub-section (1) of section 8A for`
  line `any period shall be disqualified for the same period for voting at any election.`
  line
  line `(3) The decision of the President on a petition submitted by any person under sub-section (2) of`
  line `section 8A in respect of any disqualification for being chosen as, and for being, a member of either House of Parliament or of the Legislative Assembly or Legislative Council of a State shall, so for as may be,`
  line `apply in respect of the disqualification for voting at any election incurred by him under clause (b) of`
  line `sub-section (1) of section 11A of this Act as it stood immediately before the commencement of the`
  line `Election Laws (Amendment) Act, 1975 (40 of 1975), as if such decision were a decision in respect of the`
  line `said disqualification for voting also.]`
obj_root_law_sections_11_a_footnotes:
  string
  line `1. Ins. by Act 40 of 1975, s. 3 (w.e.f. 6-8-1975).`
  line
  line `2. Section 11A re-numbered as sub-section (1) of that section by s. 4, ibid. (w.e.f. 6-8-1975).`
  line
  line `3. The brackets and letter "(a)" omitted by Act 38 of 1978, s. 3 and the Second Schedule (w.e.f. 26-11-1978).`
  line
  line `4. The word "or" omitted by s. 3 and the Second Schedule, ibid. (W.e.f. 26-11-1978).`
  line
  line `5. Omitted by Act 40 of 1975, s. 4 (w.e.f. 6-8-1975).`
  line
  line `6. Ins. by s. 4, ibid. (w.e.f. 6-8-1975).`
obj_root_law_sections_11_b:
  sectionId (29507)
  sectionNo 11B
  orderNo 17
  title `Removal of disqualifications.`
  content obj_root_law_sections_11_b_content
  footnotes obj_root_law_sections_11_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29507&sectionno=11B&orderno=17&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_11_b_content:
  string
  line `^1[11B. Removal of disqualifications.--The Election Commission may, for reasons to be recorded,`
  line `remove ^2[any disqualification under sub-section (1) of section 11A].]`
obj_root_law_sections_11_b_footnotes:
  string
  line `1. Ins. by Act 40 of 1975, s. 3 (w.e.f. 6-8-1975).`
  line
  line `1. Subs. by Act 40 of 1975, s. 5, for "any disqualification under this Chapter" (w.e.f. 6-8-1975).`
obj_root_law_sections_12:
  sectionId (29508)
  sectionNo (12)
  orderNo 18
  title `Notification for biennial election to the Council of States.`
  content obj_root_law_sections_12_content
  footnotes `1. Subs. by Act 27 of 1956, s. 7, for "PART III" (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29508&sectionno=12&orderno=18&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_12_content:
  string
  line `^1[12. Notification for biennial election to the Council of States.--For the purpose of filling the seats`
  line `of members of the Council of States retiring on the expiration of their term of office the President shall by`
  line `one or more notifications published in the Gazette of India on such date or dates as may be recommended`
  line `by the Election Commission, call upon the elected members of the Legislative Assembly or as the case`
  line `may be, the members of the electoral college, of each State concerned to elect members in accordance`
  line `with the provisions of this Act and of the rules and orders made thereunder:`
  line
  line `Provided that no notification under this section shall be issued more than three months prior to the`
  line `date on which the term of office of the retiring members is due to expire.]`
obj_root_law_sections_12_a:
  sectionId (29509)
  sectionNo 12A
  orderNo 19
  title `Notification for election to fill the seat allotted to the State of Sikkim in the Council of States.`
  content obj_root_law_sections_12_a_content
  footnotes `1. Ins. by Act 10 of 1976, s. 2 and the Schedule (w.e.f. 9-9-1975).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29509&sectionno=12A&orderno=19&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_12_a_content:
  string
  line `^1[12A. Notification for election to fill the seat allotted to the State of Sikkim in the Council of`
  line `States.--For the purpose of filling for the first time the seat allotted to the State of Sikkim by the`
  line `Constitution (Thirty-sixth Amendment) Act, 1975 in the Council of States, the President shall, by a`
  line `notification published in the Gazette of India, on such date as may be recommended by Election`
  line `Commission, call upon the elected members of the Legislative Assembly of the State of Sikkim to elect a`
  line `member in accordance with the provisions of this Act and of the rules and orders made thereunder and the`
  line `election so held shall for all purposes and intent be deemed to have been held under section 12.]`
obj_root_law_sections_13:
  sectionId (29510)
  sectionNo (13)
  orderNo 20
  title [Omitted.].
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 27 of 1956, s. 7, for "PART III" (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29510&sectionno=13&orderno=20&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_13_content:
  string
  line `[^1[Notification for reconstitution of electoral colleges of certain Union territories.] Omitted by the`
  line `Territorial Councils Act, 1956 (103 of 1956), s. 66 (w.e.f. 1-1-1957).]`
obj_root_law_sections_14:
  sectionId (29511)
  sectionNo (14)
  orderNo 21
  title `Notification for general election to the House of the People.`
  content obj_root_law_sections_14_content
  footnotes `1. Subs. by Act 27 of 1956, s. 7, for "PART III" (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29511&sectionno=14&orderno=21&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_14_content:
  string
  line `^1[14. Notification for general election to the House of the People.--((1) A general election shall be`
  line `held for the purpose of constituting a new House of the People on the expiration of the duration of the`
  line `existing House or on its dissolution.`
  line
  line `(2) For the said purpose the President shall, by one or more notifications published in the Gazette of`
  line `India on such date or dates as may be recommended by the Election Commission, call upon all`
  line `Parliamentary constituencies to elect members in accordance with the provisions of this Act and of the`
  line `rules and orders made thereunder:`
  line
  line `Provided that where a general election is held otherwise than on the dissolution of the existing House`
  line `of the People, no such notification shall be issued at any time earlier than six months prior to the date on`
  line `which the duration of that House would expire under the provisions of clause (2) of article 83.]`
obj_root_law_sections_14_a:
  sectionId (29512)
  sectionNo 14A
  orderNo 22
  title `Notification for electing the representative of the State of Sikkim to the existing House of the people.`
  content obj_root_law_sections_14_a_content
  footnotes obj_root_law_sections_14_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29512&sectionno=14A&orderno=22&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_14_a_content:
  string
  line `^1[^2[14A. Notification for electing the representative of the State of Sikkim to the existing House of`
  line `the People.--For the purpose of electing a representative of the State of Sikkim to the House of the`
  line `People, specified in clause (e) of article 371F of the Constitution, the Election Commission shall call`
  line `upon the members of the Legislative Assembly of the State of Sikkim to elect the representative in`
  line `accordance with such of the provisions of this Act, and the rules and orders make thereunder, as are`
  line `applicable to the election of the members of the Council of States.]`
obj_root_law_sections_14_a_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 7, for "PART III" (w.e.f. 28-8-1956).`
  line
  line `2. Ins. by Act 10 of 1976, s. 2 and the Schedule (w.e.f. 9-9-1975).`
obj_root_law_sections_15:
  sectionId (29513)
  sectionNo (15)
  orderNo 23
  title `Notification for general election to a State Legislative Assembly.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29513&sectionno=15&orderno=23&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_15_content:
  string
  line `^1[15. Notification for general election to a State Legislative Assembly.--(1) A general election shall`
  line `be held for the purpose of constituting a new Legislative Assembly on the expiration of the duration of the`
  line `existing Assembly or on its dissolution.`
  line
  line `(2) For the said purpose, ^2[the Governor or Administrator, as the case may be ], ^3*** shall by one or`
  line `more notifications published in the Official Gazette of the State on such date or dates as may be`
  line `recommended by the Election Commission, call upon all Assembly constituencies in the State to elect`
  line `members in accordance with the provisions of this Act and of the rules and orders made thereunder:`
  line
  line `Provided that where a general election is held otherwise than on the dissolution of the existing`
  line `Legislative Assembly, no such notification shall be issued at any time earlier than six months prior to the`
  line `date on which the duration of that Assembly would expire under the provisions of clause (1) of`
  line `article 172 ^3*** ^4[or under the provisions of section 5 of the Government of Union Territories`
  line `Act, 1963 (20 of 1963), as the case may be.]`
obj_root_law_sections_15_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 7, for "PART III" (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by Act 20 of 1963, s. 57 and the Second Schedule for "the Governor" (w.e.f. 13-5-1963).`
  line
  line `3. The words "Rajpramukh, Lieutenant-Governor or Chief Commissioner, as the case may be", omitted by the Adaptation of`
  line `Laws (No. 2) Order, 1956.`
  line
  line `4. Added by Act 20 of 1963, s. 57 and the Second Schedule (w.e.f. 13-5-1963).`
obj_root_law_sections_15_a:
  sectionId (29514)
  sectionNo 15A
  orderNo 24
  title `Notification for certain elections to Legislative Councils.`
  content obj_root_law_sections_15_a_content
  footnotes obj_root_law_sections_15_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29514&sectionno=15A&orderno=24&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_15_a_content:
  string
  line `^1[15A. Notification for certain elections to Legislative Councils.--For the purpose of constituting`
  line `the Legislative Council of the State of Madhya Pradesh under the State Reorganisation Act, 1956 (37 of`
  line `1956) and constituting the Legislative Council of the State of Andhra Pradesh ^2[under the Andhra Pradesh`
  line `Legislative Council Act, 2005 (1 of 2006)], ^3[and constituting the Legislative Council of the State of`
  line `Tamil Nadu under the Tamil Nadu Legislative Council Act, 2010 (16 of 2010)] ^4[and constituting the`
  line `Legislative Council of the State of Telangana under the Andhra Pradesh Reorganisation Act, 2014 (6 of`
  line `2014) the Governor of each of the aforesaid States shall, by one or more notifications published in the`
  line `Official Gazette of the State on such date or dates as may be recommended by the Election Commission,`
  line `call upon the members of the Legislative Assembly of the State and all the Council constituencies to elect`
  line `members in accordance with the provisions of this Act and of the rules and orders made thereunder.]`
obj_root_law_sections_15_a_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 7, for "PART III" (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by Act 1 of 2006, s. 5, for "under the Legislative Councils Act, 1957" (w.e.f. 11-1-2006).`
  line
  line `3. Ins. by Act 16 of 2010, s. 5 (w.e.f. 18-5-2010).`
  line
  line `4. Ins. by Act 6 of 2014, s. 98 (w.e.f. 2-6-2014).`
obj_root_law_sections_16:
  sectionId (29515)
  sectionNo (16)
  orderNo 25
  title `Notification for biennial election to a State Legislative Council.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29515&sectionno=16&orderno=25&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_16_content:
  string
  line `^1[16. Notification for biennial election to a State Legislative Council.--For the purpose of filling the`
  line `seats of members of the Legislative Council of a State retiring on the expiration of their term of office, the`
  line `Governor ^2*** shall, by one or more notifications published in the Official Gazette of the State on such`
  line `date or dates as may be recommended by the Election Commission call upon the members of the`
  line `Legislative Assembly of the State and all the Council constituencies concerned to elect members in`
  line `accordance with the provisions of this Act and of the rules and orders made thereunder:`
  line
  line `Provided that no notification under this section shall be issued more than three months prior to the`
  line `date on which the term of office of the retiring members is due to expire.]`
obj_root_law_sections_16_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 7, for PART III (w.e.f. 28-8-1956).`
  line
  line `2. The words "or Rajpramukh, as the case may be," omitted by the Adaptation of Laws (No. 2) Order, 1956.`
obj_root_law_sections_19:
  sectionId (29516)
  sectionNo (19)
  orderNo 26
  title Definition.
  content obj_root_law_sections_19_content
  footnotes `1. The words "an electoral college constituency or" omitted by Act 103 of 1956, s. 66 (w.e.f. 1-1-1957).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29516&sectionno=19&orderno=26&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_19_content:
  string
  line `In this Part and in Part V, unless the context otherwise requires, "constituency"`
  line `means ^1*** Parliamentary constituency or an Assembly constituency or a Council constituency.`
obj_root_law_sections_19_a:
  sectionId (29517)
  sectionNo 19A
  orderNo 27
  title `Delegation of functions of Election Commission.`
  content obj_root_law_sections_19_a_content
  footnotes `1. Ins. by Act 47 of 1966, s. 21 (w.e.f. 14-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29517&sectionno=19A&orderno=27&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_19_a_content:
  string
  line `^1[19A. Delegation of functions of Election Commission.--The functions of the Election`
  line `Commission under the Constitution, the Representation of the People Act, 1950 (43 of 1950) and this Act`
  line `or under the rules made thereunder may, subject to such general or special directions, if any, as may be`
  line `given by the Election Commission in this behalf, be performed also by a Deputy Election Commissioner`
  line `or by the Secretary to the Election Commission.]`
obj_root_law_sections_20:
  sectionId (29518)
  sectionNo (20)
  orderNo 28
  title `General duties of chief electoral officers.`
  content obj_root_law_sections_20_content
  footnotes `1. Subs. by Act 27 of 1956, s. 9, for sections 20 and 21 (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29518&sectionno=20&orderno=28&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_20_content:
  string
  line `^1[20. General duties of chief electoral officers.--Subject to the superintendence, direction and`
  line `control of the Election Commission, the chief electoral officer of each State shall supervise the conduct of`
  line `all elections in the State under this Act.]`
obj_root_law_sections_20_a:
  sectionId (29519)
  sectionNo 20A
  orderNo 29
  title `General duties of district election officer.`
  content obj_root_law_sections_20_a_content
  footnotes `1. Ins. by Act 47 of 1966, s. 22 (w.e.f. 14-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29519&sectionno=20A&orderno=29&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_20_a_content:
  string
  line `^1[20A. General duties of district election officer.--(1) Subject to the superintendence, direction`
  line `and control of the chief electoral officer, the district election officer shall co-ordinate and supervise all`
  line `work in the district or in the area within his jurisdiction in connection with the conduct of all elections to`
  line `Parliament and the Legislature of the State.`
  line
  line `(2) The district election officer shall also perform such other functions as may be entrusted to him by`
  line `the Election Commission and the chief electoral officer.]`
obj_root_law_sections_20_b:
  sectionId (29520)
  sectionNo 20B
  orderNo 30
  title Observers.
  content obj_root_law_sections_20_b_content
  footnotes `1. Ins. by Act 21 of 1996, s. 4 (w.e.f. 1-8-1996).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29520&sectionno=20B&orderno=30&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_20_b_content:
  string
  line `^1[20B. Observers.—(1) The Election Commission may nominate an Observer who shall be an officer`
  line `officer of Government to watch the conduct of election or elections in a constituency or a group of`
  line `constituencies and to perform such other functions as may be entrusted to him by the Election`
  line Commission.
  line
  line `(2) The Observer nominated under sub-section (1) shall have the power to direct the returning officer`
  line `for the constituency or for any of the constituencies for which he has been nominated, to stop the counting`
  line `of votes at any time before the declaration of the result or not to declare the result if in the opinion of the`
  line `Observer booth capturing has taken place at a large number of polling stations or at places fixed for the`
  line `poll or counting of votes or any ballot papers used at a polling station or at a place fixed for the poll are`
  line `unlawfully taken out of the custody of the returning officer or are accidentally or intentionally destroyed`
  line `or lost or are damaged or tampered with to such an extent that the result of the poll at that polling station`
  line `or place cannot be ascertained.`
  line
  line `(3) Where an Observer has directed the returning officer under this section to stop counting of votes`
  line `or not to declare the result, the Observer shall forthwith report the matter to the Election Commission and`
  line `thereupon the Election Commission shall, after taking all material circumstances into account, issue`
  line `appropriate directions under section 58A or section 64A or section 66.`
  line
  line `Explanation.—For the purposes of sub-section (2) and sub-section (3), "Observer" shall include a`
  line `Regional Commissioner or any such officer of the Election Commission as has been assigned under this`
  line `section the duty of watching the conduct of election or elections in a constituency or group of`
  line `constituencies by the Commission.]`
obj_root_law_sections_21:
  sectionId (29521)
  sectionNo (21)
  orderNo 31
  title `Returning officers.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29521&sectionno=21&orderno=31&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_21_content:
  string
  line `^1[21. Returning officers.--For every constituency, for every election to fill a seat or seats in the`
  line `Council of States and for every election by the members of the Legislative Assembly of a State to fill a`
  line `seat or seats in the Legislative Council of the State, the Election Commission shall, in consultation with`
  line `the Government of the State, designate or nominate a returning officer who shall be ^2[an officer of`
  line `Government or of a local authority:]`
  line
  line `Provided that nothing in this section shall prevent the Election Commission from designating or`
  line `nominating the same person to be the returning officer for more than one constituency].`
obj_root_law_sections_21_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 9, for section 21 (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by Act 47 of 1966, s. 23, for "an officer of Government" (w.e.f. 14-12-1966).`
obj_root_law_sections_22:
  sectionId (29522)
  sectionNo (22)
  orderNo 32
  title `Assistant returning officers.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29522&sectionno=22&orderno=32&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_22_content:
  string
  line `(1) The Election Commission may appoint one or more persons`
  line `to assist any returning officer in the performance of his functions:`
  line
  line `Provided that every such person shall be ^1[an officer of Government or of a local authority.]`
  line
  line `(2) Every assistant returning officer shall, subject to the control of the returning officer, be competent`
  line `to perform all or any of the functions of the returning officer:`
  line
  line `Provided that no assistant returning officer shall perform any of the functions of the returning officer`
  line `which relate ^2*** to the scrutiny of nominations ^3*** unless the returning officer is unavoidably`
  line `prevented from performing the said function.`
obj_root_law_sections_22_footnotes:
  string
  line `1. Subs. by Act 47 of 1966, s. 23, for "an officer of Government" (w.e.f. 14-12-1966).`
  line `2. Certain words omitted by Act 27 of 1956, s. 10 (w.e.f. 28-8-1956).`
  line `3. The words "or to the counting of votes" omitted by s. 10, ibid. (w.e.f. 28-8-1956).`
obj_root_law_sections_23:
  sectionId (29523)
  sectionNo (23)
  orderNo 33
  title `Returning officer to include assistant returning officers performing the functions of the returning officer.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29523&sectionno=23&orderno=33&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_23_content:
  string
  line `References in this Act to the returning officer shall, unless the context otherwise`
  line `requires, be deemed to include an assistant returning officer performing any function which he is`
  line `authorised to perform under sub-section (2) of section 22.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (29524)
  sectionNo (24)
  orderNo 34
  title `General duty of the returning officer.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29524&sectionno=24&orderno=34&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_24_content:
  string
  line `It shall be general duty of the returning officer at any`
  line `election to do all such acts and things as may be necessary for effectually conducting the election in the`
  line `manner provided by this Act and rules or orders made thereunder.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (29525)
  sectionNo (25)
  orderNo 35
  title `Provision of polling stations for constituencies.`
  content obj_root_law_sections_25_content
  footnotes `1. Subs. by Act 47 of 1966, s. 25, for section 25 (w.e.f. 14-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29525&sectionno=25&orderno=35&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_25_content:
  string
  line `^1[25. Provision of polling stations for constituencies.—The district election officer shall, with the`
  line `previous approval of the Election Commission, provide a sufficient number of polling stations for every`
  line `constituency the whole or greater part of which lies within his jurisdiction, and shall publish, in such`
  line `manner as the Election Commission may direct, a list showing the polling stations so provided and the`
  line `polling areas or groups of voters for which they have respectively been provided.]`
obj_root_law_sections_26:
  sectionId (29526)
  sectionNo (26)
  orderNo 36
  title `Appointment of presiding officers for polling stations.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29526&sectionno=26&orderno=36&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_26_content:
  string
  line `(1) The ^1[district election officer] shall`
  line `appoint a presiding officer for each polling station and such polling officer or officers as he thinks`
  line `necessary, but he shall not appoint any person who has been employed by or on behalf of, or has been`
  line `otherwise working for, a candidate in or about the election:`
  line
  line `Provided that if a polling officer is absent from the polling station, the presiding officer may appoint`
  line `any person who is present at the polling station other than a person who has been employed by or on`
  line `behalf of, or has been otherwise working for, a candidate in or about the election, to be the polling officer`
  line `during the absence of the former officer, and inform the ^1[district election officer] accordingly:`
  line
  line `^2[Provided further that nothing in this sub-section shall prevent that ^1[district election officer] from`
  line `appointing the same person to be the presiding officer for more than one polling station in the same`
  line premises.]
  line
  line `(2) A polling officer shall, if so directed by the presiding officer, perform all or any of the functions`
  line `of a presiding officer under this Act or any rules or orders made thereunder.`
  line
  line `(3) If the presiding officer, owing to illness or other unavoidable cause, is obliged to absent himself`
  line `from the polling station, his functions shall be performed by such polling officer as has been previously`
  line `authorised by the ^1[district election officer] to perform such functions during any such absence.`
  line
  line `(4) References in this Act to the presiding officer shall, unless the context otherwise requires, be`
  line `deemed to include any person performing any function which he is authorised to perform under`
  line `sub-section (2) or sub-section (3), as the case may be.`
  line
  line ^3*****
obj_root_law_sections_26_footnotes:
  string
  line `1. Subs. by s. 26, ibid., for "returning officer" (w.e.f. 14-12-1966).`
  line `2. Ins. by Act 27 of 1956, s. 12 (w.e.f. 28-8-1956).`
  line `3. Sub-section (5) omitted by Act 2 of 2004, s. 3 (w.e.f. 29-10-2003).`
obj_root_law_sections_27:
  sectionId (29527)
  sectionNo (27)
  orderNo 37
  title `General duty of the presiding officer.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29527&sectionno=27&orderno=37&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_27_content:
  string
  line `It shall be the general duty of the presiding officer at a`
  line `polling station to keep order thereat and to see that the poll is fairly taken.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (29528)
  sectionNo (28)
  orderNo 38
  title `Duties of a polling officer.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29528&sectionno=28&orderno=38&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_28_content:
  string
  line `It shall be the duty of the polling officers at a polling station to`
  line `assist the presiding officer for such station in the performance of his functions.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_28_a:
  sectionId (29529)
  sectionNo 28A
  orderNo 39
  title `Returning officer, presiding officer, etc., deemed to be on deputation to Election Commission.`
  content obj_root_law_sections_28_a_content
  footnotes `1. Ins. by Act 1 of 1989, s. 5 (w.e.f. 15-3-1989).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29529&sectionno=28A&orderno=39&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_28_a_content:
  string
  line `^1[28A. Returning officer, presiding officer, etc., deemed to be on deputation to Election`
  line `Commission.--The returning officer, assistant returning officer, presiding officer, polling officer and any`
  line `other officer appointed under this Part, and any police officer designated for the time being by the State`
  line `Government, for the conduct of any election shall be deemed to be on deputation to the Election`
  line `Commission for the period commencing on and from the date of the notification calling for such election`
  line `and ending with the date of declaration of the results of such election and accordingly, such officers shall,`
  line `during that period, be subject to the control, superintendence and discipline of the Election Commission.]`
obj_root_law_sections_29:
  sectionId (29530)
  sectionNo (29)
  orderNo 40
  title `Special provisions in the case of certain elections.`
  content obj_root_law_sections_29_content
  footnotes `1. The brackets and words "(other than a primary election)" omitted by Act 27 of 1956, s. 13 (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29530&sectionno=29&orderno=40&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_29_content:
  string
  line `(1) The returning officer for an`
  line `election ^1*** to fill a seat or seats in the Council of States or for an election by the members of the`
  line `Legislative Assembly of a State to fill a seat or seats in the Legislative Council of the State shall, with the`
  line `previous approval of the Election Commission, fix the place at which the poll will be taken for such`
  line `election and shall notify the place so fixed in such manner as the Election Commission may direct.`
  line
  line `(2) The returning officer shall preside over such election at the place so fixed and shall appoint such`
  line `polling officer or officers to assist him as he thinks necessary but he shall not appoint any person who has`
  line `been employed by or on behalf of, or has been otherwise working for, a candidate in or about the election.`
obj_root_law_sections_29_a:
  sectionId (29531)
  sectionNo 29A
  orderNo 41
  title `Registration with the Election Commission of associations and bodies as political parties.`
  content obj_root_law_sections_29_a_content
  footnotes `1. Ins. by Act 1 of 1989, s. 6 (w.e.f. 15-6-1989).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29531&sectionno=29A&orderno=41&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_29_a_content:
  string
  line `^1[29A. Registration with the Election Commission of associations and bodies as political`
  line `parties.--(1) Any association or body of individual citizens of India calling itself a political party and`
  line `intending to avail itself of the provisions of this Part shall make an application to the Election`
  line `Commission for its registration as a political party for the purposes of this Act.`
  line
  line `(2) Every such application shall be made,--`
  line
  line `(a) if the association or body is in existence at the commencement of the Representation of the`
  line `People (Amendment) Act, 1988 (1 of 1989), within sixty days next following such commencement;`
  line
  line `(b) if the association or body is formed after such commencement, within thirty days next`
  line `following the date of its formation.`
  line
  line `(3) Every application under sub-section (1) shall be signed by the chief executive officer of the`
  line `association or body (whether such chief executive officer is known as Secretary or by any other`
  line `designation) and presented to the Secretary to the Commission or sent to such Secretary by registered`
  line post.
  line
  line `(4) Every such application shall contain the following particulars, namely:--`
  line
  line `(a) the name of the association or body;`
  line
  line `(b) the State in which its head office is situate;`
  line
  line `(c) the address to which letters and other communications meant for it should be sent;`
  line
  line `(d) the names of its president, secretary, treasurer and other office-bearers;`
  line
  line `(e) the numerical strength of its members, and if there are categories of its members, the`
  line `numerical strength in each category;`
  line
  line `(f) whether it has any local units; if so, at what levels;`
  line
  line `(g) whether it is represented by any member or members in either House of Parliament or of any`
  line `State Legislature; if so, the number of such member or members.`
  line
  line `(5) The application under sub-section (1) shall be accompanied by a copy of the memorandum or`
  line `rules and regulations of the association or body, by whatever name called, and such memorandum or rules`
  line `and regulations shall contain a specific provision that the association or body shall bear true faith and`
  line `allegiance to the Constitution of India as by law established, and to the principles of socialism, secularism`
  line `and democracy, and would uphold the sovereignty, unity and integrity of India.`
  line
  line `(6) The Commission may call for such other particulars as it may deem fit from the association or`
  line body.
  line
  line `(7) After considering all the particulars as aforesaid in its possession and any other necessary and`
  line `relevant factors and after giving the representatives of the association or body reasonable opportunity of`
  line `being heard, the Commission shall decide either to register the association or body as a political party for`
  line `the purposes of this Part, or not so to register it; and the Commission shall communicate its decision to`
  line `the association or body:`
  line
  line `Provided that no association or body shall be registered as a political party under this sub-section`
  line `unless the memorandum or rules and regulations of such association or body conform to the provisions of`
  line `sub-section (5).`
  line
  line `(8) The decision of the Commission shall be final.`
  line
  line `(9) After an association or body has been registered as a political party as aforesaid, any change in its`
  line `name, head office, office-bearers, address or in any other material matters shall be communicated to the`
  line `Commission without delay.]`
obj_root_law_sections_29_b:
  sectionId (29532)
  sectionNo 29B
  orderNo 42
  title `Political parties entitled to accept contribution.`
  content obj_root_law_sections_29_b_content
  footnotes `1. Ins. by Act 46 of 2003, s. 2 (w.e.f. 11-9-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29532&sectionno=29B&orderno=42&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_29_b_content:
  string
  line `^1[29B. Political parties entitled to accept contribution.--Subject to the provisions of the`
  line `Companies Act, 1956 (1 of 1956), every political party may accept any amount of contribution`
  line `voluntarily offered to it by any person or company other than a Government company:`
  line
  line `Provided that no political party shall be eligible to accept any contribution from any foreign source`
  line `defined under clause (e) of section 2 of the Foreign Contribution (Regulation) Act, 1976 (49 of 1976).`
  line
  line `Explanation,--For the purposes of this section and section 29C,--`
  line
  line `(a) "company" means a company as defined in section 3;`
  line
  line `(b) "Government company" means a company within the meaning of section 617; and`
  line
  line `(c) "contribution" has the meaning assigned to it under section 293A, of the Companies Act, 1956`
  line `(1 of 1956) and includes any donation or subscription offered by any person to a political party; and`
  line
  line `(d) "person" has the meaning assigned to it under clause (31) of section 2 of the Income-tax`
  line `Act, 1961 (43 of 1961), but does not include Government company, local authority and every`
  line `artificial juridical person wholly or partially funded by the Government.]`
obj_root_law_sections_29_c:
  sectionId (29533)
  sectionNo 29C
  orderNo 43
  title `Declaration of donation received by the political parties.`
  content obj_root_law_sections_29_c_content
  footnotes `1. Ins. by Act 7 of 2017, s. 137 (w.e.f. 1-4-2017).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29533&sectionno=29C&orderno=43&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_29_c_content:
  string
  line `(1) The treasurer of a political`
  line `party or any other person authorised by the political party in this behalf shall, in each financial year,`
  line `prepare a report in respect of the followings namely:`
  line
  line `(a) the contribution in excess of twenty thousand rupees received by such political party from any`
  line `person in that financial year;`
  line
  line `(b) the contribution in excess of twenty thousand rupees received by such political party from`
  line `companies other than Government companies in that financial year.`
  line
  line `^1[Provided that nothing contained in this sub-section shall apply to the contributions received by`
  line `way of an electoral bond.`
  line
  line `Explanation.—For the purposes of this sub-section, "electoral bond" means a bond referred to in`
  line `the Explanation to sub-section (3) of section 31 of the Reserve Bank of India Act, 1934 (2 of 1934).]`
  line
  line `(2) The report under sub-section (1) shall be in such form as may be prescribed.`
  line
  line `(3) The report for a financial year under sub-section (1) shall be submitted by the treasurer of a`
  line `political party or any other person authorised by the political party in this behalf before the due date`
  line `for furnishing a return of its income of that financial year under section 139 of the Income-tax`
  line `Act, 1961 (43 of 1961) to the Election Commission.`
  line
  line `(4) Where the treasurer of any political party or any other person authorised by the political party in`
  line `this behalf fails to submit a report under sub-section (3), then, notwithstanding anything contained in the`
  line `Income-tax Act, 1961 (43 of 1961), such political party shall not be entitled to any tax relief under that`
  line Act.]
obj_root_law_sections_30:
  sectionId (29534)
  sectionNo (30)
  orderNo 44
  title `Appointment of dates for nominations, etc.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29534&sectionno=30&orderno=44&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_30_content:
  string
  line `^1[30. Appointment of dates for nominations, etc.--As soon as the notification calling upon a`
  line `constituency to elect a member or members is issued, the Election Commission shall, by notification in`
  line `the Official Gazette, appoint`
  line
  line `(a) the last date for making nominations, which shall be the ^2[seventh day] after the date of`
  line `publication of the first mentioned notification or, if that day is a public holiday, the next succeeding`
  line `day which is not a public holiday;`
  line
  line `(b) the date for the scrutiny of nominations, which shall be ^3[the day immediately following] the`
  line `last date for making nominations or, if that day is a public holiday, the next succeeding day which is`
  line `not a public holiday;`
  line
  line `(c) the last date for the withdrawal of candidatures, which shall be ^4[the second day] after the date`
  line `for the scrutiny of nominations or, if that day is a public holiday, the next succeeding day which is not`
  line `a public holiday;`
  line
  line `(d) the date or dates on which a poll shall, if necessary, be taken which or the first of which shall`
  line `be a date not earlier than the ^5[fourteenth day] after the last date for the withdrawal of candidatures;`
  line and
  line
  line `(e) the date before which the election shall be completed.`
  line
  line ^6*****
obj_root_law_sections_30_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 14, for section 30 (w.e.f. 28-8-1956).`
  line `2. Subs. by Act 40 of 1961, s. 7, for "tenth day" (w.e.f. 20-9-1961).`
  line `3. Subs. by Act 47 of 1966, s. 27, for "the second day after" (w.e.f. 14-12-1966).`
  line `4. Subs. by Act 47 of 1966, s. 27, for "the third day" (w.e.f. 14-12-1966).`
  line `5. Subs. by Act 21 of 1996, s. 5, for "twentieth day" (w.e.f. 1-8-1996).`
  line `6. The Explanation omitted by Act 47 of 1966, s. 27 (w.e.f. 14-12-1966).`
obj_root_law_sections_31:
  sectionId (29535)
  sectionNo (31)
  orderNo 45
  title `Public notice of election.`
  content obj_root_law_sections_31_content
  footnotes `1. The words "for the constituency" omitted by s. 28, ibid. (w.e.f. 14-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29535&sectionno=31&orderno=45&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_31_content:
  string
  line `On the issue of a notification under section 30, the returning`
  line `officer ^1*** shall give public notice of the intended election in such form and manner as may be`
  line `prescribed, inviting nominations of candidates for such election and specifying the place at which the`
  line `nomination papers are to be delivered.`
obj_root_law_sections_32:
  sectionId (29536)
  sectionNo (32)
  orderNo 46
  title `Nomination of candidates for election.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29536&sectionno=32&orderno=46&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_32_content:
  string
  line `Any person may be nominated as a candidate for`
  line `election to fill a seat ^1*** if he is qualified to be chosen to fill that seat under the provisions of the`
  line `Constitution and this Act ^2*** ^3[or under the provisions of the Government of Union Territories`
  line `Act, 1963 (20 of 1963), as the case may be.]`
obj_root_law_sections_32_footnotes:
  string
  line `1. The words "in any constituency" omitted by Act 27 of 1956, s. 15 (w.e.f. 28-8-1956).`
  line `2. Certain words and figures omitted by the Adaptation of Laws (No. 2) Order, 1956.`
  line `3. Ins. by Act 20 of 1963, s. 57 and the Second Schedule (w.e.f. 13-5-1963).`
obj_root_law_sections_33:
  sectionId (29537)
  sectionNo (33)
  orderNo 47
  title `Presentation of nomination paper and requirement for a valid nomination.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29537&sectionno=33&orderno=47&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_33_content:
  string
  line `^1[33. Presentation of nomination paper and requirements for a valid nomination.--(1) On or`
  line `before the date appointed under clause (a) of section 30 each candidate shall, either in person or by his`
  line `proposer, between the hours of eleven O'clock in the forenoon and three O'clock in the afternoon deliver`
  line `to the returning officer at the place specified in this behalf in the notice issued under section 31 a`
  line `nomination paper completed in the prescribed form and signed by the candidate and by an elector of the`
  line `constituency as proposer:`
  line
  line `^2[Provided that a candidate not set up by a recognised political party, shall not be deemed to be duly`
  line `nominated for election form a constituency unless the nomination paper is subscribed by ten proposers`
  line `being electors of the constituency:`
  line
  line `Provided further that no nomination paper shall be delivered to the returning officer on a day which is`
  line `a public holiday:`
  line
  line `Provided also that in the case of a local authorities' constituency, graduates' constituency or teachers'`
  line `constituency, the reference to an elector of the constituency as proposer shall be construed as a`
  line `reference to ten per cent. of the electors of the constituency or ten such electors, whichever is less, as`
  line proposers.]
  line
  line `^3[(1A) Notwithstanding anything contained in sub-section (1), for election to the Legislative`
  line `Assembly of Sikkim (deemed to be the Legislative Assembly of that State duly constituted under the`
  line `Constitution), the nomination paper to be delivered to the returning officer shall be in such form and`
  line `manner as may be prescribed:`
  line
  line `Provided that the said nomination paper shall be subscribed by the candidate as assenting to the nomination, and`
  line
  line `(a) in the case of a seat reserved for Sikkimese of Bhutia-Lepcha origin, also by at least twenty`
  line `electors of the constituency as proposers and twenty electors of the constituency as seconders;`
  line
  line `(b) in the case of a seat reserved for Sanghas, also by at least twenty electors of the constituency`
  line `as proposers and at least twenty electors of the constituency as seconders;`
  line
  line `(c) in the case of a seat reserved for Sikkimese of Nepali origin, by an elector of the constituency`
  line `as proposer:`
  line
  line `Provided further that no nomination paper shall be delivered to the returning officer on a day which is`
  line `a public holiday.]`
  line
  line `(2) In a constituency where any seat is reserved, a candidate shall not be deemed to be qualified to be`
  line `chosen to fill that seat unless his nomination paper contains a declaration by him specifying the particular`
  line `caste or tribe of which he is a member and the area in relation to which that caste or tribe is a Scheduled`
  line `Caste or, as the case may be, a Scheduled Tribe of the State.`
  line
  line `(3) Where the candidate is a person who, having held any office referred to in ^4[section 9] has been`
  line `dismissed and a period of five years has not elapsed since the dismissal, such person shall not be deemed`
  line `to be duly nominated as a candidate unless his nomination paper is accompanied by a certificate issued in`
  line `the prescribed manner by the Election Commission to the effect that he has not been dismissed for`
  line `corruption or disloyalty to the State.`
  line
  line `(4) On the presentation of a nomination paper, the returning officer shall satisfy himself that the`
  line `names and electoral roll numbers of the candidate and his proposer as entered in the nomination paper are`
  line `the same as those entered in the electoral rolls:`
  line
  line `^5[Provided that no misnomer or inaccurate description or clerical, technical or printing error in regard`
  line `to the name of the candidate or his proposer or any other person, or in regard to any place, mentioned in`
  line `the electoral roll or the nomination paper and no clerical, technical or printing error in regard to the`
  line `electoral roll numbers of any such person in the electoral roll or the nomination paper, shall affect the full`
  line `operation of the electoral roll or the nomination paper with respect to such person or place in any case`
  line `where the description in regard to the name of the person or place is such as to be commonly understood;`
  line `and the returning officer shall permit any such misnomer or inaccurate description or clerical, technical or`
  line `printing error to be corrected and where necessary, direct that any such misnomer, inaccurate description,`
  line `clerical, technical or printing error in the electoral roll or in the nomination paper shall be overlooked.]`
  line
  line `(5) Where the candidate is an elector of a different constituency, a copy of the electoral roll of that`
  line `constituency or of the relevant part thereof or a certified copy of the relevant entries in such roll shall,`
  line `unless it has been filed along with the nomination paper, be produced before the returning officer at the`
  line `time of scrutiny.`
  line
  line `^6[(6) Nothing in this section shall prevent any candidate from being nominated by more than one`
  line `nomination paper:`
  line
  line `Provided that not more than four nomination papers shall be presented by or on behalf of any`
  line `candidate or accepted by the returning officer for election in the same constituency.]`
  line
  line `^7[(7) Notwithstanding anything contained in sub-section (6) or in any other provisions of this Act, a`
  line `person shall not be nominated as a candidate for election,--`
  line
  line `(a) in the case of a general election to the House of the People (whether or not held`
  line `simultaneously from all Parliamentary constituencies), from more than two Parliamentary`
  line constituencies;
  line
  line `(b) in the case of a general election to the Legislative Assembly of a State (whether or not held`
  line `simultaneously from all Assembly constituencies), from more than two Assembly constituencies in`
  line `that State;`
  line
  line `(c) in the case of a biennial election to the Legislative Council of a State having such Council,`
  line `from more than two Council constituencies in the State;`
  line
  line `(d) in the case of a biennial election to the Council of States for filling two or more seats allotted`
  line `to a State, for filling more than two such seats;`
  line
  line `(e) in the case of bye-elections to the House of the People from two or more Parliamentary`
  line `constituencies which are held simultaneously, from more than two such Parliamentary constituencies;`
  line
  line `(f) in the case of bye-elections to the Legislative Assembly of a State from two or more Assembly`
  line `constituencies which are held simultaneously, from more than two such Assembly constituencies;`
  line
  line `(g) in the case of bye-elections to the Council of States for filling two or more seats allotted to a`
  line `State, which are held simultaneously, for filling more than two such seats;`
  line
  line `(h) in the case of bye-elections to the Legislative Council of a State having such Council from`
  line `two or more Council constituencies which are held simultaneously, from more than two such Council`
  line constituencies.
  line
  line `Explanation.For the purposes of this sub-section, two or more bye-elections shall be deemed to be`
  line `held simultaneously where the notification calling such bye-elections are issued by the Election`
  line `Commission under sections 147, 149, 150 or, as the case may be, 151 on the same date.]`
obj_root_law_sections_33_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 16, for section 33 (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by Act 21 of 1996, s. 6, for "the provisos" (w.e.f. 1-8-1996).`
  line `3. Ins. by Act 10 of 1976, s. 2 and the Schedule (w.e.f. 9-9-1975).`
  line
  line `4. Subs. by Act 38 of 1978, s. 3 and the Second Schedule, for clause (f) of section 7 (w.e.f. 26-11-1978).`
  line
  line `5. Subs. by Act 47 of 1966, s. 29, for the proviso (w.e.f. 14-12-1966).`
  line
  line `6. Subs. by Act 40 of 1961, s. 8, for sub-section (6) (w.e.f. 20-9-1961).`
  line
  line `7. Ins. by Act 21 of 1996, s. 6 (w.e.f. 1-8-1996).`
obj_root_law_sections_33_a:
  sectionId (29538)
  sectionNo 33A
  orderNo 48
  title `Right to information.`
  content obj_root_law_sections_33_a_content
  footnotes `1. Ins. by Act 72 of 2002, s. 2 (w.e.f. 24-8-2002).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29538&sectionno=33A&orderno=48&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_33_a_content:
  string
  line `^1[33. Presentation of nomination paper and requirements for a valid nomination.--(1) A candidate shall, apart from any information which he is`
  line `required to furnish, under this Act or the rules made thereunder, in his nomination paper delivered under`
  line `sub-section (1) of section 33, also furnish the information as to whether--`
  line
  line `(i) he is accused of any offence punishable with imprisonment for two years or more in a pending`
  line `case in which a charge has been framed by the court of competent jurisdiction;`
  line
  line `(ii) he has been convicted of an offence [other than any offence referred to in sub-section (1) or`
  line `sub-section (2), or covered in sub-section (3), of section 8] and sentenced to imprisonment for one`
  line `year or more.`
  line
  line `(2) The candidate or his proposer, as the case may be, shall, at the time of delivering to the returning`
  line `officer the nomination paper under sub-section (1) of section 33, also deliver to him an affidavit sworn by`
  line `the candidate in a prescribed form verifying the information specified in sub-section (1).`
  line
  line `(3) The returning officer shall, as soon as may be after the furnishing of information to him under`
  line `sub-section (1), display the aforesaid information by affixing a copy of the affidavit, delivered under`
  line `sub-section (2), at a conspicuous place at his office for the information of the electors relating to a`
  line `constituency for which the nomination paper is delivered.]`
obj_root_law_sections_33_b:
  sectionId (29539)
  sectionNo 33B
  orderNo 49
  title `Candidate to furnish information only under the Act and the rules.`
  content obj_root_law_sections_33_b_content
  footnotes `1. Ins. by s. 3, ibid. (w.e.f. 24-8-2002).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29539&sectionno=33B&orderno=49&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_33_b_content:
  string
  line `^1[[33B. Candidate to furnish information only under the Act and the rules.--Notwithstanding`
  line `anything contained in any judgment, decree or order of any court or any direction, order or any other`
  line `instruction issued by the Election Commission, no candidate shall be liable to disclose or furnish any such`
  line `information, in respect of his election, which is not required to be disclosed or furnished under this Act or`
  line `the rules made thereunder.]`
obj_root_law_sections_34:
  sectionId (29540)
  sectionNo (34)
  orderNo 50
  title Deposits.
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29540&sectionno=34&orderno=50&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_34_content:
  string
  line `^1[(1) A candidate shall not be deemed to be duly nominated for election from a`
  line `constituency unless he deposits or causes to be deposited,`
  line
  line `(a) in the case of an election from a Parliamentary constituency, ^2[a sum of twenty-five thousand`
  line `rupees or where the candidate is a member of a Scheduled Caste or Scheduled Tribe, a sum of twelve`
  line `thousand five hundred rupees]; and`
  line
  line `(b) in the case of an election from an Assembly or Council constituency, ^3[a sum of ten thousand`
  line `rupees or where the candidate is a member of a Scheduled Caste or Scheduled Tribe, a sum of five`
  line `thousand rupees:]`
  line
  line `Provided that where a candidate has been nominated by more than one nomination paper for election`
  line `in the same constituency, not more than one deposit shall be required of him under this sub-section.]`
  line
  line `(2) Any sum required to be deposited under sub-section (1) shall not be deemed to have been`
  line `deposited under that sub-section unless at the time of delivery of the nomination paper ^4[under sub-section (1) or, as the case may be, sub-section (1A) of section 33] the candidate has either deposited`
  line `or caused to be deposited that sum with the returning officer in cash or enclosed with the nomination`
  line `paper a receipt showing that the said sum has been deposited by him or on his behalf in the Reserve Bank`
  line `of India or in a Government Treasury.`
obj_root_law_sections_34_footnotes:
  string
  line `1. Subs. by Act 21 of 1996, s. 7, for sub-section (1) (w.e.f. 1-8-1996).`
  line `2. Subs. by Act 41 of 2009, s. 5, for certain words (w.e.f. 1-2-2010).`
  line `3. Subs. by s. 5, ibid., for certain words (w.e.f. 1-2-2010).`
  line `4. Subs. by Act 10 of 1976, s. 2 and the Schedule for "under sub-section (1) of section 33" (w.e.f. 9-9-1975).`
obj_root_law_sections_35:
  sectionId (29541)
  sectionNo (35)
  orderNo 51
  title `Notice of nominations and the time and place for their scrutiny.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29541&sectionno=35&orderno=51&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_35_content:
  string
  line `The returning officer shall,`
  line `on receiving the nomination paper ^1[under sub-section (1) or, as the case may be, sub-section (1A) of`
  line `section 33], inform the person or persons delivering the same of the date, time and place fixed for the`
  line `scrutiny of nominations and shall enter on the nomination paper its serial number, and shall sign thereon a`
  line `certificate stating the date on which and the hour at which the nomination paper has been delivered to`
  line `him; and shall, as soon as may be thereafter, cause to be affixed in some conspicuous place in his office a`
  line `notice of the nomination containing descriptions similar to those contained in the nomination paper, both`
  line `of the candidate and of ^2[the proposer.]`
obj_root_law_sections_35_footnotes:
  string
  line `1. Subs. by s. 2 and the Schedule, ibid., for under sub-section (1) (w.e.f. 9-9-1975).`
  line `2. Subs. by Act 27 of 1956, s. 18, for certain words (w.e.f. 28-8-1956).`
obj_root_law_sections_36:
  sectionId (29542)
  sectionNo (36)
  orderNo 52
  title `Scrutiny of nominations.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29542&sectionno=36&orderno=52&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_36_content:
  string
  line `(1) On the date fixed for the scrutiny of nominations under`
  line `section 30, the candidates, their election agents, one proposer ^1*** of each candidate, and one other`
  line `person duly authorised in writing by each candidate, but no other person, may attend at such time and`
  line `place as the returning officer may appoint; and the returning officer shall give them all reasonable`
  line `facilities for examining the nomination papers of all candidates which have been delivered within the time`
  line `and in the manner laid down in section 33.`
  line
  line `(2) The returning officer shall then examine the nomination papers and shall decide all objections`
  line `which may be made to any nomination and may, either on such objection or on his own motion, after such`
  line `summary inquiry, if any, as he thinks necessary, ^2[reject] any nomination on any of the following`
  line `grounds:`
  line
  line `^3[(a) ^4that on the date fixed for the scrutiny of nominations the candidate] either is not qualified`
  line `or is disqualified for being chosen to fill the seat under any of the following provisions that may be`
  line `applicable, namely:`
  line
  line `Articles 84, 102, 173 and 191, ^5***.`
  line
  line `^6[Part II of this Act and sections 4 and 14 of the Government of Union Territories`
  line `Act, 1963 (20 of 1963)] ^7***; or`
  line
  line `(b) that there has been a failure to comply with any of the provisions of section 33 or`
  line `section 34; or`
  line
  line `(c) that the signature of the candidate or the proposer on the nomination paper is not genuine.]`
  line
  line `(3) Nothing contained in ^8[clause (b) or clause (c)] of sub-section (2) shall be deemed to authorise the ^9[rejection] of the nomination of any candidate on the ground of any irregularity in respect of a`
  line `nomination paper, if the candidate has been duly nominated by means of another nomination paper in`
  line `respect of which no irregularity has been committed.`
  line
  line `(4) The returning officer shall not reject any nomination paper on the ground of any ^10*** defect`
  line `which is not of a substantial character.`
  line
  line `(5) The returning officer shall hold the scrutiny on the date appointed in this behalf under clause (b)`
  line `of section 30 and shall not allow any adjournment of the proceedings except when such proceedings are`
  line `interrupted or obstructed by riot or open violence or by causes beyond his control:`
  line
  line `Provided that in case ^11[an objection is raised by the returning officer or is made by any other person]`
  line `the candidate concerned may be allowed time to rebut it not later than the next day but one following the`
  line `date fixed for scrutiny, and the returning officer shall record his decision on the date to which the`
  line `proceedings have been adjourned.`
  line
  line `(6) The returning officer shall endorse on each nomination paper his decision accepting or rejecting`
  line `the same and, if the nomination paper is rejected, shall record in writing a brief statement of his reasons`
  line `for such rejection.`
  line
  line `^12(7) For the purposes of this section, a certified copy of an entry in the electoral roll for the time`
  line `being in force of a constituency shall be conclusive evidence of the fact that the person referred to in that`
  line `entry is an elector for that constituency, unless it is proved that he is subject to a disqualification`
  line `mentioned in section 16 of the Representation of the People Act, 1950 (43 of 1950).`
  line
  line `(8) Immediately after all the nomination papers have been scrutinised and decisions accepting or`
  line `rejecting the same have been recorded, the returning officer shall prepare a list of validly nominated`
  line `candidates, that is to say, candidates whose nominations have been found valid, and affix it to his notice`
  line board.]
obj_root_law_sections_36_footnotes:
  string
  line `1. The words "and one seconder" omitted by s. 19, ibid. (w.e.f. 28-8-1956).`
  line `2. Subs. by s. 19, ibid., for "refuse" (w.e.f. 28-8-1956).`
  line `3. Subs. by s. 19, ibid., for clauses (a) to (e) (w.e.f. 28-8-1956).`
  line `4. Subs. by Act 40 of 1961, s. 9, for "that the candidate" (w.e.f. 20-9-1961).`
  line `5. The word "and" omitted by Act 20 of 1963, s. 57 and the Second Schedule (w.e.f. 13-5-1963).`
  line `6. Subs. by s. 57 and the Second Schedule, ibid., for "Part II of this Act" (w.e.f. 13-5-1963).`
  line `7. Certain words and figures omitted by the Adaptation of Laws (No. 2) Order, 1956.`
  line `8. Subs. by Act 27 of 1956, s. 19, for "clause (c), clause (d) or clause (e)" (w.e.f. 28-8-1956).`
  line `9. Subs. by s. 19, ibid., for refusal (w.e.f. 28-8-1956).`
  line `10. The word "technical" omitted by Act 27 of 1956, s. 19 (w.e.f. 28-8-1956).`
  line `11. Subs. by Act 40 of 1961, s. 9, for "and objection is made" (w.e.f. 20-9-1961).`
  line `12. Subs. by Act 27 of 1956, s. 19, for sub-section (7) (w.e.f. 28-8-1956).`
obj_root_law_sections_37:
  sectionId (29543)
  sectionNo (37)
  orderNo 53
  title `Withdrawal of candidature.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29543&sectionno=37&orderno=53&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_37_content:
  string
  line `(1) Any candidate may withdraw his candidature by a notice in`
  line `writing which shall contain such particulars as may be prescribed and shall be subscribed by him and`
  line `delivered before three O'clock in the afternoon on the day fixed under clause (c) of section 30 to the`
  line `returning officer either by such candidate in person or by his proposer, ^1*** or election agent who has`
  line `been authorised in this behalf in writing by such candidate.`
  line
  line ^2****
  line
  line `(2) No person who has given a notice or withdrawal of his candidature under sub-section (1) shall be`
  line `allowed to cancel the notice.`
  line
  line `^3[(3) The returning officer shall, on being satisfied as to the genuineness of a notice or withdrawal and`
  line `and the identity of the person delivering it under sub-section (1), cause the notice to be affixed in some`
  line `conspicuous place in his office.]`
obj_root_law_sections_37_footnotes:
  string
  line `1. The word "seconder" omitted by s. 20, ibid. (w.e.f. 28-8-1956).`
  line `2. The proviso omitted by s. 20, ibid. (w.e.f. 28-8-1956).`
  line `3. Subs. by Act 40 of 1961, s. 10, for sub-section (3) (w.e.f. 20-9-1961).`
obj_root_law_sections_38:
  sectionId (29544)
  sectionNo (38)
  orderNo 54
  title `Publication of list of contesting candidates.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29544&sectionno=38&orderno=54&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_38_content:
  string
  line `^1[38. Publication of list of contesting candidates.--(1) Immediately after the expiry of the period`
  line `within which candidatures may be withdrawn under sub-section (1) of section 37, the returning officer`
  line `shall prepare and publish in such form and manner as may be prescribed a list of contesting candidates,`
  line `that is to say, candidates who were included in the list of validity nominated candidates and who have not`
  line `withdrawn their candidature within the said period.`
  line
  line `^2[(2) For the purpose of listing the names under sub-section (1), the candidates shall be classified as follows, namely:--`
  line
  line `(i) candidates of recognised political parties;`
  line
  line `(ii) candidates of registered political parties other than those mentioned in clause (i);`
  line
  line `(iii) other candidates.`
  line
  line `(3) The categories mentioned in sub-section (2) shall be arranged in the order specified therein and`
  line `the names of candidates in each category shall be arranged in alphabetical order and the addresses of the`
  line `contesting candidates as given in the nomination papers together with such other particulars as may be`
  line prescribed].]
obj_root_law_sections_38_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 21, for section 38 (w.e.f. 28-8-1956).`
  line `2. Subs. by Act 21 of 1966, s. 8, for sub-section (2) (w.e.f. 1-8-1996).`
obj_root_law_sections_39:
  sectionId (29545)
  sectionNo (39)
  orderNo 55
  title `Nomination of candidates at other elections.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29545&sectionno=39&orderno=55&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_39_content:
  string
  line `^1[39.Nomination of candidates at other elections.--(1) As soon as the notification calling upon the`
  line `elected members or the members of the Legislative Assembly of a State or the members of the electoral`
  line `college of a ^2[Union territory] to elect a member or members is issued, the Election Commission shall, by`
  line `notification in the Official Gazette, appoint`
  line
  line `(a) the last date for making nominations, which shall be the ^3[seventh day] after the date of`
  line `publication of the first-mentioned notification or, if that day is a public holiday, the next succeeding`
  line `day which is not a public holiday;`
  line
  line `(b) the date for the scrutiny of nominations, which shall be ^4[the day immediately following] the`
  line `last date for making nominations or, if that day is a public holiday, the next succeeding day which is`
  line `not a public holiday;`
  line
  line `(c) the last date for the withdrawal of candidatures, which shall be ^5[the second day] after the date`
  line `date for the scrutiny of nominations or, if that day is a public holiday, the next succeeding day which`
  line `is not a public holiday;`
  line
  line `(d) the date or dates on which a poll shall, if necessary, be taken, which or the first of which shall`
  line `be a date not earlier than the seventh day after the last date for the withdrawal of candidatures; and`
  line
  line `(e) the date before which the election shall be completed.`
  line
  line ^6*****
  line
  line `(2) The provisions of sections 31 to 38, excluding sub-sections (2) and (5) of section 33`
  line `and ^7[clause (a) of sub-section (1) of section 34], shall apply in relation to any such election as they apply`
  line `apply in relation to an election in any constituency:`
  line
  line `Provided that`
  line
  line `(a) any references in the said provisions to the electoral roll of the constituency shall, unless the`
  line `context otherwise requires, be construed, in the case of an election by the members or the elected`
  line `members of the Legislative Assembly of the State, as references to the list of members or elected`
  line `members, as the case may be, of that Assembly maintained under sub-section (1) of section 152, and`
  line `in the case of an election by the members of the electoral college of a ^2[Union territory], as references`
  line `to the list of members of such electoral college maintained under sub-section (2) of that section;`
  line
  line `^8[(aa) the reference in the opening paragraph of sub-section (1) of section 33 to "an elector of the`
  line `constituency as proposer" shall be construed as a reference to "ten per cent. of the elected members or`
  line `of the members of the Legislative Assembly of a State or of the members of the electoral college of a`
  line `Union territory, as the case may be, or ten members concerned, whichever is less, as proposers":`
  line
  line `Provided that where as a result of the calculation of the percentage referred to in this clause, the`
  line `number of members arrived at is a fraction and if the fraction so arrived at is more than one-half it`
  line `shall be counted as one, and if the fraction so arrived at is less than one-half it shall be ignored;]`
  line
  line `^9[^10[(ab)] in the case of an election to the Legislative Council of a State by the members of the`
  line `Legislative Assembly of that State, clause (a) of sub-section (2) of section 36 shall be construed as`
  line `including a reference to sub-clause (d) of clause (3) of article 171;]`
  line
  line `(b) any references in the said provisions to section 30 shall be construed as references to`
  line `sub-section (1) of this section; and`
  line
  line `(c) at the time of presenting the nomination paper, the returning officer may require the person`
  line `presenting the same to produce either a copy of the electoral roll, or part of the electoral roll, in which`
  line `the name of the candidate is included or a certified copy of the relevant entries in such roll.]`
obj_root_law_sections_39_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 22, for section 39 (w.e.f. 28-8-1956).`
  line `2. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part C State".`
  line `3. Subs. by Act 40 of 1961, s. 11, for "tenth day" (w.e.f. 20-9-1961).`
  line `4. Subs. by Act 47 of 1966, s. 30, for "the second day after" (w.e.f. 14-12-1966).`
  line `5. Subs. by s. 30, ibid., for "the third day" (w.e.f. 14-12-1966).`
  line `6. The Explanation omitted by s. 30, ibid. (w.e.f. 14-12-1966).`
  line `7. Subs. by Act 58 of 1958, s. 19, for "section 34" (w.e.f. 30-12-1958).`
  line `8. Ins. by Act 1 of 1989, s. 8 (w.e.f. 1-4-1989)`
  line `9. Ins. by Act 47 of 1966, s. 30 (w.e.f. 14-12-1966).`
  line `10. Clause (aa) relettered as clause (ab) by Act 1 of 1989, s. 8 (w.e.f. 1-4-1989).`
obj_root_law_sections_39_a:
  sectionId (29546)
  sectionNo 39A
  orderNo 56
  title `Allocation of equitable sharing of time.`
  content obj_root_law_sections_39_a_content
  footnotes `1. Ins. by Act 46 of 2003, s. 3 (w.e.f. 11-9-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29546&sectionno=39A&orderno=56&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_39_a_content:
  string
  line `^1[39A. Allocation of equitable sharing of time.(1) Notwithstanding anything contained in any`
  line `other law for the time being in force, the Election Commission shall, on the basis of the past performance`
  line `of a recognised political party, during elections, allocate equitable sharing of time on the cable television`
  line `network and other electronic media in such manner as may be prescribed to display or propagate any`
  line `election matter or to address public in connection with an election.`
  line
  line `(2) The allocation of equitable sharing of time under sub-section (1), in respect of an election, shall be`
  line `made after the publication of list of contesting candidates under section 38 for the election and shall be`
  line `valid till forty-eight hours before the hour fixed for poll for such election.`
  line
  line `(3) The allocation of equitable sharing of time under sub-section (1) shall be binding on all political`
  line `parties concerned.`
  line
  line `(4) The Election Commission may, for the purposes of this section, make code of conduct for cable`
  line `operators and electronic media and the cable operators and every person managing or responsible for the`
  line `management of the electronic media shall abide by such code of conduct.`
  line
  line `Explanation--For the purposes of this section,`
  line
  line `(a) "electronic media" includes radio and any other broadcasting media notified by the Central`
  line `Government in the Official Gazette;`
  line
  line `(b) "cable television network" and "cable operator" have the meanings respectively assigned to`
  line `them under the Cable Television Networks (Regulation) Act, 1995 (7 of 1995).]`
obj_root_law_sections_40:
  sectionId (29547)
  sectionNo (40)
  orderNo 57
  title `Election agents.`
  content obj_root_law_sections_40_content
  footnotes `1. Subs. by Act 27 of 1956, s. 23, for section 40 (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29547&sectionno=40&orderno=57&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_40_content:
  string
  line `^1[40. Election agents.--A candidate at an election may appoint in the prescribed manner any one`
  line `person other than himself to be his election agent and when any such appointment is made, notice of the`
  line `appointment shall be given in the prescribed manner to the returning officer.]`
obj_root_law_sections_41:
  sectionId (29548)
  sectionNo (41)
  orderNo 58
  title `Disqualification for being an election agent.`
  content obj_root_law_sections_41_content
  footnotes `1. Subs. by Act 47 of 1966, s. 31, for section 41 (w.e.f. 14-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29548&sectionno=41&orderno=58&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_41_content:
  string
  line `^1[41. Disqualification for being an election agent.--Any person who is for the time being`
  line `disqualified under the Constitution or under this Act for being a member of either House of Parliament or`
  line `the House or either House of the Legislature of a State or for voting at elections, shall, so long as the`
  line `disqualification subsists, also be disqualified for being an election agent at any election.]`
obj_root_law_sections_42:
  sectionId (29549)
  sectionNo (42)
  orderNo 59
  title `Revocation of the appointment, or death, of an election agent.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29549&sectionno=42&orderno=59&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_42_content:
  string
  line `(1) Any revocation of the`
  line `appointment of an election agent, ^1*** shall be signed by the candidate, and shall operate from the date on`
  line `on which it is lodged with the returning officer.`
  line
  line `^2[(2) In the event of such a revocation or of the death of an election agent whether that event occurs`
  line `before or during the election, or after the election but before the account of the candidates election`
  line `expenses has been lodged in accordance with the provisions of section 78, the candidate may appoint in`
  line `the prescribed manner another person to be his election agent and when such appointment is made notice`
  line `of the appointment shall be given in the prescribed manner to the returning officer.]`
obj_root_law_sections_42_footnotes:
  string
  line `1. The words "whether he be the candidate himself or not" omitted by Act 27 of 1956, s. 24 (w.e.f. 28-8-1956).`
  line `2. Subs. by s. 24, ibid., for sub-section (2) (w.e.f. 28-8-1956).`
obj_root_law_sections_43:
  sectionId (29550)
  sectionNo (43)
  orderNo 60
  title [Omitted.].
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29550&sectionno=43&orderno=60&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_43_content:
  string
  line `[Effect of default in appointment of election agent under section 42.] Omitted by the`
  line `Representation of the People (Second Amendment) Act, 1956 (27 of1956), s 25 (w.e.f. 28-8-1956).`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (29551)
  sectionNo (44)
  orderNo 61
  title [Omitted.].
  content `[Duty of the election agent to keep accounts.] Omitted by s. 25, ibid. (w.e.f. 28-8-1956).`
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29551&sectionno=44&orderno=61&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (29552)
  sectionNo (45)
  orderNo 62
  title `Functions of election agents.`
  content obj_root_law_sections_45_content
  footnotes `1. Subs. by Act 27 of 1956, s. 26, for section 45 (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29552&sectionno=45&orderno=62&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_45_content:
  string
  line `^1[45. Functions of election agents.--An election agent may perform such functions in connection`
  line `with the election as are authorised by or under this Act to be performed by an election agent.]`
obj_root_law_sections_46:
  sectionId (29553)
  sectionNo (46)
  orderNo 63
  title `Appointment of polling agents.`
  content obj_root_law_sections_46_content
  footnotes `1. Subs. by s. 27, ibid., for s. 46 (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29553&sectionno=46&orderno=63&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_46_content:
  string
  line `^1[46. Appointment of polling agents.--A contesting candidate or his election agent may appoint in`
  line `the prescribed manner such number of agents and relief agents as may be prescribed to act as polling`
  line `agents of such candidate at each polling station provided under section 25 or at the place fixed under`
  line `sub-section (1) of section 29 for the poll.]`
obj_root_law_sections_47:
  sectionId (29554)
  sectionNo (47)
  orderNo 64
  title `Appointment of counting agents.`
  content obj_root_law_sections_47_content
  footnotes `1. Subs. by s. 28, ibid., for section 47 (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29554&sectionno=47&orderno=64&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_47_content:
  string
  line `^1[47. Appointment of counting agents.--A contesting candidate or his election agent may appoint in`
  line `in the prescribed manner one or more persons, but not exceeding such number as may be prescribed, to`
  line `the present as his counting agent or agents at the counting of votes, and when any such appointment is`
  line `made notice of the appointment shall be given in the prescribed manner to the returning officer.]`
obj_root_law_sections_48:
  sectionId (29555)
  sectionNo (48)
  orderNo 65
  title `Revocation of the appointment, or death of a polling agent or counting agent.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29555&sectionno=48&orderno=65&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_48_content:
  string
  line `(1) Any`
  line `revocation of the appointment of a polling agent shall be signed by the candidate or his election agent and`
  line `shall operate from the date on which it is lodged with such officer as may be prescribed, and in the event`
  line `of such a revocation or of the death of a polling agent before the close of the poll, the candidate or his`
  line `election agent may appoint in the prescribed manner another polling agent at any time before the poll is`
  line `closed and shall forthwith give notice of such appointment in the prescribed manner to such officer as`
  line `may be prescribed.`
  line
  line `(2) Any revocation of the appointment of a counting agent shall be signed by the candidate or his`
  line `election agent and shall operate from the date on which it is lodged with the returning officer, and in the`
  line `event of such revocation or of the death of a counting agent before the commencement of the counting of`
  line `votes, the candidate or his election agent may appoint in the prescribed manner another counting agent at`
  line `any time before the counting of votes is commenced and shall forthwith give notice of such appointment`
  line `in the prescribed manner to the returning officer.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (29556)
  sectionNo (49)
  orderNo 66
  title `Functions of polling agents and counting agents.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29556&sectionno=49&orderno=66&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_49_content:
  string
  line `(1) A polling agent may perform such`
  line `functions in connection with the poll as are authorised by or under this Act to be performed by a polling`
  line agent.
  line
  line `(2) A counting agent may perform such functions in connection with the counting of votes as are`
  line `authorised by or under this Act to be performed by a counting agent`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (29557)
  sectionNo (50)
  orderNo 67
  title `Attendance of a contesting candidate or his election agent at polling stations, and performance by him of the functions of a polling agent or counting agent.`
  content obj_root_law_sections_50_content
  footnotes `1. Subs. by Act 58 of 1958, s. 20, for "candidate" (w.e.f. 30-12-1958).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29557&sectionno=50&orderno=67&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_50_content:
  string
  line `(1) At every election`
  line `where a poll is taken, each ^1[contesting candidate] at such election and his election agent shall have a`
  line `right to be present at any polling station provided under section 25 for the taking of the poll or at the place`
  line `fixed under sub-section (1) of section 29 for the poll.`
  line
  line `(2) A ^1[contesting candidate] or his election agent may himself do any act or thing which any polling`
  line `agent or the counting agent of such ^1[contesting candidate] if appointed, would have been authorised by`
  line `or under this Act to do, or may assist any polling agent or the counting agent of such ^1[contesting candidate] in doing any such act or thing.`
obj_root_law_sections_51:
  sectionId (29558)
  sectionNo (51)
  orderNo 68
  title `Non-attendance of polling or counting agents.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29558&sectionno=51&orderno=68&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_51_content:
  string
  line `Where any act or thing is required or`
  line `authorised by or under this Act to be done in the presence of the polling or counting agents, the`
  line `non-attendance of any such agent or agents at the time and place appointed for the purpose shall not, if the`
  line `act or thing is otherwise duly done, invalidate the act or thing done.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (29559)
  sectionNo (52)
  orderNo 69
  title `Death of candidate of recognised Political Party before Poll.`
  content obj_root_law_sections_52_content
  footnotes `1. Subs. by Act 21 of 1996, s. 9, for section 52 (w.e.f. 1-8-1996).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29559&sectionno=52&orderno=69&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_52_content:
  string
  line `^1[52. Death of a candidate of a recognised political party before poll.--(1) If a candidate, set up`
  line `by a recognised political party,`
  line
  line `(a) dies at any time after 11.00 A.M. on the last date for making nominations and his nomination`
  line `is found valid on scrutiny under section 36; or`
  line
  line `(b) whose nomination has been found valid on scrutiny under section 36 and who has not`
  line `withdrawn his candidature under section 37, dies,`
  line
  line `and in either case, a report of his death is received at any time before the publication of the list of`
  line `contesting candidates under section 38; or`
  line
  line `(c) dies as a contesting candidate and a report of his death is received before the commencement`
  line `of the poll,`
  line
  line `the returning officer shall, upon being satisfied about the fact of the death of the candidate, by order,`
  line `announce an adjournment of the poll to a date to be notified later and report the fact to the Election`
  line `Commission and also to the appropriate authority:`
  line
  line `Provided that no order for adjourning a poll should be made in a case referred to in clause (a) except`
  line `after the scrutiny of all the nominations including the nomination of the deceased candidate.`
  line
  line `(2) The Election Commission shall, on the receipt of a report from the returning officer under`
  line `sub-section (1), call upon the recognised political party, whose candidate has died, to nominate another`
  line `candidate for the said poll within seven days of issue of such notice to such recognised political party and`
  line `the provisions of sections 30 to 37 shall, so far as may be, apply in relation to such nomination as they`
  line `would apply to other nominations:`
  line
  line `Provided that no person who has given a notice of withdrawal of his candidature under`
  line `sub-section (1) of section 37 before the adjournment of the poll shall be ineligible for being nominated as`
  line `a candidate for the election after such adjournment.`
  line
  line `(3) Where a list of contesting candidates had been published under section 38 before the adjournment`
  line `of the poll under sub-section (1), the returning officer shall again prepare and publish a fresh list of`
  line `contesting candidates under that section so as to include the name of the candidate who has been validly`
  line `nominated under sub-section (2).`
  line
  line `Explanation.For the purposes of this section, sections 33 and 38, "recognised political party",`
  line `means a political party recognised by the Election Commission under the Election Symbols (Reservation`
  line `and Allotment) Order, 1968.]`
obj_root_law_sections_53:
  sectionId (29560)
  sectionNo (53)
  orderNo 70
  title `Procedure in contested and uncontested elections.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29560&sectionno=53&orderno=70&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_53_content:
  string
  line `^1[(1) If the number of contesting`
  line `candidates is more than the number of seats to be filled, a poll shall be taken.]`
  line
  line `(2) If the number of such candidates is equal to the number of seats to be filled, the returning officer`
  line `shall forthwith declare all such candidates to be duly elected to fill those seats.`
  line
  line `(3) If the number of such candidates is less than the number of seats to be filled, the returning officer`
  line `shall forthwith declare all such candidates to be elected and the ^2[Election Commission] shall, by`
  line `notification in the Official Gazette, call upon the constituency or the elected members or the members of`
  line `the State Legislative Assembly or the members of the electoral college concerned ^3*** as the case may`
  line `be, to elect a person or persons to fill the remaining seat or seats ^4***:`
  line
  line `Provided that where the constituency or the elected members or the members of the State Legislative`
  line `Assembly or the members of the electoral college ^3*** having already been called upon under this sub-section, has or have failed to elect a person or the requisite number of persons, as the case may be, to fill the vacancy or vacancies, the ^2[Election Commission] shall not be bound to call again upon the`
  line `consituency, or such members to elect a person or persons ^5[until it is satisfied that if called upon again,`
  line `there will be no such failure on the part of the constituency of such members].`
obj_root_law_sections_53_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 30, for sub-section (1) (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by s. 30, ibid., for "appropriate authority" (w.e.f. 28-8-1956).`
  line
  line `3. The words "or the elected members of the Coorg Legislative Council" omitted by Act 49 of 1951, s. 44 and the Fifth`
  line `Schedule (w.e.f. 6-9-1951).`
  line
  line `4. Certain words omitted by Act 27 of 1956, s. 30 (w.e.f. 28-8-1956).`
  line
  line `5. Subs. by s. 30, ibid., for "until such date as the Election Commission may specify in this behalf" (w.e.f. 28-8-1956)`
obj_root_law_sections_54:
  sectionId (29561)
  sectionNo (54)
  orderNo 71
  title [Omitted.].
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29561&sectionno=54&orderno=71&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_54_content:
  string
  line `[Special procedure at elections in constituencies where seats are reserved for`
  line `Scheduled Castes or Scheduled Tribes.] Omitted by the Representation of the People (Amendment)`
  line `Act, 1961 (40 of 1961), s. 12 (w.e.f. 20-9-1961).`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (29562)
  sectionNo (55)
  orderNo 72
  title `Eligibility of members of Scheduled Castes or Scheduled Tribes to hold seats not reserved for those castes or tribes.`
  content obj_root_law_sections_55_content
  footnotes `1. Added by Act 20 of 1963, s. 57 and the second Schedule (w.e.f. 13-5-1963).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29562&sectionno=55&orderno=72&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_55_content:
  string
  line `For the avoidance of doubt it is hereby declared that a member of the Scheduled`
  line `Castes or of the Scheduled Tribes shall not be disqualified to hold a seat not reserved for members of those`
  line `castes or tribes, if he is otherwise qualified to hold such seats under the Constitution and this Act ^1[or under the`
  line `Government of Union Territories Act, 1963 (20 of 1963), as the case may be].`
obj_root_law_sections_55_a:
  sectionId (29563)
  sectionNo 55A
  orderNo 73
  title [Omitted.].
  content obj_root_law_sections_55_a_content
  footnotes obj_root_law_sections_55_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29563&sectionno=55A&orderno=73&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_55_a_content:
  string
  line `[Retirement from contest at elections in Parliamentary and Assembly constituencies] Omitted by the`
  line `Representation of the People (Amendment) Act, 1958 (58 of 1958), s. 22 (w.e.f. 30-12-1958).`
obj_root_law_sections_55_a_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (29564)
  sectionNo (56)
  orderNo 74
  title `Fixing time for poll.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29564&sectionno=56&orderno=74&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_56_content:
  string
  line `The ^1[Election Commission] shall fix the hours during which the poll will`
  line `be taken; and the hours so fixed shall be published in such manner as may be prescribed:`
  line
  line `Provided that the total period allotted on any one day for polling at an election in ^2[a Parliamentary or Assembly constituency] shall not be less than eight hours.`
obj_root_law_sections_56_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 34, for "appropriate authority" (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by Act 58 of 1958, s. 23, for "a Constituency" (w.e.f. 30-12-1958).`
obj_root_law_sections_57:
  sectionId (29565)
  sectionNo (57)
  orderNo 75
  title `Adjournment of poll in emergencies.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29565&sectionno=57&orderno=75&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_57_content:
  string
  line `(1) If at an election the proceedings at any polling`
  line `station provided under section 25 or at the place fixed under sub-section (1) of section 29 for the poll are`
  line `interrupted or obstructed by any riot or open violence, or if at an election it is not possible to take the poll`
  line `at any polling station or such place on account of any natural calamity, or any other sufficient cause, the`
  line `presiding officer for such polling station or the returning officer presiding over such place, as the case`
  line `may be, shall announce an adjournment of the poll to a date to be notified later, and where the poll is so`
  line `adjourned by a presiding officer, he shall forthwith inform the returning officer concerned.`
  line
  line `(2) Whenever a poll is adjourned under sub-section (1), the returning officer shall immediately report`
  line `the circumstances to the appropriate authority and the Election Commission, and shall, as soon as may be,`
  line `with the previous approval of the Election Commission, appoint the day on which the poll shall`
  line `recommence, and fix the polling station or place at which and the hours during which, the poll will be`
  line `taken, and shall not count the votes cast at such election until such adjourned poll shall have been`
  line completed.
  line
  line `(3) In every such case as aforesaid the returning officer shall notify in such manner as the Election`
  line `Commission may direct the date, place and hours of polling fixed under sub-section (2).`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (29566)
  sectionNo (58)
  orderNo 76
  title `Fresh poll in the case of destruction, etc., of ballot boxes.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29566&sectionno=58&orderno=76&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_58_content:
  string
  line `^1[Fresh poll in the case of destruction, etc., of ballot boxes.(1) If at any election,`
  line
  line `(a) any ballot box used at a polling station or at a place fixed for the poll is unlawfully taken out`
  line `of the custody of the presiding officer or the returning officer, or is accidentally or intentionally`
  line `destroyed or lost, or is damaged or tampered with, to such an extent, that the result of the poll at that`
  line `polling station or place cannot be ascertained; or`
  line
  line `^2[(aa) any voting machine develops a mechanical failure during the course of the recording of votes; or]`
  line
  line `(b) any such error or irregularity in procedure as is likely to vitiate the poll is committed at apolling station or at a place fixed for the poll,`
  line
  line `the returning officer shall forthwith report the matter to the Election Commission.`
  line
  line `(2) Thereupon the Election Commission shall, after taking all material circumstances into`
  line `account; either`
  line
  line `(a) declare the poll at that polling station or place to be void, appoint a day, and fix the hours, for`
  line `taking a fresh poll at that polling station or place and notify the day so appointed and the hours so`
  line `fixed in such manner as it may deem fit, or`
  line
  line `(b) if satisfied that the result of a fresh poll at that polling station or place will not, in any way,`
  line `affect the result of the election or that ^1[the mechanical failure of the voting machine or] the error or`
  line `irregularity in procedure is not material, issue such directions to the returning officer as it may deem`
  line `proper for the further conduct and completion of the election.`
  line
  line `(3) The provisions of this Act and of any rules or orders made thereunder shall apply to every such`
  line `fresh poll as they apply to the original poll.]`
obj_root_law_sections_58_footnotes:
  string
  line `1. Subs. by Act 40 of 1961, s. 13, for section 58 (w.e.f. 20-9-1961).`
  line
  line `2. Ins. by Act 1 of 1989, s. 9 (w.e.f. 15-3-1989).`
obj_root_law_sections_58_a:
  sectionId (29567)
  sectionNo 58A
  orderNo 77
  title `Adjournment of poll or countermanding of election on the ground of booth capturing.`
  content obj_root_law_sections_58_a_content
  footnotes `1. Ins. by s. 10, ibid. (w.e.f. 15-3-1989).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29567&sectionno=58A&orderno=77&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_58_a_content:
  string
  line `^1[Adjournment of poll or countermanding of election on the ground of booth caputring.—(1) If at any election,—`
  line
  line `(a) booth capturing has taken place at a polling station or at a place fixed for the poll (hereafter in`
  line `this section referred to as a place) in such a manner that the result of the poll at that polling station or`
  line `place cannot be ascertained; or`
  line
  line `(b) booth capturing takes place in any place for counting of votes in such a manner that the result`
  line `of the counting at that place cannot be ascertained,`
  line
  line `the returning officer shall forthwith report the matter to the Election Commission.`
  line
  line `(2) The Election Commission shall, on the receipt of a report from the returning officer under`
  line `sub-section (1) and after taking all material circumstances into account, either—`
  line
  line `(a) declare that the poll at that polling station or place be void, appoint a day, and fix the hours,`
  line `for taking fresh poll at that polling station or place and notify the date so appointed and hours so fixed`
  line `in such manner as it may deem fit; or`
  line
  line `(b) if satisfied that in view of the large number of polling stations or places involved in booth`
  line `capturing the result of the election is likely to be affected, or that booth capturing had affected`
  line `counting of votes in such a manner as to affect the result of the election, countermand the election in`
  line `that constituency.`
  line
  line `Explanation.—In this section, "booth capturing" shall have the same meaning as in section 135A.]`
obj_root_law_sections_59:
  sectionId (29568)
  sectionNo (59)
  orderNo 78
  title `Manner of voting at elections.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29568&sectionno=59&orderno=78&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_59_content:
  string
  line `At every election where a poll is taken votes shall be given by`
  line `ballot in such manner as may be prescribed, ^1[and, save as expressly provided by this Act, no votes shall`
  line `be received by proxy]:`
  line
  line `^2[Provided that the votes at every election to fill a seat or seats in the Council of States shall be given by open ballot.]`
obj_root_law_sections_59_footnotes:
  string
  line `1. Subs. by Act 24 of 2003, s. 2, for "and no votes shall be received by proxy" (w.e.f. 22-9-2003).`
  line
  line `2. Ins. by Act 40 of 2003, s. 3 (w.e.f. 28-8-2003).`
obj_root_law_sections_60:
  sectionId (29569)
  sectionNo (60)
  orderNo 79
  title `Special procedure for voting by certain classes of persons.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29569&sectionno=60&orderno=79&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_60_content:
  string
  line `^1[60. Special prodecure for voting by certain classes of persons.--Without prejudice to the`
  line `generality of the provisions contained in section 59, provision may be made, by rules made under this`
  line `Act, for enabling,`
  line
  line `(a) any of the persons as is referred to in clause (a) or clause (b) of sub-section (8) of section 20`
  line `of the Representation of the People Act, 1950 (43 of 1950) (hereinafter in this section referred to as`
  line `the 1950-Act) to give his vote either in person or by postal ballot or by proxy, and not in any other`
  line `manner, at an election in a constituency where poll is taken;`
  line
  line `(b) any of the following persons to give his vote either in person or by postal ballot, and not in`
  line `any other manner, at an election in a constituency where a poll is taken, namely:`
  line
  line `(i) any person as is referred to in clause (c) or clause (d) of sub-section (8) of section 20 of`
  line `the 1950-Act;`
  line
  line `(ii) the ^2[spouse] of any such person to whom the provisions of sub-section (3) of section 20 of`
  line `the 1950-Act apply and such ^2[spouse] being ordinarily residing with that person in terms of`
  line `sub-section (6) of that section;`
  line
  line `(c) any person belonging to a class of persons notified by the Election Commission in`
  line `consultation with the Government to give his vote by postal ballot, and not in any other manner, at an`
  line `election in a constituency where a poll is taken subject to the fulfilment of such requirements as may`
  line `be specified in those rules;`
  line
  line `(d) any person subjected to preventive detention under any law for the time being in force to give`
  line `his vote by postal ballot, and not in any other manner, at an election in a constituency where a poll is`
  line `taken, subject to the fulfilment of such requirements as may be specified in those rules.]`
obj_root_law_sections_60_footnotes:
  string
  line `1. Subs. by Act 24 of 2003, s. 3, for section 60 (w.e.f. 22-9-2003).`
  line
  line `2. Subs. by Act 49 of 2021, s. 6, for “wife” (w.e.f. 1-8-2022).`
obj_root_law_sections_61:
  sectionId (29570)
  sectionNo (61)
  orderNo 80
  title `Special procedure for preventing personation of electors.`
  content obj_root_law_sections_61_content
  footnotes `1. Subs. by Act 58 of 1958, s. 25, for "section 61" (w.e.f. 30-12-1958).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29570&sectionno=61&orderno=80&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_61_content:
  string
  line `^1[61. Special procedure for preventing personation of electors.--With a view to preventing`
  line `personation of electors provision may be made by rules made under this Act:`
  line
  line `(a) for the marking with indelible ink of the thumb or any other finger of every elector who`
  line `applies for a ballot paper or ballot papers for the purpose of voting at a polling station before delivery`
  line `of such paper or papers to him;`
  line
  line `(b) for the production before the presiding officer or a polling officer of a polling station by every`
  line `such elector as aforesaid of identity card before the delivery of a ballot paper or ballot papers to him if`
  line `under rules made in that behalf under the Representation of the People Act, 1950 (43 of 1950),`
  line `electors of the constituency in which the polling station is situated have been supplied with identity`
  line `cards with or without their respecting photographs attached thereto; and`
  line
  line `(c) for prohibiting the delivery of any ballot paper to any person for voting at a polling station if`
  line `at the time such person applies for such paper he has already such a mark on his thumb or any other`
  line `finger or does not produce on demand his identity card before the presiding officer or a polling officer`
  line `of the polling station].`
obj_root_law_sections_61_a:
  sectionId (29571)
  sectionNo 61A
  orderNo 81
  title `Voting machines at elections.`
  content obj_root_law_sections_61_a_content
  footnotes `1. Ins. by Act 1 of 1989, s. 11 (w.e.f. 15-3-1989).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29571&sectionno=61A&orderno=81&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_61_a_content:
  string
  line `^1[61A. Voting machines at elections.--Notwithstanding anything contained in this Act or the rules`
  line `made thereunder, the giving and recording of votes by voting machines in such manner as may be`
  line `prescribed, may be adopted in such constituency or constituencies as the Election Commission may,`
  line `having regard to the circumstances of each case, specify.`
  line
  line `Explanation.For the purpose of this section, "voting machine" means any machine or apparatus`
  line `whether operated electronically or otherwise used for giving or recording of votes and any reference to a`
  line `ballot box or ballot paper in this Act or the rules made thereunder shall, save as otherwise provided, be`
  line `construed as including a reference to such voting machine wherever such voting machine is used at any`
  line election.]
obj_root_law_sections_62:
  sectionId (29572)
  sectionNo (62)
  orderNo 82
  title `Right to vote.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29572&sectionno=62&orderno=82&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_62_content:
  string
  line `(1) No person who is not, and except as expressly provided by this Act, every`
  line `person who is, for the time being entered in the electoral roll of any constituency shall be entitled to vote`
  line `in that constituency.`
  line
  line `(2) No person shall vote at an election in any constituency if he is subject to any of the`
  line `disqualifications referred to in section 16 of the Representation of the People Act, 1950 (43 of 1950).`
  line
  line `(3) No person shall vote at a general election in more than one constituency of the same class, and if a`
  line `person votes in more than one such constituency, his votes in all such constituencies shall be void.`
  line
  line `(4) No person shall at any election vote in the same constituency more than once, notwithstanding`
  line `that his name may have been registered in the electoral roll for that constituency more than once, and if he`
  line `does so vote, all his votes in that constituency shall be void.`
  line
  line `(5) No person shall vote at any election if he is confined in a prison, whether under a sentence of`
  line `imprisonment or transportation or otherwise, or is in the lawful custody of the police:`
  line
  line `Provided that nothing in this sub-section shall apply to a person subjected to preventive detention`
  line `under any law for the time being in force.`
  line
  line `^1[Provided further that by reason of the prohibition to vote under this sub-section, a person whose`
  line `name has been entered in the electoral roll shall not cease to be an elector.]`
  line
  line `^2[(6) Nothing contained in sub-sections (3) and (4) shall apply to a person who has been authorised to`
  line `vote as proxy for an elector under this Act in so far as he votes as a proxy for such elector.]`
obj_root_law_sections_62_footnotes:
  string
  line `1. Ins. by Act 29 of 2013, s. 3 (w.e.f. 10-7-2013).`
  line
  line `2. Ins. by Act 24 of 2003, s. 4 (w.e.f. 22-9-2003).`
obj_root_law_sections_63:
  sectionId (29573)
  sectionNo (63)
  orderNo 83
  title [Omitted.].
  content `[Method of voting.] Omitted by the Representation of the People (Amendment) Act, 1961 (40 of 1961), s. 14 (w.e.f. 20-9-1961).`
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29573&sectionno=63&orderno=83&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (29574)
  sectionNo (64)
  orderNo 84
  title `Counting of votes.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29574&sectionno=64&orderno=84&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_64_content:
  string
  line `At every election where a poll is taken, votes shall be counted by, or under`
  line `the ^1[supervision and direction] of, the returning officer, and each ^2`
  line `[contesting candidate], his election`
  line `agent and his ^3[counting agents], shall have a right to be present at the time of counting.`
obj_root_law_sections_64_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 36, for "supervision" (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by Act 58 of 1958, s. 26, for "candidate" (w.e.f. 30-12-1958).`
  line
  line `3. Subs. by Act 27 of 1956, s. 36, for "counting agent" (w.e.f. 28-8-1956).`
obj_root_law_sections_64_a:
  sectionId (29575)
  sectionNo 64A
  orderNo 85
  title `Destruction, loss, etc., of ballot papers at the time of counting.`
  content obj_root_law_sections_64_a_content
  footnotes `1. Ins. by Act 47 of 1966, s. 34 (w.e.f. 14-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29575&sectionno=64A&orderno=85&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_64_a_content:
  string
  line `^1[64A. Destruction, loss, etc., of ballot papers at the time of counting.—(1) If at any time before`
  line `the counting of votes is completed any ballot papers used at a polling station or at a place fixed for the`
  line `poll are unlawfully taken out of the custody of the returning officer or are accidentally or intentionally`
  line `destroyed or lost or are damaged or tampered with, to such an extent that the result of the poll at that`
  line `polling station or place cannot be ascertained, the returning officer shall forthwith report the matter to the`
  line `Election Commission.`
  line
  line `(2) Thereupon, the Election Commission shall, after taking all material circumstances into account,`
  line either—
  line
  line `(a) direct that the counting of votes shall be stopped, declare the poll at that polling station or`
  line `place to be void, appoint a day, and fix the hours, for taking a fresh poll at that polling station or place`
  line `and notify the date so appointed and hours so fixed in such manner as it may deem fit, or`
  line
  line `(b) if satisfied that the result of a fresh poll at that polling station or place will not, in any way,`
  line `affect the result of the election, issue such directions to the returning officer as it may deem proper for`
  line `the resumption and completion of the counting and for the further conduct and completion of the`
  line `election in relation to which the votes have been counted.`
  line
  line `(3) The provisions of this Act and of any rules or orders made thereunder shall apply to every such`
  line `fresh poll as they apply to the original poll.]`
obj_root_law_sections_65:
  sectionId (29576)
  sectionNo (65)
  orderNo 86
  title `Equality of votes.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29576&sectionno=65&orderno=86&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_65_content:
  string
  line `If, after the counting of the votes is completed, an equality of votes is found`
  line `to exist between any candidates, and the addition of one vote will entitle any of those candidates to be`
  line `declared elected, the returning officer shall forthwith decide between those candidates by lot, and proceed`
  line `as if the candidate on whom the lot falls had received an additional vote.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (29577)
  sectionNo (66)
  orderNo 87
  title `Declaration of results.`
  content obj_root_law_sections_66_content
  footnotes `1. Subs. by Act 47 of 1966, s. 35, for "shall forthwith declare" (w.e.f. 14-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29577&sectionno=66&orderno=87&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_66_content:
  string
  line `When the counting of the votes has been completed, the returning`
  line `officer ^1[shall, in the absence of any direction by the Election Commission to the contrary, forthwith`
  line `declare] the result of the election in the manner provided by this Act or the rules made thereunder.`
obj_root_law_sections_67:
  sectionId (29578)
  sectionNo (67)
  orderNo 88
  title `Report of the result.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29578&sectionno=67&orderno=88&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_67_content:
  string
  line `As soon as may be after the result of an election has been declared, the`
  line `returning officer shall report the result to the appropriate authority and the Election Commission, and in`
  line `the case of an election to a House of Parliament or of the Legislature of a State also to the Secretary of`
  line `that House, and the appropriate authority shall cause to be published in the Official Gazette the`
  line `declarations containing the names of the elected candidates.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_67_a:
  sectionId (29579)
  sectionNo 67A
  orderNo 89
  title `Date of election of candidate.`
  content `^1[67A. Date of election of candidate.—For the purposes of this Act, the date on which a candidate is declared by the returning officer under the provisions of section 53, ^2***, ^3***, or section 66, to be elected to a House of Parliament or of the Legislature of a State ^4*** shall be the date of election of that candidate.]`
  footnotes obj_root_law_sections_67_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29579&sectionno=67A&orderno=89&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_67_a_footnotes:
  string
  line `1. Ins. by Act 27 of 1956, s. 37 (w.e.f. 28-8-1956).`
  line
  line `2. The word and figures "section 54" omitted by Act 40 of 1961, s. 15 (w.e.f. 20-9-1961).`
  line
  line `3. The word, figures and letter "section 55A" omitted by Act 58 of 1958, s. 27 (w.e.f. 30-12-1958).`
  line
  line `4. Certain words omitted by Act 103 of 1956, s. 66 (w.e.f. 1-1-1957),`
obj_root_law_sections_68:
  sectionId (29580)
  sectionNo (68)
  orderNo 90
  title `Vacation of seats when elected to both Houses of Parliament.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29580&sectionno=68&orderno=90&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_68_content:
  string
  line `(1) Any person who is chosen`
  line `a member of both the Houses of the People and the Council of States and who has not taken his seat in`
  line `either House may, by notice in writing signed by him and delivered to the Secretary to the Election`
  line `Commission ^1[within ten days from the date, or the later of the dates, on which he is so chosen, intimate] in which of the Houses he wishes to serve, and thereupon, his seat in the House in which he does not wish`
  line `to serve shall become vacant.`
  line
  line `(2) In default of such intimation within the aforesaid period, his seat in the Council of States shall, at`
  line `the expiration of that period, become vacant.`
  line
  line `(3) Any intimation given under sub-section (1) shall be final and irrevocable.`
  line
  line `^2[(4) For the purposes of this section and of section 69, the date on which a person is chosen to be a`
  line `member of either House of Parliament shall be in the case of an elected member, the date of his election`
  line `and in the case of a nominated member, the date of first publication in the Gazette of India of his`
  line nomination.]
obj_root_law_sections_68_footnotes:
  string
  line `1. Subs. by Act 27 of 1956, s. 38, for certain words (w.e.f. 28-8-1956).`
  line
  line `2. Ins. by s. 38, ibid. (w.e.f. 28-8-1956).`
obj_root_law_sections_69:
  sectionId (29581)
  sectionNo (69)
  orderNo 91
  title `Vacation of seats by persons already members of one House on election to other House of Parliament.`
  content obj_root_law_sections_69_content
  footnotes `1. Subs. by s. 39, ibid., for certain words (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29581&sectionno=69&orderno=91&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_69_content:
  string
  line `(1) If a person who is already a member of the House of the People and has taken his`
  line `seat in such House is chosen a member of the Council of States, his seat in the House of the People shall,`
  line `^1[on the date on which he is so chosen], become vacant.`
  line
  line `(2) If a person who is already a member of the Council of States and has taken his seat in`
  line `such Council is chosen a member of the House of the People, his seat in the Council of States`
  line `shall, ^1[on the date on which he is so chosen], become vacant.`
obj_root_law_sections_70:
  sectionId (29582)
  sectionNo (70)
  orderNo 92
  title `Election to more than one seat in either House of Parliament or in the House or either House of the Legislature of a State.`
  content obj_root_law_sections_70_content
  footnotes `1. Ins. by Act 27 of 1956, s. 40 (w.e.f. 28-8-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29582&sectionno=70&orderno=92&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_70_content:
  string
  line `If a person is elected to more than one seat in either House of`
  line `Parliament or in the House or either House of the Legislature of a State, then, unless within the prescribed time he resigns all but one of the seats ^1[by writing under his hand addressed to the Speaker or Chairman,`
  line `as the case may be, or to such other authority or officer as may be prescribed], all the seats shall become`
  line vacant.
obj_root_law_sections_71:
  sectionId (29583)
  sectionNo (71)
  orderNo 93
  title `Publication of results of elections to the Council of States and of names of persons nominated by the President.`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29583&sectionno=71&orderno=93&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_71_content:
  string
  line `^1[71. Publication of results of elections to the Council of States and of names of persons nominated by the President.After the elections held in any year in pursuance of the notifications`
  line `issued under section 12, there shall be notified by the appropriate authority in the Official Gazette the`
  line `names of members elected by the elected members of the Legislative Assemblies of the States and by the`
  line `members of the electoral colleges for the various ^2[Union territories] at the said elections together with the`
  line `the name of any persons nominated by the President to the Council of States under sub-clause (a) of`
  line `clause (1) of article 80 or under any other provisions.`
obj_root_law_sections_71_footnotes:
  string
  line `1. Subs. by s. 41, ibid., for sections 71 to 75 (w.e.f. 28-8-1956).`
  line
  line `2. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part C States".`
obj_root_law_sections_72:
  sectionId (29584)
  sectionNo (72)
  orderNo 94
  title [Omitted.].
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29584&sectionno=72&orderno=94&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_72_content:
  string
  line `[Publication of results of elections for the reconstitution of electoral colleges for certain Union`
  line `territories.] Omitted by the Territorial Councils Act, 1956 (103 of 1956), s. 66 (w.e.f. 1-1-1957).`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (29585)
  sectionNo (73)
  orderNo 95
  title `Publication of results of general elections to the House of the People and the State Legislative Assemblies and of names of persons nominated thereto.`
  content obj_root_law_sections_73_content
  footnotes obj_root_law_sections_73_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29585&sectionno=73&orderno=95&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_73_content:
  string
  line `Where a general election is held for the purpose of constituting a new House of`
  line `the People or a new State Legislative Assembly, there shall be notified by ^1`
  line `[the Election Commission] in`
  line `the Official Gazette, as soon as may be after ^2[the results of the elections in all the constituencies] [other`
  line `than those in which the poll could not be taken for any reason on the date originally fixed under clause (d)`
  line `of section 30 or for which the time for completion of the election has been extended under the provisions`
  line `of section 153] have been declared by the returning officer under the provisions of section 53 or, as the`
  line `case may be, section 66, the names of the members elected for those constituencies] ^3`
  line `*** and upon the`
  line `issue of such notification that House or Assembly shall be deemed to be duly constituted:—`
  line
  line `Provided that the issue of such notification shall not be deemed—`
  line
  line `^4[(a) to preclude—`
  line
  line `(i) the taking of the poll and the completion of the election in any Parliamentary or Assembly`
  line `constituency or constituencies in which the poll could not be taken for any reason on the date`
  line `originally fixed under clause (d) of section 30; or`
  line
  line `(ii) the completion of the election in any Parliamentary or Assembly constituency or`
  line `constituencies for which time has been extended under the provisions of section 153; or]`
  line
  line `(b) to affect the duration of the House of the People or the State Legislative Assembly, if any,`
  line `functioning immediately before the issue of the said notification.`
obj_root_law_sections_73_footnotes:
  string
  line `1. Subs. by Act 40 of 1961, s. 16, for "the appropriate authority" (w.e.f. 20-9-1961).`
  line
  line `2. Subs. by Act 10 of 1967, s. 2, for certain words (w.e.f. 11-4-1967).`
  line
  line `3. Certain words omitted by Act 40 of 1961, s. 16 (w.e.f. 20-9-1961).`
  line
  line `4. Subs. by Act 10 of 1967, s. 2, for "clause (a)" (w.e.f. 11-4-1967).`
obj_root_law_sections_73_a:
  sectionId (29586)
  sectionNo 73A
  orderNo 96
  title `Special provisions as to certain elections.`
  content obj_root_law_sections_73_a_content
  footnotes `1. Subs. by Act 31 of 1991, s. 2, for sections 73A and 73AA (w.e.f. 18-4-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29586&sectionno=73A&orderno=96&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_73_a_content:
  string
  line `^1[73A. Special provision as to certain elections.--Notwithstanding anything contained in`
  line `section 73 or in any other provision of this Act, with respect to the general election for the purpose of`
  line `constituting a New House of the People upon dissolution of the Ninth House of the People,--`
  line
  line `(a) the notification under section 73 may be issued without taking into account the Parliamentary`
  line `constituencies in the State of Jammu and Kashmir; and`
  line
  line `(b) the Election Commission may take the steps in relation to elections from the Parliamentary`
  line `constituencies in the State of Jammu and Kashmir separately and in such manner and on such date or`
  line `dates as it may deem appropriate.]`
obj_root_law_sections_74:
  sectionId (29587)
  sectionNo (74)
  orderNo 97
  title `Publication of results of elections to the State Legislative Councils and of names of persons nominated to such Councils.`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_81_00001_195143_1517807327542&sectionId=29587&sectionno=74&orderno=97&orgactid=AC_CEN_3_81_00001_195143_1517807327542
obj_root_law_sections_74_content:
  string
  line `After the elections held ^1[in pursuance of the notifications issued under`
  line `section 15A or] in any year in pursuance of the notifications issued under section 16, there shall be`
  line `notified by the appropriate authority in the Official Gazette the names of the members elected for the`
  line `various Council constituencies and by the members or the Legislative Assembly of the State at the said`
  line `elections together with the names of any persons nominated by the Governor ^2*** under sub-clause (e) of`
  line `of clause (3) of article 171.]`
obj_root_law_sections_74_footnotes:
  string
