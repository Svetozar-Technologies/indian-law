obj_root_law_sections_1:
  sectionId (50823)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50823&sectionno=1&orderno=1&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Forensic Sciences`
  line `University Act, 2020.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint, and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st October, 2020, vide notification No. S.O. 3424(E), dated 30th August, 2020, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (50824)
  sectionNo (2)
  orderNo 2
  title `Declaration of National Forensic Sciences University as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50824&sectionno=2&orderno=2&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the National Forensic Sciences University are such as to make it`
  line `an institution of national importance, it is hereby declared that the National University of Forensic`
  line `Sciences is an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (50825)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50825&sectionno=3&orderno=3&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the University referred to in section 18;`
  line
  line `(b) "academic staff" means teachers and such categories of staff as are designated to be academic`
  line `staff by the Statutes;`
  line
  line `(c) "affiliated college" means an institution recognised as such by the Board of Governors in`
  line `accordance with the provisions of this Act and the Statutes made thereunder;`
  line
  line `(d) "Board of Governors" means the Board of Governors of the University referred to in section 15;`
  line
  line `(e) "campus" means the campus of the Gujarat Forensic Sciences University situated at`
  line `Gandhinagar, Gujarat, and that of the Lok Nayak Jayaprakash Narayan National Institute of`
  line `Criminology and Forensic Sciences situated at Rohini, New Delhi, or such other campus as may be`
  line `established by the University at any place within India or outside India;`
  line
  line `(f) "Chancellor" means the Chancellor of the University;`
  line
  line `(g) "college" means a college or institution maintained or admitted to the privileges of the`
  line `University for imparting education and training in forensic sciences or its related disciplines;`
  line
  line `(h) "Court" means the Court of the University referred to in section 14;`
  line
  line `(i) "Dean", in relation to any School campus, means the Dean of such School campus;`
  line
  line `(j) "department" means an academic department of the University;`
  line
  line `(k) "distance education system" means the system of imparting education through any means of`
  line `communication such as broadcasting, telecasting, internet, correspondence courses, seminars, contact`
  line `programmes or the combination of any two or more such means;`
  line
  line `(l) "employee" means any person appointed by the University and includes teachers, other`
  line `academic and non-academic staff of the University;`
  line
  line `(m) "Executive Registrar" means the Executive Registrar of the University referred to in`
  line `section 25;`
  line
  line `(n) "Finance Committee" means the Finance Committee of the University referred to in section 28;`
  line
  line `(o) "Fund" means the Fund of University referred to in section 35;`
  line
  line `(p) "notification" means a notification published in the Official Gazette;`
  line
  line `(q) "School" means a school of study of the University;`
  line
  line `(r) "Statutes" and "Ordinances" mean, respectively, the Statutes and Ordinances of the University`
  line `made under this Act;`
  line
  line `(s) "student" means a student of the University and its affiliated colleges, and includes any person`
  line `who has enrolled for pursuing any course of study in the University;`
  line
  line `(t) "teachers" means Directors, Deans, professors, associate professors, assistant professors and`
  line `such other persons as may be appointed for imparting instruction or conducting research or for giving`
  line `guidance for research or rendering assistance to students, in the University or in any college or`
  line `institution maintained by the University;`
  line
  line `(u) "University" means the National Forensic Sciences University established under this Act;`
  line
  line `(v) "Vice-Chancellor" means the Vice-Chancellor of the University referred to in section 21.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (50826)
  sectionNo (4)
  orderNo 4
  title `Establishment and incorporation of University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50826&sectionno=4&orderno=4&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_4_content:
  string
  line `(1) The Gujarat Forensic Sciences University,`
  line `Gandhinagar, Gujarat established under the Gujarat Forensic Sciences University Act, 2008 (Gujrat Act 17 of 2018), and the Lok Nayak Jayaprakash Narayan National Institute of Criminology and Forensic`
  line `Sciences, New Delhi shall be established as an University by the name of National Forensic Sciences`
  line University.
  line
  line `(2) The National Forensic Sciences University shall be a body corporate having perpetual succession`
  line `and a common seal with power, subject to the provisions of this Act, to acquire, hold and dispose of`
  line `property and to contract, and shall, by the said name, sue or be sued.`
  line
  line `(3) The headquarters of the University shall be at Gandhinagar, Gujarat.`
  line
  line `(4) The campuses of the University shall include the campuses situated at Gujarat Forensic Sciences`
  line `University, Gandhinagar, Gujarat and the Lok Nayak Jayaprakash Narayan National Institute of`
  line `Criminology and Forensic Sciences, New Delhi and such other campuses as the Central Government may,`
  line `by notification, specify.`
  line
  line `(5) The first Chancellor, Vice-Chancellor, Board of Governors, Academic Council, Directors, Deans,`
  line `Executive Registrar and all other persons who may hereafter become such officers or members, so long as`
  line `they continue to hold such office or membership, shall constitute the University.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (50827)
  sectionNo (5)
  orderNo 5
  title `Effect of incorporation of University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50827&sectionno=5&orderno=5&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_5_content:
  string
  line `On and from the commencement of this Act,--`
  line
  line `(a) any reference to the Gujarat Forensic Sciences University, Gandhinagar, Gujarat or the Lok`
  line `Nayak Jayaprakash Narayan National Institute of Criminology and Forensic Sciences, New Delhi in`
  line `any other law for the time being in force or in any contract or other instrument, shall be deemed as a`
  line `reference to the University;`
  line
  line `(b) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted or other things done under the provisions of the`
  line `Gujarat Forensic Sciences University Act, 2008, in so far as it relates to the Gujarat Forensic Sciences`
  line `University, Gandhinagar, shall be deemed to have been, respectively, made, issued, conferred,`
  line `awarded, granted or done under the corresponding provisions of this Act, and, except as otherwise`
  line `provided by or under this Act or the Statutes or Ordinances or regulations, continue in force unless`
  line `and until they are superseded by the Statutes or Ordinances made under this Act;`
  line
  line `(c) the status of "Centre of Excellence" and "Institute of Strategic or Security related Interest"`
  line `granted to the Gujarat Forensic Sciences University, Gandhinagar by the Government of Gujarat and`
  line `the status of "Center of Excellence for Narcotics Drugs and Psychotropic Substances" conferred by`
  line `the Ministry of Home Affairs, Government of India, to the Gujarat Forensic Sciences University,`
  line `Gandhinagar, shall be applicable to the University;`
  line
  line `(d) all properties, movable and immovable, of or belonging to the Gujarat Forensic Sciences`
  line `University, Gandhinagar, Gujarat or the Lok Nayak Jayaprakash Narayan National Institute of`
  line `Criminology and Forensic Sciences, New Delhi shall vest in the University;`
  line
  line `(e) all rights, debts and other liabilities of the Gujarat Forensic Sciences University, Gandhinagar,`
  line `Gujarat or the Lok Nayak Jayaprakash Narayan National Institute of Criminology and Forensic`
  line `Sciences, New Delhi shall be transferred to and be the rights, debts and liabilities of the University;`
  line
  line `(f) every person employed by the Gujarat Forensic Sciences University, Gandhinagar, Gujarat or`
  line `the Lok Nayak Jayaprakash Narayan National Institute of Criminology and Forensic Sciences, New`
  line `Delhi, immediately before such commencement, shall hold his office or service in the University by`
  line `the same tenure, at the same remuneration and upon the same terms and conditions and with the same`
  line `rights and privileges as to pension, leave, gratuity, provident fund, and other matters as he would have`
  line `held if this Act had not been passed, and shall continue to do so unless and until his employment is`
  line `terminated or until such tenure, remuneration and terms and conditions are duly altered by the`
  line `Statutes, not detrimental to the service conditions of such employee:`
  line
  line `Provided that any reference, by whatever form of words, to the Registrar and other officers of the`
  line `Gujarat Forensic Sciences University, Gandhinagar, Gujarat or the Lok Nayak Jayaprakash Narayan`
  line `National Institute of Criminology and Forensic Sciences, New Delhi, in any law for the time being in`
  line `force, or in any instrument or other document, shall be deemed to be reference to the Executive`
  line `Registrar and other officers of the University;`
  line
  line `(g) any activity for appointment or promotion of academic or non-academic staff underway in the`
  line `Gujarat Forensic Sciences University, Gandhinagar at the time of commencement of this Act shall be`
  line `deemed to be valid, and further proceeding in such appointment or promotion shall be taken in`
  line `accordance with the provisions of this Act and be continued from the stage at the time of`
  line `commencement of this Act;`
  line
  line `(h) every person pursuing, before the commencement of this Act, any academic or research`
  line `course or programmes of study in the Gujarat Forensic Sciences University, Gandhinagar, shall be`
  line `deemed to have migrated and registered with the University, on such commencement, at the same`
  line `level of course or programme and shall continue to pursue such academic or research course and`
  line `programmes of study in the University;`
  line
  line `(i) every person pursuing, before the commencement of this Act, any academic or research course`
  line `in the Lok Nayak Jayaprakash Narayan National Institute of Criminology and Forensic Sciences,`
  line `New Delhi, shall continue to pursue their academic courses and programmes of study under the`
  line `enrolment and affiliation of the Guru Gobind Singh Indraprastha University, Delhi which shall`
  line `conduct examinations and award degrees to them upon successful completion of such courses and`
  line `programmes of study;`
  line
  line `(j) all suits and other legal proceedings instituted or which could have been instituted by or`
  line `against the Gujarat Forensic Sciences University, Gandhinagar or the Lok Nayak Jayaprakash`
  line `Narayan National Institute of Criminology and Forensic Sciences, New Delhi, immediately before the`
  line `commencement of this Act, shall be continued or instituted by or against the University.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (50828)
  sectionNo (6)
  orderNo 6
  title `Objects of University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50828&sectionno=6&orderno=6&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_6_content:
  string
  line `The objects of the University shall be--`
  line
  line `(i) to facilitate and promote academic learning and practices in the field of forensic science in`
  line `conjunction with applied behavioural science studies, law, legal studies, criminology and other allied`
  line `areas and technology, including training, skill-development, research and extension of work with`
  line `focus on emerging areas in the said fields for strengthening criminal justice institutions in the country;`
  line
  line `(ii) to foster research and applied applications in forensic science, applied behavioural science`
  line `studies, law, legal studies and other allied areas and technology for training, research and`
  line `development by promoting innovations and best practices;`
  line
  line `(iii) to promote and provide advanced institutional and research facilities in the fields of forensic`
  line `science, applied behavioural science, law, legal studies and other allied areas and technology;`
  line
  line `(iv) to create capacities and capabilities of global standards of education, training and research for`
  line `development of aptitude, skills and knowledge within and outside the country at various levels in the`
  line `fields of forensic science, applied behavioural science, law, legal studies and other allied areas and`
  line technology;
  line
  line `(v) to coordinate with the Central Government and State Governments to improve investigation,`
  line `crime detection and prevention through projects and research, funded by grants-in-aid from the`
  line `Central Government and State Governments, in fields of forensic science, applied behavioural`
  line `science, law, legal studies, criminology and other allied areas and technology;`
  line
  line `(vi) to advice and assist the Central Government, State Governments and Union territory`
  line `Administrations in formulation of relevant policies including their review in the fields of forensic`
  line `science, applied behavioural science, law, legal studies, criminology and other allied areas and`
  line technology;
  line
  line `(vii) to coordinate and network with the institutions having specialisation so as to expand the`
  line `fields of forensic science, applied behavioural science, law, legal studies, criminology and other allied`
  line `areas and technology, for promoting academics and research work through various pursuits;`
  line
  line `(viii) to administer, maintain and manage the University and to establish such off-site campus and`
  line `off-shore centres for education, training and research as are necessary for the furtherance of the`
  line `objects of the University within and outside the country;`
  line
  line `(ix) to assist the Central Government or State Governments to accredit forensic science`
  line `laboratories, provide standard operating procedures, and lay down specifications for forensic`
  line `equipment and kits to be used for forensic work in the country;`
  line
  line `(x) to set-up campus, colleges, schools, centres and institutions of excellence for imparting State`
  line `of-the-art education, training and research in the fields of forensic science, cyber security and digital`
  line `forensics, behavioural science, technology and management;`
  line
  line `(xi) to assist the Central Government to create and maintain national forensic data base required`
  line `for criminal investigation, including fingerprints, voice, Deoxyribonucleic Acid (DNA), firearms,`
  line `counterfeit currency, narcotic drugs and psychotropic substances, cyber security, cyber defence and`
  line `internal security;`
  line
  line `(xii) to undertake special projects for Central Government and State Governments; and`
  line
  line `(xiii) to undertake any other objects, not inconsistent with the provisions of this Act which the`
  line `Central Government may, by notification, specify in this behalf.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (50829)
  sectionNo (7)
  orderNo 7
  title `Powers and functions of University.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50829&sectionno=7&orderno=7&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of this Act, the`
  line `University shall exercise the following powers and perform the following functions, namely:--`
  line
  line `(a) to provide for studies, training, skill-development, research and extension of work in forensic`
  line `science, applied behavioural science, law, legal studies, criminology and other allied areas and`
  line `technology with focus on emerging areas of forensic science studies and related technologies;`
  line
  line `(b) to establish and maintain campuses, colleges, institutions, schools, departments, laboratories,`
  line `libraries, centres of research, training, skill-development, research and specialised studies within and`
  line `outside the country;`
  line
  line `(c) to plan and prescribe courses of study or skill-development, such as degrees, diplomas, and`
  line certificates;
  line
  line `(d) to hold examinations and grant degrees, diplomas, certificates and other academic`
  line distinctions;
  line
  line `(e) to confer honorary degrees or other distinctions;`
  line
  line `(f) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, of evaluation or any other method of testing, and to withdraw any such diplomas, certificates,`
  line `degrees or other academic distinction for good and sufficient cause;`
  line
  line `(g) to provide facilities through the distance education system to such persons as it may`
  line determine;
  line
  line `(h) to introduce semester system, continuous evaluation and choice-based credit system and enter`
  line `into agreements with other Universities and academic institutions for credit transfer and joint degree`
  line programmes;
  line
  line `(i) to make provisions for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions or bodies, national or international, as the University may deem`
  line necessary;
  line
  line `(j) to receive grants-in-aid to undertake projects for research and special assignments for the`
  line `Central Government and State Governments;`
  line
  line `(k) to determine, specify and receive payment of fees and other charges as the University may`
  line `deem fit, from students and any other person, institution or body corporate for instruction and other`
  line `services, including training, consultancy and advisory services, provided by the University;`
  line
  line `(l) to establish, maintain and manage University buildings, halls, hostels and other campuses for the`
  line `University in any other place;`
  line
  line `(m) to affiliate colleges and institutions of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(n) to supervise and control the residence and regulate the discipline of students of the University`
  line `and to make arrangements for promoting their health, general welfare, cultural and corporate life;`
  line
  line `(o) to create academic and other teaching posts and to make appointments thereto (except the`
  line `posts of Chancellor and Vice-Chancellor) as may be necessary for imparting instruction and`
  line `managing the affairs of the University;`
  line
  line `(p) to appoint on contract or otherwise visiting professors, emeritus professors, consultants,`
  line `scholars including those located outside the country, and such other persons who may contribute to`
  line `the advancement of the University;`
  line
  line `(q) to create non-teaching, administrative, ministerial and other posts in the University and to`
  line `make appointment thereto;`
  line
  line `(r) to cooperate, collaborate or partner or associate with educational or other institutions and`
  line `organisations, public and private, including those located outside the country having objects wholly or`
  line `partly similar to those of the University by exchange of teachers and scholars and generally in such`
  line `manner as may be conducive to their common objects;`
  line
  line `(s) to institute and award fellowships, scholarships, exhibitions, prizes and medals;`
  line
  line `(t) to provide for the preparation of instructional material including related software and other`
  line `audio-visual aids;`
  line
  line `(u) to sponsor and make provision for research and development in areas of core competence of`
  line `the University;`
  line
  line `(v) to enter into, carry out, vary or cancel contracts;`
  line
  line `(w) to demand and receive such fees and other charges as may be specified by Ordinances;`
  line
  line `(x) to receive benefactions, donations and gifts from persons and to name after them such chairs,`
  line `institutions, buildings and the like, as the University may determine, whose gift and donations to the`
  line `University is worth such as the University may decide;`
  line
  line `(y) to acquire, hold, manage and dispose of any property, movable or immovable, including trust`
  line `and endowment properties for the purposes of the University;`
  line
  line `(z) to initiate measures to enlist the cooperation of the industry to provide complementary`
  line facilities;
  line
  line `(za) to establish off-shore campus at any place outside the country as and when it is considered`
  line `necessary for advancing the aims and objectives of the University;`
  line
  line `(zb) to provide for printing, reproduction and publication of research and other work;`
  line
  line `(zc) to provide, control and maintain discipline among the students and all categories of`
  line `employees and to lay down the conditions of service of such employees, including their code of`
  line conduct;
  line
  line `(zd) to conduct innovative experiments and develop new methods and technologies in the field of`
  line `science, technology and management in relation to the domains of investigation, prevention and detection of crimes and furthering the cause of criminal justice systems in order to achieve`
  line `international standards of such education, training research and consultancy;`
  line
  line `(ze) to admit students for courses in Institute and its affiliated centres and institutes on an all India`
  line `basis in such manner as may be laid down in the Statutes;`
  line
  line `(zf) to admit foreign students, Overseas Citizen of India card holder, Person of Indian Origin,`
  line `non-resident Indian, children of Indian workers in Gulf and South-East Asian Countries, in such`
  line `manner and as may be laid down in the Statutes;`
  line
  line `(zg) to purchase or to take on lease any land or building or works which may be necessary or`
  line `convenient for the purpose of the University on such terms and conditions as it may think fit and`
  line `proper and to construct, alter and maintain any such buildings or works;`
  line
  line `(zh) to raise and borrow moneys on bonds, mortgages, promissory notes or other obligations or`
  line `securities founded or based upon all or any of the properties and assets of the University or without`
  line `any securities and upon such terms and conditions as it may think fit and to pay out of the funds of the`
  line `University, all expenses incidental to the raising of moneys, to repay and redeem any money`
  line `borrowed after taking prior permission of the Board of Governors;`
  line
  line `(zi) to invest the funds of the University in or upon such securities and transpose any investment`
  line `from time to time in such manner as it may deem fit in the interest of University; and`
  line
  line `(zj) to do all such things as may be necessary, incidental or conducive to the attainment of all or`
  line `any of the objects of the University.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the University shall not dispose of in`
  line `any manner any immovable property without the prior approval of the Central Government.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (50830)
  sectionNo (8)
  orderNo 8
  title `Jurisdiction of University.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50830&sectionno=8&orderno=8&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_8_content:
  string
  line `The jurisdiction of the University shall extend to the whole of`
  line India.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (50831)
  sectionNo (9)
  orderNo 9
  title `University to be open to all races, creeds and classes.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50831&sectionno=9&orderno=9&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_9_content:
  string
  line `(1) The University shall be open to`
  line `all persons irrespective of gender, race, caste, creed, disability, domicile, ethnicity, social or economic`
  line background.
  line
  line `(2) No bequest, donation or transfer of any property shall be accepted by the University which in`
  line `the opinion of the Board of Governors involves conditions or obligations opposed to the spirit and`
  line `object of this section.`
  line
  line `(3) Admissions to every academic programme of study in the University shall be based on merit`
  line `assessed through transparent and reasonable criteria disclosed prior to the commencement of the`
  line `process of admission by the University:`
  line
  line `Provided that the University shall be a Central Educational Institution for the purposes of the`
  line `Central Educational Institutions (Reservation in Admission) Act, 2006 (5 of 2007).`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (50832)
  sectionNo (10)
  orderNo 10
  title `Admission of students.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50832&sectionno=10&orderno=10&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_10_content:
  string
  line `(1) It shall be the endeavor of the University to maintain an all-India`
  line `character, and high standards of teaching and research.`
  line
  line `(2) Admission of students for courses in University shall be made on an all-India basis in such`
  line `manner as may be specified in the Ordinances.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (50833)
  sectionNo (11)
  orderNo 11
  title `Teaching at University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50833&sectionno=11&orderno=11&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_11_content:
  string
  line `All teaching at the University and its campuses or affiliated colleges`
  line `shall be conducted by and in the name of the University in accordance with the Statutes and Ordinances`
  line `made in this behalf.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (50834)
  sectionNo (12)
  orderNo 12
  title `Authorities of University.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50834&sectionno=12&orderno=12&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_12_content:
  string
  line `The following shall be the authorities of the University, namely:--`
  line
  line `(a) Chancellor;`
  line
  line `(b) Court;`
  line
  line `(c) Board of Governors;`
  line
  line `(d) Academic Council;`
  line
  line `(e) Board for Affiliation and Recognition;`
  line
  line `(f) Finance Committee; and`
  line
  line `(g) such other authorities as may laid down in the Statutes to be the authorities of the University.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (50835)
  sectionNo (13)
  orderNo 13
  title Chancellor.
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50835&sectionno=13&orderno=13&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_13_content:
  string
  line `(1) The Central Government may, by notification, appoint a person of eminence as`
  line `the Chancellor of the University in consultation with such State Governments as it deems fit.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the Head of the University and shall preside at`
  line `the convocations of the University held for conferring degrees.`
  line
  line `(3) The Chancellor may invite any person or persons of eminence to advise the University in`
  line `relation to the affairs of the University as and when necessary.`
  line
  line `(4) Notwithstanding anything contained in this Act, the Chancellor may order or undertake an`
  line `inspection or inquiry, if he deems it necessary.`
  line
  line `(5) The Chancellor shall have such other powers as may be laid down in the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (50836)
  sectionNo (14)
  orderNo 14
  title Court.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50836&sectionno=14&orderno=14&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_14_content:
  string
  line `(1) The Central Government shall, by notification, constitute a Court for the University to`
  line `be headed by the Chancellor.`
  line
  line `(2) The members of the Court shall be nominated by the Central Government, in consultation with`
  line `such State Governments as it deems fit, from amongst persons of eminence, including from the fields of`
  line `forensics, bio-technology, criminal justice, law enforcement, technology and academia.`
  line
  line `(3) The term of office of members of the Court shall be such as may be laid down in the Statutes.`
  line
  line `(4) The Vice-Chancellor shall be the convenor of the Court.`
  line
  line `(5) Subject to the provisions of this Act, the Court shall have the following powers and perform the`
  line `following functions, namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University, and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the University`
  line `and the audit report on such accounts; and`
  line
  line `(c) to perform such other functions as may be laid down in the Statutes.`
  line
  line `(6) The Court shall meet at least once in a year.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (50837)
  sectionNo (15)
  orderNo 15
  title `Board of Governors.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50837&sectionno=15&orderno=15&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_15_content:
  string
  line `(1) The Board of Governors of the University shall consist of the`
  line `following members, namely:--`
  line
  line `(a) Vice-Chancellor--Chairperson,ex officio;`
  line
  line `(b) Financial Adviser, Ministry of Home Affairs, Government of India--member, ex officio;`
  line
  line `(c) one representative of the Ministry of Home Affairs in the Government of India not below the`
  line `rank of Joint Secretary--member, ex officio;`
  line
  line `(d) an officer of the Home Department, not below the rank of the Secretary to the Government of`
  line `Gujarat--member, ex officio;`
  line
  line `(e) Registrar General of the High Court of Gujarat--member, ex officio;`
  line
  line `(f) Director-cum-Chief Forensic Scientist, Director of Forensic Science Services, Ministry of`
  line `Home Affairs, Government of India--member,ex officio;`
  line
  line `(g) five persons of eminence selected from the fields of forensic science, law, enforcement,`
  line `criminology, computer science, engineering, technology, management, forensic medicine and`
  line `pharmacy, to be nominated by the Central Government, in consultation with such State Governments`
  line `as it deems fit--members;`
  line
  line `(h) all Campus Directors of the University--members, ex officio.`
  line
  line `(2) The Executive Registrar shall be the Secretary of the Board.`
  line
  line `(3) The Chairperson shall exercise such other powers and perform such other functions as may be`
  line `assigned to him by or under this Act or the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (50838)
  sectionNo (16)
  orderNo 16
  title `Powers of Board of Governors.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50838&sectionno=16&orderno=16&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_16_content:
  string
  line `(1) Subject to the provisions of this Act, the Board of`
  line `Governors shall be responsible for the general superintendence, direction and the control of affairs of the`
  line `University and shall exercise all the powers of the University not otherwise provided by this Act, Statutes or Ordinances and shall have the power to review the acts of the Academic Council and the Finance`
  line `Committee and other committees or authorities of the University.`
  line
  line `(i) take decisions on question of policy relating to the administration and working of the`
  line University;
  line
  line `(ii) institute courses of study in the University;`
  line
  line `(iii) make Statutes;`
  line
  line `(iv) modify or cancel Statutes;`
  line
  line `(v) create posts and appoint persons to academic as well as other posts in the University and`
  line `determine salary structure and the terms and conditions of different cadres of employees;`
  line
  line `(vi) consider and pass resolutions on the annual report, annual accounts and the budget estimates of`
  line `the University for every financial year;`
  line
  line `(vii) invest money and funds of the University and to take decision on the recommendations of the`
  line `Finance Committee;`
  line
  line `(viii) publish or finance the publication of studies, treaties, books, periodicals, reports and other`
  line `literature from time to time and to sell or arrange for the sale as it may deem fit;`
  line
  line `(ix) appoint such committees as it considers necessary for the exercise of its powers and`
  line `performance of its duties under this Act;`
  line
  line `(x) appoint Campus Directors;`
  line
  line `(xi) consider and approve the proposals recommended by the Board for Affiliation and`
  line Recognition;
  line
  line `(xii) delegate any of its power to the Directors, Deans, Executive Registrar or any other officer,`
  line `employee or to any authority of the University or to a committee appointed by it; and`
  line
  line `(xiii) exercise such other powers and perform such other functions as may be conferred or imposed`
  line `upon it by or under this Act or the Statutes or Ordinances made thereunder for achieving the objects of`
  line `the University.`
  line
  line `(3) The Board of Governors shall meet at least two times in a year and the presence of at least six`
  line `members shall form the quorum for a meeting of the Board of Governors.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (50839)
  sectionNo (17)
  orderNo 17
  title `Terms of office of members of Board of Governors.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50839&sectionno=17&orderno=17&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_17_content:
  string
  line `(1) Save as otherwise provided in this`
  line `section, the term of a nominated member of the Board of Governors under clause (g) of sub-section (1) of`
  line `section 15 shall be three years from the date of his nomination.`
  line
  line `(2) A nominated member of the Board of Governors shall be eligible for re-nomination for the next`
  line term.
  line
  line `(3) A nominated member of the Board of Governors may resign from his office by writing under his`
  line `hand addressed to the Chairperson and his resignation shall take effect from the date it is accepted by the`
  line Chairperson.
  line
  line `(4) The term of office of an ex officio`
  line `member of the Board of Governors shall continue so long as he`
  line `holds the office by the virtue of which he is a member.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (50840)
  sectionNo (18)
  orderNo 18
  title `Academic Council.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50840&sectionno=18&orderno=18&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_18_content:
  string
  line `(1) The Academic Council of the University shall consist of the following`
  line `members, namely:--`
  line
  line `(i) Vice-Chancellor--Chairperson, ex officio;`
  line
  line `(ii) two academicians or professionals to be nominated by the Board of Governors --members;`
  line
  line `(iii) two academicians or professionals in the field of forensic science to be nominated by the Board`
  line `of Governors--members;`
  line
  line `(iv) Director-cum-Chief Forensic Scientist, Directorate of Forensic Science Services, Ministry of`
  line `Home Affairs, Government of India--member, ex officio;`
  line
  line `(v) Campus Directors--members, ex officio;`
  line
  line `(vi) one Dean or professor or associate professor from each discipline of the School, by rotation, to`
  line `be nominated by the Vice-Chancellor--members, ex officio;`
  line
  line `(vii) two representatives of industry or industry bodies in related sectors to be nominated by the`
  line `Board of Governors--members.`
  line
  line `(2) The Executive Registrar shall be the Secretary of the Council.`
  line
  line `(3) The term of office of the members nominated under clauses (ii), (iii), (vi) and (vii) of`
  line `sub-section (1) shall be three years, and the members shall be eligible for re-nomination for the next term.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (50841)
  sectionNo (19)
  orderNo 19
  title `Powers of Academic Council.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50841&sectionno=19&orderno=19&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_19_content:
  string
  line `Subject to the provisions of this Act and the Statutes made`
  line `thereunder, the Academic Council of the University shall exercise the following powers and perform`
  line `following functions, namely:--`
  line
  line `(i) to specify the academic policies of the University and be responsible for the maintenance and`
  line `improvement of standards of instruction, education and evaluation in the University;`
  line
  line `(ii) to consider matters of general academic interest either on its own initiative or on a reference`
  line `from the faculty of the University or the Board of Governors and to take appropriate action thereof;`
  line
  line `(iii) to review and recommend to the Board of Governors regarding proposals received from the`
  line `Board for Affiliation and Recognition;`
  line
  line `(iv) to make Ordinances;`
  line
  line `(v) to recommend to the Board of Governors, to make such Statutes as are consistent with this Act`
  line `regarding the academic functioning of the Institute including discipline of students; and`
  line
  line `(vi) to exercise such other powers and perform such other functions as may be conferred or`
  line `imposed upon it by the Statutes or Ordinances.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (50842)
  sectionNo (20)
  orderNo 20
  title `Officers of University.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50842&sectionno=20&orderno=20&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_20_content:
  string
  line `The following shall be the officers of the University, namely:--`
  line
  line `(a) Vice-Chancellor;`
  line
  line `(b) Campus Directors;`
  line
  line `(c) Deans;`
  line
  line `(d) Executive Registrar; and`
  line
  line `(e) such other persons in the service of the University as may be laid down in the Statutes, to be`
  line `the officers of the University.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (50843)
  sectionNo (21)
  orderNo 21
  title `Vice Chancellor.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50843&sectionno=21&orderno=21&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_21_content:
  string
  line `(1) The Central Government may, in consultation with such State`
  line `Governments as it deems fit, by notification, appoint the Vice-Chancellor of the University.`
  line
  line `(2) A person shall be qualified to be appointed as the Vice-Chancellor of the University, if he is--`
  line
  line `(i) a person of eminence in the field of forensic sciences;`
  line
  line `(ii) associated in administration of criminal justice, development matters, education, philanthropy,`
  line `industrial or business development or exemplary administration in the central services, State services,`
  line `corporations or public bodies at national and international levels.`
  line
  line `(3) The Vice-Chancellor shall hold office for a period of three years and shall be eligible for`
  line `reappointment for another term or till he attains the age of seventy years.`
  line
  line `(4) The other terms and conditions of the Vice-Chancellor shall be such as may be laid down in the`
  line Statutes.
  line
  line `(5) The Vice-Chancellor may resign from his office by writing under his hand addressed to the`
  line `Chancellor and such a resignation shall take effect from the date of acceptance by the Chancellor.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (50844)
  sectionNo (22)
  orderNo 22
  title `Powers of Vice Chancellor.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50844&sectionno=22&orderno=22&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_22_content:
  string
  line `(1) The Vice-Chancellor shall have, subject to the provisions of`
  line `this Act, power to cause an inspection or review to be made by such person or persons as he may direct,`
  line `of the University, its buildings, hostels, libraries, equipment and systems and processes and of any`
  line `institution or centre maintained by the University, and also of the examinations, teaching, research and`
  line `other works conducted or done by the University and to cause an inquiry to be made in like manner in`
  line `respect of any matter connected with the administration, academic affairs and finance of the University.`
  line
  line `(2) Without prejudice to the generality of the foregoing provisions, the Vice-Chancellor shall--`
  line
  line `(i) preside at the meetings of the Board of Governors, Academic Council, Board for Affiliation and`
  line `Recognition and Finance Committee;`
  line
  line `(ii) be the principal academic and executive officer of the University and shall exercise general`
  line `supervision and control over the affairs of the University and give effect to the decisions of all the`
  line `authorities of the University;`
  line
  line `(iii) be responsible for imparting of instructions and maintenance of discipline in the University;`
  line
  line `(iv) submit annual reports and accounts to the Board of Governors;`
  line
  line `(v) ensure that decisions taken by the Board of Governors are implemented;`
  line
  line `(vi) have the power to delegate some of his powers to any of his subordinates under intimation to`
  line `the Board of Governors;`
  line
  line `(vii) nominate a Director of the University to perform his functions during the period of his leave;`
  line
  line `(viii) have all financial powers of the Secretary to the Government of India for the purposes of rules`
  line `of the Government, in so far as they are applicable or may be made applicable to the conduct of the`
  line `business of the University, subject to the additional power that may be delegated by the Board of`
  line `Governors from time to time;`
  line
  line `(ix) exercise such other powers and perform such other duties as may be assigned to him by or`
  line `under this Act or the Statutes or Ordinances or as may be delegated to him by the Board of Governors.`
  line
  line `(3) If the post of the Vice-Chancellor remains vacant for any reason, it shall be open to the Chancellor`
  line `to authorise a senior regular professor in the service of the University or any other appropriate person`
  line `possessing the qualification provided under sub-section (2) of section 21 to exercise such powers,`
  line `functions and duties of the Vice-Chancellor during such vacancy.`
  line
  line `(4) Where any matter is of urgent nature requiring immediate action and the same cannot be`
  line `immediately dealt with by the authority or body of the University empowered under this Act to deal with`
  line `it, the Vice-Chancellor may take such action as he may deem fit and shall forthwith report the action so`
  line `taken by him to the authority or body of the University who or which, in the ordinary course, would have`
  line `dealt with the matter:`
  line
  line `Provided that if such authority or other body is of the opinion that such action ought not to have been`
  line `taken by the Vice-Chancellor, it may refer the matter to the Board of Governors which may either confirm`
  line `the action taken by the Vice-Chancellor or annul the same or modify it in such manner as it thinks fit, and`
  line `thereupon the action shall cease to have effect or, as the case may be, shall take effect in such modified`
  line `form, and such modification or annulment shall be without prejudice to the validity of anything`
  line `previously done by or under the order of the Vice-Chancellor.`
  line
  line `(5) Where the exercise of the power by the Vice-Chancellor under sub-section (4) involves the`
  line `appointment of any person, such appointment shall be confirmed by the competent authority in the`
  line `University empowered to approve such appointment in accordance with the provisions of this Act and the`
  line `Statutes made thereunder, within a period of one year from the date of order of the Vice-Chancellor, otherwise such appointment shall cease to have effect on the expiration of a period of one year from the`
  line `date of order of the Vice-Chancellor.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (50845)
  sectionNo (23)
  orderNo 23
  title `Campus Directors.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50845&sectionno=23&orderno=23&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_23_content:
  string
  line `(1) The Campus Directors of the University shall be appointed by the`
  line `Vice-Chancellor with the approval of the Board of Governors in such manner and on such terms and`
  line `conditions as may be laid down in the Statutes.`
  line
  line `(2) The Campus Directors shall assist the Vice-Chancellor in managing the academic, administrative`
  line `and other affairs of the campus of University, and shall exercise such powers and perform such functions`
  line `as may be laid down in the Statutes or entrusted to them by the Vice-Chancellor.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (50846)
  sectionNo (24)
  orderNo 24
  title Dean.
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50846&sectionno=24&orderno=24&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_24_content:
  string
  line `(1) The Deans of each School of the University shall be appointed by the Vice-Chancellor on such terms and conditions as may be laid down in the Statutes.`
  line
  line `(2) The Deans shall assist the Vice-Chancellor, Executive Registrar and respective Campus Directors`
  line `in managing the academic and other affairs of the Schools of the University and shall exercise such`
  line `powers and perform such functions as may be laid down in the Statutes or entrusted to them by the`
  line Vice-Chancellor.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (50847)
  sectionNo (25)
  orderNo 25
  title `Executive Registrar.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50847&sectionno=25&orderno=25&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_25_content:
  string
  line `(1) The Executive Registrar shall be appointed by the University in such`
  line `manner and on such terms and conditions as may be laid down in the Statutes.`
  line
  line `(2) The Executive Registrar shall exercise the following powers and perform the following duties,`
  line `namely:--`
  line
  line `(i) be responsible for the custody of records, common seal, the funds and properties of the`
  line University;
  line
  line `(ii) place before the Board of Governors and other authorities of the University all such information`
  line `and documents as may be necessary for transaction of its business;`
  line
  line `(iii) be responsible to the Vice-Chancellor for the proper discharge of his functions;`
  line
  line `(iv) be responsible for the administration of the University and conduct the examinations and make`
  line `all other arrangements necessary thereof and be responsible for the execution of all processes`
  line `connected therewith;`
  line
  line `(v) attest and execute all documents on behalf of the University;`
  line
  line `(vi) verify and sign the pleadings in all suits and other legal proceedings by or against the`
  line `University and all processes in such suits and proceedings shall be issued to and served on the`
  line `Executive Registrar;`
  line
  line `(vii) act as the Secretary of the Board of Governors, the Academic Council, the Finance Committee`
  line `and such committees as may be specified by the Board of Governors; and`
  line
  line `(viii) exercise such other powers and perform such other duties as may be laid down in the Statutes`
  line `or as may be delegated to him by the Board of Governors or the Vice-Chancellor.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (50848)
  sectionNo (26)
  orderNo 26
  title `Finance Officer.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50848&sectionno=26&orderno=26&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_26_content:
  string
  line `The Finance Officer shall be appointed by the University in such manner, on`
  line `such emoluments and on such other terms and conditions of service and shall exercise such powers and`
  line `perform such duties as may be laid down in the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (50849)
  sectionNo (27)
  orderNo 27
  title `Other officers.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50849&sectionno=27&orderno=27&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_27_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be such as may be laid down in the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (50850)
  sectionNo (28)
  orderNo 28
  title `Finance Committee.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50850&sectionno=28&orderno=28&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_28_content:
  string
  line `(1) The Finance Committee shall consist of the following members,`
  line `namely:--`
  line
  line `(a) Vice-Chancellor, who shall be the Chairperson of the Committee;`
  line
  line `(b) two members of the Board of Governors, of which one shall be ex officio`
  line `member to be`
  line `nominated by the Board of Governors;`
  line
  line `(c) all Campus Directors;`
  line
  line `(d) one expert in the field of finance to be nominated by the Board of Governors;`
  line
  line `(e) Dean of any one School of the University, in rotation, as may be nominated by the Board of`
  line Governors.
  line
  line `(2) The Executive Registrar shall be the Secretary of the Finance Committee.`
  line
  line `(3) The term of office of the members nominated under clauses (b), (d) and (e) shall be three years`
  line `and the said members shall be eligible for renomination.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (50851)
  sectionNo (29)
  orderNo 29
  title `Powers of Finance Committee.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50851&sectionno=29&orderno=29&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_29_content:
  string
  line `Save as otherwise provided in this Act, the Finance`
  line `Committee shall exercise the following powers and perform the following functions, namely:--`
  line
  line `(a) to examine the annual accounts and annual budget estimates of the University and to advise the`
  line `Board of Governors thereof;`
  line
  line `(b) to review from time to time the financial position of the University;`
  line
  line `(c) to make recommendations to the Board of Governors on all financial policy matters of the`
  line University;
  line
  line `(d) to make recommendations to the Board of Governors on all proposals involving raising of`
  line `funds, receipts and expenditure;`
  line
  line `(e) to provide guidelines for investment of surplus funds;`
  line
  line `(f) to make recommendations to the Board of Governors on all proposals involving expenditure for`
  line `which no provision has been made in the budget or for which expenditure in excess of the amount`
  line `provided in the budget needs to be incurred;`
  line
  line `(g) to examine all proposals relating to the revision of pay scales, upgradation of the pay scales and`
  line `those items which are not included in the budget prior to placing before the Board of Governors; and`
  line
  line `(h) to exercise such other powers and perform such other functions as may be conferred or imposed`
  line `upon it by this Act or the Statutes or Ordinances made thereunder.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (50852)
  sectionNo (30)
  orderNo 30
  title `Board for Affiliation and Recognition.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50852&sectionno=30&orderno=30&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_30_content:
  string
  line `(1) The Board for Affiliation and Recognition shall be`
  line `responsible for admitting colleges and institutions to the privileges of the University.`
  line
  line `(2) The constitution of the Board for Affiliation and Recognition, the term of office of its members`
  line `and its powers and functions shall be such as may be laid down in the Statutes.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (50853)
  sectionNo (31)
  orderNo 31
  title `Other officers of University.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50853&sectionno=31&orderno=31&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_31_content:
  string
  line `The Board of Governors may, by Statutes, declare such other`
  line `authorities or officers of the University and specify the powers, functions and duties of each such`
  line `authority or officer, as the case may be.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (50854)
  sectionNo (32)
  orderNo 32
  title `Grants by Central Government.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50854&sectionno=32&orderno=32&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_32_content:
  string
  line `For the purpose of enabling the University to discharge its`
  line `functions efficiently under this Act, the Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the University, in each financial year, such sums of money in such`
  line `manner as it may deem fit.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (50855)
  sectionNo (33)
  orderNo 33
  title `Grants by State Governments.`
  content `The University may receive such sums of money as grants-inaid annually or as one-time grant from any State Government.`
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50855&sectionno=33&orderno=33&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (50856)
  sectionNo (34)
  orderNo 34
  title `Corpus of University.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50856&sectionno=34&orderno=34&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_34_content:
  string
  line `The University may receive funds from the Central Government or State`
  line `Governments or other sources or use its funds to maintain and operate a corpus of the University.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (50857)
  sectionNo (35)
  orderNo 35
  title Fund.
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50857&sectionno=35&orderno=35&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_35_content:
  string
  line `(1) The University shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government;`
  line
  line `(b) all moneys received from State Governments;`
  line
  line `(c) all fees and other charges received by the University;`
  line
  line `(d) all moneys received by the University by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers;`
  line
  line `(e) all interest from corpus, or any other such earnings;`
  line
  line `(f) any loans taken by the University;`
  line
  line `(g) the moneys received by the University from the collaborating industries in terms of the`
  line `provisions of the Memorandum of Understanding entered between the University and such industry`
  line `for establishment of sponsored chairs, fellowships or infrastructure facilities of the University; and`
  line
  line `(h) all moneys received by the University in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund of the University shall be deposited in such banks or invested in`
  line `such manner as the University may, with the approval of the Finance Committee, decide.`
  line
  line `(3) The Fund of the University shall be applied towards the expenses of the University including`
  line `expenditure incurred in the exercise of its powers and discharge of its functions by or under this Act.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (50858)
  sectionNo (36)
  orderNo 36
  title `Accounts and audit.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50858&sectionno=36&orderno=36&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_36_content:
  string
  line `(1) The University shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts including the balance-sheet, in such form and`
  line `accounting standard as may be specified, by notification, by the Central Government in consultation with`
  line `the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the University shall be audited by the Comptroller and Auditor-General of India`
  line `and any expenditure incurred by it in connection with such audit shall be payable by it to the Comptroller`
  line `and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the University shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts, and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line University.
  line
  line `(4) The accounts of the University as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (50859)
  sectionNo (37)
  orderNo 37
  title `Pension and provident funds.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50859&sectionno=37&orderno=37&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_37_content:
  string
  line `(1) The University may constitute for the benefit of its`
  line `employees such provident or pension fund or provide such insurance scheme as it may deem fit in such`
  line `manner and subject to such conditions as may be laid down in the Statutes.`
  line
  line `(2) Where any provident fund has been constituted under sub-section (1), the Central Government`
  line `may declare that the provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to such fund as`
  line `if it were a Government provident fund.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (50860)
  sectionNo (38)
  orderNo 38
  title `Annual report of University.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50860&sectionno=38&orderno=38&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_38_content:
  string
  line `(1) The annual report of the University shall be prepared by the`
  line `Vice-Chancellor, which shall include, among other matters, the steps taken by the University towards the`
  line `fulfilment of its objects and an outcome based assessment of the research being undertaken by it, and be`
  line `submitted to the Board of Governors on or before such date as may be specified and the Board of`
  line `Governors shall consider the report in its annual meeting.`
  line
  line `(2) The annual report, as approved by the Board of Governors, shall be published and placed on the`
  line `website of the University.`
  line
  line `(3) The Vice-Chancellor shall prepare and release for every year a report, in English and in Hindi, the`
  line `working of the University in the previous year on or before the expiry of nine months from the close of`
  line `financial year, and a copy of the same, together with an audited statement of accounts showing the`
  line `income and expenditure for the previous year shall be submitted to the Central Government within that`
  line `stipulated time, and the same may be caused to be laid before each House of Parliament.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (50861)
  sectionNo (39)
  orderNo 39
  title `Appointments of officers of University.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50861&sectionno=39&orderno=39&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_39_content:
  string
  line `All appointments of the employees of the University,`
  line `except the Vice-Chancellor, shall be made in accordance with the procedure laid down in the Statutes,`
  line by--
  line
  line `(a) the Board of Governors, if the appointment is made on the academic staff in the post of`
  line `Assistant Professor or above, or if the appointment is made on the non-academic staff in any post`
  line `equivalent to Group 'A' and above, as the case may be;`
  line
  line `(b) by the Vice-Chancellor, in any other case.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (50862)
  sectionNo (40)
  orderNo 40
  title Statutes.
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50862&sectionno=40&orderno=40&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_40_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of authorities and other bodies of the University, as may`
  line `be constituted from time to time;`
  line
  line `(b) the appointment and continuance in office of the members of the said authorities and bodies,`
  line `the filling up of vacancies of members, and all other matters relating to those authorities and other`
  line `bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers, academic staff from within the country or from outside the`
  line `country, and other employees of the University, their emoluments and conditions of service;`
  line
  line `(e) the appointment of teachers and academic staff working in any other University or organisation`
  line `for a specific period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provisions for pension, insurance, provident`
  line `fund, manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing the seniority of service of the employees of the University;`
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Board of Governors by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(j) the conferment of affiliation to a college or an institution or a Department under the University;`
  line
  line `(k) the establishment and abolition of Schools, departments, centres, halls, colleges and`
  line institutions;;
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(n) the management of campuses and affiliated colleges by the University;`
  line
  line `(o) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(p) the maintenance of discipline among the employees and students; and`
  line
  line `(q) any other matter, which by this Act are to be, or may be, laid down in the Statutes.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (50863)
  sectionNo (41)
  orderNo 41
  title `Statutes how to be made.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50863&sectionno=41&orderno=41&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_41_content:
  string
  line `(1) The first Statutes of the University shall be made by the Board`
  line `of Governors with the prior approval of the Central Government and a copy of the same shall be laid as`
  line `soon as may be it is made, before each House of Parliament:`
  line
  line `Provided that till such Statutes are made, the provisions of existing regulations of the Gujarat`
  line `Forensic Sciences University, Gandhinagar shall continue to be applicable:`
  line
  line `Provided further that till the Statutes for the administrative functioning of Delhi campus of the`
  line `University is made, the functions in Delhi campus shall continue in the same manner presently being`
  line `followed by the Lok Nayak Jayaprakash Narayan National Institute of Criminology and Forensic`
  line `Sciences, New Delhi.`
  line
  line `(2) The Board of Governors may, from time to time, make new or additional Statutes or may amend`
  line `or repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Board of Governors shall not make, amend or repeal any Statutes affecting the`
  line `status, powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Board of Governors.`
  line
  line `(3) Notwithstanding anything contained in this section, the Central Government may direct the`
  line `University to make provisions in the Statutes in respect of any matter as it may specify.`
  line
  line `(4) The power to make Statutes shall include the power to give retrospective effect from a date not`
  line `earlier than the date of commencement of this Act, to the Statutes or any of them, but no retrospective`
  line `effect shall be given to any Statute so as to prejudicially affect the interests of any person to whom such`
  line `Statute may be applicable.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (50864)
  sectionNo (42)
  orderNo 42
  title Ordinances.
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50864&sectionno=42&orderno=42&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_42_content:
  string
  line `Subject to the provisions of this Act and the Statutes, the Ordinances may provide`
  line `for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the University;`
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to examinations,`
  line `degrees and diplomas to the University;`
  line
  line `(f) the conditions and institution for award of fellowships, scholarships, studentships, medals and`
  line prizes;
  line
  line `(g) the conduct of examination including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence and teaching of women`
  line `students and the specifying of special courses of studies for them;`
  line
  line `(j) the establishment of centres of studies, boards of studies, specialised laboratories and other`
  line committees;
  line
  line `(k) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(l) the setting up of machinery for redressal of grievances of employees and students; and`
  line
  line `(m) any other matter which by this Act or Statutes, is to be, or may be, specified in the Ordinances.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (50865)
  sectionNo (43)
  orderNo 43
  title `Ordinances how made.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50865&sectionno=43&orderno=43&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_43_content:
  string
  line `(1) Save as otherwise provided in this section, Ordinances shall be`
  line `made by the Academic Council.`
  line
  line `(2) All Ordinances made by the Academic Council shall have effect from such date as it may direct,`
  line `but every Ordinance so made shall be submitted, as soon as may be, to the Board of Governors and shall`
  line `be considered by the Board of Governors at its next succeeding meeting.`
  line
  line `(3) The Board of Governors shall have power by resolution to approve, modify or cancel any such`
  line `Ordinance and such Ordinance shall from the date of such resolution stand modified accordingly or`
  line `cancelled, as the case may be.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (50866)
  sectionNo (44)
  orderNo 44
  title `Tribunal of Arbitration.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50866&sectionno=44&orderno=44&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_44_content:
  string
  line `(1) Every employee of the University shall be appointed under a`
  line `written contract, which shall be retained by the University and a copy of which shall be given to the`
  line `employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Board of Governor, one member nominated by the employee concerned and chaired by an umpire`
  line `appointed by the Central Government.`
  line
  line `(3) The decision of the Tribunal of Arbitration shall be final and no suit shall lie in any civil court in`
  line `respect of the matters decided by the said Tribunal:`
  line
  line `Provided that nothing in this sub-section shall preclude the employee from availing of the judicial`
  line `remedies available under articles 32 and 226 of the Constitution.`
  line
  line `(4) Every request made by the employee under sub-section (2) shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation Act, 1996`
  line `(26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Tribunal of Arbitration shall be laid down in the`
  line Statutes.
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (50867)
  sectionNo (45)
  orderNo 45
  title `Redressal for debarment from examination and disciplinary action against students.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50867&sectionno=45&orderno=45&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_45_content:
  string
  line `(1)`
  line `Any student or candidate for an examination whose name has been removed from the rolls of the`
  line `University by an order or resolution of the Vice-Chancellor and who has been debarred from appearing at`
  line `the examinations of the University for more than one year, may, within ten days of the date of receipt of`
  line `such order or copy of such resolution by him, appeal to the Board of Governors and the Board of`
  line `Governors may confirm, modify or reverse the decision of the Vice-Chancellor, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of`
  line `sub-sections (2), (3), (4) and (5) of section 44 shall apply to a reference made under this sub-section.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (50868)
  sectionNo (46)
  orderNo 46
  title `Disputes as to constitution of authorities and bodies.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50868&sectionno=46&orderno=46&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_46_content:
  string
  line `If any question arises as to whether any`
  line `person has been duly elected or appointed as, or is entitled to be, a member of any authority or other body`
  line `of the University, the matter shall be referred to the Board of Governors for decision.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (50869)
  sectionNo (47)
  orderNo 47
  title `Power of Central Government to make rules in respect of matters relating to Board of Governors.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50869&sectionno=47&orderno=47&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_47_content:
  string
  line `(1) The Central Government may, after previous publication, make rules to carry out the`
  line `purposes relating to the Board of Governors.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of filling vacancies among the members of the Board of Governors;`
  line
  line `(b) the disqualifications for being chosen as, and for being a member of the Board of Governors;`
  line
  line `(c) the circumstances in which, and the authority by which, members may be removed;`
  line
  line `(d) the meetings of the Board of Governors and the procedure for conduct of business;`
  line
  line `(e) the travelling and other allowances payable to members of the Board of Governors; and`
  line
  line `(f) the manner in which functions of the Board of Governors may be exercised.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (50870)
  sectionNo (48)
  orderNo 48
  title `Acts and proceeding not to be invalidated by vacancies, etc.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50870&sectionno=48&orderno=48&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_48_content:
  string
  line `No act of the Board of Governors`
  line `or any other body set up under this Act or the Statutes, shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or defect in the constitution thereof; or`
  line
  line `(b) any defect in the election, nomination or appointment of a person acting as a member thereof;`
  line or
  line
  line `(c) any irregularity in its procedure not affecting the merits of the case.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (50871)
  sectionNo (49)
  orderNo 49
  title `University to be a public authority under Right to Information Act.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50871&sectionno=49&orderno=49&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_49_content:
  string
  line `The provisions of Right`
  line `to Information Act, 2005 (22 of 2005) shall apply to the University, as it were a public authority defined`
  line `in clause (h) of section 2 of that Act.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (50872)
  sectionNo (50)
  orderNo 50
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50872&sectionno=50&orderno=50&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_50_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or other employee of the University for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act or Statutes or Ordinances made thereunder.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (50873)
  sectionNo (51)
  orderNo 51
  title `Power of Central Government to issue directions.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50873&sectionno=51&orderno=51&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_51_content:
  string
  line `(1) The University shall, in discharge of`
  line `its functions under this Act, be bound by such directions on questions of policy as the Central`
  line `Government may give in writing to it from time to time.`
  line
  line `(2) The decision of the Central Government as to whether a question is one of policy or not shall be`
  line final.
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (50874)
  sectionNo (52)
  orderNo 52
  title `Residuary provision.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50874&sectionno=52&orderno=52&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_52_content:
  string
  line `(1) The Board of Governors shall have the authority to deal with any`
  line `matter pertaining to the University and not specifically dealt with in this Act.`
  line
  line `(2) The decision of the Board of Governors on all such matters shall be final.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (50875)
  sectionNo (53)
  orderNo 53
  title `Laying of rules, Statutes, Ordinances and notifications.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50875&sectionno=53&orderno=53&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_53_content:
  string
  line `(1) Every rule, Statute or Ordinance`
  line `made and every notification issued under this Act shall be published in the Official Gazette.`
  line
  line `(2) Every rule, Statute or Ordinance made and every notification issued under this Act, shall be laid,`
  line `as soon as may be after it is made, before each House of Parliament, while it is in session, for a total`
  line `period of thirty days which may be comprised in one session or in two or more successive sessions, and`
  line `if, before the expiry of the session immediately following the session or the successive sessions aforesaid,`
  line `both Houses agree in making any modification in the rule, Statute, Ordinance or notification or both`
  line `Houses agree that the rule, Statute, Ordinance or notification should not be made, the rule, Statute,`
  line `Ordinance or notification shall thereafter have effect only in such modified form or be of no effect, as the`
  line `case may be; so, however, that any such modification or annulment shall be without prejudice to the`
  line `validity of anything previously done under that rule, Statute, Ordinance or notification.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (50876)
  sectionNo (54)
  orderNo 54
  title `Power to remove difficulties.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50876&sectionno=54&orderno=54&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_54_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `or give such directions not inconsistent with the provisions of this Act, as appears to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of the period of two`
  line `years from the date of commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (50877)
  sectionNo (55)
  orderNo 55
  title `Transitional provisions.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50877&sectionno=55&orderno=55&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_55_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes made`
  line thereunder,--
  line
  line `(a) the existing Director General of the Gujarat Forensic Sciences University, Gandhinagar shall be`
  line `appointed by the Central Government as the first Vice-Chancellor of the University for a period of`
  line `three years and he shall be eligible for re-appointment for a further period of three years;`
  line
  line `(b) till such time the University constitutes such authorities or committees as may be required under`
  line `the provisions of this Act, the existing committee or Board in the Gujarat Forensic Sciences`
  line `University, Gandhinagar shall continue to exercise the respective roles or, as the case may be, till the`
  line `Board of Governors determine;`
  line
  line `(c) the existing Director of Lok Nayak Jayaprakash Narayan National Institute of Criminology and`
  line `Forensic Sciences, New Delhi shall be appointed as the Campus Director for Delhi campus of the`
  line `University till a regular Director is appointed by the University;`
  line
  line `(d) the existing Registrar of the Gujarat Forensic Sciences University, Gandhinagar shall be`
  line `appointed as the first Executive Registrar of the University, or, as the case may be, till the Board of`
  line `Governors determine.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (50878)
  sectionNo (56)
  orderNo 56
  title `Repeal of Gujarat Act 17 of 2008.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_1461_00001_202032_1602501703622&sectionId=50878&sectionno=56&orderno=56&orgactid=AC_CEN_5_1461_00001_202032_1602501703622
obj_root_law_sections_56_content:
  string
  line `(1) The Gujarat Forensic Sciences University Act, 2008 is`
  line `hereby repealed.`
  line
  line `(2) Notwithstanding such repeal,--`
  line
  line `(a) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted, or other things done under the Gujarat Forensic`
  line `Sciences University Act, 2008, shall be deemed to have been respectively made, issued, conferred,`
  line `awarded, granted or done under the corresponding provisions of this Act and, except as otherwise`
  line `provided by or under this Act or the Statutes, continue in force unless and until they are superseded by`
  line `any order made under this Act or the Statutes; and`
  line
  line `(b) all the proceedings of selection committee or any other authority, if any, for the appointment or`
  line `promotion of teachers and other employees that took place before the commencement of this Act and`
  line `all actions of the concerned authorities in respect of the recommendations of such selection committee`
  line `or authority, if any, where no orders of appointment on the basis thereof were passed before the`
  line `commencement of this Act shall, notwithstanding that the procedure for selection has been modified by this Act, be deemed to have been valid but further proceeding in connection with such pending`
  line `selections shall be taken in accordance with the provisions of this Act and be continued from the stage`
  line `where they stood immediately before such commencement, except if the concerned authorities take a`
  line `decision to the contrary.`
obj_root_law_sections_56_footnotes:
  string
  line
