obj_root_law:
  slug the-national-forensic-sciences-university-act-2020
  handle (15623)
  collectionHandle 123456789/1362
  title `The National Forensic Sciences University Act, 2020`
  actNumber (32)
  enactmentDate 2020-09-28
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/15623`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्ट्रीय न्यायालयिक विज्ञान विश्वविद्यालय अधिनियम, 2020`
  actYear (2020)
  ministry `Ministry of Home Affairs`
  department `Department of Women Safety Division`
  longTitle `An Act to establish and declare an institution to be known as the National Forensic Sciences University as an institution of national importance to facilitate and promote studies and research and to achieve excellence in the field of forensic science in conjunction with applied behavioural science studies, law, criminology and other allied areas and technology and other related fields, and to provide for matters connected therewith or incidental thereto.`
  enforcementDate 01-10-2020
  notification undefined
