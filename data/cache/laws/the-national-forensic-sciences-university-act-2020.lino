obj_root_law_translations_hi_sections_19:
  kind ocr-page
  sectionId pdf-page-19
  sectionNo (19)
  orderNo 19
  title `Page 19`
  content obj_root_law_translations_hi_sections_19_content
  footnotes obj_root_law_translations_hi_sections_19_footnotes
  sourcePage 19
  ocrLanguages hin+eng
obj_root_law_translations_hi_sections_19_content:
  string
  line `अनुभाग ।क] भारत का राजपत्र असाधारण 2`
  line `30. (). सहबदूधता. और मान्यता. बोर्ड, महाविद्यालयों और संस्थाओं को सहबदूधता .. और`
  line `विश्वविद्यालय के विशेषाधिकारों को देने के लिए जिम्मेदार होगा | मान्यता बोर्ड |`
  line `(2) सहबदूधता और मान्यता के लिए बोर्ड का गठन, उसके सदस्यों की पदावधि और`
  line `उसकी शक्तियां तथा कृत्य वे होंगे, जो परिनियमों में अधिकथित किए जाएं |`
  line `37. शासी बोर्ड, परिनियमों द्वारा विश्वविद्यालय के ऐसे अन्य प्राधिकारियों या... विश्वविद्यालय के`
  line `अधिकारियों को घोषित कर सकेगा और यथास्थिति, ऐसे प्रत्येक प्राधिकारी या अधिकारी की... अन्य अधिकारी |`
  line `शक्तियों, कृत्यों और कर्तव्यों को विनिर्दिष्ट कर सकेगा |`
  line `32. केन्द्रीय सरकार, विश्वविद्यालय को इस अधिनियम के अधीन उसके कृत्यों को... केन्द्रीय _ सरकार`
  line `दक्षतापूर्वक निर्वहन करने में समर्थ बनाने के प्रयोजन के लिए, इस निमित्त संसद्‌ gam, द्वारा अनुदान |`
  line `विधि द्वारा किए गए सम्यक्‌ विनियोग के पश्चात्‌ प्रत्येक वित्तीय वर्ष में विश्वविद्यालय को`
  line `ऐसी धनराशि, ऐसी रीति में, जो वह ठीक समझे, संदत्त कर सकेगा |`
  line `33. विश्वविद्यालय, किसी राज्य सरकार से ऐसी धनराशियों को प्रतिवर्ष अनुदान राज्य... सरकार`
  line `सहायता के रूप में या एकमुश्त अनुदान के रूप में प्राप्त कर सकेगा | 'दूवारा अनुदान |`
  line `अध्याय 4`
  line `लेखा और संपरीक्षा`
  line `34. विश्वविद्यालय, केन्द्रीय सरकार या राज्य सरकारों या अन्य स्रोतों से निधियां विश्वविद्यालय का`
  line `प्राप्त कर सकेगा या अपनी निधियों को विश्वविद्यालय के समग्र को बनाए रखने dik समग्र।`
  line `प्रचालित करने के लिए उपयोग कर सकेगा |`
  line `35. (।) विश्वविद्यालय, एक निधि बनाए रखेगा, जिसमें निम्नलिखित जमा किए निधि |`
  line जाएंगे.
  line `(क) केन्द्रीय सरकार द्वारा दिए गए सभी धन ;`
  line `(ख) राज्य सरकारों से प्राप्त सभी धन ;`
  line `(ग) विश्वविद्यालय द्वारा प्राप्त सभी फीसें तथा अन्य प्रभार ;`
  line `(घ) विश्वविद्यालय द्वारा अनुदानों, ami, संदानों, उपकृतियों, वसीयतों अथवा`
  line `अंतरणों के रूप में प्राप्त सभी धन ;`
  line `(ड) समग्र से प्राप्त सभी हित या कोई अन्य ऐसे उपार्जन ;`
  line `(च) विश्वविद्यालय द्वारा लिए गए कोई उधार ;`
  line `(छ) विश्वविद्यालय और ऐसे उद्योग के बीच किए गए समझौता ज्ञापन के`
  line `उपबंधों के निबंधनानुसार सहयोगी उद्योगों से विश्वविद्यालय के प्रायोजित पीठ आचार्य`
  line `पदों, अध्येतावृत्ति या अवसंरचना सुविधाओं की स्थापना के लिए विश्वविद्यालय द्वारा`
  line `प्राप्त धन ; और`
  line `(ज) विश्वविद्यालय द्वारा किसी अन्य रीति में या किसी अन्य स्रोत से प्राप्त`
  line `सभी धन |`
  line `(2) विश्वविद्यालय की निधि में जमा किए गए सभी धनों को ऐसे बैंकों में जमा या`
  line `ऐसी रीति में विनिधान किया जाएगा जो विश्वविद्यालय, वित्त समिति के अनुमोदन से`
  line `विनिश्चित करे |`
