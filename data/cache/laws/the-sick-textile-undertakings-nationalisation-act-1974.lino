obj_root_law:
  object
  (str slug) (str the-sick-textile-undertakings-nationalisation-act-1974)
  (str handle) (str 1607)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Sick Textile Undertakings (Nationalisation) Act, 1974`)
  (str actNumber) (str 57)
  (str enactmentDate) (str 1974-12-21)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1607`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `रुग्‍ण कपड़ा-उपक्रम (राष्‍ट्रीयकरण) अधिनियम, 1974`)
  (str actYear) (str 1974)
  (str ministry) (str `Ministry of Textiles`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the sick textile undertakings, and the right, title and interest of the owners in respect of the sick textile undertakings, specified in the First Schedule with a view to re-organising and rehabilitating such sick textile undertakings so as to subserve the interests of the general public by the augmentation of the production and distribution, at fair prices, of different verieties of cloth and yarn, and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-04-1974)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T12:21:11.578Z`)
  (str translations) obj_root_law_translations
