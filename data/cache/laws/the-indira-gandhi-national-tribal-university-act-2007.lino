obj_root_law_sections_1:
  sectionId (23293)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 8th July 2008, vide notification No. S.O. 1630(E), dated 7th July, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23293&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Indira Gandhi National Tribal`
  line `University Act, 2007.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_2:
  sectionId (23294)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23294&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the context otherwise`
  line requires.--
  line
  line `(a) "Academic Board" in relation to a regional centre or a recognised institution means the`
  line `academic body charged with the academic matters of such centre or institution, as the case may be,`
  line `and recognised as such by the University;`
  line
  line `(b) "Academic Council" means the Academic Council of the University;`
  line
  line `(c) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(d) "Affiliated College" means a college admitted to the privileges of the University;`
  line
  line `(e) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(f) "Campus" means the unit established or constituted for making arrangements for instruction,`
  line `or research, or both, and includes off-campuses;`
  line
  line `(g) "Chancellor", "Vice-Chancellor" and "Pro-Vice-Chancellor" mean, respectively, the`
  line `Chancellor, Vice-Chancellor and Pro-Vice-Chancellor of the University;`
  line
  line `(h) "College Development Council" means the College Development Council of the University;`
  line
  line `(i) "Court" means the Court of the University;`
  line
  line `(j) "Dean" means Head of a Faculty of the University;`
  line
  line `(k) "Department" means a Department of Studies and includes a Centre of Studies;`
  line
  line `(l) "distance education system" means the system of imparting education through any means of`
  line `communication, such as broadcasting, telecasting, webcasting correspondence courses, seminars,`
  line `contact programmes or the combination of any two or more such means;`
  line
  line `(m) "Director" means Head of a Regional Centre;`
  line
  line `(n) "employee" means any person appointed by the University and includes teachers and other`
  line `staff of the University;`
  line
  line `(o) "Executive Council" means the Executive Council of the University;`
  line
  line `(p) "Faculty" means a Faculty of the University;`
  line
  line `(q) "Finance Committee" means the Finance Committee of the University;`
  line
  line `(r) "Hall" means a unit of residence or of corporate life for the students of the University, or of a`
  line `College or of an Institution, maintained or recognised by the University;`
  line
  line `(s) "Institution" means an academic institution, not being a College, maintained by, or admitted to`
  line `the privileges of, the University;`
  line
  line `(t) "Management Board" in relation to a regional centre or a recognised institution means the`
  line `governing body charged with the management of the affairs of such centre or institution, as the case`
  line `may be, and recognised as such by the University;`
  line
  line `(u) "Principal" means the Head of a College or an Institution maintained by the University and`
  line `includes, where there is no Principal, the person for the time being duly appointed to act as Principal,`
  line `and in the absence of the Principal, or the acting Principal, a Vice-Principal duly appointed as such;`
  line
  line `(v) "recognised teachers" means such persons as may be recognised by the University for the`
  line `purpose of imparting instructions in a College or an Institution admitted to the privileges of the`
  line University;
  line
  line `(w) "Regional Centres" means off-campuses constituted by the University and functioning as part`
  line `of the University, established in more tribal dominated areas, as prescribed in the Statutes;`
  line
  line `(x) "Regulations" means the Regulations made by any authority of the University under this Act`
  line `for the time being in force;`
  line
  line `(y) "Scheduled Population" means and includes the Scheduled Tribes as well as Scheduled`
  line `Castes, as defined in the Constitution of India;`
  line
  line `(z) "Statutes" and "Ordinances" mean, respectively, the Statutes and the Ordinances of the`
  line `University, for the time being in force;`
  line
  line `(za) "teachers" of the University means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instructions or conducting research in the University or any College`
  line `or Institution maintained by the University and are designated as teachers by the Ordinances;`
  line
  line `(zb) "University" means the Indira Gandhi National Tribal University as incorporated under this`
  line Act.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (23295)
  sectionNo (3)
  orderNo 3
  title `Establishment of University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23295&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established, in the State of Madhya Pradesh, a`
  line `University by the name of "Indira Gandhi National Tribal University".`
  line
  line `(2) The headquarters of the University shall be at Amarkantak.`
  line
  line `(3) The University shall have such number of Regional Centres and Campuses in the tribal areas as`
  line `the University may deem fit.`
  line
  line `(4) The first Chancellor, the first Vice-Chancellor and the first members of the Court, the Executive`
  line `Council and the Academic Council, and all such persons who may hereafter become such officers or`
  line `members, so long as they continue to hold such office or membership, are hereby constituted a body`
  line `corporate by the name of "Indira Gandhi National Tribal University".`
  line
  line `(5) The University shall have perpetual succession and a common seal, and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (23296)
  sectionNo (4)
  orderNo 4
  title `Objects of University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23296&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_4_content:
  string
  line `The objects of the University shall be,--`
  line
  line `(i) to provide avenues of higher education and research facilities primarily for the tribal`
  line `population of India;`
  line
  line `(ii) to disseminate and advance knowledge by providing instructional and research facilities in`
  line `tribal art, culture, tradition, language, medicinal systems, customs, forest based economic activities,`
  line `flora, fauna and advancement in technologies relating to the natural resources of the tribal areas;`
  line
  line `(iii) to collaborate with national and international universities or organisations, specially for`
  line `undertaking cultural studies and research on tribal populations;`
  line
  line `(iv) to formulate tribal centric development models, publish reports and monographs; and to`
  line `organise conferences, seminars on issues relating to tribes; and to provide inputs to policy matters in`
  line `different spheres;`
  line
  line `(v) to take appropriate measures for promoting, the members of tribal communities capable of`
  line `managing, administering and looking after their own needs by access to higher education through a`
  line `University of their own;`
  line
  line `(vi) to disseminate and advance knowledge by providing instructional and research facilities in`
  line `such other branches of learning as it may deem fit;`
  line
  line `(vii) to take appropriate measures for promoting innovations in teaching-learning processes in`
  line `inter-disciplinary studies and research; and to pay special attention to the improvement of the social,`
  line `educational and economic conditions and welfare of the Scheduled Tribes within the Union of India,`
  line `their intellectual, academic and cultural development.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (23297)
  sectionNo (5)
  orderNo 5
  title `Powers of University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23297&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_5_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provisions for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing on, persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(iii) to organise and to undertake extra-mural studies, training and extension services;`
  line
  line `(iv) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(v) to provide facilities through the distance education system to such persons as it may`
  line determine;
  line
  line `(vi) to institute Directorships, Principalships, Associateships, Professorships, Readerships,`
  line `Lecturerships and other teaching or academic positions, required by the University and to appoint`
  line `persons to such Directorships, Principalships, Associateships, Professorships, Readerships,`
  line `Lecturerships and other teaching or academic positions;`
  line
  line `(vii) to recognise an institution of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(viii) to recognise persons for imparting instructions in any College or Institution recognised or`
  line `maintained by the University;`
  line
  line `(ix) to appoint persons working in any other University or educational institution as teachers of`
  line `the University for a specified period;`
  line
  line `(x) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(xi) to co-operate or collaborate or associate with any other University or authority or Institution`
  line `of higher learning in such manner and for such purposes as the University may determine;`
  line
  line `(xii) to establish, with the prior approval of the Central Government, such Campuses, special`
  line `centres, specialised laboratories or other units for research and instruction as are, in the opinion of the`
  line `University, necessary for the furtherance of its objects;`
  line
  line `(xiii) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xiv) to establish and maintain Colleges, Institutions and Halls;`
  line
  line `(xv) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions, industrial or other organisations, as the University may deem`
  line necessary;
  line
  line `(xvi) to organise and conduct refresher courses, workshops, seminars and other programmes for`
  line `teachers, evaluators and other academic staff;`
  line
  line `(xvii) to make special arrangements in respect of the residence and teaching of women students as`
  line `the University may deem necessary;`
  line
  line `(xviii) to appoint on contract or otherwise visiting professors, Emeritus Professors, Consultants,`
  line `Scholars and such other persons who may contribute to the advancement of the objects of the`
  line University;
  line
  line `(xix) to confer autonomous status on a College or an Institution or a Department, as the case may`
  line `be, in accordance with the Statutes;`
  line
  line `(xx) to admit to its privileges Colleges and Institutions located in India not maintained by the`
  line `University; to withdraw all or any of those privileges in accordance with such conditions as may be`
  line `prescribed by the Statutes; to recognise, guide, supervise, and control Halls not maintained by the`
  line `University and other accommodation for students, and to withdraw any such recognition;`
  line
  line `(xxi) to determine standards of admission to the University which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xxii) to demand and receive payment of fees and other charges;`
  line
  line `(xxiii) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xxiv) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xxv) to regulate and enforce discipline among the students and the employees and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxvi) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(xxvii) to receive benefactions, donations and gifts and to acquire, hold, manage and dispose of`
  line `with the previous approval of the Central Government, any property, movable or immovable,`
  line `including trust and endowment properties for the purposes of the University;`
  line
  line `(xxviii) to borrow, with the prior approval of the Central Government, on the security of the`
  line `property of the University, money for the purposes of the University;`
  line
  line `(xxix) to establish such number of Regional Centres in various tribal areas of the country as are, in`
  line `the opinion of the University, necessary for the furtherance of its objects;`
  line
  line `(xxx) to make special provisions for the promotion of educational, economic interests and welfare`
  line `of the members belonging to the Scheduled Tribes by providing adequate percentage of seats in the`
  line `matters of admission, of posts in the matter of employment and other benefits;`
  line
  line `(xxxi) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (23298)
  sectionNo (6)
  orderNo 6
  title Jurisdiction.
  content `The jurisdiction of the University shall extend to the whole of India.`
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23298&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (23299)
  sectionNo (7)
  orderNo 7
  title `University open to all classes, castes and creed.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23299&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_7_content:
  string
  line `The University shall be open to persons of`
  line `either sex and of whatever race, creed, caste or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person, any test whatsoever of religious belief or profession in order to entitle him to be`
  line `appointed as a teacher of the University or to hold any other office therein or be admitted as a student in`
  line `the University or to graduate thereat or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for the employment or admission of women, persons with disabilities or of persons belonging`
  line `to the weaker sections of the society and, in particular, of the Scheduled Castes and the Scheduled Tribes.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (23300)
  sectionNo (8)
  orderNo 8
  title `Residence of students.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23300&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_8_content:
  string
  line `Every student of the University other than a student who pursues a`
  line `course of study by distance education system, shall reside in a Hall or hostel or under such conditions as`
  line `may be prescribed by the Ordinances.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (23301)
  sectionNo (9)
  orderNo 9
  title `Power to establish and maintain schools.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23301&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_9_content:
  string
  line `The University shall, subject to Statutes, have power`
  line `to establish at least one school in every Regional Centre, as a model school for the schools of the region.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (23302)
  sectionNo (10)
  orderNo 10
  title `The Visitor.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23302&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_10_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University, including Colleges and Institutions maintained by it, and to submit a report thereon; and`
  line `upon receipt of that report, the Visitor may, after obtaining the views of the Executive Council thereon`
  line `through the Vice-Chancellor, take such action and issue such directions as he considers necessary in`
  line `respect of any of the matters dealt with in the report and the University shall be bound to comply with`
  line `such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection to be made by such person or persons as he`
  line `may direct, of the University, its buildings, libraries, laboratories and equipment, and of any College or`
  line `Institution maintained by the University or admitted to its privileges; and also of the examinations,`
  line `teaching and other work conducted or done by the University and to cause an inquiry to be made in like`
  line `manner in respect of any matter connected with the administration or finances of the University, Colleges`
  line `or Institutions.`
  line
  line `(4) The Visitor shall, in every matter referred to in sub-section (3), give notice of his intention to`
  line `cause an inspection or inquiry to be made,--`
  line
  line `(a) to the University, if such inspection or inquiry is to be made in respect of the University or`
  line `any College or Institution maintained by it, or`
  line
  line `(b) to the management of the College or Institution, if the inspection or inquiry is to be made in`
  line `respect of College or Institution admitted to the privileges of the University, and the University or the`
  line `management, as the case may be, shall have the right to make such representations to the Visitor, as it`
  line `may consider necessary.`
  line
  line `(5) After considering the representations, if any, made by the University or the management, as the`
  line `case may be, the Visitor may cause to be made such inspection or inquiry as is referred to in`
  line `sub-section (3).`
  line
  line `(6) Where any inspection or inquiry has been caused to be made by the Visitor, the University or the`
  line `management shall be entitled to appoint a representative, who shall have the right to be present and be`
  line `heard at such inspection or inquiry.`
  line
  line `(7) The Visitor may, if the inspection or inquiry is made in respect of the University or any College or`
  line `Institution maintained by it, address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry together with such views and advice with regard to the action to be taken thereon, as the Visitor`
  line `may be pleased to offer, and on receipt of address made by the Visitor, the Vice-Chancellor shall`
  line `communicate, to the Executive Council, the views of the Visitor with such advice as the Visitor may offer`
  line `upon the action to be taken thereon.`
  line
  line `(8) The Visitor may, if the inspection or inquiry is made in respect of any College or Institution`
  line `admitted to the privileges of the University, address the management concerned through the ViceChancellor`
  line `with reference to the result of such inspection or inquiry, his views thereon and such advice as`
  line `he may be pleased to offer upon the action to be taken thereon.`
  line
  line `(9) The Executive Council or the management, as the case may be, shall communicate, through the`
  line `Vice-Chancellor to the Visitor such action, if any, as it proposes to take or has been taken upon the result`
  line `of such inspection or inquiry.`
  line
  line `(10) Where, the Executive Council or the management, does not, within a reasonable time, take action`
  line `to the satisfaction of the Visitor, the Visitor may, after considering any explanation furnished or`
  line `representation made by the Executive Council or the management, issue such directions as he may think`
  line `fit and the Executive Council or the management, as the case may be, shall comply with such directions.`
  line
  line `(11) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annual any proceeding of the University which is not in conformity with the Act, the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the Registrar to show cause why such`
  line `an order should not be made, and, if any cause is shown within a reasonable time, he shall consider the`
  line same.
  line
  line `(12) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (23303)
  sectionNo (11)
  orderNo 11
  title `Officers of University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23303&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_11_content:
  string
  line `The following shall be the officers of the University:--`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Pro-Vice-Chancellor;`
  line
  line `(4) the Director;`
  line
  line `(5) the Deans of Faculties;`
  line
  line `(6) the Registrar;`
  line
  line `(7) the Finance Officer;`
  line
  line `(8) the Controller of Examinations;`
  line
  line `(9) the Librarian; and`
  line
  line `(10) such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (23304)
  sectionNo (12)
  orderNo 12
  title `The Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23304&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_12_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the head of the University and shall, if present,`
  line `preside at the Convocations of the University held for conferring degrees and meetings of the Court.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (23305)
  sectionNo (13)
  orderNo 13
  title `The Vice-Chancellor.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23305&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_13_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of the opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority at its next meeting the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of the opinion that such action ought not to have been`
  line `taken, it may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to represent against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated`
  line `to him and thereupon the Executive Council may confirm, modify or reverse the action taken by the ViceChancellor.`
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the University is`
  line `beyond the powers of the authority conferred by the provisions of this Act, the Statutes or the Ordinances`
  line `or that any decision taken is not in the interest of the University, may ask the authority concerned to`
  line `review its decision within sixty days of such decision and if the authority refuses to review the decision`
  line `either in whole or in part or no decision is taken by it within the said period of sixty days, the matter shall`
  line `be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (23306)
  sectionNo (14)
  orderNo 14
  title `The Pro-Vice-Chancellor.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00019_200752_1517807325078&sectionId=23306&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00019_200752_1517807325078
obj_root_law_sections_14_content:
  string
  line `The Pro-Vice-Chancellor shall be appointed in such manner and on`
  line `such terms and conditions of service, and shall exercise such powers and perform such duties, as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
