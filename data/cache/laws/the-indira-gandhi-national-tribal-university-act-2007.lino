obj_root_law:
  slug the-indira-gandhi-national-tribal-university-act-2007
  handle (2016)
  collectionHandle 123456789/1362
  title `The Indira Gandhi National Tribal University Act, 2007`
  actNumber (52)
  enactmentDate 2007-12-20
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2016`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `इंदिरा गांधी राष्ट्री य जनजातीय विश्वाविद्यालयअधिनियम, 2007`
  actYear (2007)
  ministry `Ministry of Education`
  department `Department of Higher Education`
  longTitle `An Act to establish and incorporate a teaching and affiliating University at Amarkantak in the State of Madhya Pradesh to facilitate and promote avenues of higher education and research facilities for the tribal population in India and to provide for matters connected therewith or incidental thereto.`
  enforcementDate 08-07-2008
  notification `8th July 2008, vide notification No. S.O. 1630(E), dated 7th July, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T22:51:33.687Z`
  translations obj_root_law_translations
