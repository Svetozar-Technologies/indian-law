  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00020_196147_1517807321164&sectionId=32227&sectionno=51&orderno=63&orgactid=AC_CEN_2_11_00020_196147_1517807321164
obj_root_law_sections_51_content:
  string
  line `[Amendment of Certain Enactments.]--Rep. by the Repealing and Amending Act, 1964`
  line `(52 of 1964), s. 2 and First Schedule (w.e.f. 15-7-1978).`
