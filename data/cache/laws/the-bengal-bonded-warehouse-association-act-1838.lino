obj_root_law_sections_1:
  object
  (str sectionId) (str 68679)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str Incorporation.)
  (str content) (str `It is hereby enacted, that the persons whose names appear in the Schedule
No. 1, hereunto annexed, shall, from the 14th day of March, 1838, form a corporate body for the
Warehousing of Goods, either in bond or otherwise, by the name of the Bengal Bonded Warehouse
Association`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68679&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_2:
  object
  (str sectionId) (str 68680)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Power to sue and be sued, and to acquire, hold and transfer property.`)
  (str content) (str `^1 * * * The said
Association shall sue and be sued by its corporate name, and shall use such common seal as the
Directors of the said Association shall from time to time appoint, and may acquire, may hold
absolutely, may hold by way of pledge, and may transfer, any description of property whatever`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68680&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_3:
  object
  (str sectionId) (str 68681)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Capital Stock and shares.`)
  (str content) (str `^1* * * The sum of Rs. 10,00,000 subscribed for the purpose of the
said Association by the persons hereby incorporated, shall be the Capital Stock of the said
Association, and shall be divided into 2,000 shares of 500 Rupees each, and ^2* * * every one of the
persons hereby incorporated shall have one share of such Capital Stock for every 500 Rupees which
such person shall have subscribed.`)
  (str footnotes) (str `1. The word “that” omitted by Act 12 of 1891 s. 2 and Sch. I.

2. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68681&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_4:
  object
  (str sectionId) (str 68682)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Registering of names of proprietors. Register to be open to inspection.`)
  (str content) (str `^1 * * * The Directors of the said Association shall
cause the names, additions, and places of residence of the proprietors of shares in the said Capital
Stock, and the number of shares held by each proprietor, to be registered in a book, and the said
shares shall in such book be numbered, beginning from No. 1, and such book shall be kept at the
office of the said Association,

Register to be open to inspection.--and shall there be open to the inspection of all persons
during the usual hours of business.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68682&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_5:
  object
  (str sectionId) (str 68683)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str Share-certificates.)
  (str content) (str `^1 * * * A certificate signed by three Directors of the said Association shall
be delivered to every proprietor of the said Capital Stock, and ^2* * * it shall be at the option of every
proprietor of several shares to receive one certificate for all the shares of such proprietor, or one
certificate for each of those shares or several certificates, each of which may be for any number of
those shares.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word “that” omitted by s. 2 and Sch. I ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68683&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_6:
  object
  (str sectionId) (str 68684)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Transfer of shares.`)
  (str content) (str `^1 * * * Any share or shares of the said Capital Stock may be transferred
by indorsement made on the certificate for such share or shares by the proprietor of such share or
shares, or by the Attorney of such proprietor duly authorized thereunto; provided always, that such
indorsement shall specify the name of the party to whom the transfer is made; and provided also that
no such indorsement shall be effectual to transfer any such share or shares until such indorsement
shall have been registered in a Register to be kept for that purpose at the office of the said
Association, and until a note of such registration, and of the date thereof, shall have been made on the
back of the indorsed certificate under the hand of an officer appointed for that purpose by the
Directors of the said Association.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68684&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_7:
  object
  (str sectionId) (str 68685)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Proprietors of shares to be members of Association.`)
  (str content) (str `^1 * * * Every proprietor of a share of
the said Capital Stock, who shall cease to be a proprietor of such Stock, shall cease to be a member of
the corporation created by this Act; and ^2* * * every person who shall become a proprietor of the said
Capital Stock, shall become a member of the corporation created by this Act; and shall, in respect of
his share or shares of the said Capital Stock, be under the same liabilities under which an original
proprietor of the said Capital Stock would be.`)
  (str footnotes) (str `1. The words "And it is hereby enacted, that" omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word "that" omitted by s. 2 and Sch. I, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68685&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_8:
  object
  (str sectionId) (str 68686)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str `First Directors of Association.`)
  (str content) (str `^1* * * The business of the said Association shall be managed
by six Directors, and ^2* * * Francis Macnaghten, Joseph Walker, Jasper Ouseley, Richard Howe
Cockerell, Alexander Colvin, Joseph Willis, and James Church, Esquires, shall be the first Directors
of the said Association`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word “that” omitted by s. 2 and Sch. I, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68686&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_9:
  object
  (str sectionId) (str 68687)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str `Removal and election of Directors.`)
  (str content) (str `^1* * * Every Director of the said Association may be
removed by a general meeting of the proprietors, and ^2* * * every future Director of the said
Association shall be elected by such a general meeting`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word “that” omitted by s. 2 and Sch. I, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68687&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_10:
  object
  (str sectionId) (str 68688)
  (str sectionNo) (str 10)
  (str orderNo) (int 10)
  (str title) (str `Directors to go out by rotation.`)
  (str content) (str `1* * * A rotation among the Directors of the said
Association shall be settled by lot, so that two of the said Directors may go out of office on the
Monday following the 15th day of May, in every year, and 2* * * on the Monday following the
15th day of May, in every year, a general meeting of proprietors shall be held, at which two Directors
shall be chosen, and that no Director going out by such rotation shall be capable of being re-elected,
till the Monday after the 15th of May in the year next following.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68688&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_11:
  object
  (str sectionId) (str 68689)
  (str sectionNo) (str 11)
  (str orderNo) (int 11)
  (str title) (str `Election of successor, when Director ceases to be so otherwise than by rotation.`)
  (str content) (str `^1* * *
If any Director of the said Association shall cease to be a Director, otherwise than by the operation of
the rule of rotation aforesaid, the Directors of the said Association shall, with all convenient speed
after such public notice as is hereinafter directed, call an extraordinary general meeting of the
proprietors for the purpose of choosing a successor and such successor shall come into the same place
in the rotation aforesaid in which the Director whom he has succeeded was.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68689&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_12:
  object
  (str sectionId) (str 68690)
  (str sectionNo) (str 12)
  (str orderNo) (int 12)
  (str title) (str [Repealed].)
  (str content) (str `[Qualifications of Directors[.—[Repealed by Act 5 of 1854, Section 1].`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68690&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_13:
  object
  (str sectionId) (str 68691)
  (str sectionNo) (str 13)
  (str orderNo) (int 13)
  (str title) (str `Directors to be residents of Bengal Presidency.`)
  (str content) (str `^1* * * No person shall be capable of being
a Director of the said Association, unless he be resident within the Territories subject to the
Presidency of Fort William in Bengal`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68691&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_14:
  object
  (str sectionId) (str 68692)
  (str sectionNo) (str 14)
  (str orderNo) (int 14)
  (str title) (str [Repealed].)
  (str content) (str `[Ordinary meetings.[--[Repealed by Act 5 of 1854, Section 1.]`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68692&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_15:
  object
  (str sectionId) (str 68693)
  (str sectionNo) (str 15)
  (str orderNo) (int 15)
  (str title) (str `Adjournment of ordinary meetings.`)
  (str content) (str `^1* * * Any ordinary general meeting of the said
Association may adjourn itself to a future day, and may, on the day to which it shall have so
adjourned itself, resume its proceedings, and transact any business which it would have been
competent to transact on the day when it originally assembled.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68693&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_16:
  object
  (str sectionId) (str 68694)
  (str sectionNo) (str 16)
  (str orderNo) (int 16)
  (str title) (str `Extraordinary general meetings.`)
  (str content) (str `^1* * * Extraordinary general meetings of the said
Association shall be held according to such rules as may be made for that purpose, in the Bye-laws of
the said Association; provided always, that no such extraordinary general meeting shall be held
without a previous notice of not less than fourteen days, which notice shall be published in not less
than two newspapers printed at Calcutta.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68694&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_17:
  object
  (str sectionId) (str 68695)
  (str sectionNo) (str 17)
  (str orderNo) (int 17)
  (str title) (str `Voting at general meetings Qualification for voting.`)
  (str content) (str `^1* * * At General Meetings of the Proprietors, every election
and question shall be decided by a majority of votes; and

Qualifications for voting.---^2* * * no proprietor shall be allowed to vote unless he be possessed of two or more shares of the Capital Stock
of the said Association, which shares shall have been registered in his name not less than three
calendar months before.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word “that” omitted by s. 2 and Sch. I, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68695&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_18:
  object
  (str sectionId) (str 68696)
  (str sectionNo) (str 18)
  (str orderNo) (int 18)
  (str title) (str `Number of votes to which proprietors entitled.`)
  (str content) (str `^1* * * At such general meetings, no
proprietor shall have more than eight votes, and ^2* * * the proprietors shall vote according to the
following scale:---
2 Shares shall entitle to 1 vote.
4 2 votes.
6 3
10 4
20 6
35 7
50 8`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word “that” omitted by s. 2 and Sch. I, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68696&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_19:
  object
  (str sectionId) (str 68697)
  (str sectionNo) (str 19)
  (str orderNo) (int 19)
  (str title) (str `Votes of joint proprietors shares.`)
  (str content) (str `^1* * * If more persons than one, being partners in trade,
shall be joint proprietors of two or more shares of the said Capital Stock, and shall agree to give a
joint vote or joint votes, such joint vote or joint votes, shall be received in all respects as the vote or
votes of a single proprietor would be received`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68697&sectionno=19&orderno=19&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_20:
  object
  (str sectionId) (str 68698)
  (str sectionNo) (str 20)
  (str orderNo) (int 20)
  (str title) (str `Voting by proxy.`)
  (str content) (str `^1* * * Every proprietor entitled to vote at any general meeting may give a
proxy in writing, general or special, limited or unlimited, and signed by himself or by his attorney
duly authorized thereunto, to any other proprietor; and ^2* * * the proprietor to whom the proxy is
given, may vote on behalf of the proprietor who had given the proxy, according to the terms of such
proxy.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word “that” omitted by s. 2 and Sch. I, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68698&sectionno=20&orderno=20&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_21:
  object
  (str sectionId) (str 68699)
  (str sectionNo) (str 21)
  (str orderNo) (int 21)
  (str title) (str `Authority of Directors.`)
  (str content) (str `^1* * * The Directors of the said Association shall have authority to
expend the money of the said Association for the purpose of purchasing and erecting warehouses, and
of warehousing and bonding goods therein, and to make and fulfil contracts for the said purpose, and
to appoint and remove such servants as may be necessary for the said purpose and generally to
manage all the concerns of the said Association, subject to such rules as may be laid down in the
Bye-laws of the said Association, and to keep the seal of the said Association, and to use the said seal
in the affairs of the said Association, provided always, that the said seal shall never be affixed to any
instrument except in the presence and by the consent of three Directors, who shall sign their names on
every such instrument in token of their presence and consent.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68699&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_22:
  object
  (str sectionId) (str 68700)
  (str sectionNo) (str 22)
  (str orderNo) (int 22)
  (str title) (str `Calls for share money.`)
  (str content) (str `^1* * * The Directors of the said Association shall have authority to
call on the proprietors to pay such instalment or instalments as shall, together with the instalments
already paid, amount to a sum not exceeding 50 per cent. on each share; and ^1* * * no further call shall be
made, except in consequence of a vote of a general meeting of the proprietors, authorising such
further call; provided always that no proprietor shall be called upon to pay more in proportion to his
share in the Capital Stock than any other proprietor.`)
  (str footnotes) (str `1. The words "And it is hereby enacted, that" omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68700&sectionno=22&orderno=22&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_23:
  object
  (str sectionId) (str 68701)
  (str sectionNo) (str 23)
  (str orderNo) (int 23)
  (str title) (str `Interest to run on each call. Application of dividend in satisfaction of unpaid calls.`)
  (str content) (str `^1* * * If any proprietor shall not pay any instalment which he
is lawfully called upon to pay, in the manner described in the last section, on the day appointed for
such payment, the said Association shall have a claim against such proprietor for interest on the
deficient sum, after the rate of 10 per cent. per annum; and

Application of dividend in satisfaction of unpaid calls.---^1* * * it shall be lawful for the
Directors of the said Association to apply, in satisfaction of such instalment and of such interest, any
dividend due to such proprietor, placing every dividend so applied to the credit of such proprietor with
the said Association`)
  (str footnotes) (str `1. The words "And it is hereby enacted, that" omitted by s. 2 and Sch. I, ibid.

2. The word "that" omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68701&sectionno=23&orderno=23&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_24:
  object
  (str sectionId) (str 68802)
  (str sectionNo) (str 24)
  (str orderNo) (int 24)
  (str title) (str `Power to refuse to register transfer by defaulting proprietor. Power to sell shares to satisfy calls, and issue fresh certificates.`)
  (str content) (str `^1* * * It shall be lawful for
the Directors of the said Association to refuse to register the transfer of any share belonging to any
proprietor who shall not have paid such instalment and interest as aforesaid; and ^2* * * in case such
instalment and interest shall not be paid within two months after notice to pay the same has been
given by the said Directors to such proprietor, or to his attorney or attorneys duly authorised, it shall
be lawful for the said Directors to sell by public sale the share or shares of such proprietor, to such an
extent as may be sufficient to satisfy such instalment and interest, and to grant, upon such sale,

Power to sell shares to satisfy calls, and issue fresh certificates.---a new certificate or new
certificates to the purchaser of such share or shares whereupon the former certificate or certificates for
such share or shares shall become void, and if there be any surplus after such instalment and interest
have been satisfied, such surplus shall be paid on demand to the proprietor of such share or shares,
and shall, till demand, be credited in the books of the said Association to such proprietor, but no
interest shall run thereon.`)
  (str footnotes) (str `1. The words "And it is hereby enacted, that" omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The word "that" omitted by ibid. s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68802&sectionno=24&orderno=24&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_25:
  object
  (str sectionId) (str 68703)
  (str sectionNo) (str 25)
  (str orderNo) (int 25)
  (str title) (str `Extension of Act 25 of 1836 to warehouses of Association.`)
  (str content) (str `^1* * * All the provisions
of ^2Act 25 of 1836, of the Governor General of India in council, relating to private licensed
Warehouses, shall be applicable to all Warehouses wherein the said Association shall receive bonded
Goods.`)
  (str footnotes) (str `1. The words "And it is hereby enacted, that" omitted by Act 12 of 1891, s. 2 and Sch. I.

2. Rep. by the Repealing Act, 1873 (12 of 1873).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68703&sectionno=25&orderno=25&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_26:
  object
  (str sectionId) (str 68704)
  (str sectionNo) (str 26)
  (str orderNo) (int 26)
  (str title) (str `Power to give general security for payment of import and export duties.`)
  (str content) (str `^1* * * It shall
be lawful for the said Association to give general security, by bond, under the seal of the said
Association, for payment of the full duties of importation on Goods, lodged in any Warehouse of the
said Association, or for the due exportation of such Goods; and if the said Association shall give such
bond, no security shall be required from any other party to the same effect.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68704&sectionno=26&orderno=26&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_27:
  object
  (str sectionId) (str 68705)
  (str sectionNo) (str 27)
  (str orderNo) (int 27)
  (str title) (str `Rates for warehousing.`)
  (str content) (str `^1* * * The Directors of the said Association shall, from time to
time, fix the rates at which the said Association will Warehouse Goods and receive Goods at its
Wharfs, and ^2* * * a table of such rates shall be placed at every Warehouse and Wharf of the said
Association`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch.I

2. The word “that” omitted by Act 12 of 1891, s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68705&sectionno=27&orderno=27&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_28:
  object
  (str sectionId) (str 68706)
  (str sectionNo) (str 28)
  (str orderNo) (int 28)
  (str title) (str `Certificates of deposit, transferable by endorsement.`)
  (str content) (str `^1* * * As often as any Goods are
lodged in any Warehouse of the said Association, the Secretary of the said Association shall deliver a warrant signed by him as such Secretary, to the person lodging such Goods, which warrant shall be, as
nearly as possible, in the form set forth in Schedule II annexed to this Act, and such warrant shall be
transferable by indorsement, and shall entitle any person to whom it may have been so transferred by
endorsement, to receive the Goods specified in such warrant on the same terms on which the person
who originally lodged those Goods would have been entitled to receive the same.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68706&sectionno=28&orderno=28&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_29:
  object
  (str sectionId) (str 68707)
  (str sectionNo) (str 29)
  (str orderNo) (int 29)
  (str title) (str `Suits against Association.`)
  (str content) (str `^1* * * All suits brought against the said Association shall be
brought in the Supreme Court of Judicature at Fort William in Bengal and not elsewhere.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68707&sectionno=29&orderno=29&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_30:
  object
  (str sectionId) (str 68708)
  (str sectionNo) (str 30)
  (str orderNo) (int 30)
  (str title) (str `Joint Stock of Association.`)
  (str content) (str `^1* * * All the Joint Stock of the said Association of what kind
or description soever, and all the Land, Warehouses, Messuages, Tenements, Hereditaments, Premises
and Property acquired therewith, of which the said Association shall become in any manner
possessed, entitled to, or interested in, shall be held and enjoyed by the Proprietors thereof, and their
successors respectively, as Personal Estate, or as in the nature of Chattel Interests, and not as, or in the
nature of, Real Estate`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68708&sectionno=30&orderno=30&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_31:
  object
  (str sectionId) (str 68709)
  (str sectionNo) (str 31)
  (str orderNo) (int 31)
  (str title) (str `Individual members not to be liable.`)
  (str content) (str `^1* * * In order to define the liability of Proprietors or
shares, and to save harmless themselves and their respective Heirs, Executors, Administrators,
Representatives and Assigns, no Proprietor, his Heirs, Executors, Administrators, Representatives or
Assigns, shall be personally liable to any person or persons whatsoever by reason of being a
Proprietor in any event, or for or on account of any acts, deeds, contracts or liabilities of the said
Association, or of the Directors or Secretary thereof respectively, or under or by virtue of any
judgment or decree in any action or suit, but ^2* * * the party or parties having any legal or equitable
demand or claim for or on the account last aforesaid, or having obtained such judgment or decree as
last aforesaid, shall and may only recover the amount of such demand, claim, judgment or decree
from and out of or to the whole extent of the paid up Capital, accumulated Funds, Lands, Messuages,
Tenements, Hereditaments and Premises whatsoever and wheresoever, which may at the time belong
to the said Association, or to which they may at the time be entitled.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. The words “that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68709&sectionno=31&orderno=31&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_32:
  object
  (str sectionId) (str 68710)
  (str sectionNo) (str 32)
  (str orderNo) (int 32)
  (str title) (str [Repealed].)
  (str content) (str `[Bye-laws].--[Repealed by Act 5 of 1854, Section 1].`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68710&sectionno=32&orderno=32&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_33:
  object
  (str sectionId) (str 68711)
  (str sectionNo) (str 33)
  (str orderNo) (int 33)
  (str title) (str `Increase of Capital Stock.`)
  (str content) (str `^1* * * It shall be lawful for the said Association to increase its
Capital Stock; provided always that no such increase shall take place unless it be authorized by a vote
of two extraordinary general meetings of Proprietors specially convened for that purpose, of which
meetings the second shall be held not less than three calendar months after the first.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68711&sectionno=33&orderno=33&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_34:
  object
  (str sectionId) (str 68712)
  (str sectionNo) (str 34)
  (str orderNo) (int 34)
  (str title) (str `Option to original proprietors to subscribe in first instance.`)
  (str content) (str `^1* * * In the event of such
increase, the Proprietors of the original Stock shall not be bound to subscribe, but shall in the first
instance have the option of subscribing for the increased Capital Stock in proportion to the share
which each has of the original Capital Stock; and so much of the additional Capital Stock as shall not
be subscribed for by the said Proprietors of the original stock, within one year after the passing of the
final resolution for the increase, shall be open to the public, and be sold, for the benefit of the said
Association, by public sale.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68712&sectionno=34&orderno=34&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_35:
  object
  (str sectionId) (str 68713)
  (str sectionNo) (str 35)
  (str orderNo) (int 35)
  (str title) (str `Provisions of Act to apply to additional Stock.`)
  (str content) (str `^1* * * All the rules laid down in this Act
respecting the original Capital Stock of the said Association, shall be applicable to any additional
Stock which may be subscribed in the manner hereinbefore described`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68713&sectionno=35&orderno=35&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_36:
  object
  (str sectionId) (str 68714)
  (str sectionNo) (str 36)
  (str orderNo) (int 36)
  (str title) (str `East India Company to have right of pre-emption.`)
  (str content) (str `^1* * * If the said Association shall be
desirous to dispose of any premises purchased by the said Association from the East India Company, the said East India Company shall the right of pre-emption, and the price shall be fixed by two
appraisers, the one named on the part of the said East India Company, and the other by the Directors
of the said Association; and if the said appraisers shall not agree on a price, the price shall be fixed by
an umpire named by the said appraisers.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68714&sectionno=36&orderno=36&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_37:
  object
  (str sectionId) (str 68715)
  (str sectionNo) (str 37)
  (str orderNo) (int 37)
  (str title) (str `Dissolution of Association by order of the Governor General in Council.`)
  (str content) (str `[Dissolution of Association by order of the Governor General in Council.]----[Repealed by Act
5 of 1854, Section 1.]`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68715&sectionno=37&orderno=37&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_38:
  object
  (str sectionId) (str 68716)
  (str sectionNo) (str 38)
  (str orderNo) (int 38)
  (str title) (str `Dissolution of Association by resolution of proprietors.`)
  (str content) (str `^1* * * The said Association may
at any time be dissolved by a resolution to that effect of two-thirds in number and value of the
proprietors qualified to vote at two successive extraordinary meetings specially called for the purpose
of taking into consideration the expediency of such dissolution; provided that not less than three
months shall have elapsed between the first and second of such two extraordinary meetings.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68716&sectionno=38&orderno=38&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
obj_root_law_sections_39:
  object
  (str sectionId) (str 68717)
  (str sectionNo) (str 39)
  (str orderNo) (int 39)
  (str title) (str `Division of property on dissolution.`)
  (str content) (str `^1* * * Whenever the dissolution of the said
Association shall be ordered either by the ^2[Central Government], or by a vote of the said Association,
the Directors of the said Association shall cause all the property of the said Association to be
converted into money, and shall divide whatever surplus may remain after satisfying the debts of the
said Association among the proprietors in proportion to the shares which the proprietors have in the
Capital Stock of the said Association; and after such distribution the said Association shall forthwith
be dissolved.`)
  (str footnotes) (str `1. The words “And it is hereby enacted, that” omitted by Act 12 of 1891, s. 2 and Sch. I.

2. Subs. by the A.O. 1937, for “Governor General of India in Council”.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00093_183805_1662013952073&sectionId=68717&sectionno=39&orderno=39&orgactid=AC_CEN_5_5_00093_183805_1662013952073)
