  (str slug) (str the-protection-of-women-from-domestic-violence-act-2005)
  (str handle) (str 2021)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Protection of Women from Domestic Violence Act, 2005`)
  (str actNumber) (str 43)
  (str enactmentDate) (str 2005-09-13)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2021`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `घरेलू हिंसा से महिला संरक्षण अधिनियम, 2005`)
  (str actYear) (str 2005)
  (str ministry) (str `Ministry of Women and Child Development`)
  (str longTitle) (str `An Act to provide for more effective protection of the rights of women guaranteed under the Constitution who are victims of violence of any kind occurring within the family and formatters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 26-10-2006)
  (str notification) (str `26th October, 2006, vide notification No. S.O. 1776(E), dated by 17th October, 2006, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
