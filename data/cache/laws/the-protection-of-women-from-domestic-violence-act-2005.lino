obj_root_law:
  slug the-protection-of-women-from-domestic-violence-act-2005
  handle (2021)
  collectionHandle 123456789/1362
  title `The Protection of Women from Domestic Violence Act, 2005`
  actNumber (43)
  enactmentDate 2005-09-13
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2021`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `घरेलू हिंसा से महिला संरक्षण अधिनियम, 2005`
  actYear (2005)
  ministry `Ministry of Women and Child Development`
  longTitle `An Act to provide for more effective protection of the rights of women guaranteed under the Constitution who are victims of violence of any kind occurring within the family and formatters connected therewith or incidental thereto.`
  enforcementDate 26-10-2006
  notification `26th October, 2006, vide notification No. S.O. 1776(E), dated by 17th October, 2006, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
