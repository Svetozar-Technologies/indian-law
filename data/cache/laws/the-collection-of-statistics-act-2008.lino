  object
  (str title) (str `सांख्यितकी संग्रहण अधिनियम, 2008`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2081/2/H2009-7.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:52:06.968Z`)
