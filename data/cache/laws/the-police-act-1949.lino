obj_root_law_sections_1:
  sectionId (37132)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00012_194964_1517807321847&sectionId=37132&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00012_194964_1517807321847
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Police Act, 1949.`
  line
  line `(2) It extends to all the ^1`
  line `[Union territories].`
  line
  line `(3) It shall come into force in a ^2`
  line `[Union territory] on such date as the Central Government may, by`
  line `notification in the Official Gazette, appoint in this behalf for ^3`
  line `[such territory].`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs., ibid., for "Part C States".`
  line
  line `2. Subs., ibid., for "Part C State."`
  line
  line `3. Subs., ibid., for "such state".`
obj_root_law_sections_2:
  sectionId (37133)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00012_194964_1517807321847&sectionId=37133&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00012_194964_1517807321847
obj_root_law_sections_2_content:
  string
  line `In this Act "general police-district" means the general police-district constituted`
  line `under section 3.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (37134)
  sectionNo (3)
  orderNo 3
  title `Constitution of general police-district embracing two or more Union territories.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Chief Commissioners' Provinces".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00012_194964_1517807321847&sectionId=37134&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00012_194964_1517807321847
obj_root_law_sections_3_content:
  string
  line `Notwithstanding anything contained in the Police Act, 1861 (5 of 1861), the Central Government may, by`
  line `notification in the Official Gazette, constitute a general police-district embracing two or more ^1`
  line [Union
  line territories].
obj_root_law_sections_4:
  sectionId (37135)
  sectionNo (4)
  orderNo 4
  title `Constitution of one police force for general police-district.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00012_194964_1517807321847&sectionId=37135&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00012_194964_1517807321847
obj_root_law_sections_4_content:
  string
  line `The entire police establishment in a`
  line `general police-district shall be one police force and shall consist of such number of officers and men and`
  line `shall be constituted in such manner as the Central Government may, by order, direct.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (37136)
  sectionNo (5)
  orderNo 5
  title `Superintendence and administration of police.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00012_194964_1517807321847&sectionId=37136&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00012_194964_1517807321847
obj_root_law_sections_5_content:
  string
  line `(1) The superintendence of the police`
  line `throughout a general police-district shall vest in, and be exercised by, the Central Government.`
  line
  line `(2) The administration of the said police force shall vest in an officer, appointed in this behalf by the`
  line `Central Government, who shall exercise in respect of that police force such of the powers exercisable by`
  line `an Inspector-General of Police under the Police Act, 1861 (5 of 1861), as the Central Government may,`
  line `by notification in the Official Gazette, specify in this behalf.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (37137)
  sectionNo (6)
  orderNo 6
  title `Application of the Police Act, 1861.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs., ibid., for "any State".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00012_194964_1517807321847&sectionId=37137&sectionno=6&orderno=6&orgactid=AC_CEN_5_23_00012_194964_1517807321847
obj_root_law_sections_6_content:
  string
  line `Save as otherwise expressly provided in this Act, the`
  line `provisions of the Police Act, 1861 (5 of 1861), shall apply to the police force constituted for the general`
  line `police-district as if it were one police force constituted for a State, and members of the said police force`
  line `shall have, in every part of ^1`
  line `[any territory] which is included in the general police-district, the same`
  line `powers, duties and privileges, and shall be subject to the same liabilities, as they would have had, or`
  line `would have been subject to, as police officers if they had formed a police establishment under one State`
  line Government.
obj_root_law_sections_7:
  sectionId (37138)
  sectionNo (7)
  orderNo 7
  title Saving.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00012_194964_1517807321847&sectionId=37138&sectionno=7&orderno=7&orgactid=AC_CEN_5_23_00012_194964_1517807321847
obj_root_law_sections_7_content:
  string
  line `Nothing in this Act shall be deemed to affect the provisions contained in the Delhi`
  line `Special Police Establishment Act, 1946 (25 of 1946).`
obj_root_law_sections_7_footnotes:
  string
  line
