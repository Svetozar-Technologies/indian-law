  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1812`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (1984)
  ministry `Ministry of Agriculture and Farmers Welfare`
  department `Department of Animal Husbandry and Dairying`
  longTitle `An Act to regulate veterinary practice and to provide, for that purpose, for the establishment of a Veterinary Council of India and State Veterinary Councils and the maintenance of registers of the veterinary practitioners and for matters connected therewith.`
  enforcementDate 18-08-1984
  notification `yet to be notified`
