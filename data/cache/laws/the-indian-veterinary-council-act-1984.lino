  (str slug) (str the-indian-veterinary-council-act-1984)
  (str handle) (str 1812)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Indian Veterinary Council Act, 1984`)
  (str actNumber) (str 52)
  (str enactmentDate) (str 1984-08-18)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1812`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (undefined)
  (str actYear) (str 1984)
  (str ministry) (str `Ministry of Agriculture and Farmers Welfare`)
  (str department) (str `Department of Animal Husbandry and Dairying`)
  (str longTitle) (str `An Act to regulate veterinary practice and to provide, for that purpose, for the establishment of a Veterinary Council of India and State Veterinary Councils and the maintenance of registers of the veterinary practitioners and for matters connected therewith.`)
  (str enforcementDate) (str 18-08-1984)
  (str notification) (str `yet to be notified`)
