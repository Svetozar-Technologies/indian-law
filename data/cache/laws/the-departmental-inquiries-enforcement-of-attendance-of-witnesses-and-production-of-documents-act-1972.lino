obj_root_law_sections_1:
  sectionId (47901)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00008_197218_1517807325020&sectionId=47901&sectionno=1&orderno=1&orgactid=AC_CEN_26_36_00008_197218_1517807325020
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Departmental Inquiries (Enforcement of`
  line `Attendance of Witnesses and Production of Documents) Act, 1972.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
obj_root_law_sections_2:
  sectionId (47902)
  sectionNo (2)
  orderNo 2
  title `Departmental inquiries to which the Act shall apply.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00008_197218_1517807325020&sectionId=47902&sectionno=2&orderno=2&orgactid=AC_CEN_26_36_00008_197218_1517807325020
obj_root_law_sections_2_content:
  string
  line `The provisions of this Act shall apply to`
  line `every departmental inquiry made in relation to--`
  line
  line `(a) persons appointed to public services or posts in connection with the affairs of the Union;`
  line
  line `(b) persons who, having been appointed to any public service or post in connection with the`
  line `affairs of the Union, are in service or pay of,--`
  line
  line `(i) any local authority in any Union territory,`
  line
  line `(ii) any corporation established by or under a Central Act and owned or controlled by the`
  line `Central Government,`
  line
  line `(iii) any Government company within the meaning of section 617 of the Companies`
  line `Act, 1956 (1 of 1956), in which not less than fifty-one per cent. of the paid-up share capital is`
  line `held by the Central Government or any company which is a subsidiary of such Government`
  line company,
  line
  line `(iv) any society registered under the Societies Registration Act, 1860 (21 of 1860), which is`
  line `subject to the control of the Central Government.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47903)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00008_197218_1517807325020&sectionId=47903&sectionno=3&orderno=3&orgactid=AC_CEN_26_36_00008_197218_1517807325020
obj_root_law_sections_3_content:
  string
  line `For the purposes of this Act,--`
  line
  line `(a) "departmental inquiry" means an inquiry held under and in accordance with--`
  line
  line `(i) any law made by Parliament or any rule made thereunder, or`
  line
  line `(ii) any rule made under the proviso to article 309, or continued under article 313, of the`
  line `Constitution of India,`
  line
  line `into any allegation of lack of integrity against any person to whom this Act applies;`
  line
  line `(b) "inquiring authority" means an officer or authority appointed by the Central Government or`
  line `by any officer or authority subordinate to that Government to hold a departmental inquiry and`
  line `includes any officer or authority who is empowered by or under any law or rule for the time being in`
  line `force to hold such inquiry;`
  line
  line `(c) "lack of integrity" includes bribery or corruption.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47904)
  sectionNo (4)
  orderNo 4
  title `Power of Central Government to authorise the exercise of powers specified in section 5.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00008_197218_1517807325020&sectionId=47904&sectionno=4&orderno=4&orgactid=AC_CEN_26_36_00008_197218_1517807325020
obj_root_law_sections_4_content:
  string
  line `(1) Where the Central Government is of opinion that for the purposes of any departmental`
  line `inquiry it is necessary to summon as witnesses, or call for any document from, any class or category of`
  line `persons, it may, by notification in the Official Gazette, authorise the inquiring authority to exercise the`
  line `power specified in section 5 in relation to any person within such class or category and thereupon the`
  line `inquiring authority may exercise such power at any stage of the departmental inquiry.`
  line
  line `(2) The power conferred on the Central Government by sub-section (1) may also be exercised by such`
  line `authority, not being an authority inferior to the appointing authority in relation to the person against`
  line `whom the departmental inquiry is being held, as the Central Government may, by notification in the`
  line `Official Gazette, specify in this behalf.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47905)
  sectionNo (5)
  orderNo 5
  title `Power of authorised inquiring authority to enforce attendance of witnesses and production of documents.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00008_197218_1517807325020&sectionId=47905&sectionno=5&orderno=5&orgactid=AC_CEN_26_36_00008_197218_1517807325020
obj_root_law_sections_5_content:
  string
  line `(1) Every inquiring authority authorised under section 4 (hereafter referred to as the`
  line `"authorised inquiring authority") shall have the same powers as are vested in a civil court under the Code`
  line `of Civil Procedure, 1908 (5 of 1908), while trying a suit, in respect of the following matters, namely:--`
  line
  line `(a) the summoning and enforcing the attendance of any witness and examining him on oath;`
  line
  line `(b) requiring the discovery and production of any document or other material which is producible`
  line `as evidence;`
  line
  line `(c) the requisitioning of any public record from any court or office.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the authorised inquiring authority shall not`
  line `compel the Reserve Bank of India, the State Bank of India, any subsidiary bank as defined in clause (k) of`
  line `section 2 of the State Bank of India (Subsidiary Banks) Act, 1959 (38 of 1959), or any corresponding new`
  line `bank constituted under section 3 of the Banking Companies (Acquisition and Transfer of Undertakings)`
  line `Act, 1970 (5 of 1970),`
  line
  line `(a) to produce any books of account or other documents which the Reserve Bank of India, the`
  line `State Bank of India, the subsidiary bank or the corresponding new bank claims to be of a confidential`
  line `nature, or`
  line
  line `(b) to make any such books or documents a part of the record of the proceedings of the`
  line `departmental inquiry, or`
  line
  line `(c) to give inspection of any such books or documents, if produced, to any party before it or to`
  line `any other person.`
  line
  line `(3) Every process issued by an authorised inquiring authority for the attendance of any witness or for`
  line `the production of any document shall be served and executed through the District Judge within the local`
  line `limits of whose jurisdiction the witness or other person, on whom the process is to be served or executed,`
  line `voluntarily resides or carries on business or personally works for gain, and, for the purpose of taking any`
  line `action for the disobedience of any such process, every such process shall be deemed to be a process`
  line `issued by the District Judge.`
  line
  line `(4) Every authorised inquiring authority making any departmental inquiry under this Act shall be`
  line `deemed to be a civil court for the purposes of sections 480 and 482 of the Code of Criminal`
  line `Procedure, 1898 (5 of 1898).`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47906)
  sectionNo (6)
  orderNo 6
  title `Territorial limits in which powers specified in section 5 may be exercised.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00008_197218_1517807325020&sectionId=47906&sectionno=6&orderno=6&orgactid=AC_CEN_26_36_00008_197218_1517807325020
obj_root_law_sections_6_content:
  string
  line `For the purpose of`
  line `exercising the powers specified in section 5, the territorial jurisdiction of every authorised inquiring`
  line `authority shall extend to the limits of the territory to which this Act extends.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47907)
  sectionNo (7)
  orderNo 7
  title `Power to make rules.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00008_197218_1517807325020&sectionId=47907&sectionno=7&orderno=7&orgactid=AC_CEN_26_36_00008_197218_1517807325020
obj_root_law_sections_7_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for the purpose of giving effect to the provisions of this Act.`
  line
  line `(2) Every rule made by the Central Government under this section shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament while it is in session for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `the modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.`
obj_root_law_sections_7_footnotes:
  string
  line
