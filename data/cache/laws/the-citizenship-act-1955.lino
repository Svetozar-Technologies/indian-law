obj_root_law_sections_11_content:
  string
  line `[Commonwealth citizenship].Omitted by Act The Citizenship (Amendment) Act, (6 of 2004),`
  line `s. 10 (w.e.f. 3-12-2004).`
obj_root_law_sections_11_footnotes:
  string
