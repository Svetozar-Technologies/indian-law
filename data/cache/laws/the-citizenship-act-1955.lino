obj_root_law_sections_1:
  sectionId (14346)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Citizenship Act, 1955.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14346&sectionno=1&orderno=1&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (14347)
  sectionNo (2)
  orderNo 2
  title Interpretation.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14347&sectionno=2&orderno=2&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "a Government in India" means the Central Government or a State Government.`
  line
  line `^1[(b) "illegal migrant" means a foreigner who has entered into India--`
  line
  line `(i) without a valid passport or other travel documents and such other document or`
  line `authority as may be prescribed by or under any law in that behalf; or`
  line
  line `(ii) with a valid passport or other travel documents and such other document or authority`
  line `as may be prescribed by or under any law in that behalf but remains therein beyond the`
  line `permitted period of time;]`
  line
  line `^2[Provided that any person belonging to Hindu, Sikh, Buddhist, Jain, Parsi or Christian`
  line `community from Afghanistan, Bangladesh or Pakistan, who entered into India on or before the`
  line `31st day of December, 2014 and who has been exempted by the Central Government by or under`
  line `clause (c) of sub-section (2) of section 3 of the Passport (Entry into India) Act, 1920 (34 of 1920)`
  line `or from the application of the provisions of the Foreigners Act, 1946 (31 of 1946) or any rule or`
  line `order made there under, shall not be treated as illegal migrant for the purposes of this Act;]`
  line
  line `(d) "Indian consulate means the office of any consular officer of the Government of India`
  line `where a register of births is kept, or where there is no such office, such office as may be`
  line prescribed;
  line
  line `(e) "minor" means a person who has not attained the age of eighteen years;`
  line
  line `^3[(ee) "Overseas Citizen of India Cardholder" means a person registered as an Overseas`
  line `Citizen of India Cardholder by the Central Government under section 7A;]`
  line
  line `(f) "person" does not include any company or association or body of individuals, whether`
  line `incorporated or not;`
  line
  line `(g) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^4* * * * *`
  line
  line `(h) "undivided India" means India as defined in the Government of India Act, 1935, as`
  line `originally enacted.`
  line
  line `(2) For the purposes of this Act, a person born aboard a registered ship or aircraft, or aboard an`
  line `unregistered ship or aircraft of the government of any country, shall be deemed to have been born in`
  line `the place in which the ship or aircraft was registered or, as the case may be, in that country.`
  line
  line `(3) Any reference in this Act to the status or description of the father of a person at the time of`
  line `that person's birth shall, in relation to a person born after the death of his father, be construed as a`
  line `reference to the status or description of the father at the time of the father's death; and where that`
  line `death occurred before, and the birth occurs after, the commencement of this Act, the status or`
  line `description which would have been applicable to the father had he died after the commencement of`
  line `this Act shall be deemed to be the status or description applicable to him at the time of his death.`
  line
  line `(4) For the purposes of this Act, a person shall be deemed to be of full age if he is not a minor and`
  line `of full capacity if he is not of unsound mind.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 6 of 2004, s. 2, for clauses (b) and (c) (w.e.f. 3-12-2004).`
  line
  line `2.Ins. by Act 47 of 2019, s. 2 (w.e.f. 10-1-2020).`
  line
  line `3. Subs. by Act 1 of 2015, s. 2, for clause (ee) (w.e.f. 6-1-2015).`
  line
  line `4. Omitted by Act 32 of 2005, s. 2 (w.e.f. 28-6-2005).`
obj_root_law_sections_3:
  sectionId (14348)
  sectionNo (3)
  orderNo 3
  title `Citizenship by birth.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 6 of 2004, s. 3, for section 3 (w.e.f. 3-12-2004)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14348&sectionno=3&orderno=3&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_3_content:
  string
  line `^1[3. Citizenship by birth.―(1) Except as provided in sub-section (2), every person born in`
  line India―
  line
  line `(a) on or after the 26th day of January, 1950, but before the 1st day of July, 1987;`
  line
  line `(b) on or after the 1st day of July, 1987, but before the commencement of the Citizenship`
  line `(Amendment) Act, 2003 (6 of 2004) and either of whose parents is a citizen of India at the time of`
  line `his birth;`
  line
  line `(c) on or after the commencement of the Citizenship (Amendment) Act, 2003 (6 of 2004),`
  line where―
  line
  line `(i) both of his parents are citizens of India; or`
  line
  line `(ii) one of whose parents is a citizen of India and the other is not an illegal migrant at the`
  line `time of his birth,`
  line
  line `shall be a citizen of India by birth.`
  line
  line `(2) A person shall not be a citizen of India by virtue of this section if at the time of his birth―`
  line
  line `(a) either his father or mother possesses such immunity from suits and legal process as is`
  line `accorded to an envoy of a foreign sovereign power accredited to the President of India and he or`
  line `she, as the case may be, is not a citizen of India; or`
  line
  line `(b) his father or mother is an enemy alien and the birth occurs in a place then under`
  line `occupation by the enemy.]`
obj_root_law_sections_4:
  sectionId (14349)
  sectionNo (4)
  orderNo 4
  title `Citizenship by descent.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14349&sectionno=4&orderno=4&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_4_content:
  string
  line `^1[(1) A person born outside India shall be a citizen of India by`
  line descent,--
  line
  line `(a) on or after the 26th day of January, 1950, but before the 10th day of December, 1992, if`
  line `his father is a citizen of India at the time of his birth; or`
  line
  line `(b) on or after the 10th day of December, 1992, if either of his parents is a citizen of India at`
  line `the time of his birth:`
  line
  line `Provided that if the father of a person referred to in clause (a) was a citizen of India by descent`
  line `only, that person shall not be a citizen of India by virtue of this section unless--`
  line
  line `(a) his birth is registered at an Indian consulate within one year of its occurrence or the`
  line `commencement of this Act, whichever is later, or, with the permission of the Central Government,`
  line `after the expiry of the said period; or`
  line
  line `(b) his father is, at the time of his birth, in service under a Government in India:`
  line
  line `Provided further that if either of the parents of a person referred to in clause (b) was a citizen of`
  line `India by descent only, that person shall not be a citizen of India by virtue of this section, unless--`
  line
  line `(a) his birth is registered at an Indian consulate within one year of its occurrence or on or after`
  line `the 10th day of December, 1992, whichever is later, or, with the permission of the Central`
  line `Government, after the expiry of the said period; or`
  line
  line `(b) either of his parents is, at the time of his birth, in service under a Government in India:`
  line
  line `Provided also that on or after the commencement of the Citizenship (Amendment) Act, 2003(6 of`
  line `2004), a person shall not be a citizen of India by virtue of this section, unless his birth is registered at`
  line `an Indian consulate in such form and in such manner, as may be prescribed,--`
  line
  line `(i) within one year of its occurrence or the commencement of the Citizenship (Amendment)`
  line `Act, 2003(6 of 2004), whichever is later; or`
  line
  line `(ii) with the permission of the Central Government, after the expiry of the said period:`
  line
  line `Provided also that no such birth shall be registered unless the parents of such person declare, in`
  line `such form and in such manner as may be prescribed, that the minor does not hold the passport of`
  line `another country.`
  line
  line `(1A) A minor who is a citizen of India by virtue of this section and is also a citizen of any other`
  line `country shall cease to be a citizen of India if he does not renounce the citizenship or nationality of`
  line `another country within six months of attaining full age.]`
  line
  line `(2) If the Central Government so directs, a birth shall be deemed for the purposes of this section`
  line `to have been registered with its permission, notwithstanding that its permission was not obtained`
  line `before the registration.`
  line
  line `(3) For the purposes of the proviso to sub-section @I@(1)@/I@, ^2[any person] born outside undivided India`
  line `who was, or was deemed to be, a citizen of India at the commencement of the Constitution shall be`
  line `deemed to be a citizen of India by descent only.`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by s. 4,ibid., for sub-section (1) (w.e.f. 3-12-2004)`
  line `2. Subs. by Act 39 of 1992, s. 2, for "any male person".`
obj_root_law_sections_5:
  sectionId (14350)
  sectionNo (5)
  orderNo 5
  title `Citizenship by registration.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14350&sectionno=5&orderno=5&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_5_content:
  string
  line `^1[(1) Subject to the provisions of this section and such other`
  line `conditions and restrictions as may be prescribed, the Central Government may, on an application`
  line `made in this behalf, register as a citizen of India any person not being an illegal migrant who is not`
  line `already such citizen by virtue of the Constitution or of any other provision of this Act if he belongs to`
  line `any of the following categories, namely:--`
  line
  line `(a) a person of Indian origin who is ordinarily resident in India for seven years before`
  line `making an application for registration;`
  line
  line `(b) a person of Indian origin who is ordinarily resident in any country or place outside`
  line `undivided India;`
  line
  line `(c) a person who is married to a citizen of India and is ordinarily resident in India for seven`
  line `years before making an application for registration;`
  line
  line `(d) minor children of persons who are citizens of India;`
  line
  line `(e) a person of full age and capacity whose parents are registered as citizens of India under`
  line `clause (a) of this sub-section or sub-section (1) of section 6;`
  line
  line `(f) a person of full age and capacity who, or either of his parents, was earlier citizen of`
  line `independent India, and ^2[is ordinarily resident in India for twelve months] immediately before`
  line `making an application for registration;`
  line
  line `(g) a person of full age and capacity who has been registered as an ^3[Overseas Citizen of`
  line `India Cardholder] for five years, and who ^4[is ordinarily resident in India for twelve months]`
  line `before making an application for registration.`
  line
  line `Explanation 1.--For the purposes of clauses (a) and (c), an applicant shall be deemed to be`
  line `ordinarily resident in India if--`
  line
  line `(i) he has resided in India throughout the period of twelve months immediately before making`
  line `an application for registration; and`
  line
  line `(ii) he has resided in India during the eight years immediately preceding the said period of`
  line `twelve months for a period of not less than six years.`
  line
  line `Explanation 2.--For the purposes of this sub-section, a person shall be deemed to be of Indian`
  line `origin if he, or either of his parents, was born in undivided India or in such other territory which`
  line `became part of India after the 15th day of August, 1947.]`
  line
  line `^5[(1A) The Central Government, if it is satisfied that special circumstances exist, may after`
  line `recording the circumstances in writing, relax the period of twelve months, specified in clauses (f) and`
  line `(g) and clause (i) of Explanation 1 of sub-section (1), up to a maximum of thirty days which may be`
  line `in different breaks.]`
  line
  line `(2) No person being of full age shall be registered as a citizen of India under sub-section (1) until`
  line `he has taken the oath of allegiance in the form specified in the Second Schedule.`
  line
  line `(3) No person who has renounced, or has been deprived of, his Indian citizenship or whose Indian`
  line `citizenship has terminated, under this Act shall be registered as a citizen of India under sub-section (1)`
  line `except by order of the Central Government.`
  line
  line `(4) The Central Government may, if satisfied that there are special circumstances justifying such`
  line `registration, cause any minor to be registered as a citizen of India.`
  line
  line `(5) A person registered under this section shall be a citizen of India by registration as from the`
  line `date on which he is so registered; and a person registered under the provisions of clause (b)(ii) of`
  line `article 6 or article 8 of the Constitution shall be deemed to be a citizen of India by registration as from`
  line `the commencement of the Constitution or the date on which he was so registered, whichever may be`
  line later.
  line
  line `^6[(6) If the Central Government is satisfied that circumstances exist which render it necessary to`
  line `grant exemption from the residential requirement under clause (c) of sub-section (1) to any person or`
  line `a class of persons, it may, for reasons to be recorded in writing, grant such exemption.].`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 6 of 2004, s. 5, for sub-section (1) (w.e.f. 3-12-2004).`
  line
  line `2. Subs. by Act 1 of 2015, s. 3, for "has been residing in India for one year" (w.e.f. 6-1-2015).`
  line
  line `3. Subs. by s. 3, ibid., for "Overseas Citizen of India" (w.e.f. 6-1-2015).`
  line
  line `4. Subs. by s.3, ibid., for "has been residing in India for one year" (w.e.f. 6-1-2015).`
  line
  line `5. Ins. by Act 1 of 2015, s. 3 (w.e.f. 6-1-2015).`
  line
  line `6. Ins. by Act 6 of 2004, s. 5 (w.e.f. 3-12-2004)`
obj_root_law_sections_6:
  sectionId (14351)
  sectionNo (6)
  orderNo 6
  title `Citizenship by naturalization.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by s. 6, ibid., for "who is not a citizen of a country specified in the First Schedule" (w.e.f. 3-12-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14351&sectionno=6&orderno=6&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_6_content:
  string
  line `(1) Where an application is made in the prescribed manner by`
  line `any person of full age and capacity ^1[not being an illegal migrant] for the grant of a certificate of`
  line `naturalisation to him, the Central Government may, if satisfied that the applicant is qualified for`
  line `naturalisation under the provisions of the Third Schedule, grant to him a certificate of naturalisation:`
  line
  line `Provided that, if in the opinion of the Central Government, the applicant is a person who has`
  line `rendered distinguished service to the cause of science, philosophy, art, literature, world peace or`
  line `human progress generally, it may waive all or any of the conditions specified in the Third Schedule.`
  line
  line `(2) The person to whom a certificate of naturalisation is granted under sub-section (1) shall, on`
  line `taking the oath of allegiance in the form specified in the Second Schedule, be a citizen of India by`
  line `naturalisation as from the date on which that certificate is granted.`
obj_root_law_sections_6_a:
  sectionId (14352)
  sectionNo 6A
  orderNo 7
  title `Special provisions as to citizenship of persons covered by the Assam Accord.`
  content obj_root_law_sections_6_a_content
  footnotes `1. Ins. by Act 65 of 1985, s. 2 (w.e.f. 7-12-1985).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14352&sectionno=6A&orderno=7&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_6_a_content:
  string
  line `^1[6A. Special provisions as to citizenship of persons covered by the Assam Accord.―(1) For`
  line `the purposes of this section`
  line
  line `(a) "Assam" means the territories included in the State of Assam immediately before the`
  line `commencement of the Citizenship (Amendment) Act, 1985 (65 of 1985);`
  line
  line `(b) "detected to be a foreigner" means detected to be a foreigner in accordance with the`
  line `provisions of the Foreigners Act, 1946 (31 of 1946) and the Foreigners (Tribunals) Order, 1964`
  line `by a Tribunal constituted under the said Order;`
  line
  line `(c) "specified territory" means the territories included in Bangladesh immediately before the`
  line `commencement of the Citizenship (Amendment) Act, 1985 (65 of 1985);`
  line
  line `(d) a person shall be deemed to be Indian origin, if he, or either of his parents or any of his`
  line `grandparents was born in undivided India;`
  line
  line `(e) a person shall be deemed to have been detected to be a foreigner on the date on which a`
  line `Tribunal constituted under the Foreigners (Tribunals) Order, 1964 submits its opinion to the effect`
  line `that he is a foreigner to the officer or authority concerned.`
  line
  line `(2) Subject to the provisions of sub-sections (6) and (7), all persons of Indian origin who came`
  line `before the lst day of January, 1966 to Assam from the specified territory (including such of those`
  line `whose names were included in the electoral rolls used for the purposes of the General Election to the`
  line `House of the People held in 1967) and who have been ordinarily resident in Assam since the dates of`
  line `their entry into Assam shall be deemed to be citizens of India as from the lst day of January, 1966.`
  line
  line `(3) Subject to the provisions of sub-sections (6) and (7), every person of Indian origin who―`
  line
  line `(a) came to Assam on or after the lst day of January, 1966 but before the 25th day of March,`
  line `1971 from the specified territory; and`
  line
  line `(b) has, since the date of his entry into Assam, been ordinarily resident in Assam; and`
  line
  line `(c) has been detected to be a foreigner;`
  line
  line `shall register himself in accordance with the rules made by the Central Government in this behalf`
  line `under section 18 with such authority (hereafter in this sub-section referred to as the registering`
  line `authority) as may be specified in such rules and if his name is included in any electoral roll for any`
  line `Assembly or Parliamentary constituency in force on the date of such detection, his name shall be`
  line `deleted therefrom.`
  line
  line `Explanation.―In the case of every person seeking registration under this sub-section, the opinion`
  line `of the Tribunal constituted under the Foreigners (Tribunals) Order, 1964 holding such person to be a`
  line `foreigner, shall be deemed to be sufficient proof of the requirement under clause (c) of this subsection`
  line `and if any question arises as to whether such person complies with any other requirement`
  line `under this sub-section, the registering authority shall,―`
  line
  line `(i) if such opinion contains a finding with respect to such other requirement, decide the`
  line `question in conformity with such finding;`
  line
  line `(ii) if such opinion does not contain a finding with respect to such other requirement, refer the`
  line `question to a Tribunal constituted under the said Order hang jurisdiction in accordance with such`
  line `rules as the Central Government may make in this behalf under section 18 and decide the question`
  line `in conformity with the opinion received on such reference.`
  line
  line `(4) A person registered under sub-section (3) shall have, as from the date on which he has been`
  line `detected to be a foreigner and till the expiry of a period of ten years from that date, the same rights`
  line `and obligations as a citizen of India (including the right to obtain a passport under the Passports Act,`
  line `1967 (15 of 1967) and the obligations connected therewith), but shall not entitled to have his name`
  line `included in any electoral roll for any Assembly or Parliamentary constituency at any time before the`
  line `expiry of the said period of ten years.`
  line
  line `(5) A person registered under sub-section (3) shall be deemed to be a citizen of India for all`
  line `purposes as from the date of expiry of a period of ten years from the date on which he has been`
  line `detected to be a foreigner.`
  line
  line `(6) Without prejudice to the provisions of section 8―`
  line
  line `(a) if any person referred to in sub-section (2) submits in the prescribed manner and form and`
  line `to the prescribed authority within sixty days from the date of commencement of the Citizenship`
  line `(Amendment) Act, 1985 (65 of 1985), a declaration that he does not wish to be a citizen of India,`
  line `such person shall not be deemed to have become a citizen of India under that sub-section;`
  line
  line `(b) if any person referred to in sub-section (3) submits in the prescribed manner and form and`
  line `to the prescribed authority within sixty days from the date of commencement of the Citizenship`
  line `(Amendment) Act, 1985(65 of 1985), or from the date on which he has been detected to be a`
  line `foreigner, whichever is later, a declaration that he does not wish to be governed by the provisions`
  line `of that sub-section and sub-sections (4) and (5), it shall not be necessary for such person to`
  line `register himself under sub-section (3).`
  line
  line `Explanation.―Where a person required to file a declaration under this sub-section does not have`
  line `the capacity to enter into a contract, such declaration may be filed on his behalf by any person`
  line `competent under the law for the time being in force to act on his behalf.`
  line
  line `(7) Nothing in sub-sections (2) to (6) shall apply in relation to any person―`
  line
  line `(a) who, immediately before the commencement of the Citizenship (Amendment) Act, 1985`
  line `(65 of 1985), is a citizen of India;`
  line
  line `(b) who was expelled from India before the commencement of the Citizenship (Amendment)`
  line `Act, 1985, under the Foreigners Act, 1946 (31 of 1946).`
  line
  line `(8) Save as otherwise expressly provided in this section, the provisions of this section shall have`
  line `effect notwithstanding anything contained in any other law for the time being in force.]`
obj_root_law_sections_6_b:
  sectionId (49773)
  sectionNo 6B
  orderNo 8
  title `Special provisions as to citizenship of person covered by proviso to clause (b) of sub-section (1) of section 2.`
  content obj_root_law_sections_6_b_content
  footnotes `1. Ins. by Act 47 of 2019, s. 3 (w.e.f. 10-1-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=49773&sectionno=6B&orderno=8&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_6_b_content:
  string
  line `^1[(1) The Central Government or an authority specified by it in this behalf may,`
  line `subject to such conditions, restrictions and manner as may be prescribed, on an application made in this`
  line `behalf, grant a certificate of registration or certificate of naturalisation to a person referred to in the`
  line `proviso to clause (b) of sub-section (1) of section 2.`
  line `(2) Subject to fulfillment of the conditions specified in section 5 or the qualifications for`
  line `naturalisation under the provisions of the Third Schedule, a person granted the certificate of registration`
  line `or certificate of naturalisation under sub-section (1) shall be deemed to be a citizen of India from the date`
  line `of his entry into India.`
  line `(3) On and from the date of commencement of the Citizenship (Amendment) Act, 2019, any`
  line `proceeding pending against a person under this section in respect of illegal migration or citizenship shall`
  line `stand abated on conferment of citizenship to him:`
  line `Provided that such person shall not be disqualified for making application for citizenship under this`
  line `section on the ground that the proceeding is pending against him and the Central Government or authority`
  line `specified by it in this behalf shall not reject his application on that ground if he is otherwise found`
  line `qualified for grant of citizenship under this section:`
  line `Provided further that the person who makes the application for citizenship under this section shall not`
  line `be deprived of his rights and privileges to which he was entitled on the date of receipt of his application`
  line `on the ground of making such application.`
  line `(4) Nothing in this section shall apply to tribal area of Assam, Meghalaya, Mizoram or Tripura as`
  line `included in the Sixth Schedule to the Constitution and the area covered under The Inner Line notified`
  line `under the Bengal Eastern Frontier Regulation, 1873 (Reg. 5 of 1873).]`
obj_root_law_sections_7:
  sectionId (14353)
  sectionNo (7)
  orderNo 9
  title `Citizenship by incorporation of territory.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14353&sectionno=7&orderno=9&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_7_content:
  string
  line `If any territory becomes a part of India, the`
  line `Central Government may, by order notified in the Official Gazette, specify the persons who shall be`
  line `citizens of India by reason of their connection with that territory; and those persons shall be citizens of`
  line `India as from the date to be specified in the order.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_7_a:
  sectionId (14354)
  sectionNo 7A
  orderNo 10
  title `Registration of Overseas Citizen of India Cardholder.`
  content obj_root_law_sections_7_a_content
  footnotes obj_root_law_sections_7_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14354&sectionno=7A&orderno=10&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_7_a_content:
  string
  line `^1[^2[7A. Registration of Overseas Citizen of India Cardholder.--(1) The Central Government`
  line `may, subject to such conditions, restrictions and manner as may be prescribed, on an application made`
  line `in this behalf, register as an Overseas Citizen of India Cardholder--`
  line
  line `(a) any person of full age and capacity,--`
  line
  line `(i) who is a citizen of another country, but was a citizen of India at the time of, or at any`
  line `time after the commencement of the Constitution; or`
  line
  line `(ii) who is a citizen of another country, but was eligible to become a citizen of India at the`
  line `time of the commencement of the Constitution; or`
  line
  line `(iii) who is a citizen of another country, but belonged to a territory that became part of`
  line `India after the 15th day of August, 1947; or`
  line
  line `(iv) who is a child or a grandchild or a great grandchild of such a citizen; or`
  line
  line `(b) a person, who is a minor child of a person mentioned in clause (a); or`
  line
  line `(c) a person, who is a minor child, and whose both parents are citizens of India or one of the`
  line `parents is a citizen of India; or`
  line
  line `(d) spouse of foreign origin of a citizen of India or spouse of foreign origin of an Overseas`
  line `Citizen of India Cardholder registered under section 7A and whose marriage has been registered`
  line `and subsisted for a continuous period of not less than two years immediately preceding the`
  line `presentation of the application under this section:`
  line
  line `Provided that for the eligibility for registration as an Overseas Citizen of India Cardholder, such`
  line `spouse shall be subjected to prior security clearance by a competent authority in India:`
  line
  line `Provided further that no person, who or either of whose parents or grandparents or great`
  line `grandparents is or had been a citizen of Pakistan, Bangladesh or such other country as the Central`
  line `Government may, by notification in the Official Gazette, specify, shall be eligible for registration as`
  line `an Overseas Citizen of India Cardholder under this sub-section.`
  line
  line `(2) The Central Government may, by notification in the Official Gazette, specify the date from`
  line `which the existing persons of Indian Origin Cardholders shall be deemed to be Overseas Citizens of`
  line `India Cardholders.`
  line
  line `Explanation.--For the purposes of this sub-section, "Persons of Indian Origin Cardholders"`
  line `means the persons registered as such under notification number 26011/4/98 F.I., dated the 19th`
  line `August, 2002, issued by the Central Government in this regard.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1), the Central Government may, if it is`
  line `satisfied that special circumstances exist, after recording the circumstances in writing, register a`
  line `person as an Overseas Citizen of India Cardholder]`
obj_root_law_sections_7_a_footnotes:
  string
  line `1. Ins. by Act 6 of 2004, s. 7 (w.e.f. 3-12-2004).`
  line
  line `2. Subs. by Act 1 of 2015, s. 4, for sections 7A, 7B, 7C and 7D (w.e.f. 6-1-2015).`
obj_root_law_sections_7_b:
  sectionId (14355)
  sectionNo 7B
  orderNo 11
  title `Conferment of rights on Overseas Citizen of India Cardholder.`
  content obj_root_law_sections_7_b_content
  footnotes `1. Ins. by Act 6 of 2004, s. 7 (w.e.f. 3-12-2004).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14355&sectionno=7B&orderno=11&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_7_b_content:
  string
  line `^1[7B. Conferment of rights on Overseas Citizen of India Cardholder.-- (1) Notwithstanding`
  line `anything contained in any other law for the time being in force, an Overseas Citizen of India`
  line `Cardholder shall be entitled to such rights, other than the rights specified under sub-section (2), as the`
  line `Central Government may, by notification in the Official Gazette, specify in this behalf.--`
  line
  line `(2) An Overseas Citizen of India Cardholder shall not be entitled to the rights conferred on a`
  line `citizen of India`
  line
  line `(a) under article 16 of the Constitution with regard to equality of opportunity in matters of`
  line `public employment;`
  line
  line `(b) under article 58 of the Constitution for election as President;`
  line
  line `(c) under article 66 of the Constitution for election as Vice-President;`
  line
  line `(d) under article 124 of the Constitution for appointment as a Judge of the Supreme Court;`
  line
  line `(e) under article 217 of the Constitution for appointment as a Judge of the High Court;`
  line
  line `(f) under section 16 of the Representation of the People Act, 1950 (43 of 1950) in regard to`
  line `registration as a voter;`
  line
  line `(g) under sections 3 and 4 of the Representation of the People Act, 1951 (43 of 1951) with`
  line `regard to the eligibility for being a member of the House of the People or of the Council of States,`
  line `as the case may be;`
  line
  line `(h) under sections 5, 5A and section 6 of the Representation of the People Act, 1951 (43 of`
  line `1951) with regard to the eligibility for being a member of the Legislative Assembly or the`
  line `Legislative Council, as the case may be, of a State;`
  line
  line `(i) for appointment to public services and posts in connection with affairs of the Union or of`
  line `any State except for appointment in such services and posts as the Central Government may, by`
  line `special order in that behalf, specify.`
  line
  line `(3) Every notification issued under sub-section (1) shall be laid before each House of Parliament.]`
obj_root_law_sections_7_c:
  sectionId (14356)
  sectionNo 7C
  orderNo 12
  title `Renunciation of Overseas Citizen of India Card.`
  content obj_root_law_sections_7_c_content
  footnotes `1. Ins. by Act 6 of 2004, s. 7 (w.e.f. 3-12-2004)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14356&sectionno=7C&orderno=12&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_7_c_content:
  string
  line `^1[7C. Renunciation of Overseas Citizen of India Card.-- (1) If any Overseas Citizen of India`
  line `Cardholder of full age and capacity makes in prescribed manner a declaration renouncing the Card`
  line `registering him as an Overseas Citizen of India Cardholder, the declaration shall be registered by the`
  line `Central Government, and upon such registration, that person shall cease to be an Overseas Citizen of`
  line `India Cardholder.`
  line
  line `(2) Where a person ceases to be an Overseas Citizen of India Cardholder under sub-section (1),`
  line `the spouse of foreign origin of that person, who has obtained Overseas Citizen of India Card under`
  line `clause (d) of sub-section (1) of section 7A, and every minor child of that person registered as an`
  line `Overseas Citizen of India Cardholder shall thereupon cease to be an Overseas Citizen of India`
  line Cardholder.]
obj_root_law_sections_7_d:
  sectionId (14357)
  sectionNo 7D
  orderNo 13
  title `Cancellation of registration as Overseas Citizen of India Cardholder.`
  content obj_root_law_sections_7_d_content
  footnotes obj_root_law_sections_7_d_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14357&sectionno=7D&orderno=13&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_7_d_content:
  string
  line `^1[7D. Cancellation of registration as Overseas Citizen of India Cardholder.--The Central`
  line `Government may, by order, cancel the registration granted under sub-section (1) of section 7A, if it is`
  line `satisfied that--`
  line
  line `(a) the registration as an Overseas Citizen of India Cardholder was obtained by means of`
  line `fraud, false representation or the concealment of any material fact; or`
  line
  line `(b) the Overseas Citizen of India Cardholder has shown disaffection towards the Constitution,`
  line `as by law established; or`
  line
  line `(c) the Overseas Citizen of India Cardholder has, during any war in which India may be`
  line `engaged, unlawfully traded or communicated with an enemy or been engaged in, or associated`
  line `with, any business or commercial activity that was to his knowledge carried on in such manner as`
  line `to assist an enemy in that war; or`
  line
  line `(d) the Overseas Citizen of India Cardholder has, within five years after registration under`
  line `sub-section (1) of section 7A, been sentenced to imprisonment for a term of not less than two`
  line `years; or`
  line
  line `^2[(da) the Overseas Citizen of India Cardholder has violated any of the provisions of this Act or`
  line `provisions of any other law for time being in force as may be specified by the Central Government in`
  line `the notification published in the Official Gazette; or;]`
  line
  line `(e) it is necessary so to do in the interests of the sovereignty and integrity of India, the`
  line `security of India, friendly relations of India with any foreign country, or in the interests of the`
  line `general public; or`
  line
  line `(f) the marriage of an Overseas Citizen of India Cardholder, who has obtained such Card`
  line `under clause (d) of sub-section (1) of section 7A,`
  line
  line `(i) has been dissolved by a competent court of law or otherwise; or`
  line
  line `(ii) has not been dissolved but, during the subsistence of such marriage, he has`
  line `solemnised marriage with any other person.`
  line
  line `^2[Provided that no order under this section shall be passed unless the Overseas Citizen of`
  line `India Cardholder has been given a reasonable opportunity of being heard.]`
obj_root_law_sections_7_d_footnotes:
  string
  line `1. Ins. by Act 6 of 2004, s. 7 (w.e.f. 3-12-2004)`
  line
  line `2. Ins. by Act 47 of 2019, s. 4 (w.e.f. 10-1-2020).`
obj_root_law_sections_8:
  sectionId (14358)
  sectionNo (8)
  orderNo 14
  title `Renunciation of citizenship.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14358&sectionno=8&orderno=14&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_8_content:
  string
  line `(1) If any citizen of India of full age and capacity, ^1* * *, makes`
  line `in the prescribed manner a declaration renouncing his Indian Citizenship, the declaration shall be`
  line `registered by the prescribed authority; and, upon such registration, that person shall cease to be a`
  line `citizen of India:`
  line
  line `Provided that if any such declaration is made during any war in which India may be engaged,`
  line `registration thereof shall be withheld until the Central Government otherwise directs.`
  line
  line `(2) Where ^2[a person] ceases to be a citizen of India under sub-section (1), every minor child of`
  line `that person shall thereupon cease to be a citizen of India:`
  line
  line `Provided that any such child may, within one year after attaining full age, make a declaration ^3[in`
  line `the prescribed form and manner] that he wishes to resume Indian citizenship and shall thereupon`
  line `again become a citizen of India.`
  line
  line `^4* * * * *`
obj_root_law_sections_8_footnotes:
  string
  line `1. The words "who is also a citizen or national of another country" omitted by Act 6 of 2004, s. 8 (w.e.f. 3-12-2004).`
  line
  line `2. Subs. by Act 39 of 1992, s. 3, for "a male person" (w.e.f. 10-12-1987).`
  line
  line `3. Ins. by Act 6 of 2004, s. 8 (w.e.f. 3-12-2014).`
  line
  line `4. Omitted by s. 8, ibid. (w.e.f. 3-12-2004).`
obj_root_law_sections_9:
  sectionId (14359)
  sectionNo (9)
  orderNo 15
  title `Termination of citizenship.`
  content obj_root_law_sections_9_content
  footnotes `1. Subs. by s. 9, ibid., for "person" (w.e.f. 3-12-2004)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14359&sectionno=9&orderno=15&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_9_content:
  string
  line `(1) Any citizen of India who by naturalisation, registration`
  line `otherwise voluntarily acquires, or has at any time between the 26th January, 1950 and the`
  line `commencement of this Act, voluntarily acquired, the citizenship of another country shall, upon such`
  line `acquisition or, as the case may be, such commencement, cease to be a citizen of India:`
  line
  line `Provided that nothing in this sub-section shall apply to a citizen of India who, during any war in`
  line `which India may be engaged, voluntarily acquires the citizenship of another country, until the Central`
  line `Government otherwise directs.`
  line
  line `(2) If any question arises as to whether, when or how any ^1`
  line `[citizen of India] has acquired the`
  line `citizenship of another country, it shall be determined by such authority, in such manner, and having`
  line `regard to such rules of evidence, as may be prescribed in this behalf.`
obj_root_law_sections_10:
  sectionId (14360)
  sectionNo (10)
  orderNo 16
  title `Deprivation of citizenship.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00001_195557_1517807319455&sectionId=14360&sectionno=10&orderno=16&orgactid=AC_CEN_5_40_00001_195557_1517807319455
obj_root_law_sections_10_content:
  string
  line `(1) A citizen of India who is such by naturalisation or by virtue`
  line `only of clause (c) of article 5 of the Constitution or by registration otherwise than under clause (b)(ii)`
  line `of article 6 of the Constitution or clause (a) of sub-section (1) of section 5 of this Act, shall cease to`
  line `be a citizen of India, if he is deprived of that citizenship by an order of the Central Government under`
  line `this section.`
  line
  line `(2) Subject to the provisions of this section, the Central Government may, by order, deprive any`
  line `such citizen of Indian citizenship, if it is satisfied that―`
  line
  line `(a) the registration or certificate of naturalisation was obtained by means of fraud, false`
  line `representation or the concealment of any material fact; or`
  line
  line `(b) that citizen has shown himself by act or speech to be disloyal or disaffected towards the`
  line `Constitution of India as by law established; or`
  line
  line `(c) that citizen has, during any war in which India may be engaged, unlawfully traded or`
  line `communicated with an enemy or been engaged in, or associated with, any business that was to his`
  line `knowledge carried on in such manner as to assist an enemy in that war; or`
  line
  line `(d) that citizen has, within five years after registration or naturalisation, been sentenced in any`
  line `country to imprisonment for a term of not less than two years; or`
  line
  line `(e) that citizen has been ordinarily resident out of India for a continuous period of seven`
  line `years, and during that period, has neither been at any time a student of any educational institution`
  line `in a country outside India or in the service of a Government in India or of an international`
  line `organisation of which India is a member, not registered annually in the prescribed manner at an`
  line `Indian consulate his intention to retain his citizenship of India.`
  line
  line `(3) The Central Government shall not deprive a person of citizenship under this section unless it is`
  line `satisfied that it is not conducive to the public good that person should continue to be a citizen of India.`
  line
  line `(4) Before making an order under this section, the Central Government shall give the person`
  line `against whom the order is proposed to be made notice in writing informing him of the ground on`
  line `which it is proposed to be made and, if the order is proposed to be made on any of the grounds`
  line `specified in sub-section (2) other than clause (e) thereof, of his right, upon making application`
  line `therefore in the prescribed manner, to have his case referred to a committee of inquiry under this`
  line section.
  line
  line `(5) If the order is proposed to be made against a person on any of the grounds specified in subsection`
  line `(2) other than clause (e) thereof and that person so applies in the prescribed manner, the`
  line `Central Government shall, and in any other case it may, refer the case to a Committee of Inquiry`
  line `consisting of a chairman (being a person who has for at least ten years held a judicial office) and two`
  line `other members appointed by the Central Government in this behalf.`
  line
  line `(6) The Committee of Inquiry shall, on such reference, hold the inquiry in such manner as may be`
  line `prescribed and submit its report to the Central Government; and the Central Government shall`
  line `ordinarily be guided by such report in making an order under this section.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
