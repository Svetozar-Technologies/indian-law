  object
  (str hi) obj_root_law_translations_hi
obj_root_law_translations_hi:
  object
  (str title) (str `नागरिकता अधिनियम, 1955`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1522/2/H1955-57.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T10:14:05.258Z`)
  (str pageCount) (int 13)
  (str sections) obj_root_law_translations_hi_sections
