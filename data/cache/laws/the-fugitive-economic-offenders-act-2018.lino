obj_root_law_sections_1:
  sectionId (31984)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31984&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Fugitive Economic`
  line `Offenders Act, 2018.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall be deemed to have come into force on the 21st day of April, 2018.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (31985)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31985&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Administrator" means an Administrator appointed under sub-section (1) of section 15;`
  line
  line `(b) "benami property" and 'benami transaction" shall have the same meanings as assigned to`
  line `them under clauses (8) and (9) respectively of section 2 of the Prohibition of Benami Property`
  line `Transactions Act, 1988 (45 of 1988);`
  line
  line `(c) "contracting State" means any country or place outside India in respect of which`
  line `arrangements have been made by the Central Government with the Government of such country`
  line `through a treaty or otherwise;`
  line
  line `(d) "Deputy Director" means the Deputy Director appointed under sub-section (1) of section 49`
  line `of the Prevention of Money-laundering Act, 2002 (15 of 2003);`
  line
  line `(e) "Director" means the Director appointed under sub-section (1) of section 49 of the`
  line `Prevention of Money-laundering Act, 2002 (15 of 2003);`
  line
  line `(f) "fugitive economic offender" means any individual against whom a warrant for arrest in`
  line `relation to a Scheduled Offence has been issued by any Court in India, who`
  line
  line `(i) has left India so as to avoid criminal prosecution; or`
  line
  line `(ii) being abroad, refuses to return to India to face criminal prosecution;`
  line
  line `(g) "key managerial personnel" shall have the same meaning as assigned to it in clause (51) of`
  line `section 2 of the Companies Act, 2013 (18 of 2013);`
  line
  line `(h) "notification" means a notification published in the Official Gazette and the expression`
  line `"notify" shall be construed accordingly;`
  line
  line `(i) "person" includes--`
  line
  line `(i) an individual;`
  line
  line `(ii) a Hindu Undivided Family;`
  line
  line `(iii) a company;`
  line
  line `(iv) a trust;`
  line
  line `(v) a partnership;`
  line
  line `(vi) a limited liability partnership;`
  line
  line `(vii) an association of persons or a body of individuals, whether incorporated or not;`
  line
  line `(viii) every artificial juridical person not falling within any of the preceding sub-clauses; and`
  line
  line `(ix) any agency, office or branch owned or controlled by any of the above persons`
  line `mentioned in the preceding sub-clauses;`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(k) "proceeds of crime" means any property derived or obtained, directly or indirectly, by any`
  line `person as a result of criminal activity relating to a Scheduled Offence, or the value of any such`
  line `property, or where such property is taken or held outside the country, then the property equivalent`
  line `in value held within the country or abroad;`
  line
  line `(l) "Schedule" means the Schedule appended to this Act;`
  line
  line `(m) "Scheduled Offence" means an offence specified in the Schedule, if the total value`
  line `involved in such offence or offences is one hundred crore rupees or more;`
  line
  line `(n) "Special Court" means a Court of Session designated as a Special Court under`
  line `sub-section (1) of section 43 of the Prevention of Money-laundering Act, 2002 (15 of 2003).`
  line
  line `(2) The words and expressions used and not defined in this Act but defined in the Prevention of`
  line `Money-laundering Act, 2002 (15 of 2003) shall have the meanings respectively assigned to them in`
  line `that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (31986)
  sectionNo (3)
  orderNo 3
  title `Application of Act.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31986&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_3_content:
  string
  line `The provisions of this Act shall apply to any individual who is, or`
  line `becomes, a fugitive economic offender on or after the date of coming into force of this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (31987)
  sectionNo (4)
  orderNo 4
  title `Application for declaration of fugitive economic offender and procedure therefor.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31987&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_4_content:
  string
  line `(1) Where the Director or any other officer not below the rank of Deputy Director`
  line `authorised by the Director for the purposes of this section, has reason to believe (the reasons for such`
  line `belief to be recorded in writing), on the basis of material in his possession, that any individual is a`
  line `fugitive economic offender, he may file an application in such form and manner as may be prescribed`
  line `in the Special Court that such individual may be declared as a fugitive economic offender.`
  line
  line `(2) The application referred to in sub-section (1) shall contain––`
  line
  line `(a) reasons for the belief that an individual is a fugitive economic offender;`
  line
  line `(b) any information available as to the whereabouts of the fugitive economic offender;`
  line
  line `(c) a list of properties or the value of such properties believed to be the proceeds of crime,`
  line `including any such property outside India for which confiscation is sought;`
  line
  line `(d) a list of properties or benami properties owned by the individual in India or abroad for`
  line `which confiscation is sought; and`
  line
  line `(e) a list of persons who may have an interest in any of the properties listed under clauses (c)`
  line `and (d).`
  line
  line `(3) The Authorities appointed for the purposes of the Prevention of Money-laundering Act, 2002`
  line `(15 of 2003) shall be the Authorities for the purposes of this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (31988)
  sectionNo (5)
  orderNo 5
  title `Attachment of property.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31988&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_5_content:
  string
  line `(1) The Director or any other officer authorised by the Director, not`
  line `below the rank of Deputy Director, may, with the permission of the Special Court, attach any property`
  line `mentioned in the application under section 4 by an order in writing in such manner as may be`
  line prescribed.
  line
  line `(2) Notwithstanding anything contained in sub-section (1) or section 4, the Director or any other`
  line `officer, not below the rank of Deputy Director, authorised by the Director, may, by an order in`
  line `writing, at any time prior to the filing of the application under section 4, attach any property––`
  line
  line `(a) for which there is a reason to believe that the property is proceeds of crime, or is a property`
  line `or benami property owned by an individual who is a fugitive economic offender; and`
  line
  line `(b) which is being or is likely to be dealt within a manner which may result in the property`
  line `being unavailable for confiscation:`
  line
  line `Provided that the Director or any other officer who provisionally attaches any property under this`
  line `sub-section shall, within a period of thirty days from the date of such attachment, file an application`
  line `under section 4 before the Special Court.`
  line
  line `(3) The attachment of any property under this section shall continue for a period of one hundred`
  line `and eighty days from the date of order of attachment or such other period as may be extended by the`
  line `Special Court before the expiry of such period.`
  line
  line `(4) Nothing in this section shall prevent the person interested in the enjoyment of the immovable`
  line `property attached under sub-section (1) from such enjoyment.`
  line
  line `Explanation.—For the purposes of this sub-section, the expression "person interested", in relation`
  line `to any immovable property includes all persons claiming or entitled to claim any interest in the`
  line property.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (31989)
  sectionNo (6)
  orderNo 6
  title `Powers of Director and other officers.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31989&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_6_content:
  string
  line `The Director or any other officer shall, for the`
  line `purposes of section 4, have the same powers as are vested in a civil court under the Code of Civil`
  line `Procedure, 1908 (5 of 1908) while trying a suit in respect of the following matters, namely:—`
  line
  line `(a) discovery and inspection;`
  line
  line `(b) enforcing the attendance of any person, including any officer of a reporting entity and`
  line `examining him on oath;`
  line
  line `(c) compelling the production of records;`
  line
  line `(d) receiving evidence on affidavits;`
  line
  line `(e) issuing commissions for examination of witnesses and documents; and`
  line
  line `(f) any other matter which may be prescribed.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (31990)
  sectionNo (7)
  orderNo 7
  title `Power of survey.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31990&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_7_content:
  string
  line `(1) Notwithstanding anything contained in any other provisions of this Act,`
  line `where a Director or any other officer authorised by the Director, on the basis of material in his`
  line `possession, has reason to believe (the reasons for such belief to be recorded in writing), that an`
  line `individual may be a fugitive economic offender, he may enter any place—`
  line
  line `(i) within the limits of the area assigned to him; or`
  line
  line `(ii) in respect of which he is authorised for the purposes of this section, by such other authority,`
  line `who is assigned the area within which such place is situated.`
  line
  line `(2) Where the Director or any other officer authorised by him, on the basis of material in his`
  line `possession, has reason to believe (the reasons for such belief to be recorded in writing) that an`
  line `individual may be a fugitive economic offender and it is necessary to enter any place as mentioned in`
  line `sub-section (1), he may request any proprietor, employee or any other person who may be present at`
  line `that time, to—`
  line
  line `(a) afford him the necessary facility to inspect such records as he may require and which may`
  line `be available at such place;`
  line
  line `(b) afford him the necessary facility to check or verify the proceeds of crime or any transaction`
  line `related to proceeds of crime which may be found therein; and`
  line
  line `(c) furnish such information as he may require as to any matter which may be useful for, or`
  line `relevant to any proceedings under this Act.`
  line
  line `(3) The Director, or any other officer acting under this section may—`
  line
  line `(i) place marks of identification on the records inspected by him and make or cause to be`
  line `made extracts or copies therefrom;`
  line
  line `(ii) make an inventory of any property checked or verified by him; and`
  line
  line `(iii) record the statement of any person present at the property which may be useful for, or`
  line `relevant to, any proceeding under this Act.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (31991)
  sectionNo (8)
  orderNo 8
  title `Search and seizure.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31991&sectionno=8&orderno=8&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_8_content:
  string
  line `(1) Notwithstanding anything contained in any other law for the time`
  line `being in force, where the Director or any other officer not below the rank of Deputy Director`
  line `authorised by him for the purposes of this section, on the basis of information in his possession, has`
  line `reason to believe (the reason for such belief to be recorded in writing) that any person—`
  line
  line `(i) may be declared as a fugitive economic offender;`
  line
  line `(ii) is in possession of any proceeds of crime;`
  line
  line `(iii) is in possession of any records which may relate to proceeds of crime; or`
  line
  line `(iv) is in possession of any property related to proceeds of crime,`
  line
  line `then, subject to any rules made in this behalf, he may authorise any officer subordinate to him to—`
  line
  line `(a) enter and search any building, place, vessel, vehicle or aircraft where he has reason to`
  line `suspect that such records or proceeds of crime are kept;`
  line
  line `(b) break open the lock of any door, box, locker, safe, almirah or other receptacle for exercising`
  line `the powers conferred by clause (a) where the keys thereof are not available;`
  line
  line `(c) seize any record or property found as a result of such search;`
  line
  line `(d) place marks of identification on such record or property, if required or make or cause to be`
  line `made extracts or copies therefrom;`
  line
  line `(e) make a note or an inventory of such record or property; and`
  line
  line `(f) examine on oath any person, who is found to be in possession or control of any record or`
  line `property, in respect of all matters relevant for the purposes of any investigation under this Act.`
  line
  line `(2) Where an authority, upon information obtained during survey under section 7, is satisfied that`
  line `any evidence shall be or is likely to be concealed or tampered with, he may, for reasons to be recorded`
  line `in writing, enter and search the building or place where such evidence is located and seize that`
  line evidence.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (31992)
  sectionNo (9)
  orderNo 9
  title `Search of persons.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31992&sectionno=9&orderno=9&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_9_content:
  string
  line `Notwithstanding anything contained in any other law for the time being`
  line `in force—`
  line
  line `(a) if an authority, authorised in this behalf by the Central Government by general or special`
  line `order, has reason to believe (the reason for such belief to be recorded in writing) that any person`
  line `has secreted about his person or anything under his possession, ownership or control, any record or`
  line `proceeds of crime which may be useful for or relevant to any proceedings under this Act, he may`
  line `search that person and seize such record or property which may be useful for or relevant to any`
  line `proceedings under this Act;`
  line
  line `(b) where an authority is about to search any person, he shall, if such person so requires, take`
  line `such person within twenty-four hours to the nearest Gazetted Officer, superior in rank to him, or a`
  line `Magistrate:`
  line
  line `Provided that the period of twenty-four hours shall exclude the time necessary for the journey`
  line `undertaken to take such person to the nearest Gazetted Officer, superior in rank to him, or the`
  line `Magistrate's Court;`
  line
  line `(c) if the requisition under clause (b) is made, the authority shall not detain the person for more`
  line `than twenty-four hours prior to taking him before the Gazetted Officer, superior in rank to him, or`
  line `the Magistrate referred to in that clause:`
  line
  line `Provided that the period of twenty-four hours shall exclude the time necessary for the journey`
  line `from the place of detention to the office of the Gazetted Officer, superior in rank to him, or the`
  line `Magistrate's Court;`
  line
  line `(d) the Gazetted Officer or the Magistrate before whom any such person is brought shall, if he`
  line `sees no reasonable ground for search, forthwith discharge such person but otherwise shall direct`
  line `that search be made;`
  line
  line `(e) before making the search under clause (a) or clause (d), the authority shall call upon two or`
  line `more persons to attend and witness the search and the search shall be made in the presence of such`
  line persons;
  line
  line `(f) the authority shall prepare a list of record or property seized in the course of the search and`
  line `obtain the signatures of the witnesses on the list;`
  line
  line `(g) no female shall be searched by anyone except a female; and`
  line
  line `(h) the authority shall record the statement of the person searched under clause (a) or clause (d)`
  line `in respect of the records or proceeds of crime found or seized in the course of the search.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (31993)
  sectionNo (10)
  orderNo 10
  title Notice.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31993&sectionno=10&orderno=10&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_10_content:
  string
  line `(1) Where an application under section 4 has been duly filed, the Special Court shall`
  line `issue a notice to an individual who is alleged to be a fugitive economic offender.`
  line
  line `(2) The notice referred to in sub-section (1), shall also be issued to any other person who has`
  line `any interest in the property mentioned in the application under sub-section (2) of section 4.`
  line
  line `(3) A notice under sub-section (1) shall---`
  line
  line `(a) require the individual to appear at a specified place and time not less than six weeks`
  line `from the date of issue of such notice; and`
  line
  line `(b) state that failure to appear on the specified place and time shall result in a declaration of`
  line `the individual as a fugitive economic offender and confiscation of property under this Act.`
  line
  line `(4) A notice under sub-section (1) shall be forwarded to such authority, as the Central`
  line `Government may notify, for effecting service in a contracting State.`
  line
  line `(5) The authority referred to in sub-section (4) shall make efforts to serve the notice within a`
  line `period of two weeks in such manner as may be prescribed.`
  line
  line `(6) A notice under sub-section (1) may also be served to the individual alleged to be a fugitive`
  line `economic offender by electronic means to---`
  line
  line `(a) his electronic mail address submitted in connection with an application for allotment of`
  line `Permanent Account Number under section 139A of the Income-tax Act, 1961 (43 of 1961);`
  line
  line `(b) his electronic mail address submitted in connection with an application for enrolment`
  line `under section 3 of the Aadhaar (Targeted Delivery of Financial and Other Subsidies, Benefits`
  line `and Services) Act, 2016 (18 of 2016); or`
  line
  line `(c) any other electronic account as may be prescribed, belonging to the individual which is`
  line `accessed by him over the internet, subject to the satisfaction of the Special Court that such`
  line `account has been recently accessed by the individual and constitutes a reasonable method for`
  line `communication of the notice to the individual.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (31994)
  sectionNo (11)
  orderNo 11
  title `Procedure for hearing application.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31994&sectionno=11&orderno=11&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_11_content:
  string
  line `(1) Where any individual to whom notice has been`
  line `issued under sub-section (1) of section 10 appears in person at the place and time specified in the`
  line `notice, the Special Court may terminate the proceedings under this Act.`
  line
  line `(2) Where any individual to whom notice has been issued under sub-section (1) of section 10 fails`
  line `to appear at the place and time specified in the notice, but enters appearance through counsel, the Special Court may in its discretion give a period of one week to file a reply to the application under`
  line `section 4.`
  line
  line `(3) Where any individual to whom notice has been issued under sub-section (1) of section 10 fails`
  line `to enter appearance either in person or through counsel, and the Special Court is satisfied—`
  line
  line `(a) that service of notice has been effected on such party; or`
  line
  line `(b) that notice could not be served in spite of best efforts because such individual has evaded`
  line `service of notice,`
  line
  line `it may, after recording reasons in writing, proceed to hear the application.`
  line
  line `(4) The Special Court may also give any person to whom notice has been issued under`
  line `sub-section (2) of section 10 a period of one week to file a reply to the application under section 4.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (31995)
  sectionNo (12)
  orderNo 12
  title `Declaration of fugitive economic offender.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31995&sectionno=12&orderno=12&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_12_content:
  string
  line `(1) After hearing the application under`
  line `section 4, if the Special Court is satisfied that an individual is a fugitive economic offender, it may, by`
  line `an order, declare the individual as a fugitive economic offender for reasons to be recorded in writing.`
  line
  line `(2) On a declaration under sub-section (1), the Special Court may order that any of the following`
  line `properties stand confiscated to the Central Government—`
  line
  line `(a) the proceeds of crime in India or abroad, whether or not such property is owned by the`
  line `fugitive economic offender; and`
  line
  line `(b) any other property or benami property in India or abroad, owned by the fugitive economic`
  line offender.
  line
  line `(3) The confiscation order of the Special Court shall, to the extent possible, identify the properties`
  line `in India or abroad that constitute proceeds of crime which are to be confiscated and in case such`
  line `properties cannot be identified, quantify the value of the proceeds of crime.`
  line
  line `(4) The confiscation order of the Special Court shall separately list any other property owned by`
  line `the fugitive economic offender in India which is to be confiscated.`
  line
  line `(5) Where the Special Court has made an order for confiscation of any property under`
  line `sub-section (2), and such property is in a contracting State, the Special Court may issue a letter of`
  line `request to a Court or authority in the contracting State for execution of such order.`
  line
  line `(6) Every letter of request to be transmitted to a contracting State under sub-section (5) shall be`
  line `transmitted in such form and manner as the Central Government may, by notification, specify in this`
  line behalf.
  line
  line `(7) The Special Court may, while making the confiscation order, exempt from confiscation any`
  line `property which is a proceed of crime in which any other person, other than the fugitive economic`
  line `offender, has an interest if it is satisfied that such interest was acquired bona fide and without`
  line `knowledge of the fact that the property was proceeds of crime.`
  line
  line `(8) All the rights and title in the confiscated property shall, from the date of the confiscation order,`
  line `vest in the Central Government, free from all encumbrances.`
  line
  line `(9) Where on the conclusion of the proceedings, the Special Court finds that the individual is not a`
  line `fugitive economic offender, the Special Court shall order release of property or record attached or`
  line `seized under this Act to the person entitled to receive it.`
  line
  line `(10) Where an order releasing the property has been made by the Special Court under`
  line `sub-section (9), the Director or any other officer authorised by him in this behalf may withhold the`
  line `release of any such property or record for a period of ninety days from the date of receipt of such`
  line `order, if he is of the opinion that such property is relevant for the appeal proceedings under this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (31996)
  sectionNo (13)
  orderNo 13
  title `Supplementary application.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31996&sectionno=13&orderno=13&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_13_content:
  string
  line `(1) Where at any time after the institution of the application`
  line `under section 4, any other property is discovered or identified which constitutes proceeds of crime or`
  line `is property or benami property owned by the individual in India or abroad who is a fugitive economic offender liable to be confiscated under this Act, the Director or any other officer not below the rank of`
  line `Deputy Director authorised by the Director for the purposes of this section, may file a supplementary`
  line `application in the Special Court seeking confiscation of such properties.`
  line
  line `(2) The provisions of sections 4 to 12 shall, as far as may be, apply in relation to such application`
  line `as they apply in relation to an application under section 4.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (31997)
  sectionNo (14)
  orderNo 14
  title `Power to disallow civil claims.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31997&sectionno=14&orderno=14&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_14_content:
  string
  line `Notwithstanding anything contained in any other law for the`
  line `time being in force,—`
  line
  line `(a) on a declaration of an individual as a fugitive economic offender, any Court or tribunal in`
  line `India, in any civil proceeding before it, may, disallow such individual from putting forward or`
  line `defending any civil claim; and`
  line
  line `(b) any Court or tribunal in India in any civil proceeding before it, may, disallow any company`
  line `or limited liability partnership from putting forward or defending any civil claim, if an individual`
  line `filing the claim on behalf of the company or the limited liability partnership, or any promoter or`
  line `key managerial personnel or majority shareholder of the company or an individual having a`
  line `controlling interest in the limited liability partnership has been declared as a fugitive economic`
  line offender.
  line
  line `Explanation.—For the purposes of this section, the expressions—`
  line
  line `(a) "company" means any body corporate and includes a firm, or other association of`
  line `persons; and`
  line
  line `(b) "limited liability partnership" shall have the same meaning as assigned to it in clause (n)`
  line `of sub-section (1) of section 2 of the Limited Liability Partnership Act, 2008 (6 of 2009).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (31998)
  sectionNo (15)
  orderNo 15
  title `Management of properties confiscated under this Act.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31998&sectionno=15&orderno=15&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_15_content:
  string
  line `(1) The Central Government`
  line `may, by order published in the Official Gazette, appoint as many of its officers (not below the rank`
  line `of a Joint Secretary to the Government of India) as it thinks fit, to perform the functions of an`
  line Administrator.
  line
  line `(2) The Administrator appointed under sub-section (1) shall receive and manage the property in`
  line `relation to which an order has been made under sub-section (2) of section 12 in such manner and`
  line `subject to such conditions as may be prescribed.`
  line
  line `(3) The Administrator shall also take such measures, as the Central Government may direct, to`
  line `dispose of the property which is vested in the Central Government under section 12:`
  line
  line `Provided that the Central Government or the Administrator shall not dispose of any property for`
  line `a period of ninety days from the date of the order under sub-section (2) of section 12.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (31999)
  sectionNo (16)
  orderNo 16
  title `Rules of evidence.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=31999&sectionno=16&orderno=16&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_16_content:
  string
  line `(1) The burden of proof for establishing—`
  line
  line `(a) that an individual is a fugitive economic offender; or`
  line
  line `(b) that a property is the proceeds of crime or any other property in which the individual alleged`
  line `to be a fugitive economic offender has an interest,`
  line
  line `shall be on the Director or the person authorised by the Director to file the application under section 4.`
  line
  line `(2) Notwithstanding anything contained in any other law for the time being in force, where any`
  line `person referred to in sub-section (2) of section 10 claims that any interest in any property was`
  line `acquired bona fide and without knowledge of the fact that, such property constitutes proceeds of`
  line `crime, the burden of proving such fact shall lie upon him.`
  line
  line `(3) The standard of proof applicable to the determination of facts by the Special Court under this`
  line `Act shall be preponderance of probabilities.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (32000)
  sectionNo (17)
  orderNo 17
  title Appeal.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32000&sectionno=17&orderno=17&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_17_content:
  string
  line `(1) An appeal shall lie from any judgment or order, not being an interlocutory order,`
  line `of a Special Court to the High Court both on facts and on law.`
  line
  line `(2) Every appeal under this section shall be preferred within a period of thirty days from the date`
  line `of the judgment or order appealed from:`
  line
  line `Provided that the High Court may entertain an appeal after the expiry of the said period of thirty`
  line `days, if it is satisfied that the appellant had sufficient cause for not preferring the appeal within the`
  line `period of thirty days:`
  line
  line `Provided further that no appeal shall be entertained after the expiry of period of ninety days.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (32001)
  sectionNo (18)
  orderNo 18
  title `Bar of jurisdiction.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32001&sectionno=18&orderno=18&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_18_content:
  string
  line `No civil court shall have jurisdiction to entertain any suit or proceeding`
  line `in respect of any matter which the Special Court is empowered by or under this Act to determine and`
  line `no injunction shall be granted by any court or other authority in respect of any action taken or to be`
  line `taken in pursuance of any power conferred by or under this Act.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (32002)
  sectionNo (19)
  orderNo 19
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32002&sectionno=19&orderno=19&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_19_content:
  string
  line `No suit, prosecution or other legal proceeding`
  line `shall lie against the Central Government or Presiding Officer of the Special Court or Director or`
  line `Deputy Director or any other officer authorised by the Director for anything which is in good faith`
  line `done or intended to be done under this Act or any rule made thereunder.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (32003)
  sectionNo (20)
  orderNo 20
  title `Power of Central Government to amend Schedule.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32003&sectionno=20&orderno=20&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_20_content:
  string
  line `(1) The Central Government may,`
  line `having regard to the objects of this Act, and if it considers necessary or expedient so to do, by`
  line `notification add to, or as the case may be, omit from the Schedule any offences specified therein.`
  line
  line `(2) Every such notification shall, as soon as after it is issued, be laid before each House of`
  line Parliament.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (32004)
  sectionNo (21)
  orderNo 21
  title `Overriding effect.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32004&sectionno=21&orderno=21&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_21_content:
  string
  line `The provisions of this Act shall have effect, notwithstanding anything`
  line `inconsistent therewith contained in any other law for the time being in force.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (32005)
  sectionNo (22)
  orderNo 22
  title `Application of other laws not barred.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32005&sectionno=22&orderno=22&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_22_content:
  string
  line `The provisions of this Act shall be in addition to and`
  line `not in derogation of any other law for the time being in force.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (32006)
  sectionNo (23)
  orderNo 23
  title `Power to make rules.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32006&sectionno=23&orderno=23&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_23_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, make rules for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:—`
  line
  line `(a) the form and manner of filing application under sub-section (1) of section 4;`
  line
  line `(b) the manner of attachment of property under sub-section (1) of section 5;`
  line
  line `(c) other matters under clause (f) of section 6;`
  line
  line `(d) the procedure for conducting search and seizure under section 8;`
  line
  line `(e) the manner in which the notice shall be served under sub-section (5) of section 10;`
  line
  line `(f) any other electronic account under clause (c) of sub-section (6) of section 10;`
  line
  line `(g) the manner and conditions subject to which the Administrator shall receive and manage the`
  line `property confiscated under sub-section (2) of section 15; and`
  line
  line `(h) any other matter which is required to be, or may be, prescribed or in respect of which`
  line `provision is to be made by rules.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (32007)
  sectionNo (24)
  orderNo 24
  title `Laying of rules before Parliament.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32007&sectionno=24&orderno=24&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_24_content:
  string
  line `Every rule made under this Act shall be laid, as soon as`
  line `may be after it is made, before each House of Parliament, while it is in session, for a total period of`
  line `thirty days which may be comprised in one session or in two or more successive sessions, and if,`
  line `before the expiry of the session immediately following the session or the successive sessions`
  line `aforesaid, both Houses agree in making any modification in the rule or both Houses agree that the rule`
  line `should not be made, the rule shall thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that any such modification or annulment shall be without prejudice`
  line `to the validity of anything previously done under that rule.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (32008)
  sectionNo (25)
  orderNo 25
  title `Power to remove difficulties.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32008&sectionno=25&orderno=25&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_25_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such`
  line `provisions not inconsistent with the provisions of this Act as may appear to be necessary for removing`
  line `the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of five years from the date`
  line `of commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (32009)
  sectionNo (26)
  orderNo 26
  title `Repeal and saving.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00032_A2018-17_1542613466306&sectionId=32009&sectionno=26&orderno=26&orgactid=AC_CEN_2_11_00032_A2018-17_1542613466306
obj_root_law_sections_26_content:
  string
  line `(1) The Fugitive Economic Offenders Ordinance, 2018 (Ord. 1 of 2018),`
  line `is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance, shall`
  line `be deemed to have been done or taken under this Act.`
obj_root_law_sections_26_footnotes:
  string
  line
