obj_root_law:
  slug the-fugitive-economic-offenders-act-2018
  handle (4035)
  collectionHandle 123456789/1362
  title `The Fugitive Economic Offenders Act, 2018`
  actNumber (17)
  enactmentDate 2018-07-31
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/4035`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भगोड़ा आर्थिक अपराधी अधिनियम, 2018`
  actYear (2018)
  ministry `Ministry of Finance`
  department `Department of Economic Affairs`
  longTitle `An Act to provide for measures to deter fugitive economic offenders from evading the process of law in India by staying outside the jurisdiction of Indian courts, to preserve the sanctity of the rule of law in India and for matters connected therewith or incidental thereto.`
  enforcementDate 21-04-2018
