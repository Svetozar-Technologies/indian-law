  object
  (str slug) (str the-fugitive-economic-offenders-act-2018)
  (str handle) (str 4035)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Fugitive Economic Offenders Act, 2018`)
  (str actNumber) (str 17)
  (str enactmentDate) (str 2018-07-31)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/4035`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भगोड़ा आर्थिक अपराधी अधिनियम, 2018`)
  (str actYear) (str 2018)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Economic Affairs`)
  (str longTitle) (str `An Act to provide for measures to deter fugitive economic offenders from evading the process of law in India by staying outside the jurisdiction of Indian courts, to preserve the sanctity of the rule of law in India and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 21-04-2018)
