obj_root_law_sections_1:
  sectionId (32341)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00021_194954_1517807322840&sectionId=32341&sectionno=1&orderno=1&orgactid=AC_CEN_6_6_00021_194954_1517807322840
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Industrial Disputes (Banking and`
  line `Insurance Companies) Act, 1949.`
  line
  line `(2) It extends to the whole of India ^1[except the State of Jammu and Kashmir*].`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 3 of 1951, s. 3 and the Schedule, for "except Part B States" (w.e.f. 1-4-1951).`
  line
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (32342)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00021_194954_1517807322840&sectionId=32342&sectionno=2&orderno=2&orgactid=AC_CEN_6_6_00021_194954_1517807322840
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context, the`
  line `expressions "award", "banking company", "industrial dispute" and "insurance company" have the`
  line `meanings respectively assigned to them in section 2 of the Industrial Disputes Act, 1947 (14 of 1947) as`
  line `amended by this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (32343)
  sectionNo (3)
  orderNo 3
  title Repealed.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00021_194954_1517807322840&sectionId=32343&sectionno=3&orderno=3&orgactid=AC_CEN_6_6_00021_194954_1517807322840
obj_root_law_sections_3_content:
  string
  line `[Amendment of section 2, Act 14 of 1947.] Rep. by the Repealing and Amending Act, 1952`
  line `(48 of 1952), s. 2 and the First Schedule.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (32344)
  sectionNo (4)
  orderNo 4
  title `Prohibition of references by State Governments of certain industrial disputes for adjudication, inquiry or settlement`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00021_194954_1517807322840&sectionId=32344&sectionno=4&orderno=4&orgactid=AC_CEN_6_6_00021_194954_1517807322840
obj_root_law_sections_4_content:
  string
  line `4. Prohibition of references by ^1[State] Governments of certain industrial disputes for`
  line `adjudication, inquiry or settlement.--Notwithstanding anything contained in any other law, it shall not`
  line `be competent for a State Government or any officer or authority subordinate to such Government to refer`
  line `an industrial dispute concerning any banking or insurance company, or any matter relating to such`
  line `dispute, to any tribunal or other authority for adjudication, inquiry or settlement.`
obj_root_law_sections_5:
  sectionId (32345)
  sectionNo (5)
  orderNo 5
  title `Abatement of proceedings relating to disputes pending before State tribunals and reference of such disputes to tribunals constituted by the Central Government`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by the A.O. 1950, for "Provincial".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00021_194954_1517807322840&sectionId=32345&sectionno=5&orderno=5&orgactid=AC_CEN_6_6_00021_194954_1517807322840
obj_root_law_sections_5_content:
  string
  line `5. Abatement of proceedings relating to disputes pending before`
  line `^1[State] tribunals and reference`
  line `of such disputes to tribunals constituted by the Central Government.--(1) Where under any law any`
  line `industrial dispute concerning any banking or insurance company or any matter relating to such dispute`
  line `has, before the 30th day of April, 1949, been referred by a ^1[State] Government or any officer or`
  line `authority subordinate to such Government to any tribunal or other authority for adjudication or settlement`
  line `and any proceedings in respect of or arising out of such reference were immediately before that date`
  line `pending before any tribunal or other authority, then on the aforesaid date such refence shall be deemed to`
  line `have been withdrawn and all such proceedings shall have abated.`
  line
  line `(2) The Central Government shall, as soon as may be after the commencement of this Act, by order in`
  line `writing, refer under section 10 of the said Act every industrial dispute to which the provisions of`
  line `sub-section (1) apply to an Industrial Tribunal constituted under the said Act for adjudication.`
obj_root_law_sections_6:
  sectionId (32346)
  sectionNo (6)
  orderNo 6
  title `Powers of Central Government to refer disputes in respect of which awards or decisions have been made for adjudication.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00021_194954_1517807322840&sectionId=32346&sectionno=6&orderno=6&orgactid=AC_CEN_6_6_00021_194954_1517807322840
obj_root_law_sections_6_content:
  string
  line `(1) Where any award or decision has been made in respect of any`
  line `industrial dispute concerning any banking or insurance company by any tribunal or other authority`
  line `constituted or appointed by a ^1[State] Government, or any officer or authority subordinate to such`
  line `Government, then the Central Government may, notwithstanding that the said award or decision is in`
  line `force, by order in writing refer under section 10 of the said Act the dispute or any of the matters in dispute`
  line `to an Industrial Tribunal constituted under the said Act for adjudication and stay the implementation of`
  line `the award or decision so made or of any part of such award or decision until the Industrial Tribunal to`
  line `which the dispute or any of the matters in dispute is referred for adjudication has submitted its award or`
  line `for such further period as the Central Government may consider necessary.`
  line
  line `(2) After the Industrial Tribunal to which the dispute or any of the matters in dispute has been so`
  line `referred for adjudication has submitted its award under sub-section (1) of section 15 of the said Act, the`
  line `Central Government may, by order in writing, declare that the award or decision previously made in`
  line `respect of such dispute by the tribunal or other authority constituted or appointed by the ^2[State]`
  line `Government or any officer or authority subordinate to such Government or such part of that award or`
  line `decision as may be specified in the order shall cease to be in operation.`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "Provincial".`
  line
  line `2. Subs. by the A.O. 1950, for "Provincial".`
obj_root_law_sections_7:
  sectionId (32347)
  sectionNo (7)
  orderNo 7
  title `Repeal of Ordinance 28 of 1949.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00021_194954_1517807322840&sectionId=32347&sectionno=7&orderno=7&orgactid=AC_CEN_6_6_00021_194954_1517807322840
obj_root_law_sections_7_content:
  string
  line `(1) The Industrial Disputes (Banking and Insurance`
  line `Companies) Second Ordinance, 1949 (28 of 1949) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken in the exercise of any power`
  line `conferred by or under the said Ordinance shall be deemed to have been done or taken in the exercise of`
  line `the powers conferred by or under this Act, as if this Act were in force on the day on which such thing was`
  line `done or action taken.`
obj_root_law_sections_7_footnotes:
  string
  line
