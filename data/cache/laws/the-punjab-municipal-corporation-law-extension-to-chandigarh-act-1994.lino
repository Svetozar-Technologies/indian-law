obj_root_law_sections_1:
  sectionId (40664)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00012_199445_1517807322850&sectionId=40664&sectionno=1&orderno=1&orgactid=AC_CEN_17_19_00012_199445_1517807322850
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Punjab Municipal Corporation`
  line `Law (Extension to Chandigarh) Act, 1994.`
  line
  line `(2) It shall be deemed to have come into force on the 24th day of May, 1994.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (40665)
  sectionNo (2)
  orderNo 2
  title `Extension and amendments of Punjab Act 42 of 1976.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00012_199445_1517807322850&sectionId=40665&sectionno=2&orderno=2&orgactid=AC_CEN_17_19_00012_199445_1517807322850
obj_root_law_sections_2_content:
  string
  line `(1) The Punjab Municipal Corporation`
  line `Act, 1976 is hereby extended to, and shall be in force in, the Union territory of Chandigarh.`
  line
  line `(2) With effect from the commencement of this Act,--`
  line
  line `(a) the references, in the Punjab Municipal Corporation Act, 1976 (Pun. Act 42 of 1976), to State,`
  line `authorities, or City mentioned in column 1 of Part I of the Schedule annexed to this Act shall be`
  line `construed as if references therein to State, authorities, or City respectively mentioned or referred to`
  line `opposite thereto in column 2 of that Part;`
  line
  line `(b) the Punjab Municipal Corporation Act, 1976 (Pun. Act 42 of 1976) shall be amended as`
  line `specified in Part II of the Schedule.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (40666)
  sectionNo (3)
  orderNo 3
  title `Repeal of Punjab Act III of 1911 and savings.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00012_199445_1517807322850&sectionId=40666&sectionno=3&orderno=3&orgactid=AC_CEN_17_19_00012_199445_1517807322850
obj_root_law_sections_3_content:
  string
  line `(1) The Punjab Municipal Act, 1911 in so far as`
  line `it applies to the Union territory of Chandigarh or any part thereof shall stand repealed on the coming into`
  line `force of this Act:`
  line
  line `Provided that the repeal shall not affect--`
  line
  line `(a) the previous operation of the Punjab Municipal Act, 1911 (Pun. Act III of 1911) so repealed`
  line `or anything duly done or suffered thereunder, or`
  line
  line `(b) any right, privilege, obligation or liability acquired, accrued or incurred under the said Act so`
  line `repealed, or`
  line
  line `(c) any investigation, legal proceeding or remedy in respect of any such right, privilege,`
  line `obligation or liability as aforesaid,`
  line
  line `and any such investigation, legal proceeding or remedy may be instituted, continued or enforced as if this`
  line `Act had not been passed:`
  line
  line `Provided further that, subject to the preceding proviso, anything done or any action taken (including`
  line `any appointment or delegation made, notification, instruction or direction issued, form or bye-law framed,`
  line `certificate obtained, permit or licence granted or registration effected) under such Act shall be deemed to`
  line `have been done or taken under the corresponding provisions of the Act now extended to that Union`
  line `territory, and shall continue to be in force accordingly unless and until superseded by anything done or`
  line `any action taken under the said Act.`
  line
  line `(2) In every law or notification passed or issued before the commencement of this Act in which`
  line `reference is made to or to any Chapter or section or provision of the said Act hereby repealed, such`
  line `references shall, so far as may be practicable, be taken to be made to the said Act or, their corresponding`
  line `Chapter or section.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (40667)
  sectionNo (4)
  orderNo 4
  title `Transitory provision.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00012_199445_1517807322850&sectionId=40667&sectionno=4&orderno=4&orgactid=AC_CEN_17_19_00012_199445_1517807322850
obj_root_law_sections_4_content:
  string
  line `Notwithstanding anything contained in this Act, the Central Government`
  line `may, if necessary, appoint a person to be called the Special Officer, to exercise the powers and discharge`
  line `the functions of the Municipal Corporation of Chandigarh until the day on which the first meeting of the`
  line `Corporation is held after the commencement of this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (40668)
  sectionNo (5)
  orderNo 5
  title `Repeal of Ordinance 7 of 1994 and saving.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00012_199445_1517807322850&sectionId=40668&sectionno=5&orderno=5&orgactid=AC_CEN_17_19_00012_199445_1517807322850
obj_root_law_sections_5_content:
  string
  line `(1) The Punjab Municipal Corporation Law`
  line `(Extension to Chandigarh) Ordinance, 1994 is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the Ordinance so repealed`
  line `shall be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_5_footnotes:
  string
  line
