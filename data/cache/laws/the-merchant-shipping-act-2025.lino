obj_root_law:
  slug the-merchant-shipping-act-2025
  handle (22147)
  collectionHandle 123456789/1362
  title `The Merchant Shipping Act, 2025`
  actNumber (24)
  enactmentDate 2025-08-18
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/22147`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (2025)
  ministry `Ministry of Ports, Shipping and Waterways`
  department undefined
  longTitle `An Act to consolidate and amend the law relating to merchant shipping to ensure compliance with India's obligation under the maritime treaties and international instruments to which India is a party and also to ensure the development of Indian shipping and efficient maintenance of Indian mercantile marine in a manner best suited to serve the national interest and for matters connected therewith or incidental thereto.`
  enforcementDate 15-03-2026
  notification undefined
