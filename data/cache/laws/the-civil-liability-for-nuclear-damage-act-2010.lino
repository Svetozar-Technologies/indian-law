  (str slug) (str the-civil-liability-for-nuclear-damage-act-2010)
  (str handle) (str 2084)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Civil Liability for Nuclear Damage Act, 2010`)
  (str actNumber) (str 38)
  (str enactmentDate) (str 2010-09-21)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2084`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `परमाणुवीय नुकसान के लिए सिविल दायित्‍व अधिनियम, 2010`)
  (str actYear) (str 2010)
  (str ministry) (undefined)
  (str department) (str `Department of Atomic Energy`)
  (str longTitle) (str `An Act to provide for civil liability for nuclear damage and prompt compensation to the victims of a nuclear incident through a no-fault liability regime channeling liability to the operator, appointment of Claims Commissioner, establishment of Nuclear Damage Claims Commission and for matters connected therewith or incidental thereto.`)
