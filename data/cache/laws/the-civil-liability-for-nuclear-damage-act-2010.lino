  (str title) (str `परमाणुवीय नुकसान के लिए सिविल दायित्‍व अधिनियम, 2010`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2084/3/H2010-38.pdf`)
