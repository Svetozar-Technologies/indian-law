obj_root_law_translations_hi_sections_1_content:
  string
  line `परमाणुवीय नुकसान के लिए लसलवि दालयत्व`
  line `अलिलनयम, 2010`
  line _________
  line `िाराओं का क्र म`
  line _________
  line िाराएं
  line `अध्या य 1 प्र`
  line ारंलिक
  line `1. संलिप् त नाम, लवस्ता र, िागू होना और प्र ारंि।`
  line `2. पररिाषाएं।`
  line `अध्या य 2`
  line `परमाणुवीय नुकसान के लिए दालयत्व`
  line `3. परमाणुवीय घटना का परमाणु ऊ र् ाा लवलनयामक बोर्ा द्व ारा अलिसूलित ककया र् ाना।`
  line `4. प्र िािक का दालयत्व।`
  line `5. कलतपय पररलस्ि लतयों में प्र िािक का दायी न होना।`
  line `6. दालयत्व की सीमाएं।`
  line `7. केन्‍दरी य सरकार का दालयत्व।`
  line `8. प्र िािक द्व ारा बीमा या लवत्तीय प्र लतिूलत बनाए रखना।`
  line `अध्या य 3`
  line `दावा आ युक्त`
  line `9. परमाणुवीय नुकसान के लिए प्र लतकर और उसका न्‍द या यलनणायन।`
  line `10. दावा आयुक्त के रू प में लनयुलक्त के लिए अहाताएं।`
  line `11. दावा आयुक्त का वेतन, ित्ते और सेवा के अन्‍दय लनबंिन तिा शतें।`
  line `12. न्‍द या यलनणायन की प्र कक्रया और दावा आयुक्त की शलक्त यां।`
  line `अध्या य 4`
  line `दावे और अलिलनणाय`
  line `13. दावा आयुक्त द्व ारा दावों के लिए आवेदन आमंलित करना।`
  line `14. परमाणुवीय नुकसान के लिए आवेदन करने का हकदार व् य लक् त।`
  line `15. दावा आयुक्त के समि आवेदन करने के लिए प्र कक्रया।`
  line `16. दावा आयुक्त द्व ारा अलिलनणाय।`
  line `17. प्र िािक का अविं बन का अलिकार।`
  line `18. दावा करने के अलिकारों का लनवाापन।`
  line `अध्या य 5`
  line `परमाणुवीय नुकसान दावा आयोग`
  line `19. परमाणुवीय नुकसान दावा आयोग की स् िा पना।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `20. आयोग की संरिना।`
  line `21. पदावलि।`
  line `22. अध्य ि और सदस्यों के वेतन और ित्ते तिा सेवा के अन्‍दय लनबंिन और शतें।`
  line `23. ररलक् त यों का िरा र् ाना।`
  line `24. पद त् या ग और हटाया र् ाना।`
  line `25. अध्य ि या सदस्य को सेवा से लनवृत्त समझा र् ाना।`
  line `26. पेंशन का लनिंबन।`
  line `27. मध्य स् ि के रू प में काया करने का प्र लतषेि।`
  line `28. व् य वसाय करने का प्र लतषेि।`
  line `29. अध्य ि की शक् ल तयां।`
  line `30. आयोग के अलिकारी और अन्‍दय कमािारी।`
  line `31. आयोग के समि प्र लतकर के लिए आवेदन।`
  line `32. आयोग की न्‍द या यलनणायन प्र कक्रया और शलक्त यां।`
  line `33. िंलबत मामिों का आयोग को अंतरण।`
  line `34. दावा आयुक्त या आयोग के समि कायावालहयों का न्‍द या लयक कायावालहयां होना।`
  line `35. लसलवि न्‍द या याियों की अलिकाररता का अपवर्ान।`
  line `36. अलिलनणायों का प्र वतान।`
  line `37. वार्षाक ररपोटा।`
  line `38. कलतपय पररलस्ि लतयों में आयोग का लवघटन।`
  line `अध्या य 6`
  line `अपराि और शालस्त यां`
  line `39. अपराि और शालस्त यां।`
  line `40. कंपलनयों द्व ारा अपराि।`
  line `41. सरकारी लविागों द्व ारा अपराि।`
  line `42. अपरािों का संज्ञान।`
  line `अध्या य 7 प्र`
  line कीणा
  line `43. लनदेश देने की शलक्त।`
  line `44. र् ानकारी मांगने की शलक्त।`
  line `45. इस अलिलनयम के िागू होने से छूट।`
  line `46. अलिलनयम का ककसी अन्‍दय लवलि के अलतररक्त होना।`
  line `47. सद्भावपूवाक की गई कारावाई के लिए संरिण।`
  line `48. लनयम बनाने की शलक्त।`
  line `49. करिनाइयों को दूर करने की शलक् त।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
