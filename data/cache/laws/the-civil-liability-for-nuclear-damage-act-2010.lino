obj_root_law:
  slug the-civil-liability-for-nuclear-damage-act-2010
  handle (2084)
  collectionHandle 123456789/1362
  title `The Civil Liability for Nuclear Damage Act, 2010`
  actNumber (38)
  enactmentDate 2010-09-21
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2084`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `परमाणुवीय नुकसान के लिए सिविल दायित्‍व अधिनियम, 2010`
  actYear (2010)
  ministry undefined
  department `Department of Atomic Energy`
  longTitle `An Act to provide for civil liability for nuclear damage and prompt compensation to the victims of a nuclear incident through a no-fault liability regime channeling liability to the operator, appointment of Claims Commissioner, establishment of Nuclear Damage Claims Commission and for matters connected therewith or incidental thereto.`
  enforcementDate undefined
  notification `yet to be notified`
  fetchedAt `2026-05-09T15:20:26.516Z`
  translations obj_root_law_translations
