obj_root_law_sections_1:
  sectionId (17673)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17673&sectionno=1&orderno=1&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Navy Act, 1957.`
  line
  line `(2) It shall come into force on such date^1 as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st January, 1958, vide notification S.R.O. 11(E), dated 31st December, 1957, see Gazette of India, Extraordinary, 1958,`
  line `Part II, s. 4(ii).`
obj_root_law_sections_2:
  sectionId (17674)
  sectionNo (2)
  orderNo 2
  title `Persons subject to naval law.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17674&sectionno=2&orderno=2&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_2_content:
  string
  line `(1) The following persons shall be subject to naval law wherever`
  line `they may be, namely:--`
  line
  line `(a) every person belonging to the Indian Navy during the time that he is liable for service under`
  line `this Act;`
  line
  line `(b) every person belonging to the Indian Naval Reserve Forces when he is--`
  line
  line `(i) on active service; or`
  line
  line `(ii) in or on any property of the naval service including naval establishments, ships and other`
  line `vessels, aircraft, vehicles and armouries; or`
  line
  line `(iii) called up for training or undergoing training in pursuance of regulations made under this`
  line `Act, until he is duly released from his training; or`
  line
  line `(iv) called up into actual service in the Indian Navy in pursuance of regulations made under`
  line `this Act, until he is duly released therefrom; or`
  line
  line `(v) in uniform;`
  line
  line `(c) members of the regular Army and the Air Force when embarked on board any ship or aircraft`
  line `of the Indian Navy, to such extent and subject to such conditions as may be prescribed;`
  line
  line `(d) every person not otherwise subject to naval law, who enters into an engagement with the`
  line `Central Government under section 6;`
  line
  line `(e) every person belonging to any auxiliary forces raised under this Act, to such extent and`
  line `subject to such conditions as may be prescribed; and`
  line
  line `(f) every person who, although he would not otherwise be subject to naval law, is by any other`
  line `Act or during active service by regulations made under this Act in this behalf made subject to naval`
  line `law, to such extent and subject to such conditions as may be prescribed.`
  line
  line `(2) The following persons shall be deemed to be persons subject to naval law, namely:--`
  line
  line `(a) every person ordered to be received, or being a passenger, on board any ship or aircraft of the`
  line `Indian Navy, to such extent and subject to such conditions as may be prescribed;`
  line
  line `(b) every person sentenced under this Act to imprisonment or detention, during the term of his`
  line `sentence, notwithstanding that he is discharged or dismissed with or without disgrace from naval`
  line `service or would otherwise but for this provision cease to be subject to naval law.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (17675)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17675&sectionno=3&orderno=3&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(1) "active service" means service or duty--`
  line
  line `(a) during the period of operation of a Proclamation of Emergency issued under clause (1) of`
  line `article 352 of the Constitution; or`
  line
  line `(b) during any period declared by the Central Government by notification in the Official`
  line `Gazette as a period of active service with reference to any area in which any person or class of`
  line `persons subject to naval law may be serving;`
  line
  line `(2) "Chief of the Naval Staff means the flag officer appointed by the President as Chief of the`
  line `Naval Staff or in his absence on leave or otherwise an officer appointed by the Central Government to`
  line `officiate as such or in the absence of such officiating appointment the officer on whom the command`
  line `devolves in accordance with regulations made under this Act;`
  line
  line `(3) "civil offence" means an offence triable by a Court of ordinary criminal jurisdiction in India;`
  line
  line `(4) "civil prison" means any jail or place used for the detention of any criminal prisoner under the`
  line `Prisons Act, 1894 (9 of 1894), or under any other law for the time being in force;`
  line
  line `(5) "commissioned officer" means a person holding a commission from the President in Indian`
  line `Navy or the Indian Naval Reserve Forces;`
  line
  line `(6) "Court-martial" means a Court-martial constituted under this Act;`
  line
  line `(7) "enemy" includes all armed rebels, armed mutineers, armed rioters and pirates and any person`
  line `in arms against whom it is the duty of any person subject to naval law to act;`
  line
  line `(8) "flag officer" means an officer of the rank of Admiral of the Fleet, Admiral, Vice-Admiral or`
  line Rear-Admiral;
  line
  line `(9) "Indian Naval Reserve Forces" means the naval reserve forces raised and maintained by the`
  line `Central Government;`
  line
  line `(10) "Indian Navy" means the regular naval forces raised and maintained by the Central`
  line Government;
  line
  line `(11) "Indian waters", for the purposes of sections 31, 97 and 99, means the seas extending from`
  line `the shores of India to such limits as may be prescribed;`
  line
  line `(12) "naval custody" means the arrest or confinement of a person in the prescribed manner or in`
  line `accordance with the usages of the naval service, and includes military or air force custody;`
  line
  line `^1[(12A) "naval establishment" means an establishment belonging to, or under the control of, the`
  line `Indian Navy whether within or without India;]`
  line
  line `(13) "naval offence" means any of the offences under sections 34 to 76;`
  line
  line `(14) "naval service" means the naval organisation of India;`
  line
  line `(15) "naval tribunal" means a Court-martial constituted under section 97 and includes a`
  line `disciplinary Court constituted under section 96, a commanding officer or other officer or authority`
  line `exercising powers of punishment under this Act;`
  line
  line `^2[(16) "Officer" means a commissioned officer and includes`
  line
  line `(a) a subordinate officer other than a petty officer;`
  line
  line `(b) a commissioned officer re-employed as such;]`
  line
  line `^3[(17) "petty officer" means a sailor rated as such and includes a chief petty officer and a master`
  line `chief petty officer;]`
  line
  line `(18) "prescribed" means prescribed by regulations made under this Act;`
  line
  line `(19) "provost-marshal" means a person appointed as such under section 89 and includes any of`
  line `his deputies or assistants or any other person lawfully exercising authority under him or on his behalf;`
  line
  line `(20)`
  line `^4["sailor"] means a person in the naval service other than an officer;`
  line
  line `(21) "ship", except in the expression "on board a ship", includes an establishment of the Indian`
  line `Navy commissioned as a ship in accordance with the custom of the navy;`
  line
  line `(22) "subject to naval law" means liable to be arrested and tried under this Act for any offence;`
  line
  line `(23) "subordinate officer" means a person appointed as an acting sub-lieutenant, a midshipman or`
  line `a cadet in any branch of the Indian Navy or the Indian Naval Reserve Forces, but does not include a`
  line `cadet whilst under training in a joint service institution;`
  line
  line `(24) "superior officer", when used in relation to a person subject to naval law, means any officer`
  line `or petty officer who is senior to that person under regulations made under this Act and any officer or`
  line `petty officer, who though not so senior to that person, is entitled under this Act or the regulations`
  line `made thereunder to give a command to that person, and includes, when such person is serving under`
  line `prescribed conditions, an officer, junior commissioned officer, warrant officer, noncommissioned`
  line `officer of the regular Army or the Air Force of higher relative rank to that person or entitled under`
  line `this Act or the regulations made thereunder to give a command to that person;`
  line
  line `(25) all words and expressions used but not defined in this Act but defined in the Indian Penal`
  line `Code (45 of 1860), shall have the meanings respectively assigned to them in that Code.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Ins. by Act 53 of 1974, s. 3 (w.e.f. 16-12-1974).`
  line
  line `2. Subs. by Act 23 of 2005, s. 2. for clause (16) (w.e.f. 23-6-2005).`
  line
  line `3. Subs. by Act 53 of 1974, s. 3, for clause (17) (w.e.f. 16-12-197).`
  line
  line `4. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
obj_root_law_sections_4:
  sectionId (17676)
  sectionNo (4)
  orderNo 4
  title `Fundamental rights to apply to persons subject to naval law with modifications.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17676&sectionno=4&orderno=4&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_4_content:
  string
  line `The rights`
  line `conferred by Part III of the Constitution in their application to persons subject to naval law shall be`
  line `restricted or abrogated to the extent provided in this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (17677)
  sectionNo (5)
  orderNo 5
  title `Power of Central Government to raise and maintain naval forces.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17677&sectionno=5&orderno=5&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_5_content:
  string
  line `The Central Government`
  line `may raise and maintain a regular naval force and also reserve and auxiliary naval forces.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (17678)
  sectionNo (6)
  orderNo 6
  title `Provision respecting discipline of persons under engagement to serve Central Government.`
  content obj_root_law_sections_6_content
  footnotes `1. Ins by Act 53 of 1974, s. 4 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17678&sectionno=6&orderno=6&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_6_content:
  string
  line `(1) If any person not otherwise subject to naval law enters into an engagement with the`
  line `Central Government to serve,--`
  line
  line `(a) in a particular ship; or`
  line
  line `(b) in such particular ship or in such ships as the Central Government, the Chief of the Naval`
  line `Staff, or the prescribed officer may, from time to time, determine;`
  line
  line `and agrees to become subject to naval law upon entering into the engagement, that person shall, so long as`
  line `the engagement remains in force and notwithstanding that for the time being he may not be serving in any`
  line `ship, be subject to naval law.`
  line
  line `(2) The Central Government may, by order, direct that, subject to such exceptions as may in particular`
  line `cases be made by or on behalf of the Chief of the Naval Staff, persons of any such class as may be`
  line `specified in the order shall, while being subject to naval law by virtue of this section, be deemed to be officers, petty officers or other ^1[sailors], as the case may be, for the purposes of this Act or of such`
  line `provisions of this Act as may be so specified.`
obj_root_law_sections_7:
  sectionId (17679)
  sectionNo (7)
  orderNo 7
  title `Relations between the members of the Navy, Army and Air Force acting together.`
  content obj_root_law_sections_7_content
  footnotes `1. Ins by Act 53 of 1974, s. 4 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17679&sectionno=7&orderno=7&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_7_content:
  string
  line `(1) When`
  line `members of the regular Army and the Air Force or of either of these forces are serving with members of`
  line `the Indian Navy or Indian Naval Reserve Forces under prescribed conditions, then those members of the`
  line `regular Army or the Air Force shall exercise such command, if any, and be subject to such discipline as`
  line `may be prescribed.`
  line
  line `(2) Nothing in sub-section (1) shall be deemed to authorise the exercise of powers of punishment by`
  line `members of the regular Army or the Air Force over members of the Indian Navy or the Indian Naval`
  line `Reserve Forces, except as provided in clause (e) of sub-section (3) of section 93 ^1[or in such cases and`
  line `subject to such conditions as may be prescribed].`
obj_root_law_sections_8:
  sectionId (17680)
  sectionNo (8)
  orderNo 8
  title `Provision respecting discipline of master of merchant vessel under convoy.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17680&sectionno=8&orderno=8&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_8_content:
  string
  line `(1) Every master`
  line `or other person for the time being in command of any merchant or other vessel comprised in a convoy`
  line `under the command of an officer of the Indian Navy shall obey, in all matters relating to the navigation or`
  line `security of the convoy, any directions which may be given by such officer, and shall take such`
  line `precautions for avoiding the enemy as may be required by any such directions.`
  line
  line `(2) If any such directions are not obeyed, any such officer or any person acting under his orders may`
  line `compel obedience by force of arms without being liable for any injury or loss of life or any danger to or`
  line `loss of property resulting therefrom.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (17681)
  sectionNo (9)
  orderNo 9
  title `Eligibility for appointment or enrolment.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17681&sectionno=9&orderno=9&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_9_content:
  string
  line `(1) No person who is not a citizen of India shall be`
  line `eligible for appointment or enrolment in the Indian Navy or the Indian Naval Reserve Forces except with`
  line `the consent of the Central Government.`
  line
  line `Provided that nothing in this section shall render a person ineligible for appointment or enrolment in`
  line `the Indian Navy or the Indian Naval Reserve Forces on the ground that he is a subject of Nepal.`
  line
  line `(2) No woman shall be eligible for appointment or enrolment in the Indian Navy or the Indian Naval`
  line `Reserve Forces except in such department, branch or other body forming part thereof or attached thereto`
  line `and subject to such conditions as the Central Government may, by notification in the Official Gazette,`
  line `specify in this behalf.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (17682)
  sectionNo (10)
  orderNo 10
  title `Commissions and appointments.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17682&sectionno=10&orderno=10&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_10_content:
  string
  line `(1) Officers other than subordinate officers shall be`
  line `appointed by commission granted by the President.`
  line
  line `(2) The grant of the commission shall be notified in the Official Gazette and such notification shall be`
  line `conclusive proof of the grant of such commission.`
  line
  line `(3) Subordinate officers shall be appointed in such manner and shall hold such rank as may be`
  line prescribed.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (17683)
  sectionNo (11)
  orderNo 11
  title Enrolment.
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17683&sectionno=11&orderno=11&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_11_content:
  string
  line `(1) Save as otherwise provided in this Act, the terms and conditions of service of`
  line `^1[sailors], the person authorised to enrol for service as ^1[sailors] and the manner and procedure of such`
  line `enrolment shall be such as may be prescribed.`
  line
  line `(2) No person shall be enrolled as a ^1[sailor] in the Indian Navy for a period exceeding ^2[twenty years]`
  line `in the first instance:`
  line
  line `Provided that in the case of a minor the said period of ^3[twenty years] shall be reckoned from the date`
  line `on which he attains the age of seventeen.`
  line
  line `(3) Notwithstanding anything contained in any other law for the time being in force,`
  line
  line `(a) the enrolment of any person under this Act shall be binding on him both during his minority`
  line `and after he attains majority;`
  line
  line `(b) neither the parent or guardian of a minor duly enrolled under this Act nor any other person`
  line `shall be entitled to claim custody of the said minor as against the Central Government or any of its`
  line `officers or other persons set over him.`
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by s. 2, ibid., for "seaman" (w.e.f. 16-12-1974).`
  line
  line `2. Subs. by Act 34 of 1987, s. 2, for "fifteen years" (w.e.f. 9-9-1987).`
  line
  line `3. Subs. by Act 34 of 1987, s. 2, for "fifteen years" (w.e.f. 9-9-1987).`
obj_root_law_sections_12:
  sectionId (17684)
  sectionNo (12)
  orderNo 12
  title `Validity of enrolment.`
  content obj_root_law_sections_12_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17684&sectionno=12&orderno=12&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_12_content:
  string
  line `Where a person after his enrolment has for a period of three months`
  line `from the date of such enrolment been in receipt of pay as a ^10[sailor], he shall be deemed to have been duly`
  line `enrolled and shall not thereafter be entitled to claim his discharge on the ground of any irregularity or`
  line `illegality in his engagement or any other ground whatsoever; and if within the said three months such`
  line `person claims his discharge, no such irregularity or illegality or other ground shall, until such person is`
  line `discharged in pursuance of his claim, affect his position as a ^1[sailor] in the naval service or invalidate any`
  line `proceedings, act or thing taken or done prior to his discharge.`
obj_root_law_sections_13:
  sectionId (17685)
  sectionNo (13)
  orderNo 13
  title `Oath of allegiance.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17685&sectionno=13&orderno=13&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_13_content:
  string
  line `Every officer and every ^1[sailor] shall, as soon as may be, after appointment`
  line `or enrolment make and subscribe before the commanding officer of the ship to which he belongs, or the`
  line `prescribed officer an oath or affirmation in the following form, that is to say:--`
  line
  line `"I.........................do swear in the name of God`
  line `Solemnly affirm that I will bear true faith and allegiance to the`
  line `Constitution of India as by law established and that I will, as in duty bound, honestly and faithfully`
  line `serve in the naval service and go wherever ordered by sea, land or air, and that I will observe and`
  line `obey all commands of the President and the commands of any superior officer set over me, even to`
  line `the peril of my life.".`
obj_root_law_sections_14:
  sectionId (17686)
  sectionNo (14)
  orderNo 14
  title `Liability for service of officers and sailors.`
  content obj_root_law_sections_14_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17686&sectionno=14&orderno=14&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_14_content:
  string
  line `(1) Subject to the provisions of subsection (4),`
  line `officers and ^1[sailors] shall be liable to serve in the Indian Navy or the Indian Naval Reserve Forces, as`
  line `the case may be, until they are duly discharged, dismissed, dismissed with disgrace, retired, permitted to`
  line `resign, or released.`
  line
  line `(2) No officer shall be at liberty to resign his office except with the permission of the Central`
  line `Government and no ^1[sailor] shall be at liberty to resign his post except with the permission of the`
  line `prescribed officer.`
  line
  line `(3) The acceptance of any resignation shall be a matter within the discretion of the Central`
  line `Government or the officer concerned, as the case may be.`
  line
  line `(4) Officers retired or permitted to resign shall be liable to recall to naval service in an emergency in`
  line `accordance with regulations made under this Act, and on such recall shall be liable to serve until they`
  line `have been duly discharged, dismissed, dismissed with disgrace, retired, permitted to resign, or released.`
obj_root_law_sections_15:
  sectionId (17687)
  sectionNo (15)
  orderNo 15
  title `Tenure of service of officers and sailors.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17687&sectionno=15&orderno=15&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_15_content:
  string
  line `(1) Every Officer and ^1[sailor] shall hold office`
  line `during the pleasure of the President.`
  line
  line `(2) Subject to the provisions of this Act and the regulations made thereunder,`
  line
  line `(a) the Central Government may ^2[dismiss or] discharge or retire from the naval service any`
  line `officer or ^1[sailor];`
  line
  line `(b) the Chief of the Naval Staff or any prescribed officer may ^3[dismiss or] discharge from the`
  line `naval service any ^4[sailor].`
obj_root_law_sections_15_footnotes:
  string
  line `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  line
  line `2. Ins by s. 5, ibid. (w.e.f. 16-12-197).`
  line
  line `3. Ins by Act 53 of 1974, s. 5 (w.e.f. 16-12-1974).`
  line
  line `4. Subs. by s. 2, ibid., for "seaman" (w.e.f. 16-12-1974).`
obj_root_law_sections_16:
  sectionId (17688)
  sectionNo (16)
  orderNo 16
  title `Discharge on expiry of engagement.`
  content obj_root_law_sections_16_content
  footnotes `1. Subs. by s. 2, ibid., for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17688&sectionno=16&orderno=16&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_16_content:
  string
  line `Subject to the provisions of section 18, a ^1[sailor] shall be`
  line `entitled to be discharged at the expiration of the term of service for which he is engaged unless--`
  line
  line `(a) such expiration occurs during active service in which case he shall be liable to continue to`
  line `serve for such further period as may be required by the Chief of the Naval Staff; or`
  line
  line `(b) he is re-enrolled in accordance with the regulations made under this Act.`
obj_root_law_sections_17:
  sectionId (17689)
  sectionNo (17)
  orderNo 17
  title `Provisions as to discharge.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by s. 2, ibid., for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17689&sectionno=17&orderno=17&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_17_content:
  string
  line `(1) A ^1[sailor] entitled to be discharged under section 16 shall be`
  line `discharged with all convenient speed and in any case within one month of his becoming so entitled:`
  line
  line `Provided that where a ^1[sailor] is serving overseas as the time he becomes entitled to be discharged he`
  line `shall be returned to India for the purpose of being discharged with all convenient speed, and in any case`
  line `within three months of his becoming so entitled:`
  line
  line `Provided further that where such enrolled person serving oversea does not desire to return to India, he`
  line `may be discharged at the place where he is at the time.`
  line
  line `(2) Every ^1[sailor] discharged shall be entitled to be conveyed free of cost from any place he may be`
  line `at the time to any place in India to which he may desire to go.`
  line
  line `(3) Notwithstanding anything contained in the preceding sub-sections, an enrolled person shall remain`
  line `liable to serve until he is duly discharged.`
  line
  line `(4) Every ^1[sailor] who is dismissed, discharged, retired, permitted to resign or released from service`
  line `shall be furnished by the prescribed officer with a certificate in the language which is the mother tongue`
  line `of such ^1[sailor] and also in the English language setting forth`
  line
  line `(a) the authority terminating his service;`
  line
  line `(b) the cause for such termination; and`
  line
  line `(c) the full period of his service in the Indian Navy and the Indian Naval Reserve Forces.`
obj_root_law_sections_18:
  sectionId (17690)
  sectionNo (18)
  orderNo 18
  title `Saving of powers of dismissal by naval tribunals.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17690&sectionno=18&orderno=18&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_18_content:
  string
  line `Nothing in this Chapter shall affect the`
  line `award by a naval tribunal of the punishment of dismissal with disgrace or dismissal from the naval service`
  line `under this Act.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (17691)
  sectionNo (19)
  orderNo 19
  title `Restrictions respecting right to form associations, freedom of speech, etc.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17691&sectionno=19&orderno=19&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_19_content:
  string
  line `(1) No person`
  line `subject to naval law shall, without the express sanction of the Central Government,--`
  line
  line `(a) be a member of, or be associated in any way with, any trade union, labour union, political`
  line `association or with any class of trade unions, labour unions or political associations, or`
  line
  line `(b) be a member of, or be associated in any way with, any other society, institution, association or`
  line `organisation that is not recognised as part of the Armed Forces of the Union or is not of a purely`
  line `social, recreational or religious nature.`
  line
  line `Explanation.--If any question arises as to whether any society, institution, association or organisation`
  line `is of a purely social, recreational or religious nature, the decision of the Central Government thereon shall`
  line `be final.`
  line
  line `(2) No person subject to naval law shall attend or address any meeting or take any part in any`
  line `demonstration organised by any body of persons for any political purposes or for such other purposes as`
  line `may be specified in this behalf by the Central Government.`
  line
  line `(3) No person subject to naval law shall communicate with the press or publish or cause to be`
  line `published any book, letter or other document having bearing on any naval, army or air force subject or containing any fact or opinion calculated to embarrass the relations between the Government and the`
  line `people or any section thereof or between the Government and any foreign country, except with the`
  line `previous sanction of the Central Government.`
  line
  line `(4) No person subject to naval law shall whilst he is so subject practise any profession or carry on any`
  line `occupation, trade or business without the previous sanction of the Chief of the Naval staff.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (17692)
  sectionNo (20)
  orderNo 20
  title `Immunity from attachment.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17692&sectionno=20&orderno=20&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_20_content:
  string
  line `The arms, clothes, equipments, accoutrements or necessaries of`
  line `any person in the naval service, while subject to naval law, shall not be seized, nor shall the pay and`
  line `allowances or any part thereof of such person be attached under any process or direction issued by, or by`
  line `the authority of, any court or public servant in respect of any claim, decree or order enforceable against`
  line him.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (17693)
  sectionNo (21)
  orderNo 21
  title `Immunity from arrest for debt.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17693&sectionno=21&orderno=21&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_21_content:
  string
  line `(1) No person in the naval service shall, so long as he is`
  line `subject to naval law, be liable to be arrested for debt under any process or direction issued by, or by the`
  line `authority of, any Court or public servant.`
  line `(2) If any such person is arrested in contravention of the provisions of sub-section (1), the court or`
  line `public servant by whom or by whose authority such process or direction was issued shall on complaint by`
  line `the person arrested or by his superior officer enquire into the case and if satisfied that the arrest was made`
  line `in contravention of sub-section (1), shall make an order for the immediate discharge of the person arrested`
  line `and may award of the complainant the costs of the complaint to be recoverable in the same manner as if`
  line `such costs were awarded to him by a decree against the person at whose instance such process or direction`
  line `was issued.`
  line `(3) No court-fee shall be payable on a complaint made under sub-section (2) for recovery of the costs`
  line `that may be awarded under that sub-section.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (17694)
  sectionNo (22)
  orderNo 22
  title `Immunity of persons attending court-martial or disciplinary court from arrest.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17694&sectionno=22&orderno=22&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_22_content:
  string
  line `(1) No`
  line `President or other member of a court-martial or disciplinary court, no judge, advocate, no party to any`
  line `proceeding before a court-martial or disciplinary court or no advocate or agent of such party, and no`
  line `witness acting in obedience to a summons to attend a court-martial or disciplinary court shall, while`
  line `proceeding to, attending or returning from, a court-martial or disciplinary court, be liable to arrest under`
  line `any civil or revenue process.`
  line `(2) If any such person is arrested under any such process, he may be discharged by order of the courtmartial`
  line `or disciplinary court, as the case may be.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (17695)
  sectionNo (23)
  orderNo 23
  title `Remedy of aggrieved persons.`
  content obj_root_law_sections_23_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17695&sectionno=23&orderno=23&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_23_content:
  string
  line `(1) If an officer or ^1[sailor] thinks that he has suffered any`
  line `personal oppression, injustice or other ill-treatment at the hands of any superior officer, he may make a`
  line `complaint in accordance with the regulations made under this Act.`
  line
  line `(2) The regulations referred to in sub-section (1) shall provide for the complaint to be forwarded to`
  line `the Central Government for its consideration if the complaint is not satisfied with the decision on his`
  line complaint
obj_root_law_sections_24:
  sectionId (17696)
  sectionNo (24)
  orderNo 24
  title `Priority of hearing of cases concerning persons in the naval service.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17696&sectionno=24&orderno=24&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_24_content:
  string
  line `(1) On the presentation`
  line `to any Civil or Revenue Court by or on behalf of any person in the naval service while subject to naval`
  line `law of a certificate from the proper naval authority of leave of absence having been granted to or applied`
  line `for by him for the purpose of prosecuting or defending any suit or other proceeding in such court, the`
  line `Court shall, on the application of such person, arrange, so far as may be possible, for the hearing and final`
  line `disposal of such suit or other proceeding within the period of the leave so granted or applied for.`
  line
  line `(2) The certificate from the proper naval authority shall state the first and last day of the leave granted`
  line `or applied for and set forth a description of the case with respect to which the leave has been granted or`
  line `applied for, and shall be duly signed and authenticated by such authority.`
  line
  line `(3) No fee shall be payable to the court in respect of the presentation of any such certificate, or in`
  line `respect of any application by or on behalf of any such person for priority for the hearing of his case and every such certificate duly signed and authenticated as aforesaid shall be conclusive evidence of the`
  line `correctness of the contents thereof.`
  line
  line `(4) Where the court is unable to arrange for the hearing and final disposal of the suit or other`
  line `proceeding within the period of the leave granted or applied for as aforesaid, it shall record its reasons for`
  line `having been unable to do so, and shall cause a copy thereof to be furnished to such person on his`
  line `application, without any payment whatever by him in respect either of the application for such copy or of`
  line `the copy itself.`
  line
  line `(5) Every criminal court before which a case is pending against a person in the naval service, shall, so`
  line `far as may be possible, arrange for the early hearing and final disposal of such case.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (17697)
  sectionNo (25)
  orderNo 25
  title `Right of the Chief of the Naval Staff or commanding officers to obtain copies of judgments or orders made by a criminal court.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17697&sectionno=25&orderno=25&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_25_content:
  string
  line `A criminal court before which any proceedings have been taken`
  line `against a person in the naval service while subject to naval law shall, on application by the Chief of the`
  line `Naval Staff or the commanding officer of that person, grant copies of the judgment and final orders in the`
  line `case free of cost and without delay.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (17698)
  sectionNo (26)
  orderNo 26
  title `Saving of rights and privileges under other laws.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17698&sectionno=26&orderno=26&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_26_content:
  string
  line `The rights and privileges specified in the`
  line `preceding sections of this Chapter shall be in addition to, and not in derogation of, any other rights and`
  line `privileges conferred on persons in the naval service while subject to naval law or on members of the`
  line `regular Army, Navy and Air Force generally by any other law for the time being in force.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (17699)
  sectionNo (27)
  orderNo 27
  title `Deductions from pay, etc., not to be made unless authorized.`
  content obj_root_law_sections_27_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17699&sectionno=27&orderno=27&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_27_content:
  string
  line `No deductions other than those`
  line `authorised by or under this or any other Act shall be made from the pay, pensions, gratuities, allowances`
  line `and other benefits due to officers and ^1[sailors] under any regulations for the time being in force.`
obj_root_law_sections_28:
  sectionId (17700)
  sectionNo (28)
  orderNo 28
  title `Deductions from pay and allowances of officers.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17700&sectionno=28&orderno=28&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_28_content:
  string
  line `The following deductions may be made`
  line `from the pay and allowances of an officer without recourse to trial by a naval tribunal, namely:--`
  line
  line `(1) all pay and allowances for everyday of absence without leave unless an explanation is given`
  line `to the satisfaction of the commanding officer for such absence and approved by the Chief of the`
  line `Naval Staff:`
  line
  line `Provided that the officer is not dealt with by a naval tribunal for the said absence;`
  line
  line `(2) all pay and allowances for everyday while he is in civil or naval custody or under suspension`
  line `from duty on a charge for an offence of which he is afterwards convicted by a competent naval`
  line `tribunal or Criminal Court and sentenced to imprisonment;`
  line
  line `(3) all pay and allowances for everyday while he is in hospital on account of sickness certified by`
  line `the prescribed medical officer to have been caused by an act amounting to an offence punishable`
  line `under this Act:`
  line
  line `Provided that such certificate is accepted by the Chief of the Naval Staff;`
  line
  line `(4) any sum required to make good the pay and allowances of any person subject to naval law`
  line `which he has unlawfully retained or refused to pay;`
  line
  line `(5) any sum required to make good any loss, damage or destruction of Government property or`
  line `property belonging to a naval mess, band or institution which after due investigation appears to the`
  line `Central Government, the Chief of the Naval Staff or the prescribed officer to have been occasioned by`
  line `the wrongful act or negligence on the part of the officer;`
  line
  line `(6) any sum required to be paid for the maintenance of his wife or legitimate or illegitimate`
  line `children under the provisions of section 31;`
  line
  line `(7) any sum which after due investigation appears to the prescribed officer to be due to a service`
  line `mess or canteen.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (17701)
  sectionNo (29)
  orderNo 29
  title `Deductions from pay and allowances of sailors.`
  content obj_root_law_sections_29_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17701&sectionno=29&orderno=29&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_29_content:
  string
  line `The following deductions may be made from`
  line `the pay and allowances of a ^1[sailor] without recourse to trial by a naval tribunal, namely:--`
  line
  line `(1) all pay and allowances for everyday of absence without leave unless an explanation is given to`
  line `the satisfaction of the commanding officer for such absence:`
  line
  line `Provided that the ^1[sailor] is not dealt with by a naval tribunal for the said absence;`
  line
  line `(2) all pay and allowances for everyday he is in confinement on a charge for an offence of which`
  line `he is afterwards convicted by a competent naval tribunal or Criminal Court;`
  line
  line `(3) all pay and allowances for everyday he is in hospital on account of sickness certified by the`
  line `prescribed medical officer to have been caused by an act amounting to an offence punishable under`
  line `this Act:`
  line
  line `Provided that such certificate is accepted by the Chief of the Naval Staff or the prescribed officer;`
  line
  line `(4) any sum required to make good any loss, damage or destruction of any property which after`
  line `due investigation appears to the Central Government or the Chief of the Naval Staff or the prescribed`
  line `officer to have been occasioned by the wrongful act or negligence on the part of the ^16`
  line sailor;
  line
  line `(5) any sum required to be paid for the maintenance of his wife or legitimate or illegitimate`
  line `children under the provisions of section 31.`
obj_root_law_sections_30:
  sectionId (17702)
  sectionNo (30)
  orderNo 30
  title `Deductions awarded by naval tribunals.`
  content obj_root_law_sections_30_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17702&sectionno=30&orderno=30&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_30_content:
  string
  line `Deductions may be made from the pay and`
  line `allowances of an officer or ^1[sailor] in respect of any sentence of fine, forfeiture or mulcts of pay and`
  line `allowances awarded in pursuance of this Act by a naval tribunal.`
obj_root_law_sections_31:
  sectionId (17703)
  sectionNo (31)
  orderNo 31
  title `Liability for maintenance of wife and children.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17703&sectionno=31&orderno=31&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_31_content:
  string
  line `(1) A person subject to naval law shall be`
  line `liable to maintain his wife and his legitimate or illegitimate children to the same extent as if he were not`
  line `so subject; but the execution or enforcement of any decree or order for maintenance passed or made`
  line `against such person shall not be directed against his person pay, arms, ammunition, equipments,`
  line `instruments or clothing.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1),--`
  line
  line `(a) where it appears to the satisfaction of the Central Government or the Chief of the Naval Staff`
  line `or the prescribed authority that a person subject to naval law has without reasonable cause deserted or`
  line `left in destitute circumstances his wife or any legitimate child unable to maintain himself or has by`
  line `reason of contracting a second marriage become liable to provide separate maintenance to his first`
  line `wife; or`
  line
  line `(b) where any decree or order is passed under any law against a person who is, or subsequently`
  line `becomes, subject to naval law for the maintenance of his wife or his legitimate or illegitimate children`
  line `and a copy of the decree or order is sent to the Central Government or the Chief of the Naval Staff or`
  line `the prescribed authority;`
  line
  line `the Central Government, or the Chief of the Naval Staff or the prescribed authority may direct a portion`
  line `of the pay of the person so subject to naval law to be deducted from such pay and appropriated in the`
  line `prescribed manner towards the maintenance of his wife or children, but the amount deducted shall not`
  line `exceed the amount fixed by the decree or order (if any) and shall not be at a higher rate than the rate fixed`
  line `by regulation made under this Act in this behalf:`
  line
  line `Provided that in the case of a decree or order for maintenance referred to in clause (b) no deduction`
  line `from pay shall be directed unless the Central Government, or the Chief of the Naval Staff or the`
  line `prescribed authority is satisfied that the person against whom such decree or order has been passed or`
  line `made, has had a reasonable opportunity of appearing, or has actually appeared either in person or through`
  line `a duly appointed legal practitioner, to defend the case before the Court by which the decree or order was`
  line `passed or made.`
  line
  line `(3) Where arrears of maintenance under a decree or order referred to in sub-section (2) have`
  line `accumulated while the person against whom the decree or order has been made is subject to naval law`
  line `whether or not deductions in respect thereof have been made from his pay under this section, no step for`
  line `the recovery of those arrears shall be taken in any Court after such person has ceased to be so subject`
  line `unless the Court is satisfied that he has, since he ceased to be subject to naval law, the ability to pay the`
  line `arrears or any part thereof and has failed to do so.`
  line
  line `(4) Notwithstanding anything contained in any other law, where a proceeding for obtaining a decree`
  line `or order for maintenance is started against a person subject to naval law,--`
  line
  line `(a) the court may send the process for service on that person to the commanding officer of the`
  line `ship on which such person is serving or on the books of which he is borne; or`
  line
  line `(b) if, by reason of the ship being at sea or otherwise, it is impracticable for the court to send the`
  line `process to the commanding officer, the Court may, after not less than three weeks' notice to the`
  line `Central Government, send it to a Secretary to that Government for transmission to the commanding`
  line `officer for service on that person:`
  line
  line `Provided that such service shall not be valid unless there is sent along with the process such sum of`
  line `money as may be prescribed to enable that person to attend the hearing of the proceeding and to return to`
  line `his ship or quarters after such attendance.`
  line
  line `(5) If a decree or order is passed or made in the proceeding against the person on whom the process is`
  line `served, the sum sent along with the process shall be awarded as costs of the proceeding against that`
  line person.
  line
  line `(6) No process in any proceeding under this section shall be valid against a person subject to naval`
  line `law if served on him after he is under orders for service at a foreign station or beyond Indian waters.`
  line
  line `(7) The production of a certificate of the receipt of the process purporting to be signed by such`
  line `commanding officer as aforesaid shall be evidence that the process has been duly served, unless the`
  line `contrary is proved.`
  line
  line `(8) Where by a decree or order a copy whereof has been sent to the Central Government or the Chief`
  line `of the Naval Staff or the prescribed authority under clause (b) of sub-section (2), the person against whom`
  line `the decree or order has been passed or made is directed to pay as costs any sum sent along with the`
  line `process [referred to in the proviso to sub-section (4)], the Central Government may pay to the person`
  line `entitled an amount in full satisfaction of that sum and the amount so paid by the Central Government shall`
  line `be deemed to be a public demand recoverable from the person against whom the decree or order has been`
  line `passed or made, and without prejudice to any other mode of recovery, may be recovered by deduction`
  line `from his pay, in addition to the deductions authorised by sub-section (2).`
  line
  line `(9) Where any person subject to naval law has made an allotment of any part of his pay and`
  line `allowances for the benefit of his wife, that allotment shall not be discontinued or reduced until the Central`
  line `Government or the Chief of the Naval Staff or the prescribed authority is satisfied that the allotment`
  line `should no longer be made or should be reduced.`
  line
  line `(10) In this section, the expression "pay" includes all sums payable to a person subject to naval law in`
  line `respect of his services other than allowances in lieu of lodgings, rations, provisions, clothing and`
  line `travelling allowances.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (17704)
  sectionNo (32)
  orderNo 32
  title `Limit of certain deductions.`
  content obj_root_law_sections_32_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17704&sectionno=32&orderno=32&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_32_content:
  string
  line `Except when the deductions are made under sub-sections (1), (2)`
  line `and (4) of section 28 or sub-sections (1) and (2) of section 29, the total deductions from the pay and allowances of an officer or ^1[sailor] shall not exceeded in any one month one-half of his pay and`
  line `allowances for that month.`
obj_root_law_sections_33:
  sectionId (17705)
  sectionNo (33)
  orderNo 33
  title `Remission of deductions.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17705&sectionno=33&orderno=33&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_33_content:
  string
  line `(1) Any deduction from the pay and allowances authorised by or`
  line `under this Act may be remitted by the Chief of the Naval Staff in his discretion.`
  line
  line `(2) Such deduction may also be remitted in such manner and to such extent and by such other`
  line `authority as may be prescribed.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (17706)
  sectionNo (34)
  orderNo 34
  title `Misconduct by officers or persons in command.`
  content obj_root_law_sections_34_content
  footnotes `1. Subs. by s. 7, ibid., for sections 34 to 37 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17706&sectionno=34&orderno=34&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_34_content:
  string
  line `^1[34. Misconduct by officers or persons in command.--Every flag officer, captain or other person`
  line `subject to naval law who, being in command of any ship, vessel or aircraft of the Indian Navy, or any`
  line `naval establishment--`
  line
  line `(a) fails to use his utmost exertions to bring into action any such ship, vessel or aircraft which it is`
  line `his duty to bring into action; or`
  line
  line `(b) surrenders any such ship, vessel or aircraft to the enemy when it is capable of being`
  line `successfully defended or destroyed; or`
  line
  line `(c) fails to pursue the enemy whom it is his duty to pursue or to assist to the utmost of his ability`
  line `any friend whom it is his duty to assist; or`
  line
  line `(d) in the course of any action by or against the enemy improperly withdraws from the action or`
  line `from his station or fails in his own person and according to his rank to encourage the persons under`
  line `his command to fight courageously; or`
  line
  line `(e) surrenders any such naval establishment or any part of such an establishment to the enemy`
  line `when it is capable of being successfully defended or when it is his duty to cause it to be destroyed,`
  line
  line shall,--
  line
  line `(a) if such act is committed with intent to assist the enemy or from cowardice, be punished with`
  line `death or such other punishment as is hereinafter mentioned; and`
  line
  line `(b) in any other case, be punished with imprisonment for a term which may extend to seven years`
  line `or such other punishment as is hereinafter mentioned.]`
obj_root_law_sections_35:
  sectionId (17707)
  sectionNo (35)
  orderNo 35
  title `Misconduct by persons other than those in command.`
  content obj_root_law_sections_35_content
  footnotes `1. Subs. by s. 7, ibid., for sections 34 to 37 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17707&sectionno=35&orderno=35&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_35_content:
  string
  line `^1[35. Misconduct by persons other than those in command.--Every person subject to naval law`
  line `who, not being in command of any naval establishment or any ship, vessel or aircraft of the Indian Navy,`
  line `fails when ordered to prepare for action by or against the enemy, or during any such action, to use his`
  line `utmost exertions to carry the lawful orders of his superior officers into execution shall,--`
  line
  line `(a) if such act is committed with intent to assist the enemy, be punished with death or such other`
  line `punishment as is hereinafter mentioned; and`
  line
  line `(b) in any other case, be punished with imprisonment for a term which may extend to seven years`
  line `or such other punishment as is hereinafter mentioned.]`
obj_root_law_sections_36:
  sectionId (17708)
  sectionNo (36)
  orderNo 36
  title `Delaying or discouraging action or service commanded.`
  content obj_root_law_sections_36_content
  footnotes `1. Subs. by s. 7, ibid., for sections 34 to 37 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17708&sectionno=36&orderno=36&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_36_content:
  string
  line `^1[36. Delaying or discouraging action or service commanded.--Every person subject to naval law`
  line `who wilfully delays or discourages upon any pretext whatsoever, any action or service which has been`
  line `commanded on the part of the Navy, regular Army, or Air Force or of any forces cooperating therewith`
  line shall,--
  line
  line `(a) if such act is committed with intent to assist the enemy, be punished with death or such other`
  line `punishment as is hereinafter mentioned; and`
  line
  line `(b) in any other case, be punished with imprisonment which may extend to seven years or such`
  line `other punishment as is hereinafter mentioned.]`
obj_root_law_sections_37:
  sectionId (17709)
  sectionNo (37)
  orderNo 37
  title `Penalty for disobedience in action.`
  content obj_root_law_sections_37_content
  footnotes `1. Subs. by s. 7, ibid., for sections 34 to 37 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17709&sectionno=37&orderno=37&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_37_content:
  string
  line `^1[37. Penalty for disobedience in action.--Every person subject to naval law who, being in the`
  line `presence or vicinity of the enemy or having been ordered to be prepared for action by or against the`
  line enemy--
  line
  line `(a) desert his post; or`
  line
  line `(b) sleeps upon his watch,`
  line
  line `shall be punished with death or such other punishment as is hereinafter mentioned.]`
obj_root_law_sections_38:
  sectionId (17710)
  sectionNo (38)
  orderNo 38
  title `Penalty for spying.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17710&sectionno=38&orderno=38&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_38_content:
  string
  line `Every person not otherwise subject to naval law who is or acts as a spy for`
  line `the enemy shall be punished under this Act with death or such other punishment as is hereinafter`
  line `mentioned as if he were a person subject to naval law.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (17711)
  sectionNo (39)
  orderNo 39
  title `Correspondence, etc., with the enemy.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17711&sectionno=39&orderno=39&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_39_content:
  string
  line `Every person subject to naval law, who,--`
  line
  line `(a) traitorously holds correspondence with the enemy or gives intelligence to the enemy; or`
  line
  line `(b) fails to make known to the proper authorities any information he may have received from the`
  line `enemy; or`
  line
  line `(c) assists the enemy with any supplies; or`
  line
  line `(d) having been made a prisoner of war, voluntarily serves with or aids the enemy;`
  line
  line `shall be punished with death or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (17712)
  sectionNo (40)
  orderNo 40
  title `Improper communication with the enemy.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17712&sectionno=40&orderno=40&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_40_content:
  string
  line `Every person subject to naval law who without`
  line `any traitorous intention holds any improper communication with the enemy shall be punished with`
  line `imprisonment for a term which may extend to fourteen years or such other punishment as is hereinafter`
  line mentioned.
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (17713)
  sectionNo (41)
  orderNo 41
  title `Deserting post and neglect of duty.`
  content obj_root_law_sections_41_content
  footnotes `1. Subs. by Act 53 of 1974, s. 8, for clause (c) (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17713&sectionno=41&orderno=41&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_41_content:
  string
  line `Every person subject to naval law, who,--`
  line
  line `(a) deserts his post; or`
  line
  line `(b) sleeps upon his watch; or`
  line
  line `^1[(c) fails to perform or negligently performs the duty imposed on him; or]`
  line
  line `(d) wilfully conceals any words, practice or design tending to the hindrance of the naval service;`
  line
  line `shall be punished with imprisonment for a term which may extend to two years or such other punishment`
  line `as is hereinafter mentioned.`
obj_root_law_sections_42:
  sectionId (17714)
  sectionNo (42)
  orderNo 42
  title `Mutiny defined.`
  content obj_root_law_sections_42_content
  footnotes `1. Subs. by s. 9, ibid., for section 42 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17714&sectionno=42&orderno=42&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_42_content:
  string
  line `^1[42. Mutiny defined.--Mutiny means any assembly or combination of two or more persons subject`
  line `to naval law, the Army Act, 1950 (40 of 1950), or the Air Force Act, 1950 (40 of 1950), or between`
  line `persons two at least of whom, are subject to naval law or any such Act,--`
  line
  line `(a) to overthrow or resist lawful authority in the Navy, regular Army or Air Force or any part of`
  line `any one or more of them or any forces co-operating therewith or any part thereof; or`
  line
  line `(b) to disobey such authority in such circumstances as to make the disobedience subversive of`
  line `discipline or with the object of avoiding any duty or service against, or in connection with operations`
  line `against, the enemy; or`
  line
  line `(c) to show contempt to such authority in such circumstances as to make such conduct subversive`
  line `of discipline; or`
  line
  line `(d) to impede the performance of any duty or service in the Navy, regular Army or Air Force or`
  line `any part of any one or more of them or any forces co-operating therewith or any part thereof.]`
obj_root_law_sections_43:
  sectionId (17715)
  sectionNo (43)
  orderNo 43
  title `Punishment for mutiny.`
  content obj_root_law_sections_43_content
  footnotes `1. Ins by Act 53 of 1974, s. 10 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17715&sectionno=43&orderno=43&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_43_content:
  string
  line `Every person subject to naval law, who,--`
  line
  line `(a) joins in a mutiny; or`
  line
  line `(b) begins, incites, causes or conspires with any other persons to cause, a mutiny; or`
  line
  line `(c) endeavours to incite any person to join in a mutiny or to commit an act of mutiny; or`
  line
  line `(d) endeavours to seduce any person in the regular Army, Navy or Air Force from his allegiance`
  line `to the Constitution or loyalty to the State or duty to his superior officers or uses any means to compel`
  line `or induce any such person to abstain from acting against the enemy or discourage such person from`
  line `acting against the enemy; or`
  line
  line `(e) does not use his utmost exertions to suppress ^1[or prevent] a mutiny; or`
  line
  line `(f) wilfully conceals any traitorous or mutinous practice or design or any traitorous words spoken`
  line `against the State; or`
  line
  line `(g) knowing or having reason to believe in the existence of any mutiny or of any intention to`
  line `mutiny does not without delay give information thereof to the commanding officer of his ship or other`
  line `superior officer; or`
  line
  line `(h) utters words of sedition or mutiny;`
  line
  line `shall be punished with death or such other punishment as is hereinafter mentioned`
obj_root_law_sections_44:
  sectionId (17716)
  sectionNo (44)
  orderNo 44
  title `Persons on board ships or aircraft seducing naval personnel from allegiance.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17716&sectionno=44&orderno=44&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_44_content:
  string
  line `Every person`
  line `not otherwise subject to naval law who being on board any ship or aircraft of the Indian Navy or on board`
  line `any ship in the service of the Government endeavours to seduce from his allegiance to the Constitution or`
  line `loyalty to the State or duty to superior officers any person subject to naval law shall be punished under`
  line `this Act with death or such other punishment as is hereinafter mentioned as if he were a person subject to`
  line `naval law.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (17717)
  sectionNo (45)
  orderNo 45
  title `Striking superior officers.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17717&sectionno=45&orderno=45&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_45_content:
  string
  line `Every person subject to naval law who commits any of the`
  line `following offences, that is to say,--`
  line
  line `(a) strikes or attempts to strike his superior officer; or`
  line
  line `(b) draws or lifts up any weapon against such officer; or`
  line
  line `(c) uses or attempts to use any violence against such officer;`
  line
  line `shall be punished,--`
  line
  line `if the offence is committed on active service with imprisonment for a term which may extend to ten`
  line `years or such other punishment as is hereinafter mentioned; and`
  line
  line `in any other case, with imprisonment for a term which may extend to five years or such other`
  line `punishment as is hereinafter mentioned.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (17718)
  sectionNo (46)
  orderNo 46
  title `Ill-treating subordinates.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17718&sectionno=46&orderno=46&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_46_content:
  string
  line `Every person subject to naval law who is guilty of ill-treating any`
  line `other person subject to such law, being his subordinate in rank or position, shall be punished with`
  line `imprisonment for a term which may extend to seven years or such other punishment as is hereinafter`
  line mentioned.
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (17719)
  sectionNo (47)
  orderNo 47
  title `Disobedience and insubordination.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17719&sectionno=47&orderno=47&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_47_content:
  string
  line `Every person subject to naval law, who,--`
  line
  line `(a) wilfully disobeys any lawful command of his superior officer; or`
  line
  line `(b) in the presence of his superior officer, or otherwise shows or expresses his intention to`
  line `disobey a lawful command given by such superior officer; or`
  line
  line `(c) uses insubordinate, threatening or insulting language to his superior officer; or`
  line
  line `(d) behaves with contempt to his superior officer;`
  line
  line `shall, if the offence is committed on active service or in a manner to show wilful defiance of authority, be`
  line `punished with imprisonment for a term which may extend to ten years or such other punishment as is`
  line `hereinafter mentioned and in other cases, be punished with imprisonment for a term which may extend to`
  line `three years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (17720)
  sectionNo (48)
  orderNo 48
  title `Quarrelling, fighting and disorderly behavior.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17720&sectionno=48&orderno=48&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_48_content:
  string
  line `Every person subject to naval law, who,--`
  line
  line `(a) quarrels, fights with or strikes any other person, whether such person is or is not subject to`
  line `naval law; or`
  line
  line `(b) uses reproachful or provoking speeches or gestures tending to make a quarrel or disturbance;`
  line or
  line
  line `(c) behaves in a disorderly manner;`
  line
  line `shall be punished with imprisonment for a term which may extend to two years or such other punishment`
  line `as is hereinafter mentioned.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (17721)
  sectionNo (49)
  orderNo 49
  title Desertion.
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17721&sectionno=49&orderno=49&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_49_content:
  string
  line `(1) Every person subject to naval law who absents himself from his ship or from the`
  line `place where his duty requires him to be, with an intention of not returning to such ship or place, or who at`
  line `any time and under any circumstances when absent from his ship or place of duty does any act which`
  line `shows that he has an intention of not returning to such ship or place is said to desert.`
  line `(2) Every person who deserts shall,--`
  line
  line `(a) if he deserts to the enemy, be punished with death or such other punishment as is hereinafter`
  line `mentioned; or`
  line
  line `(b) if he deserts under any other circumstances, be punished with imprisonment for a term which`
  line `may extend to fourteen years or such other punishment as is hereinafter mentioned;`
  line
  line `and in every such case he shall forfeit all pay, head money, bounty, salvage, prize money and allowances`
  line `that have been earned by him and all annuities, pensions, gratuities, medals and decorations that may have`
  line `been granted to him and also all clothes and effects which he may have left on board the ship or the place`
  line `from which he deserted, unless the tribunal by which he is tried or the Central Government or the Chief of`
  line `the Naval Staff, otherwise directs.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (17722)
  sectionNo (50)
  orderNo 50
  title `Inducing person to desert.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17722&sectionno=50&orderno=50&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_50_content:
  string
  line `Every person subject to naval law who endeavours to seduce any`
  line `other person subject to naval law to desert shall be punished with imprisonment for a term which may`
  line `extend to two years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (17723)
  sectionNo (51)
  orderNo 51
  title `Breaking out of ship and absence without leave.`
  content obj_root_law_sections_51_content
  footnotes `1. Ins by Act 53 of 1974, s. 11 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17723&sectionno=51&orderno=51&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_51_content:
  string
  line `Every person subject to naval law who`
  line `without being guilty of desertion improperly leaves his ship or place of duty ^1[or any place where he is`
  line `required to be] or is absent without leave shall be punished with imprisonment for a term which may`
  line `extend to two years or such other punishment as is hereinafter mentioned and shall also be punished by`
  line `such mulcts of pay and allowances as may be prescribed.`
obj_root_law_sections_52:
  sectionId (17724)
  sectionNo (52)
  orderNo 52
  title Drunkenness.
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17724&sectionno=52&orderno=52&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_52_content:
  string
  line `^1[(1)] Every person subject to naval law who is guilty of drunkenness shall, if the`
  line `offence is committed on active service, be punished with imprisonment for a term which may extend to`
  line `two years or such other punishment as is hereinafter mentioned and in other cases be punished with`
  line `imprisonment for a term which may extend to six months or such other punishment as is hereinafter`
  line mentioned.
  line
  line `^2[(2) For the purpose of sub-section (1), a person shall be deemed to be guilty of drunkenness if,`
  line `owing to the influence of alcohol or any drug whether alone or in combination with any other`
  line `circumstances, he is unfit to be entrusted with his duty or with any duty which he may be called upon to`
  line `perform or behaves in a disorderly manner or in a manner likely to bring discredit to the naval service.]`
obj_root_law_sections_52_footnotes:
  string
  line `1. Section 52 renumbered as sub-section (1) thereof by s. 12, ibid. (w.e.f. 16-12-1974).`
  line `2. Ins. by s. 12, ibid. (w.e.f. 16-12-1974).`
obj_root_law_sections_53:
  sectionId (17725)
  sectionNo (53)
  orderNo 53
  title `Uncleanness or indecent acts.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17725&sectionno=53&orderno=53&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_53_content:
  string
  line `Every person subject to naval law who is guilty of,--`
  line
  line `(a) uncleanness; or`
  line
  line `(b) any indecent act;`
  line
  line `shall be punished with imprisonment for a term which may extend to two years or such other punishment`
  line `as is hereinafter mentioned.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (17726)
  sectionNo (54)
  orderNo 54
  title `Cruelty and conduct unbecoming the character of an officer.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17726&sectionno=54&orderno=54&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_54_content:
  string
  line `(1) Every officer subject to`
  line `naval law who is guilty of cruelty shall be punished with imprisonment for a term which may extend to`
  line `seven years or such other punishment as is hereinafter mentioned.`
  line
  line `(2) Every officer subject to naval law who is guilty of any scandalous or fraudulent conduct or of any`
  line `conduct unbecoming the character of an officer shall be punished with imprisonment for a term which`
  line `may extend to two years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (17727)
  sectionNo (55)
  orderNo 55
  title `Losing ship or aircraft.`
  content obj_root_law_sections_55_content
  footnotes `1. Subs. by Act 53 of 1974, s. 14, for "designedly" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=17727&sectionno=55&orderno=55&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_55_content:
  string
  line `(1) Every person subject to naval law who ^1[wilfully] loses, strands or`
  line `hazards or suffers to be lost, stranded or hazarded any ship of the Indian Navy or in the service of the`
  line `Government, or loses or suffers to be lost any aircraft of the Indian Navy or in the service of the`
  line `Government shall be punished with imprisonment for a term which may extend to fourteen years or such`
  line `other punishment as is hereinafter mentioned.`
  line
  line `(2) Every person subject to naval law who negligently or by any default loses, strands or hazards or`
  line `suffers to be lost, stranded or hazarded any ship of the Indian Navy or in the service of the Government,`
  line `or loses or suffers to be lost any aircraft of the Indian Navy or in the service of the Government shall be`
  line `punished with imprisonment for a term which may extend to two years or such other punishment as is`
  line `hereinafter mentioned.`
obj_root_law_sections_55_a:
  sectionId (29250)
  sectionNo 55A
  orderNo 56
  title `Dangerous unauthorised flying.`
  content obj_root_law_sections_55_a_content
  footnotes obj_root_law_sections_55_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29250&sectionno=55A&orderno=56&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_55_a_content:
  string
  line `^1[55A. Dangerous unauthorised flying.--Every person subject to naval law, who is guilty of any act`
  line `or neglect in flying or in the use of any aircraft of the Indian Navy or in relation to any such aircraft or`
  line `aircraft material, which causes or is likely to cause loss of life or bodily injury to any person shall,--`
  line
  line `(a) if he acts wilfully or with wilful neglect, be punished with imprisonment for a term which`
  line `may extend to fourteen years ^2[or such other punishment as is hereinafter mentioned]; and`
  line
  line `(b) in any other case, be punished with imprisonment for a term which may extend to five years`
  line `or such other punishment as is hereinafter mentioned.]`
obj_root_law_sections_55_a_footnotes:
  string
  line `1. Ins. by s. 14, ibid. (w.e.f. 15-12-1974).`
  line `2. Ins. by Act 48 of 1982, s. 2 (w.e.f. 16-10-1982).`
obj_root_law_sections_55_b:
  sectionId (29251)
  sectionNo 55B
  orderNo 57
  title `Inaccurate certificate.`
  content obj_root_law_sections_55_b_content
  footnotes `1. Ins. by s. 14, ibid. (w.e.f. 15-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29251&sectionno=55B&orderno=57&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_55_b_content:
  string
  line `^1[55B. Inaccurate certificate.--Every person subject to naval law who signs any certificate in relation`
  line `to an aircraft or aircraft material belonging to or in the service of the Government without ensuring the`
  line `accuracy thereof, shall be punished with imprisonment for a term which may extend to two years or such`
  line `other punishment as is hereinafter mentioned.]`
obj_root_law_sections_55_c:
  sectionId (29252)
  sectionNo 55C
  orderNo 58
  title `Low flying and annoyance by flying`
  content obj_root_law_sections_55_c_content
  footnotes `1. Ins. by s. 14, ibid. (w.e.f. 15-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29252&sectionno=55C&orderno=58&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_55_c_content:
  string
  line `^1[55C. Low flying and annoyance by flying.--Every person subject to naval law being the pilot of an`
  line `aircraft of the Indian Navy, who--`
  line
  line `(a) flies it at a height less than the minimum height authorised by his commanding officer or`
  line `appropriate service authority except while taking off or landing; or`
  line
  line `(b) flies it so as to cause or likely to cause unnecessary annoyance to any person,`
  line
  line `shall be punished with imprisonment for a term which may extend to two years or such other punishment`
  line `as is hereinafter mentioned.]`
obj_root_law_sections_55_d:
  sectionId (29253)
  sectionNo 55D
  orderNo 59
  title `Disobedience of lawful command of captain of an aircraft.`
  content obj_root_law_sections_55_d_content
  footnotes `1. Ins. by s. 14, ibid. (w.e.f. 15-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29253&sectionno=55D&orderno=59&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_55_d_content:
  string
  line `^1[55D. Disobedience of lawful command of captain of an aircraft.--Every person subject to naval`
  line `law, who while he is in an aircraft belonging to or in the use of the Government, disobeys any lawful`
  line `command given by the captain of the aircraft, whether such captain is subject to naval law or not, in`
  line `relation to all matters relating to flying or handling of the aircraft or affecting the safety thereof, shall be`
  line `punished with imprisonment for a term which may extend to fourteen years or such other punishment as`
  line `is hereinafter mentioned.]`
obj_root_law_sections_56:
  sectionId (29254)
  sectionNo (56)
  orderNo 60
  title `Offences by officers in charge of convoy`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29254&sectionno=56&orderno=60&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_56_content:
  string
  line `(1) All officers appointed for the convoy and`
  line `protection of any ships or vessels shall diligently perform their duty without delay according to their`
  line `instructions in that behalf.`
  line
  line `(2) Every such officer subject to naval law, who,--`
  line
  line `(a) does not defend the ships and goods under his convoy without deviation to any other objects;`
  line or
  line
  line `(b) refuses to fight in their defence if they are assailed; or`
  line
  line `(c) cowardly abandons and exposes the ships in his convoy to hazard; or`
  line
  line `(d) demands or exacts any money or other reward from any merchant or master for convoying`
  line `any ships or vessels entrusted to his care; or`
  line
  line `(e) misuses the masters or mariners thereof;`
  line
  line `shall be punished with death or such other punishment as is hereinafter mentioned, and shall also make`
  line `such reparation in damages to the merchants, owners and others as a Civil Court of competent jurisdiction`
  line `may adjudge.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (29255)
  sectionNo (57)
  orderNo 61
  title `Taking unauthorised goods on board ship`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29255&sectionno=57&orderno=61&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_57_content:
  string
  line `Every officer subject to naval law in command of`
  line `any ship of the Indian Navy who receives on board or permits to be received on board such ship any`
  line `goods or merchandise whatsoever other than for the sole use of the ship or persons belonging to the ship,`
  line `except goods and merchandise on board any ship which may be shipwrecked or in imminent danger either`
  line `on the high seas or in some port, creek, or harbour, for the purpose of preserving them for their proper`
  line `owners, or except such goods or merchandise as he may at any time be ordered to take or receive on`
  line `board by order of the Central Government or his superior officer, shall be punished with dismissal from`
  line `the naval service or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (29256)
  sectionNo (58)
  orderNo 62
  title `Offences in respect of property.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29256&sectionno=58&orderno=62&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_58_content:
  string
  line `Every person subject to naval law who wastefully expends or`
  line `fraudulently buys, sells or receives any property of Government or property belonging to a naval, military`
  line `or air force mess, band or institution, and every person who knowingly permits any such wasteful`
  line `expenditure, or any such fraudulent purchase, sale or receipt, shall be punished with imprisonment for a`
  line `term which may extend to two years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (29257)
  sectionNo (59)
  orderNo 63
  title Arson
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29257&sectionno=59&orderno=63&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_59_content:
  string
  line `Every person subject to naval law who unlawfully sets fire to any dockyard, victualling`
  line `yard or steam factory yard, arsenal, magazine, building, stores or to any ship, vessel, hoy, barge, boat,`
  line `aircraft, or other craft or furniture thereunto belonging, not being the property of an enemy, shall be`
  line `punished with death or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (29258)
  sectionNo (60)
  orderNo 64
  title `Falsifying official documents and false declarations.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29258&sectionno=60&orderno=64&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_60_content:
  string
  line `Every person subject to naval law--`
  line
  line `(a) who knowingly makes or signs a false report, return, list, certificate, book, muster or other`
  line `document to be used for official purposes; or`
  line
  line `(b) who commands, counsels or procures the making or signing thereof; or`
  line
  line `(c) who aids or abets any other person in the making or signing thereof; or`
  line
  line `(d) who knowingly makes, commands, counsels or procures the making of, a false or fraudulent`
  line `statement or a fraudulent omission in any such document;`
  line
  line `shall be punished with imprisonment for a term which may extend to seven years or such other`
  line `punishment as is hereinafter mentioned.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (29259)
  sectionNo (61)
  orderNo 65
  title `Malingering, etc.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29259&sectionno=61&orderno=65&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_61_content:
  string
  line `Every person subject to naval law--`
  line
  line `(a) who wilfully does any act or wilfully disobeys any orders whether in hospital or elsewhere`
  line `with intent to produce or to aggravate any disease or infirmity or to delay his cure; or`
  line
  line `(b) who feigns any disease, infirmity or inability to perform his duty;`
  line
  line `shall be punished with imprisonment for a term which may extend to five years or such other punishment`
  line `as is hereinafter mentioned.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (29260)
  sectionNo (62)
  orderNo 66
  title `Penalty for endeavouring to stir up disturbance on account of unwholesomeness of victuals or other just grounds.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29260&sectionno=62&orderno=66&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_62_content:
  string
  line `Every person subject to naval law who has any cause of complaint either of the`
  line `unwholesomeness of the victuals or upon any other just ground shall quietly make the same known to his`
  line `superior or captain or to the Chief of the Naval Staff, in accordance with the prescribed channels of`
  line `communication and the said superior, captain or Chief of the Naval Staff shall, as far as he is able, cause`
  line `the same to be presently remedied; and every person subject to naval law who upon any pretence`
  line `whatever attempts to stir up any disturbance shall be punished with imprisonment for a term which may`
  line `extend to fourteen years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (29261)
  sectionNo (63)
  orderNo 67
  title `Offences in respect of papers relating to prize.`
  content obj_root_law_sections_63_content
  footnotes `1. Subs. by Act 58 of 1960, s. 3 and the Second Schedule, for "abroad" (w.e.f. 26-12-1960).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29261&sectionno=63&orderno=67&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_63_content:
  string
  line `(1) All the papers, charter-parties, bills of`
  line `lading passports and other writings whatsoever that shall be taken, seized, or found ^1[aboard] any ships`
  line `which are taken as prize shall be duly preserved and the commanding officer of the ship which takes such`
  line `prize shall send the originals entire and without fraud to the Court of competent jurisdiction or such other`
  line `Court or commissioners as shall be authorised to determine whether such prize be lawful capture, there to`
  line `be viewed, made use of and proceeded upon according to law.`
  line
  line `(2) Every commanding officer who wilfully fails to send the papers, charter-parties, bills of lading,`
  line `passports or other writings whatsoever that shall be taken, seized, or found ^1[aboard] any ships which are`
  line `taken as prize to the proper Court or other authority shall be punished with dismissal from the naval`
  line `service or such other punishment as is hereinafter mentioned and in addition shall forfeit and lose any`
  line `share of the capture.`
obj_root_law_sections_64:
  sectionId (29262)
  sectionNo (64)
  orderNo 68
  title `Offences in respect of price.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29262&sectionno=64&orderno=68&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_64_content:
  string
  line `Every person subject to naval law who takes out of any prize or`
  line `ship seized for prize, any money, plate or goods, unless it is necessary for the better securing thereof, or`
  line `for the necessary use and service of any ships of war of the Indian Navy, before the same be adjuged`
  line `lawful prize in a Court of competent jurisdiction, shall be punished with imprisonment for a term which`
  line `may extend to two years or such other punishment as is hereinafter mentioned, and in addition shall`
  line `forfeit and lose his share of the capture.`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (29263)
  sectionNo (65)
  orderNo 69
  title `Offences in respect of persons on board a prize ship.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29263&sectionno=65&orderno=69&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_65_content:
  string
  line `Every person subject to naval law who`
  line `in any sort pillages, beats, or ill-treats officers, mariners or other persons on board a ship or vessel taken`
  line `as prize or who unlawfully strips them off their clothes, shall be punished with imprisonment for a term`
  line `which may extend to two years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (29264)
  sectionNo (66)
  orderNo 70
  title `Unlawful taking of ransoming a prize`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29264&sectionno=66&orderno=70&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_66_content:
  string
  line `Every commanding officer of a ship of the Indian`
  line `Navy subject to naval law, who,--`
  line
  line `(a) by collusion with the enemy take as prize any vessel, goods or thing; or`
  line
  line `(b) unlawfully agrees with any person for the ransoming of any vessel, goods or thing taken as`
  line `prize; or`
  line
  line `(c) in pursuance of any unlawful agreement for ransoming or otherwise by collusion actually`
  line `quits or restores any vessel, goods or thing taken as prize;`
  line
  line `shall be punished with imprisonment for a term which may extend to two years or such other punishment`
  line `as is hereinafter mentioned.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (29265)
  sectionNo (67)
  orderNo 71
  title `Breaking bulk on board a prize ship.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29265&sectionno=67&orderno=71&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_67_content:
  string
  line `Every person subject to naval law who breaks bulk on`
  line `board any vessel taken as prize, or detained in the exercise of any beligerent right or under any law`
  line `relating to piracy or to the slave trade or to the customs, with intent dishonestly to misappropriate`
  line `anything therein or belonging thereto, shall be punished with imprisonment for a term which may extend`
  line `to two years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (29266)
  sectionNo (68)
  orderNo 72
  title `Violation of the Act, regulations and orders.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29266&sectionno=68&orderno=72&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_68_content:
  string
  line `Every person subject to naval law who neglects`
  line `to obey or contravenes any provisions of this Act or any regulation made under this Act or any general or`
  line `local order, shall, unless other punishment is provided in this Act for such neglect or contravention, be`
  line `punished with imprisonment for a term which may extend to two years or such other punishment as is`
  line `hereinafter mentioned.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (29267)
  sectionNo (69)
  orderNo 73
  title `Offences in relation to Court-martial.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29267&sectionno=69&orderno=73&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_69_content:
  string
  line `Every person subject to naval law, who,--`
  line
  line `(a) being duly summoned or ordered to attend as a witness before a court-martial wilfully or`
  line `without reasonable excuse fails to attend; or`
  line
  line `(b) refuses to take an oath or make an affirmation legally required by a court-martial to be taken`
  line `or made; or`
  line
  line `(c) being sworn, refuses to answer any questions which he is in law bound to answer; or`
  line
  line `(d) refuses to produce or deliver up a document in his power which the court may legally`
  line `demand; or`
  line
  line `(e) is guilty of contempt of court-martial;`
  line
  line `shall be punished with imprisonment for a term which may extend to three years or such other`
  line `punishment as is hereinafter mentioned.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (29268)
  sectionNo (70)
  orderNo 74
  title `Fraudulent entry`
  content obj_root_law_sections_70_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29268&sectionno=70&orderno=74&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_70_content:
  string
  line `Every person who upon entry into or offering himself to enter the naval`
  line `service wilfully makes or gives any false statement whether orally or in writing to any officer or person`
  line `authorised to enter or enrol ^1[sailors] or others in or for such naval service, shall, if he has become subject`
  line `to naval law, be punished with imprisonment for a term which may extend to five years or such other`
  line `punishment as is hereinafter mentioned.`
obj_root_law_sections_71:
  sectionId (29269)
  sectionNo (71)
  orderNo 75
  title `Escape from custody`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29269&sectionno=71&orderno=75&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_71_content:
  string
  line `Every person subject to naval law who being in lawful custody escapes`
  line `or attempts to escape from such custody shall be punished with imprisonment for a term which may`
  line `extend to five years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_71_footnotes:
  string
  line
obj_root_law_sections_72:
  sectionId (29270)
  sectionNo (72)
  orderNo 76
  title `Failure to assist in detention of offenders.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29270&sectionno=72&orderno=76&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_72_content:
  string
  line `Every person subject to naval law, who,--`
  line
  line `(a) does not use his utmost endeavours to detect, apprehend or bring to punishment all offenders`
  line `against this Act; or`
  line
  line `(b) does not assist the officers appointed for that purpose;`
  line
  line `shall be punished with imprisonment for a term which may extend to two years or such other punishment`
  line `as is hereinafter mentioned.`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (29271)
  sectionNo (73)
  orderNo 77
  title `Penalty for failure to attend by members of reserve forces when called up.`
  content obj_root_law_sections_73_content
  footnotes `1. Ins. by s. 15, ibid. (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29271&sectionno=73&orderno=77&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_73_content:
  string
  line `Every member`
  line `of the Indian Naval Reserve Forces ^1[and every person belonging to any auxiliary forces raised under this`
  line `Act who, when called up for training or when called up into actual service with the Indian Navy in`
  line `pursuance of the regulations made under this Act, and required by such call to join any ship or attend at`
  line `any place, fails, without reasonable excuse to comply with such requirement, shall be punished with`
  line `imprisonment for a term which may extend to three years or such other punishment as is hereinafter`
  line mentioned.
obj_root_law_sections_74:
  sectionId (29272)
  sectionNo (74)
  orderNo 78
  title `Offences against good order and naval discipline`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29272&sectionno=74&orderno=78&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_74_content:
  string
  line `Every person subject to naval law who is`
  line `guilty of an act, disorder, or neglect to the prejudice of good order and naval discipline, not hereinbefore`
  line `specified, shall be punished with imprisonment for a term which may extend to three years or such other`
  line `punishment as is hereinafter mentioned.`
obj_root_law_sections_74_footnotes:
  string
  line
obj_root_law_sections_75:
  sectionId (29273)
  sectionNo (75)
  orderNo 79
  title Attempts.
  content obj_root_law_sections_75_content
  footnotes obj_root_law_sections_75_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29273&sectionno=75&orderno=79&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_75_content:
  string
  line `Every person subject to naval law who attempts to commit any of the offences`
  line `specified in sections 34 to 74 and 76 and in such attempt does any act towards the commission of the offence shall, where no express provision is made by this Act for the punishment of such attempt, be`
  line punished,--
  line
  line `(a) if the offence attempted to be committed is punishable with death, with imprisonment for a`
  line `term which may extend to fourteen years or such other punishment as is hereinafter mentioned, and`
  line
  line `(b) if the offence attempted to be committed is punishable with imprisonment, with one-half of`
  line `the maximum punishment provided for the offence or with such other punishment as is hereinafter`
  line mentioned.
obj_root_law_sections_75_footnotes:
  string
  line
obj_root_law_sections_76:
  sectionId (29274)
  sectionNo (76)
  orderNo 80
  title `Abetment of offences.`
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29274&sectionno=76&orderno=80&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_76_content:
  string
  line `Any person subject to naval law who abets the commission of any of the`
  line `offences specified in sections 34 to 74 shall, whether the act abetted is committed or not in consequence`
  line `of the abetment, and where no express provision is made by this Act for the punishment of such abetment,`
  line `be punished with the punishment provided for that offence.`
obj_root_law_sections_76_footnotes:
  string
  line
obj_root_law_sections_77:
  sectionId (29275)
  sectionNo (77)
  orderNo 81
  title `Civil offences`
  content obj_root_law_sections_77_content
  footnotes obj_root_law_sections_77_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29275&sectionno=77&orderno=81&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_77_content:
  string
  line `(1) Every person subject to naval law who commits a civil offence punishable`
  line `with death or with imprisonment for life shall be punished with the punishment assigned for that offence.`
  line
  line `(2) Every person subject to naval law who commits any other civil offence shall be punished either`
  line `with the punishment assigned for the offence or with imprisonment for a term which may extend to three`
  line `years or such other punishment as is hereinafter mentioned.`
obj_root_law_sections_77_footnotes:
  string
  line
obj_root_law_sections_78:
  sectionId (29276)
  sectionNo (78)
  orderNo 82
  title `Jurisdiction as to place and offences.`
  content obj_root_law_sections_78_content
  footnotes obj_root_law_sections_78_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29276&sectionno=78&orderno=82&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_78_content:
  string
  line `(1) Subject to the provisions of sub-section (2), every`
  line `person subject to naval law who is charged with a naval offence or a civil offence may be tried and`
  line `punished under this Act regardless of where the alleged offence was committed.`
  line
  line `(2) A person subject to naval law who commits an offence of murder against a person not subject to`
  line `army, naval or air force law or an offence of culpable homicide not amounting to murder against such`
  line `person or an offence of rape in relation to such person shall not be tried and punished under this Act`
  line `unless he commits any of the said offences--`
  line
  line `(a) while on active service; or`
  line
  line `(b) at any place outside India; or`
  line
  line `(c) at any place specified by the Central Government by notification in this behalf.`
obj_root_law_sections_78_footnotes:
  string
  line
obj_root_law_sections_79:
  sectionId (29277)
  sectionNo (79)
  orderNo 83
  title `Jurisdiction as to time`
  content obj_root_law_sections_79_content
  footnotes `1. Subs. by Act 23 of 2005, s. 3, for "Proviso further that" (w.e.f. 23-6-2005).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29277&sectionno=79&orderno=83&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_79_content:
  string
  line `No person unless he is an offender who has avoided apprehension or`
  line `fled form justice or committed the offence of desertion or fraudulent entry or the offence of mutiny shall`
  line `be tried or punished in pursuance of this Act for any offence committed by him unless such trial`
  line `commences within three years from the commission of such offence:`
  line
  line `Provided that in the computation of the said period of three years any time during which an offender`
  line `was outside Indial or any time during which he was a prisoner of war shall be deducted:`
  line
  line ^1
  line `[Provided further that in computation of the said period of three years, any time during which,--`
  line
  line `(a) the commission of the offence was not known to the person aggrieved by the offence or to the`
  line `authority competent to initiate action, the first day on which such offence comes to the knowledge of`
  line `such person or authority, whichever is earlier;`
  line
  line `(b) it was not known by whom the offence was committed, the first day on which the identity of`
  line `the offender is known to the person aggrieved by the offence or to the authority investigating into the`
  line `offence, whichever is earlier, shall be excluded;`
  line
  line `Provided also that] where the institution of the prosecution in respect of an offence has been stayed by`
  line `an injunction or order, then, in computing the said period of three years, the period of the continuance of`
  line `the injunction or order, the day on which it was issued or made and the day on which it was withdrawn`
  line `shall be excluded:`
  line
  line `Provided also that no trial for an offence of desertion other than desertion on active service or`
  line `fraudulent entry shall be commenced if the person in question not being an officer has subsequently to the commission of the offence served continuously in an exemplary manner for not less than three years in`
  line `the Indian Navy.`
obj_root_law_sections_80:
  sectionId (29278)
  sectionNo (80)
  orderNo 84
  title `Trial after a person ceases to be subject to naval law`
  content obj_root_law_sections_80_content
  footnotes obj_root_law_sections_80_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29278&sectionno=80&orderno=84&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_80_content:
  string
  line `When any offence mentioned in this`
  line `Chapter has been committed by any person while subject to naval law and such person has since the`
  line `commission of the offence ceased to be subject to naval law, he may be taken into and kept in custody,`
  line `tried and punished under this Act for such offence in like manner as he may have been taken into and kept`
  line `in custody, tried and punished if he had continued subject to naval law:`
  line
  line `Provided that he shall not be tried for such offence except in the case of an offence of mutiny or`
  line `desertion, unless the trial against him commences within six months after he has ceased to be so subject.`
obj_root_law_sections_80_footnotes:
  string
  line
obj_root_law_sections_81:
  sectionId (29279)
  sectionNo (81)
  orderNo 85
  title Punishments.
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29279&sectionno=81&orderno=85&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_81_content:
  string
  line `(1) The following punishments may be inflicted under this Act, namely:--`
  line
  line `(a) death;`
  line
  line `(b) imprisonment which may be for the term of life or any other lesser term;`
  line
  line `(c) dismissal with disgrace from the naval service;`
  line
  line `(d) detention;`
  line
  line `(e) dismissal from the naval service;`
  line
  line `(f) forfeiture of seniority in rank in the case of officers ^1[and master chief petty officers];`
  line
  line `(g) forfeiture of time for promotion in the case of ^2[officers below the rank of commander and`
  line `master chief petty officers];`
  line
  line `(h) dismissal from the ship to which the offender belongs;`
  line
  line `(i)`
  line `^3[reduction in rank], in the case of ^4[petty officers] and persons holding leading rates;`
  line
  line `(j) fine, in respect of civil offences;`
  line
  line `(k) mulcts of pay and allowances;`
  line
  line `(l) severe reprimand or reprimand;`
  line
  line `(m) forfeiture of pay, head money, bounty, salvage, prize money and allowances earned by, and`
  line `all annuities, pensions, gratuities, medals and decorations granted to, the offender or of any one or`
  line `more of the above particulars; also in the case of desertion, of all clothes and effects left by the`
  line `deserter in the ship to which he belongs;`
  line
  line `(n) such minor punishments as are inflicted according to the custom of the navy or may from time`
  line `to time be prescribed.`
  line
  line `(2) Each of the punishments specified in sub-section (1) shall be deemed to be inferior in degree to`
  line `every punishment preceding it in the above scale.`
obj_root_law_sections_81_footnotes:
  string
  line `1. Ins. by Act 48 of 1982, s. 3 (w.e.f. 16-10-1982).`
  line
  line `2. Subs. by s. 3, ibid., for "subordinate officers" (w.e.f. 16-10-1982).`
  line
  line `3. Subs. by s. 3, ibid., for "disrating" (w.e.f. 16-10-1982).`
  line
  line `4. Subs. by s. 3, ibid., for "subordinate and petty officers" (w.e.f. 16-10-1982).`
obj_root_law_sections_82:
  sectionId (29280)
  sectionNo (82)
  orderNo 86
  title `Provisions as to award of punishment`
  content obj_root_law_sections_82_content
  footnotes obj_root_law_sections_82_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29280&sectionno=82&orderno=86&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_82_content:
  string
  line `(1) The punishments that may be inflicted under this`
  line `Act shall be awarded in accordance with the provisions of the following sub-sections.`
  line
  line `(2) Except in the case of mutiny in time of war or on active service, the punishment of death shall not`
  line `be inflicted on any offender until the sentence has been confirmed by the Central Government.`
  line
  line `(3) The punishment of imprisonment for a term exceeding two years shall in all cases be accompanied`
  line `by a sentence of dismissal with disgrace from the naval service.`
  line
  line `(4) The punishment of imprisonment for a term not exceeding two years may in all cases be`
  line `accompanied by a sentence of dismissal with disgrace or dismissal from the naval service:`
  line
  line `Provided that in the case of officers, unless the sentence of dismissal with disgrace is also awarded,`
  line `such sentence of imprisonment shall involve dismissal from the naval service.`
  line
  line `(5) The sentence of imprisonment may be rigorous or simple, or partly rigorous and partly simple.`
  line
  line `(6) The sentence of dismissal with disgrace shall involve in all cases forfeiture of all pay, head`
  line `money, bounty, salvage, prize money and allowances that have been earned by and of all annuities,`
  line `pensions, gratuities, medals and decorations that may have been granted to the offender and an incapacity`
  line `to serve Government again in a defence service, or a civil service, or to hold any post connected with`
  line `defence or any civil post under the Government:`
  line
  line `Provided that the forfeiture of moneys shall not apply, except in the case of deserters, to moneys`
  line `which should have been paid on the last pay day preceding conviction.`
  line
  line `(7) The punishment of dismissal from the naval service shall in the case of persons who hold any lien`
  line `on appointments in the regular Army or Air Force, involve dismissal from such army or air force service.`
  line
  line `(8) The punishment of detention may be inflicted for any term not exceeding two years but no`
  line `sentence of detention shall be awarded unless naval detention quarters or army or air force detention`
  line `barracks are in existence.`
  line
  line `(9) The punishment of imprisonment or detention whether on board ship or on shore shall, subject to`
  line `the provisions of sub-section (14), involve ^1[reduction in rank], in the case of a petty officer or a person`
  line `holding a leading ^2[rank], and shall in all cases be accompanied by stoppage of pay and allowances during`
  line `the term of imprisonment or detention:`
  line
  line `Provided that where the punishment awarded is detention for a term not exceeding fourteen days, the`
  line `sentence may direct that the punishment shall not be accompanied by stoppage of pay and allowances`
  line `during the term of detention.`
  line
  line `(10) No officer shall be subject to detention.`
  line
  line `(11) The punishment of forfeiture of seniority shall be imposed in the substantive rank held at the date`
  line `of the sentence, and shall involve a corresponding forfeiture of seniority in every higher acting rank`
  line `subject always to the condition that forfeiture of seniority in any rank shall in no case exceed the seniority`
  line `in that rank at the date of the sentence.`
  line
  line `(12) The punishment of forfeiture of seniority shall involve the loss of the benefit of service included`
  line `in the seniority forfeited for the purposes of pay, pension, gratuity, promotion and such other purposes, as`
  line `may be prescribed, provided that such pay, pension, gratuity and promotion and other purposes depend`
  line `upon such service.`
  line
  line `^3[(12A) No master chief petty officer shall be subject to the punishment of forfeiture of seniority of`
  line `more than twelve months.]`
  line
  line `(13) The punishment of forfeiture of time for promotion shall delay the promotion by the time`
  line specified,
  line
  line `^3[(13A) No master chief petty officer shall be subject to the punishment of forfeiture of time for`
  line `promotion of more than twelve months.]`
  line
  line `(14) No person shall be ^4[reduced in rank] below the limits prescribed, or lower either actually or`
  line `relatively than the ^5[rank] in which he entered or was appointed in the naval service.`
  line
  line `(15) Mulcts of pay and allowances shall not be awarded except as provided in sub-sections (16)`
  line `and (17).`
  line
  line `(16) Mulcts of pay and allowances shall be awarded in accordance with the regulations made under`
  line `this Act on conviction of offences under Section 31.`
  line
  line `(17) Mulcts of pay may also be awarded to make good any proved loss or damage occasioned by the`
  line `offence on which there is a conviction, and for the offence of drunkenness by ^6[sailors].`
  line
  line `(18) The punishment of fine may be awarded in respect of civil offences in addition to, or in lieu of,`
  line `other punishments specified in this Act.`
  line
  line `(19) The forfeiture of moneys under clause (m) of sub-section (1) of section 81 shall not, except in`
  line `case of desertion apply to moneys which should have been paid on the last pay day preceding conviction.`
  line
  line `(20) All other punishments authorised by this Act may be inflicted in such manner as is heretofore in`
  line `use in the naval service or as may be prescribed.`
  line
  line `(21) Subject to the provisions of the foregoing sub-sections, where any punishment is specified by`
  line `this Act as the penalty for an offence and it is further declared that "such other punishment as is`
  line `hereinafter mentioned" may be awarded in respect of the same offence, the expression "such other`
  line `punishment" shall be deemed to comprise any one or more of the punishments inferior in degree to the`
  line `specified punishment according to the scale of punishments laid down in sub-section (1) of section 81.`
obj_root_law_sections_82_footnotes:
  string
  line `1. Subs. by Act 48 of 1982, s. 4, for "distracting" (w.e.f. 16-10-1982).`
  line
  line `2. Subs. by s. 4, ibid., for "rate" (w.e.f. 16-10-1982).`
  line
  line `3. Ins. by s. 4, ibid. (w.e.f. 16-10-1982).`
  line
  line `4. Subs. by s. 4, ibid., for "distracting" (w.e.f. 16-10-1982).`
  line
  line `5. Subs. by s. 4, ibid., for "rate" (w.e.f. 16-10-1982).`
  line
  line `6. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-10-1982).`
obj_root_law_sections_83:
  sectionId (29281)
  sectionNo (83)
  orderNo 87
  title `Power to issue warrants of arrest.`
  content obj_root_law_sections_83_content
  footnotes obj_root_law_sections_83_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29281&sectionno=83&orderno=87&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_83_content:
  string
  line `(1) The Chief of the Naval Staff, every officer in command`
  line `of a fleet or squadron of ships of the Indian Navy or of any ship of the Indian Navy or the senior officer`
  line `present at a port or an officer having by virtue of sub-sections (2) and (3) of section 93 power to try`
  line `offences, may, by warrant under his hand, authorise any person to arrest any offender subject to naval law`
  line `for any offence triable under this Act mentioned in such warrant and any such warrant may include the`
  line `names of more persons than one in respect of several offences of the same nature.`
  line
  line `(2) Any person named in any such warrant as aforesaid may, forthwith on his arrest, if the warrant so`
  line `directs, be taken to the ship of the Indian Navy to which he belongs or some other ship of the`
  line `Indian Navy.`
  line
  line `(3) A person authorised to arrest an offender may use such force as may be necessary for the purpose`
  line `of effecting such arrest.`
  line
  line `(4) Where a warrant under sub-section (1) is issued to a police officer, the police officer shall take`
  line `steps to execute the warrant and arrest the offender in like manner as if such warrant had been issued by a`
  line `Magistrate of competent jurisdiction and shall, as soon as may be, deliver the person when arrested into`
  line `naval custody.`
obj_root_law_sections_83_footnotes:
  string
  line
obj_root_law_sections_84:
  sectionId (29282)
  sectionNo (84)
  orderNo 88
  title `Arrest without warrant.`
  content obj_root_law_sections_84_content
  footnotes obj_root_law_sections_84_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29282&sectionno=84&orderno=88&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_84_content:
  string
  line `(1) Any person subject to naval law may be ordered without warrant`
  line `into naval custody by any superior officer for any offence triable under this Act.`
  line
  line `(2) A person subject to naval law may arrest without warrant any other person subject to naval law`
  line `though he may be of a higher rank who in his view commits an offence punishable with death, or`
  line `imprisonment for life or for a term which may extend to fourteen years.`
  line
  line `(3) A provost-marshal may arrest any person subject to naval law in accordance with the provisions`
  line `of section 89.`
  line
  line `(4) It shall be lawful for the purpose of effecting arrest, or taking a person into custody, without`
  line `warrant to use such force as may be necessary for the purpose.`
obj_root_law_sections_84_footnotes:
  string
  line
obj_root_law_sections_85:
  sectionId (29283)
  sectionNo (85)
  orderNo 89
  title `Procedure and conditions of naval custody.`
  content obj_root_law_sections_85_content
  footnotes obj_root_law_sections_85_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29283&sectionno=85&orderno=89&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_85_content:
  string
  line `(1) No person subject to naval law who is`
  line `arrested under this Act shall be detained in naval custody without being informed, as soon as may be, of`
  line `the grounds for such arrest.`
  line
  line `(2) Every person subject to naval law who is arrested and detained in naval custody shall be produced`
  line `before his commanding officer or other officer prescribed in this behalf within a period of forty-eight`
  line `hours of such arrest excluding the time necessary for the journey from the place of arrest to such`
  line `commanding or other officer and no such person shall be detained in custody beyond the said period`
  line `without the authority of such commanding or other officer.`
obj_root_law_sections_85_footnotes:
  string
  line
obj_root_law_sections_86:
  sectionId (29284)
  sectionNo (86)
  orderNo 90
  title `Investigation after arrest.`
  content obj_root_law_sections_86_content
  footnotes obj_root_law_sections_86_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29284&sectionno=86&orderno=90&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_86_content:
  string
  line `The charge made against any person subject to naval law taken into`
  line `custody shall without any unnecessary delay be investigated by the proper authority and as soon as may`
  line `be either proceedings shall be taken for the trial or such person shall be discharged from custody.`
obj_root_law_sections_86_footnotes:
  string
  line
obj_root_law_sections_87:
  sectionId (29285)
  sectionNo (87)
  orderNo 91
  title `Duty to receive or keep in custody.`
  content obj_root_law_sections_87_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-10-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29285&sectionno=87&orderno=91&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_87_content:
  string
  line `(1) The commanding officer shall be responsible for the`
  line `safe custody of every person who is in naval custody on board his ship or in his establishment.`
  line
  line `(2) The officer or ^1[sailor] in charge of a guard, or a provost-marshal shall receive and keep any`
  line `person who is duly committed to his custody.`
obj_root_law_sections_88:
  sectionId (29286)
  sectionNo (88)
  orderNo 92
  title `Procedure before trial.`
  content obj_root_law_sections_88_content
  footnotes obj_root_law_sections_88_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29286&sectionno=88&orderno=92&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_88_content:
  string
  line `Subject to the provisions of this Act, the procedure before trial and the`
  line `manner of investigation shall be as prescribed.`
obj_root_law_sections_88_footnotes:
  string
  line
obj_root_law_sections_89:
  sectionId (29287)
  sectionNo (89)
  orderNo 93
  title Provost-marshals
  content obj_root_law_sections_89_content
  footnotes obj_root_law_sections_89_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29287&sectionno=89&orderno=93&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_89_content:
  string
  line `(1) Provost-marshals may be appointed by the Chief of the Naval Staff or`
  line `the prescribed officer.`
  line
  line `(2) The duties of a provost-marshal or to take charge of persons in naval custody, to preserve good`
  line `order and discipline and to prevent breaches of the same by persons subject to naval law or to the law in`
  line `force relating to the Government of the regular Army or the Air Force.`
  line
  line `(3) A provost-marshal may at any time arrest and detain for trial any person subject to naval law who`
  line `commits, or is charged with, an offence and may also carry into effect any punishment to be inflicted in`
  line `pursance of a sentence passed under this Act, but shall not inflict any punishment on his own authority:`
  line
  line `Provided that no officer shall be so arrested or detained otherwise than on the order of`
  line `another officer.`
  line
  line `(4) For the purpose of sub-sections (2) and (3), a provost-marshal shall be deemed to include a`
  line `provost-marshal and any of his assistants appointed under the law in force relating to the government of`
  line `the regular Army or the Air Force.`
obj_root_law_sections_89_footnotes:
  string
  line
obj_root_law_sections_90:
  sectionId (29288)
  sectionNo (90)
  orderNo 94
  title `Joinder of charges.`
  content obj_root_law_sections_90_content
  footnotes obj_root_law_sections_90_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29288&sectionno=90&orderno=94&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_90_content:
  string
  line `For every distinct offence of which any person is accused, there shall be a`
  line `separate charge but except as otherwise provided by regulations made under this Act all separate charges`
  line `may be tried together.`
obj_root_law_sections_90_footnotes:
  string
  line
obj_root_law_sections_91:
  sectionId (29289)
  sectionNo (91)
  orderNo 95
  title `Acts amounting to different offences.`
  content obj_root_law_sections_91_content
  footnotes obj_root_law_sections_91_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29289&sectionno=91&orderno=95&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_91_content:
  string
  line `If a single act or series of acts is of such a nature that it`
  line `is doubtful which of several offences the acts which can be proved will constitute, the accused may be`
  line `charged with having committed all or any of such offences, and any number of such charges may be tried`
  line `at one trial; or he may be charged in the alternative with having committed some one of the said offences.`
obj_root_law_sections_91_footnotes:
  string
  line
obj_root_law_sections_92:
  sectionId (29290)
  sectionNo (92)
  orderNo 96
  title `Joinder of accused person`
  content obj_root_law_sections_92_content
  footnotes obj_root_law_sections_92_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29290&sectionno=92&orderno=96&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_92_content:
  string
  line `The following persons may be charged and tried together,`
  line `namely:--`
  line
  line `(i) persons accused of the same offence committed in the course of the same transaction;`
  line
  line `(ii) persons accused of an offence and persons accused of abetment of, or an attempt to commit,`
  line `such offence; and`
  line
  line `(iii) persons accused of different offences committed in the course of the same transaction:`
  line
  line `Provided that in a trial by a court-martial the trial judge advocate may, on the application made in this`
  line `behalf by any accused, direct that each of the accused be tried separately by the same court-martial.`
obj_root_law_sections_92_footnotes:
  string
  line
obj_root_law_sections_93:
  sectionId (29291)
  sectionNo (93)
  orderNo 97
  title `Power of court-martial and commanding officers to try offences`
  content obj_root_law_sections_93_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29291&sectionno=93&orderno=97&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_93_content:
  string
  line `(1) An offence triable`
  line `under this Act may be tried and punished by court-martial.`
  line
  line `(2) An offence not capital which is triable under this Act and which is committed by a person other`
  line `than an officer (and in cases by this Act expressly provided for when committed by an officer), may,`
  line `subject to regulations made under this Act be summarily tried and punished by the commanding officer of`
  line `the ship to which the offender belongs at the time either of the commission or of the trial of the offence,`
  line `subject to the restriction that the commanding officer shall not have power to award imprisonment or`
  line `detention for more than three months, or to award dismissal with disgrace from the naval service:`
  line
  line `Provided that no sentence of imprisonment or dismissal shall be carried into effect until approved by`
  line `the prescribed authorities.`
  line
  line `(3) The power by this section vested in a commanding officer of a ship may, subject to regulations`
  line `made under this Act,--`
  line
  line `(a) as respects ^1[sailors] on board a tender to the ship, be exercised in the case of a single tender`
  line `absent from the ship, by the officer in command of such tender and in the case of two or more tenders`
  line `absent from the ship in company or acting together, by the officer in immediate command of such`
  line tenders;
  line
  line `(b) as respects ^[sailors] on board any boat belonging to the ship, be exercised when such boat is`
  line `absent on detached service by the officer in command of the boat;`
  line
  line `(c) as respects ^1[sailors] on detached service either on shore or otherwise, be exercised by the`
  line `officer in immediate command of those persons;`
  line
  line `(d) as respects ^1[sailors] quartered in naval barracks, be exercised by the officer in command`
  line `of the barracks;`
  line
  line `(e) as respects ^1[sailors] attached to or serving with any body of the regular Army or the Air Force`
  line `under prescribed conditions be exercised by the commanding officer of any such body of the regular`
  line `Army or the Air Force.`
  line
  line `(4) The commanding officer of a ship or barracks may delegate the power of awarding`
  line `punishments inferior in scale to dismissal, to other officers under his command in accordance with the`
  line `regulations made under this Act.`
obj_root_law_sections_94:
  sectionId (29292)
  sectionNo (94)
  orderNo 98
  title `Power of Central Government, Chief of the Naval Staff and other officers to impose forfeiture of time or seniority`
  content obj_root_law_sections_94_content
  footnotes obj_root_law_sections_94_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29292&sectionno=94&orderno=98&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_94_content:
  string
  line `^1[(1) The Central Government may impose on any officer below the`
  line `rank of commander one or more of the following punishments, namely:--`
  line
  line `(a) forfeiture of seniority in rank of not more than twelve months;`
  line
  line `(b) forfeiture of time for promotion of not more than twelve months;`
  line
  line `(c) mulcts of pay and allowances.`
  line
  line `(2) The Chief of the Naval Staff may impose on ^2[any officer below the rank of commander] one or`
  line `more of the following punishments, namely:--`
  line
  line `(a) forfeiture of seniority in rank of not more than six months;`
  line
  line `(b) forfeiture of time for promotion of not more than six months;`
  line
  line `(c) mulcts of pay and allowances.`
  line
  line `(2A) The Flag Officer Commanding-in-Chief of a naval command may, subject to regulations made`
  line `under this Act, impose on any officer below the rank of commander one or more of the following`
  line `punishments, namely:--`
  line
  line `(a) forfeiture of seniority in rank of not more than three months;`
  line
  line `(b) forfeiture of time for promotion of not more than three months;`
  line
  line `(c) severe reprimand or reprimand;`
  line
  line `(d) mulcts of pay and allowances.`
  line
  line `(3) The commanding officer of a ship may. subject to regulations made under this Act, may impose`
  line `on any officer below the rank of commander one or more of the following punishments, namely:--`
  line
  line `(a) forfeiture of seniority in rank of not more than three months;`
  line
  line `(b) forfeiture of time for promotion of not more than three months;`
  line
  line `(c) mulcts of pay and allowances.]`
  line
  line `(4) In imposing punishments under sub-sections (1)`
  line `^3[(2) and (2A)], it shall not be necessary for the`
  line `Central Government or the Chief of the Naval Staff, as the case may be, to hear the accused in person or`
  line `by any friend or counsel.`
  line
  line `^4[(5) The commanding officer of a ^5[ship] or the officer-in-charge of a naval academy may impose on`
  line `any subordinate officer whilst under training such minor punishments, not higher than the punishment of`
  line `severe reprimand or reprimand, as may, from time to time, be prescribed.]`
  line
  line `(1) The Central Government may impose the punishment of forfeiture of time or seniority of not`
  line `more than twelve months on any officer below the rank of commander.`
  line
  line `(2) The Chief of the Naval Staff may impose the punishment of forfeiture of time or seniority of`
  line `not more than six months on any officer below the rank of commander.`
  line
  line `(2A) The Flag Officer Commanding-in-Chief of a naval command may, subject to regulations`
  line `made under this Act, impose on any officer below the rank of commander one or more of the`
  line `following punishments, namely:--`
  line
  line `(a) forfeiture of seniority in rank of not more than three months;`
  line
  line `(b) forfeiture of time for promotion of not more than three months;`
  line
  line `(c) severe reprimand or reprimand.`
  line
  line `(3) The commanding officer of a ship may subject to regulations made under this Act, impose the`
  line `punishment of forfeiture of time or seniority of not more than three months on any subordinate`
  line officer
obj_root_law_sections_94_footnotes:
  string
  line `1. Subs. by Act 23 of 2005, s. 4, for sub-sections (1), (2), (2A), and (3) (w.e.f. 23-6-2005).`
  line
  line `2. Subs. by Act 48 of 1982, s. 5, for "any subordinate officer" (w.e.f. 16-10-1982).`
  line
  line `3. Subs. Act, 48 of 1982, s. 5, for "and (2)" (w.e.f. 16-10-1982).`
  line
  line `4. Ins. by Act 53 of 1970, s. 16 (w.e.f. 16-12-1974).`
  line
  line `5. Subs. by s. 5, ibid., for "training ship" (w.e.f. 16-10-1982).`
obj_root_law_sections_95:
  sectionId (29293)
  sectionNo (95)
  orderNo 99
  title `Disciplinary Courts when may be constituted.`
  content obj_root_law_sections_95_content
  footnotes obj_root_law_sections_95_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29293&sectionno=95&orderno=99&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_95_content:
  string
  line `When an officer is, in time of war or during`
  line `active service, alleged to have been guilty of a disciplinary offence, that is to say of a breach of sections`
  line `41, 47, 48, 49, 51, 52, 68 and 74 or of any of those sections read with section 75 or 76, the officer having`
  line `the power to order a court-martial may, if he considers the offence to be of such a character as not to`
  line `necessitate trial by court-martial, in lieu of ordering a court-martial, order a disciplinary court constituted`
  line `as hereinafter mentioned.`
obj_root_law_sections_95_footnotes:
  string
  line
obj_root_law_sections_96:
  sectionId (29294)
  sectionNo (96)
  orderNo 100
  title `Constitution and procedure of disciplinary courts.`
  content obj_root_law_sections_96_content
  footnotes obj_root_law_sections_96_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29294&sectionno=96&orderno=100&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_96_content:
  string
  line `(1) A disciplinary court shall be`
  line `composed of not less than three nor more than five officers:`
  line
  line `Provided that the majority of the officers including the president shall be officers of the executive`
  line `branch of the naval service.`
  line
  line `(2) At least one of these officers composing the court shall be superior in rank to the officer under`
  line `trial and in any case shall be of the rank of substantive or acting commander or of a higher rank.`
  line
  line `(3) A disciplinary court shall have power to impose any punishment inferior to detention in the scale`
  line `hereinbefore contained, but no greater punishment.`
  line
  line `(4) The officers composing the disciplinary court shall be named by the authority ordering the same`
  line `or by an officer empowered in this behalf by such authority.`
  line
  line `(5) Subject to the provisions of the foregoing sub-sections, the procedure and practice of courtsmartial`
  line `provided by or under this Act shall apply to the procedure and practice of disciplinary courts`
  line `subject to such modifications as may be prescribed.`
obj_root_law_sections_96_footnotes:
  string
  line
obj_root_law_sections_97:
  sectionId (29295)
  sectionNo (97)
  orderNo 101
  title `Constitution of courts-martial.`
  content obj_root_law_sections_97_content
  footnotes `1. Ins. by Act 48 of 1982, s. 6 (w.e.f. 16-10-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29295&sectionno=97&orderno=101&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_97_content:
  string
  line `(1) Courts-martial shall be constituted and convened subject to`
  line `the provisions of the following sub-sections.`
  line
  line `(2) The President, the Chief of the Naval Staff, or any officer empowered in this behalf by`
  line `commission from the Chief of the Naval Staff shall have the power to order courts-martial for the trial of`
  line `offences under this Act.`
  line
  line `(3) Unless otherwise prescribed in respect of any specified port or station, an officer holding a`
  line `commission from the Chief of the Naval Staff to order courts-martial shall not be empowered to do so if`
  line `there is present at the place where such court-martial is to be held an officer superior in rank to himself`
  line `and in command of one or more of the ships of the Indian Navy although such last mentioned officer may`
  line `not hold a commission to order courts-martial and in such a case such last mentioned officer may order a`
  line `court-martial although he does not hold a commission for the purpose.`
  line
  line `(4) If an officer holding a commission from the Chief of the Naval Staff to order courts-martial,`
  line `having the command of a fleet or squadron and being outside Indian waters die, be recalled, leave his`
  line `station or be removed from his command, the officer upon whom the command of the fleet or squadron`
  line `devolves and so from time to time the officer who shall have the command of the fleet or squadron, shall`
  line `without any commission from the Chief of the Naval Staff have the same power to order courts-martial as`
  line `the first mentioned officer was invested with.`
  line
  line `(5) If an officer holding a commission from the Chief of the Naval Staff to order courts-martial and`
  line `having the command of any fleet or squadron of the Indian Navy outside Indian waters shall detach any`
  line `part of such fleet or squadron, or separate himself from any part of such fleet or squadron he may by`
  line `commission under his hand empower in the first mentioned case, the commanding officer of the squadron`
  line `or detachment ordered on such separate service and in the case of his death or ceasing so to command, the`
  line `officer to whom the command of such separate squadron or detachment shall belong, and in the second`
  line `mentioned case, the senior officer of the ships of the Indian Navy on the division of the station from`
  line `which he is absent, to order courts-martial during the time of such separate service or during his absence`
  line `from that division of the station as the case may be, and every such authority shall continue in force until`
  line `revoked or until the officer holding it returns to India or until he comes into the presence of a superior`
  line `officer empowered to order courts-martial in the same squadron, detachment or division of station but so`
  line `that such authority shall revive on the officer holding it ceasing to be in the presence of such a superior`
  line `officer and so from time to time as often as the case so requires.`
  line
  line `(6) A court-martial shall consist of not less than five nor more than nine officers.`
  line
  line `(7) No officer shall be qualified to sit as a member of a court-martial unless--`
  line
  line `(a) he is subject to naval law,`
  line
  line `(b) he is an officer of the Indian Navy of the rank of lieutenant or higher rank, and`
  line
  line `(c) he is of or over twenty-one years of age.`
  line
  line `(8) A prosecutor shall not be qualified to sit on the court-martial for the trial of the person`
  line `he prosecutes.`
  line
  line `(9) The officer ordering the court-martial, the officer who was the commanding officer of the ship to`
  line `which the accused belonged at the time of the commission of the alleged offence and the officer`
  line `investigating the offence shall not be qualified to sit on a court- martial for the trial of such accused.`
  line
  line `(10) Subject to the provisions of sub-sections (7) to (9), officers of the Indian Navy shall be eligible to`
  line `sit as members of a court-martial irrespective of the branch of the naval service to which they belong:`
  line
  line `Provided that--`
  line
  line `(a) the majority of the members of the court-martial, including the president, shall be officers of`
  line `the executive branch of the naval service, and`
  line
  line `(b) at trials for offences against sections 34, 35, 55, ^1[55A, 55C] and 56, officers other than`
  line `officers of the executive branch of the naval service shall not be eligible to sit.`
  line
  line `(11) A court-martial shall not be deemed to be duly constituted unless the members thereof are drawn`
  line `from at least two ships not being tenders, and commanded by officers of the rank of lieutenant or`
  line `higher rank.`
  line
  line `(12) The president of a court-martial shall be named by the authority ordering the same or by any`
  line `officer empowered by such authority to name the president.`
  line
  line `(13) No court-martial for the trial of a flag officer shall be duly constituted unless the president is a`
  line `flag officer and the other officers composing the court are of the rank of captain or of higher rank.`
  line
  line `(14) No court-martial for the trial of a captain shall be duly constituted unless the president is a`
  line `captain or of higher rank and`
  line
  line `(15) No court-martial for the trial of a commander shall be duly constituted unless the president is a`
  line `commander or of higher rank and two other members are commanders or officers of higher rank.`
  line
  line `(16) No court-martial for the trial of a person below the rank of commander shall be duly constituted`
  line `unless the president is a substantive or acting commander or of higher rank.`
  line
  line `(17) No commander or lieutenant-commander or lieutenant shall be required to sit as a member of a`
  line `court-martial when four officers of higher rank and junior to the president can be assembled at the place`
  line `where the court-martial is to be held, but the regularity or validity of any court-martial or of the`
  line `proceedings thereof shall not be affected by any commander, lieutenant-commander or lieutenant being`
  line `required to sit or sitting thereon under any circumstances and when any commander, lieutenantcommander`
  line `or lieutenant sits on any court- martial, the members of it shall not exceed five.`
  line
  line `(18) Members of the court-martial other than the president shall be appointed, subject to the`
  line `provisions of the foregoing sub-sections, in the manner provided in sub-section (19).`
  line
  line `(19) Subject to the provisions of sub-section (11), the president shall summon all officers except such`
  line `as are exempted under the provisions of sub-section (20), next in seniority to himself present at the place`
  line `where the court-martial shall be held, to sit thereon until the number of nine or such other number not less`
  line `than five as is attainable is complete.`
  line
  line `(20) The officer convening the court-martial or the senior naval officer present at the place where the`
  line `court-martial is to be held, may exempt by writing under his hand conveyed to the president of the courtmartial`
  line `any officer from attending as member on ground of sickness or urgent public duty.`
  line
  line `(21) In this section references to specified ranks of officers shall, unless otherwise stated, be deemed`
  line `to be references to substantive ranks and to include references to equivalent ranks in all branches of the`
  line `naval service.`
  line
  line `(22) When the naval forces are on active service, officers of the Indian Naval Reserve Forces subject`
  line `to naval law shall be eligible to sit as members of courts-martial on the same basis and under the same`
  line `conditions as officers of the Indian Navy.`
obj_root_law_sections_98:
  sectionId (29296)
  sectionNo (98)
  orderNo 102
  title `Where courts-martial to be held.`
  content `A court-martial may be held ashore or afloat.`
  footnotes obj_root_law_sections_98_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29296&sectionno=98&orderno=102&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_98_footnotes:
  string
  line
obj_root_law_sections_99:
  sectionId (29297)
  sectionNo (99)
  orderNo 103
  title `Trial judge advocate`
  content obj_root_law_sections_99_content
  footnotes obj_root_law_sections_99_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29297&sectionno=99&orderno=103&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_99_content:
  string
  line `(1) Every court-martial shall be attended by a person (in this Act referred`
  line `to as the trial judge advocate) who shall be either a judge advocate in the department of the Judge`
  line `Advocate-General of the Navy or any fit person appointed by the convening officer:`
  line
  line `Provided that in the case of a court-martial for the trial of a capital offence the trial judge advocate`
  line `shall be a person nominated by the Judge Advocate-General of the Navy unless such trial is held outside`
  line `Indian waters.`
  line
  line `(2) The trial judge advocate shall administer oath to every witness at the trial and shall perform such`
  line `other duties as are provided in this Act and as may be prescribed.`
obj_root_law_sections_99_footnotes:
  string
  line
obj_root_law_sections_100:
  sectionId (29298)
  sectionNo (100)
  orderNo 104
  title `Courts-martial to be public.`
  content obj_root_law_sections_100_content
  footnotes obj_root_law_sections_100_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29298&sectionno=100&orderno=104&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_100_content:
  string
  line `The place in which a court-martial is held for the purpose of`
  line `trying an offence under this Act shall be deemed to be an open court to which the public generally may`
  line `have access, so far as the same can conveniently contain them:`
  line
  line `Provided that, if the court is satisfied that it is necessary or expedient in the public interest or for the`
  line `ends of justice so to do, the court may at any stage of the trial of any particular case order that the public`
  line `generally or any portion thereof or any particular person shall not have access to, or be or remain in, the`
  line `place in which the court is held.`
obj_root_law_sections_100_footnotes:
  string
  line
obj_root_law_sections_101:
  sectionId (29299)
  sectionNo (101)
  orderNo 105
  title `Commencement of proceedings.`
  content obj_root_law_sections_101_content
  footnotes obj_root_law_sections_101_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29299&sectionno=101&orderno=105&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_101_content:
  string
  line `(1) As soon as the court has been assembled the accused`
  line `shall be brought before it and the prosecutor, the person or persons, if any, defending the accused and the`
  line `audience admitted.`
  line
  line `(2) Except where the accused defends himself, he may be defended by such person or persons as may`
  line `be prescribed.`
  line
  line `(3) The trial judge advocate shall read out the warrant for assembling the court and the names of`
  line `officers who are exempted from attending under sub-section (20) of section 97 together with the reasons`
  line `for such exemption.`
  line
  line `(4) The trial judge advocate shall read out the names of the officers composing the court and shall ask`
  line `the prosecutor whether he objects to any of them.`
  line
  line `(5) If the prosecutor shall have made no objection or after any objection made by the prosecutor has`
  line `been disposed of, the trial judge advocate shall ask the accused if he objects to any member of the court.`
obj_root_law_sections_101_footnotes:
  string
  line
obj_root_law_sections_102:
  sectionId (29300)
  sectionNo (102)
  orderNo 106
  title `Objections to members.`
  content obj_root_law_sections_102_content
  footnotes obj_root_law_sections_102_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29300&sectionno=102&orderno=106&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_102_content:
  string
  line `The following provisions shall apply to the disposal of objections`
  line `raised by the prosecutor as well as the accused:--`
  line
  line `(a) any member may be objected to on a ground which affects his competency to act as an`
  line `impartial Judge; and the trial judge advocate may reject summarily without reference to the members`
  line `of the court any objection not made on such ground; '`
  line
  line `(b) objections to members shall be decided separately, those to the officer lowest in rank being`
  line `taken first: provided that if the objection is to the President, such objection shall be decided first and`
  line `all the other members whether objected to or not shall vote as to the disposal of the objection;`
  line
  line `(c) on an objection being allowed by one-half or more of the officers entitled to decide`
  line `the objection, the member objected to shall at once retire and his place shall be filled up before an`
  line `objection against another member is taken up;`
  line
  line `(d) should the president be objected to and the objection be allowed, the court shall adjourn until`
  line `a new president has been appointed by the convening authority or by the officer empowered in this`
  line `behalf by the convening authority; and`
  line
  line `(e) should a member be objected to on the ground of being summoned as a witness and should it`
  line `be found that the objection has been made in good faith and that the officer is to give evidence as to`
  line `facts and not merely as to character, the objection shall be allowed.`
obj_root_law_sections_102_footnotes:
  string
  line
obj_root_law_sections_103:
  sectionId (29301)
  sectionNo (103)
  orderNo 107
  title `Further objections`
  content obj_root_law_sections_103_content
  footnotes obj_root_law_sections_103_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29301&sectionno=103&orderno=107&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_103_content:
  string
  line `(1) The trial judge advocate shall then ask the accused whether he has any`
  line `further objections to make respecting the constitution of the court; and should the accused raise any such`
  line `objection, it shall then be decided by the court, which decision shall be final and the constitution of the`
  line `court-martial shall not be afterwards impeached and it shall be deemed in all respects to have been duly`
  line constituted.
  line
  line `(2) If the accused should have no further objection to make to the constitution of the court or if any`
  line `objection is disallowed, the members and the trial judge advocate shall then make an oath or affirmation`
  line `in the form set out in section 104.`
obj_root_law_sections_103_footnotes:
  string
  line
obj_root_law_sections_104:
  sectionId (29302)
  sectionNo (104)
  orderNo 108
  title `Administering oath or affirmation`
  content obj_root_law_sections_104_content
  footnotes obj_root_law_sections_104_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29302&sectionno=104&orderno=108&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_104_content:
  string
  line `(1) Before the court shall proceed to try the person`
  line `charged, an oath or affirmation in the following form and manner shall be administered to the president`
  line `and every member of the court-martial in the order of their seniority by the trial judge advocate:--`
  line
  line `"I......................................do swear in the name of God`
  line `solemnly affirm that I will duly and faithfully`
  line `and to the best of my ability, knowledge and judgment administer justice according to law, without`
  line `fear or favour, affection or ill-will, and that I will not on any account at any time whatsoever disclose`
  line `or discover the vote or opinion of any particular member of this court-martial unless thereunto`
  line `required in due course of law."`
  line
  line `(2) The trial judge advocate shall then be sworn or affirmed by the president in the following form:--`
  line
  line `"I......................................do swear in the name of God`
  line `solemnly affirm that I will duly and faithfully`
  line `and to the best of my ability, knowledge and judgment perform the duties of my office according to`
  line `law, without fear or favour, affection or ill-will, and that I will not upon any account at any time`
  line `whatsoever disclose or discover the vote or opinion of any particular member of this court-martial`
  line `unless thereunto required in due course of law."`
obj_root_law_sections_104_footnotes:
  string
  line
obj_root_law_sections_105:
  sectionId (29303)
  sectionNo (105)
  orderNo 109
  title Arraignment.
  content obj_root_law_sections_105_content
  footnotes obj_root_law_sections_105_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29303&sectionno=105&orderno=109&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_105_content:
  string
  line `(1) When the court is ready to commence the trial, the trial judge advocate shall`
  line `read out the charges and shall ask the accused whether he pleads guilty or not guilty.`
  line
  line `(2) If the accused pleads guilty, then, before such plea is recorded, the trial judge advocate shall`
  line `ensure that the accused understands the charge to which he has pleaded guilty and the difference of`
  line `procedure which will result from the plea of guilty.`
  line
  line `(3) If it appears from the accuseds replies or from the summary of evidence prepared in the`
  line `prescribed manner that he should not plead guilty, the trial judge advocate may advise the accused to`
  line `withdraw his plea.`
  line
  line `(4) If the court accepts the plea of guilty, it shall be recorded as the finding of the court and the court`
  line `shall proceed to take steps to pass sentence unless there are other charges to be tried in which event the`
  line `sentence shall be deferred until after the findings on such charges are given.`
obj_root_law_sections_105_footnotes:
  string
  line
obj_root_law_sections_106:
  sectionId (29304)
  sectionNo (106)
  orderNo 110
  title `Opening of prosecution case.`
  content obj_root_law_sections_106_content
  footnotes obj_root_law_sections_106_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29304&sectionno=106&orderno=110&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_106_content:
  string
  line `(1) If the accused pleads not guilty or refuses to, or does not,`
  line `plead or if he claims to be tried or if in the circumstances mentioned in sub-section (3) of section 105`
  line `withdraws the plea of guilty or if the court does not accept the plea of guilty, the court shall proceed to try`
  line `the accused.`
  line
  line `(2) The prosecutor shall open his case by reading the circumstantial letter prepared in accordance with`
  line `the regulations made under this Act, reading from this Act or the Indian Penal Code (45 of 1860) or other`
  line `law the description of the offence charged and stating shortly by what evidence he expects to prove the`
  line `guilt of the accused.`
  line
  line `(3) The prosecutor shall then examine his witnesses.`
obj_root_law_sections_106_footnotes:
  string
  line
obj_root_law_sections_107:
  sectionId (29305)
  sectionNo (107)
  orderNo 111
  title `Calling of prosecution witness not in the original list`
  content obj_root_law_sections_107_content
  footnotes obj_root_law_sections_107_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29305&sectionno=107&orderno=111&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_107_content:
  string
  line `No witness whose name was not`
  line `included in the original list of witnesses supplied to the trial judge advocate and the accused in`
  line `accordance with regulations made under this Act shall be called by the prosecutor unless the trial judge advocate has given notice to the accused of the prosecutor's intention to call such witness and has`
  line `supplied the accused with a summary of the evidence of such witness.`
obj_root_law_sections_107_footnotes:
  string
  line
obj_root_law_sections_108:
  sectionId (29306)
  sectionNo (108)
  orderNo 112
  title `Swearing of interpreter and shorthand-writer.`
  content obj_root_law_sections_108_content
  footnotes obj_root_law_sections_108_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29306&sectionno=108&orderno=112&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_108_content:
  string
  line `(1) At any time during the trial, should the`
  line `court think it necessary, an impartial person may be employed to serve as an interpreter and sworn or`
  line `affirmed as such in the following manner:--`
  line
  line `"I......................................do swear in the name of God`
  line `solemnly affirm that I will to the best of my ability truly`
  line `interpret and translate as I will be required to do touching the matter before this court-martial."`
  line
  line `(2) During the trial, an impartial person shall be employed as a shorthand-writer and duly sworn or`
  line `affirmed as such in the following manner:--`
  line
  line `"I......................................do swear in the name of God`
  line `solemnly affirm that I will truly take down to the best of`
  line `my power the evidence to be given before this court-martial and such other matters as I will be`
  line `required, and when required, will deliver to the court a true transcript of the same."`
obj_root_law_sections_108_footnotes:
  string
  line
obj_root_law_sections_109:
  sectionId (29307)
  sectionNo (109)
  orderNo 113
  title `Objection to interpreter or shorthand-writer.`
  content obj_root_law_sections_109_content
  footnotes obj_root_law_sections_109_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29307&sectionno=109&orderno=113&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_109_content:
  string
  line `(1) Before any person is sworn or affirmed as`
  line `an interpreter or a shorthand-writer, the accused shall be asked if he objects to such person as not being`
  line `impartial and the court shall decide the objection.`
  line
  line `(2) The evidence given by a witness shall be read over to him by the shorthand-writer before the`
  line `witness leaves the court, if so required by the court or the witness.`
obj_root_law_sections_109_footnotes:
  string
  line
obj_root_law_sections_110:
  sectionId (29308)
  sectionNo (110)
  orderNo 114
  title `Swearing of witnesses.`
  content obj_root_law_sections_110_content
  footnotes obj_root_law_sections_110_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29308&sectionno=110&orderno=114&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_110_content:
  string
  line `(1) No witness shall be examined until he has been duly sworn or`
  line `affirmed in the following manner:--`
  line
  line `"I......................................do swear in the name of God`
  line `solemnly affirm that the evidence which I shall give`
  line `before this court shall be the truth, the whole truth and nothing but the truth.".`
  line
  line `(2) Every person giving evidence on oath or affirmation before a court-martial shall be bound to state`
  line `the truth.`
obj_root_law_sections_110_footnotes:
  string
  line
obj_root_law_sections_111:
  sectionId (29309)
  sectionNo (111)
  orderNo 115
  title `Plea of no case and defence of accused`
  content obj_root_law_sections_111_content
  footnotes obj_root_law_sections_111_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29309&sectionno=111&orderno=115&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_111_content:
  string
  line `(1) When the examination of the witnesses for the`
  line `prosecution is concluded, the accused shall be called on for his defence.`
  line
  line `(2) Before entering on his defence, the accused may raise a plea of no case to answer.`
  line
  line `(3) If such a plea is raided, the court will decide the plea after hearing the accused and the prosecutor`
  line `and the advice of the trial judge advocate.`
  line
  line `(4) If the court accepts the plea, the accused shall be acquitted on the charge or charges in respect`
  line `whereof the plea has been accepted.`
  line
  line `(5) If the court overrules the plea, the accused shall be called upon to enter on his defence.`
  line
  line `(6) The trial judge advocate shall then inform the accused that he may give evidence as a witness on`
  line `his own behalf should he desire to do so and should he make a request in writing to do so, but that he will`
  line `thereby render himself liable to cross-examination.`
  line
  line `(7) If the accused does not apply to give evidence, he may make a statement as to the facts of the`
  line `case, and if he has no defence witnesses to examine as to facts, the prosecutor may sum up his case and`
  line `the accused shall be entitled to reply.`
  line
  line `(8) If the, accused or any one of the several accused applies to give evidence and there are no other`
  line `witnesses in the case for the defence, other than witnesses as to character, then the evidence of such`
  line `accused shall be recorded and if the accused so desires the witnesses as to character shall be examined`
  line `and the prosecutor shall then sum up his case and the accused may reply.`
  line
  line `(9) If the accused or any one of the accused adduces any oral evidence as to facts other than his own`
  line `evidence, if any, the accused may then sum up his case on the conclusion of that evidence and the`
  line `prosecutor shall be entitled to reply.`
obj_root_law_sections_111_footnotes:
  string
  line
obj_root_law_sections_112:
  sectionId (29311)
  sectionNo (112)
  orderNo 116
  title `Adjournment to view`
  content obj_root_law_sections_112_content
  footnotes obj_root_law_sections_112_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29311&sectionno=112&orderno=116&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_112_content:
  string
  line `(1) Whenever the court thinks that it should view the place in which`
  line `the offence charged is alleged to have been committed or any other place in which any other transaction`
  line `material to the trial is alleged to have occurred, the court shall make an order to that effect and may then`
  line `adjourn to the place to be viewed, along with the prosecutor and the accused and the person, if any, by`
  line `whom the accused is represented.`
  line
  line `(2) The court on completion of the view shall adjourn and reassemble in the court-room.`
obj_root_law_sections_112_footnotes:
  string
  line
obj_root_law_sections_113:
  sectionId (29312)
  sectionNo (113)
  orderNo 117
  title `Summing up by the trial judge advocate`
  content obj_root_law_sections_113_content
  footnotes obj_root_law_sections_113_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29312&sectionno=113&orderno=117&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_113_content:
  string
  line `When the case for the defence and the prosecutor's`
  line `reply, if any, are concluded, the trial judge advocate shall proceed to sum up in open court the evidence`
  line `for the prosecution and the defence and lay down the law by which the court is to be guided.`
obj_root_law_sections_113_footnotes:
  string
  line
obj_root_law_sections_114:
  sectionId (29313)
  sectionNo (114)
  orderNo 118
  title `Duties of the trial judge advocate`
  content obj_root_law_sections_114_content
  footnotes obj_root_law_sections_114_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29313&sectionno=114&orderno=118&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_114_content:
  string
  line `(1) At all trials by courts-martial it is the duty of the trial`
  line `judge advocate to decide all questions of law arising in the course of the trial, and specially all questions`
  line `as to the relevancy of facts which it is proposed to prove and the admissibility of evidence or the propriety`
  line `of the questions asked by or on behalf of the parties; and in his discretion to prevent the production of`
  line `inadmissible evidence whether it is or is not objected to by the parties.`
  line
  line `(2) Whenever in the course of a trial it appears desirable to the trial judge advocate that arguments`
  line `and evidence as to the admissibility of evidence or arguments in support of an application for separate`
  line `trials or on any other points of law should not be heard in the presence of the court, he may advise the`
  line `president of the court accordingly and the president shall thereupon make an order for the court to retire`
  line `or direct the trial judge advocate to hear the arguments in some other convenient place.`
obj_root_law_sections_114_footnotes:
  string
  line
obj_root_law_sections_115:
  sectionId (29314)
  sectionNo (115)
  orderNo 119
  title `Duties of the court`
  content obj_root_law_sections_115_content
  footnotes obj_root_law_sections_115_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29314&sectionno=115&orderno=119&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_115_content:
  string
  line `It is the duty of the court to decide which view of the facts is true and then`
  line `arrive at the finding which under such view ought to be arrived at.`
obj_root_law_sections_115_footnotes:
  string
  line
obj_root_law_sections_116:
  sectionId (29315)
  sectionNo (116)
  orderNo 120
  title `Retirement to consider finding`
  content obj_root_law_sections_116_content
  footnotes obj_root_law_sections_116_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29315&sectionno=116&orderno=120&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_116_content:
  string
  line `(1) After the trial judge advocate has finished his summing`
  line `up, the court will be cleared to consider the finding.`
  line
  line `(2) The trial judge advocate shall not sit with the court when the court is considering the finding, and`
  line `no person shall speak to or hold any communication with the court while the court is considering the`
  line finding.
obj_root_law_sections_116_footnotes:
  string
  line
obj_root_law_sections_117:
  sectionId (29317)
  sectionNo (117)
  orderNo 121
  title `Announcement of the finding`
  content obj_root_law_sections_117_content
  footnotes obj_root_law_sections_117_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29317&sectionno=117&orderno=121&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_117_content:
  string
  line `(1) When the court has considered the finding, the court shall`
  line `be re-assembled and the president shall inform the trial judge advocate in open court what is the finding`
  line `of the court as ascertained in accordance with section 124.`
  line
  line `(2) The court shall give its findings on all the charges on which the accused is tried.`
obj_root_law_sections_117_footnotes:
  string
  line
obj_root_law_sections_118:
  sectionId (29319)
  sectionNo (118)
  orderNo 122
  title `Drawing up of the finding`
  content obj_root_law_sections_118_content
  footnotes obj_root_law_sections_118_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29319&sectionno=118&orderno=122&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_118_content:
  string
  line `(1) The trial judge advocate shall then draw up the finding as`
  line `announced by the court.`
  line
  line `(2) The finding so drawn up shall be signed by all the members of the court by way of attestation`
  line `notwithstanding any difference of opinion there may have been among the members and shall be`
  line `countersigned by the trial judge advocate.`
  line
  line `(3) Where the finding on any charge is one of not guilty the court shall acquit the accused of`
  line `that charge.`
  line `(4) If the accused is acquitted of all the charges, the court shall, after signing the findings as provided`
  line `in sub-section (2), be dissolved.`
  line
  line `(5) Neither the court nor the trial judge advocate shall announce in open court whether the finding`
  line `was unanimous or not; but the president shall make a record of the division of voting on each finding`
  line `without disclosing the vote or opinion of any particular member of the court-martial and such record shall`
  line `be communicated to the trial judge advocate for transmission to the Judge Advocate-General of the Navy.`
obj_root_law_sections_118_footnotes:
  string
  line
obj_root_law_sections_119:
  sectionId (29320)
  sectionNo (119)
  orderNo 123
  title `Evidence of character and previous convictions`
  content obj_root_law_sections_119_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29320&sectionno=119&orderno=123&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_119_content:
  string
  line `(1) If the accused is found guilty on any or`
  line `all of the charges, the court before awarding punishment may call evidence as to the previous character`
  line `and qualifications of the accused and in addition to any oral evidence of general character that may be adduced, shall take into consideration the following documents which shall be read by the trial judge`
  line `advocate in open court:--`
  line
  line `(a) for any officer--`
  line
  line `(i) any entries against him relating to his previous convictions in the list of officers who have`
  line `been tried by court-martial; and`
  line
  line `(ii) any previous entries against him in the log of the ship to which he may have belonged`
  line `when the offence or offences for which he is being tried were committed and also any documents,`
  line `other than such entries in the log, of the nature of a definite censure by superior authority, which`
  line `log and documents the prosecution is to produce; and`
  line
  line `(iii) any certificate or other documents of character which the accused may produce;`
  line
  line `(b) for a ^1[sailor]--`
  line
  line `(i) the entries against him in the conduct and offences record sheets prior to the date of the`
  line `offence charged, but subsequent to his joining his present ship, with character assessed from the`
  line `previous 31st day of December to the date of the offence for which he may be under trial but`
  line `excluding all consideration of the latter;`
  line
  line `(ii) his certificate of service; and`
  line
  line `(iii) any entries against him relating to his previous convictions in the list of those who have`
  line `been tried by court-martial.`
  line
  line `(2) The accused may then make a statement in mitigation of punishment and lead any evidence of`
  line `character if he has not already done so before the finding.`
obj_root_law_sections_120:
  sectionId (29322)
  sectionNo (120)
  orderNo 124
  title `Consideration of the sentence`
  content obj_root_law_sections_120_content
  footnotes obj_root_law_sections_120_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29322&sectionno=120&orderno=124&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_120_content:
  string
  line `(1) The Court shall then retire and consider and determine on`
  line `the punishment proper to be inflicted in conformity with the finding, and all the members of the court,`
  line `whether they have voted for an acquittal or not, shall vote on the question of what punishment is proper to`
  line `be awarded for the offence of which the accused has been found guilty.`
  line
  line `(2) The trial Judge advocate shall sit with the court while they are considering the sentence and assist`
  line `the court in the determination of the sentence but shall not vote thereon.`
obj_root_law_sections_120_footnotes:
  string
  line
obj_root_law_sections_121:
  sectionId (29323)
  sectionNo (121)
  orderNo 125
  title `Announcement of the sentence`
  content obj_root_law_sections_121_content
  footnotes obj_root_law_sections_121_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29323&sectionno=121&orderno=125&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_121_content:
  string
  line `(1) When the court has decided on the sentence whether`
  line `unanimously or by majority, the trial Judge advocate shall draw up the sentence in the prescribed form`
  line `which shall be signed by every member of the court by way of attestation notwithstanding any difference`
  line `of opinion there may have been among the members and shall be countersigned by the trial Judge`
  line advocate.
  line
  line `(2) The court shall then be reassembled and the accused brought in and the trial Judge advocate shall`
  line `by direction of the court pronounce the sentence.`
  line
  line `(3) The accused shall then be removed and the court dissolved.`
obj_root_law_sections_121_footnotes:
  string
  line
obj_root_law_sections_122:
  sectionId (29325)
  sectionNo (122)
  orderNo 126
  title Adjournment
  content obj_root_law_sections_122_content
  footnotes obj_root_law_sections_122_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29325&sectionno=122&orderno=126&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_122_content:
  string
  line `(1) A court-martial may, if it appears to the court that an adjournment`
  line `desirable, be adjourned accordingly, but except where such an adjournment is ordered, shall sit from day`
  line `to day with the exception of Sundays until the trial is concluded, unless prevented from so doing by stress`
  line `of weather or unavoidable accident.`
  line
  line `(2) The proceedings of a court-martial shall not, after the commencement of a trial, be delayed by the`
  line `absence of a member:`
  line
  line `Provided that not less than four members are present: and`
  line
  line `Provided further that if any member is absent from any part of the trial, he shall not thereafter take`
  line `any part in the proceedings.`
obj_root_law_sections_122_footnotes:
  string
  line
obj_root_law_sections_123:
  sectionId (29327)
  sectionNo (123)
  orderNo 127
  title `Provisions relating to dissolution of courts-martial`
  content obj_root_law_sections_123_content
  footnotes obj_root_law_sections_123_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29327&sectionno=123&orderno=127&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_123_content:
  string
  line `(1) A court-martial assembled under`
  line `this Act shall be dissolved--`
  line
  line `(a) when the number of members comprising the court is after the commencement of a trial`
  line `reduced below four;`
  line
  line `(b) by the prolonged illness of the president, trial judge advocate or the accused;`
  line
  line `(c) by the death of the president or the trial judge advocate;`
  line
  line `(d) on the making of a report under sub-section (2) of section 143.`
  line
  line `(2) Whenever a court-martial is dissolved by virtue of sub-section (1), the accused may be retired.`
obj_root_law_sections_123_footnotes:
  string
  line
obj_root_law_sections_124:
  sectionId (29328)
  sectionNo (124)
  orderNo 128
  title `Ascertaining the opinion of the court`
  content obj_root_law_sections_124_content
  footnotes obj_root_law_sections_124_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29328&sectionno=124&orderno=128&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_124_content:
  string
  line `(1) Subject to the provisions of sub-sections (2) and`
  line `(3), every question for determination by a court-martial shall be decided by the vote of the majority:`
  line
  line `Provided that where there is an equality of votes, the decision most favourable to the accused`
  line `shall prevail.`
  line
  line `(2) The sentence of death shall not be passed on any offender unless four at least of the members`
  line `present at the court-martial where the number does not exceed five, and in all other cases a majority of not`
  line `less than two-thirds of the members present, concur in the sentence.`
  line
  line `(3) Where in respect of an offence, the only punishment which may be awarded is death, a finding`
  line `that a charge for such offence is proved shall not be given unless four at least of the members present at`
  line `the court-martial where the number does not exceed five, and in all other cases a majority of not less than`
  line `two-thirds of the members present, concur in the finding.`
obj_root_law_sections_124_footnotes:
  string
  line
obj_root_law_sections_125:
  sectionId (29331)
  sectionNo (125)
  orderNo 129
  title `Finding that the offence was committed with intent involving less degree of punishment`
  content obj_root_law_sections_125_content
  footnotes obj_root_law_sections_125_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29331&sectionno=125&orderno=129&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_125_content:
  string
  line `Where the amount of punishment for any offence depends upon the intent with which it`
  line `has been committed and any person is charged with having committed such an offence with an intent`
  line `involving a greater degree of punishment, a court-martial may find that the offence was committed with`
  line `an intent involving less degree of punishment and award such punishment accordingly.`
obj_root_law_sections_125_footnotes:
  string
  line
obj_root_law_sections_126:
  sectionId (29333)
  sectionNo (126)
  orderNo 130
  title `Alternative findings`
  content obj_root_law_sections_126_content
  footnotes obj_root_law_sections_126_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29333&sectionno=126&orderno=130&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_126_content:
  string
  line `If the accused is charged with one offence and it appears in evidence`
  line `that he committed a different offence for which he might have been charged under section 91, he may be`
  line `convicted of the offence which he is shown to have committed although he was not charged with it.`
obj_root_law_sections_126_footnotes:
  string
  line
obj_root_law_sections_127:
  sectionId (29335)
  sectionNo (127)
  orderNo 131
  title `Finding lesser offence proved on charge of greater offence`
  content obj_root_law_sections_127_content
  footnotes obj_root_law_sections_127_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29335&sectionno=127&orderno=131&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_127_content:
  string
  line `(1) When a person is charged`
  line `with an offence consisting of several particulars, a combination of some only of which constitutes a`
  line `complete minor offence and such combination is proved, but the remaining particulars are not proved, he`
  line `may be convicted of the minor offence although he was not charged with it.`
  line
  line `(2) When a person is charged with an offence and facts are proved which reduce it to a minor offence,`
  line `he may be convicted of the minor offence although he was not charged with it.`
  line
  line `(3) When a person is charged with an offence, he may be convicted of an attempt to commit such an`
  line `offence, although the attempt is not separately charged.`
obj_root_law_sections_127_footnotes:
  string
  line
obj_root_law_sections_128:
  sectionId (29336)
  sectionNo (128)
  orderNo 132
  title `Transmission of proceedings to the Judge Advocate General of the Navy`
  content obj_root_law_sections_128_content
  footnotes obj_root_law_sections_128_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29336&sectionno=128&orderno=132&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_128_content:
  string
  line `The trial Judge`
  line `advocate shall transmit in accordance with the prescribed procedure with as much expedition as may be,`
  line `the original proceedings or a complete and authenticated copy thereof and the original sentence of every`
  line `court-martial attended by him to the Judge Advocate General of the Navy to be dealt with by him in`
  line `accordance with the provisions of Chapter XV.`
obj_root_law_sections_128_footnotes:
  string
  line
obj_root_law_sections_129:
  sectionId (29338)
  sectionNo (129)
  orderNo 133
  title `Right of accused to copy of proceedings and sentence`
  content obj_root_law_sections_129_content
  footnotes obj_root_law_sections_129_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29338&sectionno=129&orderno=133&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_129_content:
  string
  line `Every person tried by a court-martial`
  line `and convicted shall be entitled on demand to one copy of the proceedings and sentence of such courtmartial`
  line `free of cost but no such demand shall be allowed after the lapse of one year from the date of the`
  line `final decision of such court.`
obj_root_law_sections_129_footnotes:
  string
  line
obj_root_law_sections_130:
  sectionId (29340)
  sectionNo (130)
  orderNo 134
  title `Application of the Evidence Act`
  content obj_root_law_sections_130_content
  footnotes obj_root_law_sections_130_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29340&sectionno=130&orderno=134&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_130_content:
  string
  line `Subject to the provisions of this Act, the Indian Evidence`
  line `Act, 1872 (1 of 1872), shall apply to all proceedings before a court-martial.`
obj_root_law_sections_130_footnotes:
  string
  line
obj_root_law_sections_131:
  sectionId (29341)
  sectionNo (131)
  orderNo 135
  title `Accused competent witness for defence`
  content obj_root_law_sections_131_content
  footnotes obj_root_law_sections_131_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29341&sectionno=131&orderno=135&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_131_content:
  string
  line `A person of an offence before a court-martial shall`
  line `be a competent witness for the defence and may give evidence on oath in disproof of the charges made`
  line `against him or any person charged together with him at the same trial:`
  line
  line `Provided that--`
  line
  line `(a) he shall not be called as a witness except on his own request in writing; or`
  line
  line `(b) his failure to give evidence shall not be made the subject of any comment by any of the parties`
  line `or the court or give rise to any presumption against himself or any person charged together with him`
  line `at the same trial.`
obj_root_law_sections_131_footnotes:
  string
  line
obj_root_law_sections_132:
  sectionId (29342)
  sectionNo (132)
  orderNo 136
  title `Judicial notice`
  content obj_root_law_sections_132_content
  footnotes obj_root_law_sections_132_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29342&sectionno=132&orderno=136&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_132_content:
  string
  line `A court-martial may take judicial notice of any matter within the general`
  line `naval, army or air force experience and knowledge of the members.`
obj_root_law_sections_132_footnotes:
  string
  line
obj_root_law_sections_133:
  sectionId (29343)
  sectionNo (133)
  orderNo 137
  title `Presumption as to certain documents`
  content obj_root_law_sections_133_content
  footnotes `1. Subs. by Act 23 of 2005, s. 5, for sub-section (6) (w.e.f. 23-6-2005).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29343&sectionno=133&orderno=137&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_133_content:
  string
  line `(1) Whenever it is necessary for the purposes of either`
  line `the prosecution or the defence to prove the contents of any voucher, receipt, account, muster, ship's book,`
  line `letter, signal, telegram or other document made or kept in pursuance of any Act of the legislature, any`
  line `regulations framed under this Act or of the custom of the service, a copy of the same purporting to be`
  line `signed and certified as a correct copy by the officer for the time being commanding the ship in which the`
  line `same was made or kept or by a Secretary to the Central Government, may be received as evidence of such`
  line `document and of the matters, transactions and accounts therein recorded.`
  line
  line `(2) A Navy List or Gazette or other official document purporting to be published by authority of the`
  line `Central Government or the Chief of the Naval Staff shall be evidence of the status and rank of officers`
  line `therein mentioned and of any appointment held by such officers until the contrary is proved.`
  line
  line `(3) Where it is shown that a person is borne on the books of a ship of the Indian Navy, such fact shall`
  line `be evidence that such person is subject to naval law until the contrary is proved.`
  line
  line `Explanation.-- In this section, the term "books of a ship" shall include any official book, document`
  line `or list purporting to contain the name or names of persons appointed to the ship.`
  line
  line `(4) Where any person subject to naval law is being tried on a charge of desertion, improperly leaving`
  line `his ship, or absence without leave and such person has surrendered himself into custody of or has been`
  line `apprehended by any person subject to naval law or by a person subject to the law relating to the`
  line `Government of the regular Army or the Air Force, a certificate purporting to be signed by such person`
  line `and stating the fact, date and place of such surrender or apprehension shall be evidence of the matters so`
  line `stated unless the contrary is proved.`
  line
  line `(5) Where any person subject to naval law is being tried on a charge of desertion, improperly leaving`
  line `his ship, or absence without leave and such person has on arrest or surrender been taken to a police`
  line `station, a certificate purporting to be signed by the officer-in-charge of the station and stating the fact,`
  line `date and place of such surrender or apprehension shall be evidence of the matters stated unless the`
  line `contrary is proved.`
  line
  line `^1[(6) Any document purporting to be a report under the hand of:`
  line
  line `(a) any Chemical Examiner or Assistant Chemical Examiner to the Government;`
  line
  line `(b) the Chief Inspector of Explosives;`
  line
  line `(c) the Director of Finger Print Bureau;`
  line
  line `(d) the Director of Haffkeine Institute, Bombay;`
  line
  line `(e) the Director, Deputy Director or Assistant Director of a Central Forensic Science Laboratory`
  line `or a State Forensic Science Laboratory;`
  line
  line `(f) the Serologist to the Government,`
  line
  line `uponany matter or thing duly submitted to him for examination or analysis, may be used an evidence in`
  line `any proceeding under this Act.`
  line
  line `(7) The statement of a naval, army or air force medical officer taken and attested by the commanding`
  line `officer of a ship or establishment may be given in evidence in any proceeding under this Act:`
  line
  line `Provided that the court may, if it thinks fit, and shall if so required by the prosecutor or the accused,`
  line `summon and examine such medical officer as to the subject-matter of his statement.`
  line
  line `(8) If it is proved that an offender under this Act has absconded and that there is no immediate`
  line `prospect of arresting him, the commanding officer or other prescribed person may, in his absence,`
  line `examine any person who might appear to him to be acquainted with the case and record their depositions`
  line `on oath and any such deposition may on the arrest of such person be used in evidence against him in any`
  line `proceeding under this Act, if the deponent is dead or incapable of giving evidence or his attendance`
  line `cannot be procured without an amount of delay, expense or inconvenience which under the circumstances`
  line `of the case would be unreasonable.`
obj_root_law_sections_134:
  sectionId (29344)
  sectionNo (134)
  orderNo 138
  title `Summoning of witnesses`
  content obj_root_law_sections_134_content
  footnotes obj_root_law_sections_134_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29344&sectionno=134&orderno=138&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_134_content:
  string
  line `(1) Every person who may be required to give evidence or produce`
  line `a document before a court-martial shall be summoned in the prescribed manner in writing under the hand`
  line `of the Judge Advocate General of the Navy or the trial judge advocate.`
  line
  line `(2) Every person who may be required to give evidence before a commanding officer or the officer`
  line `preparing a summary of evidence in accordance with the regulations made under this Act or before a`
  line `board of inquiry shall be summoned in the prescribed manner by writing under the hand of the Judge`
  line `Advocate General of the Navy or the senior officer in the station or such other officer prescribed in`
  line `this behalf.`
  line
  line `(3) In the case of a witness subject to naval law or to the law relating to the Government of the regular`
  line `Army or the Air Force, the summons shall be served in the manner prescribed.`
  line
  line `(4) In the case of any other witness, the summons shall be served either in the prescribed manner, or it`
  line `shall be sent to the magistrate within whose jurisdiction the witness may be or resides and such magistrate`
  line `shall give effect to the summons as if the witness were required in the court of such magistrate.`
  line
  line `(5) When a witness is required to produce any particular document or thing in his possession or`
  line `power, the summons shall describe it with reasonable precision.`
  line
  line `(6) Every person not subject to naval law who may be summoned as aforesaid shall be allowed and`
  line `paid such reasonable expenses as may be prescribed.`
  line
  line `(7) Nothing in this section shall be deemed to affect the operation of sections 123 and 124 of the`
  line `Indian Evidence Act, 1872 (1 of 1872), or to apply to any document in the custody of the postal or`
  line `telegraph authorities.`
obj_root_law_sections_134_footnotes:
  string
  line
obj_root_law_sections_135:
  sectionId (29345)
  sectionNo (135)
  orderNo 139
  title `Commissions for examination of witnesses`
  content obj_root_law_sections_135_content
  footnotes obj_root_law_sections_135_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29345&sectionno=135&orderno=139&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_135_content:
  string
  line `(1) Whenever in the course of a trial by courtmartial,`
  line `it appears to the trial judge advocate that the examination of a witness is necessary for the ends of`
  line `justice and that the attendance of such witness cannot be procured without an amount of delay, expense or`
  line `inconvenience which under the circumstances of the case would be unreasonable, the trial judge advocate`
  line `may dispense with such attendance and may apply to the Judge Advocate General of the Navy to issue a`
  line `commission to ^1[any metropolitan magistrate or judicial magistrate of the first class] within the local`
  line `limits of whose jurisdiction such witness resides, to take the evidence of such witness.`
  line
  line `(2) The trial in such an event may be adjourned for a specified time reasonably sufficient for the`
  line `execution and return of the commission.`
  line
  line `(3) The Judge Advocate General of the Navy on receipt of an application under sub-section (1) may,`
  line `if he thinks fit, issue a commission to the ^2[metropolitan magistrate or judicial magistrate of the first class`
  line `or an authority exercising the powers equivalent to those of a judicial magistrate of the first class under`
  line `the Code of Criminal Procedure, 1973 (2 of 1974),] for the examination of the witness.`
  line
  line `(4) The magistrate or authority to whom the commission is issued or ^3[if he is a Chief Metropolitan`
  line `Magistrate or a Chief Judicial Magistrate, he or such metropolitan magistrate or judicial magistrate of the`
  line `first class as is appointed by him in this behalf] shall proceed to such place where the witness is or shall`
  line `summon the witness before him and shall take down his evidence in the same manner and may for this`
  line `purpose exercise the same powers as in trials of warrant cases under the ^4[Code of Criminal Procedure,`
  line `1973 (2 of 1974)], or of any corresponding law in force at the place where the evidence is recorded.`
obj_root_law_sections_135_footnotes:
  string
  line `1. Subs. by Act 48 of 1982, s. 7, for "any district magistrate or a magistrate of the first class" (w.e.f. 16-10-1982).`
  line
  line `2. Subs by s. 7, ibid., for certain words and figures (w.e.f. 16-10-1982).`
  line
  line `3. Subs. by Act 48 of 1982, s. 7, for certain words (w.e.f. 16-10-1982).`
  line
  line `4. Subs. by s. 7, ibid., for "Code of Criminal Procedure, 1898 (5 of 1898)" (w.e.f. 16-10-1982).`
obj_root_law_sections_136:
  sectionId (29346)
  sectionNo (136)
  orderNo 140
  title `Examination of witnesses on commission`
  content obj_root_law_sections_136_content
  footnotes obj_root_law_sections_136_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29346&sectionno=136&orderno=140&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_136_content:
  string
  line `(1) Where a commission is issued under the`
  line `provisions of section 135, the prosecutor and the accused may respectively forward any interrogatories in`
  line `writing which the trial judge advocate may think relevant to, the issue and the magistrate or authority to`
  line `whom the commission is directed or to whom the duty of executing such commission has been delegated`
  line `shall examine the witness upon such interrogatories.`
  line
  line `(2) The prosecutor and the accused may appear before such magistrate or authority by counsel or,`
  line `except in the case of an accused person in custody, in person, and may examine, cross-examine arid reexamine,`
  line `as the case may be, the said witness.`
  line
  line `(3) After a commission issued under section 135 has been duly executed, it shall be returned together`
  line `with the deposition of the witness examined thereunder to the Judge Advocate General of the Navy who`
  line `issued the commission.`
  line
  line `(4) On receipt of the commission and the deposition returned under sub-section (3), the Judge`
  line `Advocate General of the Navy shall forward the same to the trial judge advocate at whose instance the`
  line `commission was issued.`
  line
  line `(5) The commission, the return thereto and the deposition shall be open to inspection by the`
  line `prosecutor and the accused and may subject to all just exceptions be read in evidence in the case by either`
  line `the prosecutor or the accused and shall form part of the proceedings of the trial.`
  line
  line `(6) Any deposition so taken shall be received in evidence at any subsequent stage of the trial whether`
  line `before the same court or, if the said court is dissolved meanwhile, before another court convened for the`
  line `trial of the accused in respect of the same charges.`
obj_root_law_sections_136_footnotes:
  string
  line
obj_root_law_sections_137:
  sectionId (29347)
  sectionNo (137)
  orderNo 141
  title `Power to summon and examine material witnesses`
  content obj_root_law_sections_137_content
  footnotes obj_root_law_sections_137_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29347&sectionno=137&orderno=141&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_137_content:
  string
  line `(1) The trial judge advocate may, at any`
  line `stage of the trial, summon any person as a witness or examine any person in attendance, though not`
  line `summoned as a witness, or recall and re-examine any person already examined; and the trial judge`
  line `advocate shall summon and examine or recall and re-examine any such person if his evidence appears to`
  line `the court or to the trial judge advocate as essential to the just decision of the case.`
  line
  line `(2) Summons to the witnesses shall be issued as provided under this Act.`
obj_root_law_sections_137_footnotes:
  string
  line
obj_root_law_sections_138:
  sectionId (29348)
  sectionNo (138)
  orderNo 142
  title `Power of court to pay compensation out of fine`
  content obj_root_law_sections_138_content
  footnotes obj_root_law_sections_138_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29348&sectionno=138&orderno=142&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_138_content:
  string
  line `(1) Whenever a court-martial imposes a fine`
  line `as a punishment, the court may when passing judgment order the whole or any part of the fine recovered`
  line `to be applied,--`
  line
  line `(a) in the payment to any person aggrieved as compensation for any loss or injury caused by the`
  line offence;
  line
  line `(b) When any person is convicted of any civil offence which includes theft, criminal`
  line `misappropriation, criminal breach of trust or cheating or of having dishonestly received or retained or`
  line `of having voluntarily assisted in disposing of stolen property knowing or having reason to believe the`
  line `same to be stolen property, in compensating any bona fide purchaser of the property for the loss of the`
  line `same if such property is restored to the possession of the person entitled thereto.`
  line
  line `(2) No such payment or compensation shall, however, be made before the expiry of fifteen days from`
  line `the date of the sentence, and when a petition is presented against the conviction or sentence until the said`
  line `petition is disposed of Power of courts-martial respecting contempt, etc.`
obj_root_law_sections_138_footnotes:
  string
  line
obj_root_law_sections_139:
  sectionId (29349)
  sectionNo (139)
  orderNo 143
  title `Summary punishment for contempt of court person subject to naval law`
  content obj_root_law_sections_139_content
  footnotes obj_root_law_sections_139_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29349&sectionno=139&orderno=143&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_139_content:
  string
  line `When any`
  line `person subject to naval law commits any offence as is described in section 69 in the presence of or in`
  line `relation to a proceeding before a court-martial such court-martial may punish the offender summarily by`
  line `imprisonment for a term which may extend to three months or such other less punishment as may be`
  line `awarded for that offence under section 69.`
obj_root_law_sections_139_footnotes:
  string
  line
obj_root_law_sections_140:
  sectionId (29350)
  sectionNo (140)
  orderNo 144
  title `Summary punishment for contempt of court by person not subject to naval law`
  content obj_root_law_sections_140_content
  footnotes obj_root_law_sections_140_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29350&sectionno=140&orderno=144&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_140_content:
  string
  line When
  line `any person not subject to naval law commits an offence as is described in section 165 in the presence of a`
  line `court-martial, such court-martial may take such person into custody and at any time before the rising of`
  line `the court on the same day, if it thinks fit, take cognizance of the offence and sentence the offender to fine`
  line `not exceeding two hundred rupees or in default of payment to simple imprisonment for a term which may`
  line `extend to one month, unless such fine shall be sooner paid.`
obj_root_law_sections_140_footnotes:
  string
  line
obj_root_law_sections_141:
  sectionId (29351)
  sectionNo (141)
  orderNo 145
  title `Powers of court-martial when certain offences are committed by persons not subject to naval law`
  content obj_root_law_sections_141_content
  footnotes obj_root_law_sections_141_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29351&sectionno=141&orderno=145&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_141_content:
  string
  line `When any such offence as is described in section 165 of this Act, or section 193, section`
  line `194, section 195, section 196, section 199, section 200, section 228, section 463 or section 471 of the`
  line `Indian Penal Code (45 of 1860) is committed by any person not subject to naval law in or in relation to a`
  line `proceeding before a court-martial, such court-martial or the officer ordering the same if such court-martial`
  line `is dissolved, may exercise the powers ^1[under section 340 of the Code of Criminal Procedure, 1973 (2 of`
  line `1974)], as if it or he were a criminal court within the meaning of that section.`
obj_root_law_sections_141_footnotes:
  string
  line `1. Subs. by Act 48 of 1982, s. 8, for "under section 476 of the Code of Criminal Procedure, 1898 (5 of 1898)"`
  line `(w.e.f. 16-10-1982).`
obj_root_law_sections_142:
  sectionId (29352)
  sectionNo (142)
  orderNo 146
  title `Powers of courts martial and disciplinary courts in relation to proceedings under this Act`
  content obj_root_law_sections_142_content
  footnotes obj_root_law_sections_142_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29352&sectionno=142&orderno=146&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_142_content:
  string
  line `Any trial by a court-martial or disciplinary court under the provisions of this Act shall be deemed`
  line `to be a judicial proceeding within the meaning of sections 193 and 228 of the Indian Penal Code`
  line `(45 of 1860), and the court-martial or disciplinary court shall be deemed to be a court within the meaning`
  line `of ^1[sections 345 and 346 of the Code of Criminal Procedure, 1973 (2 of 1974).]`
obj_root_law_sections_142_footnotes:
  string
  line `1. Subs by s. 9, ibid., for "under sections 480 and 482 of the Code of Criminal Procedure Code, 1898 (5 of 1898)"`
  line `(w.e.f. 16-10-1982).`
obj_root_law_sections_143:
  sectionId (29353)
  sectionNo (143)
  orderNo 147
  title `Accused found insane during trial`
  content obj_root_law_sections_143_content
  footnotes obj_root_law_sections_143_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29353&sectionno=143&orderno=147&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_143_content:
  string
  line `(1) Where it appears in the course of the trial by courtmartial`
  line `of any person, charged with an offence that such person is insane, the court shall find specially the`
  line `fact of his insanity and shall order such person to be kept in strict custody in such place and in such`
  line `manner as the court may deem fit until the directions of the Central Government thereupon are known.`
  line
  line `(2) Every such case shall be reported by the court to the convening authority for orders of the Central`
  line `Government and it shall be lawful for the Central Government to give orders for the safe custody of such`
  line `person in such place and in such manner as the Central Government may deem fit.`
  line
  line `(3) Whenever on the receipt of a report from the Central Government or otherwise the convening`
  line `authority considers that such person is capable of making his defence, the convening authority may take`
  line `steps to convene a court-martial for the trial of such person.`
obj_root_law_sections_143_footnotes:
  string
  line
obj_root_law_sections_144:
  sectionId (29354)
  sectionNo (144)
  orderNo 148
  title `Lunacy of the accused at the time of offence`
  content obj_root_law_sections_144_content
  footnotes obj_root_law_sections_144_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29354&sectionno=144&orderno=148&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_144_content:
  string
  line `(1) Whenever any person subject to naval law`
  line `is acquitted upon the ground that, at the time at which he is alleged to have committed an offence, he was,`
  line `by reason of unsoundness of mind, incapable of knowing the nature of the act alleged as constituting the`
  line `offence, or that it was wrong or contrary to law, the finding shall specifically state whether he committed`
  line `the act or not.`
  line
  line `(2) Whenever the finding made under sub-section (1) states that the accused person committed the act`
  line `alleged, the court-martial shall, if such act would, but for the incapacity found, have constituted an`
  line `offence, order such person to be detained in safe custody in such place and in such manner as may be`
  line `prescribed and shall report the action taken to the officer convening the court.`
  line
  line `(3) The officer convening the court shall then report the case for the orders of the Central Government`
  line `and shall take necessary steps to detain the said person in safe custody pending receipt of such orders.`
  line
  line `(4) The Central Government may on receipt of a report under sub-section (3) order the accused`
  line `person to be detained in a mental hospital or other suitable place of safe custody.`
obj_root_law_sections_144_footnotes:
  string
  line
obj_root_law_sections_145:
  sectionId (29355)
  sectionNo (145)
  orderNo 149
  title `Disposal of property pending trial`
  content obj_root_law_sections_145_content
  footnotes obj_root_law_sections_145_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29355&sectionno=145&orderno=149&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_145_content:
  string
  line `When any property regarding which an offence appears`
  line `to have been committed or which appears to have been used for the commission of an offence is produced`
  line `before a court-martial, the court may make such order as it thinks fit for the proper custody such property`
  line `pending the conclusion of the trial and if the property is subject to speedy or natural decay may after`
  line `recording such evidence as it thinks necessary order it to be sold or otherwise disposed of`
obj_root_law_sections_145_footnotes:
  string
  line
obj_root_law_sections_146:
  sectionId (29356)
  sectionNo (146)
  orderNo 150
  title `Disposal of property regarding which offence is committed`
  content obj_root_law_sections_146_content
  footnotes obj_root_law_sections_146_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29356&sectionno=146&orderno=150&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_146_content:
  string
  line `(1) When the trial before any`
  line `court-martial is concluded, the court may make such order as it thinks fit for the disposal by destruction,`
  line `confiscation or delivery to any person claiming to be entitled to possession thereof or otherwise of any`
  line `property or document produced before it or in its custody or regarding which an offence appears to have`
  line `been committed or which has been used for the commission of any offence:`
  line
  line `Provided that except in the case of property which is subject to speedy or natural decay such property`
  line `or document shall, if so required by regulations, made under this Act, be kept in custody until the orders`
  line `of the Chief of the Naval Staff are known.`
  line
  line `(2) An order under sub-section (1) shall not be carried out for one month, unless the property is`
  line `subject to speedy or natural decay.`
  line
  line `(3) When an order under this section cannot be conveniently carried out by persons in the naval`
  line `service, a copy of such order certified by the Chief of the Naval Staff or an officer prescribed in this`
  line `behalf, may be sent to a magistrate within whose jurisdiction the property is for the time being situate and`
  line `such magistrate shall thereupon take steps to cause the order to be carried into effect as if it were an order`
  line `passed by him.`
  line
  line `Explanation.-- In this section the term "property" includes, in the case of property regarding which`
  line `an offence appears to have been committed, not only such property as has been originally in the`
  line `possession or under the control of any person, but also any property into or for which the same may have`
  line `been converted or exchanged and anything acquired by such conversion or exchange whether`
  line `immediately or otherwise.`
obj_root_law_sections_146_footnotes:
  string
  line
obj_root_law_sections_147:
  sectionId (29357)
  sectionNo (147)
  orderNo 151
  title `Form of sentence of death`
  content obj_root_law_sections_147_content
  footnotes obj_root_law_sections_147_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29357&sectionno=147&orderno=151&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_147_content:
  string
  line `In awarding a sentence of death, a court-martial shall in its`
  line `discretion direct that the offender shall suffer death by being hanged by the neck until he be dead or shall`
  line `suffer death by being shot to death.`
obj_root_law_sections_147_footnotes:
  string
  line
obj_root_law_sections_148:
  sectionId (29358)
  sectionNo (148)
  orderNo 152
  title `Interim custody until execution of sentence of death`
  content obj_root_law_sections_148_content
  footnotes obj_root_law_sections_148_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29358&sectionno=148&orderno=152&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_148_content:
  string
  line `A person sentenced to death may be`
  line `detained in naval custody or may be removed to a civil prison to be kept in custody until further orders be`
  line `received from the Central Government, the Chief of the Naval Staff or the officer ordering the courtmartial`
  line `by which he was sentenced to death or other prescribed officer and the order in the prescribed`
  line `form of the Central Government, the Chief of the Naval Staff or the convening authority or such officer`
  line `shall be sufficient warrant for detaining the person in custody.`
obj_root_law_sections_148_footnotes:
  string
  line
obj_root_law_sections_149:
  sectionId (29359)
  sectionNo (149)
  orderNo 153
  title `Execution of sentences of death`
  content obj_root_law_sections_149_content
  footnotes obj_root_law_sections_149_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29359&sectionno=149&orderno=153&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_149_content:
  string
  line `(1) When a sentence of death is to be executed, the Chief of`
  line `the Naval Staff or the convening authority or the prescribed officer shall give directions as to the time,`
  line `place and manner in which sentence is to be carried out and the order of such officer or authority in the`
  line `prescribed form shall be sufficient warrant for the execution of such sentence.`
  line
  line `(2) There shall be attached to the prescribed form an order of the Central Government certifying the`
  line `confirmation of the sentence by the Central Government in all cases where such confirmation is necessary; and where such confirmation is not necessary, a certificate of the Chief of the Naval Staff or`
  line `other prescribed officer stating that such confirmation is not necessary.`
obj_root_law_sections_149_footnotes:
  string
  line
obj_root_law_sections_150:
  sectionId (29360)
  sectionNo (150)
  orderNo 154
  title `Place of imprisonment and detention`
  content obj_root_law_sections_150_content
  footnotes obj_root_law_sections_150_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29360&sectionno=150&orderno=154&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_150_content:
  string
  line `(1) Every term of imprisonment whether`
  line `imprisonment was awarded as an original or commuted punishment may be served in a naval prison,`
  line `naval detention quarters or in any civil prison, house of correction or military or air force prison or`
  line `detention barracks.`
  line
  line `(2) Every term of detention whether the detention was awarded as an original or commuted`
  line `punishment may be served in any naval detention quarters or army or air force detention barracks.`
  line
  line `(3) Where in pursuance of this Act, a person is sentenced to imprisonment or detention or has his`
  line `sentence commuted to imprisonment or detention, the order in the prescribed form of the Central`
  line `Government or the Chief of the Naval Staff or the officer ordering the court-martial by which such person`
  line `was sentenced or the senior officer present in port or, if he was sentenced by the commanding officer of a`
  line `ship, or other officer empowered under this Act to exercise like powers, the order in the prescribed form`
  line `of such commanding officer or other officer, shall be a sufficient warrant for the sending of such person`
  line `to the place of imprisonment or detention, as the case may be, thereto undergo the sentence according to`
  line `law, or until he reaches such place of imprisonment or detention for detaining him in naval custody or in`
  line `the case of a person sentenced to imprisonment, in any civil prison or place of confinement.`
obj_root_law_sections_150_footnotes:
  string
  line
obj_root_law_sections_151:
  sectionId (29361)
  sectionNo (151)
  orderNo 155
  title `Commencement of sentence`
  content obj_root_law_sections_151_content
  footnotes obj_root_law_sections_151_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29361&sectionno=151&orderno=155&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_151_content:
  string
  line `(1) Subject to the provisions of ^1[sub-sections (2) and (3)] every`
  line `term of imprisonment or detention awarded in pursuance of this Act shall be reckoned as commencing on`
  line `the day on which the sentence was awarded.`
  line
  line `(2) Where by reason of a ship being at sea or off a place at which there is no proper prison or naval`
  line `detention quarters, a sentence of imprisonment or detention, as the case may be, cannot be duly executed,`
  line `then subject as hereinafter mentioned, an offender under the sentence of imprisonment or detention, as the`
  line `case may be, may be sent with all reasonable speed to some place at which there is a proper prison or`
  line `naval detention quarters or in the case of an offender under sentence of detention to some place at which`
  line `there are some naval detention quarters in which the sentence can be duly executed; and on arrival there,`
  line `the offender shall undergo his sentence in like manner as if the date of such arrival were the day on which`
  line `the sentence was awarded and notwithstanding that in the meanwhile he has returned to his duty or`
  line `become entitled to his discharge; and the term of imprisonment or detention, as the case may be, shall be`
  line `reckoned accordingly, subject however to the deduction of any time during which he has been kept in`
  line `confinement in respect of the said offence.`
  line
  line `^2[(3) Whenever any offender is sentenced by a court-martial to a term of imprisonment, in pursuance`
  line `of this Act, not being imprisonment in default of payment of fine, the period spent by him in civil or naval`
  line `custody during investigation, inquiry or trial of the same case, and before the date of order of such`
  line `sentence, shall be set off against the terms of imprisonment imposed upon him, and the liability of such`
  line `offender to undergo imprisonment on such order of sentence shall be restricted to the remainder, if any, of`
  line `the term of imprisonment imposed upon him.]`
obj_root_law_sections_151_footnotes:
  string
  line `1. Subs. by Act 23 of 2005, s. 6, for "sub-section (2)" (w.e.f. 23-6-2005).`
  line
  line `2. Ins. s. 6, ibid. (w.e.f. 23-6-2005).`
obj_root_law_sections_152:
  sectionId (29362)
  sectionNo (152)
  orderNo 156
  title `Imprisonment of offender already under sentence`
  content obj_root_law_sections_152_content
  footnotes obj_root_law_sections_152_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29362&sectionno=152&orderno=156&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_152_content:
  string
  line `Whenever a sentence shall be passed by`
  line `a court-martial on an offender already under sentence either of detention or imprisonment passed upon`
  line `him under this Act for a former offence, the court may award a sentence of detention or imprisonment for`
  line `the offence for which he is under trial to commence at the expiration of the sentence of detention or`
  line `imprisonment to which he has been previously sentenced:`
  line
  line `Provided that so much of any term of detention imposed on a person by a sentence in pursuance of`
  line `this section as will prolong the total term of detention beyond two years shall be deemed to be remitted.`
obj_root_law_sections_152_footnotes:
  string
  line
obj_root_law_sections_153:
  sectionId (29363)
  sectionNo (153)
  orderNo 157
  title `Change of place of confinement`
  content obj_root_law_sections_153_content
  footnotes obj_root_law_sections_153_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29363&sectionno=153&orderno=157&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_153_content:
  string
  line `Whenever it is deemed expedient, it shall be lawful for the`
  line `Central Government, the Chief of the Naval Staff or senior officer present, by an order in writing in the`
  line `prescribed form, from time to time to change the place of confinement of any offender imprisoned or sentenced to be imprisoned or detained in pursuance of this Act or of any offender undergoing or`
  line `sentenced to undergo detention; and the gaoler or other person having the custody of such offender shall`
  line `immediately on the receipt of such order remove such offender to the gaol, prison or house of correction`
  line `or, in the case of an offender undergoing or sentenced to undergo detention, to the naval detention`
  line `quarters mentioned in the said order, or shall deliver him over to naval custody for the purpose of the`
  line `offender being removed to such prison or naval detention quarters, and every gaoler or keeper of such`
  line `last-mentioned prison, gaol, or house of correction or naval detention quarters shall, upon being furnished`
  line `with such order of removal, receive into his custody and shall confine pursuant to such sentence or order`
  line `every such offender.`
obj_root_law_sections_153_footnotes:
  string
  line
obj_root_law_sections_154:
  sectionId (29364)
  sectionNo (154)
  orderNo 158
  title `Discharge or removal of prisoners`
  content obj_root_law_sections_154_content
  footnotes obj_root_law_sections_154_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29364&sectionno=154&orderno=158&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_154_content:
  string
  line `Whenever any offender is undergoing imprisonment or`
  line `detention in pursuance of this Act, it shall be lawful for the Central Government or the Chief of the Naval`
  line `Staff, or where an offender is undergoing imprisonment or detention by order of his commanding officer,`
  line `for such commanding officer or the Central Government or the Chief of the Naval Staff, to give an order`
  line `in writing in the prescribed form directing that the offender be discharged; and it shall also be lawful for`
  line `the Central Government and the Chief of the Naval Staff, by order in writing in the prescribed form, to`
  line `direct that any such offender be delivered over to naval custody for the purpose of being brought before a`
  line `court-martial, either as a witness or for trial or otherwise, and such offender shall accordingly, on the`
  line `production of any such order, be discharged, or be delivered over to such custody.`
obj_root_law_sections_154_footnotes:
  string
  line
obj_root_law_sections_155:
  sectionId (29365)
  sectionNo (155)
  orderNo 159
  title `Time of detention in naval custody`
  content obj_root_law_sections_155_content
  footnotes obj_root_law_sections_155_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29365&sectionno=155&orderno=159&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_155_content:
  string
  line `The time during which any offender under sentence of`
  line `imprisonment or detention is detained in naval custody shall be reckoned as imprisonment or detention`
  line `under his sentence for whatever purpose he is so detained; and the governor, gaoler, keeper or`
  line `superintendent who shall deliver over any such offender shall again receive him from naval custody, so`
  line `that he may undergo the remainder of his punishment.`
obj_root_law_sections_155_footnotes:
  string
  line
obj_root_law_sections_156:
  sectionId (29366)
  sectionNo (156)
  orderNo 160
  title `Removal of insane prisoners`
  content obj_root_law_sections_156_content
  footnotes obj_root_law_sections_156_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29366&sectionno=156&orderno=160&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_156_content:
  string
  line `If any person imprisoned or undergoing detention by virtue of`
  line `this Act shall become insane, and a certificate to that effect shall be given by two physicians or surgeons,`
  line `the Central Government shall, by warrant in the prescribed form, direct the removal of such person to`
  line `such asylum or other proper receptacle for insane persons in India as it may judge proper for the`
  line `unexpired term of his imprisonment or detention; and if any such person shall in the same manner be`
  line `certified to be again of sound mind, the Central Government may issue a warrant in the prescribed form`
  line `for his being removed to such prison or place of confinement or in the case of a person sentenced to`
  line `detention, such naval detention quarters as may be deemed expedient, to undergo the remainder of his`
  line `punishment, and every gaoler or keeper of any prison, gaol, or house of correction shall receive him`
  line accordingly.
obj_root_law_sections_156_footnotes:
  string
  line
obj_root_law_sections_157:
  sectionId (29367)
  sectionNo (157)
  orderNo 161
  title `Naval prisons and naval detention quarters`
  content obj_root_law_sections_157_content
  footnotes obj_root_law_sections_157_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29367&sectionno=157&orderno=161&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_157_content:
  string
  line `The Central Government may set apart any`
  line `buildings or vessels or any parts thereof as naval prisons or naval detention quarters and any buildings,`
  line `vessels or parts of buildings or vessels so set apart as naval prisons or naval detention quarters, as the case`
  line `may be, shall be deemed to be naval prisons or naval detention quarters respectively within the meaning`
  line `of this Act.`
obj_root_law_sections_157_footnotes:
  string
  line
obj_root_law_sections_158:
  sectionId (29368)
  sectionNo (158)
  orderNo 162
  title `Execution of sentence of fine`
  content obj_root_law_sections_158_content
  footnotes obj_root_law_sections_158_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29368&sectionno=158&orderno=162&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_158_content:
  string
  line `When a sentence of fine is imposed under this Act by a courtmartial`
  line `or disciplinary court, the officer ordering the court-martial or disciplinary court may transmit a`
  line `copy of the order imposing the fine duly certified under his hand to any magistrate in India, and such`
  line `magistrate shall thereupon cause the fine to be recovered in accordance with the provisions of the`
  line `^1[Code of Criminal Procedure, 1973(2 of 1974),] or any law corresponding thereto in force in the State of`
  line `Jammu and Kashmir* as if it were a sentence of fine imposed by such magistrate.`
obj_root_law_sections_158_footnotes:
  string
  line `1. Subs. by Act 48 of 1982, s. 10, for "Code of Criminal Procedure, 1898 (5 of 1898)" (w.e.f. 16-10-1982).`
  line
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_159:
  sectionId (29369)
  sectionNo (159)
  orderNo 163
  title `Power to make regulations in respect of naval prisons and detention quarters.`
  content obj_root_law_sections_159_content
  footnotes obj_root_law_sections_159_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29369&sectionno=159&orderno=163&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_159_content:
  string
  line `(1) The`
  line `Central Government may, by notification in the Official Gazette, make regulations providing,--`
  line
  line `(a) for the government, management and regulation of naval prisons and detention quarters;`
  line
  line `(b) for the appointment and removal and powers of inspectors, visitors and officers thereof;`
  line
  line `(c) for the food, bedding and clothing of prisoners or persons undergoing detention therein;`
  line
  line `(d) for the labour of such prisoners or persons therein and for enabling such prisoners or persons`
  line `to earn by special industry and good conduct remission of a portion of their sentence; and`
  line
  line `(e) for the care of such prisoners or persons, their safe custody and the maintenance of good order`
  line `and discipline among them and the punishment by personal correction, restraint or otherwise of`
  line `offences committed by such prisoners or persons.`
  line
  line `(2) The regulations to be made under this section may apply to naval prisons or detention quarters any`
  line `of the provisions of the Prisons Act, 1894 (9 of 1874), and rules made thereunder, imposing punishments`
  line `on any persons not being prisoners or relating to the duties of gaolers, medical officers and other officers`
  line `of the prisons.`
  line
  line `(3) The regulations to be made under this section shall not authorise corporal punishment to be`
  line `inflicted for any offence.`
obj_root_law_sections_159_footnotes:
  string
  line
obj_root_law_sections_160:
  sectionId (29370)
  sectionNo (160)
  orderNo 164
  title `Judicial review by the Judge Advocate General of the Navy.`
  content obj_root_law_sections_160_content
  footnotes obj_root_law_sections_160_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29370&sectionno=160&orderno=164&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_160_content:
  string
  line `(1) All proceedings of trials by`
  line `court-martial or by disciplinary courts shall be reviewed by the Judge Advocate General of the Navy`
  line `either on his own motion or on application made to him within the prescribed time by any person`
  line `aggrieved by any sentence or finding, and the Judge Advocate General of the Navy shall transmit the`
  line `report of such review together with such recommendations as may appear just and proper to the Chief of`
  line `the Naval Staff for his consideration and for such action as the Chief of the Naval Staff may think fit.`
  line
  line `(2) Where any person aggrieved has made an application under sub-section (1), the Judge Advocate`
  line `General of the Navy may, if the circumstances of the case so require, give him an opportunity of being`
  line `heard either in person or through a legal practitioner or an officer of the Indian Navy.`
obj_root_law_sections_160_footnotes:
  string
  line
obj_root_law_sections_161:
  sectionId (29371)
  sectionNo (161)
  orderNo 165
  title `Consideration by the Chief of the Naval Staff.`
  content obj_root_law_sections_161_content
  footnotes obj_root_law_sections_161_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29371&sectionno=161&orderno=165&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_161_content:
  string
  line `(1) On receipt of the report and`
  line `recommendations if any, under section 160, the Chief of the Naval Staff shall in all cases of capital`
  line `sentence and in all cases where the court-martial is ordered by the President, and may in other cases`
  line `transmit the proceedings and the report to the Central Government together with such recommendations`
  line `as he may deem fit to make.`
  line
  line `(2) Nothing in section 160 or this section shall authorise the Judge Advocate General of the Navy or`
  line `the Chief of the Naval Staff to make any recommendation for setting aside, or the Central Government to`
  line `set aside, an order of acquittal passed under this Act.`
obj_root_law_sections_161_footnotes:
  string
  line
obj_root_law_sections_162:
  sectionId (29372)
  sectionNo (162)
  orderNo 166
  title `Petitions to the Central Government or Chief of the Naval Staff against findings or sentences`
  content obj_root_law_sections_162_content
  footnotes obj_root_law_sections_162_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29372&sectionno=162&orderno=166&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_162_content:
  string
  line `Any person subject to naval law who considers himself aggrieved by a finding or sentence of`
  line `any court-martial may present a petition to the Central Government or to the Chief of the Naval Staff, and`
  line `the Central Government or the Chief of the Naval Staff, as the case may be, may pass such order thereon`
  line `as may be thought fit.`
obj_root_law_sections_162_footnotes:
  string
  line
obj_root_law_sections_163:
  sectionId (29373)
  sectionNo (163)
  orderNo 167
  title `Powers of Central Government and the Chief of the Naval Staff in respect of findings and sentences.`
  content obj_root_law_sections_163_content
  footnotes obj_root_law_sections_163_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29373&sectionno=163&orderno=167&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_163_content:
  string
  line `(1) Where any person is tried under the provisions of this Act, the Central Government or the`
  line `Chief of the Naval Staff, may, in the case of a conviction,--`
  line
  line `(a) set aside the finding and sentence and acquit or discharge the accused or order him to be`
  line `retried, or`
  line
  line `(b) alter the finding, maintaining the sentence (provided that such sentence may be legally passed`
  line `on the altered finding), or`
  line
  line `(c) with or without altering the finding, reduce the sentence or commute the punishment awarded`
  line `for any punishment inferior in scale, or`
  line
  line `(d) either with or without conditions, pardon the person or remit the whole or any part of the`
  line `punishment awarded, or`
  line
  line `(e) either with or without conditions, release the person on parole:`
  line
  line `Provided that a sentence of imprisonment shall not be commuted for a sentence of detention for a`
  line `term exceeding the term of imprisonment awarded, and a sentence of dismissal with disgrace not`
  line `accompanied by a sentence of imprisonment shall not be commuted for a sentence of detention:`
  line
  line `Provided further that nothing in this section shall authorise the Central Government or the Chief of`
  line `the Naval Staff to enhance the sentence.`
  line
  line `(2) Any sentence modified under the provisions of sub-section (1) shall be carried into execution as if`
  line `it had been originally passed.`
  line
  line `(3) If any condition on which a person has been pardoned or released on parole or a punishment has`
  line `been remitted is in the opinion of the authority which granted the pardon, release or remission not`
  line `fulfilled, such authority may cancel the pardon or release or remission and thereupon the sentence`
  line `awarded shall be carried into effect as if such pardon, release or remission had not been granted:`
  line
  line `Provided that in the case of a person sentenced to imprisonment or detention such person shall`
  line `undergo only the unexpired portion of the sentence.`
obj_root_law_sections_163_footnotes:
  string
  line
obj_root_law_sections_163_a:
  sectionId (29479)
  sectionNo 163A
  orderNo 168
  title `Provision relating to parole.`
  content obj_root_law_sections_163_a_content
  footnotes `1. Ins. by Act 23 of 2005, s. 8 (w.e.f. 23-6-2005).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29479&sectionno=163A&orderno=168&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_163_a_content:
  string
  line `^1[163A. Provision relating to parole.--Where any person is tried under the provisions of this Act,`
  line `the Central Government or the chief of the Naval Staff or the Flag Officers commanding-in-Chief of the`
  line `Naval Commands may in the case of conviction either with or without conditions release the person on`
  line parole.]
obj_root_law_sections_164:
  sectionId (29480)
  sectionNo (164)
  orderNo 169
  title `Suspension of sentences.`
  content obj_root_law_sections_164_content
  footnotes obj_root_law_sections_164_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29480&sectionno=164&orderno=169&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_164_content:
  string
  line `(1) Where a person has been sentenced to imprisonment or`
  line `detention, the Central Government or the officer who by virtue of the foregoing section or sub-section (3)`
  line `of section 150 has power to issue an order of committal (hereinafter in this section referred to as "the`
  line `committing authority") may, in lieu of issuing such an order, order that the sentence be suspended until an`
  line `order of committal is issued, and in such case--`
  line
  line `(a) notwithstanding anything in this Act, the term of the sentence shall not be reckoned as`
  line `commencing until an order of committal is issued;`
  line
  line `(b) the case may at any time, and shall at intervals of not more than three months, be reconsidered`
  line `by the Central Government or committing authority or the prescribed officer, and if on any such`
  line `reconsideration it appears to the Central Government or committing authority or such prescribed`
  line `officer that the conduct of the offender since his conviction has been such as to justify a remission of`
  line `the sentence, the Central Government or committing authority or such prescribed officer shall remit`
  line `the whole or any part of it;`
  line
  line `(c) subject to regulations made under this Act, the Central Government or the committing`
  line `authority or such prescribed officer may at any time whilst the sentence is suspended issue an order of`
  line `committal and thereupon the sentence shall cease to be suspended;`
  line
  line `(d) where a person subject to naval law, whilst a sentence on him is so suspended, is sentenced to`
  line `imprisonment or detention for any other offence then, if he is at any time committed either under the`
  line `suspended sentence or under any such subsequent sentence, and whether or not any such subsequent`
  line `sentence has also been suspended, the committing authority may direct that the two sentences shall`
  line `run either concurrently or consecutively, so, however, as not to cause a person to undergo detention`
  line `for a period exceeding the aggregate of two consecutive years.`
  line
  line `(2) When a person has been sentenced to imprisonment or detention and an order of committal has`
  line `been issued, the Central Government or the committing authority, or prescribed officer may order the`
  line `sentence to be suspended, and in such cases the person whose sentence is suspended shall be discharged`
  line `and the currency of the sentence shall be suspended until he is again committed under the same sentence, and the provisions of clauses (b), (c) and (d) of sub-section (1) shall apply in like manner as in the case`
  line `where a sentence has been suspended before an order of committal has been issued.`
  line
  line `(3) Where a sentence is suspended under this section, whether before or after committal, the Central`
  line `Government or, subject to regulations made under this Act, the committing authority or officer by whom`
  line `the sentence is suspended may, direct that any penalty which is involved by the punishment of`
  line `imprisonment or detention either shall be or shall not be remitted or suspended.`
obj_root_law_sections_164_footnotes:
  string
  line
obj_root_law_sections_165:
  sectionId (29481)
  sectionNo (165)
  orderNo 170
  title `Offences by persons not subject to naval law in relation to courts-martial and disciplinary courts.`
  content obj_root_law_sections_165_content
  footnotes obj_root_law_sections_165_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29481&sectionno=165&orderno=170&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_165_content:
  string
  line `Every person not subject to naval law, who,--`
  line
  line `(a) being duly summoned or ordered to attend as a witness before a court-martial or disciplinary`
  line `court fails to attend without due cause, or`
  line
  line `(b) refuses to take an oath or make an affirmation legally required by a court-martial or`
  line `disciplinary court to be taken or made, or`
  line
  line `(c) being sworn or affirmed, refuses to answer any questions put by or before a court-martial or`
  line `disciplinary court, which he is in law bound to answer, or`
  line
  line `(d) refuses to produce or deliver up a document in his power which the court-martial or`
  line `disciplinary court may legally demand, or`
  line
  line `(e) is guilty of contempt of court-martial or disciplinary court,`
  line
  line `shall be punished with imprisonment for a term which may extend to two years, or with fine, or with both.`
obj_root_law_sections_165_footnotes:
  string
  line
obj_root_law_sections_166:
  sectionId (29482)
  sectionNo (166)
  orderNo 171
  title `Penalties for aiding escape or attempt to escape of prisoners and for breach of prison regulations.`
  content obj_root_law_sections_166_content
  footnotes obj_root_law_sections_166_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29482&sectionno=166&orderno=171&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_166_content:
  string
  line `(1) Every person, who,--`
  line
  line `(a) conveys or causes to be conveyed into any naval prison or naval detention quarters any arms,`
  line `tools, or instruments, or any mask or other disguise to facilitate the escape of any prisoner or person`
  line `undergoing detention, or`
  line
  line `(b) by any means whatever aids any prisoner or person undergoing detention to escape or in an`
  line `attempt to escape from such prison or naval detention quarters, whether an escape be actually made or`
  line `not, shall be punished with imprisonment for a term which may extend to fourteen years.`
  line
  line `(2) Every person who brings or attempts to bring into a naval prison or naval detention quarters, in`
  line `contravention of regulations made under this Act, any spirituous or fermented liquor, shall for every such`
  line `offence be punished with a fine not exceeding two hundred rupees and not less than one hundred rupees.`
  line
  line `(3) Every person, who,--`
  line
  line `(a) brings into a naval prison or naval detention quarters or to or for any prisoner or person`
  line `undergoing detention, without the knowledge of the officer having charge or command thereof, any`
  line `money, clothing, provisions, tobacco, letters, papers, or other articles not allowed by the rules of the`
  line `prison or naval detention quarters, to be in the possession of a prisoner or person undergoing`
  line `detention, or`
  line
  line `(b) throws into the said prison or naval detention quarters, any such articles, or by desire of any`
  line `prisoner or person undergoing detention, without the sanction of the said officer carried out of the`
  line `prison or naval detention quarters any of the articles aforesaid,`
  line
  line `shall for every such offence be punished with a fine not exceeding two hundred rupees.`
  line
  line `(4) Every person, who,--`
  line
  line `(a) interrupts any officer of a naval prison or naval detention quarters in the execution of his`
  line `duty, or`
  line
  line `(b) aids or abets any person to assault, resist, or interrupt any such officer, shall for every such`
  line `offence be punished with imprisonment which may extend to two years, or with fine, or both.`
  line
  line `(5) Every fine recovered under the foregoing sub-sections of this section shall be applied as the`
  line `Central Government may direct notwithstanding any law, charter, or custom to the contrary.`
obj_root_law_sections_166_footnotes:
  string
  line
obj_root_law_sections_167:
  sectionId (29483)
  sectionNo (167)
  orderNo 172
  title `Penalty as regards gaolers, etc.`
  content obj_root_law_sections_167_content
  footnotes obj_root_law_sections_167_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29483&sectionno=167&orderno=172&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_167_content:
  string
  line `Every governor, gaoler, and keeper of any prison, gaol, or`
  line `house of correction or of any naval detention quarters, and every person having the charge of command of`
  line `any place, ship, or vessel for imprisonment, who shall without lawful excuse, refuse or neglect to receive`
  line `or confine, remove, discharge, or deliver up any offender against the provisions of this Act, or any of`
  line `them, shall incur for every such refusal or neglect a penalty not exceeding one thousand rupees and every`
  line `such penalty shall be applied as the Central Government may direct notwithstanding any law, charter, or`
  line `custom to the contrary.`
obj_root_law_sections_167_footnotes:
  string
  line
obj_root_law_sections_168:
  sectionId (29484)
  sectionNo (168)
  orderNo 173
  title `Appointment of the Judge Advocate General of the Navy and his subordinate officers`
  content obj_root_law_sections_168_content
  footnotes `1. Ins by Act 53 of 1974, s. 17 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29484&sectionno=168&orderno=173&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_168_content:
  string
  line `There shall be appointed by the Central Government a Judge Advocate General of the Navy and as many`
  line `judge advocates in the department of the Judge Advocate General of the Navy as the Central Government`
  line `may deem necessary.`
  line
  line `(2) Out of the judge advocates so appointed, the Central Government may designate any one to be the`
  line `Deputy Judge Advocate General of the Navy.`
  line
  line `(3) A person shall not be qualified for appointment as Judge Advocate General of the Navy`
  line `unless he--`
  line
  line `(a) is a citizen of India, and`
  line
  line `(b) has for at least ten years held a judicial office in the territory of India, or`
  line
  line `(c) has for at least ten years been an advocate of a High Court or two or more such courts in`
  line succession
  line
  line `^1[Provided that the Central Government may, if it is of opinion that it is necessary or expedient so to`
  line `do in the exigencies of service, relax, for reasons to be recorded in writing, the qualification specified in`
  line `clause (b) or clause (c) in respect of any person.]`
  line
  line `(4) A person shall not be qualified for appointment as Deputy Judge Advocate General of the Navy`
  line `unless he--`
  line
  line `(a) is a citizen of India, and`
  line
  line `(b) has for at least seven years held a judicial office in the territory of India, or`
  line
  line `(c) has for at least seven years been an advocate of a High Court or two or more such courts in`
  line succession.
  line
  line `^1[Provided that the Central Government may, if it is of opinion that it is necessary or expedient so to`
  line `do in the exigencies of service, relax, for reasons to be recorded in writing, the qualification specified in`
  line `clause (b) or clause (c) in respect of any person.]`
  line
  line `(5) A person shall not be qualified for appointment as a judge advocate unless he--`
  line
  line `(a) is a citizen of India, and`
  line
  line `(b) is qualified for enrolment as an advocate or a leader of a High Court.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) in computing the period during which a person has been an advocate of a High Court, there`
  line `shall be included any period during which the person has held judicial office after he became an`
  line advocate;
  line
  line `(b) in computing the period during which a person has held judicial office in the territory of India`
  line `or been an advocate of a High Court, there shall be included any period before the commencement of`
  line `the Constitution during which he has held judicial office in any area which was comprised before the`
  line `15th day of August, 1947, within India as defined in the Government of India Act, 1935, or has`
  line `practised as an advocate of any High Court in any such area as the case may be;`
  line
  line `(c) the expression "judicial office" shall be deemed to include the office of the Judge Advocate of`
  line `the Fleet or any of his deputies or assistants and any other legal or judicial office in the department of`
  line `the Judge Advocate of the Fleet held before the commencement of this Act, and the office of the`
  line `Judge Advocate General of the Navy or of a judge advocate held after the commencement of this Act.`
obj_root_law_sections_169:
  sectionId (29485)
  sectionNo (169)
  orderNo 174
  title `Functions of the Judge Advocate General of the Navy.`
  content obj_root_law_sections_169_content
  footnotes obj_root_law_sections_169_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29485&sectionno=169&orderno=174&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_169_content:
  string
  line `It shall be the duty of the Judge`
  line `Advocate General of the Navy to perform such duties of a legal and judicial character pertaining to the`
  line `Indian Navy as may from time to time be referred or assigned to him by the Central Government or the`
  line `Chief of the Naval Staff, and to discharge the functions conferred on him by or under this Act or any`
  line `other law for the time being in force.`
obj_root_law_sections_169_footnotes:
  string
  line
obj_root_law_sections_170:
  sectionId (29486)
  sectionNo (170)
  orderNo 175
  title `Discharge of functions of the Judge Advocate General of the Navy in his absence.`
  content obj_root_law_sections_170_content
  footnotes obj_root_law_sections_170_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29486&sectionno=170&orderno=175&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_170_content:
  string
  line `The functions of the Judge Advocate General of the Navy shall in his absence on leave or`
  line `otherwise, be performed by such one of the judge advocates in his department as may be designated in`
  line `this behalf by the Chief of the Naval Staff.`
obj_root_law_sections_170_footnotes:
  string
  line
obj_root_law_sections_171:
  sectionId (29487)
  sectionNo (171)
  orderNo 176
  title `Disposal of property of deceased sailors.`
  content obj_root_law_sections_171_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29487&sectionno=171&orderno=176&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_171_content:
  string
  line `(1) On the death of a ^1[sailor] while subject to naval`
  line `law, the commanding officer of the ship to which the ^1[sailor] belonged shall as soon as may be,--`
  line
  line `(a) secure all movable property belonging to the deceased that is in the ship or quarters and cause`
  line `an inventory thereof to be made;`
  line
  line `(b) draw the pay and allowances due to such persons;`
  line
  line `(c) if he thinks fit, and subject to any regulations made in this behalf, collect all moneys left by`
  line `the deceased in any banking company, including any post office savings banks, cooperative bank or`
  line `society, or any other institution receiving deposits in money however named, and for that purpose`
  line `may require the agent, manager or other proper authority of such banking company, society or other`
  line `institution to pay the moneys to the commanding officer forthwith notwithstanding anything in the`
  line `rules of the banking company, society or institution; and such agent, manager or other authority shall,`
  line `notwithstanding anything contained in any other law, be bound to comply with the requisition.`
  line
  line `(2) Where any money has been paid by the banking company, society or other institution in`
  line `compliance with the requisition under clause (c) of sub-section (1), no person shall have any claim against`
  line `the said banking company, society or other institution in respect of such money.`
  line
  line `(3) The commanding officer shall, if in his opinion it is necessary for the purpose of securing the`
  line `payment of the ship and service debts and other debts in the ship or quarters of the deceased and the`
  line `expenses, if any, incurred by the commanding officer in respect of the estate of the deceased, cause the`
  line `movable property of the deceased to be sold or converted into money.`
  line
  line `(4) If the representative of the deceased is on the spot and either pays or gives security for the`
  line `payment of the ship and service debts and other debts in ship or quarters due from the deceased, the`
  line `commanding officer shall not take action under clause (c) of sub-section (1) or under sub-section (3).`
  line
  line `(5) The commanding officer shall, out of the moneys so received, collected or realised under`
  line `sub-sections (1) and (3), pay the ship and service debts and other debts in ship or quarters of the deceased,`
  line `and the expenses incurred in connection with the realisation of the assets of the deceased.`
  line
  line `(6) Any property left over after meeting the expenditure indicated in sub-section (5), or where the`
  line `representative had paid or given security for the payment of the ship and service debts and other debts in`
  line `ship or quarters the entire property of the deceased, shall be delivered over by the commanding officer to`
  line `the representative of the deceased, whereupon his responsibility for the administration of the estate of the`
  line `deceased shall cease.`
  line
  line `(7) If no claim is made in respect of the said surplus by a representative of the deceased within twelve`
  line `months of the death, the commanding officer shall take steps to hand over the property to the prescribed`
  line `person who shall continue the administration of the estate of the deceased as provided for in section 176.`
obj_root_law_sections_172:
  sectionId (29488)
  sectionNo (172)
  orderNo 177
  title `Disposal of property of deceased officers.`
  content obj_root_law_sections_172_content
  footnotes obj_root_law_sections_172_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29488&sectionno=172&orderno=177&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_172_content:
  string
  line `The provisions of section 171 shall also apply to`
  line `the disposal of the property of an officer who dies while subject to naval law, but with the following`
  line `modifications, namely:--`
  line
  line `(i) the functions of the commanding officer under section 171 shall be performed by a Committee`
  line `of Adjustment constituted in this behalf in the prescribed manner; and`
  line
  line `(ii) the surplus, if any, after the payment of debts and expenses specified in sub-section (3) of`
  line `section 171 shall be paid to the person prescribed in this behalf.`
obj_root_law_sections_172_footnotes:
  string
  line
obj_root_law_sections_173:
  sectionId (29489)
  sectionNo (173)
  orderNo 178
  title `Decision of questions as to ship and service debts and other debts in ship or quarters.`
  content obj_root_law_sections_173_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29489&sectionno=173&orderno=178&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_173_content:
  string
  line `If in`
  line `any case doubt or difference arises as to what are the ship or service debts and the debts in ship or`
  line `quarters of a deceased officer or ^1[sailor] or as to the amount payable in respect thereof, the decision of`
  line `the prescribed person shall be final and shall be binding on all persons for all purposes.`
obj_root_law_sections_174:
  sectionId (29490)
  sectionNo (174)
  orderNo 179
  title `Nature of the powers of commanding officer or Committee of Adjustment.`
  content obj_root_law_sections_174_content
  footnotes obj_root_law_sections_174_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29490&sectionno=174&orderno=179&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_174_content:
  string
  line `For the`
  line `purpose of the exercise of his or its duties under section 171 or 172, as the case may be, the commanding`
  line `officer or the Committee of Adjustment, as the case may be, shall, to the exclusion of all other persons`
  line `and authorities have the same rights and powers as if the commanding officer or the Committee had taken`
  line `out representation to the estate of the deceased, and any receipt given by such commanding officer or the`
  line `Committee, as the case may be, shall have effect accordingly.`
  line
  line `Explanation.--"Representation" includes probate, letters of administration with or without the will`
  line `annexed and a succession certificate issued by a court of competent jurisdiction constituting a person`
  line `executor or administrator of the estate of the deceased person or authorising him to receive or realise the`
  line `assets of a deceased person.`
obj_root_law_sections_174_footnotes:
  string
  line
obj_root_law_sections_175:
  sectionId (29695)
  sectionNo (175)
  orderNo 180
  title `Powers of Central Government to hand over estate of deceased persons to the AdministratorGeneral.`
  content obj_root_law_sections_175_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29695&sectionno=175&orderno=180&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_175_content:
  string
  line `(1) Notwithstanding anything contained in the Administrator-General's`
  line `Act, 1913 (3 of 1913), an Administrator-General shall not interpose in any manner in relation to any`
  line `property of a deceased which has been dealt with under section 171 or section 172 except in so far as he is`
  line `expressly required or competent to do so by or under the provisions of this Act.`
  line
  line `(2) The Central Government may, at any time and in such circumstances as it thinks fit, direct that the`
  line `estate of a deceased ^1[sailor] or officer shall be handed over by the commanding officer or the Committee`
  line `of Adjustment, as the case may be, to the Administrator-General of a State for administration and`
  line `thereupon such commanding officer or the Committee shall make over the estate to such`
  line Administrator-General.
  line
  line `(3) Where under this section any estate is handed over to the Administrator-General, the latter shall`
  line `administer such estate in accordance with the provisions of the Administrator-Generals Act, 1913`
  line `(3 of 1913):`
  line
  line `Provided that where the estate is handed over to the Administrator-General before the ship and`
  line `service debts and other debts in ship or quarters of the deceased are paid, it shall be the duty of the`
  line `Administrator-General to pay these debts in priority to any debts due by the deceased.`
  line
  line `(4) The Administrator-General shall pay the surplus, if any, remaining in his hands after discharging`
  line `all debts and charges, to the heirs of the deceased and if no heir is traceable, shall make over the surplus`
  line `to the person prescribed in this behalf.`
  line
  line `(5) The Administrator-General shall not charge in respect of his duties under this section any fee`
  line `exceeding three per cent. of the total amount coming to or remaining in his hands after payment of the`
  line `ship and service debts and the other debts in ship or quarters.`
obj_root_law_sections_176:
  sectionId (29696)
  sectionNo (176)
  orderNo 181
  title `Disposal of surplus by prescribed persons.`
  content obj_root_law_sections_176_content
  footnotes `1. Subs. by Act 23 of 2005, s. 9, for "ten thousand rupees in value and" (w.e.f. 23-6-2005).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29696&sectionno=176&orderno=181&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_176_content:
  string
  line `On receipt of the surplus referred to in`
  line `sub-section (7) of section 171 or clause (ii) of section 172 or sub-section (4) of section 175, the prescribed`
  line `person shall,--`
  line
  line `(a) if he knows of a legal representative of the deceased, pay the surplus to that representative;`
  line
  line `(b) if the surplus does not exceed ^1[the prescribed amount not exceeding rupees on lakh in value] if he`
  line `thinks fit, pay or deliver to any person appearing to him to be entitled to receive the same, without`
  line `requiring such person to produce any probate, letters of administration, succession certificate or other`
  line `conclusive evidence of title;`
  line
  line `(c) if the prescribed person does not know of any such representative to whom the surplus could be`
  line `paid under clause (a), or if the surplus has not been disposed of under clause (b), publish every year a`
  line `notice in the prescribed form and manner for six consecutive years; and if no claim to the surplus is made`
  line `by the legal representative of the deceased within six months even after the publication of the last of such`
  line `notices, the prescribed person shall deposit the surplus together with any income or accumulation of`
  line `income accrue therefrom, to the credit of the Central Government:`
  line
  line `Provided that such deposit shall not prejudice the claims of any person to such surplus or any part`
  line `thereof, if he is otherwise entitled to it.`
obj_root_law_sections_177:
  sectionId (29697)
  sectionNo (177)
  orderNo 182
  title `Disposal of effects not converted into money.`
  content obj_root_law_sections_177_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29697&sectionno=177&orderno=182&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_177_content:
  string
  line `Where any part of the estate of a deceased`
  line `officer or ^1[sailor] consists of effects, securities or other property not converted into money, the`
  line `provisions of sub-section (7) of section 171 or clause (ii) of section 172 and section 176 with respect to`
  line `the payment of the surplus shall, save as may be prescribed, extend to the delivery, transmission or`
  line `transfer of such effects, securities or property, and the prescribed person shall have the same power of`
  line `converting the same into money as a legal representative of the deceased.`
obj_root_law_sections_178:
  sectionId (29698)
  sectionNo (178)
  orderNo 183
  title `Termination of liability of commanding officer, Committee, prescribed person and the Central Government.`
  content obj_root_law_sections_178_content
  footnotes obj_root_law_sections_178_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29698&sectionno=178&orderno=183&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_178_content:
  string
  line `Any payment or application of money or delivery, sale or other disposition of`
  line `any property made, or purported to be made by the commanding officer, the Committee or the prescribed`
  line `person in good faith in pursuance of sections 171 to 176 shall be valid and shall fully absolve the`
  line `commanding officer, the Committee or the prescribed person, as the case may be, as well as the Central`
  line `Government from all liability in respect of the money or property so paid, applied or disposed of; but`
  line `nothing herein contained shall be deemed to affect the right of any executor or administrator or other legal`
  line `representative or of any creditor of the deceased against any person to whom any such payment or`
  line `delivery as aforesaid has been made.`
obj_root_law_sections_178_footnotes:
  string
  line
obj_root_law_sections_179:
  sectionId (29699)
  sectionNo (179)
  orderNo 184
  title `Saving of rights of representative.`
  content obj_root_law_sections_179_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29699&sectionno=179&orderno=184&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_179_content:
  string
  line `Nothing in this Chapter shall affect the rights and duties`
  line `of the representative of a deceased ^1[sailor] or officer or any Administrator-General, in respect of the`
  line `property of such deceased ^1[sailor] or officer not collected by the commanding officer or the Committee,`
  line `as the case may be, and not forming part of the surplus handed over to the prescribed person either under`
  line `sub-section (7) of section 171 or clause (ii) of section 172.`
obj_root_law_sections_180:
  sectionId (29700)
  sectionNo (180)
  orderNo 185
  title `Application of sections 171 to 179 to persons of unsound mind.`
  content obj_root_law_sections_180_content
  footnotes obj_root_law_sections_180_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29700&sectionno=180&orderno=185&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_180_content:
  string
  line `The provisions of sections`
  line `171 to 179 shall, so far as they can be made applicable, also apply in the case of an officer or ^1[sailor]`
  line `subject to naval law who is ascertained in the prescribed manner to be of unsound mind notwithstanding`
  line `anything contained in the Indian Lunacy Act, 1912 (4 of 1912), or who, while on active service, is`
  line `officially reported missing, as if the said officer or ^1[sailor] had died on the day on which his unsoundness`
  line `of mind is so ascertained or, as the case may be, on the day on which he is officially reported missing:`
  line
  line `Provided that in the case of an officer or ^2[sailor] so reported missing, no action shall be taken to`
  line `dispose of the property under sections 171, 172 and 175 until such time as a certificate under the`
  line `regulations made under this Act is issued by or under the authority of the Chief of the Naval Staff or other`
  line `prescribed person that he is confirmed or presumed to be dead.`
obj_root_law_sections_180_footnotes:
  string
  line `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  line `2. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
obj_root_law_sections_181:
  sectionId (29701)
  sectionNo (181)
  orderNo 186
  title `Appointment of Standing Committee of Adjustment in certain cases.`
  content obj_root_law_sections_181_content
  footnotes obj_root_law_sections_181_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29701&sectionno=181&orderno=186&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_181_content:
  string
  line `When an officer`
  line `while subject to naval law dies or is ascertained in the prescribed manner to be of unsound mind or while`
  line `on active service is officially reported missing, the reference in the foregoing provisions of this Chapter to`
  line `the Committee shall be construed as references to the Standing Committee of Adjustment, if any,`
  line `constituted in this behalf in the prescribed manner and such Standing Committee, if constituted, shall`
  line `alone by entitled to perform all the functions of such Committee unless otherwise directed by the Chief of`
  line `the Naval Staff.`
obj_root_law_sections_181_footnotes:
  string
  line
obj_root_law_sections_182:
  sectionId (29702)
  sectionNo (182)
  orderNo 187
  title `Exercise of powers by other persons.`
  content obj_root_law_sections_182_content
  footnotes obj_root_law_sections_182_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29702&sectionno=182&orderno=187&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_182_content:
  string
  line `The functions and powers of the commanding officer`
  line `in this Chapter may in any case be performed or exercised by any other person appointed in this behalf by`
  line `the Chief of the Naval Staff.`
obj_root_law_sections_182_footnotes:
  string
  line
obj_root_law_sections_183:
  sectionId (29703)
  sectionNo (183)
  orderNo 188
  title `Forfeiture of effects for absence without leave.`
  content obj_root_law_sections_183_content
  footnotes obj_root_law_sections_183_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29703&sectionno=183&orderno=188&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_183_content:
  string
  line `If any person subject to naval law is absent`
  line `without leave for a period of one month (whether he is guilty of desertion or of improperly leaving his`
  line `ship or place of duty or not) but is not apprehended or tried for his offence, he shall be liable for forfeiture`
  line `of pay and allowances and other benefits as the Central Government from time to time by regulations`
  line `provide, and the Central Government, the Chief of the Naval Staff or the prescribed officer may by an`
  line `order containing a statement of the absence without leave direct that the clothes and effects, if any, left by`
  line `him on board ship or at his place of duty be forfeited and the same be sold and the proceeds of the same`
  line `shall be disposed of as provided in the regulations made under this Act; and every order under this`
  line `provision for forfeiture or sale be conclusive for the purpose of this section as to the fact of the absence`
  line `without leave as therein stated of the person therein named; but in any case the Central Government may,`
  line `if it deems fit on sufficient cause being shown at any time after forfeiture and before sale, remit the`
  line `forfeiture, or after sale pay or dispose of the proceeds of the sale or any part thereof to or for the use of the`
  line `person to whom the clothes or effects belonged, or his representatives.`
obj_root_law_sections_183_footnotes:
  string
  line
obj_root_law_sections_184:
  sectionId (29704)
  sectionNo (184)
  orderNo 189
  title `Power to make regulations.`
  content obj_root_law_sections_184_content
  footnotes obj_root_law_sections_184_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29704&sectionno=184&orderno=189&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_184_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line `Gazette, make regulations for the governance, command, discipline, recruitment, conditions of service`
  line `and regulation of the naval forces and generally for the purpose of carrying into effect the provisions of`
  line `this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for--`
  line
  line `(a) the rank, precedence, powers of command and authority of officers and ^1[sailors] in the naval`
  line service;
  line
  line `(b) the relative rank, precedence, powers of command and authority of officers and ^1[sailors] in`
  line `the naval service in relation to members of the regular Army and the Air Force;`
  line
  line `^2[(c) the cases in which, and the conditions subject to which, powers of punishment may be`
  line `exercised under sub-section (2) of section 7;`
  line
  line `(ca) the retirement, discharge and dismissal of persons in the naval service;`
  line
  line `(cb) the authority to which any matter referred to in section 19A may be referred and the manner`
  line `in which an enquiry may be made by that authority;]`
  line
  line `(d) the convening and constitution of courts-marital and the appointment of prosecutors at trials`
  line `by court-martial;`
  line
  line `(e) the adjournment, dissolution and sittings of courts-martial;`
  line
  line `(f) the procedure to be observed in trials by courts-martial, the persons by whom an accused may`
  line `be defended in such trials and the appearance of such persons thereat;`
  line
  line `(g) the forms of orders to be made under the provisions of this Act relating to courts-martial and`
  line `the awards and infliction of death, imprisonment and detention;`
  line
  line `(h) the carrying into effect of sentences of courts-martial;`
  line
  line `(i) any matter necessary for the purpose of carrying this Act into execution as far as it relates to`
  line `the investigation, arrest, custody, trial and punishment of offences triable or punishable under`
  line `this Act;`
  line
  line `(j) the terms and conditions of service, the pay, pensions, allowances and other benefits of`
  line `persons in the naval service, including special provision in this behalf during active service;`
  line
  line `(k) the ceremonials to be observed and marks of respect to be paid in the naval service;`
  line
  line `(l) the convening of, the constitution, procedure and practice of boards of inquiry, the summoning`
  line `of witnesses before them and the administration of oaths by such boards;`
  line
  line `(m) the computation of time of absence without leave or custody of deserters and`
  line `absentees without leave;`
  line
  line `(n) any matter relating to the realisation and disposal of the estates of officers or ^69`
  line `sailors who`
  line `are deceased, ascertained to be of unsound mind or reported missing on active service;`
  line
  line `(o) the enquiry into the conduct of prisoners of war, and their pay and allowances;`
  line
  line `(p) the provision to be made for the wives and children of prisoners of war or missing persons;`
  line
  line `(q) the procedure relating to the exercise of powers under section 163;`
  line
  line `^3[(qa) the amount required to be prescribed under clause (b) of section 176]`
  line
  line `(r) any other matter which is to be, may be, or is required to be, prescribed under this Act.`
obj_root_law_sections_184_footnotes:
  string
  line `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-74).`
  line
  line `2. Subs by s. 18, ibid., for clause (c) (w.e.f. 16-12-1974).`
  line
  line `3. Ins. by Act 23 of 2005, s. 10 (w.e.f. 23-6-2005).`
obj_root_law_sections_184_a:
  sectionId (29705)
  sectionNo 184A
  orderNo 190
  title `Power to make regulations with retrospective effect`
  content obj_root_law_sections_184_a_content
  footnotes `1. Ins. by Act 48 of 1982, s. 11 (w.e.f. 16-10-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29705&sectionno=184A&orderno=190&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_184_a_content:
  string
  line `^1[184A. Power to make regulations with retrospective effect.--The power to make regulations`
  line `conferred by this Act shall include the power to give retrospective effect, from a date not earlier than the`
  line `date of commencement of this Act, to the regulations or any of them, but no retrospective effect shall be`
  line `given to any regulation so as to prejudicially affect the interests of any person to whom such regulation`
  line `may be applicable.]`
obj_root_law_sections_185:
  sectionId (29706)
  sectionNo (185)
  orderNo 191
  title `Regulations to be laid before Parliament.`
  content obj_root_law_sections_185_content
  footnotes `1. Subs. by Act 53 of 1974, s. 19, for section 185 (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29706&sectionno=185&orderno=191&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_185_content:
  string
  line `^1[185. Regulations to be laid before Parliament.--Every regulation made under this Act shall be`
  line `laid, as soon as may be after it is made, before each House of Parliament, while it is in session for a total`
  line `period of thirty days which may be comprised in one session or in two or more successive sessions, and`
  line `if, before the expiry of the session immediately following the session or the successive sessions aforesaid,`
  line `both Houses agree in making any modification in the regulation or, both Houses agree that the regulation`
  line `should not be made, the regulation shall thereafter have effect only in such modified form or be of no`
  line `effect, as the case may be; so, however, that any such modification or annulment shall be without`
  line `prejudice to the validity of anything previously done under that regulation.]`
obj_root_law_sections_186:
  sectionId (29707)
  sectionNo (186)
  orderNo 192
  title Repeals.
  content obj_root_law_sections_186_content
  footnotes obj_root_law_sections_186_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29707&sectionno=186&orderno=192&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_186_content:
  string
  line `[Repeals].—Rep. by the Repealing and Amending Act, 1960 (58 of 1960), s. 2 and the First`
  line `Schedule (w.e.f. 29-12-1960).`
obj_root_law_sections_186_footnotes:
  string
  line
obj_root_law_sections_187:
  sectionId (29708)
  sectionNo (187)
  orderNo 193
  title `Provisions as to existing naval forces, appointments, etc.`
  content obj_root_law_sections_187_content
  footnotes `1. Subs. by Act 53 of 1974, s. 2, for "seaman" (w.e.f. 16-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29708&sectionno=187&orderno=193&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_187_content:
  string
  line `(1) The Indian Navy in existence`
  line `at the commencement of this Act shall be deemed to be the regular naval force raised under this Act.`
  line
  line `(2) The Indian Naval Reserve, the Indian Naval Volunteer Reserve and the Indian Fleet Reserve in`
  line `existence at the commencement of this Act shall be deemed to be the Indian Naval Reserve Forces raised`
  line `under this Act.`
  line
  line `(3) Officers in the Indian Navy or the Indian Naval Reserve Forces at the commencement of this Act`
  line `shall be deemed to have been appointed as such under this Act.`
  line
  line `(4) The person holding office as Judge Advocate of the Fleet at the commencement of this Act shall,`
  line `on such commencement, be deemed to have been appointed as the Judge Advocate General of the Navy`
  line `under this Act.`
  line
  line `(5)`
  line `^1[Sailors] in the Indian Navy or in the Indian Naval Reserve Forces at the commencement of this`
  line `Act shall be deemed to have been duly enrolled as such under this Act.`
obj_root_law_sections_188:
  sectionId (29709)
  sectionNo (188)
  orderNo 194
  title `Power of officers of the Royal Navy.`
  content obj_root_law_sections_188_content
  footnotes obj_root_law_sections_188_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_28_38_00006_195762_1517807321397&sectionId=29709&sectionno=188&orderno=194&orgactid=AC_CEN_28_38_00006_195762_1517807321397
obj_root_law_sections_188_content:
  string
  line `(1) An officer of the Royal Navy attached to or serving`
  line `with the Indian Navy shall have and exercise all such powers as are vested in or may be exercised by an`
  line `officer of the Indian Navy of corresponding rank or holding a corresponding appointment and shall be`
  line `eligible to be granted a commission to convene courts-martial or to be appointed as president of a`
  line `court-martial or to sit on a court-martial as a member as if he were an officer of the Indian Navy subject`
  line `to naval law.`
  line
  line `(2) The expression "superior officer" wherever used in this Act shall be deemed to include an officer`
  line `of the Royal Navy when serving under conditions specified in sub-section (1).`
obj_root_law_sections_188_footnotes:
  string
  line
