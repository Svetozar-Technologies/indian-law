obj_root_law_sections_1:
  sectionId (67134)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67134&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Bihar Value Added Tax`
  line `Act, 2005.`
  line
  line `(2) It shall extend to the whole of the State of Bihar.`
  line
  line `(3) It shall be deemed to have come into force on the 1st day of April, 2005.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (67135)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67135&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,`
  line
  line `(a) "Assessing Authority" means any of the authorities referred to in section 10 who is directed`
  line `under sub-section (2) of that section to exercise or perform all or any of the powers and functions`
  line `conferred on an Assessing Authority under this Act;`
  line
  line `(b) "Assistant Commercial Taxes Officer" means an Assistant Commercial Taxes Officer`
  line `appointed under sub-section (1) of section 10;`
  line
  line `(c) "Assistant Commissioner of Commercial Taxes" means an Assistant Commissioner of`
  line `Commercial Taxes and Additional Assistant Commissioner of Commercial Taxes appointed under`
  line `sub-section (1) of section 10;`
  line
  line `(d) "business" includes,`
  line
  line `(i) any trade, commerce, manufacture or any adventure or concern in the nature of trade,`
  line `commerce, manufacture, whether or not such trade, commerce, manufacture, adventure or concern`
  line `is carried on with a motive to make gain or profit and whether or not any gain or profit accrues`
  line `from such trade, commerce, manufacture, adventure or concern;`
  line
  line `(ii) any transaction of sale or purchase in connection with, or incidental or ancillary to, such`
  line `trade, commerce, manufacture, adventure or concern; and`
  line
  line `(iii) any transaction in connection with, or incidental or ancillary to, the commencement or`
  line `closure of such business;`
  line
  line `(e) "capital goods" means plant, machinery and equipment used in trade or manufacturing of goods;`
  line
  line `(f) "casual trader" means a person, who, whether as principal, agent or in any other capacity`
  line `undertakes occasional transactions in the nature of business involving buying, selling, supply or`
  line `distribution of goods or conducting any exhibition-cum-sale in the State of Bihar, whether for cash,`
  line `deferred payment, commission, remuneration or other valuable consideration;`
  line
  line `(g) "Commercial Taxes Officer" means a Commercial Taxes Officer appointed under`
  line `sub-section (1) of section 10;`
  line
  line `(h) "Commissioner" means the Commissioner of Commercial Taxes appointed under`
  line `sub-section (1) of section 10 or Additional Commissioner of Commercial Taxes and any other officer`
  line `upon whom the State Government may, by notification, confer all or any of the powers and duties of`
  line `the Commissioner under this Act;`
  line
  line `(i) "dealer" means any person who, whether regularly or otherwise, in the course of business, buys,`
  line `sells, supplies, distributes or does anything incidental to such buying, selling, supplying or distributing of goods, directly or indirectly, whether for cash, or for deferred payment or for`
  line `commission, remuneration or other valuable consideration and includes--`
  line
  line `(A) a local authority;`
  line
  line `(B) a Hindu undivided family;`
  line
  line `(C) a company, or any society (including a co-operative society), club, firm, association of`
  line `persons or body of individuals, whether incorporated or not, which carries on such business;`
  line
  line `(D) a society (including a co-operative society), club, firm or association which buys goods`
  line `from, or sells, supplies or distributes goods to its members;`
  line
  line `(E) an industrial, commercial, banking or trading undertaking, whether or not, of the Central`
  line `Government or of any of the State Governments or of a local authority;`
  line
  line `(F) a casual trader;`
  line
  line `(G) a commission agent, broker, factor, a del credere agent, an auctioneer or any other`
  line `mercantile agent, by whatever name called, who carries on the business of buying, selling,`
  line `supplying or distributing goods on behalf of the principal.`
  line
  line `Explanation.-- Every person who acts as an agent on behalf of a dealer residing outside the State`
  line `of Bihar and buys, sells, supplies or distributes goods in the State or acts on behalf of such dealer`
  line as--
  line
  line `(a) a commission agent, broker, factor, a del credere agent, an auctioneer or any other`
  line `mercantile agent, by whatever name called; or`
  line
  line `(b) an agent for handling goods or documents of title to goods; or`
  line
  line `(c) an agent for the collection or the payment of the sale price of goods or as a guarantor`
  line `for such collection or payment; or`
  line
  line `(d) a local branch of a firm or company situated outside the State, shall be deemed to be a`
  line `dealer for the purposes of this Act;`
  line
  line `(j) "declared goods" means goods declared under section 14 of the Central Sales Tax Act, 1956 (74`
  line `of 1956) to be of special importance in inter-State trade or commerce;`
  line
  line `(k) "Deputy Commissioner of Commercial Taxes" means the Deputy Commissioner of`
  line `Commercial Taxes or Additional Deputy Commissioner of Commercial Taxes appointed under`
  line `sub-section (1) of section 10;`
  line
  line `(l) "goods" means all kinds of movable property including livestock, computer software, any`
  line `electronic chip used for the purpose of storing or transmitting data or voice and all materials,`
  line `commodities and articles (as such or in some other form) but excluding newspapers, electricity,`
  line `actionable claims, stocks, shares or security.`
  line
  line `Explanation.-- For the purposes of this clause, materials, commodities and articles,--`
  line
  line `(i) attached to or forming part of an immovable property which are agreed to be severed under`
  line `the contract of sale; or`
  line
  line `(ii) sold or supplied as such or in some other form in the execution of works contract, lease or`
  line `hire purchase, shall be deemed to be goods within the meaning of this clause;`
  line
  line `(m) "goods carrier" means a motor vehicle, vessel, boat, animal and any form of conveyance used`
  line `for carrying goods;`
  line
  line `(n) "Government" means the Government of the State of Bihar;`
  line
  line `(o) "gross turnover" means,--`
  line
  line `(i) for the purposes of levy of tax on sales, in respect of sale of goods, aggregate of sale prices`
  line `received or receivable by a dealer on sales and includes sale of goods made outside the State of`
  line `Bihar or in the course of inter-State trade or commerce or export but does not include sale price of`
  line `goods which have borne the incidence of tax on purchases under sections 4 and 5;`
  line
  line `(ii) for the purposes of levy of tax on purchase, aggregate of purchase prices paid or payable`
  line `by a dealer during any given period in respect of purchase of goods or class or description of goods`
  line `which are liable to tax under sections 4 and 5; and`
  line
  line `(iii) for the purposes of section 3, the aggregate of the amounts under sub-clauses (i) and (ii)`
  line above.
  line
  line `Explanation.--For the purposes of this clause, the amount received by a dealer on account of price`
  line `variation or price escalation in respect of sale or supply of goods shall be deemed to form part of gross`
  line `turnover of the financial year during which it is actually received;`
  line
  line `(p) "importer" means a dealer who brings any goods into the State of Bihar or to whom any goods`
  line `are despatched from any place outside the State of Bihar;`
  line
  line `(q) "input" means goods (excluding goods specified in Schedule IV) purchased in the course of`
  line business--
  line
  line `(a) for re-sale;`
  line
  line `(b) for use in manufacture of goods including packing materials;`
  line
  line `(c) for use as capital goods as defined in clause (e);`
  line
  line `(r) "input tax" means the amount paid or payable by a registered dealer, by way of tax under this`
  line `Act, in respect of purchase of any taxable goods;`
  line
  line `(s) "Inspector" means an Inspector of Commercial Taxes appointed under sub-section (3) of`
  line `section 10;`
  line
  line `(t) "month" means a calendar month;`
  line
  line `(u) "notification" means a notification published in the Official Gazette;`
  line
  line `(v) "output tax" means the tax charged or chargeable in respect of sale or supply of goods made by`
  line `a registered dealer;`
  line
  line `(w) "place of business" means any place where a dealer, either usually or for the time being,`
  line `manufactures, sells or purchases goods or keeps accounts of stocks, manufactures, sales or purchases,`
  line `execution of works contracts, hire purchase contracts and lease contracts or any other place where`
  line `business activity takes place and includes--`
  line
  line `(i) the place of business of an agent, in case of a dealer carrying on business through an agent;`
  line or
  line
  line `(ii) any place or building in which a person carrying on a business, keeps any of his books of`
  line `account, documents, stocks or other things, relating to his business;`
  line
  line `(x) "prescribed authority" means the authority prescribed by the rules made under this Act to`
  line `exercise powers conferred under different provisions and perform such functions as may be conferred`
  line `by or under this Act;`
  line
  line `(y) "prescribed" means prescribed under the rules made under this Act;`
  line
  line `(z) "purchase price" means the amount paid or payable by a dealer as a valuable consideration in`
  line `respect of purchase of goods and includes--`
  line
  line `(i) any amount charged for anything done by the vendor in respect of the goods at the time of,`
  line `or before, the delivery thereof;`
  line
  line `(ii) transport costs or freight, if any;`
  line
  line `(iii) trade commission, if any, by whatever name called;`
  line
  line `(iv) clearing, forwarding and handling charges, if any;`
  line
  line `(v) insurance charges, if any;`
  line
  line `(vi) taxes or duties under any law for the time being in force (other than tax paid or payable`
  line `under this Act) by whatever name called, if any;`
  line
  line `(vii) cost of packing, if any; and`
  line
  line `(viii) the amount paid or payable by the purchaser by way of non-refundable deposit, whether`
  line `by way of a separate agreement or not, in connection with or incidental or ancillary to, the said`
  line `purchase of goods;`
  line
  line `(za) "quarter" means the quarter ending on the 30th June, 30th September, 31st December and 31st`
  line `March and the expression "quarterly" shall be construed accordingly;`
  line
  line `(zb) "registered dealer" means a dealer in possession of a valid certificate of registration granted to`
  line `him under section 19 or under the provisions of the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as`
  line `it stood before its repeal by section 94;`
  line
  line `(zc) "sale" with all its grammatical variations and cognate expressions means any transfer of`
  line `property in goods for cash or deferred payment or for other valuable consideration and includes--`
  line
  line `(i) a transfer, otherwise than in pursuance of a contract, of property in any goods for cash,`
  line `deferred payment or other valuable consideration;`
  line
  line `(ii) a transfer of property in goods (whether as goods or in some other form) involved in the`
  line `execution of a works contract;`
  line
  line `(iii) a delivery of goods on hire purchase or any system of payment by instalments;`
  line
  line `(iv) a transfer of the right to use any goods for any purpose (whether or not for a specified`
  line `period) for cash, deferred payment or other valuable consideration;`
  line
  line `(v) a supply of goods by any unincorporated association or body of persons to a member thereof`
  line `for cash, deferred payment or other valuable consideration;`
  line
  line `(vi) a supply, by way of or as part of any service or in any other manner whatsoever, of goods,`
  line `being food or any other article for human consumption or any drink (whether or not intoxicating)`
  line `where such supply or service is for cash, deferred payment or other valuable consideration,`
  line
  line `and such transfer, delivery or supply of any goods shall be deemed to be a sale of those goods by the person`
  line `making the transfer, delivery or supply and purchase of those goods by the person to whom such transfer,`
  line `delivery or supply is made;`
  line
  line `(zd) "sale price" means the amount payable to a dealer as valuable consideration for the sale or`
  line `supply of any goods and includes--`
  line
  line `(i) any amount charged for anything done by the vendor in respect of the goods at the time of,`
  line `or before, the delivery thereof;`
  line
  line `(ii) transport costs or freight, if any;`
  line
  line `(iii) trade commission, if any, by whatever name called;`
  line
  line `(iv) clearing, forwarding and handling charges, if any;`
  line `(v) insurance charges, if any;`
  line
  line `(vi) taxes or duties levied under any law for the time being in force (other than tax paid or`
  line `payable under this Act) by whatever name called, if any;`
  line
  line `(vii) cost of packing, if any; and`
  line
  line `(viii) the amount received or receivable by the seller by way of non-refundable deposit, whether`
  line `by way of a separate agreement or not, in connection with or incidental to or ancillary to, the said`
  line `sale of goods;`
  line
  line `Explanation I.-- Where goods are sold on hire purchase or any system of payment by instalments,`
  line `the sale price of such goods shall be inclusive of insurance charges, interest and hire charges and such`
  line `other charges related to hire purchase or any system of payment by instalments.`
  line
  line `Explanation II.-- Where goods are sold by way of transfer of right to use such goods, the sale price`
  line `thereof shall be the amount of valuable consideration received or receivable by the transferor for such`
  line transfer;
  line
  line `(ze) "tax" means the tax leviable and payable under this Act;`
  line
  line `(zf) "taxable goods" means all goods in respect of which tax is payable under section 14;`
  line
  line `(zg) "Tribunal" means the Tribunal constituted under sub-section (1) of section 9;`
  line
  line `(zh) "works contract" means any agreement for carrying out for cash or deferred payment or other`
  line `valuable consideration, the construction, fitting out, improvement or repair of any building, road, bridge`
  line `or other immovable or movable property;`
  line
  line `(zi) "year" means the financial year.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (67136)
  sectionNo (3)
  orderNo 3
  title `Charge of tax.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67136&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_3_content:
  string
  line `(1) Every dealer who is registered under the Bihar Finance Act, 1981 (Bihar Act 5`
  line `of 1981), as it stood before its repeal by section 94, shall be liable, on or after the commencement of this`
  line `Act, to pay tax under this Act on sale or purchase, made by him.`
  line
  line `(2) Every dealer, to whom sub-section (1) does not apply, shall be liable to pay tax on sale or purchase,`
  line `as the case may be, from the date on which his gross turnover, during a period not exceeding twelve months,`
  line `first exceeded five lakh rupees.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1) or sub-section (2) but subject to the other`
  line `provisions of this Act, every dealer,--`
  line
  line `(a) being an importer or a manufacturer; or`
  line
  line `(b) who is required to file a return under the Income-tax Act, 1961 (43 of 1961); or`
  line
  line `(c) who holds any licence under the Explosives Act, 1884 (4 of 1884), or the Bihar Excise Act,`
  line `1915 (Bihar and Orissa Act 2 of 1915), or the Drugs and Cosmetics Act, 1940 (23 of 1940), or the`
  line `Essential Commodities Act, 1955 (10 of 1955) or the Mines and Minerals (Development and`
  line `Regulation) Act, 1957 (67 of 1957); or`
  line
  line `(d) being a corporation, constituted under any law for the time being in force or a company`
  line `incorporated under the Companies Act, 1956 (1 of 1956), or, is registered under the Central Sales Tax`
  line `Act, 1956 (74 of 1956); or`
  line
  line `(e) whose place of business is located inside the market yard established under the Bihar`
  line `Agriculture Produce Market Act, 1960 (Bihar Act 16 of 1960); or`
  line
  line `(f) who fulfils the following two conditions, namely:--`
  line
  line `(i) uses a telephone in his place of business or has a mobile telephone; and`
  line
  line `(ii) the receipts or payments of whose business, either wholly or in part, are transacted through`
  line `any bank,`
  line
  line `shall be liable to pay tax on sale or purchase, as the case may be, with effect from the date of the first sale`
  line `of any taxable goods made by him.`
  line
  line `(4) Every dealer who has become liable to pay tax under sub-sections (1), (2) and (3) shall, subject to`
  line `the provisions of sub-section (5), cease to be so liable after the expiry of twelve consecutive months from`
  line `the date he either closes or discontinues his business or entirely transfers his business to another person.`
  line
  line `(5) A registered dealer shall, within a period of twelve consecutive months, pay tax on the stock of`
  line `goods remaining with him on the date with effect from which he closes or discontinues his business:`
  line
  line `Provided that the Commissioner may, after recording the reasons, extend the period of twelve`
  line `consecutive months if the goods are held in stock beyond the said period of twelve months because of`
  line `reasons beyond the control of the dealer.`
  line
  line `(6) Notwithstanding anything contained in sub-section (1) or sub-section (2) or sub-section (3), where`
  line `any person who, is, or was, less than six months earlier, a member of the partnership firm, concern or Hindu`
  line `undivided family, which is, or was, less than six months earlier, liable to pay tax, starts a new business,`
  line `either singly or jointly with other persons, or joins other business, partnership firm or concern, tax as`
  line `aforesaid, shall likewise be payable on sales and purchases made from such business, partnership firm or`
  line `concern, on and from the date the person starts or joins it, unless the liability in respect of such business,`
  line `partnership firm or concern has arisen from an earlier date under the said sub-sections.`
  line
  line `(7) The tax for each year or any part thereof, may, with the previous approval of the Commissioner, be`
  line `estimated and collected in advance, in the manner prescribed, during a year, in such instalments as may be`
  line `fixed by the prescribed authority.`
  line
  line `(8) For the purposes of sub-section (7), the prescribed authority may require the dealer to furnish an`
  line `advance estimate of his taxable turnover for that year or any part thereof and may provisionally determine`
  line `the amount of tax payable by the dealer in respect of the year or any part thereof and thereupon the dealer`
  line `shall pay the amount so determined by such date as may be fixed by such authority.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (67137)
  sectionNo (4)
  orderNo 4
  title `Levy of purchase tax.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67137&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_4_content:
  string
  line `Subject to the provisions of sections 6 and 7, every dealer liable to pay tax`
  line `under section 3, who purchases goods in circumstances in which no tax on sales is payable or has been paid`
  line `on the sale price of such goods and either consumes such goods in the manufacture of other goods for sale`
  line `or otherwise disposes of such goods in any manner other than by way of sale in the State or sale in the`
  line `course of inter-State trade or commerce, shall be liable to pay tax on the purchase price of such goods at`
  line `the same rate at which it would have been leviable on the sale price of such goods under section 14.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (67138)
  sectionNo (5)
  orderNo 5
  title `Liability to pay purchase tax on certain purchases.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67138&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_5_content:
  string
  line `Where a dealer purchases any taxable goods`
  line `from any person within the State of Bihar, and such person is not a registered dealer and the said goods are`
  line `used as capital assets anytime after such purchase, there shall be levied, a tax on the purchase price of such`
  line `purchases at the rate at which tax on sales is leviable on the said goods.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (67139)
  sectionNo (6)
  orderNo 6
  title `Non-levy of tax in certain cases.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67139&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_6_content:
  string
  line `(1) No tax shall be payable under this Act on sales or purchases`
  line `of goods which have taken place--`
  line
  line `(a) in the course of inter-State trade or commerce;`
  line
  line `(b) outside the State of Bihar;`
  line
  line `(c) in the course of import of goods into, or, export of goods out of, the territory of India.`
  line
  line `(2) The provisions of the Central Sales Tax Act, 1956 (74 of 1956) shall apply for determining when a`
  line `sale or purchase of goods shall be deemed to have taken place in any of the ways mentioned in clause (a)`
  line `or clause (b) or clause (c) of sub-section (1).`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (67140)
  sectionNo (7)
  orderNo 7
  title Exemptions.
  content `No tax shall be payable on sale or purchase of goods specified in Schedule I.`
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67140&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (67141)
  sectionNo (8)
  orderNo 8
  title `Burden of proof.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67141&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_8_content:
  string
  line `The burden of proving that any sale or purchase effected by a dealer is not liable`
  line `to tax under section 6 or section 7 or sub-section (2) of section 13, as the case may be, or that he is eligible`
  line `for an input tax credit under sections 16 and 17 shall be on the dealer`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (67142)
  sectionNo (9)
  orderNo 9
  title Tribunal.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67142&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_9_content:
  string
  line `(1) Subject to such rules, as may be prescribed, the State Government shall, by a`
  line `notification published in the Official Gazette, constitute a Tribunal to be called the Commercial Tax`
  line `Tribunal consisting of a Chairperson and two other Members to exercise all the powers and perform all the`
  line `functions conferred by or under this Act or any other law for the time being in force upon such a Tribunal:`
  line
  line `Provided that till the Tribunal is constituted under this Act, the Tribunal constituted under the Bihar`
  line `Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94, shall be deemed to be`
  line `the Commercial Tax Tribunal constituted under this Act and shall exercise all the powers and perform all`
  line `the functions conferred by or under this Act or any other law for the time being in force.`
  line
  line `(2) The Chairperson of the Tribunal shall be a retired High Court Judge, not exceeding sixty-five years`
  line `of age, or a judicial officer of the rank of a District Judge.`
  line
  line `(3) One of the other two Members shall be an officer of the Commercial Taxes Department of the State`
  line `Government not below the rank of Joint Commissioner and the third Member shall be a person--`
  line
  line `(a) who has, for at least ten years, been in the practice of accountancy as a chartered accountant`
  line `under the Chartered Accountants Act, 1949 (38 of 1949) or as a registered accountant under any law`
  line `formerly in force or partly as a registered accountant and partly as a chartered accountant; or`
  line
  line `(b) who is or has been an officer of the Indian Audit and Accounts Service not below the rank of`
  line `Deputy Accountant-General; or`
  line
  line `(c) who is a Government servant, whether serving or retired having experience of at least four years`
  line `in the administration of accounts or financial management in the State Government or public sector`
  line undertaking.
  line
  line `(4) (a) The State Government may, if it considers expedient to do so, set up by a notification, one or`
  line `more additional benches of the Tribunal at such places and having jurisdiction over such area as may be`
  line `specified in the notification.`
  line
  line `(b) It shall consist of such Member or Members, as may be specified in the notification, possessing`
  line `such qualifications as are specified in sub-sections (2) and (3):`
  line
  line `Provided that if a judicial officer is appointed to such an additional bench, he shall be an officer not`
  line `below the rank of an Additional District Judge.`
  line
  line `(5) Any vacancy in the membership of the Tribunal shall be filled up by the State Government as soon`
  line `as possible.`
  line
  line `(6) During the vacancy in the post of the Chairperson pending the appointment of a permanent`
  line `Chairperson, the Government may appoint one of the remaining members to act as the Chairperson.`
  line
  line `(7) Any person appointed as a member of the Tribunal shall ordinarily hold office for a period of three`
  line `years:`
  line
  line `Provided that in case a retired High Court Judge is appointed as the Chairperson or any other`
  line `Government servant is appointed as a Member, after his superannuation to the Tribunal, the terms and`
  line `conditions of service (including his pay and allowances) shall be such as may be prescribed.`
  line
  line `(8) (a) The functions of the Tribunal shall be exercised by a bench to be constituted by the Chairperson`
  line `consisting of one or two or three members.`
  line
  line `(b) The nature of cases to be disposed of by either of these benches shall be under the discretion of the`
  line `Chairperson:`
  line
  line `Provided that a bench consisting of only one Member or two Members may in its discretion refer a case`
  line `to a larger bench of two or three Members, as the case may be.`
  line
  line `(9) (a) Where an application is heard by all the three Members of the Tribunal and the Members are`
  line `divided in opinion on any point or points, such point or points shall be decided in accordance with the`
  line `opinion of the majority:`
  line
  line `Provided that if the post of any one of the Members is vacant such points shall be decided in accordance`
  line `with the opinion of the Chairperson.`
  line
  line `(b) Where an application is heard by a bench consisting of two Members, whether it consists of the`
  line `Chairperson or not, and the Members are divided in opinion on any point or points, such point or points`
  line `shall be referred to a bench consisting of all the three Members.`
  line
  line `(10) (a) The Members of the Tribunal shall be deemed to be public servants within the meaning of`
  line `section 21 of the Indian Penal Code (45 of 1860).`
  line
  line `(b) No Member shall accept any other paid employment outside the duties of his office during the term`
  line `of his membership of the Tribunal.`
  line
  line `(11) The Tribunal shall, with the previous sanction of the State Government, make regulations`
  line `consistent with the provisions of this Act and the rules made thereunder, for regulating its procedure and`
  line `other matters incidental to the disposal of its business and publish such regulations in the Official Gazette.`
  line
  line `(12) The Members of the Tribunal shall, ordinarily be appointed for a period of three years from the`
  line `date of their appointment:`
  line
  line `Provided that the period of appointment may be reduced or extended by the State Government.`
  line
  line `(13) The Chairperson or any other Member may, by notice in writing under his hand addressed to the`
  line `State Government, resign his office:`
  line
  line `Provided that the Chairperson or any other Member shall, unless he is permitted by the State`
  line `Government to relinquish his office sooner, continue to hold office until the expiry of three months from`
  line `the date of receipt of such notice or until a person duly appointed as his successor enters upon his office or`
  line `until the expiry of his term of office, whichever is the earliest.`
  line
  line `(14) The Chairperson or any other Member of the Tribunal shall not be removed from his office except`
  line `by an order by the State Government on the ground of proved misbehaviour or incapacity after an inquiry`
  line `made by a Judge of the High Court, in which the Chairperson or any other member concerned has been`
  line `informed of the charges against him and given a reasonable opportunity of being heard in respect of those`
  line charges.
  line
  line `(15) The State Government may, by rules, regulate the procedure for the investigation of misbehaviour`
  line `or incapacity of the Chairperson or any other Member.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (67143)
  sectionNo (10)
  orderNo 10
  title `Taxing Authorities and Inspectors.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67143&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_10_content:
  string
  line `(1) There shall be the following classes of authorities to be`
  line `appointed by the State Government, for carrying out the purposes of this Act, namely:--`
  line
  line `(a) Commissioner of Commercial Taxes;`
  line
  line `(b) Senior Joint Commissioner of Commercial Taxes;`
  line
  line `(c) Joint Commissioner of Commercial Taxes;`
  line
  line `(d) Deputy Commissioner of Commercial Taxes;`
  line
  line `(e) Assistant Commissioner of Commercial Taxes;`
  line
  line `(f) Commercial Taxes Officer;`
  line
  line `(g) Assistant Commercial Taxes Officer.`
  line
  line `(2) The authorities appointed under sub-section (1) shall, within such areas or in respect of such`
  line `transactions falling within an area as the State Government may, by notification specify, exercise such`
  line `powers as may be conferred and perform such duties as may be imposed, by or under this Act.`
  line
  line `(3) The Commissioner may appoint such number of Inspectors of Commercial Taxes as may be`
  line `necessary to assist any of the authorities appointed under sub-section (1) and the Inspectors so appointed`
  line `shall, within such areas exercise powers under sub-sections (1) and (2) of section 56 and perform such other`
  line `functions in the execution of this Act in those areas as may be prescribed or as the Commissioner may, by`
  line `general or special order, assign to them and such assignment may be subject to such conditions and`
  line `restrictions as may be specified in the order.`
  line
  line `(4) All persons appointed under sub-section (1) or sub-section (3) shall be deemed to be public servants`
  line `within the meaning of section 21 of the Indian Penal Code, 1860 (45 of 1860).`
  line
  line `(5) The Commissioner may, at any stage, direct transfer of a proceeding under section 27 or section 28`
  line `or section 31 or section 32 or section 33 or section 72 in respect of any dealer from the prescribed authority`
  line `to another of the same or higher rank appointed under sub-section (1) and where such direction is given by`
  line `the Commissioner the authority to whom the proceeding is transferred shall proceed to dispose it of as if it`
  line `had been initiated by the said authority, irrespective of the local limits of its jurisdiction; such transfer shall`
  line `not render necessary the re-issue of any notice already issued before the transfer and the authority to whom`
  line `the proceeding is transferred may, in its discretion, continue it from the stage at which it was left by the`
  line `authority from whom it was transferred.`
  line
  line `(6) For smooth functioning of the office, it shall be lawful for the Deputy Commissioner or the Assistant`
  line `Commissioner in-charge of a circle to allot work and proceedings amongst the officers posted in the circle,`
  line `as the case may be, and it may include transfer of a proceeding from one officer to another posted in the`
  line `same office and exercising concurrent jurisdiction.`
  line
  line `(7) The Commissioner may, from time to time, issue such orders, instructions and directions as he may`
  line `deem fit, to the authorities subordinate to him, for carrying out the purposes of this Act, and such authorities`
  line `shall observe and follow such orders, instructions and directions of the Commissioner:`
  line
  line `Provided that no such orders, instructions and directions shall be issued--`
  line
  line `(i) so as to require any authority to pass a particular order or to dispose of a particular case in a`
  line `particular manner; or`
  line
  line `(ii) so as to interfere with the discretion of the Appellate authorities in a particular case:`
  line
  line `Provided further that if the Commissioner is of the opinion that it is necessary in the public interest`
  line `so to do, he may cause such orders, instructions and directions to be published and circulated for general`
  line information.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (67144)
  sectionNo (11)
  orderNo 11
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67144&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_11_content:
  string
  line `No suit, prosecution or other legal proceeding shall lie`
  line `against any servant of the Government or any officer or authority appointed under section 10 or section 86`
  line `of this Act for anything which is in good faith done or intended to be done in pursuance or rules made`
  line thereunder.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (67145)
  sectionNo (12)
  orderNo 12
  title `Power to issue summons and examine on oath.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67145&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_12_content:
  string
  line `(1) The Tribunal constituted under section 9, or`
  line `the Commissioner or any officer or authority appointed under section 10 or section 86 shall, for carrying`
  line `out the purposes of this Act, have all the powers of a Civil Court under the Code of Civil Procedure, 1908`
  line `(5 of 1908) and in particular in respect of the following matters, namely:--`
  line
  line `(a) to summon and enforce attendance of any person, including any officer of a banking company,`
  line `and examine him on oath or affirmation;`
  line
  line `(b) to compel the production of documents or accounts and to impound and retain them;`
  line
  line `(c) to issue commissions for the examination of witness.`
  line
  line `(2) Every proceeding under this Act before the Tribunal, shall be deemed to be a judicial proceeding`
  line `within the meaning of section 193 and section 228 of the Indian Penal Code, 1860 (45 of 1860).`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (67146)
  sectionNo (13)
  orderNo 13
  title `Point or points in series of sales at which sales tax shall be levied.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67146&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_13_content:
  string
  line `(1) (a) Subject to the`
  line `provisions of sections 16 and 17, tax on sale of goods (other than goods specified in Schedule IV) shall be`
  line `levied at each point in a series of sales in the State of Bihar by a dealer liable to pay tax under this Act.`
  line
  line `(b) Where the tax is levied at each point of sale, the tax payable by a dealer at any point shall be the`
  line `amount arrived at after deducting, the input tax credit specified under section 16 or section 17, from the tax`
  line `computed at that point of sale.`
  line
  line `(2) (a) The tax on sales, in respect of goods specified in Schedule IV, shall be levied at the first point of`
  line `their sale in the State of Bihar by a dealer and subsequent sales of the same goods in the State of Bihar shall`
  line `not be levied to tax, if the dealer making the subsequent sale produces before the prescribed authority the`
  line `original copy of the cash memo, or invoice or bill issued to him and files a true and complete declaration`
  line `in the form and in the manner prescribed.`
  line
  line `(b) The declaration referred to in clause (a) shall be issued by the selling dealer to the purchasing dealer`
  line `not later than the 30th day of September of the year following the year to which such sales relate.`
  line
  line `(3) If upon information, the prescribed authority has reasons to believe that the selling dealer has,`
  line `without reasonable cause, failed to issue to the purchasing dealer the declaration referred to in sub-section`
  line `(2), he shall, after giving the selling dealer a reasonable opportunity of being heard, direct that the selling`
  line `dealer shall pay, by way of penalty, a sum of rupees five thousand per month for every month of default or`
  line `the amount of tax involved, whichever is less.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (67147)
  sectionNo (14)
  orderNo 14
  title `Rate of tax.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67147&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_14_content:
  string
  line `(1) Tax shall be payable on the sale price of --`
  line
  line `(a) the goods specified in the Schedule II, at the rate of one per cent.;`
  line
  line `(b) the goods specified in the Schedule III, at the rate of four per cent.`
  line
  line `(c) the goods specified in the Schedule IV, at the rate not exceeding fifty per cent. but not less than`
  line `twenty per cent., as the State Government may, subject to such conditions and restrictions, by`
  line `notification, specify;`
  line
  line `(d) any other goods, not specified in the Schedules I, II, III and IV, at the rate of twelve and a-half`
  line `per cent.`
  line
  line `(2) The State Government may, by notification, alter any Schedule to this Act.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (67148)
  sectionNo (15)
  orderNo 15
  title `Compounding of tax liability in certain cases.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67148&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_15_content:
  string
  line `(1) Notwithstanding anything to the contrary`
  line `contained in the Act, the State Government may, by notification and subject to such conditions and`
  line `restrictions as may be prescribed, permit any class of registered dealers, whose gross turnover does not`
  line `exceed the limit specified in the notification to pay, in lieu of the tax payable by him, an amount calculated`
  line `at such rate, not exceeding four per cent. of his taxable turnover, as may be specified in the notification:`
  line
  line `Provided that no such permission shall be granted to a manufacturer or a person who imports any goods`
  line `from any place outside the State of Bihar for the purpose of his business:`
  line
  line `Provided further that the amount so specified shall be in addition to any tax that may be payable by the`
  line `dealer under section 4.`
  line
  line `(2) The dealers to whom the provisions of sub-section (1) apply shall--`
  line
  line `(a) not charge any tax on the sale of goods specified in Schedule I;`
  line
  line `(b) not charge tax in excess of the rate specified in the notification issued under sub-section (1);`
  line and
  line
  line `(c) not be entitled to issue tax invoices in respect of sales made by them.`
  line
  line `(3) If the Assessing Authority has reasons to believe that the dealer was not eligible to pay tax at a rate`
  line `specified under sub-section (1), the Assessing Authority shall, without prejudice to any action which is or`
  line `may be taken under section 81, impose a penalty equivalent to three times of the amount of tax arrived at`
  line `after applying the rate, specified under section 14, to the gross turnover of the dealer after deducting the`
  line `value of sales under section 6:`
  line
  line `Provided that no order under this sub-section shall be passed without giving the dealer a reasonable`
  line `opportunity of being heard.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (67149)
  sectionNo (16)
  orderNo 16
  title `Input tax credit.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67149&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_16_content:
  string
  line `(1) Subject to the provisions of this Act, an input tax credit as provided in this`
  line `section shall be claimed by a registered dealer, subject to such conditions and restrictions as may be`
  line `prescribed, on sales of goods in the following circumstances, namely:--`
  line
  line `(a) when a registered dealer purchases any input within the State of Bihar from another registered`
  line `dealer after paying him the tax as specified under section 14, he shall claim credit of the input tax in`
  line `the manner prescribed, if the goods are sold within the State or in the course of inter-State trade and`
  line commerce;
  line
  line `(b) when a registered dealer--`
  line
  line `(i) purchases any input within the State from another registered dealer after paying him the tax`
  line `under section 14, or`
  line
  line `(ii) purchases any input and pays tax on such purchase under section 4 of the Act,`
  line
  line `and consumes such goods in the manufacture of any goods mentioned in clause (a), (b) and (d) of`
  line `section 14, he shall claim credit of the said input tax in the manner prescribed, if the goods so`
  line `manufactured are sold within the State of Bihar or in the course of inter-State trade and commerce;`
  line
  line `(c) when a registered dealer purchases any capital goods within the State from another registered`
  line `dealer after paying him the tax as specified under section 14, and uses such goods in the manufacture`
  line `of any goods mentioned in clauses (a), (b) and (d) of section 14 and sells the manufactured goods within`
  line `the State of Bihar or in the course of inter-State trade or commerce, or otherwise, he shall claim and be`
  line `allowed, in such manner as may be prescribed, credit of the amount of input tax;`
  line
  line `(d) when a registered dealer holds in stock, on the 1st day of April, 2005, such goods as have been`
  line `purchased by him on or after the 1st day of April, 2004 and which have suffered the incidence of tax`
  line `under the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94`
  line and--
  line
  line `(i) he sells such goods within the State of Bihar or in the course of inter-State trade and`
  line `commerce, or`
  line
  line `(ii) he consumes such goods in the manufacture of any goods mentioned in clauses (a), (b) and`
  line `(d) of section 14 and the goods so manufactured are sold within the State of Bihar or in the course`
  line `of inter-State trade and commerce,`
  line
  line `he shall claim credit of the input tax in the manner prescribed;`
  line
  line `(e) when a registered dealer purchases any input within the State of Bihar from another such dealer`
  line `after paying him the tax as specified under section 14 at a rate higher than four per cent. and transfers`
  line `such goods or goods manufactured from such goods to another dealer outside the State of Bihar, he`
  line `shall be allowed credit of such tax in excess of four per cent. in the manner as may be prescribed:`
  line
  line `Provided that if the claim for input tax credit under clause (a) or clause (b) or clause (c) or clause`
  line `(d) or clause (e) for any month exceeds the output tax for the same month, such excess shall be carried`
  line `forward for adjustment against the output tax of subsequent months, not being a month later than two`
  line `years after the close of the year during which such excess had arisen and the amount of input tax`
  line `remaining unadjusted after two years after the close of the year during which such excess had arisen`
  line `shall be refunded to the dealer subject to the provisions of sections 68, 69 and 71 of this Act:`
  line
  line `Provided further that input tax credit in respect of capital goods shall be allowed in the manner and`
  line `over such period, not exceeding thirty-six months from the date of their acquisition, as may be`
  line `prescribed:`
  line
  line `Provided also that no credit of input tax shall be allowed in respect of capital assets purchased or`
  line `acquired before the commencement of this Act.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where a registered dealer purchases any`
  line `input in the circumstances mentioned in clause (a) or clause (b) or clause (c) or clause (d) of the said`
  line `sub-section and,--`
  line
  line `(a) he despatches such goods or the goods manufactured by consuming such goods, to a`
  line `commission agent registered under this Act or transfers such goods to its branch or head office within`
  line `the State of Bihar for sale, as the case may be; or`
  line
  line `(b) he supplies such goods in the course of execution of a works contract to another registered`
  line `dealer to whom he has let out a sub-contract, for use in the execution thereof,`
  line `the input tax credit on the sale or supply, as the case may be, of such goods shall be claimed by the registered`
  line `dealer selling the goods on commission or using the goods supplied in the execution of`
  line `sub-contract, as the case may be, in accordance with the provisions of sub-section (1), in such manner as`
  line `may be prescribed.`
  line
  line `(3) No input tax credit under sub-section (1) shall be claimed or be allowed to a registered dealer--`
  line
  line `(a) in respect of goods specified in Schedule IV or such other goods as may be prescribed; or`
  line
  line `(b) in respect of inputs purchased by him from another registered dealer or manufactured by him`
  line `and the right wherein to use is transferred to another dealer; or`
  line
  line `(c) in respect of inputs purchased from a registered dealer permitted to pay tax under the provisions`
  line `of section 15; or`
  line
  line `(d) in respect of inputs consumed for the manufacture of goods specified in Schedule I; or`
  line
  line `(e) in respect of goods used for self consumption or as gift.`
  line
  line `(4) In case the inputs or goods are used partially for the purpose specified in sub- section (3), the claim`
  line `for input tax credit shall stand reduced to the extent they are so used.`
  line
  line `(5) (a) No dealer shall claim an input tax credit in respect of inputs purchased unless he is in possession`
  line `of an original copy of the tax invoice, signed and issued by the selling registered dealer, containing the`
  line `prescribed particulars of sale.`
  line
  line `(b) If the original tax invoice is lost, input tax credit shall be allowed only on the basis of a duplicate`
  line `copy of the original tax invoice in the form and manner prescribed.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (67150)
  sectionNo (17)
  orderNo 17
  title `Exports to be zero-rated.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67150&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_17_content:
  string
  line `(1) In the case of a sale in the course of export under section 5 of the`
  line `Central Sales Tax Act, 1956 (74 of 1956); or sale of any input made to any dealer in a special economic`
  line `zone outside the customs territory of India; or sale (including sale outside India and Domestic Tariff Area)`
  line `by an export oriented unit, there shall be no tax payable on the turnover of such sale and the person exporting`
  line `the goods or selling them shall be entitled, in the manner prescribed, to a credit of input tax paid--`
  line
  line `(a) on the purchase of the goods sold in the course of export (excluding sale to Domestic Tariff`
  line `Area) or purchase of goods sold to any dealer in the special economic zone or sale (including sale`
  line `outside India and Domestic Tariff Area) by an export oriented unit, or`
  line
  line `(b) on the purchase of inputs and capital assets which have been used for the manufacture of goods`
  line `sold in the course of export (excluding sale to Domestic Tariff Area) or to any dealer in the special`
  line `economic zone:`
  line
  line `Provided that the input tax credit on account of capital assets shall be allowed only to the extent`
  line `and in the manner prescribed.`
  line
  line `(2) The organisations specified in the Schedule V to this Act shall be entitled to claim a refund of tax`
  line `paid on goods purchased in the State of Bihar, subject to such restrictions and conditions as may be`
  line `prescribed and such organisation shall be entitled to a refund of the same only on an application made to`
  line `the prescribed authority within such time and in such manner as may be prescribed.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (67151)
  sectionNo (18)
  orderNo 18
  title `Rate of tax on packing materials and containers.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67151&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_18_content:
  string
  line `Notwithstanding anything contained in section`
  line `14, where any goods packed in any container or packing material are sold or purchased, the container or`
  line `packing material in which such goods are so packed shall be deemed to have been sold or purchased along`
  line `with such goods and the tax under sections 3, 4 and 5 shall be levied on the sale or purchase of such container`
  line `or packing material (whether such packing materials or containers are separately charged for or not) at the`
  line `rate of tax applicable to the sale or the purchase, as the case may be, of such goods:`
  line
  line `Provided that where the price of the goods is less than the container or packing material in which they`
  line `are packed, the rate of tax specified in respect of such containers under sub-section (1) of section 14 shall`
  line apply.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (67152)
  sectionNo (19)
  orderNo 19
  title Registration.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67152&sectionno=19&orderno=19&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_19_content:
  string
  line `(1) No person liable to pay tax under section 3 or section 4, as the case may be, of`
  line `this Act shall sell or purchase goods unless he has obtained and is in possession of a valid certificate of`
  line `registration:`
  line
  line `Provided that any dealer not liable to pay tax under this Act may also apply for grant of a certificate of`
  line registration.
  line
  line `(2) Every person, referred to in sub-section (1), shall apply for the grant of certificate of registration to`
  line `the prescribed authority in the prescribed manner and the prescribed authority, shall, after verifying that the`
  line `application has been duly filled in, grant certificate of registration in the manner as may be prescribed:`
  line
  line `Provided that dealers registered under the Bihar Finance Act, 1981(Bihar Act 5 of 1981), as it stood`
  line `before its repeal by section 94, shall be deemed to be dealers registered under this Act and such dealers`
  line `shall be granted, a certificate of registration within such time and in the manner as may be prescribed and`
  line `such dealers may sell or purchase goods till such time as the certificate of registration is granted to them:`
  line
  line `Provided further that a dealer, who exclusively sells or purchases, goods mentioned in Schedule I, shall`
  line `not be liable for registration.`
  line
  line `(3) Every dealer registered under sub-section (1) of section 7 of the Central Sales Tax Act, 1956 (74 of`
  line `1956), shall apply for and obtain a certificate of registration, notwithstanding whether such dealer is not`
  line `liable to pay tax under this Act.`
  line
  line `(4) Where the prescribed authority, at any time after the grant of the certificate of registration, is`
  line `satisfied upon an inquiry, that the particulars mentioned in the application are incorrect or the applicant has`
  line `suppressed or misrepresented certain material facts, he shall, after giving the applicant an opportunity of`
  line `being heard, and after recording reasons therefor, cancel the certificate of registration granted to him.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (67153)
  sectionNo (20)
  orderNo 20
  title `Amendment and cancellation of certificate of registration.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67153&sectionno=20&orderno=20&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_20_content:
  string
  line `(1) The prescribed authority may,`
  line `after considering such information as may be furnished by the dealer under section 23 or as may be`
  line `otherwise received by the said authority, amend the certificate of registration of the dealer in respect of`
  line `whom the information has been furnished or received.`
  line
  line `(2) When--`
  line
  line `(a) any registered dealer discontinues or entirely transfers his business to other persons; or`
  line
  line `(b) the liability of a registered dealer to pay tax under this Act has ceased,`
  line `the dealer shall, forthwith, surrender his certificate of registration in the manner prescribed to the prescribed`
  line `authority and the said authority shall cancel the certificate of registration in the manner prescribed:`
  line
  line `Provided that, in a case covered by clause (a), the certificate of registration shall be deemed to be`
  line `inoperative with effect from the date of discontinuance or transfer of the business and, in a case covered by`
  line `clause (b), with effect from the date on which the dealer's liability to pay tax has ceased.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (67154)
  sectionNo (21)
  orderNo 21
  title Security.
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67154&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_21_content:
  string
  line `Where it appears necessary to the prescribed authority to do so for the proper realisation`
  line `of the tax payable under this Act, he may, by an order in writing and for reasons to be recorded therein,`
  line `direct a dealer to furnish such security and in such manner as may be prescribed.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (67155)
  sectionNo (22)
  orderNo 22
  title `Declared manager.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67155&sectionno=22&orderno=22&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_22_content:
  string
  line `(1) Every dealer, who is liable to pay tax under this Act, and who is a Hindu`
  line `undivided family, a firm, company or corporation or a society or club or association or who is engaged in`
  line `business as a guardian or a trustee or otherwise on behalf of another person, shall furnish to the prescribed`
  line `authority in the prescribed manner a declaration stating the name and prescribed particulars of the person`
  line `or persons who shall be deemed to be the manager or managers of such dealer's business for the purposes`
  line `of this Act.`
  line
  line `(2) Every dealer shall specifically authorise his manager or officer or any other person to receive any`
  line `form of declaration, make any statement, furnish any return, statement, accounts, produce documents or`
  line `other evidence and any statement made, return or statement furnished, accounts, registers or documents`
  line `produced or evidence given by the manager or any person authorised by him or by the dealer in this behalf,`
  line `in the course of any proceeding under this Act, shall be binding on the dealer.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (67156)
  sectionNo (23)
  orderNo 23
  title `Furnishing of information by dealers.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67156&sectionno=23&orderno=23&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_23_content:
  string
  line `If any person or dealer liable to pay tax under this Act--`
  line
  line `(a) transfers or otherwise disposes of his business or any part thereof, whether by way of sale or`
  line `otherwise, or`
  line
  line `(b) acquires any business or part of any business, whether by way of purchase or otherwise, or`
  line
  line `(c) effects any other change in the ownership or constitution of the business, or`
  line
  line `(d) discontinues his business, or shifts his place of business, or`
  line
  line `(e) changes the name, style or nature of his business or effects any change in the class or description`
  line `of goods dealt in by him, or`
  line
  line `(f) starts a new business or joins another business either singly or jointly with other person or`
  line `persons, or`
  line
  line `(g) effects any change in the particulars furnished in an application under section 19 or declaration`
  line `furnished under section 22, or`
  line
  line `(h) applies for or has an application made against him for insolvency or liquidation under any law`
  line `for the time being in force, or`
  line
  line `(i) makes a reference or has a reference made under the Sick Industrial Companies (Special`
  line `Provisions) Act, 1985 (1 of 1986),`
  line
  line `he shall, within seven days of the occurring of any of the events aforesaid, inform the prescribed authority`
  line `accordingly, and, if any such dealer dies without doing so, his executor, administrator, successor-in-interest`
  line `or legal representative, as the case may be, shall, within fifteen days of the dealer's death, inform the said`
  line `authority accordingly.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (67157)
  sectionNo (24)
  orderNo 24
  title `Returns, payment of tax, interest and penalty.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67157&sectionno=24&orderno=24&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_24_content:
  string
  line `(1) Every person, being--`
  line
  line `(a) a dealer, who is not registered under this Act, by a notice served in the manner prescribed by`
  line `the prescribed authority;`
  line
  line `(b) a registered dealer (other than a dealer permitted under section 15 to pay tax at a fixed rate in`
  line `lieu of the tax payable by him),`
  line
  line `shall furnish a true and complete return in respect of all his transactions relating to sales, purchases, receipts`
  line `and despatches of goods and any other transactions prescribed specifically for each month, on or before the`
  line `end of the next following month to the prescribed authority in such form and in such manner as may be`
  line prescribed.
  line
  line `(2) Without prejudice to the provisions contained in sub-section (1), every person, being --`
  line
  line `(a) a dealer, who is not registered under this Act, by a notice served in the manner prescribed by`
  line `the prescribed authority;`
  line
  line `(b) a registered dealer (other than a dealer permitted under section 15 to pay tax at a fixed rate in`
  line `lieu of the tax payable by him),`
  line
  line `shall furnish a true and complete statement in respect of all his transactions relating to sales and purchases`
  line `of goods and any such details as may be prescribed for each completed quarter on or before the end of the`
  line `month following the end of the quarter to the prescribed authority in such form and in such manner as may`
  line `be prescribed.`
  line
  line `(3) Every registered dealer shall furnish to the prescribed authority, on or before the due date, a true`
  line `and complete return in respect of every financial year in the form and manner prescribed.`
  line
  line `Explanation.--In this sub-section, "due date" means--`
  line
  line `(a) where the dealer is a company within the meaning of the Companies Act, 1956 (1 of 1956), the`
  line `30th day of November of the year following the year to which such return relates;`
  line
  line `(b) where the dealer is a person, other than a company,--`
  line
  line `(i) in a case where the accounts of the dealer are required under this Act or any other law to be`
  line `audited or where the report of an accountant is required to be furnished under section 54, the 31st`
  line `day of October of the year following the year to which such return relates;`
  line
  line `(ii) in any other case, the 31st day of July of the year following the year to which such return`
  line relates.
  line
  line `(4) Every dealer who has been permitted to pay tax under section 15 shall file a quarterly abstract`
  line `statement for each completed quarter on or before the end of the month following the end of the quarter to`
  line `the prescribed authority in such form and in such manner as may be prescribed.`
  line
  line `(5) If the due date prescribed for the filing of quarterly statement or monthly return or quarterly abstract`
  line `statement or annual return happens to be a holiday, the next date on which the office opens shall be deemed`
  line `to be the due date.`
  line
  line `(6) Notwithstanding anything contained in sub-section (1) or sub-section (2), the prescribed authority`
  line `may, for specific reasons to be recorded in writing, extend the date of filing such return or quarterly`
  line `statement, as the case may be, subject to the condition that such an extension may be allowed only once`
  line `and for a period not exceeding thirty days from the due date; but the Commissioner may allow extension`
  line `beyond thirty days for reasons to be recorded in writing subject to the condition that such an extension may`
  line `be allowed only once and that also for a period not exceeding three months.`
  line
  line `(7) If a dealer, having furnished a monthly return under sub-section (1) or the quarterly statement under`
  line `sub-section (2), discovers any omission or wrong statement therein, he may furnish a revised return or`
  line `statement, as the case may be, in the form and manner prescribed to the prescribed authority at any time`
  line `before the due date within the meaning of sub-section (3):`
  line
  line `Provided that no such return or statement shall be taken into consideration if, upon information or`
  line `otherwise and for reasons to be recorded in writing, the prescribed authority is satisfied that the return or`
  line `statement originally furnished was deliberately false or that it was furnished with intent to defraud the State`
  line `Government of its revenue.`
  line
  line `(8) If a dealer fails to furnish the return within the time specified under sub-section (1) or the quarterly`
  line `statement under sub-section (2) or the quarterly abstract statement under sub-section (4), the prescribed`
  line `authority shall, after giving such a dealer an opportunity of being heard in the manner prescribed, impose a`
  line `penalty at the rate of twenty-five rupees for every day of such failure.`
  line
  line `(9) (a) Every dealer liable to furnish the return under sub-section (1) shall also deposit the tax payable,`
  line `according to the return on or before the fifteenth day of the following month in such manner as may be`
  line `prescribed and shall enclose the proof of payment in the form and manner prescribed along with the return.`
  line
  line `(b) Every dealer permitted to pay tax under section 15 shall also deposit the tax, arrived at after applying`
  line `the rate specified in the notification issued under section 15 to his quarterly turnover, on or before the`
  line `fifteenth day of the month following the quarter to which it relates and shall enclose the proof of payment`
  line `in the form and manner prescribed along with the statement required to be furnished under sub-section (4).`
  line
  line `(c) Subject to the provisions of sub-section (10), if any registered dealer submits a revised return under`
  line `sub-section (7) and if the amount of tax due from such dealer according to the revised return is higher than`
  line `the amount which was due according to the original return, such revised return shall be accompanied by a`
  line `receipt showing the payment of extra amount of tax in the manner provided in clause (a).`
  line
  line `(10) If a dealer, required to furnish the return under sub-section (1) or statement under sub-section (4),`
  line `fails to pay the amount of tax payable according to the provisions of sub-section (9), such dealer shall be`
  line `liable to pay interest--`
  line
  line `(a) in respect of tax payable under sub-section (9), by him in accordance with the return or the`
  line `quarterly abstract statement or revised return, as the case may be; or`
  line
  line `(b) in respect of the tax payable for the period for which he has failed to furnish returns under subsection (1) or quarterly abstract statement under sub-section (4),`
  line `at the rate of one and a-half per cent. per month of the amount due from the date the tax so payable had`
  line `become due to the date of its payment.`
  line
  line `Explanation.For the purposes of this sub-section--`
  line
  line `(i) where the period of default in payment of tax covers a period less than a month, the interest`
  line `payable on such tax in respect of such period shall be computed proportionately;`
  line
  line `(ii) "month" shall mean thirty days.`
  line
  line `(11) Any interest levied or penalty imposed under this section shall be without prejudice to any action,`
  line `which is or may be taken under section 81.`
  line
  line `(12) A rebate at the rate of half per cent. of the amount of tax admitted to be due in the return furnished`
  line `under sub-section (1), subject to a maximum of fifty thousand rupees in a year, shall be allowed to a`
  line `registered dealer who has furnished the return within the due dates specified under this section and has paid`
  line `such amount in full on or before the date specified for payment of tax under this section.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (67158)
  sectionNo (25)
  orderNo 25
  title `Scrutiny of returns.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67158&sectionno=25&orderno=25&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_25_content:
  string
  line `(1) The prescribed authority shall, within the time and in the manner`
  line `prescribed, scrutinize every return filed under sub-sections (1) and (3) of section 24 for the purpose of`
  line `ascertaining that--`
  line
  line `(a) all calculations contained therein are arithmetically accurate;`
  line
  line `(b) the output tax, the input tax, the tax payable and interest payable, if any, have been computed`
  line `correctly and properly;`
  line
  line `(c) the rates of tax have been applied correctly; and`
  line
  line `(d) evidence, as prescribed, has been furnished with regard to payment of tax and interest payable,`
  line `if any.`
  line
  line `(2) If, upon scrutiny under sub-section (1), the prescribed authority discovers any error, he shall serve`
  line `a notice in the prescribed form on the concerned dealer directing him to--`
  line
  line `(a) pay, within thirty days, the extra amount of tax along with the interest, if any, payable and`
  line `furnish the challan evidencing such payment; or`
  line
  line `(b) explain, within thirty days, that the return or returns filed by him do not suffer from any error`
  line `and all requirements specified in clauses (a) to (d) of sub-section (1) have been complied with.`
  line
  line `(3) (a) The prescribed authority shall, in a case falling under clause (b) of sub-section (2) and after`
  line `giving the dealer a reasonable opportunity to adduce necessary evidence, pass such order in the matter as it`
  line `may deem fit.`
  line
  line `(b) If, pursuant to an order under clause (a), any tax or interest is found to be payable by a dealer, a`
  line `notice in the form and manner prescribed, shall be served upon the dealer requiring him to pay the tax and`
  line `interest within the time as may be prescribed.`
  line
  line `(c) Any tax or interest payable under clause (b) shall be deemed to be an arrear of tax within the meaning`
  line `of section 39.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (67159)
  sectionNo (26)
  orderNo 26
  title `Self-Assessment of tax.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67159&sectionno=26&orderno=26&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_26_content:
  string
  line `(1) Subject to the provisions of section 25, the tax due in respect of a`
  line `financial year from every registered dealer, who has furnished the return and statement mentioned in section`
  line `24, shall be deemed to have been assessed.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the Commissioner may, in the interest of`
  line `revenue, select any registered dealer for detailed audit of his business, on the basis of a selection model as`
  line `may be prepared for such purpose, incorporating therein such criteria as may be deemed fit by the`
  line Commissioner.
  line
  line `(3) The audit of the business of a dealer selected under sub-section (2) shall be conducted, within a`
  line `period of twenty-four months from the due date within the meaning of sub-section (3) of section 24, in such`
  line `manner as may be prescribed.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (67160)
  sectionNo (27)
  orderNo 27
  title `Assessment of dealer not filing returns.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67160&sectionno=27&orderno=27&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_27_content:
  string
  line `(1) If a registered dealer fails to furnish before the due`
  line `date specified under sub-section (3) of section 24--`
  line
  line `(a) the returns specified under sub-section (1) or sub-section (3) of section 24; or`
  line
  line `(b) the quarterly abstract statement under sub-section (4) of section 24; or`
  line
  line `(c) the statement under sub-section (2) of section 24,`
  line `the prescribed authority shall, after giving the dealer a reasonable opportunity of being heard, assess to the`
  line `best of its judgment, the amount of tax due from the dealer and interest, if any--`
  line
  line `(2) Any assessment made or interest levied under this section shall be without prejudice to any action,`
  line `which is, or may be, taken under section 81.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (67161)
  sectionNo (28)
  orderNo 28
  title `Assessment of tax of dealers evading registration.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67161&sectionno=28&orderno=28&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_28_content:
  string
  line `(1) If upon information which has come into`
  line `his possession, the prescribed authority is satisfied that reasonable grounds exist to believe that any dealer`
  line `has been liable to pay tax under this Act in respect of any period, and has nevertheless wilfully failed to`
  line `apply for grant of certificate of registration, or, having so applied, failed to furnish any particulars or`
  line `information required for the purposes of section 19, the prescribed authority shall, after giving the dealer a`
  line `reasonable opportunity of being heard, assess, to the best of its judgment, the amount of tax due, if any,`
  line `from the dealer in respect of such period and all subsequent periods; and the prescribed authority may,`
  line `direct that the dealer shall pay, by way of penalty, in addition to the amount of tax so assessed, a sum of`
  line `one hundred rupees for every day of the period during which the dealer failed to apply for registration or`
  line `failed to furnish any particulars or information required for the purposes of section 19 or an amount equal`
  line `to the amount of tax assessed, whichever is higher:`
  line
  line `Provided that no proceeding for such assessment shall be initiated except before the expiry of two years`
  line `from the expiry of the period to which it relates:`
  line
  line `Provided further that a proceeding initiated under this sub-section shall be completed within a period`
  line `of four years from the date of initiation.`
  line
  line `(2) Any assessment made, interest levied or penalty imposed under this section shall be without`
  line `prejudice to any action which is, or may be, taken under section 81.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (67162)
  sectionNo (29)
  orderNo 29
  title `Assessment of tax on disputed question.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67162&sectionno=29&orderno=29&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_29_content:
  string
  line `Notwithstanding anything contained in any other`
  line `provision of this Act, where the assessment involves a decision on a point which is concluded against any`
  line `of the authorities specified in sub-section (1) of section 10 by a judgment of the Tribunal and an appeal has`
  line `been filed under section 79, then unless otherwise directed by the High Court, the prescribed authority may`
  line `complete the assessment as if the point was not so decided against such authority, but shall stay the recovery`
  line `of such of the dues including tax, penalty, interest or amount forfeited, if any, in so far as they relate to such`
  line `point, until the decision by the High Court and after such decision, may modify the assessment order, if`
  line `found necessary, after giving the dealer a reasonable opportunity of being heard.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (67163)
  sectionNo (30)
  orderNo 30
  title `Assessment of tax of non-resident dealer doing business temporarily by way of fair, mela, etc.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67163&sectionno=30&orderno=30&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_30_content:
  string
  line `(1) Notwithstanding anything contained in section 19, or section 26 and subject to such rules as may be`
  line `prescribed, it shall be open to the prescribed authority or any other officer authorised by the Commissioner`
  line `in this behalf to make provisional or final assessment of turnover of sale or purchase of goods, as the case`
  line `may be, effected by any dealer residing outside the State of Bihar and carrying on business temporarily by`
  line `way of fair, mela or by way of any other similar mode in the State of Bihar.`
  line
  line `(2) If a dealer referred to in sub-section (1) claims that the sales affected by him are not of goods`
  line `imported by him, the onus to prove such claim shall lie on the claimant.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (67164)
  sectionNo (31)
  orderNo 31
  title `Assessment or re-assessment of tax of escaped turnover.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67164&sectionno=31&orderno=31&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_31_content:
  string
  line `(1) If the prescribed authority is`
  line `satisfied, either on the basis of audit conducted under sub-section (3) of section 26 or otherwise, that`
  line `reasonable grounds exist to believe that, in respect of any assessment under this Act or under the Bihar`
  line `Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94, during any period, any`
  line `sale or purchases of goods liable to tax under this Act or the said Act, for any reason, has been underassessed or has escaped assessment, or has been assessed to tax at a lower rate, or any deduction therefrom`
  line `has been wrongly made, or an input tax credit has incorrectly been claimed, the prescribed authority shall,`
  line `in such manner as may be prescribed and after serving on the dealer a notice in the form and in the manner`
  line `prescribed, proceed to assess or re-assess, as the case may be, the tax payable by such dealer within four`
  line `years from the expiry of the year during which the original order of assessment or re-assessment was passed,`
  line `in a case where the dealer has concealed, omitted or failed to disclose full and correct particulars of such`
  line `sale or purchase or input tax credit, and the provisions of this Act shall, so far as may be, apply accordingly`
  line `as if the notice under this sub-section was a notice under section 27:`
  line
  line `Provided that the amount of tax shall be assessed or re-assessed after allowing such deductions as were`
  line `allowable during the said period and at the rates at which it would have been assessed had the turnover not`
  line `escaped assessment.`
  line
  line `(2)(a) The prescribed authority shall, in a case where the dealer has concealed, omitted or failed to`
  line `disclose full and correct particulars of such sale or purchase or input tax credit, direct that the dealer shall,`
  line `besides the amount of interest payable under sub-section (10) of section 24, pay by way of penalty, a sum`
  line `equal to three times the amount of tax which is or may be assessed on the turnover of sale or purchase which`
  line `escaped assessment.`
  line
  line `(b) The penalty imposed under clause (a) shall be in addition to the amount of tax, which is or may be`
  line `assessed on the turnover of sale or purchase which escaped assessment.`
  line
  line `(3) Any assessment or re-assessment made and any penalty imposed under this section shall be without`
  line `prejudice to any action, which is or may be taken under section 81.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (67165)
  sectionNo (32)
  orderNo 32
  title `Escaped turnover detected before or at the time of assessment of tax.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67165&sectionno=32&orderno=32&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_32_content:
  string
  line `(1) If the prescribed`
  line `authority is satisfied that any registered dealer--`
  line
  line `(a) has concealed any sales or purchases or any particulars thereof, with a view to reduce the amount`
  line `of tax payable by him under this Act; or`
  line
  line `(b) has furnished incorrect statement of his turnover or incorrect particulars of his sales or purchases`
  line `in the return furnished under sub-section (1) of section 24 or quarterly statement under sub-section (2)`
  line `of section 24 or quarterly abstract statement under sub-section (3) of section 24; or`
  line
  line `(c) has claimed input tax credit in excess of the amount of input tax credit to which he is entitled`
  line `under this Act,`
  line
  line `the prescribed authority shall, after giving such a dealer an opportunity of being heard in the prescribed`
  line `manner, by an order in writing, direct that he shall, besides the amount of interest payable under sub-section`
  line `(10) of section 24 and in addition to any tax which may be determined to be payable by him under the Act,`
  line `pay by way of penalty, a sum equal to three times the amount of tax on the concealed turnover or on`
  line `concealed or incorrect particulars or excess input tax credit claimed.`
  line
  line `(2) The penalty under sub-section (1) may be imposed before completion of assessment, and for`
  line `determining the amount of penalty, the prescribed authority may quantify the amount of tax provisionally`
  line `in the prescribed manner.`
  line
  line `(3) Any penalty imposed under sub-section (1) shall be without prejudice to any action, which is or`
  line `may be taken under section 81.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (67166)
  sectionNo (33)
  orderNo 33
  title `Assessment of tax based on audit objections.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67166&sectionno=33&orderno=33&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_33_content:
  string
  line `Where an objection has been made by the`
  line `Comptroller and Auditor-General of India in respect of an assessment or re-assessment made or scrutiny of`
  line `any return filed under this Act, the prescribed authority shall proceed to re-assess the dealer with respect to`
  line `whose assessment or re-assessment or scrutiny, as the case may be, the objection has been made in the`
  line `manner prescribed:`
  line
  line `Provided that no order under this section shall be passed without giving the dealer an opportunity of`
  line `being heard.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (67167)
  sectionNo (34)
  orderNo 34
  title `Assessment of tax proceedings, etc., not to be invalid on certain grounds.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67167&sectionno=34&orderno=34&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_34_content:
  string
  line `No assessment and`
  line `demand on account of any tax, interest or penalty shall be invalid or affected by reason only of any mistake`
  line `in the name, residence, place of business or status of any person liable to pay the tax, interest of penalty or`
  line `by reason only of clerical error or other defect of form, if the provisions contained in this Act and the rules`
  line `made thereunder have, in substance, been complied with.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (67168)
  sectionNo (35)
  orderNo 35
  title `Taxable turnover.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67168&sectionno=35&orderno=35&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_35_content:
  string
  line `(1) For the purposes of this Act, the taxable turnover of a dealer shall be that`
  line `part of his gross turnover which remains after deducting therefrom--`
  line
  line `(a) the aggregate value of the transactions specified in section 6;`
  line
  line `(b) sale price on account of sales exempted under section 7;`
  line
  line `(c) in the case of works contract, the amount remaining after deducting from the gross value of the`
  line `contract the amount on account of the following, namely:--`
  line
  line `(i) labour charges for execution of the works contract,`
  line
  line `(ii) amount paid to sub-contractor on account of labour and services,`
  line
  line `(iii) charges for planning, designing and architects fees,`
  line
  line `(iv) charges for obtaining on hire, the machineries and tools used in the execution of the works`
  line contract,
  line
  line `(v) cost of consumables such as water, electricity, fuels, etc., used in execution of the works`
  line `contract, the property in which is not transferred in the course of execution of a works contract,`
  line
  line `(vi) cost of establishment of the contractor to the extent, it is relatable to supply of labour and`
  line services,
  line
  line `(vii) other similar expenses relatable to supply of labour and services,`
  line
  line `(viii) profit earned by the contractor to the extent it is relatable to the supply of labour and`
  line `services, and`
  line
  line `(ix) goods or transaction exempted under section 6 or section 7;`
  line
  line `(d) value of goods transferred otherwise than by way of sale;`
  line
  line `(e) the value of goods sold but returned to the dealer within a period of six months from the date of`
  line `the original sales and in respect of which the selling dealer has issued to the purchasing dealer a credit`
  line `note specified in section 53;`
  line
  line `(f) sale price at the subsequent stages of sale of such goods as are specified in Schedule IV as being`
  line `subject to tax at the first point of their sale in the State of Bihar, if necessary evidence as required by`
  line `sub-section (2) of section 13 are filed along with the return filed by the dealer under sub-section (3) of`
  line `section 24.`
  line
  line `(2) Where a dealer claims that he is not liable to pay tax on any part of his gross turnover in respect of`
  line `any goods by reason of transfer of such goods by him to any other dealer or to his agent or to his principal,`
  line `as the case may be, for sale, the burden of proving such claim shall be on the dealer and for this purpose,`
  line `along with other evidences as may be prescribed, he shall furnish before the prescribed authority a`
  line `declaration in a form and in the manner prescribed.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (67169)
  sectionNo (36)
  orderNo 36
  title `Tax payable by a dealer.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67169&sectionno=36&orderno=36&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_36_content:
  string
  line `The tax payable by a dealer shall be calculated according to the following`
  line `formula, namely:--`
  line
  line `T = A–B`
  line
  line Where--
  line
  line `T means the tax payable by the dealer,`
  line
  line `A means the output tax under this Act, and`
  line
  line `B means the total amount of input tax credit allowable to the dealer under section 16 or section 17.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (67170)
  sectionNo (37)
  orderNo 37
  title `Time limit for completion of proceeding of assessment of tax.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67170&sectionno=37&orderno=37&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_37_content:
  string
  line `Except for a proceeding under`
  line `sub-section (2) of section 26, section 28, sub-section (1) of section 31 and section 33, no proceeding for`
  line `assessment of tax payable by a dealer under this Act in respect of any period shall be initiated and completed`
  line `except before the expiry of two years from the expiry of such period:`
  line
  line `Provided that a proceeding for re-assessment in pursuance of or as a result of an order on appeal,`
  line `revision or review shall be initiated and completed before the expiry of one year from the expiry of the year`
  line `during which such order was communicated to the assessing authority:`
  line
  line `Provided further that the Commissioner may, on being satisfied that it is necessary so to do and for`
  line `reasons to be recorded in writing, extend in a case or class of cases, the said period of two years to such`
  line `further period not exceeding two years.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (67171)
  sectionNo (38)
  orderNo 38
  title `Exclusion of time in assessment tax proceedings.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67171&sectionno=38&orderno=38&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_38_content:
  string
  line `In computing the period of limitation`
  line `prescribed for assessment or re-assessment, as the case may be, under section 27 or section 28 or section`
  line `29 or section 30 or section 31 or section 32 or section 33, the time during which any assessment or reassessment proceedings remained stayed under the order of any competent court shall be excluded.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (67172)
  sectionNo (39)
  orderNo 39
  title `Payment and recovery of tax.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67172&sectionno=39&orderno=39&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_39_content:
  string
  line `(1) The tax payable under this Act shall be paid in the manner`
  line `hereinafter provided.`
  line
  line `(2) The amount of--`
  line
  line `(i) tax estimated in advance under sub-section (7) of section 3, or`
  line
  line `(ii) tax due according to the returns filed by the dealer where full payment of such amount has not`
  line `been made, or`
  line
  line `(iii) tax assessed or re-assessed under section 26 or section 27 or section 28 or section 29 or section`
  line `30 or section 31 or section 32 or section 33 or in pursuance of or as a result of an order on appeal,`
  line `revision or review, less the sum, if any, already paid by the dealer, or`
  line
  line `(iv) interest chargeable or penalty imposed, if any, under any of the provisions of this Act,`
  line
  line `shall be paid by the dealer or the person concerned into a Government Treasury or a bank authorised in this`
  line `behalf by the State Government, or in such other manner as may be prescribed and by such date as may be specified in a notice issued by the prescribed authority for this purpose and the date to be specified shall,`
  line `ordinarily, not be less than thirty days from the date of service of such notice:`
  line
  line `Provided that the authority may, in respect of any particular dealer or a person, and, for reasons to be`
  line `recorded in writing, extend the date of such payment, or allow such dealer to pay tax or interest due and the`
  line `penalty, if any, by instalments in the manner prescribed:`
  line
  line `Provided further that where the prescribed authority considers it expedient in the interest of revenue, it`
  line `may, for reasons to be recorded in writing, require any dealer, or person, to make such payments forthwith.`
  line
  line `(3) If a dealer or a person fails to make payment of any amount of tax by the period specified in the`
  line `notice issued under sub-section (2) or fails to make payment of tax by the date extended or has defaulted in`
  line `making payment of instalments under the first proviso of the said sub-section, the dealer shall, for such`
  line `failure or default, pay, in addition to the amount of tax, an amount by way of simple interest calculated at`
  line `the rate of one and a-half per cent. for each calendar month or part thereof on the amount of such tax.`
  line
  line `(4) Where, in course of any proceeding, the prescribed authority finds that any dealer has--`
  line
  line `(i) wrongly claimed either the whole or part of his turnover as not taxable and, has consequently,`
  line `paid lesser amount of tax than payable by him; or`
  line
  line `(ii) wrongly declared his turnover or any particulars thereof and thereby has reduced the amount of`
  line `tax payable under this Act; or`
  line
  line `(iii) wrongly claimed input tax credit in excess of what he is entitled to under this Act,`
  line
  line `the dealer shall pay, in addition to the amount of tax assessed under any proceeding as aforesaid, simple`
  line `interest at the rate of one and a half per cent. for each calendar month or part thereof on the difference of`
  line `the amount previously admitted and tax finally assessed from the date, the tax would have been payable`
  line `had the dealer not committed any of the acts mentioned in clause (i) or clause (ii) or clause (iii):`
  line
  line `Provided that where the recovery of tax or any part thereof assessed under any proceeding under this`
  line `Act is stayed as a result of an order on appeal or by any competent court, the amount of such interest shall`
  line `be recoverable after the final order is passed and such order is confirmed from the date the tax first became`
  line due.
  line
  line `(5) If a dealer or a person has failed, without reasonable cause, to make payment of any amount of tax`
  line `by the date specified in the notice issued under sub-section (2) or forthwith as required by the second proviso`
  line `thereto, or in like manner has failed to make payment of tax and interest by the date extended under the first`
  line `proviso of the said sub-section or has defaulted in payment of instalments or has not paid the amount of`
  line `interest due, the prescribed authority, after giving the dealer a reasonable opportunity of being heard, may`
  line `direct that the dealer shall pay, in the prescribed manner, by way of penalty for such failure, an amount`
  line `which shall be five per cent. per month of the amount payable following the expiry of such date for each`
  line `subsequent month and part thereof.`
  line
  line `(6) Subject to the provisions of sub-sections (2), (4) and (5), any amount of tax, interest together with`
  line `penalty, if any, which remains unpaid after the date specified in the notice issued under sub-section (2), or`
  line `penalty imposed under sub-section (5) and remaining unpaid shall, without prejudice to any other mode of`
  line `recovery, be recoverable as if it were an arrear of land revenue:`
  line
  line `Provided that where an appeal in respect of such amount has been entertained under section 72, the`
  line `appellate authority may, subject to such rules as may be made by the State Government under this Act, stay`
  line `recovery of such amount or portion thereof for so long as the appeal remains pending or for such shorter`
  line `period as the said authority may consider to be adequate.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (67173)
  sectionNo (40)
  orderNo 40
  title `Advance recovery of tax on sales and supplies to Governments and other persons.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67173&sectionno=40&orderno=40&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_40_content:
  string
  line `(1) Subject`
  line `to the provisions of section 6, any person responsible for paying sale price or any amount purporting to be`
  line `the full or part payment of sale price in respect of sales or supplies of taxable goods exceeding rupees two`
  line `lakh fifty thousands during a year made to the State Government or the Central Government or a company,`
  line `corporation, Board, authority, undertaking or any other body owned, financed or controlled either wholly or partly by the State Government or the Central Government, shall, at the time of payment, subject to such`
  line `conditions and restrictions as may be prescribed, deduct an amount at the rate as may be specified by the`
  line `State Government, by a notification, on account of tax on the amount of such payment:`
  line
  line `Provided that the rate or rates to be specified by the State Government shall not be more than the rate`
  line `of tax applicable to the goods sold or supplied.`
  line
  line `(2) Notwithstanding any law or contract to the contrary, the person making such deduction shall be`
  line `lawfully competent to make such deduction.`
  line
  line `(3) The payment of the amount deducted under sub-section (1) into the Government Treasury in the`
  line `prescribed manner, shall be the liability of the person making such deduction.`
  line
  line `(4) The payment of the amount deducted under sub-section (1) into the Government Treasury by the`
  line `person making the deduction shall be deemed to be a payment by or on behalf of the seller or supplier`
  line concerned.
  line
  line `(5) If any person contravenes any or all of the provisions of sub-sections (1), (3) and (4), he shall be`
  line `liable to pay, by way of penalty, a sum not exceeding twice the amount of tax deductible under sub-section`
  line `(1):`
  line
  line `Provided that such penalty shall not be imposed unless the person contravening the provisions is given`
  line `an opportunity of being heard by the prescribed authority.`
  line
  line `(6) The provisions of sections 39 and 47 for recovery of any amount of tax due from a dealer shall,`
  line `mutatis mutandis, apply for recovery of any amount of tax deducted or any penalty imposed but not`
  line `deposited under this section.`
  line
  line `Explanation.--For the purposes of this section, the person in this section shall include all officers or`
  line `authorities who are competent or authorised to make payment of the sale-price in respect of sales to the`
  line `State Government or the Central Government or to a company, corporation, Board, authority, undertaking`
  line `or any other body owned, financed or controlled wholly or partly by the State Government or the Central`
  line Government.
  line
  line `(7) The provisions of sub-section (5) of section 41 shall, mutatis mutandis, apply, so far as it relates, to`
  line `issuance of certificate to person from whose bills deduction has been made and for filing of quarterly`
  line `statements by the person making the deductions.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (67174)
  sectionNo (41)
  orderNo 41
  title `Advance recovery of tax from works contractors.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67174&sectionno=41&orderno=41&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_41_content:
  string
  line `(1) Subject to the provisions of section 6,`
  line `every person, responsible for making any payment in discharge of any liability on account of valuable`
  line `consideration payable in respect of transfer of property in goods (whether as goods or in some other form)`
  line `vested in the execution of a works contract shall be lawfully competent to deduct an amount at the rate or`
  line `rates, not exceeding four per cent. to be specified by the State Government, in a notification published in`
  line `the Official Gazette, purporting to be a part or full amount of tax payable on the sale of such goods from`
  line `every bill or invoice raised by the works contractor as payable by the person and no such payment or`
  line `discharge of any such bill or invoice raised by a works contractor shall be made without deduction as`
  line aforesaid.
  line
  line `Explanation.--For the purposes of this section, the “person” in this section shall include all officers and`
  line `authorities of the Central or the State Government or of a company, corporation, Board, authority, cooperative societies, undertaking or any other body constituted or formed under any Act and of any firm or`
  line `association of persons and organisation:`
  line
  line `Provided that, the State Government may prescribe the conditions subject to which no such deductions`
  line `shall be made.`
  line
  line `(2) No such payment or discharge of any bill or invoice raised in respect of transfer of property in goods`
  line `(whether as goods or in some other form) by a works contractor shall be made without the deduction referred`
  line `to in sub-section (1):`
  line
  line `Provided that no deduction under sub-section (1) shall be made where the payment is made as advance`
  line `prior to the commencement of the execution of such works contract until it forms part of the sale price`
  line `payable for transfer of property in goods (whether as goods or in some other form):`
  line
  line `Provided further that no deduction under sub-section (1) shall be made from the payment or any part`
  line `thereof, where--`
  line
  line `(a) the payment or any part thereof does not relate to any transfer of property in goods (whether as`
  line `goods or in some other form) involved in the execution of works contract;`
  line
  line `(b) the dealer produces a certificate issued by the Deputy Commissioner, Commercial Taxes or the`
  line `Assistant Commissioner, Commercial Taxes or the Commercial Taxes Officer, in-charge of the`
  line `concerned Circle to the effect that the payment or any part thereof relates to such transfer of property`
  line `in goods (whether as goods or in some other form) on which he has no further liability to pay tax in`
  line `terms of the provisions of section 15 of the Central Sales Tax Act, 1956 (74 of 1956);`
  line
  line `(c) the dealer produces a certificate issued by the Deputy Commissioner, Commercial Taxes or the`
  line `Assistant Commissioner, Commercial Taxes or the Commercial Taxes Officer, in charge of the`
  line `concerned Circle to the effect that the payment or any part thereof relates to such transfer of property`
  line `in goods (whether as goods or in some other form) on which he has no liability to pay tax in terms of`
  line `the provisions of section 6.`
  line
  line `(3) The amount deducted under sub-section (1) shall be adjusted against the amount of tax finally`
  line `assessed or determined as being payable by the concerned works contractor and any amount deducted in`
  line `excess of the tax so assessed or determined shall be refunded in accordance with the provisions of this Act.`
  line
  line `(4) The deduction referred to in sub-section (1) shall be made in the manner prescribed.`
  line
  line `(5) The person making the deduction shall issue a certificate, in the form and manner prescribed,`
  line `containing such particulars as may be required to be mentioned therein, to the works contractor or person`
  line `from whose bill or invoice such deduction has been made and such certificate shall be deemed to be a valid`
  line `discharge of liability in terms of provisions of sub-section (9) of section 24 to the extent of amount of`
  line `deduction made under sub-section (1).`
  line
  line `(6) If any person contravenes any or all of the provisions of sub-sections (1), (2) and (5), the prescribed`
  line `authority shall, after giving a reasonable opportunity of being heard, by order in writing direct that such`
  line `person shall pay by way of penalty, a sum not exceeding twice the amount of tax deductible or deducted`
  line `and not deposited in the Government Treasury.`
  line
  line `(7) The provisions of sections 39 and 47 shall, mutatis mutandis, apply for recovery of any amount of`
  line `tax deducted but not deposited into the Government Treasury or any penalty imposed under this section.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (67175)
  sectionNo (42)
  orderNo 42
  title `Production of tax clearance certificate.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67175&sectionno=42&orderno=42&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_42_content:
  string
  line `Notwithstanding anything contained in any law for the`
  line `time being in force, no person shall be awarded by--`
  line
  line `(i) the State Government; or`
  line
  line `(ii) the Central Government; or`
  line
  line `(iii) a company, corporation, board, authority, undertaking or any other body which is owned,`
  line `financed or controlled either wholly or partly by the State Government or the Central Government,`
  line
  line `any contract involving sale or supply of goods and no person shall be granted any licence to carry on any`
  line `trade or commerce unless he produces to the State Government or the Central Government or the company,`
  line `corporation, board, authority, undertaking or any other body which is owned, financed or controlled either`
  line `wholly or partly by the State Government or the Central Government, a tax clearance certificate, granted`
  line `by the prescribed authority in the form and manner prescribed, to the effect that the prescribed authority`
  line `has no objection to the awarding of such contract or the granting of such licence to the person concerned:`
  line
  line `Provided that no such certificate shall be granted to any person who is not a registered dealer under this`
  line `Act or, being a registered dealer, has made a default in the payment of any tax, penalty or interest due under`
  line `this Act:`
  line
  line `Provided further that if a person not liable to tax under this Act applies for the grant of certificate under`
  line `this section and in whose case the value of the contract or, as the case may be, the anticipated turnover in the immediately succeeding twelve months exceeds the limit specified in sub-section (2) of section 3, he`
  line `shall be granted such certificate subject to the condition that he shall furnish, to the prescribed authority, an`
  line `undertaking to the effect that he shall apply for grant of certificate of registration in the manner and within`
  line `the period prescribed and in the event of failure to do so the concerned Government or person or authority`
  line `shall terminate the contract awarded to the person.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (67176)
  sectionNo (43)
  orderNo 43
  title `Restriction on collection of tax by dealers.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67176&sectionno=43&orderno=43&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_43_content:
  string
  line `(1) Without prejudice to the provisions of sections 40`
  line `and 41, no person, who is not a registered dealer, shall collect from any person any amount, by whatever`
  line `name or description it may be called, towards or purporting to be tax on sale of goods.`
  line
  line `(2) No registered dealer shall collect from any person any such amount exceeding the amount arrived`
  line `at after applying the rate of tax specified under section 14 to the sale price of the goods sold.`
  line
  line `(3) If any person or a registered dealer contravenes the provisions of sub-section (1) or sub-section (2),`
  line `the prescribed authority shall, after giving an opportunity of being heard in the manner prescribed, by an`
  line `order in writing direct that such person or registered dealer shall pay by way of penalty a sum equal to twice`
  line `the amount collected in contravention of the provisions of sub-sections (1) and (2).`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (67177)
  sectionNo (44)
  orderNo 44
  title `Forfeiture of tax collected in violation of this Act.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67177&sectionno=44&orderno=44&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_44_content:
  string
  line `(1) Any amount collected, by any person in`
  line `contravention of the provisions of sub-section (1) or sub-section (2) of section 43 or any amount collected`
  line `by any person by way of tax, by whatever name called, or in any other manner not payable under any`
  line `provision of this Act, shall be liable to forfeiture to the State Government.`
  line
  line `(2) If the prescribed authority, in the course of any proceeding under this Act or otherwise, has reason`
  line `to believe that any amount is liable for forfeiture under sub-section (1), it shall serve, on the person who`
  line `has collected such amount, a notice in the prescribed form requiring him to show cause why the said amount`
  line `should not be forfeited to the State Government and on receipt of the reply, if any, and after making such`
  line `inquiries as may be deemed fit, he shall make an order of forfeiture if the amount is found so liable.`
  line
  line `(3) Where an order of forfeiture under sub-section (2) has been made, the person making the`
  line `unauthorised collection shall forthwith pay the amount so forfeited to the State Government, if it has not`
  line `already been paid and on his failure to do so, such amount shall be recoverable from him as if it were a tax`
  line `due from him.`
  line
  line `(4) Where an order for forfeiture is passed, the Commissioner shall publish or cause to be published, in`
  line `the prescribed manner, a notice for information of the persons from whom the amount so forfeited had been`
  line `collected giving such details as may be prescribed.`
  line
  line `(5) On the publication of the notice under sub-section (4) a refund of such amount or part thereof may`
  line `be claimed from the State Government within one year from the date of publication of the said notice by`
  line `the person from whom it was unauthorisedly realised by way of tax and for this purpose the person claiming`
  line `the refund shall make an application in the prescribed form.`
  line
  line `(6) On receipt of an application under sub-section (5), the Commissioner shall hold such enquiry as he`
  line `deems fit and if he is satisfied that the claim is valid and admissible and that the amount so claimed as`
  line `refund was actually paid to the State Government and no refund or remission in respect of that amount was`
  line `granted, the Commissioner shall refund such amount or any part thereof to the person concerned.`
  line
  line `(7) Notwithstanding anything contained in this Act or in any other law for the time being in force,`
  line `where any amount collected by any person is forfeited to the State Government under this section, such`
  line `forfeiture shall, if the amount forfeited has been paid to the State Government, discharge him of the liability`
  line `to refund the amount to the person from whom it was so collected.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (67178)
  sectionNo (45)
  orderNo 45
  title `Rounding off of tax liability.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67178&sectionno=45&orderno=45&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_45_content:
  string
  line `Any tax, interest or penalty payable under this Act shall be rounded`
  line `off to the nearest ten rupees and shall be paid accordingly.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (67179)
  sectionNo (46)
  orderNo 46
  title `Recovery of tax as arrears of land revenue.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67179&sectionno=46&orderno=46&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_46_content:
  string
  line `(1) All authorities appointed under section 10 shall,`
  line `for the purpose of recovery of tax, interest and penalty under this Act, have the same powers as are vested`
  line `in the certificate officer under the Bihar and Orissa Public Demand Recovery Act, 1914 (Bihar and Orissa`
  line `Act 4 of 1914)..br`
  line `(2) Any proceeding under sub-section (1) before any authority appointed under section 10 shall be`
  line `deemed to be a proceeding for recovery of the public demand under the Bihar and Orissa Public Demands Recovery Act, 1914 (Bihar and Orissa Act 4 of 1914) and all provisions of the said Act for recovery,`
  line `attachment, sale, arrest shall mutatis mutandis apply.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (67180)
  sectionNo (47)
  orderNo 47
  title `Special mode of recovery of tax and other liabilities under this Act.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67180&sectionno=47&orderno=47&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_47_content:
  string
  line `(1) Notwithstanding`
  line `anything contained in section 39 or any law or contract to the contrary, the prescribed authority may, at any`
  line `time or from time to time, by notice in writing (a copy of which shall be forwarded to the dealer at his last`
  line `address known to the said authority) direct--`
  line
  line `(a) any person from whom any money is due or may become due to a dealer who has failed to`
  line `comply with a notice of demand served under section 39; or`
  line
  line `(b) any person who holds or may subsequently hold any money for or on account of such dealer,`
  line `to pay into Government treasury, in the manner specified in the notice issued under this sub-section, either`
  line `forthwith or upon the money becoming due or being held, or within the time specified in the notice (not`
  line `being before the money becomes due or it is held) so much of the money as is sufficient to pay the amount`
  line `of tax due from the dealer, together with interest and penalty, if any, under this Act or the whole of the`
  line `money when it is equal to or less than that amount.`
  line
  line `(2) The authority issuing a notice under sub-section (1) may, at any time or from time to time, amend`
  line `or revoke any such notice or extend the time for making any payment in pursuance of the notice.`
  line
  line `(3) Any person making any payment in compliance with a notice issued under sub-section (1) shall be`
  line `deemed to have made the payment under the authority of the dealer and the receipt from the Government`
  line `Treasury shall constitute a good and sufficient discharge of the liability of such person to the dealer to the`
  line `extent of the amount specified in the receipt.`
  line
  line `(4) Any person discharging any liability to the dealer after service on him of the notice issued under`
  line `sub-section (1) shall be personally liable to the State Government to the extent of the liability discharged`
  line `or to the extent of the liability of the dealer for tax, interest and penalty, whichever is less.`
  line
  line `(5) Where a person on whom a notice is served under sub-section (1) proves to the satisfaction of the`
  line `authority which issued the notice that the money demanded or any part thereof was not due to the dealer or`
  line `that he did not hold any money for or on account of the dealer, at the time the notice was served on him,`
  line `nor is the money demanded or any part thereof, likely to become due to the dealer or be held for or on`
  line `account of the dealer, nothing contained in this section shall be deemed to require such person to pay into`
  line `the Government Treasury any such money or part thereof, as the case may be.`
  line
  line `(6) If any person contravenes any of the provisions of sub-sections (1) and (4) of this section, the`
  line `prescribed authority shall after giving an opportunity of being heard by an order in writing direct that such`
  line `person shall pay by way of penalty a sum not exceeding twice the amount payable under sub-section (1).`
  line
  line `(7) Any amount of money which a person is directed to pay under subsection (1) or for which he is`
  line `personally liable to the State Government under sub-section (4), shall, if it remains unpaid, be recoverable`
  line `as an arrear of land revenue.`
  line
  line `(8) No action shall be taken under this section in respect of any amount of tax, interest and penalty, if`
  line `any, the date of payment of which has been extended or the realisation of which has been stayed under this`
  line `Act during the period of such extension or stay.`
  line
  line `(9) The provisions of this section shall be without prejudice to any action that may be taken for recovery`
  line `of the arrears of tax, interest and penalty, if any, due from the dealer or person.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (67181)
  sectionNo (48)
  orderNo 48
  title `Liability of surety.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67181&sectionno=48&orderno=48&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_48_content:
  string
  line `The liability of a surety under this Act shall be co-extensive, to the extent of`
  line `the amount of security, with that of the defaulting dealer and all modes of recovery enforceable against the`
  line `dealer shall be enforceable against the surety by the prescribed authority.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (67182)
  sectionNo (49)
  orderNo 49
  title `Transfers to defraud revenue void.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67182&sectionno=49&orderno=49&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_49_content:
  string
  line `Where, during the pendency of any proceeding relating to`
  line `assessment, re-assessment or recovery of any tax, interest or penalty payable under this Act or the Bihar`
  line `Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94, any person or dealer`
  line `creates a charge on or parts with the possession, by any mode of transfer whatsoever including sale,`
  line `mortgage, gift or exchange, of any of his assets in favour of any person with the intention of defrauding the`
  line `revenue, then, notwithstanding anything to the contrary contained in any Act or contract, such charge or transfer shall be void as against any claim inrespect of any tax or any other sum payable by the dealer as a`
  line `result of the completion of such proceeding or otherwise.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (67183)
  sectionNo (50)
  orderNo 50
  title `Period of limitation for recovery of tax.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67183&sectionno=50&orderno=50&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_50_content:
  string
  line `Notwithstanding anything contained in any other law`
  line `for the time being in force, no proceeding, for the purposes of sub-section (6) of section 39 or sub-section`
  line `(7) of section 47, shall be initiated under this Act except before the expiry of twelve years from due date`
  line `within the meaning of sub-section (3) of section 24:`
  line
  line `Provided that the period of limitation for the registered dealer availing of the tax deferment under`
  line `section 23A of the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section`
  line `94, shall be reckoned from the last date of repayment of the deferred amount of tax:`
  line
  line `Provided further that when an appeal or application for review has been filed, the period of limitation`
  line `as aforesaid shall run from the date of order passed on such appeal, application for review or from the date`
  line `of order passed in pursuance of or as a result of such order, whichever is later.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (67184)
  sectionNo (51)
  orderNo 51
  title `Tax to be first charge on property.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67184&sectionno=51&orderno=51&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_51_content:
  string
  line `Notwithstanding anything to the contrary contained in any`
  line `law for the time being in force, any amount of tax and interest and penalty, if any, payable by a dealer or`
  line `any other person under this Act shall be a first charge on the property of the dealer or such person.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (67185)
  sectionNo (52)
  orderNo 52
  title `Maintenance of accounts.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67185&sectionno=52&orderno=52&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_52_content:
  string
  line `(1) Every registered dealer (other than a dealer permitted to pay tax`
  line `under section 15), shall--`
  line
  line `(a) keep in such manner as may be prescribed a true and complete account in respect of all goods`
  line `produced, raised, manufactured, processed, bought, sold or delivered or transferred to or by him;`
  line
  line `(b) maintain in such manner as may be prescribed correct and complete accounts of despatches and`
  line `arrivals of goods as also of stock of goods manufactured or transferred.`
  line
  line `(2) Such dealers or persons, as may be prescribed, and such other dealers to whom sub-section (1)`
  line `applies, shall, at the end of each financial year, draw up, in the manner as may be prescribed,--`
  line
  line `(a) a manufacturing, trading and profit and loss account and a balance sheet, in the case of a`
  line `manufacturer; and`
  line
  line `(b) such accounts as may be prescribed, in any other case:`
  line
  line `Provided that no accounts referred to in sub-section (1) shall be considered, true and complete unless`
  line `such accounts enable the prescribed authority to compute the tax payable and the entitlement of input tax`
  line `credit under the provisions of this Act:`
  line
  line `Provided further that the accounts referred to in sub-section (1) shall not be considered true and`
  line `complete unless they give a true and fair view--`
  line
  line `(i) of the state of affairs of the dealer or the person as at the end of the financial year, in the case of`
  line `the balance sheet; and`
  line
  line `(ii) of the working results of the dealer or the person for the financial year, in the case of the`
  line `anufacturing, trading and profit and loss account.`
  line
  line `(3) Every dealer or a person required to keep accounts by sub-section (1) shall--`
  line
  line `(a) issue a challan in respect of all transfers of goods from his place of business otherwise than as`
  line `a result of sale, in such form as may be prescribed; and`
  line
  line `(b) preserve all invoices for a period of not less than six years from the end of the year to which`
  line `they relate, or for a period of two years after the completion of assessment, appeal or revision for the`
  line `year, whichever is later.`
  line
  line `(4) Every dealer permitted to pay tax under section 15 shall--`
  line
  line `(a) maintain accounts showing his purchases and sales during the year and such other accounts, as`
  line `may be prescribed; and`
  line
  line `(b) draw up, at the end of each financial year, in the manner as may be prescribed, a trading and`
  line `profit and loss account.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (67186)
  sectionNo (53)
  orderNo 53
  title `Issue of tax invoice and debit and credit notes.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67186&sectionno=53&orderno=53&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_53_content:
  string
  line `(1) A registered dealer, making a sale liable to`
  line `tax under this Act, to another registered dealer shall, provide the purchaser at the time of sale, a tax invoice`
  line `containing the particulars specified in sub-section (2) and retain a copy thereof:`
  line
  line `Provided that a tax invoice shall not be issued--`
  line
  line `(a) by a dealer permitted to pay tax under section 15; or`
  line
  line `(b) for the sale in the course of inter-State trade or commerce or export by a dealer,`
  line
  line `and in such cases a retail invoice shall be issued:`
  line
  line `Provided further that not more than one tax invoice shall be issued for each such sale:`
  line
  line `Provided also that if an invoice has been issued under the provisions of the Central Excise Act, 1944`
  line `(1 of 1944), it shall be deemed to be a tax invoice if it contains the particulars specified in sub-section (2).`
  line
  line `(2) The tax invoice issued under sub-section (1) shall contain the following particulars on the original`
  line `as well as copies thereof, namely:--`
  line
  line `(a) the words "Tax Invoice" in a prominent place;`
  line
  line `(b) the name, address and tax payer identification number of the selling registered dealer;`
  line
  line `(c) the name, address and tax payer identification number of the purchaser;`
  line
  line `(d) an individual pre-printed serialised number and the date on which the tax invoice is issued;`
  line
  line `(e) description, quantity, volume and value of goods sold and the amount of tax charged thereon`
  line `indicated separately;`
  line
  line `(f) the signature of the selling dealer or his manager, agent or servant duly authorised by him; and`
  line
  line `(g) the name and address of the printer and first and last serial number of tax invoices printed and`
  line `supplied by him to the dealer.`
  line
  line `(3) A tax invoice in respect of a sale shall be issued in duplicate and the original of which shall be`
  line `issued to the purchaser (or the person taking the delivery, as the case may be) and the duplicate shall be`
  line `retained by the selling dealer.`
  line
  line `(4) Except when a tax invoice is issued under sub-section (1), if a dealer sells any goods exceeding such`
  line `amount in value as may be prescribed, in any one transaction to any person, he shall issue to the purchaser`
  line `a retail invoice containing the particulars specified in sub-section (5) and retain a copy thereof.`
  line
  line `(5) The retail invoice issued under sub-section (4) shall contain the following particulars on the original`
  line `as well as copies thereof, namely:--`
  line
  line `(a) the words "Retail Invoice" or "Cash Memorandum" or "Bill" in a prominent place;`
  line
  line `(b) the name, address and tax payer identification number of the selling dealer, if registered;`
  line
  line `(c) in case the sale is in the course of inter-State trade or commerce, the name, registration number`
  line `and address of the purchasing dealer and type of any form, under the Central Sales Tax Act, 1956 (74`
  line `of 1956), if any, against which the sale has been made;`
  line
  line `(d) an individual pre-printed serialised number and the date on which the retail invoice is issued;`
  line
  line `(e) description, quantity, volume and value of goods sold and amount of tax charged thereon`
  line `indicated separately; and`
  line
  line `(f) the signature of the selling dealer or his servant, manager or agent, duly authorised by him.`
  line
  line `(6) The retail invoice shall be issued in duplicate, and the original of which shall be issued to the`
  line `purchaser and the duplicate copy of which shall be retained by the selling dealer.`
  line
  line `(7) The Commissioner may, by notification, specify the manner and form in which the particulars on a`
  line `tax invoice or retail invoice are to be recorded.`
  line
  line `(8) If a purchaser claims to have lost the original tax invoice, the selling dealer may, subject to such`
  line `conditions and restrictions as may be prescribed, provide a copy of such tax invoice clearly marked as a`
  line `copy of the original tax invoice.`
  line
  line `(9) Where a tax invoice has been issued in respect of a sale and--`
  line
  line `(a) the amount shown as tax in that tax invoice exceeds the tax payable in respect of the sale, the`
  line `dealer shall provide the purchaser with a credit note, containing such particulars as may be prescribed;`
  line or
  line
  line `(b) the tax payable in respect of the sale exceeds the amount shown as tax on the tax invoice, the`
  line `dealer shall provide the purchaser with a debit note, containing such particulars as may be prescribed.`
  line
  line `(10) Every dealer referred to in sub-section (1) shall preserve books of account including tax invoices`
  line `and retail invoices until the expiry of six years after the end of the year to which they relate or for such`
  line `other period as may be prescribed.`
  line
  line `(11) If a registered dealer contravenes the provisions of this section, the prescribed authority shall, after`
  line `giving the dealer an opportunity of being heard, direct him to pay by way of penalty a sum equivalent to`
  line `twice the amount of tax payable for each sale in respect of which such contravention has taken place.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (67187)
  sectionNo (54)
  orderNo 54
  title `Accounts to be audited in certain cases.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67187&sectionno=54&orderno=54&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_54_content:
  string
  line `(1) Every dealer whose gross turnover exceeds forty`
  line `lakh rupees shall, for the purposes of this Act, get his annual accounts audited by an accountant by--`
  line
  line `(i) the 30th day of November of the following year, in the case of a company formed and registered`
  line `under the Companies Act, 1956 (1 of 1956); and`
  line
  line `(ii) the 31st day of October of the following year, in any other case.`
  line
  line `(2) Every dealer referred to in sub-section (1) shall obtain, by the date specified in that sub-section, a`
  line `report of such audit in the prescribed form duly signed and verified by such accountant and setting forth`
  line `such particulars as may be prescribed and true copy of such report shall be furnished, on or before the due`
  line `date, by such dealer to the prescribed authority.`
  line
  line `Explanation 1.--In this sub-section, "due date" means--`
  line
  line `(a) where the dealer is a company within the meaning of the Companies Act, 1956 (1 of 1956), the`
  line `30th day of November of the year following the year to which such return relates;`
  line
  line `(b) where the dealer is a person, other than a company,--`
  line
  line `(i) in a case where the accounts of the dealer are required under this Act or any other law to be`
  line `audited or where the report of an accountant is required to be furnished under this section, the 31st`
  line `day of October of the year following the year to which such return relates;`
  line
  line `(ii) in any other case, the 31st day of July of the year following the year to which such return`
  line relates..
  line
  line `Explanation 2.--For the purposes of this section, "accountant" means a Chartered Accountant within`
  line `the meaning of the Chartered Accountants Act, 1949 (38 of 1949) and includes a person who, by virtue of`
  line `the provisions of sub-section (2) of section 226 of the Companies Act, 1956 (1 of 1956), is entitled to be`
  line `appointed to act as an auditor of companies registered in any State.`
  line
  line `(3) If the accounts of a registered dealer are not required to be audited in terms of the provisions of subsection (1), such dealer shall furnish, to the prescribed authority, the accounts and statements mentioned in`
  line `sub-section (2) of section 52 on or before the 31st day of July of the year following the year to which such`
  line `accounts or statements relate.`
  line
  line `(4) If a dealer contravenes the provisions of sub-section (2) or sub-section (3), the prescribed authority`
  line `shall, after giving the dealer a reasonable opportunity of being heard, impose on him, in addition to any tax`
  line `payable, a sum by way of penalty equivalent to two per cent. of the tax payable by him under section 36 for`
  line `every month, or part thereof, of such default.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (67234)
  sectionNo (55)
  orderNo 55
  title `Furnishing of information by Government departments, banks, financial institutions clearing and forwarding agents and owners of warehouses, godowns and others.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67234&sectionno=55&orderno=55&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_55_content:
  string
  line `(a) Every bank, including any`
  line `branch of a bank, or any clearing house in the State or any financial institution, department of the Government, corporation, institution, organisations or companies, boards, authorities, undertakings or any`
  line `bodies owned, financed or controlled wholly or partly by the State Government or the Central Government;`
  line and
  line
  line `(b) every clearing, forwarding or booking agent or dalal as defined in clause (a) of the Explanation to`
  line `section 59 or a person engaged in the business of transporting goods,`
  line
  line `shall, if so required by any authority appointed under section 10, furnish any such particulars as may be`
  line `required by such authority in respect of the transactions relating to sales or purchases of goods by such`
  line `dealers or any dealer with or through such banks or clearing house or any financial institution, department`
  line `of the Government, corporations, institutions, organisations or companies, boards, authorities, undertakings`
  line `or any other body owned, financed or controlled wholly or partly by the State Government or the Central`
  line Government.
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (67189)
  sectionNo (56)
  orderNo 56
  title `Production of books of account, inspection, search and seizure.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67189&sectionno=56&orderno=56&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_56_content:
  string
  line `(1) Subject to such rules as may`
  line `be made by the State Government under this Act, any authority appointed under sub-section (1) of section`
  line `10 may, either before or after assessment, require any dealer to produce before it or him any accounts,`
  line `registers or documents or to furnish any information relating to the details of his purchases and sales and`
  line `the stock of goods produced, raised, processed, manufactured, bought, sold or delivered by such dealer, and`
  line `the dealer shall comply with such requirement.`
  line
  line `(2) If reasonable grounds exist to suspect that--`
  line
  line `(a) a dealer, with an intention to reduce his tax liability under the Act, has suppressed any financial`
  line `transaction, element of value addition implicit in the transaction or the stock of goods produced, raised,`
  line `processed, manufactured, bought, sold or delivered by such dealer or has claimed input tax credit in`
  line `excess of his entitlement; or`
  line
  line `(b) any clearing or forwarding agent or a person engaged in the business of transporting goods or`
  line `owner of a warehouse or a godown is keeping or has kept his accounts in such a manner as is likely to`
  line `cause evasion of tax payable under this Act,`
  line
  line `the prescribed authority shall, after making such further inquiries as may be deemed fit and after obtaining`
  line `such authorisation in the manner prescribed, proceed to inspect all the places of business of the dealer or`
  line `the clearing or forwarding agent or the person engaged in the business of transporting goods or the owner`
  line `of warehouse or godown:`
  line
  line `Provided that if the prescribed authority is satisfied that delay in obtaining such authorisation may be`
  line `prejudicial to the interest of revenue, he may, for reasons to be recorded in writing, proceed to inspect all`
  line `the places of business of the dealer or the clearing or forwarding agent or the person engaged in the business`
  line `of transporting goods or the owner of warehouse or godown without obtaining such authorisation which`
  line `may be granted subsequently.`
  line
  line `(3) The prescribed authority shall have the powers to enter into and search the premises, including the`
  line `place of business, of such dealer or the person and, for reasons to be recorded in writing, seize such`
  line `accounts, registers or documents of the dealer or the person as may be necessary, in the manner prescribed,`
  line `and shall retain the same for so long as may be necessary in connection with any proceeding under this Act`
  line `or for a prosecution under any law:`
  line
  line `Provided that if the dealer or person whose accounts, registers or documents have been seized, applies`
  line `for a copy of the same, he shall be supplied with a photo-copy of the same on payment of appropriate cost`
  line `into a Government Treasury or a bank authorised in this behalf by the State Government:`
  line
  line `Provided further that such authority or inspector may take or cause to be taken such copies of, or extracts`
  line `from, the accounts, registers or documents, as such authority or inspector may consider necessary.`
  line
  line `(4) (a) Any authority referred to in sub-sections (1) and (2) shall have the powers to seize any goods`
  line `not properly accounted for in the books, accounts, registers and other documents of the dealer or the dalal`
  line `as defined in clause (a) of the Explanation to section 59, or the owner of the warehouse, or the clearing, booking or forwarding agent, or the person engaged in the business of transporting goods in the manner`
  line prescribed.
  line
  line `(b) The authority referred to in clause (a) shall, in a case where the dealer or the person in-charge of`
  line `goods as mentioned in clause (a) fails to produce any evidence or fails to satisfy the said authority regarding`
  line `the proper accounting of goods, impose a penalty, after allowing an opportunity of hearing in the prescribed`
  line `manner to the dealer or such person, which shall be equal to three times the amount of tax calculated on the`
  line `value of such goods and the goods shall be released as soon as the penalty is paid.`
  line
  line `(c) If the dealer or the person in-charge of the goods mentioned in clause (a) requests for time for`
  line `production of necessary documents in support of proper accounting, the authority referred to in clause (a)`
  line `shall release the goods on the condition that the dealer or such person deposits a security equivalent to three`
  line `times the amount of tax calculated on the value of the goods, either in the form of cash, to be deposited in`
  line `the Government Treasury, or in the form of bank guarantee acceptable to the authority.`
  line
  line `(d) If the goods seized under clause (a) are not claimed by any person, the authority referred to in the`
  line `said clause shall arrange for the safe custody of goods.`
  line
  line `(e) In case the penalty imposed under clause (b) is not paid or the goods remain unclaimed for a period`
  line `of thirty days or more from the date of seizure, the goods so seized shall be sold by auction in the prescribed`
  line `manner and the sale proceeds shall be appropriated towards the amount of penalty imposed under clause`
  line `(b); and the balance of the sale-proceeds, if any, shall be deposited in the Government Treasury and shall`
  line `be refunded to the lawful claimant in the prescribed manner:`
  line
  line `Provided that in the case of goods of a perishable nature, the prescribed authority may decide to sell the`
  line `goods by auction before a period of thirty days.`
  line
  line `(f) In case where the goods have been released on the deposit of a security as mentioned in clause (c)`
  line `and evidence regarding proper accounting of goods, to the satisfaction of the authority referred to in clause`
  line `(a) is not produced within thirty days from the date on which the security is deposited, the amount of`
  line `security shall stand forfeited to the State Government:`
  line
  line `Provided that in case evidence or document to the satisfaction of the authority mentioned in clause (a)`
  line `regarding the proper accounting of goods is produced within the said period of thirty days, the security shall`
  line `be released in the prescribed manner.`
  line
  line `(5) (a) The power conferred under sub-sections (3) and (4) shall include the power to break open the`
  line `lock of any box or receptacle or door of any other place or premises where any accounts, registers or other`
  line `documents or goods may be kept or are reasonably suspected to be kept.`
  line
  line `(b) The powers conferred under sub-sections (3) and (4) shall also include the power to seal any box or`
  line `receptacle, godown or building where any accounts, registers or other documents or goods may be kept or`
  line `are reasonably suspected to be kept.`
  line
  line `(6) An authority appointed under section 10 may require the assistance of any person, public servant or`
  line `police officer in making a search and a seizure or for safe custody of goods seized under this section, and`
  line `such person, public servant or police officer shall render necessary assistance in the matter.`
  line
  line `(7) Where any books of account, other documents, money or goods are found in the possession or`
  line `control of any person in the course of any search under sub-section (2) or sub-section (3), it shall be`
  line `presumed, unless it is proved to the contrary, that such books of account, documents, money or goods`
  line `belong to such person.`
  line
  line `Explanation.–For the purposes of this section the expression "proper accounting", shall--`
  line
  line `(i) in the case of a dealer, mean that the goods have either not been entered in the books of`
  line `account or they have been classified in a manner which is likely to lead to evasion of tax payable`
  line `under this Act; or`
  line
  line `(ii) in the case of the owner of a warehouse, or a clearing, booking or forwarding agent, or a`
  line `person engaged in the business of transporting goods, mean properly entered in such registers and`
  line `accounts as may be prescribed under sub-section (2) of section 59.`
  line
  line `(8) The provisions of the Code of Criminal Procedure, 1973 (2 of 1974), relating to searches and seizure`
  line `shall apply, so far as may be, to searches and seizure under this section.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (67190)
  sectionNo (57)
  orderNo 57
  title `Cross checking or verification of transactions.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67190&sectionno=57&orderno=57&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_57_content:
  string
  line `(1) With a view to preventing evasion of tax`
  line `payable under this Act and ensuring proper compliance with the provisions of this Act, the prescribed`
  line `authority may, from time to time, collect information regarding sales and purchases effected by any class`
  line `of dealers and cause any of such transactions of sale and purchase to be cross-checked.`
  line
  line `(2) For this purpose, the prescribed authority may, from time to time and by issuing a notice, in the`
  line `manner and form prescribed, require any class of dealers to furnish, before such authority and by such date`
  line `as may be specified in the said notice, such information, details and particulars as may be specified in the`
  line `notice, regarding the transactions of sales and purchases effected by the dealers during the period mentioned`
  line `in the said notice.`
  line
  line `(3) The prescribed authority shall cause any of such transactions to be cross-checked with reference to`
  line `the books of account of the purchasing and selling dealers and for this purpose, the prescribed authority`
  line `shall send an intimation required for the purpose of cross-checking, stating therein the details of the`
  line `transactions proposed to be cross-checked and the time and date on which any officer or person duly`
  line `authorised to cross check the transaction shall visit the place where the books of account are ordinarily kept`
  line `by the dealer.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (67191)
  sectionNo (58)
  orderNo 58
  title Survey.
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67191&sectionno=58&orderno=58&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_58_content:
  string
  line `(1) With a view to identifying dealers who are liable to pay tax under this Act, but have`
  line `remained unregistered, the prescribed authority, shall, from time to time, cause a survey of unregistered`
  line `dealers to be done for this purpose.`
  line
  line `(2) For the purposes of the survey, the prescribed authority may, by notice in the prescribed form,`
  line `require any dealer or class of dealers to furnish the names, addresses and other particulars, in the manner`
  line `specified, of the persons and dealers who have purchased or sold any goods from, or, to, such dealer or`
  line `class of dealers during a given period.`
  line
  line `(3) For the purposes of survey, the prescribed authority may call for, by notice in the prescribed form,`
  line `details and particulars regarding the services provided by public utilities, financial institutions including`
  line `banking companies, clearing and forwarding agents, owners of warehouses, dalals and persons engaged in`
  line `the business of transporting goods which such authority is of the opinion, shall be relevant and useful for`
  line `the purposes of this Act.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (67192)
  sectionNo (59)
  orderNo 59
  title `Control on clearing, forwarding or booking agent and any person transporting goods.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67192&sectionno=59&orderno=59&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_59_content:
  string
  line `(1)`
  line `Every clearing, forwarding or booking agent or dalal or a person transporting goods, who during course of`
  line `his business handles the document of title to the goods or transports goods or takes delivery of goods for or`
  line `on behalf of a dealer and having his place of business in the State of Bihar, shall furnish true and complete`
  line `particulars and information relating to his place of business to the prescribed authority, within such time`
  line `and in such manner as may be prescribed.`
  line
  line `(2) Every agent or person referred to in sub-section (1), shall maintain true and complete accounts,`
  line `registers and documents, as may be prescribed, in respect of the goods handled by him and the documents`
  line `of title relating thereto and shall produce the said accounts, registers and documents before the prescribed`
  line `authority as and when required by him.`
  line
  line `(3) If any agent or person referred to in sub-section (1) contravenes the provisions of sub-section (1) or`
  line `sub-section (2) in a manner which is likely to lead to evasion of any tax payable under this Act, the`
  line `prescribed authority may, without prejudice to any action under section 81, on charge of abetment, after`
  line `giving such agent or person an opportunity of being heard, direct him to pay by way of penalty an amount`
  line `which shall be equal to three times the amount of tax calculated on the value of goods in respect of which`
  line `complete particulars have not been furnished or incorrect particulars or information have been furnished.`
  line
  line `Explanation.--For the purposes of this sub-section--`
  line
  line `(a) "dalal" shall include a person who renders his services for booking of, or taking delivery of,`
  line `consignment of goods at a railway station, booking agency, goods transport company office, or any`
  line `place of loading or unloading of goods or contrives, makes and concludes bargains and contracts for or`
  line `on behalf of any dealer for a fee, reward, commission, remuneration or other valuable consideration or`
  line otherwise;
  line
  line `(b) "person transporting goods" shall, besides the owner, include the manager, agent, driver or`
  line `employee of the owner, or person in-charge of a place of loading or unloading of goods other than a`
  line `rail-head, or a post office, or of a goods carrier carrying such goods, or a person who accepts`
  line `consignments of such goods for despatch to other places or gives delivery of any consignment of such`
  line `goods to the consignee.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (67193)
  sectionNo (60)
  orderNo 60
  title `Establishment of check-posts.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67193&sectionno=60&orderno=60&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_60_content:
  string
  line `(1) The State Government may, by notification, set up and erect,`
  line `in such manner as may be prescribed, check-posts and barriers at any place in the State with a view to`
  line `preventing evasion of tax payable under this Act.`
  line
  line `(2) Every person transporting goods, other than those specified in Schedule I and subject to such`
  line `conditions as may be prescribed, shall, at any check-post or barrier, referred to in sub-section (1) and before`
  line `crossing such check-post or barrier, file before such authority or officer as may be authorised by the State`
  line `Government in this behalf, a correct and complete declaration in such form and manner as may be`
  line prescribed.
  line
  line `(3) Any authority or officer who may be authorised by the State Government in this behalf, may, for`
  line `the purpose of verifying, whether any goods are being transported in contravention of the provisions of subsection (2) and in such manner as may be prescribed, intercept, detain and search any goods carrier; and the`
  line `person, transporting goods or for the time being in-charge of goods, shall render all possible assistance to`
  line `such authority or officer in carrying out the search.`
  line
  line `(4) (a) The authority or any officer referred to in sub-section (3) may seize any goods along with the`
  line `vehicle or carrier, which, he suspects, are being transported in contravention of the provisions of`
  line `sub-section (2) together with any container or material for the packing of such goods:`
  line
  line `Provided that a list of all the goods seized under this sub-section shall be prepared by such officer and`
  line `be signed by the officer, the dealer or the person in-charge of goods and not less than two witnesses and a`
  line `copy of the seizure list shall be made over to the dealer or the person in charge of the goods, as the case`
  line `may be.`
  line
  line `(b) The provisions of section 56 shall, mutatis mutandis, apply in matters relating to such seizure,`
  line `penalty, security, release and confiscation of goods.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (67194)
  sectionNo (61)
  orderNo 61
  title `Restriction on movement of goods.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67194&sectionno=61&orderno=61&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_61_content:
  string
  line `(1) A person transporting goods--`
  line
  line `(a) from any place outside the State of Bihar to any place inside the State of Bihar, or`
  line
  line `(b) from any place inside the State of Bihar to any place outside the State of Bihar, or`
  line
  line `(c) from any place within the State of Bihar to any other such place,`
  line
  line `shall carry a declaration in such form as may be prescribed supported by a cash memo, retail invoice, bill`
  line `or tax invoice, as the case may be, in case the movement is as a result of sale or a challan in case the`
  line `movement is otherwise than as a result of sale, in respect of goods which are being transported on a goods`
  line `carrier, vehicle or a vessel or is otherwise in transit or in transit storage and shall produce such cash memo`
  line `or bill or tax invoice or challan, as the case may be, along with the aforesaid form of declaration on demand`
  line `before the prescribed authority:`
  line
  line `Provided that the Commissioner may exempt, by notification in the Official Gazette, consignments`
  line `below a particular value or quantity from the requirement of this sub-section in so far as it relates to carrying`
  line `of a declaration.`
  line
  line `(2) Any authority or officer who may be authorised by the State Government in this behalf may, for the`
  line `purpose of verifying whether any goods are being transported in contravention of the provisions of subsection (1) intercept, detain and search any goods carrier, vehicle or vessel and may also search the`
  line `warehouse or godown or any other such place of transit storage, where goods are kept in course of`
  line `transportation and if the said authority is satisfied on such verification and search that transportation of`
  line `goods is being made in contravention of the provision of sub-section (1), he may seize any such goods`
  line `together with any container or material for the packing of such goods:`
  line
  line `Provided that a list of all the goods seized under this sub-section shall be prepared by such officer and`
  line `be signed by the officer, the dealer or the person in-charge of goods and not less than two witnesses and a`
  line `copy of the seizure list shall be made over to the dealer or the person in charge of the goods, as the case`
  line `may be.`
  line
  line `(3) The provisions of section 56 shall, mutatis mutandis, apply in matters relating to such seizure,`
  line `penalty, security, release and confiscation of goods.`
  line
  line `Explanation.--For the purposes of this section, the power to seize any goods shall also include the power`
  line `to seize the goods carrier on which the goods are being transported.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (67195)
  sectionNo (62)
  orderNo 62
  title `Transportation of goods through State of Bihar.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67195&sectionno=62&orderno=62&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_62_content:
  string
  line `(1) If any consignment of goods is being`
  line `transported by road from a place outside the State of Bihar to another such place and the vehicle carrying`
  line `the consignment passes through the territory of the State, the driver or any other person in-charge of the`
  line `vehicle shall obtain transit permission in the prescribed manner from the authority of the first check-post`
  line `falling en route after entry into the State and shall surrender the same transit permission to the authority of`
  line `the last check-post before leaving the State and in the event of failure to do so within seventy-two hours of`
  line `leaving the first check-post falling en route, it shall be deemed that goods so transported have been sold by`
  line `the owner or the person in-charge of the vehicle within the State of Bihar.`
  line
  line `(2) In case the driver or person referred to in sub-section (1) fails to comply with the provisions of subsection (1), he shall be liable to pay penalty at the rate of rupees five hundred for every day of the default`
  line `or a sum twice the amount of tax calculated on the value of the goods transported in contravention of that`
  line `sub-section, whichever is higher:`
  line
  line `Provided that no such penalty shall be levied without giving the person an opportunity of being heard:`
  line
  line `Provided further that if the person proceeded against, justifies, beyond any doubt, the reasons for any`
  line `delay exceeding seventy-two hours, the prescribed authority shall, for reasons to be recorded in writing,`
  line `condone the delay.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (67196)
  sectionNo (63)
  orderNo 63
  title `Liability to pay tax in case of transfer of business.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67196&sectionno=63&orderno=63&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_63_content:
  string
  line `(1) When the ownership of the business of a dealer liable to pay tax under this Act is entirely transferred, the transferor and the transferee, shall jointly and severally be liable to pay any tax, interest and penalty, if any, payable in respect of such business and remaining unpaid at the time of the transfer and the transferee shall also be liable to pay tax on sales or purchases made by the transferee on and from the date of such transfer and shall forthwith apply for the grant of a registration certificate unless such certificate is already possessed by him.`
  line `(2) Where a dealer liable to pay tax under this Act transfers the ownership or a part of his business, the transferor shall be liable to pay tax in respect of the stock of goods transferred with that part of the business.`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (67197)
  sectionNo (64)
  orderNo 64
  title `Tax payable by deceased dealer shall be paid by his representative.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67197&sectionno=64&orderno=64&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_64_content:
  string
  line `(1) Where a dealer dies`
  line `after assessment but before payment of the tax, interest or penalty payable by him under this Act, his`
  line `executor, administrator, successor-in-interest or legal representative shall be liable to pay out of the property`
  line `of the deceased, to the extent to which it is capable of meeting the charge, the amount payable by such`
  line dealer.
  line
  line `(2) When a dealer dies without having furnished the return under section 24 or after having furnished`
  line `the return but before assessment, the prescribed authority may proceed to make an assessment and`
  line `determine the amount payable under this Act by the deceased and for the said purpose he may require the`
  line `executor, administrator, successor-in interest or legal representative, as the case may be, of the deceased to`
  line `perform all or any of the obligations, which he might, under the provisions of this Act, have required the`
  line `deceased to perform and the amount thus determined shall be payable by the executor, administrator,`
  line `successor-in-interest or legal representative of the deceased to the extent to which the property of the`
  line `deceased is capable of meeting the charge.`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (67198)
  sectionNo (65)
  orderNo 65
  title `Tax-liability of guardian and trustee, etc.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67198&sectionno=65&orderno=65&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_65_content:
  string
  line `Where the business in respect of which tax is payable`
  line `under this Act is carried on by, or is in charge of, any guardian, trustee or agent of a minor or other`
  line `incapacitated person on behalf of and for the benefit of, such minor or other incapacitated person, the tax`
  line
  line `shall be assessed upon and recoverable from such guardian, trustee or agent, as the case may be, in the`
  line `manner and to the same extent as it would be leviable upon and recoverable from any such minor or`
  line `incapacitated person, if he were of full age and sound mind, and if he were conducting the business himself`
  line `and all the provisions of this Act shall apply accordingly`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (67199)
  sectionNo (66)
  orderNo 66
  title `Tax-liability of court of wards.`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67199&sectionno=66&orderno=66&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_66_content:
  string
  line `Where the estate or any portion thereof of a dealer owning a`
  line `business in respect of which tax is payable under this Act is under the control of the court of wards, the`
  line `Administrator- General, the official trustee, or any receiver or manager, including any person, whatever his`
  line `designation who in fact manages the business, appointed by, or under the order of a court, the tax shall be`
  line `assessed upon and recoverable from such court of wards, Administrator-General, official trustee, receiver`
  line `or manager in like manner and to the same extent as it would be assessable upon and recoverable from the`
  line `dealer if he were conducting the business himself; and all the provisions of this Act shall apply accordingly.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (67200)
  sectionNo (67)
  orderNo 67
  title `Liability in case of dissolution of firm, etc.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67200&sectionno=67&orderno=67&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_67_content:
  string
  line `Where a dealer is a Hindu undivided family, firm or`
  line `association of persons, and such family, firm or association is partitioned, dissolved or disrupted, as the`
  line `case may be--`
  line
  line `(a) the tax, interest and penalty payable under this Act by such family, firm or association of persons`
  line `for the period up to the date of such partition, dissolution or disruption may be assessed as if no partition,`
  line `dissolution or disruption had taken place and all the provisions of this Act shall apply accordingly; and`
  line
  line `(b) every person who was at the time of such partition, dissolution or disruption a member or partner`
  line `of a Hindu undivided family, firm or association of persons shall, notwithstanding such partition,`
  line `dissolution or disruption, be liable severally and jointly for the payment of tax, interest including`
  line `penalty, if any, payable under this Act, by such family, firm or association of persons, whether dues of`
  line `tax, interest or penalty is for the period prior to or after such partition, dissolution or disruption`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (67201)
  sectionNo (68)
  orderNo 68
  title Refunds.
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67201&sectionno=68&orderno=68&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_68_content:
  string
  line `(1) Subject to the other provisions of this Act and the rules made thereunder, the`
  line `prescribed authority shall refund to a person the amount of tax, penalty and interest, if any, paid by such`
  line `person in excess of the amount due from him in such manner as may be prescribed.`
  line
  line `(2) Where on account of death, incapacity, insolvency liquidation or other cause a person is unable to`
  line `claim or receive any refund due to him, his legal representative or the trustee or guardian or receiver, as the`
  line `case may be, shall be entitled to claim or receive such refund in the manner prescribed:`
  line
  line `Provided that the prescribed authority shall first apply such excess amount towards the recovery of any`
  line `amount for any period in respect of which a notice under section 39 has been issued and shall then refund`
  line `the balance, if any.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (67202)
  sectionNo (69)
  orderNo 69
  title `Provisional refunds.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67202&sectionno=69&orderno=69&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_69_content:
  string
  line `(1) If a registered dealer files any returns or produces any other evidence as`
  line `required by or under this Act, and the return or evidences produced show any amount to be refundable to`
  line `the dealer, then the dealer may apply in the prescribed form to the prescribed authority for grant of`
  line `provisional refund.`
  line
  line `(2) The prescribed authority may require the said dealer to furnish such security as may be prescribed`
  line `for an amount equal to the amount of refund and on receipt of such security, the prescribed authority shall,`
  line `subject to rules, grant the dealer a provisional refund of the amount claimed refundable as aforesaid.`
  line
  line `(3) (a) Subject to other provisions of this Act, the refund under sub-section (1) shall be deemed to be`
  line `final if the dealer has no liability under the Act as per his annual return filed under section 24 and the report`
  line `submitted under sub-section (2) of section 54.`
  line
  line `(b) Upon the said refund being final, the security, if any, furnished under sub-section (2) shall be`
  line `returned to the said dealer.`
  line
  line `(c) If any amount in excess of the amount refunded under sub-section (1) is found to be payable by the`
  line `said dealer in respect of the period for which he had claimed and was allowed such provisional refund, such`
  line `excess shall be recovered as arrears of tax from the dealer and he shall be liable to pay simple interest on`
  line `such excess amount at the rate of one and half per cent. per month or part thereof from the date of grant of`
  line `provisional refund till the date of the payment of such excess amount.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (67203)
  sectionNo (70)
  orderNo 70
  title `Interest on delayed refund.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67203&sectionno=70&orderno=70&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_70_content:
  string
  line `(1) Where an amount required to be refunded by the prescribed`
  line `authority to any person is not refunded to him or the application for refund is not rejected, as the case may`
  line `be, within ninety days of the amount having become refundable, the prescribed authority shall pay such`
  line `person simple interest at the rate of six per cent. per annum or part thereof on the said amount from the date`
  line `immediately following the expiry of the period of ninety days to the date of the refund:`
  line
  line `Provided that where the amount becomes refundable by virtue of an order of the Tribunal or the High`
  line `Court or the Supreme Court, the interest under the provisions of this section shall be payable from the date`
  line `immediately following the expiry of the period of ninety days from the date of receipt of the order of the`
  line `Tribunal, the High Court or the Supreme Court, by the officer whose order forms the subject matter of the`
  line `proceedings before the Tribunal, the High Court or the Supreme Court, to the date of refund.`
  line
  line `(2) If the delay in granting the refund within the period of ninety days aforesaid is attributable to the`
  line `said person, whether wholly or in part, the period of the delay attributable to him shall be excluded from`
  line `the period for which interest is payable.`
  line
  line `(3) Where any question arises as to the period to be excluded for the purposes of calculation of interest`
  line `under the provisions of this section, such question shall be determined by the Commissioner, whose`
  line `decision shall be final.`
obj_root_law_sections_70_footnotes:
  string
  line
obj_root_law_sections_71:
  sectionId (67204)
  sectionNo (71)
  orderNo 71
  title `Power to withhold refund in certain cases.`
  content obj_root_law_sections_71_content
  footnotes obj_root_law_sections_71_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67204&sectionno=71&orderno=71&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_71_content:
  string
  line `Where an order giving rise to a refund is the subjectmatter of an appeal or further proceeding or where any other proceeding under this Act is pending, and the`
  line `authority competent to grant such refund is of the opinion that the grant of the refund is likely to adversely`
  line `affect the revenue, such authority (not being the Commissioner) with the previous approval of the`
  line `Commissioner may withhold the refund till such time as is deemed fit:`
  line
  line `Provided that the Commissioner may, on application or otherwise, order for release of such refund if`
  line `he is of the opinion that the situation does not require such action on the part of the prescribed authority.`
obj_root_law_sections_71_footnotes:
  string
  line
obj_root_law_sections_72:
  sectionId (67205)
  sectionNo (72)
  orderNo 72
  title `Appeal to Deputy Commissioner and Joint Commissioner.`
  content obj_root_law_sections_72_content
  footnotes obj_root_law_sections_72_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67205&sectionno=72&orderno=72&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_72_content:
  string
  line `(1) Subject to such rules as may be`
  line `made by the State Government under this Act, any dealer, objecting to an order of assessment or an order`
  line `levying interest or penalty passed by the prescribed authority against him, or an order under section 25 or`
  line `a person, objecting to an order of penalty passed against him or an order under section 47, may appeal to`
  line `the Joint Commissioner, or, the Deputy Commissioner specially authorised in this behalf.`
  line
  line `(2) No appeal under sub-section (1) shall be admitted unless the dealer objecting to an order of`
  line `assessment has paid twenty-five per cent. of the tax assessed or full amount of admitted tax, whichever is`
  line higher.
  line
  line `(3) Every appeal under this section shall be filed, in such form and the manner, as may be prescribed,`
  line `within forty-five days of the receipt of the notice of demand but where the appellate authority is satisfied`
  line `that the appellant had sufficient reason for not preferring the appeal within time, it may condone the delay.`
  line
  line `(4) The appellate authority while disposing of an appeal against an order, other than an order under`
  line `section 47, may--`
  line
  line `(a) (i) confirm, annul, reduce, enhance or otherwise modify such order; or`
  line
  line `(ii) set aside the order directing the authority below to make fresh order after further enquiry on`
  line `specific points as directed; and`
  line
  line `(b) in other cases, pass such order as it may, for reasons to be recorded in writing, deem fit.`
  line
  line `(5) No order under this section shall be passed without giving reasonable opportunity of hearing to the`
  line `appellant as also the authority whose order has been appealed against.`
obj_root_law_sections_72_footnotes:
  string
  line
obj_root_law_sections_73:
  sectionId (67206)
  sectionNo (73)
  orderNo 73
  title `Appeal to Tribunal.`
  content obj_root_law_sections_73_content
  footnotes obj_root_law_sections_73_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67206&sectionno=73&orderno=73&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_73_content:
  string
  line `(1) Subject to such rules as may be made by the State Government, any of`
  line `the authorities mentioned in section 10 or any person aggrieved by an order made by the Deputy`
  line `Commissioner or Joint Commissioner under section 72 or the Commissioner under section 74 or section`
  line `77, may, prefer an appeal to the Tribunal.`
  line
  line `(2) Where an appeal is preferred by a dealer, such appeal shall not be entertained by the Tribunal unless`
  line `such dealer has deposited in the manner specified by the Tribunal, twenty-five per cent. of the amount in`
  line `dispute:`
  line
  line `Provided that the Tribunal may, for reasons to be recorded in writing, waive or reduce the amount`
  line `required to be deposited under this section.`
  line
  line `(3) Every application for appeal under this section shall be filed within ninety days of the`
  line `communication of the order which is sought to be appealed, but where the Tribunal is satisfied that the`
  line `applicant had sufficient cause for not applying within time, it may condone the delay.`
  line
  line `(4) No order under this section shall be passed without giving the applicant as also the authority whose`
  line `order is sought to be appealed or their representative a reasonable opportunity of being heard.`
  line
  line `(5) On receipt of an appeal under sub-section (1), the Tribunal may, after giving the parties to the`
  line `appeal, an opportunity of being heard, pass such order thereon as it thinks fit, confirming, modifying or`
  line `setting aside the order appealed against.`
  line
  line `(6) The Tribunal shall send the copy of every order made by it to the parties to the appeal and to the`
  line `concerned authority against whose order the appeal had been preferred.`
  line
  line `(7) The appeal filed before the Tribunal under sub-section (1) shall be dealt with by it as expeditiously`
  line `as possible and endeavour shall be made by it to dispose of the appeal finally within six months from the`
  line `date of receipt of the appeal.`
obj_root_law_sections_73_footnotes:
  string
  line
obj_root_law_sections_74:
  sectionId (67207)
  sectionNo (74)
  orderNo 74
  title `Revisionary powers of Commissioner.`
  content obj_root_law_sections_74_content
  footnotes obj_root_law_sections_74_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67207&sectionno=74&orderno=74&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_74_content:
  string
  line `The Commissioner may, suo motu, call for and examine`
  line `the record of any proceeding recorded by any authority, officer or person subordinate to him under this Act`
  line `and if he considers that any order passed therein is erroneous in so far as it is prejudicial to the interest of`
  line `revenue, pass such order as he deems fit after giving the dealer or the person concerned an opportunity of`
  line `being heard.`
obj_root_law_sections_74_footnotes:
  string
  line
obj_root_law_sections_75:
  sectionId (67208)
  sectionNo (75)
  orderNo 75
  title `Additional evidence in appeal or revision.`
  content obj_root_law_sections_75_content
  footnotes obj_root_law_sections_75_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67208&sectionno=75&orderno=75&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_75_content:
  string
  line `A dealer shall not be entitled to produce additional`
  line `evidence whether oral or documentary in appeal before the appellate authority or in revision before the`
  line `Commissioner or the Tribunal except where the evidence sought to be adduced is evidence, which the`
  line `prescribed authority had wrongly refused to admit or which, after exercise of due diligence, was not within`
  line `his knowledge or could not be produced by him before the prescribed authority or for the production of`
  line `which adequate time was not given by the prescribed authority and in every such case upon the additional`
  line `evidence being taken on record reasonable opportunity for challenge or rebuttal shall be given.`
obj_root_law_sections_75_footnotes:
  string
  line
obj_root_law_sections_76:
  sectionId (67209)
  sectionNo (76)
  orderNo 76
  title Review.
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67209&sectionno=76&orderno=76&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_76_content:
  string
  line `Subject to such rules as may be made by the State Government under this Act, any`
  line `authority appointed under section 10 or the Tribunal may review any order passed by it, if such review is,`
  line `in the opinion of the said authority or the Tribunal, as the case may be, necessary on account of a mistake`
  line `which is apparent from the record:`
  line
  line `Provided that no such review, if it has the effect of enhancing the tax, interest or penalty or of reducing`
  line `a refund shall be made unless the said authority or the Tribunal, as the case may be, has given the dealer,`
  line `or the person concerned a reasonable opportunity of being heard.`
obj_root_law_sections_76_footnotes:
  string
  line
obj_root_law_sections_77:
  sectionId (67210)
  sectionNo (77)
  orderNo 77
  title `Determination of disputed questions.`
  content obj_root_law_sections_77_content
  footnotes obj_root_law_sections_77_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67210&sectionno=77&orderno=77&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_77_content:
  string
  line `(1) If any question arises, otherwise than in proceedings`
  line `before a court, or before the prescribed authority has commenced assessment of a dealer under section 27`
  line `or section 28 or section 29 or section 30 or section 31 or section 32 or section 33, whether, for the purposes`
  line `of this Act,--`
  line
  line `(a) any person, society, club or association or any firm or any branch or department of any firm, is`
  line `a dealer, or`
  line
  line `(b) any particular thing done to any goods amounts to or results in the manufacture of goods, within`
  line `the meaning of that term, or`
  line
  line `(c) any transaction is a sale or a purchase, or where it is a sale or a purchase the sale price or the`
  line `purchase price, as the case may be, thereof, or`
  line
  line `(d) any particular person or dealer is required to be registered, or`
  line
  line `(e) in the case of any person or dealer liable to pay tax, any tax is payable by such person or dealer`
  line `in respect of any particular sale or purchase, or if tax is payable, the rate thereof, or`
  line
  line `(f) input tax credit can be claimed on any particular transaction of purchase and if it can be claimed,`
  line `what are the conditions and restrictions subject to which such input tax credit can be claimed, or`
  line
  line `(g) the order passed under sub-section (2) of section 25 is just and proper, or`
  line
  line `(h) any other question involving interpretation of any provisions of this Act,`
  line
  line `the Commissioner shall, subject to such rules as may be made, make an order determining such question.`
  line
  line `Explanation.-- For the purposes of this sub-section, the prescribed authority shall be deemed to have`
  line `commenced assessment of the dealer under section 27 or section 28 or section 29 or section 30 or section`
  line `31 or section 32 or section 33, when the dealer is served with any notice by the prescribed authority under`
  line `the said sections.`
  line
  line `(2) The Commissioner may direct that the determination shall not affect the liability of any person`
  line `under this Act, as respect any sale or purchase affected prior to the determination or such date as he may`
  line specify.
  line
  line `(3) If any such question arises from any order already passed by any authority or court under this Act`
  line `or the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94, no such`
  line `question shall be entertained for determination under this section; but such question may be raised in appeal`
  line `against such order.`
obj_root_law_sections_77_footnotes:
  string
  line
obj_root_law_sections_78:
  sectionId (67211)
  sectionNo (78)
  orderNo 78
  title `Power to transfer proceedings.`
  content obj_root_law_sections_78_content
  footnotes obj_root_law_sections_78_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67211&sectionno=78&orderno=78&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_78_content:
  string
  line `(1) The Commissioner may, after giving the parties a reasonable`
  line `opportunity of being heard in the matter, by order in writing after recording his reason for so doing, transfer`
  line `any proceedings or class of proceedings under any provision of this Act, from himself to any other officer`
  line `and he may likewise transfer any such proceeding, including a proceeding pending with any officer or`
  line `already transferred under this section, from any officer to any other officer.`
  line
  line `(2) For the purpose of this section, any proceeding shall be deemed to have commenced only when any`
  line `authority having appropriate jurisdiction issues notice under the provisions of this Act, rules or notifications`
  line `and the proceedings shall be deemed to be pending only after the issue of such notice.`
  line
  line `(3) Where no proceedings are pending before any authority, then any authority having appropriate`
  line `jurisdiction over a person or dealer, may initiate and complete any proceedings whatsoever.`
  line
  line `Explanation.--In this section, the word "proceedings" in relation to any dealer means all proceedings`
  line `under this Act in respect of any year, which may be pending on the date of such order or which may have`
  line `been completed on or before such date, and also includes all proceedings under this Act which may be`
  line `commenced after the date of such order in respect of the said year in relation to such dealer.`
obj_root_law_sections_78_footnotes:
  string
  line
obj_root_law_sections_79:
  sectionId (67212)
  sectionNo (79)
  orderNo 79
  title `Appeal before High Court.`
  content obj_root_law_sections_79_content
  footnotes obj_root_law_sections_79_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67212&sectionno=79&orderno=79&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_79_content:
  string
  line `(1) An appeal shall lie to the High Court from every order passed by`
  line `the Tribunal, if the High Court is satisfied that the case involves a substantial question of law.`
  line
  line `(2) The Commissioner or a dealer aggrieved by any order passed by the Tribunal,`
  line
  line `(i) under the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section`
  line `94, on or after the date of commencement of this Act; or`
  line
  line `(ii) under this Act,`
  line
  line `may file an appeal to the High Court, and such appeal under this section shall be filed within ninety days`
  line `from the date of the communication to the dealer or the Commissioner on any question of law arising out`
  line `of such order./hr`
  line `(3) Where the High Court is satisfied that a substantial question of law is involved in any case, it shall`
  line `formulate the question.`
  line
  line `(4) The appeal shall be heard only on the question so formulated and the respondents shall, at the`
  line `hearing of the appeal, be allowed to argue that the case does not involve such question:`
  line
  line `Provided that nothing in this sub-section shall be deemed to take away or abridge the power of the High`
  line `Court to hear, for reasons to be recorded, the appeal on any other substantial question of law not formulated`
  line `by it, if it is satisfied that the case involves such question.`
  line
  line `(5) (a) The High Court shall decide the substantial question of law so formulated or involved and deliver`
  line `such judgment thereon containing the grounds on which such decision is founded and may award such costs`
  line `as it deems fit.`
  line
  line `(b) The High Court may determine any issue which--`
  line
  line `(i) has not been determined by the Tribunal, or`
  line
  line `(ii) has been wrongly determined by the Tribunal, by reason of a decision on such question of law`
  line `as is referred to in sub-section (1).`
  line
  line `(6) Save as otherwise provided in this Act, the provisions of the Code of Civil Procedure, 1908 (5 of`
  line `1908) relating to appeals to High Court, shall as far as may be, apply in the case of appeals under this`
  line section.
obj_root_law_sections_79_footnotes:
  string
  line
obj_root_law_sections_80:
  sectionId (67213)
  sectionNo (80)
  orderNo 80
  title `Case before High Court to be heard by not less than two Judges.`
  content obj_root_law_sections_80_content
  footnotes obj_root_law_sections_80_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67213&sectionno=80&orderno=80&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_80_content:
  string
  line `(1) When an appeal has been`
  line `filed before the High Court under section 79, it shall be heard by a bench of not less than two Judges of the`
  line `High Court, and shall be decided in accordance with the opinion of such Judges or of the majority, if any,`
  line `of such Judges.`
  line
  line `(2) Where there is no such majority, the Judges shall state the point of law upon which they differ and`
  line `the case shall then be heard upon that point only by one or more of other Judges of the High Court and such`
  line `point shall be decided according to the opinion of the majority of Judges who have heard the case including`
  line `those who first heard it.`
obj_root_law_sections_80_footnotes:
  string
  line
obj_root_law_sections_81:
  sectionId (67214)
  sectionNo (81)
  orderNo 81
  title `Offences and penalties.`
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67214&sectionno=81&orderno=81&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_81_content:
  string
  line `(1) Whoever--`
  line
  line `(a) carries on business as a dealer without being registered in wilful contravention of section 19, or`
  line
  line `(b) fails without sufficient cause to furnish any information required by section 23, or`
  line
  line `(c) fails, without sufficient cause, when directed so to do under section 59, to keep any accounts or`
  line `record in accordance with the directions, or`
  line
  line `(d) fails, without sufficient cause, to furnish any return as required by section 24 by the date and in`
  line `the manner prescribed,`
  line
  line `shall, on conviction, be punished with imprisonment, of either description, for a term which shall not be`
  line `less than three months but which may extend to six months and with fine not exceeding one thousand`
  line rupees.
  line
  line `(2) Whoever--`
  line
  line `(a) knowingly keeps false account of the value of the goods bought or sold by him in contravention`
  line `of sub-section (1) of section 52 or section 53, or`
  line
  line `(b) wilfully attempts, in any manner whatsoever, to evade any payment of any tax, penalty or`
  line interest,
  line
  line `shall, on conviction, be punished with imprisonment, of either description, for a term which shall not be`
  line `less than six months but which may extend to one year and with fine not exceeding two thousand rupees.`
  line
  line `(3) Whoever--`
  line
  line `(a) not being a registered dealer under section 19, falsely represents that he is or was a registered`
  line `dealer at the time when he sells or buys goods; or`
  line
  line `(b) knowingly furnishes a false return; or`
  line
  line `(c) knowingly produces before the prescribed authority, false bill, tax invoice, cash-memorandum,`
  line `voucher, declaration, certificate or other document for any of the purposes of this Act; or`
  line
  line `(d) issues to any person a certificate or declaration under this Act or the rules framed or notifications`
  line `issued thereunder, a bill, cash memorandum, tax invoice, voucher or other document which he knows`
  line `or has reason to believe to be false; or`
  line
  line `(e) obstructs any officer making inspection or search or seizure under section 56 or section 61 or`
  line `section 62,`
  line
  line `shall, on conviction, be punished with imprisonment, of either description, for a term which shall not be`
  line `less than one year but which may extend to three years and with fine not exceeding three thousand rupees.`
  line
  line `(4) Whoever aids or abets any person in the commission of any offence specified in sub-section (1) or`
  line `sub-section (2) or sub-section (3) shall, on conviction, be liable for punishment of the description specified`
  line `in respect of the offence in the commission of which he has aided or abetted.`
  line
  line `(5) Notwithstanding anything contained in sub-sections (1) to (4), no person shall be proceeded against`
  line `under these sub-sections for the commission of the offences referred therein if the total amount of tax,`
  line `interest or penalties evaded or attempted to be evaded is less than five thousand rupees.`
  line
  line `(6) Where a dealer is accused of an offence specified in sub-section (1) or sub-section (2) or sub-section`
  line `(3), the person declared as manager of the business of the dealer under section 22 shall also be deemed to`
  line `be guilty of such offence, unless he proves that the offence was committed without his knowledge or that`
  line `he had exercised all due diligence to prevent the commission thereof.`
obj_root_law_sections_81_footnotes:
  string
  line
obj_root_law_sections_82:
  sectionId (67215)
  sectionNo (82)
  orderNo 82
  title `Cognizance of offences.`
  content obj_root_law_sections_82_content
  footnotes obj_root_law_sections_82_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67215&sectionno=82&orderno=82&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_82_content:
  string
  line `(1) Save as provided in section 81, the punishments inflicted under the`
  line `said section shall be without prejudice to any penalty which may be imposed under the provisions of this`
  line Act.
  line
  line `(2) No court shall take cognizance of any offence under this Act except with the previous sanction of`
  line `the Commissioner or any officer specially empowered in this behalf and no court inferior to that of a`
  line `Magistrate of the first class shall try any such offence.`
  line
  line `(3) Notwithstanding anything contained in the Code of Criminal Procedure, 1973 (2 of 1974), all`
  line `offences punishable under section 81 shall be cognizable and bailable.`
obj_root_law_sections_82_footnotes:
  string
  line
obj_root_law_sections_83:
  sectionId (67216)
  sectionNo (83)
  orderNo 83
  title `Investigation of offences.`
  content obj_root_law_sections_83_content
  footnotes obj_root_law_sections_83_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67216&sectionno=83&orderno=83&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_83_content:
  string
  line `(1) Subject to such conditions as may be prescribed, the Commissioner`
  line `may authorise either generally or in respect of a particular case or class of cases, any officer or person`
  line `subordinate to him to investigate all or any of the offences punishable under this Act.`
  line
  line `(2) Every officer so authorised shall, in the conduct of such investigation, exercise the powers conferred`
  line `by the Code of Criminal Procedure, 1973 (2 of 1974) upon an officer in-charge of a police station for the`
  line `investigation of a cognizable offence.`
obj_root_law_sections_83_footnotes:
  string
  line
obj_root_law_sections_84:
  sectionId (67217)
  sectionNo (84)
  orderNo 84
  title `Offences by companies and others.`
  content obj_root_law_sections_84_content
  footnotes obj_root_law_sections_84_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67217&sectionno=84&orderno=84&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_84_content:
  string
  line `(1) Where an offence under this Act has been committed by`
  line `a company, every person who at the time the offence was committed, was in charge of, and was responsible`
  line `to, the company for the conduct of business of the company as well as the company shall be deemed to be`
  line `guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that, nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act if he proves that the offence was committed without his knowledge or that`
  line `he had exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.–For the purposes of this section--`
  line
  line `(a) "company" means a company incorporated under the Companies Act, 1956 (1 of 1956), and`
  line `includes a body corporate, a firm or other association of individuals;`
  line
  line `(b) "director" in relation to a firm means a partner in the firm.`
  line
  line `(3) Where an offence under this Act has been committed by a Hindu undivided family, the karta thereof`
  line `shall be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render the karta liable to any punishment if he`
  line `proves that the offence was committed without his knowledge or that he had exercised all due diligence to`
  line `prevent the commission of such offence:`
  line
  line `Provided further that, where an offence under this Act has been committed by a Hindu undivided family`
  line `and it is proved that the offence has been committed with the consent or connivance of, or is attributable to`
  line `any neglect on the part of, any adult member of the Hindu undivided family, such member shall also be`
  line `deemed to be guilty of that offence and shall be liable to be proceeded against and on conviction punished`
  line accordingly.
obj_root_law_sections_84_footnotes:
  string
  line
obj_root_law_sections_85:
  sectionId (67218)
  sectionNo (85)
  orderNo 85
  title `Compounding of offences.`
  content obj_root_law_sections_85_content
  footnotes obj_root_law_sections_85_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67218&sectionno=85&orderno=85&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_85_content:
  string
  line `(1) The Commissioner may, either before or after the institution of`
  line `proceedings under section 81, accept from any person charged with an offence under sub-section (1) or`
  line `sub-section (2) or sub-section (3) or sub-section (4) of the said section by way of composition of the offence,`
  line `a sum not exceeding ten thousand rupees and where the offence charged was likely to cause or caused`
  line `evasion of any amount of tax payable under this Act, a sum not exceeding three times of such amount,`
  line `whichever is higher.`
  line
  line `(2) On payment of such sum as may be determined by the Commissioner under sub-section (1), no`
  line `further proceeding shall be taken against the accused person in respect of the same offence.`
obj_root_law_sections_85_footnotes:
  string
  line
obj_root_law_sections_86:
  sectionId (67219)
  sectionNo (86)
  orderNo 86
  title `Bureau of Investigation.`
  content obj_root_law_sections_86_content
  footnotes obj_root_law_sections_86_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67219&sectionno=86&orderno=86&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_86_content:
  string
  line `(1) The State Government may, by an order published in the Official`
  line `Gazette, constitute a Bureau of Investigation and it shall consist of such personnel and such number of`
  line `officers and such hierarchy of supervision and control as may be specified by the State Government in the`
  line `said order:`
  line
  line `Provided that if authorities appointed under sub-section (1) of section 10 are specified as such they`
  line `shall, without prejudice to the powers under sub-section (1) of section 10, exercise the powers of an`
  line `authority under sections 55, 56, 57, 58, 59, 60, 61 and 62 for carrying out the purposes of this Act.`
  line
  line `(2) (a) The State Government may, by an order published in the Official Gazette, vest an officer of the`
  line `Bureau of Investigation with the powers of an officer in-charge of a police station under the Code of`
  line `Criminal Procedure, 1973 (2 of 1974) and with such other powers under different Acts, as it may consider`
  line necessary.
  line
  line `(b) The Commissioner may, by an order published in the Official Gazette, authorise an officer of the`
  line `Bureau of Investigation to exercise the powers of an authority appointed under section 10 in respect of such`
  line `matters as may be specified in the order.`
  line
  line `(3) The Bureau of Investigation shall function under the control and supervision of the Commissioner,`
  line `and discharge such duties as may be assigned to it by the Commissioner, including investigation of offences`
  line `under section 83 of this Act.`
obj_root_law_sections_86_footnotes:
  string
  line
obj_root_law_sections_87:
  sectionId (67220)
  sectionNo (87)
  orderNo 87
  title `Appearance before taxing authorities.`
  content obj_root_law_sections_87_content
  footnotes obj_root_law_sections_87_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67220&sectionno=87&orderno=87&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_87_content:
  string
  line `Any person, who is required to appear before any`
  line `authority appointed under section 10 or before the Tribunal or before an officer of the Bureau of`
  line `Investigation constituted under section 86 in connection with any proceeding under this Act, may appear`
  line `before such authority through--`
  line
  line `(a) a person authorised in the prescribed manner by him in this behalf, being his relative or person`
  line `in his regular and whole time employment,`
  line
  line `(b) a sales tax practitioner who possesses the prescribed qualifications; or`
  line
  line `(c) a legal practitioner, or`
  line
  line `(d) subject to such conditions as may be prescribed, a chartered accountant, or company secretary,`
  line `or cost accountant.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "chartered accountant" means a chartered accountant as defined in clause (b) of sub-section (1)`
  line `of section 2 of the Chartered Accountants Act, 1949 (38 of 1949) and who has obtained a certificate of`
  line `practice under sub-section (1) of section 6 of that Act;`
  line
  line `(b) "company secretary" means a company secretary as defined in clause (c) of sub-section (1) of`
  line `section 2 of the Company Secretaries Act, 1980 (56 of 1980) and who has obtained a certificate of`
  line `practice under sub-section (1) of section 6 of that Act;`
  line
  line `(c) "cost accountant" means a cost accountant as defined in clause (b) of sub-section (1) of section`
  line `2 of the Cost and Works Accountants Act, 1959 (23 of 1959) and who has obtained a certificate of`
  line `practice under sub-section (1) of section 6 of that Act;`
  line
  line `(d) "legal practitioner" means an advocate, vakil or an attorney of any High Court, and includes a`
  line `pleader in practice.`
obj_root_law_sections_87_footnotes:
  string
  line
obj_root_law_sections_88:
  sectionId (67221)
  sectionNo (88)
  orderNo 88
  title `Change of an incumbent of an office.`
  content obj_root_law_sections_88_content
  footnotes obj_root_law_sections_88_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67221&sectionno=88&orderno=88&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_88_content:
  string
  line `Whenever, in respect of any proceeding under this Act, any`
  line `person or authority appointed under section 10 ceases to exercise jurisdiction and is succeeded by another`
  line `person who has and exercises jurisdiction, the person so succeeding may continue the proceeding from the`
  line `stage at which the proceeding was left by his predecessor:`
  line
  line `Provided that the dealer concerned may demand that before the proceeding is so continued, the previous`
  line `proceeding or any part thereof be reopened or that before any order is passed against him, he be heard.`
obj_root_law_sections_88_footnotes:
  string
  line
obj_root_law_sections_89:
  sectionId (67222)
  sectionNo (89)
  orderNo 89
  title `Bar to certain proceedings.`
  content obj_root_law_sections_89_content
  footnotes obj_root_law_sections_89_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67222&sectionno=89&orderno=89&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_89_content:
  string
  line `Save as provided in section 79, no assessment made and no order`
  line `passed under this Act or rules made thereunder by any authority appointed under section 10 or by the Bureau`
  line `of Investigation or by the Tribunal shall be called in question in any court, and save as is provided in section`
  line `72 or section 73 or section 74 or section 76, no appeal or application for revision or review shall lie against`
  line `any such assessment or order.`
obj_root_law_sections_89_footnotes:
  string
  line
obj_root_law_sections_90:
  sectionId (67223)
  sectionNo (90)
  orderNo 90
  title `Disclosure of information by public servant.`
  content obj_root_law_sections_90_content
  footnotes obj_root_law_sections_90_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67223&sectionno=90&orderno=90&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_90_content:
  string
  line `(1) All particulars contained in any statement made,`
  line `return furnished or accounts or documents produced in accordance with this Act, or in any record of`
  line `evidence given in the course of any proceedings under this Act (other than proceeding before a criminal`
  line `court), or in any record of any assessment proceeding, or any proceeding relating to the recovery of a`
  line `demand, prepared for the purposes of this Act, shall, save as provided in sub-section (3), be treated as`
  line `confidential; and notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872), no`
  line `court shall save as aforesaid, be entitled to require any servant of the Government to produce before it any`
  line `such statement, return, account, document or record or any part thereof, or to give evidence before it in`
  line `respect thereof.`
  line
  line `(2) If, save as provided in sub-section (3), any servant of the Government discloses any of the particulars`
  line `referred to in sub-section (1), he shall, on conviction, be punished with imprisonment, which may extend`
  line `to six months or with fine or with both.`
  line
  line `(3) Nothing in this section shall apply to the disclosure of any of the particulars, referred to in subsection (1), made--`
  line
  line `(a) for the purposes of a prosecution under the Indian Penal Code, 1860 (45 of 1860) in respect of`
  line `any statement, return, accounts, registers, documents or evidence, or any part thereof; or`
  line
  line `(b) for the purposes of a prosecution under this Act; or`
  line
  line `(c) for regulating any inquiry under the Public Servant (Inquiries) Act, 1850 (37 of 1850), into the`
  line `conduct or behaviour of any authority or Inspector appointed under section 10 or an officer of the`
  line `Bureau of Investigation constituted under section 86 or into the behaviour of any other officer appointed`
  line `to conduct such inquiry; or`
  line
  line `(d) in connection with the trial of a suit in a civil court to which the State of Bihar is a party and`
  line `which relates to any matter arising out of any proceeding under this Act; or`
  line
  line `(e) for the purposes of enabling an officer of the Central Government or of any State Government`
  line `to levy or recover any tax or duty imposed by it; or`
  line
  line `(f) to any officer of the State Government where it is necessary to make such disclosure for the`
  line `purposes of this Act; or`
  line
  line `(g) to any officer of the Central Government or of the State Government for the purpose of enabling`
  line `such officer to perform his executive functions relating to the affairs of the Union or the State.`
obj_root_law_sections_90_footnotes:
  string
  line
obj_root_law_sections_91:
  sectionId (67224)
  sectionNo (91)
  orderNo 91
  title `Agreements to defeat intention and application of this Act to be void.`
  content obj_root_law_sections_91_content
  footnotes obj_root_law_sections_91_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67224&sectionno=91&orderno=91&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_91_content:
  string
  line `(1) If the Commissioner`
  line `is satisfied that an arrangement has been entered into between two or more persons or dealers to defeat the`
  line `application or purposes of this Act or any provision of this Act, then, the Commissioner may, by order,`
  line `declare the arrangement to be null and void as regards the application and purposes of this Act and he may,`
  line `by the said order, provide for increase or decrease in the amount of tax payable by any person or dealer`
  line `who is affected by the arrangement, whether or not such dealer or person is a party to the arrangement, in`
  line `such manner as the Commissioner considers appropriate so as to counter act any tax advantage obtained by`
  line `that dealer from or under the arrangement.`
  line
  line `(2) For the purposes of this section--`
  line
  line `(i) "arrangement" includes any contract, agreement, plan or understanding whether enforceable in`
  line `law or not, and all steps and transactions by which the arrangement is sought to be carried into effect;`
  line
  line `(ii) "tax advantage" includes,--`
  line
  line `(a) any reduction in the liability of any dealer to pay tax,`
  line
  line `(b) any increase in the entitlement of any dealer to claim input tax credit or refund,`
  line
  line `(c) any reduction in the sale price or purchase price receivable or payable by any dealer.`
  line
  line `(3) Before passing any order under this section, the Commissioner shall afford a reasonable opportunity`
  line `of being heard to any such person or dealer whose tax advantage is sought to be counter acted.`
obj_root_law_sections_91_footnotes:
  string
  line
obj_root_law_sections_92:
  sectionId (67225)
  sectionNo (92)
  orderNo 92
  title `Write off of dues.`
  content obj_root_law_sections_92_content
  footnotes obj_root_law_sections_92_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67225&sectionno=92&orderno=92&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_92_content:
  string
  line `Notwithstanding anything contained in this Act, the State Government, by`
  line `notification to be published in the Official Gazette, may, subject to such rules as may be prescribed, declare`
  line `any dues created under this Act or the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its`
  line `repeal by section 94, as unrecoverable.`
obj_root_law_sections_92_footnotes:
  string
  line
obj_root_law_sections_93:
  sectionId (67226)
  sectionNo (93)
  orderNo 93
  title `Power to make rules.`
  content obj_root_law_sections_93_content
  footnotes obj_root_law_sections_93_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67226&sectionno=93&orderno=93&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_93_content:
  string
  line `(1) The State Government may, subject to the condition of previous`
  line `publication, by notification, make rules to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may provide`
  line `for all or any of the following matters, namely:--`
  line
  line `(a) the manner in which the advance tax may be collected under sub-section (7) of section 3;`
  line
  line `(b) constitution of the Tribunal under sub-section (1) of section 9;`
  line
  line `(c) the terms and conditions of service of the Chairperson or any other Government servant`
  line `appointed as a member of the Tribunal under sub-section (7) of section 9;`
  line
  line `(d) the areas and functions of inspectors under sub-section (3) of section 10;`
  line
  line `(e) the form and manner in which the true and complete declaration referred to in clause (a) of subsection (2) of section 13 shall be filed;`
  line
  line `(f) the conditions and restrictions subject to which the registered dealers may be permitted to pay`
  line `an amount under sub-section (1) of section 15;`
  line
  line `(g) the conditions and restrictions subject to which an input tax credit shall be claimed under`
  line `sub-section (1) section 16;`
  line
  line `(h) the manner and the period within which the input tax credit in respect of capital goods shall be`
  line `allowed under clauses (a), (b), (c), (d) and (e) of sub-section (1) of section 16;`
  line
  line `(i) the manner in which the input tax credit on the sale or supply of goods shall be claimed by the`
  line `registered dealer selling the goods or using them in the execution of sub-contract under`
  line `sub-section (2) of section 16;`
  line
  line `(j) the other goods on which input tax credit shall not be claimed or allowed under clause (a) of`
  line `sub-section (3) of section 16;`
  line
  line `(k) the particulars of sale in the original copy of the tax invoice and the form and manner of the`
  line `duplicate copy of the original tax invoice under sub-section (5) of section 16;`
  line
  line `(l) the manner in which input tax credit on goods and the manner and extent in which the input tax`
  line `on account of capital assets shall be allowed under sub-section (1) of section 17;`
  line
  line `(m) the restrictions and conditions subject to which and the time and manner in which the`
  line `organisations specified in the Schedule V to this Act may apply for refund of tax paid on goods`
  line `purchased under sub-section (2) of section 17;`
  line
  line `(n) the manner of application for and the grant of certificate of registration under sub-section (2) of`
  line `section 19;`
  line
  line `(o) the manner in which the certificate of registration shall be surrendered and the manner in which`
  line `the certificate of registration shall be cancelled under sub-section (2) of section 20;`
  line
  line `(p) the security and the manner in which such security shall be furnished under section 21;`
  line
  line `(q) the manner in which the declaration shall be furnished and the particulars of the person under`
  line `sub-section (1) of section 22;`
  line
  line `(r) the form and manner in which the returns or statements or notice, as the case may be, under subsections (1), (2), (3), (4) and (7) of section 24 shall be furnished;`
  line
  line `(s) the manner in which the opportunity of being heard is to be provided under sub-section (8) of`
  line `section 24;`
  line
  line `(t) the manner of depositing tax and the form and manner of enclosing the proof of payment of such`
  line `tax under sub-section (9) of section 24;`
  line
  line `(u) the time and manner of scrutiny of return under sub-section (1) of section 25;`
  line
  line `(v) the form of notice to the concerned dealer under sub-section (2) of section 25;`
  line
  line `(w) the form and manner of serving a notice and the time within which the dealer is required to pay`
  line `the tax and interest under clause (b) of sub-section (3) of section 25;`
  line
  line `(x) the manner of conducting an audit of the business of a dealer under sub-section (3) of section`
  line 26;
  line
  line `(y) making of provisional or final assessment of turnover of sale or purchase of goods under subsection (1) of section 30;`
  line
  line `(z) the form and manner of notice and the manner of assessment or re-assessment under subsection (1) of section 31;`
  line
  line `(za) the manner in which the opportunity of being heard is to be provided under sub-section (1) of`
  line `section 32;`
  line
  line `(zb) the manner in which the amount of tax may be provisionally quantified under sub-section (2)`
  line `of section 32;`
  line
  line `(zc) the manner in which the re-assessment may be made under section 33;`
  line
  line `(zd) the other evidence to prove and the form and manner of declaration required to be furnished`
  line `under sub-section (2) of section 35;`
  line
  line `(ze) such other manner of payment of tax and the manner of payment of tax, interest due or the`
  line `penalty by instalments under sub-section (2) of section 39;`
  line
  line `(zf) the manner of payment of penalty under sub-section (5) of section 39;`
  line
  line `(zg) the conditions and restrictions subject to which the deduction of tax may be made under subsection (1) of section 40;`
  line
  line `(zh) the manner of payment of amount into the Government Treasury under sub-section (3) of`
  line `section 40;`
  line
  line `(zi) the conditions subject to which no deduction of tax shall be made under sub-section (1) of`
  line `section 41;`
  line
  line `(zj) the manner in which tax referred to in sub-section (1) of section 41 shall be deducted under`
  line `sub-section (4) of section 41;`
  line
  line `(zk) the form and manner of certificate by the person making deduction under sub-section (5) of`
  line `section 41;`
  line
  line `(zl) the form and manner of granting tax clearance certificate under section 42;`
  line
  line `(zm) the manner in which the opportunity of being heard is to be provided under sub-section (3) of`
  line `section 43;`
  line
  line `(zn) the form of notice by the prescribed authority under sub-section (2) of section 44;`
  line
  line `(zo) the manner of publication of notice and the details therefor under sub-section (4) of`
  line `section 44;`
  line
  line `(zp) the form of application in which the person may claim the refund under sub-section (5) of`
  line `section 44;`
  line
  line `(zq) the manner of keeping a true and complete accounts under sub-section (1) of section 52;`
  line
  line `(zr) the dealers or persons and the manner of drawing up the manufacturing, trading and profit and`
  line `loss account and a balance-sheet and other accounts under sub-section (2) of section 52;`
  line
  line `(zs) the form of challan to be issued by every dealer or a person under sub-section (3) of section`
  line 52;
  line
  line `(zt) the accounts and the manner in which the trading and profit and loss account shall be drawn up`
  line `under sub-section (4) of section 52;`
  line
  line `(zu) the value of goods exceeding which the retail invoice is required to be issued by the dealer`
  line `under sub-section (4) of section 53;`
  line
  line `(zv) the period for which invoices under sub-section (7) of section 53 may be required to be`
  line preserved;
  line
  line `(zw) the conditions and restrictions subject to which a copy of the original tax invoice may be`
  line `provided by the selling dealer under sub-section (8) of section 53;`
  line
  line `(zx) the particulars of the credit note and the debit note under sub-section (9) of section 53;`
  line
  line `(zy) the other period for which the tax invoices and retail invoices are required to be preserved`
  line `under sub-section (10) of section 53;`
  line
  line `(zz) the form of audit report and the particulars thereof under sub-section (2) of section 54;`
  line
  line `(zza) the manner of authorisation to inspect all places of business under sub-section (2) of section`
  line 56;
  line
  line `(zzb) the manner of seizure of accounts, registers or documents under sub-section (3) of section`
  line 56;
  line
  line `(zzc) the manner of seizure of goods under clause (a) of sub-section (4) of section 56;`
  line
  line `(zzd) the manner in which the opportunity of being heard is to be provided under clause (b) of subsection (4) of section 56;`
  line
  line `(zze) the manner of auction of goods and the manner in which the sale proceeds shall be refunded`
  line `under clause (e) of sub-section (4) of section 56;`
  line
  line `(zzf) the manner of release of security under clause (f) of sub-section (4) of section 56;`
  line
  line `(zzg) the manner and form of notice by the prescribed authority under sub-section (2) of`
  line `section 57;`
  line
  line `(zzh) the form of notice by the prescribed authority under sub-sections (2) and (3) of section 58;`
  line
  line `(zzi) the time and manner of furnishing information under sub-section (1) of section 59;`
  line
  line `(zzj) the accounts, registers and documents required to be maintained under sub-section (2) of`
  line `section 59;`
  line
  line `(zzk) the manner of erecting check posts and barriers under sub-section (1) of section 60;`
  line
  line `(zzl) the form and manner of furnishing declaration and the conditions subject to which such`
  line `declaration shall be furnished under sub-section (2) of section 60;`
  line
  line `(zzm) the manner of intercepting, detaining and searching any goods carrier under sub-section (3)`
  line `of section 60;`
  line
  line `(zzn) the form of declaration required by a person transporting goods under sub-section (1) of`
  line `section 61;`
  line
  line `(zzo) the manner of obtaining transit permission under sub-section (1) of section 62;`
  line
  line `(zzp) the manner of refund to a person who paid in excess of the amount due under subsection (1) of section 68;`
  line
  line `(zzq) the manner of claiming or receiving the refund under sub-section (2) of section 68;`
  line
  line `(zzr) the form of application for grant of provisional refund under sub-section (1) of section 69;`
  line
  line `(zzs) the security to be furnished by the dealer under sub-section (2) of section 69;`
  line
  line `(zzt) the form and manner of filing an appeal under section 72;`
  line
  line `(zzu) the conditions subject to which the offences punishable under this Act may be investigated`
  line `under sub-section (1) of section 83;`
  line
  line `(zzv) the manner of authorisation and the conditions subject to which an accountant, company`
  line `secretary or sales tax practitioner may appear before taxing authorities under section 87;`
  line
  line `(zzw) declaration by the State Government relating to any dues as unrecoverable under section 92;`
  line
  line `(zzx) the manner of imposition of penalty for breach of any rules made under this section;`
  line
  line `(zzy) the manner and time in which, the particulars of, and the authority to whom, goods held in`
  line `stock is to be declared under section 95;`
  line
  line `(zzz) the manner of claiming input tax credit under sub-sections (1) and (2) of section 96;`
  line
  line `(zzza) the manner and extent of deferment of tax liability under sub-section (3) of section 96;`
  line
  line `(zzzb) any other matter which is to be, or may be, prescribed, or in respect of which provision is to`
  line `be made, or may be, made by rules.`
  line
  line `(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of the State Legislature while it is in session for a total period of fourteen days, which may be`
  line `comprised in one session or in two successive sessions, and if, before the expiry of the session in which it`
  line `is so laid or the session immediately following, both Houses agree in making any modification in the rule`
  line `or both Houses agree that the rule should not be made, the rule shall thereafter have effect only in such`
  line `modified form or be of no effect, as the case may be; so, however, that any such modification or annulment`
  line `shall be without prejudice to the validity of anything previously done under that rule.`
  line
  line `(4) Any rule made under this section may provide that the contravention thereof shall be punishable`
  line `with fine which may extend to five thousand rupees and where the contravention is continuing one, with a`
  line `further fine which may extend to one hundred rupees per day for every day during which such contravention`
  line continues.
obj_root_law_sections_93_footnotes:
  string
  line
obj_root_law_sections_94:
  sectionId (67227)
  sectionNo (94)
  orderNo 94
  title `Repeal and savings.`
  content obj_root_law_sections_94_content
  footnotes obj_root_law_sections_94_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67227&sectionno=94&orderno=94&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_94_content:
  string
  line `(1) The Bihar Finance Act, 1981 (Bihar Act 5 of 1981) (hereinafter referred`
  line `to as "the repealed Act") is hereby repealed from the date of commencement of this Act.`
  line
  line `(2) The repeal shall not affect,--`
  line
  line `(a) any legal proceeding or remedy whether initiated or availed of before or after this repeal, in`
  line `respect of any such right, title, obligation or liability;`
  line
  line `(b) affect any right, privilege, obligation, or liability acquired, accrued or incurred under the`
  line `repealed Act except the right or privilege accrued under the repealed Act or the rules framed or`
  line
  line `notifications issued thereunder, to industries, granted under any industrial policy or industrial policy`
  line `resolution of the State Government; or`
  line
  line `(c) the levy, assessment or recovery of any tax or the imposition or recovery of any penalty, in`
  line `respect of such period,`
  line
  line `under the provision of the repealed Act; and all proceedings under the repealed Act in respect of matters`
  line `aforesaid shall be initiated and disposed of or continued and disposed of, as the case may be, as if this Act`
  line `has not been passed; and for this purpose all taxing authorities or Inspectors appointed under section 10,`
  line `and the Tribunal constituted under section 9 of, shall exercise all powers and perform all duties conferred`
  line `by or under the repealed Act upon the corresponding authorities appointed under section 9 or section 8`
  line `thereof:`
  line
  line `Provided that any appeal or any revision arising out of any order under the Bihar Finance Act, 1981`
  line `(Bihar Act 5 of 1981) shall be filed before, or heard or disposed of by, the appropriate authorities`
  line `mentioned in sections 72, 73 and 74 in the manner as provided therein.`
  line
  line `(3) All rules, orders and appointments made, notifications published, certificates granted, powers`
  line `conferred and other things done under the said Act and in force on the commencement of this Act, shall, so`
  line `far as they are not inconsistent with or until they are not modified, superseded or cancelled under this Act,`
  line `be deemed to have been respectively made, published, granted, conferred or done under this Act.`
  line
  line `(4) Save as otherwise provided in sub-sections (2) and (3), the mention of particular matters in those`
  line `sub-sections shall not be held to prejudice or affect the general application of section 6 of the General`
  line `Clauses Act, 1897 (10 of 1897) with regard to the effect of repeal.`
obj_root_law_sections_94_footnotes:
  string
  line
obj_root_law_sections_95:
  sectionId (67228)
  sectionNo (95)
  orderNo 95
  title `Declaration of stock of goods held on 1st April, 2005.`
  content obj_root_law_sections_95_content
  footnotes obj_root_law_sections_95_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67228&sectionno=95&orderno=95&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_95_content:
  string
  line `Every dealer who was registered under`
  line `the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94, or who makes`
  line `an application for registration as a dealer on the 1st day of April, 2005 shall declare such details regarding`
  line `the stock of goods held by him on the 31st March, 2005 in such manner and with such particulars and within`
  line `such time and to such authority, as may be prescribed.`
obj_root_law_sections_95_footnotes:
  string
  line
obj_root_law_sections_96:
  sectionId (67229)
  sectionNo (96)
  orderNo 96
  title `Transitory provisions.`
  content obj_root_law_sections_96_content
  footnotes obj_root_law_sections_96_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67229&sectionno=96&orderno=96&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_96_content:
  string
  line `(1) Where any goods, other than those specified under sub-section (2) of`
  line `section 13 of this Act, held in stock by a registered dealer on the date of commencement of this Act, are`
  line `goods which have already suffered tax on the first point of their sale within the meaning of the Bihar Finance`
  line `Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94, are sold by him or are consumed`
  line `in manufacture of other goods on or after the date of commencement of this Act, he shall claim and be`
  line `allowed, in such manner as may be prescribed, an input tax credit under sections 16 and 17 of this Act.`
  line
  line `(2) Where any goods, other than those specified under sub-section (2) of section 13 of this Act, held in`
  line `stock by a registered dealer on the date of commencement of this Act, are goods which have already suffered`
  line `tax on the first point of their sale within the meaning of the Bihar Finance Act, 1981 (Bihar Act 5 of 1981),`
  line `as it stood before its repeal by section 94, are used or consumed by him for the manufacture of goods for`
  line `sale within the State of Bihar or in the course of inter-State trade and commerce under section 3 of the`
  line `Central Sales Tax Act, 1956 (74 of 1956) or in the course of export within the meaning of section 5 of the`
  line `Central Sales Tax Act, 1956 on or after the date of commencement of this Act, he shall claim and be`
  line `allowed, in such manner as may be prescribed, an input tax credit under sections 16 and 17 of this Act.`
  line
  line `(3) Where--`
  line
  line `(a) any dealer has been granted the facility of deferment of tax payable under section 23A of the`
  line `Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section 94, and who has,`
  line `on the commencement of this Act, not availed of the full entitlement, he shall be allowed to continue`
  line `to defer the tax payable under this Act, in the manner and to the extent prescribed;`
  line
  line `(b) any dealer has been granted the facility of exemption from payment of tax under clause (b) of`
  line `sub-section (3) of section 7 of the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its`
  line `repeal by section 94, and who has, on the commencement of this Act, not availed of the full entitlement,`
  line `he shall be allowed to opt for deferment of his tax liability under this Act, in the manner and to the`
  line `extent prescribed.`
  line
  line `(4) Where--`
  line
  line `(a) the tax has been collected under the Bihar Finance Act, 1981 (Bihar Act 5 of 1981) as it stood`
  line `before its repeal by section 94, but the same has not been deposited before the date of commencement`
  line `of this Act, the tax so collected by any person under the said Act shall be deposited in accordance with`
  line `the provisions of the aforesaid Act and the rules made thereunder, as if this Act has not come into force`
  line `and the said Act had not been repealed;`
  line
  line `(b) a return or statement is required to be filed under the Bihar Finance Act, 1981 (Bihar Act 5 of`
  line `1981) as it stood before its repeal by section 94, but the same had not been filed before the`
  line `commencement of this Act, such return or statement, as the case may be, shall be filed in accordance`
  line `with the provisions of the aforesaid Act and by the person liable to file such return or statement;`
  line
  line `(c) a return has been filed, under the Bihar Finance Act, 1981 (Bihar Act 5 of 1981) as it stood`
  line `before its repeal by section 94, by any dealer for any year and no assessment in respect of that year has`
  line `been made before the commencement of this Act, the proceedings for the assessment of that dealer for`
  line `that year shall be made or be continued as if this Act had not come into force and the said Act had not`
  line `been repealed and such assessment shall be made by the prescribed authority under this Act;`
  line
  line `(d) a person has been aggrieved by any decision made or order passed under the Bihar Finance Act,`
  line `1981 (Bihar Act 5 of 1981) as it stood before its repeal by section 94, and he has not filed any appeal`
  line `or an application for review or revision, such person may file an appeal or make an application for`
  line `revision or review, as the case may be, in accordance with the provision of the said Act and the rules`
  line `made thereunder to the prescribed authority for disposing of such appeal or application;`
  line
  line `(e) any liability of any dealer to pay tax, under the Bihar Finance Act, 1981 (Bihar Act 5 of 1981),`
  line `as it stood before its repeal by section 94, had been affected, and such person was entitled to make a`
  line `reference before the High Court under section 48 of the said Act, before the date of commencement of`
  line `this Act, such person may, draw up, within two months of the date of commencement of this Act, a`
  line `reference (if not already made such reference) and refer it to the High Court in accordance with the`
  line `provisions of said section 48, as if the aforesaid Act had not been repealed.`
  line
  line `(5) No interest or penalty shall be leviable or imposable or no prosecution shall be initiated for any`
  line `offence committed under this Act during the period beginning on the 18th April, 2005 and ending on the`
  line `day preceding the day on which this Act comes into force.`
obj_root_law_sections_96_footnotes:
  string
  line
obj_root_law_sections_97:
  sectionId (67230)
  sectionNo (97)
  orderNo 97
  title `Construction of references in any repealed law to officers, authorities, etc.`
  content obj_root_law_sections_97_content
  footnotes obj_root_law_sections_97_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67230&sectionno=97&orderno=97&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_97_content:
  string
  line `Any reference in`
  line `any provision of the Bihar Finance Act, 1981 (Bihar Act 5 of 1981), as it stood before its repeal by section`
  line `94, to an officer, authority or tribunal shall, for the purpose of carrying into effect the provisions contained`
  line `in section 83, be construed as a reference to the corresponding officer, authority or tribunal appointed or`
  line `constituted by or under this Act; and if any question arises as to who such corresponding officer, authority`
  line `or tribunal is, the decision of the Commissioner thereon shall be final.`
obj_root_law_sections_97_footnotes:
  string
  line
obj_root_law_sections_98:
  sectionId (67231)
  sectionNo (98)
  orderNo 98
  title `Removal of difficulty.`
  content obj_root_law_sections_98_content
  footnotes obj_root_law_sections_98_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67231&sectionno=98&orderno=98&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_98_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of this Act, the`
  line `State Government may, by order published in the Official Gazette, make such provisions not inconsistent`
  line `with the provisions of this Act as appear to it to be necessary or expedient for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of a period of two years from`
  line `the commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of State Legislature.`
obj_root_law_sections_98_footnotes:
  string
  line
obj_root_law_sections_99:
  sectionId (67232)
  sectionNo (99)
  orderNo 99
  title `Laying of notifications on the table of the State Legislature.`
  content obj_root_law_sections_99_content
  footnotes obj_root_law_sections_99_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67232&sectionno=99&orderno=99&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_99_content:
  string
  line `Every notification issued under this`
  line `Act shall be laid, as soon as may be, after it is published in the Official Gazette, before each House of State`
  line `Legislature while it is in session for a total period of fourteen days which may be comprised in one session`
  line `or in two successive sessions, and if, before the expiry of the session in which it is so laid or the session`
  line `immediately following, both Houses agree in making any modification in the notification or both Houses`
  line `agree that the notification should be annulled, the notification shall thereafter have effect only in such`
  line `modified form or be of no effect, as the case may be; so, however, that any such modification or annulment`
  line `shall be without prejudice to the validity of anything previously done under that notification.`
obj_root_law_sections_99_footnotes:
  string
  line
obj_root_law_sections_100:
  sectionId (67233)
  sectionNo (100)
  orderNo 100
  title `Validation of Bihar Value Added Tax Ordinance, 2005.`
  content obj_root_law_sections_100_content
  footnotes obj_root_law_sections_100_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00065_200527_1657795970032&sectionId=67233&sectionno=100&orderno=100&orgactid=AC_CEN_5_5_00065_200527_1657795970032
obj_root_law_sections_100_content:
  string
  line `Anything done or any action taken`
  line `under the Bihar Value Added Tax Ordinance, 2005 (Bihar Ord. 1 of 2005) (including any order passed,`
  line
  line `notification issued and rules made) shall be deemed to be valid and be deemed to have been done or taken`
  line `under the corresponding provisions of this Act`
obj_root_law_sections_100_footnotes:
  string
  line
