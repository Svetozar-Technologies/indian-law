obj_root_law_sections_1:
  sectionId (12544)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12544&sectionno=1&orderno=1&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Rajiv Gandhi National Institute`
  line `of Youth Development Act, 2012.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1.19th November, 2012, vide notification No. S.O. 2747(E), dated 19th November, 2012, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (12545)
  sectionNo (2)
  orderNo 2
  title `Declaration of Rajiv Gandhi National Institute of Youth Development as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12545&sectionno=2&orderno=2&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the institution known as the Rajiv Gandhi National`
  line `Institute of Youth Development are such as to make the institution one of national importance, it is hereby`
  line `declared that the institution known as the Rajiv Gandhi National Institute of Youth Development is an`
  line `institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (12546)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12546&sectionno=3&orderno=3&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the Institute;`
  line
  line `(b) "appointed day" means the date appointed under sub-section (2) of section 1 for coming into`
  line `force of this Act;`
  line
  line `(c) "Chairperson" means a Chairperson to the Executive Council referred to in clause (a) of`
  line `sub-section (2) of section 12;`
  line
  line `(d) "Director" means the Director of the Institute referred to in clause (a) of section 21;`
  line
  line `(e) "Executive Council" means the Executive Council of the Institute established under`
  line `section 12;`
  line
  line `(f) "existing Institute" means the Rajiv Gandhi National Institute of Youth Development,`
  line `Sriperumbudur, established under the provisions of the Society Registration Act, 1860 (21 of 1860)`
  line `and declared as deemed to be a University under section 3 of the University Grants Commission Act,`
  line `1956 (3 of 1956), and which is in existence immediately before the commencement of this Act;`
  line
  line `(g) "Fund" means the fund of the Institute to be maintained under section 26;`
  line
  line `(h) "Institute" means the Rajiv Gandhi National Institute of Youth Development incorporated`
  line `under section 4;`
  line
  line `(i) "notification" means the notification published in the Official Gazette;`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(k) "Registrar" means the Registrar of the Institute referred to in section 23;`
  line
  line `(l) "Statutes" and "Ordinances" mean the Statutes and Ordinances of the Institute made under this`
  line Act.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (12547)
  sectionNo (4)
  orderNo 4
  title `Incorporation of Institute.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12547&sectionno=4&orderno=4&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_4_content:
  string
  line `(1) The Rajiv Gandhi National Institute of Youth Development shall`
  line `be a body corporate having perpetual succession and a common seal with power, subject to the provisions`
  line `of this Act, to acquire, hold and dispose of property and to contract, and shall, by that name, sue and be`
  line sued.
  line
  line `(2) The first Chairperson, the first Director and the first members of the Executive Council and the`
  line `Academic Council, and all persons who may hereafter become such officers or members, so long as they`
  line `continue to hold such office or membership, shall constitute the Institute.`
  line
  line `(3) The headquarters of the Institute shall be in the district of Kanchipuram, in the State of`
  line `Tamil Nadu.`
  line
  line `(4) The Institute may establish and maintain centres at such other places in India as it may deem fit.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (12548)
  sectionNo (5)
  orderNo 5
  title `Effect of establishment of Institute.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12548&sectionno=5&orderno=5&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_5_content:
  string
  line `On and from the appointed day and subject to other`
  line `provisions of this Act,—`
  line
  line `(a) any reference to the existing Institute in any contract or other instrument shall be deemed as a`
  line `reference to the Institute;`
  line
  line `(b) all property, movable and immovable, of or belonging to the existing Institute shall vest in the`
  line Institute;
  line
  line `(c) all rights and liabilities of the existing Institute shall be transferred to, and be the rights and`
  line `liabilities of, the Institute; and`
  line
  line `(d) every person employed by the existing Institute immediately before the appointed day shall`
  line `hold office or service in the Institute by the same tenure, at the same remuneration and upon the same`
  line `terms and conditions and with the same rights and privileges as to pension, leave, gratuity, provident`
  line `fund and other matters as he would have held the same if this Act had not been passed, and shall`
  line `continue to do so unless and until his employment is terminated or until such tenure, remuneration`
  line `and terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may be`
  line `terminated by the Institute in accordance with the terms of the contract with the employee or, if no`
  line `provision is made therein in this behalf, on payment to him by the Institute a compensation equivalent to`
  line `three months' remuneration in the case of permanent employees and one month's remuneration in the case`
  line `of other employees.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (12549)
  sectionNo (6)
  orderNo 6
  title `Objects of Institute.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12549&sectionno=6&orderno=6&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_6_content:
  string
  line `The objects of the Institute shall be,--`
  line
  line `(a) to evolve and achieve an integrated approach to youth development for preparing and`
  line `empowering the youth for the future, by--`
  line
  line `(i) providing action oriented research inputs for policy formulation;`
  line
  line `(ii) implementation of policy through extension and other programmes;`
  line
  line `(iii) promoting assessment and impact study and conducting teaching, training and other`
  line `academic programmes;`
  line
  line `(b) to set up advanced National Youth Resource Centre commensurate with the international`
  line `standards to provide for comprehensive and scientifically analysed data on all youth-related issues`
  line `and matters, with adequate library facility, documentation and publication;`
  line
  line `(c) to provide for research and development and dissemination of knowledge through extension`
  line `and outreach programmes;`
  line
  line `(d) to act as a nodal agency for capacity building of stakeholders including youth bodies,`
  line `organisations and agencies relating to youth;`
  line
  line `(e) to empower youth to participate in inclusive development and nation building;`
  line
  line `(f) to evolve as an institute of advanced study in the field of youth and to develop such`
  line `professional excellence as may be required for the purpose;`
  line
  line `(g) to provide for higher education in the field of youth development through employmentoriented`
  line `and inter-disciplinary courses at the post graduate level.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (12550)
  sectionNo (7)
  orderNo 7
  title `Functions of Institute.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12550&sectionno=7&orderno=7&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_7_content:
  string
  line `(1) Without prejudice to the provisions contained in section 6, the`
  line `Institute shall,--`
  line
  line `(a) develop a "think tank" by way of carrying out policy research, evaluation and impact analysis`
  line `on youth programmes and issues of contemporary and future relevance;`
  line
  line `(b) function as a repository of knowledge pertaining to data on youth;`
  line
  line `(c) develop documentation, information and publication services for youth training and extension;`
  line
  line `(d) provide technical advice and consultancy for formulation of youth related policy and`
  line `promotion of youth programme;`
  line
  line `(e) build the professional capacity of youth organisations, both in Government and voluntary`
  line sector;
  line
  line `(f) design, develop and conduct appropriate training and orientation programmes;`
  line
  line `(g) conduct seminars, workshops and conferences on issues relating to youth;`
  line
  line `(h) set up centres for dissemination of academic and training programmes;`
  line
  line `(i) collaborate with national and international university, centres, institutes and such other`
  line `agencies relating to youth training and youth development;`
  line
  line `(j) establish programmes of study and research and to provide for instruction in such branches of`
  line `study as the institute deems appropriate;`
  line
  line `(k) award, subject to such conditions as the Institute may determine, degrees, diplomas,`
  line `certificates or other academic distinctions or titles at various academic levels;`
  line
  line `(l) confer honorary degrees or other distinction awards, fellowships, scholarships, prizes and`
  line medals;
  line
  line `(m) determine, demand and receive fees and other charges for its courses, programmes and other`
  line matters;
  line
  line `(n) conduct and coordinate projects and studies relating to youth sponsored by the Government of`
  line `India and other developmental agencies;`
  line
  line `(o) create with the prior approval of the Central Government, academic, technical, administrative,`
  line `managerial and other posts in the Institute and make appointments thereto in accordance with the`
  line `rules and regulations of the Institute;`
  line
  line `(p) regulate the conduct of the affairs of the Institute;`
  line
  line `(q) supervise and control the discipline of all categories of employees and students of the`
  line Institute;
  line
  line `(r) purchase, hire, lease, exchange or acquire property, movable or immovable and to construct,`
  line `alter and maintain any building or buildings as may be necessary;`
  line
  line `(s) set up distance learning or education centres, in collaboration with Open Universities, to`
  line `provide access to the aspiring young professionals enabling them to take up a career in the field of`
  line `youth development;`
  line
  line `(t) establish, maintain and manage halls of residences and hostels for students;`
  line
  line `(u) lay down conditions of service including a code of conduct for teachers and other categories`
  line `of employees;`
  line
  line `(v) supervise, control and regulate the discipline of students of the Institute and to make`
  line `arrangements for promoting their health and general welfare;`
  line
  line `(w) coordinate student exchange programmes with reputed International Youth Development`
  line Institutions;
  line
  line `(x) undertake, assist and promote all such activities conducive or incidental to the attainment of`
  line `the objectives.`
  line
  line `(2) The Institute may receive gifts, grants, donations or benefactions from the Government and to`
  line `receive bequests, donations and transfers of movable or immovable properties from the testators, donors`
  line `or transferors, as the case may be.`
  line
  line `(3) The Institute may enter into agreements with international organisations, institutions and`
  line `universities to broaden the scope of the youth work and to facilitate knowledge development and`
  line `participatory learning.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (12551)
  sectionNo (8)
  orderNo 8
  title `Institute to be open to all races, creeds, gender and classes.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12551&sectionno=8&orderno=8&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_8_content:
  string
  line `(1) The Institute shall be open to`
  line `persons of either sex and of whatever race, creed, caste or class, physical ability, and no test or condition`
  line `shall be imposed as to religious belief or profession in admitting students, appointing teachers or`
  line `employees or in any other connection whatsoever.`
  line
  line `(2) No bequest, donation or transfer of any property shall be accepted by the Institute which in the`
  line `opinion of the Executive Council involves conditions or obligations opposed to the spirit and object of`
  line `this section.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (12552)
  sectionNo (9)
  orderNo 9
  title `Teaching at Institute.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12552&sectionno=9&orderno=9&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_9_content:
  string
  line `All teaching and other academic activities at the Institute shall be`
  line `conducted by or in the name of the Institute in accordance with the Statutes and Ordinances made in this`
  line behalf.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (12553)
  sectionNo (10)
  orderNo 10
  title Visitor.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12553&sectionno=10&orderno=10&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_10_content:
  string
  line `(1) The President of India shall be the Visitor of the Institute:`
  line
  line `Provided that the President may, by order, nominate any person to be the Visitor and such person so`
  line `nominated shall hold office for such term, not exceeding five years as may be specified in the order and`
  line `the person so nominated shall exercise the powers and discharge duties of the Visitor.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the Institute and to hold inquiries into the affairs thereof and to report thereon in such manner as the`
  line `Visitor may direct.`
  line
  line `(3) Upon receipt of any such report, the Visitor may take such action and issue such directions as he`
  line `considers necessary in respect of any of the matters dealt with in the report and the Institute shall be`
  line `bound to comply with such directions within reasonable time.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (12554)
  sectionNo (11)
  orderNo 11
  title `Authorities of Institute.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12554&sectionno=11&orderno=11&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_11_content:
  string
  line `The Institute shall consist of the following authorities, namely:--`
  line
  line `(a) the Executive Council;`
  line
  line `(b) the Academic Council; and`
  line
  line `(c) such other authorities as may be declared by the Statutes to be the authorities of the Institute.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (12555)
  sectionNo (12)
  orderNo 12
  title `Establishment of Executive Council.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12555&sectionno=12&orderno=12&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_12_content:
  string
  line `(1) With effect from such date as the Central`
  line `Government may, by notification, appoint in this behalf, there shall be established for the purpose of this`
  line `Act, a central body to be called as the Executive Council.`
  line
  line `(2) The Executive Council shall consist of the following members, namely:--`
  line
  line `(a) an eminent person of academic repute to be nominated by the Visitor--Chairperson;`
  line
  line `(b) an eminent person in the field of Youth Development to be nominated by the Visitor--ViceChairperson;`
  line
  line `(c) Secretary, Department of Youth Affairs, Ministry of Youth Affairs and Sports--ex officio`
  line Member;
  line
  line `(d) Joint Secretary, Department of Youth Affairs, Ministry of Youth Affairs and Sports--ex officio Member;`
  line
  line `(e) Director, Rajiv Gandhi National Institute of Youth Development--ex officio Member;`
  line
  line `(f) Professor from Rajiv Gandhi National Institute of Youth Development on rotation--Member;`
  line
  line `(g) one eminent sports personality to be nominated by the Central Government--Member;`
  line
  line `(h) one Head from an Academic Institution to be nominated by the Central Government--Member;`
  line
  line `(i) one representative from the industry to be nominated by the Central Government from the`
  line `Federation of Indian Chamber of Commerce and Industry or Confederation of Indian Industry by the`
  line `Central Government--Member;`
  line
  line `(j) the Registrar, Rajiv Gandhi National Institute of Youth Development--Member-Secretary.`
  line
  line `(3) While nominating the members of the Executive Council under sub-section (2) due representation`
  line `shall be given to women, different regions of the country, and weaker sections of the community and`
  line `differently abled persons.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (12556)
  sectionNo (13)
  orderNo 13
  title `Terms of office of, vacancies among, and allowances payable to members of Executive Council.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12556&sectionno=13&orderno=13&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_13_content:
  string
  line `(1) The term of office of every member of the Executive Council shall be for a period of three`
  line `years from the date of his nomination:`
  line
  line `Provided that the term of office of an ex officio member shall continue so long as he holds the office`
  line `by virtue of which he is a member.`
  line
  line `(2) The term of office of a member nominated to fill a casual vacancy shall be for the remainder of`
  line `the term of the member in whose place he has been nominated.`
  line
  line `(3) Notwithstanding anything contained in this section, an out-going member shall, unless the Central`
  line `Government otherwise directs, continue in office until another person is nominated as a member in his`
  line `place or until the expiry of one year, whichever is earlier.`
  line
  line `(4) The members of the Executive Council, other than ex officio members, shall be paid such`
  line `travelling and other allowances as may be provided by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (12557)
  sectionNo (14)
  orderNo 14
  title `Meetings of Executive Council.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12557&sectionno=14&orderno=14&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_14_content:
  string
  line `(1) The Chairperson shall ordinarily preside at the meetings of`
  line `the Executive Council and at the Convocation of the Institute:`
  line
  line `Provided that, in his absence, the Vice-Chairperson of the Executive Council shall preside at the`
  line `meetings of the Executive Council.`
  line
  line `(2) It shall be the duty of the Chairperson to ensure that the decisions taken by the Executive Council`
  line `are implemented.`
  line
  line `(3) The Chairperson shall exercise such other powers and perform such other duties as are assigned to`
  line `him by this Act.`
  line
  line `(4) The Executive Council shall meet at least four times in a year and follow such procedure, in its`
  line `meetings (including quorum at such meetings) as may be provided by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (12558)
  sectionNo (15)
  orderNo 15
  title `Powers and functions of Executive Council.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12558&sectionno=15&orderno=15&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_15_content:
  string
  line `(1) Subject to the provisions of this Act, the`
  line `Executive Council shall be responsible for the general superintendence, direction and control of the`
  line `affairs of the Institute and shall also exercise the powers of the Institute not otherwise provided for by this`
  line `Act, the Statutes and the Ordinances, and shall have the power to review the acts of the Academic Council`
  line `and Finance Committee.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Executive Council shall--`
  line
  line `(a) take decisions on questions of policy relating to the administration and working of the`
  line Institute;
  line
  line `(b) lay down policy regarding the duration of the courses, nomenclature of the degrees and other`
  line `distinctions to be conferred by the Institute;`
  line
  line `(c) institute courses of study and lay down standards of proficiency and other academic`
  line `distinctions in respect of the courses offered by the Institute;`
  line
  line `(d) lay down, with prior approval of the Central Government, the policy regarding the cadre`
  line `structure, qualification, the method of recruitment and conditions of service of the teaching and`
  line `research faculty as well as other employees of the Institute;`
  line
  line `(e) guide resource mobililsation of the Institute and to lay down policies for utilisation;`
  line
  line `(f) consider and approve proposals for taking loans for purposes of the Institute with or without`
  line `the security of the property of the Institute;`
  line
  line `(g) make Statutes and to alter, modify or rescind the same;`
  line
  line `(h) consider and pass resolutions on annual report, annual accounts and the budget estimates of`
  line `the Institutes for the next financial year as it thinks fit together with a statement of its development`
  line `plans; and`
  line
  line `(i) do all such things, not specifically covered under clauses (a) to (h), as may be necessary,`
  line `incidental or conductive to the attainment of all or any of the powers under this section.`
  line
  line `(3) The Executive Council shall have the power to appoint such committees as it considers necessary`
  line `for the exercise of its powers and the performance of its duties under this Act.`
  line
  line `(4) The Executive Council may, by a specific resolution to this effect, delegate any of its powers and`
  line `duties to the Chairperson, Director, any officer or any authority of the Institute subject to reserving the`
  line `right to review the action that may be taken under such delegated authority.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (12559)
  sectionNo (16)
  orderNo 16
  title `Academic Council.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12559&sectionno=16&orderno=16&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_16_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `Institute and shall, subject to the provisions of this Act, the Statutes and the Ordinances, co-ordinate and`
  line `exercise general supervision over the academic policies of the Institute.`
  line
  line `(2) The Academic Council shall consist of the following, namely:--`
  line
  line `(a) Director-Chairman ex officio;`
  line
  line `(b) one head of an academic institution of national importance to be nominated by the`
  line Chairperson;
  line
  line `(c) one Director from any of the Indian Institute of Technology or the Indian Institute of`
  line `Management to be nominated by the Chairperson;`
  line
  line `(d) Member in-charge of Youth Affairs in the Planning Commission of India ex officio;`
  line
  line `(e) one person from any international non-governmental organisation working in India in the`
  line `field of youth work to be nominated by the Chairperson;`
  line
  line `(f) two representatives from the non-governmental industrial sector to be nominated by the`
  line Chairperson;
  line
  line `(g) one Professor from the Institute, on rotation basis;`
  line
  line `(h) Director of the Lal Bahadur Shastri National Academy of Administration, Mussorie,`
  line `ex officio;`
  line
  line `(i) two persons from non-governmental organisations working in the field of youth and`
  line `adolescent development out of whom one person shall be from the north-eastern region, to be`
  line `nominated by the Chairperson;`
  line
  line `(j) two students of the Institute out of whom one student shall be female;`
  line
  line `(k) three eminent academicians from among the fields of Social Science, Health Science,`
  line `Agricultural Science, Skill Development, Management and Law to be nominated by the Chairperson;`
  line
  line `(l) one woman representative from the International Development Organisation to be nominated`
  line `by the Chairperson;`
  line
  line `(m) an officer not below the rank of Joint Secretary to the Government of India dealing with the`
  line `affairs of the Institute in the Union Ministry of Youth Affairs and Sports, ex officio.`
  line
  line `(3) The term of office of members of the Academic Council and its powers shall be such as may be`
  line `provided by the Statutes.`
  line
  line `(4) While nominating the members of the Academic Council due representation shall be given to`
  line `women (by including at least four women), from different regions of the country, weaker sections of the`
  line `community and differently abled persons.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (12560)
  sectionNo (17)
  orderNo 17
  title `Functions of Academic Council.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12560&sectionno=17&orderno=17&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_17_content:
  string
  line `Subject to the provisions of this Act, the Statutes and the`
  line `Ordinances, the Academic Council shall have the control and general regulation, and be responsible for`
  line `the framing of the Ordinances, maintenance of standards of instruction, education and examination in the`
  line `Institute and shall exercise such other powers and perform such other duties as may be conferred or`
  line `imposed upon it by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (12561)
  sectionNo (18)
  orderNo 18
  title `Finance Committee.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12561&sectionno=18&orderno=18&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_18_content:
  string
  line `(1) There shall be a Finance Committee of the Institute which shall be the`
  line `principal financial body of the Institute.`
  line
  line `(2) The Finance Committee shall consist of the following, namely:--`
  line
  line `(a) Director-Presiding Officer of the Finance Committee;`
  line
  line `(b) Joint Secretary and Financial Adviser in the Union Ministry of Youth Affairs and Sports;`
  line
  line `(c) Registrar of the Institute;`
  line
  line `(d) one Professor of the Institute on rotation basis, as may be nominated by the Chairperson;`
  line
  line `(e) one Member from the Executive Council to be nominated by the Chairperson;`
  line
  line `(f) Joint Secretary in the Ministry of Youth Affairs and Sports dealing with the affairs of the`
  line Institute;
  line
  line `(g) the Finance Officer of the Institute--Member-Secretary.`
  line
  line `(3) The term of office of members of the Finance Committee and its powers shall be such as may be`
  line `provided by the Statutes.`
  line
  line `(4) While nominating the members of the Academic Council due representation shall be given to`
  line `women, different regions of the country, weaker sections of the community and differently abled persons.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (12562)
  sectionNo (19)
  orderNo 19
  title `Functions of Finance Committee.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12562&sectionno=19&orderno=19&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_19_content:
  string
  line `The Finance Committee shall perform the following`
  line `functions, namely:--`
  line
  line `(a) to scrutinise the accounts and budget estimates of the Institute and to make recommendations`
  line `to the Executive Council;`
  line
  line `(b) to scrutinise the proposals for new expenditure on account of major works on purchases;`
  line
  line `(c) to scrutinise re-appropriation statements and audit notes and make recommendations thereon`
  line `to the Executive Council;`
  line
  line `(d) to review the finances of the Institute from time to time and have concurrent audit conducted`
  line `whenever necessary; and`
  line
  line `(e) to give advice and make recommendations to the Executive Council on any financial`
  line `questions affecting the affairs of the Institute.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (12563)
  sectionNo (20)
  orderNo 20
  title `Other authorities.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12563&sectionno=20&orderno=20&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_20_content:
  string
  line `The constitution, powers and functions of the other authorities, as may be`
  line `declared by the Statutes to be authorities of the Institute, shall be such as may be provided by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (12564)
  sectionNo (21)
  orderNo 21
  title `Officers of Institute.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12564&sectionno=21&orderno=21&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_21_content:
  string
  line `The Institute shall consist of the following officers, namely:--`
  line
  line `(a) the Director;`
  line
  line `(b) the Registrar; and`
  line
  line `(c) such other officers as may be declared by the Statutes to be the officers of the Institute.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (12565)
  sectionNo (22)
  orderNo 22
  title Director.
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12565&sectionno=22&orderno=22&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_22_content:
  string
  line `(1) The Director of the Institute shall be appointed by the Visitor for a period of three`
  line `years in the manner specified in sub-sections (2) and (3) on such terms and conditions of service as may`
  line `be provided by the Statutes:`
  line
  line `Provided that the first Director shall be appointed by the Central Government on such terms and`
  line `conditions as it deems fit, for a period not exceeding six months from the appointed day.`
  line
  line `(2) The Director shall be appointed by the Visitor from a panel of three persons with outstanding`
  line `academic qualifications as recommended by a Search Committee constituted by the Central Government`
  line `for that purpose.`
  line
  line `(3) The Search Committee referred to in sub-section (2) shall consist of three members, one each to`
  line `be nominated by the Executive Council, the Central Government and the Visitor.`
  line
  line `(4) The Director shall be the principal academic and executive officer of the Institute and shall be`
  line `responsible for the proper administration and academic performance of the Institute and for imparting of`
  line `instruction and maintenance of discipline therein.`
  line
  line `(5) The Director shall submit annual report and audited accounts of the Institute to the Executive`
  line `Council and the Central Government and the Central Government shall thereupon cause the same to be`
  line `laid before each House of Parliament.`
  line
  line `(6) The Director shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by the Act, the Statutes and the Ordinances.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (12566)
  sectionNo (23)
  orderNo 23
  title Registrar.
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12566&sectionno=23&orderno=23&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_23_content:
  string
  line `(1) The Registrar of the Institute shall be appointed in such manner and on such`
  line `terms and conditions as may be provided by the Statutes and shall be the custodian of records, common`
  line `seal, the funds of the Institute and such other property of the Institute as the Executive Council shall`
  line `commit to his charge.`
  line
  line `(2) The Registrar shall act as the Member-Secretary of the Executive Council, the Academic Council`
  line `and such committees as may be provided by the Statutes.`
  line
  line `(3) The Registrar shall be responsible to the Director for the proper discharge of his functions.`
  line
  line `(4) The Registrar shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by this Act, the Statutes or by the Director.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (12567)
  sectionNo (24)
  orderNo 24
  title `Other officers.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12567&sectionno=24&orderno=24&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_24_content:
  string
  line `The manner of appointment, emoluments, powers and duties of the other`
  line `officers of the Institute shall be such as may be provided by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (12568)
  sectionNo (25)
  orderNo 25
  title `Grants by Central Government.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12568&sectionno=25&orderno=25&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_25_content:
  string
  line `The Central Government may, after due appropriation made`
  line `by Parliament by law in this behalf, pay to the Institute in each financial year such sums of money and in`
  line `such manner as it may think fit for being utilised for the purposes of this Act.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (12569)
  sectionNo (26)
  orderNo 26
  title `Fund of Institute.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12569&sectionno=26&orderno=26&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_26_content:
  string
  line `(1) The Institute shall maintain a Fund to which shall be credited--`
  line
  line `(a) all monies provided by the Central Government;`
  line
  line `(b) all fees and other charges levied and collected by the Institute;`
  line
  line `(c) all monies received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all monies received by the Institute in any other manner or from any other source.`
  line
  line `(2) All monies credited to the Fund shall be deposited in such banks or invested in such manner as`
  line `may be decided by the Executive Council.`
  line
  line `(3) The Fund shall be applied towards meeting the expenses of the Institute including expenses`
  line `incurred in the exercise of its powers and discharge of its duties under this Act.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (12570)
  sectionNo (27)
  orderNo 27
  title `Endowment to other funds.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12570&sectionno=27&orderno=27&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_27_content:
  string
  line `Without prejudice to the provisions contained in section 26, the`
  line `Institute may,--`
  line
  line `(a) set up an endowment fund with an amount of one hundred crore rupees to be maintained in`
  line `the Public Account and any other fund for a specified purpose; and`
  line
  line `(b) transfer monies from its fund to the endowment fund or any other fund.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (12571)
  sectionNo (28)
  orderNo 28
  title `Accounts and audit.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12571&sectionno=28&orderno=28&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_28_content:
  string
  line `(1) The Institute shall maintain proper accounts and other relevant records`
  line `and prepare an annual statement of accounts, including the balance sheet, in such form as may be`
  line `prescribed by the Central Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Institute shall be audited by the Comptroller and Auditor-General of`
  line `India and any expenditure incurred by him in connection with such audit shall be payable by the Institute`
  line `to the Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Institute shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts, and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line Institute.
  line
  line `(4) The accounts of the Institute as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and the Central Government shall cause the same to be laid before`
  line `each House of Parliament.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (12572)
  sectionNo (29)
  orderNo 29
  title `Pension and provident fund.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12572&sectionno=29&orderno=29&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_29_content:
  string
  line `(1) The Institute shall constitute for the benefits of its employees,`
  line `including the Director, such pension, insurance and provident fund scheme as it may deem fit, in such`
  line `manner and subject to such conditions as may be provided by the Statutes.`
  line
  line `(2) Where any such provident fund has been so constituted, the Central Government may declare that`
  line `the provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to such fund as if it were a`
  line `Government Provident Fund.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (12573)
  sectionNo (30)
  orderNo 30
  title `Appointment of staff of Institute.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12573&sectionno=30&orderno=30&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_30_content:
  string
  line `All appointments of the staff of the Institute, except that of`
  line `the Director, shall be made with the prior approval of the Central Government and in accordance with the`
  line `procedure laid down in the Statutes,--`
  line
  line `(a) by the Executive Council, if the appointment is made on the academic staff in the post of`
  line `Assistant Professor or above or if the appointment is made on the non-academic staff in any cadre, the`
  line `maximum of the pay-scale for which is the same or higher than that of an Assistant Professor; and`
  line
  line `(b) by the Director, in any other case`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (12574)
  sectionNo (31)
  orderNo 31
  title `Power to make Statutes.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12574&sectionno=31&orderno=31&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_31_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all`
  line `or any of the following matters, namely:--`
  line
  line `(a) the formation of departments of teaching and other academic units;`
  line
  line `(b) the institution of fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(c) the classification of posts, terms of office, method of appointment, powers and duties and`
  line `other terms and conditions of service of the officers of the Institute including the Chairperson, the`
  line `Director, the Registrar and such other officers as may be declared as officers of the Institute by the`
  line Statutes;
  line
  line `(d) the constitution, powers and duties of the authorities of the Institute referred in clause (c) of`
  line `section 11;`
  line
  line `(e) the delegation of powers vested in the authorities or officers of the Institute;`
  line
  line `(f) the code of conduct, disciplinary actions thereto for misconduct including removal from`
  line `service of employees on account of misconduct and the procedure for appeal against the actions of an`
  line `officer or authority of the Institute;`
  line
  line `(g) the conferment of honorary degrees;`
  line
  line `(h) the establishment and maintenance of halls, residences and hostels;`
  line
  line `(i) the authentication of the orders and decisions of the Executive Council;`
  line
  line `(j) any other matter which by this Act is to be, or may be, provided by the Statutes.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (12575)
  sectionNo (32)
  orderNo 32
  title `Statutes how to be made.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12575&sectionno=32&orderno=32&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_32_content:
  string
  line `(1) The first Statutes of the Institute shall be framed by the Central`
  line `Government with the approval of the Visitor, and a copy of the same shall be laid as soon as may be, after`
  line `it is made, before each House of Parliament.`
  line
  line `(2)Without prejudice to the provisions contained in sub-section (1), the Executive Council may, from`
  line `time to time, make new or additional Statutes or may amend or repeal the Statutes in the manner hereafter`
  line `in this section provided.`
  line
  line `(3) A new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require the`
  line `previous approval of the Visitor who may assent thereto or withhold such assent or remit it to the`
  line `Executive Council for consideration.`
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (12576)
  sectionNo (33)
  orderNo 33
  title `Power to make Ordinances.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12576&sectionno=33&orderno=33&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_33_content:
  string
  line `Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances of the Institute may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of the students to the Institute;`
  line
  line `(b) the reservation in admission to various courses or programmes of the Institute for the`
  line `Scheduled Castes, the Scheduled Tribes and other categories of persons;`
  line
  line `(c) the courses of study to be laid down for all degrees, diplomas and certificates awarded by the`
  line Institute;
  line
  line `(d) the conditions under which students shall be admitted to the degree, diploma and certificate`
  line `courses and to the examinations of the Institute and the eligibility conditions for awarding the same;`
  line
  line `(e) the conditions of award of fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(f) the conditions and manner of appointment and duties of examining bodies, examiners and`
  line moderators;
  line
  line `(g) the conduct of examinations;`
  line
  line `(h) the maintenance of discipline among the students of the Institute;`
  line
  line `(i) the fees to be charged for courses of study in the Institute and for admission to the`
  line `examinations of degrees of the Institute;`
  line
  line `(j) the conditions of residence of students of the Institute and the levying of the fees for residence`
  line `in the halls and hostels and of other charges; and`
  line
  line `(k) any other matter which by this Act or the Statute is to be, or may be, provided by the`
  line Ordinances.
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (12577)
  sectionNo (34)
  orderNo 34
  title `Ordinances how to be made.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12577&sectionno=34&orderno=34&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_34_content:
  string
  line `(1) Save as otherwise provided in this section, Ordinances shall`
  line `be made by the Academic Council.`
  line
  line `(2) All Ordinances made by the Academic Council shall have effect from such date as it may direct,`
  line `but every Ordinance so made shall be submitted, as soon as may be, to the Executive Council and shall be`
  line `considered by the Executive Council at its next succeeding meeting.`
  line
  line `(3) The Executive Council shall have power by resolution to modify or cancel any such Ordinance`
  line `and such Ordinance shall from the date of such resolution stand modified accordingly or cancelled, as the`
  line `case may be.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (12578)
  sectionNo (35)
  orderNo 35
  title `Conduct of business by authorities of Institute.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12578&sectionno=35&orderno=35&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_35_content:
  string
  line `The authorities of the Institute may have their`
  line `own rules of procedure, consistent with the provisions of this Act, the Statutes and the Ordinances for the`
  line `conduct of their own business and that of the committees, if any, appointed by them and not provided for`
  line `by this Act, the Statutes or the Ordinances.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (12579)
  sectionNo (36)
  orderNo 36
  title `Tribunal of Arbitration.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12579&sectionno=36&orderno=36&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_36_content:
  string
  line `(1) Any dispute arising out of a contract between the Institute and any`
  line `of its employees shall, at the request of the employee concerned or at the instance of the Institute, be`
  line `referred to a Tribunal of Arbitration consisting of one member appointed by the Institute, one member`
  line `nominated by the employee, and an umpire appointed by the Visitor.`
  line
  line `(2) The decision of the Tribunal shall be final and shall not be questioned in any court.`
  line
  line `(3) No suit or proceeding shall lie in any court in respect of any matter, which is required by`
  line `sub-section (1) to be referred to the Tribunal of Arbitration.`
  line
  line `(4) The Tribunal of Arbitration shall have power to regulate its own procedure.`
  line
  line `(5) Nothing contained in any law for the time being in force relating to arbitration shall apply to`
  line `arbitrations under this section.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (12580)
  sectionNo (37)
  orderNo 37
  title `Acts and proceedings not to be invalidated by vacancies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12580&sectionno=37&orderno=37&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_37_content:
  string
  line `No act of the Institute or Executive`
  line `Council or Academic Council or any other body set up under this Act or the Statutes, shall be invalid`
  line `merely by reason of--`
  line
  line `(a) any vacancy in, or defect in the constitution thereof; or`
  line
  line `(b) any defect in the election, nomination or appointment, of a person acting as member thereof;`
  line or
  line
  line `(c) any irregularity in its procedure not affecting the merits of the case.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (12581)
  sectionNo (38)
  orderNo 38
  title `Grant of degrees, etc., by Institute.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12581&sectionno=38&orderno=38&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_38_content:
  string
  line `Notwithstanding anything contained in the University`
  line `Grants Commission Act, 1956 (3 of 1956) or any other law for the time being in force, the Institute shall`
  line `have power to grant degrees and other academic distinctions and titles under this Act:`
  line
  line `Provided that the nomenclature of any degree to be granted by the Institute shall be notified by the`
  line `University Grants Commission with the prior approval of the Central Government.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (12582)
  sectionNo (39)
  orderNo 39
  title `Sponsored schemes.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12582&sectionno=39&orderno=39&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_39_content:
  string
  line `Notwithstanding anything contained in this Act, whenever the Institute`
  line `receives funds from any Government, the University Grants Commission or any other agency including industry sponsoring a research scheme, a consultancy assignment, a teaching programme or a chaired`
  line `professorship or a scholarship, to be executed or endowed at the Institute,--`
  line
  line `(a) the amount received shall be kept by the Institute separately from the fund of the Institute and`
  line `utilised only for the purpose of the scheme:`
  line
  line `Provided that any money remaining unutilised under this clause shall be transferred to the`
  line `endowment fund set up under section 27; and`
  line
  line `(b) the staff required to execute the same shall be recruited in accordance with the terms and`
  line `conditions stipulated by the sponsoring organisation with prior approval of the Central Government:`
  line
  line `Provided that the principles laid down in the General Financial Rules, 2005 shall be followed for`
  line `approval of sponsored schemes funded by the Central Government.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (12583)
  sectionNo (40)
  orderNo 40
  title `Meetings of Academic Council and Finance Committee.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12583&sectionno=40&orderno=40&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_40_content:
  string
  line `The Academic Council and the`
  line `Finance Committee shall meet at such times and follow such procedure, in its meetings (including`
  line `quorum at such meetings) as may be provided by the Statutes.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (12584)
  sectionNo (41)
  orderNo 41
  title `Power of Central Government to give directions to Institute.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12584&sectionno=41&orderno=41&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_41_content:
  string
  line `(1) The Central Government`
  line `may give such directions, as it may deem necessary, to the Institute for the effective administration of this`
  line `Act and the Institute shall comply with such directions.`
  line
  line `(2) In case of dispute between the Institute and the Central Government, in connection with the`
  line `exercise of its powers and discharge of its functions by the Institute under this Act, the decision of the`
  line `Central Government on that dispute, shall be final.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (12585)
  sectionNo (42)
  orderNo 42
  title `Protection action taken in good faith.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12585&sectionno=42&orderno=42&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_42_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or employee of the Institute for anything which is in good faith done or intended to be done in`
  line `pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (12586)
  sectionNo (43)
  orderNo 43
  title `Power to make rules.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12586&sectionno=43&orderno=43&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_43_content:
  string
  line `(1) The Central Government may, by notification, make rules to carry`
  line `out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the form and manner in which the books of account of the Institute shall be maintained under`
  line `sub-section (1) of section 28;`
  line
  line `(b) any other matter which is required to be, or may be, prescribed.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (12587)
  sectionNo (44)
  orderNo 44
  title `Statutes, Ordinances notifications to be published in Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12587&sectionno=44&orderno=44&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_44_content:
  string
  line `(1) Every rule made by the Central Government and every Statute and every`
  line `Ordinance made or notification issued under this Act shall be published in the Official Gazette.`
  line
  line `(2) Every rule made by the Central Government, every Statute and every Ordinance made or`
  line `notification issued under this Act shall be laid, as soon as may be after it is made, before each House of`
  line `Parliament, while it is in session, for a total period of thirty days which may be comprised in one session`
  line `or in two or more successive sessions, and if, before the expiry of the session immediately following the`
  line `session or the successive sessions aforesaid, both Houses agree in making any modification in the Statute,`
  line `Ordinance or notification or both Houses agree that the Statute, Ordinance or notification should not be`
  line `made or issued, the Statute, Ordinance or notification shall thereafter have effect only in such modified`
  line `form or be of no effect, as the case may be; so, however, that any such modification or annulment shall be`
  line `without prejudice to the validity of anything previously done under that Statute, Ordinance or notification.`
  line
  line `(3) The power to make the Statutes, Ordinances or notifications shall include the power to give`
  line `retrospective effect from a date not earlier than the date of commencement of this Act, to the Statutes,`
  line `Ordinances, notifications or any of them but no retrospective effect shall be given to any Statute,`
  line `Ordinance or notification so as to prejudicially affect the interests of any person to whom such Statute,`
  line `Ordinance or notification may be applicable.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (12588)
  sectionNo (45)
  orderNo 45
  title `Power to remove difficulties.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12588&sectionno=45&orderno=45&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_45_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `or give such directions not inconsistent with the provisions of this Act, as appears it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (12589)
  sectionNo (46)
  orderNo 46
  title `Transitional provisions.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_53_00002_201235_1517807327912&sectionId=12589&sectionno=46&orderno=46&orgactid=AC_CEN_34_53_00002_201235_1517807327912
obj_root_law_sections_46_content:
  string
  line `Notwithstanding anything contained in this Act,--`
  line
  line `(a) the Advisory Board and the Executive Council of the existing Institute functioning as such`
  line `immediately before the commencement of this Act shall continue to so function until an Executive`
  line `Council is constituted for the Institute under this Act, but on the constitution of a new Executive`
  line `Council under this Act, the members of the Advisory Board and Executive Council holding office`
  line `before such constitution shall cease to hold office; and`
  line
  line `(b) until the first Statutes and the Ordinances are made under this Act, the Statutes and the`
  line `Ordinances of the existing Institute, or notification as in force, immediately before the`
  line `commencement of this Act, shall continue to apply to the Institute in so far as they are not`
  line `inconsistent with the provisions of this Act.`
obj_root_law_sections_46_footnotes:
  string
  line
