  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `राजीव गाांधी राष्‍टरी य युवा ववकास सांस्था न`
  line `अवधवनयम, 2012`
  line _________
  line `धाराओं का क्र म`
  line _________
  line धाराएां
  line `अध्या य 1 प्र`
  line ारांविक
  line `1. सांविप् त नाम और प्र ारांि।`
  line `2. राजीव गाांधी राष्‍टरी य युवा ववकास सांस्था न को राष्‍टरी य महत्व की सांस्था के रू प में घोवित ककया जा ना।`
  line `3. पररिािाएां।`
  line `अध्या य 2`
  line `राजीव गाांधी राष्‍टरी य युवा ववकास सांस्था न`
  line `4. सांस्था न का वनगमन।`
  line `5. सांस्था न की स् था पना का प्र िाव।`
  line `6. सांस्था न के उद्देश्य।`
  line `7. सांस्था न के कृत्य।`
  line `8. सांस्था न का सिी मूलवांशों, पांथों, ललांगों और वगों के वलए खुला होना।`
  line `9. सांस्था न में वशिा।`
  line `10. कुलाध्य ि।`
  line `अध्या य 3`
  line `सांस् था न के प्र ावधकारी`
  line `11. सांस्था न के प्र ावधकारी।`
  line `12. कायय पररिद् की स् था पना।`
  line `13. कायय पररिद् के सदस्यों की पदाववध, ररवत याां और उन्हें सांदेय ित्ते।`
  line `14. कायय पररिद् के अवधवेशन।`
  line `15. कायय पररिद् की शवत याां और कृत्य।`
  line `16. ववद्या पररिद्।`
  line `17. ववद्या पररिद् के कृत् य।`
  line `18. ववत्त सवमवत।`
  line `19. ववत्त सवमवत के कृत्य।`
  line `20. अन्य प्र ावधकारी।`
  line `अध्या य 4`
  line `सांस् था न के अवधकारी`
  line `21. सांस्था न के अवधकारी।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line धाराएां
  line `22. वनदेशक।`
  line `23. कुलसविव।`
  line `24. अन्य अवधकारी।`
  line `अध्या य 5`
  line `ववत्त, लेखा और सांपरीिा`
  line `25. केन्री य सरकार द्व ारा अनुदान।`
  line `26. सांस्था न की वनवध।`
  line `27. ववन्या स या अन्य वनवध।`
  line `28. लेखा और सांपरीिा।`
  line `29. पेंशन और िववष्‍टय वनवध।`
  line `30. सांस्था न के कमयिाररवृांद की वनयुवत।`
  line `30. सांस्था न के कमयिाररवृांद की वनयु वत।`
  line `31. पररवनयम बनाने की शवत।`
  line `32. पररवनयम ककस प्र कार बनाए जाएांगे।`
  line `33. अध्या देश बनाने की शवत।`
  line `34. अध्या देश ककस प्र कार बनाए जाएांगे।`
  line `35. सांस्था न के प्र ावधकाररयों द्व ारा कारबार का सांिालन।`
  line `36. माध्य स् थ म् अवधकरण।`
  line `अध्या य 6 प्र`
  line कीणय
  line `37. ररवत यों के कारण कायों और काययवावहयों का अवववधमान्य न होगा।`
  line `38. सांस्था ओं द्व ारा विवियों आकद का कदया जाना।`
  line `39. प्र ायोवजत स् की में।`
  line `40. ववद्या पररिद् और ववत्त सवमवत की बैठक।`
  line `41. केन्री य सरकार की सांस्था न को वनदेश देने की शवत।`
  line `42. सद्भावपूवय क की गई कारयवाई के वलए सांरिण।`
  line `43. वनयम बनाने की शवत।`
  line `44. पररवनयमों, अध्या देशों और अवधसूिनाओं का राजपत्र में प्र कावशत ककया जाना और सांसद् के समि रखा जाना।`
  line `45. करठनाइयाां दूर करने की शवत।`
  line `46. सांक्रमणकालीन उपबांध।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
