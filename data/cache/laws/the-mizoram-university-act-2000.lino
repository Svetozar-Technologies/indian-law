obj_root_law_translations_hi_sections_1_content:
  string
  line `मिजोरि मिश्ि मिद्यालय अमिमियि, 2000`
  line _________
  line `िाराओं का क्र ि`
  line _________
  line `ि ााराएं`
  line `1. संमिप् त िाि और प्र ारंभ।`
  line `2. पररभाषाएं।`
  line `3. मिश्ि मिद्यालय की स् था पिा।`
  line `4. मिश्ि मिद्यालय के उद्देश्य।`
  line `5. मिश्ि मिद्यालय की शमत यां।`
  line `6. पूिोत्तर पहाड़ी मिश्ि मिद्याल य की संपमत्त का अंतरण।`
  line `7. अमिकाररता।`
  line `8. मिश्ि मिद्यालय का सभ़ी िर्गों, जामतयों और पंथों के मलए खुला होिा।`
  line `9. कुलाध्य ि।`
  line `9 क. िुख्य कुलामिसमिि।`
  line `10. मिश्ि मिद्यालय के अमिकाऱी।`
  line `11. कुलपमत।`
  line `12. प्र मतकुलपमत।`
  line `13. मिद्याप़ीठ के संकायाध्य ि।`
  line `14. कुलसमिि।`
  line `15. मित्त अमिकाऱी।`
  line `16. पुस्त कालयाध्य ि।`
  line `17. अन्य अमिकाऱी।`
  line `18. मिश्ि मिद्यालय के प्र ामिकरण।`
  line `19. सभा।`
  line `20. कायय पररषद्।`
  line `21. मिद्या पररषद्।`
  line `22. िहामिद्यालय मिकास पररषद्।`
  line `23. अध्य यि बोर्य।`
  line `24. मित्त समिमत।`
  line `25. मिश्ि मिद्यालय के अन्य प्र ामिकर ण।`
  line `26. पररमियि बिािे की शमत।`
  line `27. पररमियि कैसे बिाए जाएंर्गे।`
  line `28. अध्या देश बिािे की शमत।`
  line `29. मिमियि।`
  line `30. िार्षयक ररपोर्य।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
