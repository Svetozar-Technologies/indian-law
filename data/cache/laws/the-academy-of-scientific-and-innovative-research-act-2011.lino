obj_root_law:
  object
  (str slug) (str the-academy-of-scientific-and-innovative-research-act-2011)
  (str handle) (str 2110)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Academy of Scientific and Innovative Research Act, 2011`)
  (str actNumber) (str 13)
  (str enactmentDate) (str 2012-02-06)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2110`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `वैज्ञानिक और प्रवर्तित अनुसंधान अकादमीअधिनियम, 2011`)
  (str actYear) (str 2012)
  (str ministry) (str `Ministry of Science and Technology`)
  (str department) (str `Department of Secientific and Industrial Research`)
  (str longTitle) (str `An Act to establish an Academy for furtherance of the advancement of learning and prosecution of research in the field of science and technology in association with Council of Scientific and Industrial Research and to declare the institution known as the Academy of Scientific and Innovative Research, to be an institution of national importance to provide for its incorporation and matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 03-04-2012)
  (str notification) (str `3rd April, 2012 (except sub-section (2) of section 5), vide notification No. S.O. 709(E), dated 2nd April, 2012, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 26th June, 2013 (sub-sec. (2) of section 5), vide notification No. S.O. 1850(E), dated 26th June, 2013, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T16:23:09.425Z`)
  (str translations) obj_root_law_translations
