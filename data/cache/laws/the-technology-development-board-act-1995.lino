obj_root_law:
  slug the-technology-development-board-act-1995
  handle (1901)
  collectionHandle 123456789/1362
  title `The Technology Development Board Act, 1995`
  actNumber (44)
  enactmentDate 1995-12-16
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1901`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `प्रौद्योगिकी विकास बोर्ड अधिनियम, 1995`
  actYear (1995)
  ministry `Ministry of Science and Technology`
  department `Department of Science and Technology`
  longTitle `An Act to provide for the constitution of a Board for payment of equity capital or any other financial assistance to industrial concerns and other agencies attempting development and commercial application of indigenous technology or adapting imported technology to wider domestic applications and for matters connected therewith or incidental thereto.`
  enforcementDate 01-11-1996
  notification `1st November, 1996, vide notification No. S.O. 602(E), dated 29th August, 1996, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T21:54:50.078Z`
