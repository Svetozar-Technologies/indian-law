obj_root_law_sections_1:
  sectionId (34816)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34816&sectionno=1&orderno=1&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Delivery of Books ^1[and Newspapers]`
  line `(Public Libraries) Act, 1954.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Ins. by Act 99 of 1956, s. 3 (w.e.f. 29-12-1956).`
  line
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (34817)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Ins. by s. 4, ibid. (w.e.f. 29-12-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34817&sectionno=2&orderno=2&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires:--`
  line
  line `(a) "book" includes every volume, part or division of a volume and pamphlet, in any language,`
  line `and every sheet of music, map, chart or plan separately printed or lithographed, but does not include a`
  line `newspaper published in conformity with the provisions of section 5 of the Press and Registration of`
  line `Books Act, 1867(XXV of 1867):`
  line
  line `^1[(aa) 'newspaper' means any printed periodical work containing public news or comments on`
  line `public news published in conformity with the provisions of section 5 of the Press and Registration of`
  line `Books Act, 1867 (25 of 1867).]`
  line
  line `(b) "public libraries" means the National Library at Calcutta and any three other libraries which`
  line `may be specified by the Central Government in this behalf by notification in the Official Gazette.`
obj_root_law_sections_3:
  sectionId (34818)
  sectionNo (3)
  orderNo 3
  title `Delivery of books of public libraries.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34818&sectionno=3&orderno=3&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_3_content:
  string
  line `(1) Subject to any rules that may be made under this Act,`
  line `but without prejudice to the provisions contained in Section 9 of the Press and Registration of Books Act,`
  line `1867 (XXV of 1867), the publisher of every book published is the territories to which this Act extends`
  line `after the commencement of this act, shall, notwithstanding any agreement to the contrary, deliver at his`
  line `own expense a copy of the book to the National Library at Calcutta and one such copy to each of the other`
  line `three public libraries within thirty days from the date of its publication.`
  line
  line `(2) The copy delivered to the National Library shall be a copy of the whole book with all maps and`
  line `illustrations belonging thereto, finished and coloured in the same manner as the best copies of the same,`
  line `and shall be bound, sewed or stitched together and on the best paper on which any copy of the book is`
  line printed.
  line
  line `(3) The copy delivered to any other public library shall be on the paper on which the largest number`
  line `of copies of the books is printed for sale, and shall be in the like condition as the book prepared for sale.`
  line
  line `(4) Nothing contained in sub-section (1) shall apply to any second or subsequent edition of a book in`
  line `which edition no additions or alterations either in the letter-press or in the maps, book prints or other`
  line `engravings belongings to the book have been made, and a copy of the first or some preceding edition of`
  line `which book has been delivered under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_3_a:
  sectionId (34819)
  sectionNo 3A
  orderNo 4
  title `Delivery of newspapers to public libraries.`
  content obj_root_law_sections_3_a_content
  footnotes `1. Ins. by s. 5, ibid. (w.e.f. 29-12-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34819&sectionno=3A&orderno=4&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Delivery of newspapers to public libraries. --Subject to any rules that may be made under`
  line `this Act, but without prejudice to the provisions contained in the Press and Registration of Books Act,`
  line `1867 (25 of 1867.), the publisher of every newspaper, published in the territories to which this Act`
  line `extends, shall deliver at his own expense one copy of each issue of such newspaper as soon as it is`
  line `published to each such public library as may be notified in this behalf by the Central Government in the`
  line `Official Gazette.]`
obj_root_law_sections_4:
  sectionId (34820)
  sectionNo (4)
  orderNo 5
  title `Receipt for books delivered.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34820&sectionno=4&orderno=5&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_4_content:
  string
  line `The person in charge of a public library (whether called a librarian`
  line `or by any other name) or any other person authorised by him in this behalf to whom a copy of a book is`
  line `delivered under Section 3 shall give to the publisher a receipt in writing therefor.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (34821)
  sectionNo (5)
  orderNo 6
  title Penalty.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34821&sectionno=5&orderno=6&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_5_content:
  string
  line `Any publisher who contravenes any provision of this Act or of any rule made`
  line `thereunder shall be punishable with fine which may extend to fifty rupees^1[and, if the contravention is in`
  line `respect of a book, shall also be punishable with fine which shall be equivalent to the value of the book],`
  line `and the court trying the offence may direct that the whole or any part of the fine realised from him shall`
  line `be paid, by way of compensation, to the public library to which the book ^2[or newspaper, as the case may`
  line `be] ought to have been delivered.`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by Act 99 of 1956, s. 6, for "and the value of the book" (w.e.f. 29-12-1956).`
  line
  line `2. Ins. by s. 6, ibid. (w.e.f. 29-12-1956).`
obj_root_law_sections_6:
  sectionId (34822)
  sectionNo (6)
  orderNo 7
  title `Cognizance of offences.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34822&sectionno=6&orderno=7&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_6_content:
  string
  line `(1) No court shall take cognizance of any offence punishable under this`
  line `Act save on complaint made by an officer empowered in this behalf by the Central Government by a`
  line `General or special order.`
  line
  line `(2) No court inferior to that of a presidency magistrate or a magistrate of the first class shall try any`
  line `offence punishable under this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (34823)
  sectionNo (7)
  orderNo 8
  title `Application of Act to books and newspapers published by Government.`
  content obj_root_law_sections_7_content
  footnotes `1. Subs. by s. 7, ibid., for section 7 (w.e.f. 29-12-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34823&sectionno=7&orderno=8&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_7_content:
  string
  line `^1[7. Application of Act to books and newspapers published by Government.--This Act shall also`
  line `apply to books and newspapers published by or under the authority of the Government but shall not apply`
  line `to books meant for official use only.]`
obj_root_law_sections_8:
  sectionId (34824)
  sectionNo (8)
  orderNo 9
  title `Power to make rules.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_27_37_00006_195427_1517807322342&sectionId=34824&sectionno=8&orderno=9&orgactid=AC_CEN_27_37_00006_195427_1517807322342
obj_root_law_sections_8_content:
  string
  line `^1[(1)] The Central Government may, by notification in the Official`
  line `Gazette, makes rules to carry out the purposes of this Act.`
  line
  line `^2[(2) Every rule made by the Central Government under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
obj_root_law_sections_8_footnotes:
  string
  line `1. Section 8 re-numbered as sub-section (1) thereof by Act 4 of 2005, s. 2 and the Schedule (w.e.f. 11-1-2005).`
  line
  line `2. Added by s. 2 and the Schedule, ibid. (w.e.f. 11-1-2005).`
