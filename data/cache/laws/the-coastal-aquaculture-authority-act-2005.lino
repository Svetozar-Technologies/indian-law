  line
obj_root_law_sections_14:
  sectionId (1748)
  sectionNo (14)
  orderNo 18
  title `Penalty for carrying on coastal aquaculture in contravention of provisions of Act.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1748&sectionno=14&orderno=18&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_14_content:
  string
  line `If any person carries`
  line `on coastal aquaculture or traditional coastal aquaculture or causes the coastal aquaculture or traditional`
  line `coastal aquaculture to be carried on in contravention of sub-section (1) of section 13, he shall be`
  line `punishable with imprisonment for a term which may extend to three years or with fine which may extend`
  line `to one lakh rupees, or with both.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_14_a:
  sectionId (77471)
  sectionNo 14A
  orderNo 19
  title Appeal.
  content obj_root_law_sections_14_a_content
  footnotes obj_root_law_sections_14_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=77471&sectionno=14A&orderno=19&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_14_a_content:
  string
  line
obj_root_law_sections_14_a_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (1749)
  sectionNo (15)
  orderNo 20
  title `Cognizance of offence.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1749&sectionno=15&orderno=20&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_15_content:
  string
  line `No court shall take cognizance of an offence under section 14 without a`
  line `written complaint filed by an officer of the Authority authorised in this behalf by it.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (1750)
  sectionNo (16)
  orderNo 21
  title `Payment to Authority.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1750&sectionno=16&orderno=21&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_16_content:
  string
  line `The Central Government may, after due appropriation made by`
  line `Parliament, by law, in this behalf, pay to the Authority in each financial year such sums as may be`
  line `considered necessary for the performance of functions of the Authority under this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (1751)
  sectionNo (17)
  orderNo 22
  title `Fund of Authority.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1751&sectionno=17&orderno=22&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_17_content:
  string
  line `(1) The Authority shall have its own fund and all sums which may, from`
  line `time to time, be paid to it by the Central Government and all the receipts of the Authority (including any`
  line `sum which any State Government or any other authority or person may hand over to the Authority) shall`
  line `be credited to the fund and all payments by the Authority shall be made therefrom.`
  line
  line `(2) All moneys belonging to the fund shall be deposited in such banks or invested in such manner as`
  line `may, subject to the approval of the Central Government, be decided by the Authority.`
  line
  line `(3) The Authority may spend such sums as it thinks fit for performing its functions under this Act,`
  line `and such sums shall be treated as expenditure payable out of the fund of the Authority.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (1752)
  sectionNo (18)
  orderNo 23
  title Budget.
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1752&sectionno=18&orderno=23&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_18_content:
  string
  line `The Authority shall prepare, in such form and at such time each year as may be`
  line `prescribed, a budget, in respect of the financial year next ensuing, showing the estimated receipts and`
  line `expenditure and copies thereof shall be forwarded to the Central Government.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (1753)
  sectionNo (19)
  orderNo 24
  title `Annual report.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1753&sectionno=19&orderno=24&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_19_content:
  string
  line `The Authority shall prepare once in every calendar year, in such form and at`
  line `such time as may be prescribed an annual report giving a true and full account of its activities during the`
  line `previous year and copies thereof shall be forwarded to the Central Government and that Government shall`
  line `cause the same to be laid before both Houses of Parliament.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (1754)
  sectionNo (20)
  orderNo 25
  title `Accounts and audit.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1754&sectionno=20&orderno=25&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_20_content:
  string
  line `(1) The Authority shall cause to be maintained such books of account and`
  line `other books in relation to its accounts in such form and in such manner as may, in consultation with the`
  line `Comptroller and Auditor-General of India, be prescribed.`
  line
  line `(2) The Authority shall, as soon as may be, after closing its annual accounts, prepare a statement of`
  line `accounts in such form, and forward the same to the Comptroller and Auditor-General of India by such`
  line `date, as the Central Government may, in consultation with the Comptroller and Auditor-General of India,`
  line determine.
  line
  line `(3) The accounts of the Authority shall be audited by the Comptroller and Auditor-General of India at`
  line `such times and in such manner as he thinks fit.`
  line
  line `(4) The accounts of the Authority as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before both`
  line `Houses of Parliament.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (1755)
  sectionNo (21)
  orderNo 26
  title `Chairperson and other members, officers and other employees of Authority, etc., to be public servants.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1755&sectionno=21&orderno=26&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_21_content:
  string
  line `The Chairperson and other members and the officers and other employees of the`
  line `Authority and the authority appointed by the Authority shall be deemed to be public servants within the`
  line `meaning of section 21 of the India Penal Code (45 of 1860).`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (1756)
  sectionNo (22)
  orderNo 27
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1756&sectionno=22&orderno=27&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_22_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government or the Authority or the Chairperson and other members of the`
  line `Authority or the authority appointed by the Authority or any person authorised by the Authority or any`
  line `officer authorised by the Chairperson for anything which is in good faith done or intended to be done in`
  line `pursuance of this act or any rule or regulation or order made thereunder.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_22_a:
  sectionId (77476)
  sectionNo 22A
  orderNo 28
  title `Arrears of cost and penalty recoverable as arrears of land revenue.`
  content obj_root_law_sections_22_a_content
  footnotes obj_root_law_sections_22_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=77476&sectionno=22A&orderno=28&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_22_a_content:
  string
  line
obj_root_law_sections_22_a_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (1757)
  sectionNo (23)
  orderNo 29
  title `Power to remove difficulties.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1757&sectionno=23&orderno=29&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_23_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of the period of two years from the date of`
  line `the commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (1758)
  sectionNo (24)
  orderNo 30
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1758&sectionno=24&orderno=30&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_24_content:
  string
  line `(1) The Central Government may, by`
  line `notification in the Official Gazette, make rules to carry out the provisions of this act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing powers, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the guidelines under section 3;`
  line
  line `(b) the salaries and allowances payable to, and the other terms and conditions of service of, the`
  line `members under sub-section (5) of section 4;`
  line
  line `(c) the other functions of the Authority under clause (e) of sub-section (1) of section 11;`
  line
  line `(d) the powers of a District Magistrate to be exercised by the authority under sub-section (2) of`
  line `section 11;`
  line
  line `(e) the rules subject to which any person referred to in section 12 may enter upon any coastal`
  line `aquaculture land, pond, pen or enclosure under that section;`
  line
  line `(f) the other acts or things under clause (c) of section 12;`
  line
  line `(g) the form of application and the fees to be accompanied therewith under sub-section (4) of`
  line `section 13;`
  line
  line `(h) the manner of considering application under sub-section (5) of section 13;`
  line
  line `(i) the form of certificate of registration under sub-section (6) of section 13;`
  line
  line `(j) the form of application and the fees to be accompanied therewith under sub-section (10) of`
  line `section 13;`
  line
  line `(k) the form and time of preparing budget under section 18;`
  line
  line `(l) the form and time of preparing annual report under section 19;`
  line
  line `(m) the books of account and other books to be maintained in relation to the accounts of the`
  line `Authority and the form and manner of maintaining such books of account and other books under subsection`
  line `(1) of section 20;`
  line
  line `(n) any other matter which is required to be, or may be, prescribed.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (1759)
  sectionNo (25)
  orderNo 31
  title `Power of Authority to make regulations.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1759&sectionno=25&orderno=31&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_25_content:
  string
  line `(1) The Authority may, by notification in the`
  line `Official Gazette, make regulations not inconsistent with the provisions of this Act and the rules made`
  line `thereunder to carry out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing powers, such regulations`
  line `may provide for all or any of the following matters, namely:--`
  line
  line `(a) the times and places of the meetings of the Authority and the rules of procedure to be`
  line `observed in regard to the transaction of business at its meetings (including quorum thereat) under`
  line `sub-section (1) of section 7;`
  line
  line `(b) the terms and conditions of appointment of the officers and other employees under`
  line `sub-section (1) section 9;`
  line
  line `(c) the terms and conditions of appointment of adviser or consultant under sub-section (2) of`
  line `section 9;`
  line
  line `(d) for the construction and operation of coastal aquaculture farms within the coastal areas under`
  line `clause (a) of sub-section (1) of section 11;`
  line
  line `(e) the form and conditions of registration under clause (c) of sub-section (3) of section 13;`
  line
  line `(f) generally for better regulation of the coastal aquaculture.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (1760)
  sectionNo (26)
  orderNo 32
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1760&sectionno=26&orderno=32&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_26_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (1761)
  sectionNo (27)
  orderNo 33
  title Validation.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=1761&sectionno=27&orderno=33&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_27_content:
  string
  line `(1) Notwithstanding anything contained in clause (v) of sub-section (2) of section 3`
  line `of the Environment (Protection) Act, 1986 (29 of 1986) or clause (d) of sub-rule (3) of rule 5 of the`
  line `Environment (Protection) Rules, 1986, in the notification of the Government of India in the Ministry of`
  line `Environment and Forests (Department of Environment, Forests and Wildlife) No. S.O.114(E), dated the`
  line `19th February, 1991 (hereafter referred to in this section as the said notification), in paragraph 2, after`
  line `sub-paragraph (xiii), the following sub-paragraph shall be inserted and shall always be deemed to have`
  line `been inserted with effect from the 19th day of February, 1991, namely:--`
  line
  line `"(xiv) nothing contained in this paragraph shall apply to coastal aquaculture".`
  line
  line `(2) The said notification shall have and shall be deemed always to have effect for all purposes as if`
  line `the foregoing provisions of this section had been in force at all material times and accordingly`
  line `notwithstanding anything contained in any judgment, decree or order of any court, tribunal or other`
  line `authority, no coastal aquaculture carried on or undertaken or purporting to have been carried on or`
  line `undertaken shall deemed to be in contravention of the said notification and shall be deemed to be and to`
  line `have always been for all purposes in accordance with law, as if the foregoing provisions of this section`
  line `had been in force at all material times and notwithstanding anything as aforesaid and without prejudice to`
  line `the generality of the foregoing provisions, no suit or other proceeding shall be maintained or continued in`
  line `any court for the enforcement of any direction given by any court of any decree or order directing the`
  line `removal or closure of any coastal aquaculture farm's activity or demolition of any structure connected`
  line `thereunder which would not have been so required to be removed, closed or demolished if the foregoing`
  line `provisions of this section had been in force at all material times.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (77478)
  sectionNo (28)
  orderNo 34
  title `Validation of certain provisions and amendments retrospectively.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00004_200524_1517807323120&sectionId=77478&sectionno=28&orderno=34&orgactid=AC_CEN_23_62_00004_200524_1517807323120
obj_root_law_sections_28_content:
  string
  line
obj_root_law_sections_28_footnotes:
  string
  line
