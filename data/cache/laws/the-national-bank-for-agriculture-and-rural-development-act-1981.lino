obj_root_law:
  slug the-national-bank-for-agriculture-and-rural-development-act-1981
  handle (1670)
  collectionHandle 123456789/1362
  title `The National Bank for Agriculture and Rural Development Act, 1981`
  actNumber (61)
  enactmentDate 1981-12-30
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1670`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्ट्रीय कृषि और ग्रामीण विकास बैंक अधिनियम, 1981`
  actYear (1981)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to establish a development bank to be known as the National Bank for Agriculture and Rural Development for providing and regulating credit and other facilities for the promotion and development of agriculture, small-scale industries, cottage and village industries, handicrafts and other rural crafts and other allied economic activities in rural areas with a view to promoting integrated rural development and securing prosperity of rural areas and for matters connected therewith or incidental thereto.`
  enforcementDate 01-05-1982
  notification `1st May, 1982, vide notification No. S.O. 278(E), dated 21st April, 1982 (except sections 3, 16 and 18), see Gazette of India, Extraordinary, Part II, sec. 3(ii). 12th July, 1982, vide notification No. S.O. 484(E), dated 6th July, 1982 (in respect sections 3, 16 and 18), see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T21:32:18.464Z`
  translations obj_root_law_translations
