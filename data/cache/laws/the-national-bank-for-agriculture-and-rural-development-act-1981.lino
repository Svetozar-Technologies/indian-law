obj_root_law:
  object
  (str slug) (str the-national-bank-for-agriculture-and-rural-development-act-1981)
  (str handle) (str 1670)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Bank for Agriculture and Rural Development Act, 1981`)
  (str actNumber) (str 61)
  (str enactmentDate) (str 1981-12-30)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1670`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `राष्ट्रीय कृषि और ग्रामीण विकास बैंक अधिनियम, 1981`)
  (str actYear) (str 1981)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Financial Services`)
  (str longTitle) (str `An Act to establish a development bank to be known as the National Bank for Agriculture and Rural Development for providing and regulating credit and other facilities for the promotion and development of agriculture, small-scale industries, cottage and village industries, handicrafts and other rural crafts and other allied economic activities in rural areas with a view to promoting integrated rural development and securing prosperity of rural areas and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-05-1982)
  (str notification) (str `1st May, 1982, vide notification No. S.O. 278(E), dated 21st April, 1982 (except sections 3, 16 and 18), see Gazette of India, Extraordinary, Part II, sec. 3(ii). 12th July, 1982, vide notification No. S.O. 484(E), dated 6th July, 1982 (in respect sections 3, 16 and 18), see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
