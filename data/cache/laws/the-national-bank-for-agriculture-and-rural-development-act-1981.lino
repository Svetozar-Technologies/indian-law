obj_root_law_sections_62:
  sectionId (28812)
  sectionNo (62)
  orderNo 69
  title `Power to remove difficulty.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_57_00002_198161_1517807321872&sectionId=28812&sectionno=62&orderno=69&orgactid=AC_CEN_23_57_00002_198161_1517807321872
obj_root_law_sections_62_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order, not inconsistent with the provisions of this Act, remove the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of three years from the`
  line `commencement of this Act.`
obj_root_law_sections_62_footnotes:
  string
  line
