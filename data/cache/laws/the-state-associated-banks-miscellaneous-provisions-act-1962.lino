  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_196256_1517807322465&sectionId=32593&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00030_196256_1517807322465
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the State-Associated Banks`
  line `(Miscellaneous Provisions) Act, 1962.`
  line
  line `(2) Section 3, except clauses (ii), (iv), and (vii) thereof, shall come into force on such date^1`
  line `as the`
  line `Central Government may, by notification in the Official Gazette, appoint; and the rest of this Act shall`
  line `come into force at once.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st January, 1963: vide notification No.G.S.R.1781, dated 18th December, 1962, see Gazette of India, Extraordinary, Part II`
  line `sec. 3(i).`
