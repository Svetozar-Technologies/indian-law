obj_root_law_sections_1:
  object
  (str sectionId) (str 32593)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the State-Associated Banks
(Miscellaneous Provisions) Act, 1962.

(2) Section 3, except clauses (ii), (iv), and (vii) thereof, shall come into force on such date^1
as the
Central Government may, by notification in the Official Gazette, appoint; and the rest of this Act shall
come into force at once.`)
  (str footnotes) (str `1. 1st January, 1963: vide notification No.G.S.R.1781, dated 18th December, 1962, see Gazette of India, Extraordinary, Part II
sec. 3(i).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00030_196256_1517807322465&sectionId=32593&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00030_196256_1517807322465)
