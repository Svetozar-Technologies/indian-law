obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `डिजाइन अडिडनयम, 2000`
  line _________
  line `िाराओं का क्र म`
  line _________
  line `िा राएं`
  line `अध्याय 1 प्र`
  line ारंडिक
  line `1. संडिप् त नाम, डिस्तार और प्र ारंि।`
  line `2. पररिाषाएं।`
  line `अध्याय 2`
  line `डिजाइनों का रडजस्रीकरण`
  line `3. डनयंत्रक और अन्य अडिकारी।`
  line `4. कडतपय डिजाइनों के रडजस्रीकरण पर प्र डतषेि।`
  line `5. डिजा इनों के रडजस्रीकरण के डिए आिेदन।`
  line `6. रडजस्रीकरण डिडिष्ट िस्तु की बाबत ही होगा।`
  line `7. रडजस्रीकृत डिजाइन की डिडिडष्ट यों का प्र कािन।`
  line `8. आिेदन, आदद के प्र डतस्थापन के संबंि में आदेि करने की डनयंत्रक की िडत।`
  line `9. रडजस्रीकरण का प्र माणपत्र।`
  line `10. डिजाइनों का रडजस्टर।`
  line `अध्याय 3`
  line `रडजस्रीकृत डिजाइनों में प्र डतडिप्यडिकार`
  line `11. रडजस्रीकरण के पश्चा त् प्र डतडिप्यडिकार।`
  line `12. व्य पगत डिजाइन का प्रत् यािततन।`
  line `13. व्य पगत डिजाइनों के प्रत् यािततन के डिए आिेदन के डनपटारे के डिए प्र दक्रया।`
  line `14. ऐसे व्य पगत डिजाइन के, जो प्रत् यािर्ततत कर ददया गया है, स् ित्ििारी के अडिकार।`
  line `15. डिक्रय के पश्चा त् पररदान के पूित की अपेिाएं।`
  line `16. प्र डतडिप्यडिकार पर प्र कटन का प्र िाि।`
  line `17. रडजस्रीकृत डिजाइनों का डनरीिण।`
  line `18. प्र डतडिप्यडिकार के डिद्यमान होने के बारे में जानकारी।`
  line `19. रडज स् रीकरण का रद्द दकया जाना।`
  line `20. डिजाइनों से सरकार का आबद्ध होना।`
  line `अध्याय 4`
  line `औद्योडगक और अन्तरराष्री य प्र दितडनयां`
  line `21. प्र दितडनयों के बारे में उपबन्ि।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
