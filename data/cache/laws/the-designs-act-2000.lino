  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line `िा राएं`
  line `अध्याय 5`
  line `डिडिक कायतिाडहयां`
  line `22. रडजस्रीकृत डिजाइन की चोरी।`
  line `23. डिजाइनों के पेटेन्टों के संबंि में अडिडनयम के कुछ उपबंिों का िागू होना।`
  line `अध्याय 6`
  line सािारण
  line फीसें
  line `24. फीसें।`
  line `पेटेन्ट कायातिय के रडजस्टरों और अन्य दस्तािेजों के बारे में उपबंि`
  line `25. न् यास की सूचना को रडजस्टरों में दजत न दकया जाना।`
  line `26. रडजस्टरों का डनरीिण और उनसे उद्धरणों आदद का दद या जाना।`
  line `27. डनयत्रंक की ररपोटों को डििेषाडिकार प्र ाप्त होना।`
  line `28. डिडनदेिों, रेखा - डचत्रों आदद के प्र कािन का उस दिा में प्र डतषेि डजसमें आिेदन का पररत्याग कर ददया गया हो।`
  line `29. िेखन िूिों को ठीक करने की डनयंत्रक की िडत।`
  line `30. समनुदेिनों और पारेषणों का रडजस्टरों में दजत दकया जाना।`
  line `31. रडजस्टर की पररिुडद्ध।`
  line `अध्याय 7`
  line `डनयंत्रक की िडत यां और कततव्य`
  line `32. अडिडनयम के अिीन कायतिाडहयों में डनयंत्रक की िडत यां।`
  line `33. डनयंत्रक द्व ारा िैिेदकक िडत का प्र योग।`
  line `34. केन्रीय सरकार से डनदेि प्र ाप्त करने की डनयंत्रक की िडत।`
  line `35. कुछ मामिों में डिजाइन को रडजस्रीकृत करने से इन्कार करना।`
  line `36. उच्च न् यायािय को अपीिें।`
  line `अध्याय 8`
  line `साक्ष्य, आदद`
  line `37. डनयंत्रक के समि साक्ष्य।`
  line `38. डनयंत्रक के प्र माणपत्र का साक्ष्य होना।`
  line `39. पेटेन्ट कायातिय में दस्तािेजों का सा क्ष् य।`
  line `40. आिेदनों और सूचनाओं का िाक द्व ारा िेजा जाना।`
  line `41. डििु, पागि आदद द्व ारा घोषणा।`
  line `42. कडतपय डनबंिनात्मक ितों का पररिजतन।`
  line `अध्याय 9`
  line अडिकरण
  line `43. अडिकरण।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
