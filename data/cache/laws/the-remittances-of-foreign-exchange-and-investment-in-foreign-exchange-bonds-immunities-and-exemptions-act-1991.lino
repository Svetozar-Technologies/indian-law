obj_root_law_translations_hi:
  object
  (str title) (str `विदेशी मुद्रा प्रेषण और विदेशी मुद्रा बंधपत्रों में विनिधान (उन्‍मुक्‍ति और छूट) अधिनियम, 1991`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1905/2/hH1991-41.pdf`)
  (str sourceKind) (str pdf)
