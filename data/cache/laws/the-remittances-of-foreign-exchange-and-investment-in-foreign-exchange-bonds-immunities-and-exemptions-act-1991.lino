obj_root_law_sections_1:
  sectionId (32534)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00017_199141_1517807320780&sectionId=32534&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00017_199141_1517807320780
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Remittances of Foreign Exchange and`
  line `Investment in Foreign Exchange Bonds (Immunities and Exemptions) Act, 1991.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (32535)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00017_199141_1517807320780&sectionId=32535&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00017_199141_1517807320780
obj_root_law_sections_2_content:
  string
  line `In this Chapter, unless the context otherwise requires,--`
  line
  line `(a) "recipient" means a person as defined in clause (31) of section 2 of the Income-tax Act, 1961`
  line `(43 of 1961) who receives any remittance under this Chapter;`
  line
  line `(b) "remittance" means remittance made in foreign exchange by any person resident outside India`
  line `to a person resident in India on or after the date of commencement of this Act but before the specified`
  line `date, in the form of draft, travellers cheques, cheques drawn on banks situated outside India`
  line `telegraphic transfers, mail transfers, money orders or by way of transfer from Non-resident (External)`
  line `Account, Foreign Currency Non-resident Account or Foreign Currency Non-resident Special Deposit`
  line `Account maintained in India under the rules made under the Foreign Exchange Regulation Act, 1973`
  line `(46 of 1973).`
  line
  line `Explanation.--For the purposes of this clause, "specified date" means the 1st day of December,`
  line `1991 or such other later date as the Central Government may, by notification in the Official Gazette,`
  line `specify in this behalf;`
  line
  line `(c) all other words and expressions used in this Chapter but not defined and defined in the`
  line `Foreign Exchange Regulation Act, 1973 (46 of 1973) shall have the meanings respectively assigned`
  line `to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (32536)
  sectionNo (3)
  orderNo 3
  title Immunities.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00017_199141_1517807320780&sectionId=32536&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00017_199141_1517807320780
obj_root_law_sections_3_content:
  string
  line `(1) Notwithstanding anything contained in any other law for the time being in`
  line force,--
  line
  line `(a) no recipient, who claims immunity under this Chapter in accordance with such scheme as the`
  line `Reserve Bank of India may, by notification in the Official Gazette, specify for the purposes of`
  line `receiving remittances under this Chapter, shall be required to disclose, for any purpose whatsoever,`
  line `the nature and source of the remittance made to him;`
  line
  line `(b) no inquiry or investigation shall be commenced against the recipient under any such law on`
  line `the ground that he has received such remittance;`
  line
  line `(c) the fact that the recipient has received a remittance shall not be taken into account and shall be`
  line `inadmissible as evidence in any proceedings relating to any offence or the imposition of any penalty`
  line `under any such law.`
  line
  line `(2) Nothing in sub-section (1) shall apply--`
  line
  line `(a) to any foreign exchange which is required to be brought into India under any of the provisions`
  line of--
  line
  line `(i) the Foreign Exchange Regulation Act, 1973 (46 of 1973); or`
  line
  line `(ii) the Income-tax Act, 1961 (43 of 1961), read with the Foreign Exchange Regulation Act,`
  line `1973 (46 of 1973),`
  line
  line `if the period within which such foreign exchange is to be brought into India has not expired or where such`
  line `period has been extended, in any manner, by the Central Government or the Reserve Bank of India or any`
  line `other authority, such extended period has not expired on the date of commencement of this Act;`
  line
  line `(b) in relation to prosecution for any offence punishable under Chapter IX or Chapter XVII of the`
  line `Indian Penal Code (45 of 1860), the Narcotic Drugs and Psychotropic Substances Act, 1985`
  line `(61 of 1985), the Terrorist and Disruptive Activities (Prevention) Act, 1987 (28 of 1987), the`
  line `Prevention of Corruption Act, 1988 (49 of 1988)or for the purpose of enforcement of any civil`
  line liability.
  line
  line `(3) The Central Government shall cause the scheme notified under clause (a) of sub-section (1) to be`
  line `laid, as soon as may be after it is notified, before each House of Parliament.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (32537)
  sectionNo (4)
  orderNo 4
  title `Remittances not to be taken into account in certain cases.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00017_199141_1517807320780&sectionId=32537&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00017_199141_1517807320780
obj_root_law_sections_4_content:
  string
  line `Without prejudice to the generality`
  line `of the provisions of section 3,--`
  line
  line `(a) any remittance received under this Chapter shall not be taken into account for the purpose of`
  line `any proceeding under the Income-tax Act, 1961 (43 of 1961) and, in particular, the recipient shall not`
  line `be entitled to claim any set-off or relief in any assessment, re-assessment, appeal, reference or other`
  line `proceeding under that Act or to re-open any assessment or re-assessment made under that Act on the`
  line `ground that he has received such remittance.`
  line
  line `Explanation.--For the avoidance of doubt, it is hereby declared that the provisions of the`
  line `Income-tax Act, 1961 (43 of 1961) will apply to any income which accrues or arises or is deemed to`
  line `accrue or arise to the recipient from the amount of the remittance;`
  line
  line `(b) any remittance received under this Chapter shall not form part of the assets of any assessee for`
  line `the purposes of computing his net wealth under the Wealth-tax Act, 1957 (27 of 1957) in relation to`
  line `any assessment year commencing before the 1st day of April, 1992.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (32538)
  sectionNo (5)
  orderNo 5
  title Definitions.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00017_199141_1517807320780&sectionId=32538&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00017_199141_1517807320780
obj_root_law_sections_5_content:
  string
  line `(1) In this Chapter, unless the context otherwise requires,`
  line
  line `(a) "Foreign Exchange Bonds" means the Bonds, issued by the State Bank of India constituted`
  line `under the State Bank of India Act, 1955 (28 of 1955) in accordance with such scheme as the Reserve`
  line `Bank of India may, by notification in the Official Gazette, specify in this behalf, the investment`
  line `wherein is made on or after the date of commencement of this Act but before the specified date.`
  line
  line `Explanation.--For the purposes of this clause, "specified date" means the 1st day of December,`
  line `1991 or such other later date as the Central Government may, by notification in the Official Gazette,`
  line `specify in this behalf;`
  line
  line `(b) "non-resident Indian" means an individual, being a citizen of India or a person of Indian`
  line `origin who is resident outside India.`
  line
  line `Explanation 1.--A person shall be deemed to be of Indian origin if--`
  line
  line `(i) he, or either of his parents or any of his grand- parents, was a citizen of India by virtue of`
  line `the Constitution or the Citizenship Act, 1955 (57 of 1955); or`
  line
  line `(ii) he at any time held an Indian passport:`
  line
  line `Provided that the nationals of Pakistan or Bangladesh shall not be deemed to be of Indian origin.`
  line
  line `Explanation 2.--A spouse (not being a national of Pakistan or Bangladesh) of a person of Indian`
  line `origin shall also be deemed to be of Indian origin;`
  line
  line `(c) "overseas corporate body" means any institution, association or body, whether incorporated or`
  line `not, established under the laws of a country outside India wherein any non-resident Indian has any`
  line interest;
  line
  line `(d) all other words and expressions used in this Chapter but not defined and defined in the`
  line `Foreign Exchange Regulation Act, 1973 (46 of 1973), shall have the meanings respectively assigned`
  line `to them in that Act.`
  line
  line `(2) The Central Government shall cause the scheme notified under clause (a) of sub-section (1) to be`
  line `laid, as soon as may be after it is notified, before each House of Parliament.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (32539)
  sectionNo (6)
  orderNo 6
  title Immunities.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00017_199141_1517807320780&sectionId=32539&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00017_199141_1517807320780
obj_root_law_sections_6_content:
  string
  line `(1) Notwithstanding anything contained in the Wealth-tax Act, 1957 (27 of 1957),`
  line `the Gift-tax Act, 1958 (18 of 1958), the Income-tax Act, 1961 (43 of 1961), the Foreign Exchange`
  line `Regulation Act, 1973 (46 of 1973) and the Foreign Contribution (Regulation) Act, 1976 (46 of 1976),--`
  line
  line `(a) no non-resident Indian or overseas corporate body who or which owns the Foreign Exchange`
  line `Bonds or any person resident in India to whom a gift of such Bonds has been made by such nonresident Indian or overseas corporate body, shall be required to disclose, for any purpose whatsoever,`
  line `the nature and source of the investment in such Bonds;`
  line
  line `(b) no inquiry or investigation shall be commenced against any of the persons referred to in`
  line `clause (a) under any of the said Acts on the ground that such person owns such Bonds;`
  line
  line `(c) the fact that any of the persons referred to in clause (a) owns such Bonds shall not be taken`
  line `into account and shall be inadmissible as evidence in any proceedings relating to any offence or the`
  line `imposition of any penalty under any of the said Acts.`
  line
  line `(2) Nothing in sub-section (1) shall apply to foreign exchange which is required to be brought into`
  line `India under any of the provisions of--`
  line
  line `(i) the Foreign Exchange Regulation Act, 1973 (46 of 1973);or`
  line
  line `(ii) the Income-tax Act, 1961 (43 of 1961), read with the Foreign Exchange Regulation Act,`
  line `1973 (46 of 1973),`
  line
  line `if the period within which such foreign exchange is to be brought into India has not expired or where such`
  line `period has been extended, in any manner, by the Central Government or the Reserve Bank of India or any`
  line `other authority, such extended period has not expired on the date of commencement of this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (32540)
  sectionNo (7)
  orderNo 7
  title `Foreign Exchange Bonds not to be taken into account in certain cases.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00017_199141_1517807320780&sectionId=32540&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00017_199141_1517807320780
obj_root_law_sections_7_content:
  string
  line `Without prejudice to`
  line `the generality of the provisions of section 6,--`
  line
  line `(a) the provisions of the Income-tax Act, 1961 (43 of 1961) shall not apply to any interest`
  line `accruing in relation to the Foreign Exchange Bonds;`
  line
  line `(b) the provisions of the Wealth-tax Act, 1957 (27 of 1957) shall not apply in relation to the`
  line `Foreign Exchange Bonds;`
  line
  line `(c) the provisions of the Gift-tax Act, 1958 (18 of 1958) shall not apply where any non-resident`
  line `Indian becomes a resident in India and makes a gift of the Foreign Exchange Bonds.`
obj_root_law_sections_7_footnotes:
  string
  line
