obj_root_law_sections_1:
  sectionId (54438)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54438&sectionno=1&orderno=1&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_1_content:
  string
  line `1. Short title and commencement.--- (1) This Act may be called the National Commission for Allied`
  line `and Healthcare Professions Act, 2021.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification, appoint; and`
  line `different dates may be appointed for different provisions of this Act and any reference in any provision to`
  line `the commencement of this Act shall be construed as a reference to the coming into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 25th May, 2021, vide notification No. S.O. 2012(E), dated 25th May, 2021, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (54439)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54439&sectionno=2&orderno=2&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_2_content:
  string
  line `2. Definitions.—In this Act, unless the context otherwise requires,—`
  line
  line `(a) “Advisory Council” means the National Allied and Healthcare Advisory Council constituted`
  line `under sub-section (1) of section 12;`
  line
  line `(b) “allied and healthcare institution” means an educational or research institution which grants`
  line `diploma or undergraduate, postgraduate or doctoral degree or any other post degree certification in any`
  line `allied and healthcare professional under this Act;`
  line
  line `(c) “allied and healthcare professional” means any allied health professional or healthcare`
  line `professional under this Act;`
  line
  line `(d) “allied health professional” includes an associate, technician or technologist who is trained to`
  line `perform any technical and practical task to support diagnosis and treatment of illness, disease, injury`
  line `or impairment, and to support implementation of any healthcare treatment and referral plan`
  line `recommended by a medical, nursing or any other healthcare professional, and who has obtained any`
  line `qualification of diploma or degree under this Act, the duration of which shall not be less than two`
  line `thousand hours spread over a period of two years to four years divided into specific semesters;`
  line
  line `(e) “allied and healthcare qualification” means a recognised diploma or degree possessed by an`
  line `allied and healthcare professional through regular learning mode under this Act or any additional`
  line `recognised course obtained thereafter;`
  line
  line `(f) “Autonomous Board” means the Autonomous Board constituted under sub-section (1) of section`
  line 29;
  line
  line `(g) “Central Register” means the Central Allied and Healthcare Professionals' Register maintained`
  line `by the Commission under section 13;`
  line
  line `(h) “Chairperson” means the Chairperson of the Commission appointed under clause ((a) of`
  line `sub-section (3) of section 3;`
  line
  line `(i) “Commission” means the National Commission for Allied and Healthcare Profession`
  line `constituted under sub-section (1) of section 3;`
  line
  line `(j) “healthcare professional” includes a scientist, therapist or other professional who studies,`
  line `advises, researches, supervises or provides preventive, curative, rehabilitative, therapeutic or`
  line `promotional health services and who has obtained any qualification of degree under this Act, the`
  line `duration of which shall not be less than three thousand six hundred hours spread over a period of three`
  line `years to six years divided into specific semesters;`
  line
  line `(k) “Interim Commission” means the Interim Commission constituted under sub-section (1)`
  line `of section 20;`
  line
  line `(l) “Member” means a Member of the Commission or, as the case may be, the State Council,`
  line `including the Chairperson, Vice-Chairperson and Part-time Member;`
  line
  line `(m) “notification” means a notification published in the Official Gazette and the expression`
  line `“notified” shall be construed accordingly;`
  line
  line `(n) “Part-time Member” means the Part-time Member of the Commission nominated by the State`
  line `Government under sub-clauses (i) and (ii) of clause (d), and nominated by the Central Government`
  line `under sub-clause (iii) of clause (d) of section 3;`
  line
  line `(o) “prescribed” means prescribed by rules made under this Act;`
  line
  line `(p) “Professional Council” means the Allied and Healthcare Professional Council constituted under`
  line `sub-section (1) of section 10;`
  line
  line `(q) “recognised categories” means any category of the allied and healthcare professionals specified`
  line `in the Schedule;`
  line
  line `(r) “regulations” means the regulations made by the Commission;`
  line
  line `(s) “Schedule” means the Schedule annexed to this Act;`
  line
  line `(t) “State Council” means a State Allied and Healthcare Council constituted under sub-section (1)`
  line `of section 22;`
  line
  line `(u) “State Government” includes Union territory Administration;`
  line
  line `(v) “State Register” means the State Allied and Healthcare Professionals' Register maintained`
  line `under section 32;`
  line
  line `(w) “Task shifting” means the process whereby specific tasks are moved, where appropriate to`
  line `related allied and healthcare professionals specialised in those tasks, by reorganising the health`
  line `workforce efficiently for improved healthcare;`
  line
  line `(x) “University” means a University defined under clause (f) of section 2 of the University Grants`
  line `Commission Act, 1956 (3 of 1956) and includes an institution declared to be a deemed University`
  line `under section 3 of that Act;`
  line
  line `(y) “Vice-Chairperson” means the Vice-Chairperson of the Commission appointed under clause (b)`
  line `of sub-section (3) of section 3.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (54440)
  sectionNo (3)
  orderNo 3
  title `Constitution and composition of Commission.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54440&sectionno=3&orderno=3&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_3_content:
  string
  line `3. Constitution and composition of Commission.--- (1) With effect from such date as the Central`
  line `Government may, by notification, appoint in this behalf, there shall be constituted a Commission to be`
  line `called the National Commission for Allied and Healthcare Profession for exercising such powers and`
  line `discharging such duties as may be laid down under this Act.`
  line
  line `(2) The Commission shall be a body corporate by the name aforesaid, having perpetual succession and`
  line `a common seal, with power to acquire, hold and dispose of property, both movable and immovable, and to`
  line `contract and shall by the same name sue or be sued.`
  line
  line `(3) The Commission shall consist of the following, namely:---`
  line
  line `(a) a person having an outstanding ability, proven administrative capacity and integrity and`
  line `possessing a postgraduate degree in any profession of recognised category of allied and healthcare`
  line `sciences from any University with experience of not less than twenty-five years in the field of allied`
  line `and healthcare sciences, out of which at least ten years shall be as a leader in the area of allied and`
  line `healthcare professions to be appointed by the Central Government--Chairperson;`
  line
  line `(b) a person having an outstanding ability, proven administrative capacity and integrity, possessing`
  line `a postgraduate degree in any profession of recognised category of allied and healthcare sciences from`
  line `any University with experience of not less than twenty years in the field of allied and healthcare`
  line `sciences, out of which at least ten years shall be as a leader in the area of allied and healthcare`
  line professions---Vice-Chairperson;
  line
  line `(c) the following persons shall be the ex officio Members of the Commission, namely:---`
  line
  line `(i) Joint Secretary to the Government of India in the Department of Legal Affairs, Ministry of`
  line `Law and Justice--ex officio Member;`
  line
  line `(ii) Joint Secretary to the Government of India in the Department of Health and Family Welfare,`
  line `Ministry of Health and Family Welfare--ex officio Member;`
  line
  line `(iii) Joint Secretary to the Government of India in the Department of Higher Education--ex`
  line `officio Member;`
  line
  line `(iv) Joint Secretary to the Government of India in the Department of Empowerment of Persons`
  line `with Disabilities, Ministry of Social Justice and Empowerment--ex officio Member;`
  line
  line `(v) Joint Secretary to the Government of India in the Ministry of Skill Development and`
  line `Entrepreneurship--ex officio Member;`
  line
  line `(vi) one person representing the Directorate General of Health Services not below the rank of`
  line `Deputy Director General--ex officio Member;`
  line
  line `(vii) one person representing the Indian Council of Medical Research not below the rank of`
  line `Deputy Director General--ex officio Member;`
  line
  line `(viii) one person representing out of the following, on biennial rotation basis, not below the`
  line `rank of Deputy Secretary to the Government of India--ex officio Member---`
  line
  line `(a) Atomic Energy Regulatory Board;`
  line
  line `(b) National Medical Commission; and`
  line
  line `(c) Rehabilitation Council of India;`
  line
  line `(ix) three persons not below the rank of Deputy Director or Medical Superintendent`
  line `representing the following, on biennial rotation basis, to be nominated by the Central Government-`
  line `-ex officio Members,---`
  line
  line `(a) All India Institute of Medical Sciences, New Delhi;`
  line
  line `(b) All India Institute of Physical Medicine and Rehabilitation, Mumbai;`
  line
  line `(c) Jawaharlal Institute of Postgraduate Medical Education and Research, Puducherry;`
  line
  line `(d) North Eastern Indira Gandhi Regional Institute of Health and Medical Sciences,`
  line Shillong;
  line
  line `(e) Pt. Deendayal Upadhyaya National Institute for Persons with Physical Disabilities,`
  line Delhi;
  line
  line `(f) National Institute of Mental Health and Neuro-Sciences, Bengaluru;`
  line
  line `(g) National Institute of Nutrition, Hyderabad;`
  line
  line `(h) National Institute of Rehabilitation Training and Research, Cuttack;`
  line
  line `(i) National Institute of Orthopedically Handicapped, Kolkata;`
  line
  line `(j) All India Institute of Speech and Hearing, Mysore, Karnataka;`
  line
  line `(k) Sree Chitra Tirunal Institute for Medical Sciences and Technology,`
  line `Thiruvananthapuram, Kerala; and`
  line
  line `(l) Tata Memorial Hospital, Mumbai;`
  line
  line `(d) the following persons shall be the Part-time Members of the Commission, namely:--`
  line
  line `(i) two persons from each of the six zones representing the State Councils on biennial`
  line `rotation in the alphabetical order as per the zonal distribution having such qualifications`
  line `and experience as may be prescribed by the Central Government to be nominated by the`
  line `concerned State Government;`
  line
  line `(ii) The President of the Professional Council and one person representing each of the`
  line `Professional Councils to be selected in such a manner as may be prescribed by the Central`
  line `Government on biennial rotation of professions by a committee comprising of Chairperson,`
  line `Vice-Chairperson and the ex officio Member under sub-clause (ii) of clause (c); and`
  line
  line `(iii) two persons, representing charitable institutions engaged in education or services`
  line `in connection with any recognised category, having such qualifications and experience as`
  line `may be prescribed by the Central Government, to be nominated by the Central`
  line Government.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (54441)
  sectionNo (4)
  orderNo 4
  title `Term of office and conditions of service of Members.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54441&sectionno=4&orderno=4&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_4_content:
  string
  line `4.Term of office and conditions of service of Members.—(1) The Chairperson, Vice-Chairperson of`
  line `the Commission and the Part-time Member nominated under sub-clauses (i), (ii) and (iii) of clause (d) of`
  line `sub-section (3) of section 3 shall hold office for a term not exceeding two years from the date on which`
  line `they enter upon their office and shall be eligible for re-nomination for a maximum period of two terms.`
  line
  line `(2) The salaries and allowances payable to, and other conditions of service of, the Chairperson and`
  line `Vice-Chairperson of the Commission shall be such as may be prescribed by the Central Government.`
  line
  line `(3) The Part-time Member nominated under sub-clauses (i), (ii) and (iii) of clause (d) of sub-section (3)`
  line `of section 3 shall receive such travelling and other allowances as may be prescribed by the Central`
  line Government.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (54442)
  sectionNo (5)
  orderNo 5
  title `Resignation and removal of Members.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54442&sectionno=5&orderno=5&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_5_content:
  string
  line `5. Resignation and removal of Members.—(1) Notwithstanding anything contained in sub-section`
  line `(1) of section 4, the Chairperson, Vice-Chairperson of the Commission and the Part-time Member`
  line `nominated under sub-clauses (i), (ii) and (iii) of clause (d) of sub-section (3) of section 3 may-`
  line
  line `(i) relinquish his office by giving in writing to the Central Government notice of not less than three`
  line `months; or`
  line
  line `(ii) be removed from his office if he—`
  line
  line `(a) has been adjudged insolvent; or`
  line
  line `(b) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as a member; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions`
  line `as a Part-time Member; or`
  line
  line `(e) has so abused his position as to render his continuance in office prejudicial to the public`
  line interest.
  line
  line `(2) No Part-time Member shall be removed from his office under clause (d) or clause (e) of sub-section`
  line `(1) unless he has been given a reasonable opportunity of being heard in the matter.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (54443)
  sectionNo (6)
  orderNo 6
  title `Cessation of membership and filling up of casual vacancy of Member.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54443&sectionno=6&orderno=6&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_6_content:
  string
  line `6. Cessation of membership and filling up of casual vacancy of Member.(1) The ex officio`
  line `Member under clauses (i) to (ix) of sub-section (3) of section 3, shall cease to be a Member of the`
  line `Commission on his cessation to the service by virtue of which he was appointed as a Member of the`
  line Commission.
  line
  line `(2) A Member nominated under sub-clause (i) of clause (d) of sub-section (3) of section 3, shall cease`
  line `to be Member of the Commission on removal of his name from the register of the State Council.`
  line
  line `(3) The Chairperson, Vice-Chairperson or any other Member appointed under any casual vacancy in`
  line `the Commission under sub-section (3) of section 3 shall hold office only for the remainder of the term of`
  line `the Member in whose place he has been appointed.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (54444)
  sectionNo (7)
  orderNo 7
  title `Meetings of Commission.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54444&sectionno=7&orderno=7&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_7_content:
  string
  line `7. Meetings of Commission.--(1) The Commission shall meet at least once in every quarter at such`
  line `time and place as may be decided by the Chairperson, and shall observe such rules of procedure in regard`
  line `to the transaction of business at its meetings in the manner as may be prescribed by the Central Government.`
  line
  line `(2) The Chairperson shall preside over the meeting of the Commission and if, for any reason, he is`
  line `unable to attend the meeting of the Commission, the Vice-Chairperson shall preside over the meeting.`
  line
  line `(3) One-half of the total number of Members of the Commission including the Chairperson or Vice Chairperson shall constitute the quorum and all decisions of the Commission shall be taken by a majority`
  line `of the Members, present and voting; and in the event of equality of votes, the Chairperson or in his absence,`
  line `the Vice-Chairperson shall have a second or casting vote.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (54445)
  sectionNo (8)
  orderNo 8
  title `Vacancies, etc., not to invalidate proceedings of Commission.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54445&sectionno=8&orderno=8&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_8_content:
  string
  line `8. Vacancies, etc., not to invalidate proceedings of Commission.—No act or proceeding of the`
  line `Commission shall be invalidated merely by reason of—`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Commission; or`
  line
  line `(b) any defect in the appointment of a person acting as a Member of the Commission; or`
  line
  line `(c) any irregularity in the procedure of the Commission not affecting the merits of the case.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (54446)
  sectionNo (9)
  orderNo 9
  title `Officers and other employees of Commission.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54446&sectionno=9&orderno=9&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_9_content:
  string
  line `9. Officers and other employees of Commission.--(1) Subject to such rules made by the Central`
  line `Government in this behalf, the Central Government shall provide a Secretariat to the Commission which`
  line `shall consist of a Secretary and other officers as it may think necessary for the efficient performance of its`
  line `functions under this Act.`
  line
  line `(2) The salaries and allowances payable to, and other conditions of service of, the Secretary and other`
  line `officers of the Commission shall be such as may be prescribed by the Central Government.`
  line
  line `(3) The Secretariat of the Commission shall also provide Secretarial assistance to the Professional`
  line `Council and the Advisory Council.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (54447)
  sectionNo (10)
  orderNo 10
  title `Professional Councils.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54447&sectionno=10&orderno=10&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_10_content:
  string
  line `10. Professional Councils.--- (1) The Commission shall, by notification, constitute Professional`
  line `Council for every recognised category and shall consist of a president and members, not less than four and`
  line `not exceeding twenty-four, representing each profession in the recognised category having such`
  line `qualifications and experiences as may be prescribed by the Central Government:`
  line
  line `Provided that where there is more than one profession represented in a Professional Council, the`
  line `president shall rotate biennially amongst the professions in the recognised category.`
  line
  line `(2) Where there is no person from a particular recognised profession represented in the Commission, if`
  line `the Commission is of opinion that the decision taken by it affects that profession, it may, before taking any`
  line `decision, give an opportunity of being heard to that profession through the related Professional Council.`
  line
  line `(3) The president and the member of the Professional Council shall be a registered professional of the`
  line `respective category.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (54448)
  sectionNo (11)
  orderNo 11
  title `Functions of Commission.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54448&sectionno=11&orderno=11&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_11_content:
  string
  line `11. Functions of Commission.—(1) It shall be the duty of the Commission to take all such steps as it`
  line `may think fit for ensuring coordinated and integrated development of education and maintenance of the`
  line `standards of delivery of services under this Act and for the purposes of performing its functions, the`
  line `Commission may—`
  line
  line `(a) frame policies and standards for the governance of allied and healthcare related education and`
  line `professional services;`
  line
  line `(b) regulate the professional conduct, code of ethics and etiquette to be observed by the allied and`
  line `healthcare professionals by or under this Act;`
  line
  line `(c) create and maintain an up-to-date online and live Central Register with details of academic`
  line `qualifications institutions, training, skill and competencies of allied and healthcare professionals related`
  line `to their profession as specified in the Schedule;`
  line
  line `(d) provide scope of practice of each profession keeping in view, inter alia, need for task shifting;`
  line
  line `(e) provide basic standards of education, courses, curricula, physical and instructional facilities,`
  line `staff pattern, staff qualifications, quality instructions, assessment, examination, training, research,`
  line `continuing professional education, maximum tuition fee payable in respect of various categories,`
  line `proportionate distribution of seats and promote innovations in categories in the manner as may be`
  line `specified by regulations;`
  line
  line `(f) provide the allied and healthcare qualifications to be obtained by allied and healthcare`
  line `professionals, including the name of the course, entry criteria, duration and such other particulars as`
  line `may be specified by regulations;`
  line
  line `(g) provide for uniform entry examination with common counselling for admission into the allied`
  line `and healthcare institutions at the diploma, undergraduate, postgraduate and doctoral level in the manner`
  line `as may be specified by regulations;`
  line
  line `(h) provide for exit or licensing examinations for allied and healthcare professionals for`
  line `professional practice or entrance into postgraduate or doctoral level and National Teachers Eligibility`
  line `Test for academicians in the manner as may be specified by regulations;`
  line
  line `(i) provide strategic framework for rational deployment of skilled manpower, performance`
  line `management systems, task shifting and associated career development pathways for allied and`
  line `healthcare professionals;`
  line
  line `(j) provide minimum standards framework for machineries, materials and services;`
  line
  line `(k) take such measures, as may be necessary, to ensure compliance of the guidelines for their`
  line `effective functioning by the State Councils under this Act in the manner as may be specified by`
  line regulations;
  line
  line `(l) constitute committees or engage independent experts for technical advice related to any of the`
  line `professions as listed in the Schedule for the efficient discharge of the functions of the Commission;`
  line
  line `(m) hold an Annual Meeting of the Commission with the National Medical Commission constituted`
  line `under section 3 of the National Medical Commission Act, 2019 (30 of 2019) and the Central Council`
  line `constituted under section 3 of the Homoeopathy Central Council Act, 1973 (59 of 1973);`
  line
  line `(n) perform such other functions as may be entrusted to it by the Central Government or as may be`
  line `necessary to carry out the provisions of this Act.`
  line
  line `(2) The Commission may delegate such of its functions to the Professional Council as it think necessary.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (54449)
  sectionNo (12)
  orderNo 12
  title `National Allied and Healthcare Advisory Council.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54449&sectionno=12&orderno=12&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_12_content:
  string
  line `12. National Allied and Healthcare Advisory Council.—(1) The Central Government shall constitute`
  line `an Advisory Council to be known as National Allied and Healthcare Advisory Council to advise the`
  line `Commission on the issues relating to allied and healthcare professionals.`
  line
  line `(2) The Advisory Council shall consist of the following persons, namely:—`
  line
  line `(i) Chairperson of the Commission--Chairperson;`
  line
  line `(ii) all Members of the Commission-- ex officio member;`
  line
  line `(iii) Principal Secretary dealing with medical education or his nominee from each State--member;`
  line
  line `(iv) Chairperson of the State Council--member; and`
  line
  line `(v) Principal Secretary dealing with medical education or his nominee representing each Union`
  line territory--member.
  line
  line `(3) The Advisory Council shall meet once in a year at Delhi as may be decided by the Chairperson of`
  line `the Advisory Council.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (54450)
  sectionNo (13)
  orderNo 13
  title `Central Allied and Healthcare Professionals' Register.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54450&sectionno=13&orderno=13&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_13_content:
  string
  line `13. Central Allied and Healthcare Professionals' Register.—(1) The Commission shall maintain`
  line `online and live Register of persons in separate parts in each of the recognised categories to be known as the`
  line `Central Allied and Healthcare Professionals' Register which shall contain information including the name`
  line `of persons and qualifications relating to any of their respective recognised categories in the manner as may`
  line `be specified by regulations.`
  line
  line `(2) For the purposes of sub-section (1), the Commission may adopt standardised format for populating`
  line `and maintaining the Central Register in the manner as may be specified by regulations.`
  line
  line `(3) The Central Register shall be deemed to be a public document within the meaning of the Indian`
  line `Evidence Act, 1872 (1 of 1872) and may be proved by a certified copy provided by the Commission.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (54451)
  sectionNo (14)
  orderNo 14
  title `Privileges for enrolment on Central Register.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54451&sectionno=14&orderno=14&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_14_content:
  string
  line `14. Privileges for enrolment on Central Register.—Subject to the conditions and restrictions laid`
  line `down in this Act regarding practice by person possessing certain recognised allied and healthcare`
  line `qualifications, every person whose name is for the time being borne on the Central Register shall be entitled`
  line `according to his qualifications to provide any service within the defined scope of practice as an allied and`
  line `healthcare professional under this Act and to receive in respect of such service, any expenses, charges or`
  line `any fees to which he may be entitled.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (54452)
  sectionNo (15)
  orderNo 15
  title `Rights of persons who are enrolled on Central Register.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54452&sectionno=15&orderno=15&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_15_content:
  string
  line `15. Rights of persons who are enrolled on Central Register.—No person, other than a registered`
  line `allied and healthcare professional, shall—`
  line
  line `(a) hold office as an allied and healthcare professional (by whatever name called) in Government`
  line `or in any institution maintained by a local or other authority;`
  line
  line `(b) provide service in any of the recognised categories in any State; and`
  line
  line `(c) be entitled to sign or authenticate any certificate required by any law for the time being in force`
  line `to be signed or authenticated by a duly qualified allied and healthcare professional.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (54453)
  sectionNo (16)
  orderNo 16
  title `Registration in Central Register.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54453&sectionno=16&orderno=16&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_16_content:
  string
  line `16. Registration in Central Register.--- The Commission may, on receipt of the report of registration`
  line `of a person in a State Register or on an application in such form and in such manner as may be prescribed`
  line `by the Central Government, enter his name in the Central Register.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (54454)
  sectionNo (17)
  orderNo 17
  title `Issue of certificate of registration.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54454&sectionno=17&orderno=17&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_17_content:
  string
  line `17. Issue of certificate of registration.--(1) Any person whose name has been entered in the Central`
  line `Register shall, on an application made by the person in this behalf in such form and in such manner and on`
  line `payment of such fees as may be prescribed by the Central Government, be entitled to get a certificate of`
  line registration.
  line
  line `(2) On receipt of an application under sub-section (1), the Commission shall grant to the applicant a`
  line `certificate of registration in such form as may be prescribed by the Central Government.`
  line
  line `(3) Where it is shown to the satisfaction of the Commission that a certificate of registration has been`
  line `lost or destroyed, the commission may, on payment of such fees, issue a duplicate certificate in such form`
  line `as may be prescribed by the Central Government.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (54455)
  sectionNo (18)
  orderNo 18
  title `Registration of additional qualifications.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54455&sectionno=18&orderno=18&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_18_content:
  string
  line `18. Registration of additional qualifications.—(1) If any person whose name is entered in the Central`
  line `Register obtains any other recognised qualification in addition to any allied and healthcare qualification, he`
  line `shall, on an application made in this behalf in such form and in such manner and on payment of such fees`
  line `as may be prescribed by the Central Government, be entitled to have an entry stating such degree or diploma`
  line `or such other qualifications made against his name in such register in addition to any entry previously made.`
  line
  line `(2) The entries in respect of any such person in a State Register shall be altered in accordance with the`
  line `alterations made in the Central Register.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (54456)
  sectionNo (19)
  orderNo 19
  title `Removal of name from Central Register.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54456&sectionno=19&orderno=19&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_19_content:
  string
  line `19. Removal of name from Central Register. ---If the name of any person enrolled on a State Register`
  line `is removed therefrom in pursuance of any power conferred under this Act, the Commission shall direct the`
  line `removal of the name of such person from the Central Register in such manner as may be specified by`
  line `regulations:`
  line
  line `Provided that on the removal of his name from the Central Register or State Register, as the case may`
  line `be, such certificate shall cease to be valid.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (54457)
  sectionNo (20)
  orderNo 20
  title `Interim Commission.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54457&sectionno=20&orderno=20&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_20_content:
  string
  line `20. Interim Commission.--- (1) The Central Government shall, as soon as may be but within sixty days`
  line `from the date on which this Act receives the assent of the President, constitute an Interim Commission, for`
  line `three years or until a regular Commission is constituted under section 3, whichever is earlier.`
  line
  line `(2) The Interim Commission constituted under sub-section (1) shall consist of the following, namely:--`
  line
  line `(a) Additional Secretary to the Government of India in the Ministry of Health and Family Welfare--Chairperson;`
  line
  line `(b) Joint Secretary to the Government of India in the Ministry of Health and Family Welfare--`
  line member;
  line
  line `(c) Joint Secretary to the Government of India in the Department of Legal Affairs, Ministry of Law`
  line `and Justice--member;`
  line
  line `(d) Joint Secretary to the Government of India in the Department of Higher Education--member;`
  line
  line `(e) Joint Secretary to the Government of India in the Ministry of Social Justice and Empowerment-`
  line -member;
  line
  line `(f) Joint Secretary to the Government of India in the Ministry of Skill Development and`
  line Entrepreneurship--member;
  line
  line `(g) One representative of the Directorate General of Health Services not below the rank of Deputy`
  line `Director General--member;`
  line
  line `(h) One representative of the National Medical Commission constituted under section 3 of the`
  line `National Medical Commission Act, 2019 (30 of 2019) not below the rank of Deputy Secretary to the`
  line `Government of India--member;`
  line
  line `(i) One representative of the Rehabilitation Council of India not below the rank of Deputy Secretary`
  line `to the Government of India--member;`
  line
  line `(j) One representative of the Atomic Energy Regulatory Board not below the rank of Deputy`
  line `Secretary to the Government of India--member;`
  line
  line `(k) two persons representing each of the recognised categories having such qualifications and`
  line `experiences as may be prescribed by the Central Government--member:`
  line
  line `Provided that the Interim Commission may engage experts from unrepresented professions`
  line `specified in the Schedule as necessary.`
  line
  line `(3) The Interim Commission shall discharge the functions assigned to the Commission under this Act`
  line `and shall follow its own procedures in discharging its duties.`
  line
  line `(4) The Central Government shall appoint a Secretary to the Interim Commission.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (54458)
  sectionNo (21)
  orderNo 21
  title `Search-cum-Selection Committee.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54458&sectionno=21&orderno=21&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_21_content:
  string
  line `21. Search-cum-Selection Committee.--- (1) The Central Government shall, on the recommendation`
  line `of a Search-cum-Selection Committee, appoint the Chairperson, Vice-Chairperson and the Secretary of the`
  line Commission.
  line
  line `(2) The Search-cum-Selection Committee shall consist of the following persons, namely:---`
  line
  line `(a) the Secretary, Ministry of Health and Family Welfare--Chairperson;`
  line
  line `(b) the Secretary or his nominee, not below the rank of Additional Secretary of Department of`
  line `Higher Education, Ministry of Education--member;`
  line
  line `(c) four experts, possessing outstanding qualifications and experience of not less than twenty-five`
  line `years in the field of allied and healthcare education, public health education and health research to be`
  line `nominated by the Central Government--members;`
  line
  line `(d) one person, possessing outstanding qualifications and experience of not less than twenty-five`
  line `years in the field of management or law or economics or science and technology to be nominated by`
  line `the Central Government--member; and`
  line
  line `(e) Additional Secretary to the Government of India in the Ministry of Health and Family Welfare`
  line Convener--member.
  line
  line `(3) The Central Government shall, within a period of three months from the date of occurrence of any`
  line `vacancy, including by reason of death, resignation or removal of the Chairperson or Vice-Chairperson or`
  line `Secretary of the Commission or within three months before the end of tenure of the Chairperson or ViceChairperson or Secretary of the Commission, make a reference to the Search-cum-Selection Committee for`
  line `selection of Chairperson, Vice-Chairperson or Secretary.`
  line
  line `(4) The Search-cum-Selection Committee shall recommend a panel of at least three names for each`
  line vacancy.
  line
  line `(5) The Search-cum-Selection Committee shall, before recommending any person for appointment of`
  line `the Chairperson or Vice-Chairperson or Secretary, satisfy itself that such person does not have any financial`
  line `or other interest which is likely to affect prejudicially his functions as such Chairperson, Vice-Chairperson`
  line `or Secretary.`
  line
  line `(6) No appointment of the Chairperson or Vice-Chairperson or Secretary of the Commission shall be`
  line `invalid merely by reason of any vacancy or absence of a member in the Search-cum-Selection Committee.`
  line
  line `(7) Subject to the provisions of sub-sections (3) to (6), the Search-cum-Selection Committee may`
  line `regulate its own procedure.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (54459)
  sectionNo (22)
  orderNo 22
  title `Constitution and composition of State Council.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54459&sectionno=22&orderno=22&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_22_content:
  string
  line `22. Constitution and composition of State Council.—(1) Every State Government shall, by`
  line `notification, within six months from the date of commencement of this Act, constitute a State Council to`
  line `be called the State Allied and Healthcare Council for exercising such powers and discharging such duties`
  line `as may be laid down under this Act.`
  line
  line `(2) The State Council shall be a body corporate by the name aforesaid, having perpetual succession and`
  line `a common seal, with power to acquire, hold and dispose of property, both movable and immovable, and to`
  line `contract and shall by the same name sue or be sued.`
  line
  line `(3) The State Council shall consist of the following, namely:—`
  line
  line `(a) a person of outstanding ability, proven administrative capacity and integrity, possessing a`
  line `postgraduate degree in any profession of recognised category of allied and healthcare sciences from`
  line `any University and having experience of not less than twenty-five years in the field of allied and`
  line `healthcare sciences, out of which at least ten years shall be as a leader in the area of allied and healthcare`
  line `professions to be nominated by the State Government--Chairperson;`
  line
  line `(b) one Director or Additional Director or Joint Director representing medical or health sciences in`
  line `the State Government--ex officio Member;`
  line
  line `(c) two persons not below the rank of Dean or Head of the Department from any medical colleges`
  line `of the State Government--ex officio Members;`
  line
  line `(d) president of the Autonomous Boards constituted by the State Council under sub-section (1) of`
  line `section 29--ex officio Member;`
  line
  line `(e) two persons representing each of the recognised categories specified in the Schedule to be`
  line `nominated by the State Government having such qualifications and experience as may be prescribed`
  line `by the State Government--Members; and`
  line
  line `(f) two persons, representing charitable institutions engaged in education or services in connection`
  line `with any recognised category, to be nominated by the State Government having such qualifications and`
  line `experience as may be prescribed by the State Government--Members.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (54460)
  sectionNo (23)
  orderNo 23
  title `Terms and conditions of service of Member.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54460&sectionno=23&orderno=23&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_23_content:
  string
  line `23. Terms and conditions of service of Member.—(1) The Chairperson of the State Council and`
  line `Member nominated under clauses (e) and (f) of sub-section (3) of section 22 shall hold office for a term not`
  line `exceeding two years from the date on which they enter upon their office and shall be eligible for renomination for a maximum period of two terms.`
  line
  line `(2) The Members nominated to the State Council under clauses (e) and (f) of sub-section (3) of section`
  line `22 shall receive such travelling and other allowances as may be prescribed by the State Government.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (54461)
  sectionNo (24)
  orderNo 24
  title `Resignation and removal of Member.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54461&sectionno=24&orderno=24&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_24_content:
  string
  line `24. Resignation and removal of Member.--(1) Notwithstanding anything contained in sub-section`
  line `(1) of section 23, the Chairperson of the State Council and Member nominated under clauses (e) and (f) of`
  line `sub-section (3) of section 22 may--`
  line
  line `(i) relinquish his office by giving in writing to the State Government notice of not less than three`
  line `months; or`
  line
  line `(ii) be removed from his office if he--`
  line
  line `(a) has been adjudged insolvent; or`
  line
  line `(b) has been convicted of an offence which, in the opinion of the State Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as a Member; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions`
  line `as a Member; or`
  line
  line `(e) has so abused his position as to render his continuance in office prejudicial to the public`
  line interest.
  line
  line `(2) No such Member shall be removed from his office under clause (d) or clause (e) of sub-section (1)`
  line `unless he has been given a reasonable opportunity of being heard in the matter.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (54462)
  sectionNo (25)
  orderNo 25
  title `Cessation of membership and filling up of casual vacancy of Member.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54462&sectionno=25&orderno=25&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_25_content:
  string
  line `25. Cessation of membership and filling up of casual vacancy of Member.—(1) A Member under`
  line `clause (b) or clause (c) of sub-section (3) of section 22, shall cease to be a Member of the State Council on`
  line `his cessation to the service by virtue of which he was appointed as a Member of the State Council.`
  line
  line `(2) The Chairperson or any other Member appointed under any casual vacancy in the State Council`
  line `under sub-section (3) of section 22, shall hold office only for the remainder of the term of the member in`
  line `whose place he has been appointed.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (54463)
  sectionNo (26)
  orderNo 26
  title `Meetings of State Council.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54463&sectionno=26&orderno=26&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_26_content:
  string
  line `26. Meetings of State Council.—(1) The State Council shall meet at such times and places, and shall`
  line `observe such rules of procedure in regard to the transaction of business at its meetings (including quorum`
  line `of such meetings) in the manner as may be prescribed by the State Government.`
  line
  line `(2) The Chairperson of the State Council, if for any reason, he is unable to attend a meeting of the State`
  line `Council, any other member chosen by the members present from amongst themselves at the meeting shall`
  line `preside over the meeting.`
  line
  line `(3) All questions which come up before any meeting of the State Council shall be decided by a majority`
  line `of the members present and voting, and in the event of an equality of votes, the Chairperson of the State`
  line `Council or in his absence, the member of the State Council presiding, shall have a second or casting vote.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (54464)
  sectionNo (27)
  orderNo 27
  title `Vacancies, etc., not to invalidate proceedings of State Council.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54464&sectionno=27&orderno=27&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_27_content:
  string
  line `27. Vacancies, etc., not to invalidate proceedings of State Council.—No act or proceeding of the`
  line `State Council shall be invalidated merely by reason of—`
  line
  line `(a) any vacancy in, or any defect in the constitution of the State Council; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the State Council; or`
  line
  line `(c) any irregularity in the procedure of the State Council not affecting the merits of the case.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (54465)
  sectionNo (28)
  orderNo 28
  title `Officers and other employees of State Council.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54465&sectionno=28&orderno=28&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_28_content:
  string
  line `28. Officers and other employees of State Council.—(1) Subject to such rules as may be made by`
  line `the State Government in this behalf, the State Council may appoint a Secretary and such other employees`
  line `as it may think necessary for the efficient performance of its functions under this Act.`
  line
  line `(2) The salaries and allowances payable to, and other conditions of service of, the Secretary, other`
  line `officers and employees of the State Council appointed under sub-section (1) shall be such as may be`
  line `prescribed by the State Government.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (54466)
  sectionNo (29)
  orderNo 29
  title `Constitution and functions of Autonomous Boards.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54466&sectionno=29&orderno=29&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_29_content:
  string
  line `29. Constitution and functions of Autonomous Boards.—(1) The State Council shall, by`
  line `notification, constitute the following Autonomous Boards for regulating the allied and healthcare`
  line `professionals, namely,--`
  line
  line `(a) Under-graduate Allied and Healthcare Education Board,`
  line
  line `(b) Post-graduate Allied and Healthcare Education Board,`
  line
  line `(c) Allied and Healthcare Professions Assessment and Rating Board, and`
  line
  line `(d) Allied and Healthcare Professions Ethics and Registration Board.`
  line
  line `(2) The Autonomous Boards constituted under sub-section (1) shall consist of a president and such`
  line `number of members from each recognised category as may be specified by the regulations and shall be`
  line `appointed by the State Government.`
  line
  line `(3) The Under-graduate Allied and Healthcare Education Board and Post-graduate Allied and`
  line `Healthcare Education Board shall determine standards of allied and healthcare education at the graduate,`
  line `postgraduate level and super-speciality level, develop competency based on dynamic curriculum content,`
  line `reviewing institutional standards against norms, faculty development, approval of courses of recognised`
  line `qualification and other functions as entrusted by the State Council for Under Graduate Education and Post`
  line `Graduate Education.`
  line
  line `(4) The Allied and Healthcare Profession Assessment and Rating Board shall determine the procedure`
  line `for the assessment and rating of allied and healthcare institutions by providing for inspection of institutions,`
  line `grant permission for establishment of new allied and healthcare institutions and seat capacity, empanelling`
  line `assessors, imposing warnings or fines, recommend for withdrawal of recognition of institutions and any`
  line `other function as entrusted by the State Council to ensure maintenance of minimum essential standards.`
  line
  line `(5) The Allied and Healthcare Profession Ethics and Registration Board shall maintain online and live`
  line `State Registers of all licensed allied and healthcare practitioners in the State, regulate the professional`
  line `conduct and promotion of ethics and undertake any other function as entrusted by the State Council.`
  line
  line `(6) The Under-graduate Allied and Healthcare education or Post-graduate Allied and Healthcare`
  line `education or Allied and Healthcare Professions Assessment and Rating or Allied and Healthcare`
  line `Professions Ethics and Registration shall perform such other functions as may be specified by regulations.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (54467)
  sectionNo (30)
  orderNo 30
  title `Functions of State Council.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54467&sectionno=30&orderno=30&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_30_content:
  string
  line `30. Functions of State Council.--- It shall be the duty of the State Council to take all such steps as it`
  line `may think fit for ensuring the co-ordinated and integrated development of education and maintenance of`
  line `the standards of delivery of services under this Act and, for the purposes of performing its functions, the`
  line `State Council shall---`
  line
  line `(a) enter the name of the recognised categories, enforce the professional conduct, code of ethics`
  line `and etiquette to be observed by the allied and healthcare professionals in the State and take disciplinary`
  line `action, including the removal of a professionals' name from the State Register;`
  line
  line `(b) ensure minimum standards of education, courses, curricula, physical and instructional facilities,`
  line `staff pattern, staff qualifications, quality instructions, assessment, examination, training, research,`
  line `continuing professional education;`
  line
  line `(c) ensure uniform entry examination with common counselling for admission into the allied and`
  line `healthcare institutions at the diploma, undergraduate, postgraduate and doctoral level under this Act;`
  line
  line `(d) ensure uniform exit or licensing examination for the allied and healthcare professionals under`
  line `this Act;`
  line
  line `(e) inspect allied and healthcare institutions and register allied and healthcare professionals in the`
  line State;
  line
  line `(f) ensure compliance of all the directives issued by the Commission;`
  line
  line `(g) provide minimum standards framework for machineries, materials and services;`
  line
  line `(h) approve or recognise courses and intake capacity for courses;`
  line
  line `(i) impose fine upon institutions in order to maintain standards; and`
  line
  line `(j) perform such other functions as may be entrusted to it by the State Government for`
  line `implementation of the provisions of this Act.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (54468)
  sectionNo (31)
  orderNo 31
  title `Constitution of Advisory Board.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54468&sectionno=31&orderno=31&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_31_content:
  string
  line `31. Constitution of Advisory Board.—The State Council may constitute as many professional`
  line `Advisory Boards as may be necessary to examine the issues relating to one or more recognised categories`
  line `and to recommend the State Council and also to undertake any other activity as may be authorised by the`
  line `State Council.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (54469)
  sectionNo (32)
  orderNo 32
  title `State Allied and Healthcare Professionals' Register.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54469&sectionno=32&orderno=32&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_32_content:
  string
  line `32. State Allied and Healthcare Professionals' Register.—(1) The State Council shall maintain`
  line `online and live State Register of persons in separate parts for each of the recognised categories to be known`
  line `as the State Allied and Healthcare Professionals' Register which shall contain information including the`
  line `name of person and qualifications relating to any of their respective recognised categories in such manner`
  line `as may be specified by regulations.`
  line
  line `(2) The State Register shall contain the details of academic qualification institutions, training, skill and`
  line `competencies of Allied and Healthcare Professionals related to their profession in the manner as may be`
  line `specified by regulations.`
  line
  line `(3) The State Register shall be deemed to be a public document within the meaning of the Indian`
  line `Evidence Act, 1872 (1 of 1872), and may be proved by a certified copy provided by the State Council.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (54470)
  sectionNo (33)
  orderNo 33
  title `Registration in State Register.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54470&sectionno=33&orderno=33&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_33_content:
  string
  line `33. Registration in State Register.—(1) A person shall be entitled, on an application and on payment`
  line `of such fees as may be prescribed by the State Government, to have his name entered in the State Register`
  line `if he resides in the State and holds a recognised allied and healthcare qualification.`
  line
  line `(2) Upon the application to the State Council, if the State Council is of the opinion that the applicant is`
  line `entitled to have his name entered on the State Register, the State Council shall enter thereon the name of`
  line `the applicant.`
  line
  line `(3) Upon entry of a name in the State Register under this section, the Secretary of the State Council`
  line `shall issue to the applicant a certificate of registration in such form as may be prescribed by the State`
  line Government.
  line
  line `(4) The certificate of registration of Allied and Healthcare Profession shall be valid for a period of five`
  line `years, and renewal of such registration shall be in such form and in such manner as specified by regulations`
  line `for the respective profession.`
  line
  line `(5) Any person whose application for registration is rejected by the State Council may, within one`
  line `month from the date of such rejection, appeal to the Commission.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (54471)
  sectionNo (34)
  orderNo 34
  title `Issue of duplicate certificates.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54471&sectionno=34&orderno=34&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_34_content:
  string
  line `34. Issue of duplicate certificates.—Where it is shown to the satisfaction of the Secretary of the State`
  line `Council that a certificate of registration or a certificate of renewal has been lost or destroyed, the State`
  line `Council may, on payment of such fee, issue a duplicate certificate in such form as may be prescribed by the`
  line `State Government.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (54472)
  sectionNo (35)
  orderNo 35
  title `Renewal of name of Allied and Healthcare professionals in the State Register.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54472&sectionno=35&orderno=35&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_35_content:
  string
  line `35. Renewal of name of Allied and Healthcare professionals in the State Register.(1) There shall`
  line `be paid in every five years to the State Council, such fee in such manner as may be prescribed by the State`
  line `Government for renewal of name of allied and healthcare professionals in the State Register.`
  line
  line `(2) Where the fee under sub-section (1) is not paid within the specified period, the Secretary of the State`
  line `Council shall remove the name of the defaulter from the State Register:`
  line
  line `Provided that a name so removed may be restored to the said register on payment of such fee as may`
  line `be prescribed by the State Government.`
  line
  line `(3) On payment of the fee under sub-section (1), the Secretary of the State Council shall issue a`
  line `certificate of renewal and such certificate shall be proof of renewal of registration.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (54473)
  sectionNo (36)
  orderNo 36
  title `Removal of name of a person from State Register.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54473&sectionno=36&orderno=36&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_36_content:
  string
  line `36. Removal of name of a person from State Register.—(1) The State Council may, by order, after`
  line `giving that person a reasonable opportunity of being heard and after such further inquiry, if any, as it may`
  line `think fit—`
  line
  line `(a) that his name has been entered in the State Register by error or on account of mis-representation`
  line `or suppression of a material fact; or`
  line
  line `(b) that he has been convicted of an offence involving moral turpitude and punishable with`
  line `imprisonment or has been guilty of any infamous conduct in any professional respect or has violated`
  line `the standards of professional conduct and etiquette or the code of ethics which in the opinion of the`
  line `State Council renders him unfit to be kept in the said register, remove the name of the person from the`
  line `State Register.`
  line
  line `(2) Any person whose name has been removed from the State Register under sub-section (1) shall be`
  line `ineligible for registration under this Act, either permanently or for such period as may be specified by`
  line regulations.
  line
  line `(3) An order under sub-section (1) shall not take effect until the expiry of three months from the date`
  line `thereof or until an appeal, if any, on such order is finally disposed of, whichever date is later.`
  line
  line `(4) A person aggrieved by an order under sub-section (1) may, within thirty days from the`
  line `communication of such order, prefer an appeal to the Commission and, after giving an opportunity of being`
  line `heard, the Commission shall, within a period of ninety days from the date of filing of such appeal, pass`
  line `such order as it thinks fit.`
  line
  line `(5) A person whose name has been removed from the State Register under this section or under subsection (2) of section 35 shall forthwith surrender his certificate of registration or certificate of renewal, if`
  line `any, to the State Council and the name so removed shall be published on the website of the State Council,`
  line `and in one daily local newspaper in vernacular language.`
  line
  line `(6) A person whose name has been removed from the State Register under this section shall not be`
  line `entitled to have his name registered in the State Register or in any other State Register except with the`
  line `approval of the State Council from whose register his name has been removed.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (54474)
  sectionNo (37)
  orderNo 37
  title `Restoration of name of a person in the State Register.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54474&sectionno=37&orderno=37&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_37_content:
  string
  line `37. Restoration of name of a person in the State Register.—The State Council may, at any time for`
  line `reasons appearing to it as sufficient and upon payment of such fee as may be prescribed by the State`
  line `Government, order that the name of a person removed from a State Register shall be restored and the name`
  line `shall be uploaded on the website of the State Council, and in one daily local newspaper in vernacular`
  line language.
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (54475)
  sectionNo (38)
  orderNo 38
  title `Recognition of persons offering services prior to commencement of Act.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54475&sectionno=38&orderno=38&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_38_content:
  string
  line `38. Recognition of persons offering services prior to commencement of Act.—Every person who`
  line `offers his services in any of the recognised categories on or before the commencement of this Act shall be`
  line `allowed to be provisionally registered under the provisions of this Act within such period from such`
  line `commencement in such manner as may be specified by regulations.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (54476)
  sectionNo (39)
  orderNo 39
  title `Recognition of allied and healthcare institutions and reciprocity.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54476&sectionno=39&orderno=39&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_39_content:
  string
  line `39. Recognition of allied and healthcare institutions and reciprocity.(1) Subject to the provisions`
  line `of this Act, any corresponding qualification granted by the institutions outside India shall be the recognised`
  line `allied and healthcare qualifications as may be specified by regulations.`
  line
  line `(2) A citizen of India who holds the corresponding qualifications under sub-section (1) shall be entitled`
  line `for registration under this Act in such manner as may be specified by regulations.`
  line
  line `(3) The Central Government may, after consultation with the Commission, by notification, direct that`
  line `the corresponding qualifications under sub-section (1) in respect of which a scheme of reciprocity is not in`
  line `force shall be recognised for the purposes of this Act or shall be so only when granted after a specified date:`
  line
  line `Provided that the foreign nationals possessing such qualification—`
  line
  line `(a) shall be permitted only if such persons are enrolled as allied and healthcare professionals in`
  line `accordance with the law regulating the registration of allied and healthcare professionals for the time`
  line `being in force in that country; and`
  line
  line `(b) shall be limited to the period specified in this behalf by the Central Government by general or`
  line `special order.`
  line
  line `(4) In respect of any such qualifications the corresponding qualifications under sub-section (1), the`
  line `Central Government may, after consultation with the Commission, by notification, direct that it shall be`
  line `recognised allied and healthcare qualification only when granted before a specified date.`
  line
  line `(5) The Commission may enter into negotiations with an authority in any country outside India, which`
  line `by the law of such country is entrusted with the recognition of corresponding qualifications, for the setting`
  line `up of a scheme of reciprocity for the recognition of allied and healthcare qualification, and in pursuance of`
  line `any such scheme, the corresponding qualification which the Commission has decided to grant should be`
  line `recognised by notification by the Central Government.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (54477)
  sectionNo (40)
  orderNo 40
  title `Permission for establishment of new allied and healthcare institutions, new courses of study, etc.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54477&sectionno=40&orderno=40&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_40_content:
  string
  line `40. Permission for establishment of new allied and healthcare institutions, new courses of study,`
  line `etc.--- (1) Notwithstanding anything contained in this Act or any other law for the time being in force, on`
  line `and from the date of commencement of this Act,---`
  line
  line `(a) no person shall establish an allied and healthcare institution; or`
  line
  line `(b) no allied and healthcare institution shall---`
  line
  line `(i) open a new or higher course of study or training (including post-graduate course of study or`
  line `training) which would enable students of each course of study or training to qualify himself for the`
  line `award of any recognised allied and healthcare qualification; or`
  line
  line `(ii) increase its admission capacity in any course of study or training (including post-graduate`
  line `course of study or training); or`
  line
  line `(iii) admit a new batch of students in any unrecognised course of study or training (including`
  line `post-graduate course of study or training), except with the previous permission of the State Council`
  line `obtained in accordance with the provisions of this Act:`
  line
  line `Provided that the allied and healthcare qualification granted to a person in respect of a new or`
  line `higher course of study or new batch without previous permission of the State Council shall not be`
  line `a recognised allied and healthcare qualification for the purposes of this Act:`
  line
  line `Provided further that where there is no State Council constituted by a State Government, the`
  line `Commission shall give the previous permission for the purposes of this section.`
  line
  line `(2) (a) Every person or allied and healthcare institution shall, for the purpose of obtaining`
  line `permission under sub-section (1), submit to the State Council a scheme in accordance with the`
  line `provisions of clause (b).`
  line
  line `(b) The scheme referred to in clause (a) shall be in such form and contain such particulars`
  line `and be preferred in such manner and be accompanied with such fee as may be prescribed by`
  line `the Central Government.`
  line
  line `(3) On receipt of a scheme under sub-section (2), the State Council may obtain such other particulars`
  line `as may be considered necessary by it from the person or the allied and healthcare institution concerned, and`
  line `thereafter, it may, ---`
  line
  line `(a) if the scheme is defective and does not contain any necessary particulars, give a reasonable`
  line `opportunity to the person or allied and healthcare institution concerned for making a written`
  line `representation and it shall be open to such person or allied and healthcare institution to rectify the`
  line `defects, if any, specified by the State Council;`
  line
  line `(b) consider the scheme, having regard to the factors referred to in sub-section (5).`
  line
  line `(4) The State Council may, after considering the scheme and after obtaining, where necessary, such`
  line `other particulars under sub-section (2) as may be considered necessary by it from the person or allied and`
  line `healthcare institution concerned, and having regard to the factors referred to in sub-section (5), either`
  line `approve with such conditions, if any, as it may consider necessary or disapprove the scheme and any such`
  line `approval shall constitute as a permission under sub-section (1):`
  line
  line `Provided that no such scheme shall be disapproved by the State Council except after giving the person`
  line `or allied and healthcare institution concerned a reasonable opportunity of being heard:`
  line
  line `Provided further that nothing in this sub-section shall prevent any person or allied and healthcare`
  line `institution whose scheme has not been approved by the State Council to submit a fresh scheme and the`
  line `provisions of this section shall apply to such scheme, as if such scheme had been submitted for the first`
  line `time under sub-section (2).`
  line
  line `(5) The State Council shall, while passing an order under sub-section (4), have due regard to the`
  line `following factors, namely:---`
  line
  line `(a) whether the proposed allied and healthcare institution or the existing allied and healthcare`
  line `institution seeking to open a new or higher course of study or training, would be in a position to offer`
  line `the basic standards of education as specified by regulations;`
  line
  line `(b) whether the person seeking to establish an allied and healthcare institution or the existing allied`
  line `and healthcare institution seeking to open a new or higher course of study or training or to increase its`
  line `admission capacity has adequate financial resources;`
  line
  line `(c) whether necessary facilities in respect of staff, equipment, accommodation, training, hospital`
  line `and other facilities to ensure proper functioning of the allied and healthcare institution or conducting`
  line `the new course of study or training or accommodating the increased admission capacity have been`
  line `provided or would be provided as may be specified in the scheme;`
  line
  line `(d) whether adequate facilities, having regard to the number of students likely to attend such allied`
  line `and healthcare institution or course of study or training or as a result of the increased admission`
  line `capacity, have been provided or would be provided as may be specified in the scheme;`
  line
  line `(e) whether any arrangement has been made or programme drawn to impart proper training to`
  line `students likely to attend such allied and healthcare institution or the course of study or training by the`
  line `persons having the recognised allied and healthcare qualifications;`
  line
  line `(f) the requirement of manpower in the allied and healthcare institution; and`
  line
  line `(g) any other factors as may be specified by regulation.`
  line
  line `(6) Where the State Council passes an order under sub-section (4), a copy of the order shall be`
  line `communicated to the person or allied and healthcare institution as the case may be.`
  line
  line `Explanation.---For the purposes of this section,---`
  line
  line `(a) "person" includes any University, institution or a trust, but does not include the Central`
  line `Government or State Government;`
  line
  line `(b) "admission capacity", in relation to any course of study or training (including post-graduate`
  line `course of study or training) in an allied and healthcare institution, means the maximum number of`
  line `students as may be decided by the State Council from time to time for being admitted to such course`
  line `of study or training.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (54478)
  sectionNo (41)
  orderNo 41
  title `Power to require information from allied and healthcare institutions.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54478&sectionno=41&orderno=41&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_41_content:
  string
  line `41. Power to require information from allied and healthcare institutions.---(1) Any University or`
  line `college or institution imparting education in any recognised category shall furnish information to the State`
  line `Council regarding course of study, duration of course, scheme of assessment and examinations and other`
  line `eligibility conditions in order to obtain the requisite qualifications as an allied and healthcare institution`
  line `under this Act as the State Council may from time to time require.`
  line
  line `(2) Any University or college or institution imparting education in any recognised category as on the`
  line `date of commencement of this Act shall furnish to the State Council such information in such manner as`
  line `may be specified by regulations.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (54479)
  sectionNo (42)
  orderNo 42
  title `Recognition of allied and healthcare qualifications by State Council.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54479&sectionno=42&orderno=42&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_42_content:
  string
  line `42. Recognition of allied and healthcare qualifications by State Council.—(1) The State Council`
  line `shall cause to verify the standards of any allied and healthcare institution where education in the recognised`
  line `category is given, or to attend any examination held by any educational or research institution for the`
  line `purpose of recognition of allied and healthcare qualifications by that allied and healthcare institution in`
  line `such manner as may be specified by regulations.`
  line
  line `(2) The verification made under sub-section (1) shall not interfere with the conduct of any training or`
  line `examination, but shall be for the purpose of reporting to the State Council on the adequacy of the standards`
  line `of education including staff, equipment, accommodation, training and other facilities for giving education`
  line `in the recognised categories, as the case may be, or on the sufficiency of every examination which they`
  line attend.
  line
  line `(3) The State Council shall forward a copy of the report of verification of standards to the allied and`
  line `healthcare institution concerned and a copy with remarks of the institution hereon to the Commission.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (54480)
  sectionNo (43)
  orderNo 43
  title `Withdrawal of recognition.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54480&sectionno=43&orderno=43&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_43_content:
  string
  line `43. Withdrawal of recognition.—(1) On receipt of a report from the State Council, if the Commission`
  line `is of the opinion that—`
  line
  line `(a) the courses of study and examination to be undergone in, or the proficiency required from`
  line `candidates at any examination held by a University or any allied and healthcare institution do not`
  line `conform to the standards specified by the Commission for the respective courses, as the case may be;`
  line or
  line
  line `(b) the standards and norms for infrastructure, faculty and quality of education in allied and`
  line `healthcare institution as determined by the Commission for the respective courses, as the case may be,`
  line `are not adhered to by any University or allied and healthcare institution, and such University or allied`
  line `and healthcare institution has failed to take necessary corrective action to maintain specified minimum`
  line `standards, it may initiate action in accordance with the provisions of sub-section (2).`
  line
  line `(2) After considering such representations, and on such enquiry as it may deem fit, the Commission`
  line `may, within a period of ninety days from the date of receipt from the State Council under sub-section (1),`
  line `by order, withdraw the recognition granted to the allied and healthcare institution:`
  line
  line `Provided that before any order passed, the Commission shall afford, the allied and healthcare institution`
  line `and the State Government within whose jurisdiction the allied and healthcare institution is situated an`
  line `opportunity of being heard:`
  line
  line `Provided further that the Commission shall, before taking any action for withdrawal of recognition`
  line `granted to the allied and healthcare professionals qualification awarded by a University or allied and`
  line `healthcare institution, impose fine in consultation with the concerned State Council.`
  line
  line `(3) The Commission may, after making such further inquiry, if any, as it may think fit, by notification,`
  line `direct that,--`
  line
  line `(a) any allied and healthcare qualification shall be a recognised qualification under this Act only`
  line `when granted before a specified date; or`
  line
  line `(b) any allied and healthcare qualification if granted to students of a specified allied and healthcare`
  line `institution shall be the recognised qualification only when granted before a specified date; or`
  line
  line `(c) any qualification shall be the recognised qualification in relation to a specified allied and`
  line `healthcare institution only when granted after a specified date.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (54481)
  sectionNo (44)
  orderNo 44
  title `Failure to maintain minimum essential standards by allied and healthcare institutions.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54481&sectionno=44&orderno=44&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_44_content:
  string
  line `44. Failure to maintain minimum essential standards by allied and healthcare institutions.—The`
  line `State Council may take such measures, including issuing warning, imposing fine, reducing intake or`
  line `stoppage of admissions and recommending to the Commission for withdrawal of recognition, against an`
  line `allied and healthcare institution for failure to maintain the minimum essential standards specified by the`
  line `Commission under this Act.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (54482)
  sectionNo (45)
  orderNo 45
  title `Grants by Central Government.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54482&sectionno=45&orderno=45&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_45_content:
  string
  line `45. Grants by Central Government.—The Central Government may, after due appropriation made`
  line `by Parliament by law in this behalf, make to the Commission grants of such sums of money as the Central`
  line `Government may think fit for being utilised for the purposes of this Act.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (54483)
  sectionNo (46)
  orderNo 46
  title `National Allied and Healthcare Fund.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54483&sectionno=46&orderno=46&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_46_content:
  string
  line `46. National Allied and Healthcare Fund.--- (1) There shall be constituted a Fund to be called the`
  line `National Allied and Healthcare Fund and there shall be credited thereto---`
  line
  line `(a) all Government grants, fees received by the Commission;`
  line
  line `(b) all sums of money received by the Commission by way of grants, benefactions, bequests and`
  line `transfers; and`
  line
  line `(c) all sums of money received by the Commission in any other manner or from any other sources`
  line `as may be prescribed by the Central Government.`
  line
  line `(2) The fund referred to in sub-section (1) shall be applied for the expenses of the Commission incurred`
  line `in discharge of its functions and purposes of this Act in such manner as may be prescribed by the Central`
  line Government.
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (54484)
  sectionNo (47)
  orderNo 47
  title `Accounts and audit of Commission.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54484&sectionno=47&orderno=47&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_47_content:
  string
  line `47. Accounts and audit of Commission.(1) The Commission shall maintain appropriate accounts`
  line `and other relevant records and prepare an annual statement of accounts including the balance sheet in`
  line `accordance with such general directions as may be issued and in such form as may be specified by the`
  line `Central Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Commission shall be audited annually by the Comptroller and Auditor-General`
  line `of India or any person appointed by him in this behalf and any expenditure incurred by him or any person`
  line `so appointed in connection with such audit shall be payable by the Commission to the Comptroller and`
  line `Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection with`
  line `the audit of the accounts of the Commission shall have the same rights and privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of Government accounts, and, in particular, shall have the right to demand the production of books of`
  line `account, connected vouchers and other documents and papers and to inspect the office of the Commission.`
  line
  line `(4) The accounts of the Commission as certified by the Comptroller and Auditor-General of India or`
  line `any person appointed by him in this behalf, together with the audit report thereon, shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each House`
  line `of Parliament.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (54485)
  sectionNo (48)
  orderNo 48
  title `Annual report of Commission.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54485&sectionno=48&orderno=48&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_48_content:
  string
  line `48. Annual report of Commission.—The Commission shall prepare every year, in such form and`
  line `within such time as may be prescribed by the Central Government an annual report giving a true and full`
  line `account of its activities during the previous year and copies thereof shall be forwarded to the Central`
  line `Government and that Government shall cause the same to be laid before each House of Parliament.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (54486)
  sectionNo (49)
  orderNo 49
  title `Returns and information.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54486&sectionno=49&orderno=49&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_49_content:
  string
  line `49. Returns and information.—The Commission shall furnish to the Central Government such`
  line `reports, returns and other information as that Government may require from time to time.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (54487)
  sectionNo (50)
  orderNo 50
  title `Grants by State Government.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54487&sectionno=50&orderno=50&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_50_content:
  string
  line `50. Grants by State Government.—The State Government may, after due appropriation made by`
  line `State Legislature by law in this behalf, make to the State Council grants of such sums of money as the State`
  line `Government may think fit for being utilised for the purposes of this Act.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (54488)
  sectionNo (51)
  orderNo 51
  title `State Allied and Healthcare Council Fund.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54488&sectionno=51&orderno=51&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_51_content:
  string
  line `51. State Allied and Healthcare Council Fund.—(1) There shall be constituted a Fund to be called`
  line `the State Allied and Healthcare Council Fund and there shall be credited thereto—`
  line
  line `(a) all sums of money received from the State Government;`
  line
  line `(b) all sums of money received by the State Council by way of grants, fees, benefactions, bequests`
  line `and transfers; and`
  line
  line `(c) all sums of money received by the State Council in any other manner or from any other source`
  line `as may be decided by the State Government.`
  line
  line `(2) All receipts of the Commission and State Councils shall be routed through an online payment portal`
  line `of the Commission and one-fourth of all the receipts shall be transferred to the National Allied and`
  line `Healthcare Fund and three-fourth of all the receipts shall transfer to the relevant State Allied and Healthcare`
  line `Council Fund through that portal.`
  line
  line `(3) The fund referred to in sub-section (1) shall be applied for the expenses of the State Council incurred`
  line `in discharge of its functions for the purposes of this Act in the manner as may be prescribed by the State`
  line Government.
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (54489)
  sectionNo (52)
  orderNo 52
  title `Accounts and audit of State Council.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54489&sectionno=52&orderno=52&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_52_content:
  string
  line `52. Accounts and audit of State Council.—(1) The State Council shall maintain appropriate accounts`
  line `and other relevant records and prepare an annual statement of accounts including the balance sheet, in`
  line `accordance with such general directions as may be issued and in such form as may be specified by the State`
  line `Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the State Council shall be audited annually by the Comptroller and Auditor-General`
  line `of India or any person appointed by him in this behalf and any expenditure incurred by him or any person`
  line `so appointed in connection with such audit shall be payable by the State Council to the Comptroller and`
  line `Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection with`
  line `the audit of the accounts of the State Council shall have the same rights and privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of Government accounts, and, in particular, shall have the right to demand the production of books of`
  line `account, connected vouchers and other documents and papers and to inspect the office of the State Council.`
  line
  line `(4) The accounts of the State Council as certified by the Comptroller and Auditor-General of India or`
  line `any person appointed by him in this behalf, together with the audit report thereon, shall be forwarded`
  line `annually to the State Government and that Government shall cause the same to be laid before each House`
  line `of State Legislature where it consists of two Houses, or where such Legislature consists of one House,`
  line `before that House.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (54490)
  sectionNo (53)
  orderNo 53
  title `Annual report of State Council.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54490&sectionno=53&orderno=53&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_53_content:
  string
  line `53. Annual report of State Council.—The State Council shall prepare every year, in such form and`
  line `within such time as may be prescribed by the State Government an annual report giving a true and full`
  line `account of its activities during the previous year and copies thereof shall be forwarded to the State`
  line `Government and that Government shall cause the same to be laid before each House of the State Legislature,`
  line `where it consists of two Houses, or where such Legislature consists of one House, before that House.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (54491)
  sectionNo (54)
  orderNo 54
  title `Authentication of orders, etc.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54491&sectionno=54&orderno=54&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_54_content:
  string
  line `54. Authentication of orders, etc.—All orders and decisions of the Commission or the State Council,`
  line `as the case may be, and the instruments issued by it shall be authenticated by the Secretary or any other`
  line `officer authorised by the Chairperson in this behalf.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (54492)
  sectionNo (55)
  orderNo 55
  title `Practice by allied and healthcare professionals.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54492&sectionno=55&orderno=55&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_55_content:
  string
  line `55. Practice by allied and healthcare professionals.5No allied and healthcare professional shall`
  line `discharge any duty or perform any function not authorised by this Act or any treatment not authorised within`
  line `the scope of practice of the profession.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (54493)
  sectionNo (56)
  orderNo 56
  title `Penalty for falsely claiming to be entered in Central Register and State Register.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54493&sectionno=56&orderno=56&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_56_content:
  string
  line `56. Penalty for falsely claiming to be entered in Central Register and State Register.--- If any`
  line `person whose name is not for the time being entered in the Central Register or a State Register falsely`
  line `represents that it is so entered or uses in connection with his name or title any words or letters to suggest`
  line `that his name is so entered, he shall be punished on first conviction with fine which may extend to fifty`
  line `thousand rupees, and on any subsequent conviction with imprisonment which may extend to six months or`
  line `with fine not exceeding one lakh rupees or with both.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (54494)
  sectionNo (57)
  orderNo 57
  title `Misuse of titles.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54494&sectionno=57&orderno=57&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_57_content:
  string
  line `57. Misuse of titles.--- If any person,---`
  line
  line `(a) not being a person registered in the Central Register or a State Register, takes or uses the`
  line `description of an allied and healthcare professional, or`
  line
  line `(b) not possessing an allied and healthcare qualification under this Act, uses a degree or a diploma`
  line `or a license or an abbreviation indicating or implying such qualification,`
  line
  line `shall be punished on first conviction with fine which may extend to one lakh rupees, and on any subsequent`
  line `conviction with imprisonment which may extend to one year or with fine not exceeding two lakh rupees or`
  line `with both.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (54495)
  sectionNo (58)
  orderNo 58
  title `Failure to surrender certificate of registration.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54495&sectionno=58&orderno=58&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_58_content:
  string
  line `58. Failure to surrender certificate of registration.—If any person whose name has been removed`
  line `from the Central Register or a State Register, he shall surrender forthwith his certificate of registration or`
  line `certificate of renewal, as the case may be, or both, failing which he shall be punishable with fine which may`
  line `extend to fifty thousand rupees and in case of a continuing offence with an additional fine which may extend`
  line `to five thousand rupees per day after the first day during which the offence continues.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (54496)
  sectionNo (59)
  orderNo 59
  title `Penalty for contravention of provisions of Act.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54496&sectionno=59&orderno=59&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_59_content:
  string
  line `59. Penalty for contravention of provisions of Act.—Whoever contravenes any of the provisions of`
  line `this Act or any rules or regulations made thereunder shall be punished with imprisonment which shall not`
  line `be less than one year but which may extend to three years or with fine which shall not be less than one lakh`
  line `rupees but which may extend to five lakh rupees or with both.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (54497)
  sectionNo (60)
  orderNo 60
  title `Cognizance of offences.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54497&sectionno=60&orderno=60&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_60_content:
  string
  line `60. Cognizance of offences.—(1) No court shall take cognizance of any offence punishable under this`
  line `Act except upon a complaint made by the Central Government, the State Government, the Commission, or`
  line `the State Council, as the case may be.`
  line
  line `(2) No court inferior to that of a Metropolitan Magistrate or a Judicial Magistrate of the first class shall`
  line `try any offence punishable under this Act.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (54498)
  sectionNo (61)
  orderNo 61
  title `Bar of jurisdiction.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54498&sectionno=61&orderno=61&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_61_content:
  string
  line `61. Bar of jurisdiction.—No Civil Court shall have jurisdiction to entertain any suit or proceeding in`
  line `respect of any order made by the Commission or State Council relating to the removal of a name or the`
  line `refusal to enter a name in the Central Register or State Register, as the case may be, under this Act.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (54499)
  sectionNo (62)
  orderNo 62
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54499&sectionno=62&orderno=62&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_62_content:
  string
  line `62. Protection of action taken in good faith.—No suit, prosecution or other legal proceeding shall lie`
  line `against the Central Government or State Government or against the Chairperson, Vice-Chairperson or any`
  line `other Member of the Commission or any Member of the State Council or any member of the Professional`
  line `Council or any member of the Autonomous Board, as the case may be, for anything which is in good faith`
  line `done or intended to be done in pursuance of this Act or any rule made thereunder in the discharge of their`
  line `official duties.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (54500)
  sectionNo (63)
  orderNo 63
  title `Direction by Central Government.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54500&sectionno=63&orderno=63&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_63_content:
  string
  line `63. Direction by Central Government.—(1) The Central Government may, from time to time, issue`
  line `such directions to the Commission, as in the opinion of Government are conducive for the fulfilment of the`
  line `objects of this Act and in the discharge of its functions.`
  line
  line `(2) Any direction issued under sub-section (1) may include directions to the Commission to make any`
  line `regulations or to amend or revoke any regulations already made.`
obj_root_law_sections_63_footnotes:
  string
  line
obj_root_law_sections_64:
  sectionId (54501)
  sectionNo (64)
  orderNo 64
  title `Act to have overriding effect.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54501&sectionno=64&orderno=64&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_64_content:
  string
  line `64. Act to have overriding effect.—The provisions of this Act shall have overriding effect`
  line `notwithstanding anything inconsistent therewith contained in any other law for the time being in force or`
  line `in any instrument having effect by virtue of any law other than this Act.`
obj_root_law_sections_64_footnotes:
  string
  line
obj_root_law_sections_65:
  sectionId (54502)
  sectionNo (65)
  orderNo 65
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54502&sectionno=65&orderno=65&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_65_content:
  string
  line `65. Power of Central Government to make rules.—(1) The Central Government may, by`
  line `notification, make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing powers under sub-section (1),`
  line `such rules may provide for all or any of the following matters, namely:--`
  line
  line `(a) the qualifications and experiences of the Part-time Member of the Commission under sub-clause`
  line `(i) of clause (d) of sub-section (3) of section 3;`
  line
  line `(b) the manner of selection of the Part-time Member of the Commission under sub-clause (ii) of`
  line `clause (d) of sub-section (3) of section 3;`
  line
  line `(c) the qualification, experience and manner of the selection of the Part-time Member of the`
  line `Commission under sub-clause (iii) of clause (d) of sub-section (3) of section 3;`
  line
  line `(d) the salaries, allowances and other conditions of service of the Chairperson and Vice Chairperson of the Commission under sub-section (2) of section 4;`
  line
  line `(e) the travelling and other allowances to the Part-time Member of the Commission under subsection (3) of section 4;`
  line
  line `(f) the rules of procedure with respect to the transaction of business at meetings of the Commission`
  line `under sub-section (1) of section 7;`
  line
  line `(g) the salaries, allowances and other conditions of service of the Secretary and other officers of`
  line `the Commission under sub-section (2) of section 9;`
  line
  line `(h) the qualifications and experiences of members of the Professional Council under sub-section`
  line `(1) of section 10;`
  line
  line `(i) the form of application and the manner of entering the name of person in the Central Register`
  line `under section 16;`
  line
  line `(j) the form, manner and fee of application for certificate of registration under sub-section (1) of`
  line `section 17;`
  line
  line `(k) the form of certificate of registration under sub-section (2) of section 17;`
  line
  line `(l) the fees for and form of duplicate certificate under sub-section (3) of section 17;`
  line
  line `(m) the form, manner and fees of application for additional entry in the Central Register under subsection (1) of section 18;`
  line
  line `(n) the qualifications, experiences and manner of appointment of members of Interim Commission`
  line `under clause (k) of sub-section (2) of section 20;`
  line
  line `(o) the form, manner, particulars and fees of the scheme under clause (b) of sub-section (2) of`
  line `section 40;`
  line
  line `(p) the manner of sums of money received by the Commission under clause (c) of sub-section (1)`
  line `of section 46;`
  line
  line `(q) the manner of application of fund for expenses incurred in discharge of the functions of the`
  line `Commission under sub-section (2) of section 46;`
  line
  line `(r) the form and time period for preparing annual report of the Commission under section 48; and`
  line
  line `(s) any other matter which is required to be, or may be, specified by rules or in respect for which`
  line `provision is to be made by rules.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (54503)
  sectionNo (66)
  orderNo 66
  title `Power to make regulations.`
  content obj_root_law_sections_66_content
  footnotes obj_root_law_sections_66_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54503&sectionno=66&orderno=66&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_66_content:
  string
  line `66. Power to make regulations.--- (1) The Commission may, after public consultation and with the`
  line `previous approval of the Central Government, make regulations generally to carry out the purposes of this`
  line Act.
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing provisions, such regulations`
  line `may provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of providing basic standards of education, courses, curricula, physical and`
  line `instructional facilities, staff pattern, staff qualifications, quality instructions, assessment, examination,`
  line `training, research, continuing professional education, maximum tuition fee payable in respect of various`
  line `recognised categories, proportionate distribution of seats and promote innovations in recognised`
  line `categories under clause (e) of sub-section (1) of section 11;`
  line
  line `(b) other particulars for allied and healthcare qualifications under clause (f) of sub-section (1) of`
  line `section 11;`
  line
  line `(c) the manner of providing uniform examination with common counselling for admission under`
  line `clause (g) of sub-section (1) of section 11;`
  line
  line `(d) the manner of providing for exit or licensing examination for allied and healthcare professionals`
  line `and National Teachers Eligibility Test under clause (h) of sub-section (1) of section 11;`
  line
  line `(e) the manner of taking measures under clause (k) of sub-section (1) of section 11;`
  line
  line `(f) the manner of containing information including name of person and qualification relating to any`
  line `of the respective recognised categories in the Central Register under sub-section (1) of section 13;`
  line
  line `(g) the manner of adopting standardised format for populating and maintaining the Central Register`
  line `under sub-section (2) of section 13;`
  line
  line `(h) the manner of removal of name of a person from the Central Register under section 19;`
  line
  line `(i) the number of members from each recognised category under sub-section (2) of section 29;`
  line
  line `(j) other functions of the Under-graduate Allied and Healthcare Education or Post-graduate Allied`
  line `and Healthcare Education or Allied and Healthcare Profession Assessment and Rating or Allied and`
  line `Healthcare Professions Ethics and Registration under sub-section (6) of section 29;`
  line
  line `(k) the manner of containing information including name of person and qualification relating to any`
  line `of their respective recognised categories under sub-section (1) of section 32;`
  line
  line `(l) the manner of containing details of academic qualification, institutions, training, skill and`
  line `competencies of Allied and Healthcare Professionals related to their profession in the State Register`
  line `under sub-section (2) of section 32;`
  line
  line `(m) the form and manner of renewal of registration under sub-section (4) of section 33;`
  line
  line `(n) the period for registration under sub-section (2) of section 36;`
  line
  line `(o) the period and manner of registration of person who offers services in any of the recognised`
  line `categories on or before the commencement of this Act under section 38;`
  line
  line `(p) the recognition of corresponding allied and healthcare qualifications granted outside India under`
  line `sub-section (1) of section 39;`
  line
  line `(q) the manner of entitlement of registration of qualifications granted by institutions outside India`
  line `under sub-section (2) of section 39;`
  line
  line `(r) the basic standards of education for seeking to open a new or higher course of study or training`
  line `under clause (a) of sub-section (5) of section 40;`
  line
  line `(s) any other factors under clause (g) of sub-section (5) of section 40;`
  line
  line `(t) the manner of furnishing information by the University or college or institution under subsection (2) of section 41;`
  line
  line `(u) the manner of verification of standards of education in allied and healthcare institutions by the`
  line `State Council under sub-section (1) of section 42; and`
  line
  line `(v) any matter for which provision may be made by the regulations under this Act.`
obj_root_law_sections_66_footnotes:
  string
  line
obj_root_law_sections_67:
  sectionId (54504)
  sectionNo (67)
  orderNo 67
  title `Laying of rules and regulations.`
  content obj_root_law_sections_67_content
  footnotes obj_root_law_sections_67_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54504&sectionno=67&orderno=67&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_67_content:
  string
  line `67. Laying of rules and regulations.—Every rule made by the Central Government, and the`
  line `regulations made by the Commission, under this Act shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or regulations, or both Houses agree that the rule or regulations should not be made, the rule or`
  line `regulations shall, thereafter have effect only in such modified form or be of no effect, as the case may be;`
  line `so, however, that any such modification or annulment shall be without prejudice to the validity of anything`
  line `previously done under that rule or regulations.`
obj_root_law_sections_67_footnotes:
  string
  line
obj_root_law_sections_68:
  sectionId (54505)
  sectionNo (68)
  orderNo 68
  title `Power of State Government to make rules.`
  content obj_root_law_sections_68_content
  footnotes obj_root_law_sections_68_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54505&sectionno=68&orderno=68&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_68_content:
  string
  line `68. Power of State Government to make rules.—(1) The State Government may, by notification,`
  line `make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing powers under sub-section (1),`
  line `such rules may provide for the following matters, namely:--`
  line
  line `(a) the qualifications and experiences of the member of the State Council under clause (e) of subsection (3) of section 22;`
  line
  line `(b) the qualifications and experiences of the member of the State Council under clause (f) of subsection (3) of section 22;`
  line
  line `(c) the travelling and other allowances for the Member of the State Council under sub-section (2)`
  line `of section 23;`
  line
  line `(d) the time, place and manner of rule of procedure in respect to transaction of business at meetings`
  line `including quorum of the State Council under sub-section (1) of section 26;`
  line
  line `(e) the salaries, allowances and other conditions of services of the Secretary, other officers and`
  line `employees of the State Council under sub-section (2) of section 28;`
  line
  line `(f) the fees for registration in the State Register under sub-section (1) of section 33;`
  line
  line `(g) the form of certificate of registration under sub-section (3) of section 33;`
  line
  line `(h) the fee and form of duplicate certificate under section 34;`
  line
  line `(i) the fee and the manner of payment of such fee under sub-section (1) of section 35;`
  line
  line `(j) the fee for restoration of name in the State Register under proviso to sub-section (2) of section`
  line 35;
  line
  line `(k) the fee for restoration of name in the State Register under section 37;`
  line
  line `(l) the manner of application of fund for expenses incurred in discharge of the functions of the State`
  line `Council under sub-section (3) of section 51;`
  line
  line `(m) the form and time for preparing annual report under section 53; and`
  line
  line `(n) any other matter which is required to be, or may be, specified by rules or in respect for which`
  line `provision is to be made by rules.`
  line
  line `(3) Every rule made by the State Government under this Act shall be laid, as soon as may be after it is`
  line `made, before each House of State Legislature, where there are two Houses and where there is one House`
  line `of State Legislature, before that House.`
obj_root_law_sections_68_footnotes:
  string
  line
obj_root_law_sections_69:
  sectionId (54506)
  sectionNo (69)
  orderNo 69
  title `Power to remove difficulties.`
  content obj_root_law_sections_69_content
  footnotes obj_root_law_sections_69_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54506&sectionno=69&orderno=69&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_69_content:
  string
  line `69. Power to remove difficulties.—(1) If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order, published in the Official Gazette, make such provisions, not`
  line `inconsistent with the provisions of this Act, as may appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of three years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_69_footnotes:
  string
  line
obj_root_law_sections_70:
  sectionId (54507)
  sectionNo (70)
  orderNo 70
  title `Power to amend Schedule.`
  content obj_root_law_sections_70_content
  footnotes obj_root_law_sections_70_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00023_202114_1622792373723&sectionId=54507&sectionno=70&orderno=70&orgactid=AC_CEN_12_13_00023_202114_1622792373723
obj_root_law_sections_70_content:
  string
  line `70. Power to amend Schedule.—(1) The Central Government may, after consultation with the`
  line `Commission, by a notification, add to or otherwise amend the Schedule for the purposes of this Act and`
  line `thereupon the said Schedule shall be deemed to be amended accordingly.`
  line
  line `(2) A copy of every notification proposed to be issued under sub-section (1), shall be laid in draft before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in disapproving the issue of`
  line `the notification or both Houses agree in making any modification in the notification, the notification shall`
  line `not be issued or, as the case may be, shall be issued only in such modified form as may be agreed upon by`
  line `both the Houses.`
obj_root_law_sections_70_footnotes:
  string
  line
