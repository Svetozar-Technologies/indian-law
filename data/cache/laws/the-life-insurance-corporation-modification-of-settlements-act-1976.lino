obj_root_law_sections_1:
  object
  (str sectionId) (str 32373)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Life Insurance Corporation (Modification of Settlements)
Act, 1976.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00029_197672_1517807322415&sectionId=32373&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00029_197672_1517807322415)
obj_root_law_sections_2:
  object
  (str sectionId) (str 32374)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act, unless the context otherwise requires,--

(a) "Corporation" means the Life Insurance Corporation of India established under section 3 of
the Life Insurance Corporation Act, 1956 (31 of 1956);

(b) "salary" means basic pay and includes--

(i) special pay, if any;

(ii) dearness allowance; and

(iii) additional dearness allowance;

(c) "settlements" means,--

(i) the settlement which was arrived at between the Corporation and their workmen on the
24th day of January, 1974, under section 18, read with clause (p) of section 2, of the Industrial
Disputes Act, 1947 (14 of 1947); and

(ii) the settlement which was arrived at between the Corporation and their workmen on the
6th day of February, 1974, under section 18, read with clause (p) of section 2, of the said Act and
in respect of the terms of which there was no approval as provided for in sub-clause (2) of clause
12 thereof.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00029_197672_1517807322415&sectionId=32374&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00029_197672_1517807322415)
obj_root_law_sections_3:
  object
  (str sectionId) (str 32375)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Modification of settlements.`)
  (str content) (str `Notwithstanding anything contained in the Industrial Disputes Act,
1947 (14 of 1947),the provisions of each of the settlements, in so far as they relate to the payment of an
annual cash bonus to every Class III and Class IV employee of the Corporation at the rate of fifteen per
cent. of his annual salary, shall not have any force or effect and shall not be deemed to have had any force
or effect on and from the 1st day of April, 1975.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00029_197672_1517807322415&sectionId=32375&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00029_197672_1517807322415)
