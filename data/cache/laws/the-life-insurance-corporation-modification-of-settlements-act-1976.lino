  (str title) (str `जीवन बीमा निगम (समझौता-उपान्‍तरण) अधिनियम, 1976`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1433/4/H1976-72.pdf`)
