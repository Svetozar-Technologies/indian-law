obj_root_law:
  slug the-airports-economic-regulatory-authority-of-india-act-2008
  handle (2090)
  collectionHandle 123456789/1362
  title `The Airports Economic Regulatory Authority of India Act, 2008`
  actNumber (27)
  enactmentDate 2008-12-05
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2090`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भारतीय विमानपत्तन आर्थिक विनियामकप्राधिकरण अधिनियम, 2008`
  actYear (2008)
  ministry `Ministry of Civil Aviation`
  department undefined
  longTitle `An Act to provide for the establishment of an Airports Economic Regulatory Authority to regulate tariff and other charges for the aeronautical services rendered at airports and to monitor performance standards of airports and also to establish Appellate Tribunal to adjudicate disputes and dispose of appeals and for matters connected therewith or incidental thereto.`
  enforcementDate 01-01-2009
  notification `1st January, 2009 (except Chapters III and IV), vide notification No. S.O. 1894(E), dated 30th December, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T10:28:17.536Z`
  translations obj_root_law_translations
