  (str slug) (str the-airports-economic-regulatory-authority-of-india-act-2008)
  (str handle) (str 2090)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Airports Economic Regulatory Authority of India Act, 2008`)
  (str actNumber) (str 27)
  (str enactmentDate) (str 2008-12-05)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2090`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भारतीय विमानपत्तन आर्थिक विनियामकप्राधिकरण अधिनियम, 2008`)
  (str actYear) (str 2008)
  (str ministry) (str `Ministry of Civil Aviation`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the establishment of an Airports Economic Regulatory Authority to regulate tariff and other charges for the aeronautical services rendered at airports and to monitor performance standards of airports and also to establish Appellate Tribunal to adjudicate disputes and dispose of appeals and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-01-2009)
  (str notification) (str `1st January, 2009 (except Chapters III and IV), vide notification No. S.O. 1894(E), dated 30th December, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T10:28:17.536Z`)
  (str translations) obj_root_law_translations
