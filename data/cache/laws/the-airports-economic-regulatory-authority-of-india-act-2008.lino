obj_root_law_translations_hi_sections_1_content:
  string
  line `भारतीय विमानपत्तन आर्थिक विवनयामक प्र`
  line `ाविकरण अविवनयम, 2008`
  line _________
  line `िाराओं का क्र म`
  line _________
  line िाराएं
  line `अध्या य 1 प्र`
  line ारंवभक
  line `1. संविप् त नाम, प्र ारंभ और लागू होना।`
  line `2. पररभाषाएं।`
  line `अध्या य 2`
  line `विमानपत्तन आर्थिक विवनयामक प्र ाविकरण`
  line `3. प्र ाविकरण की स् था पना।`
  line `4. प्र ाविकरण की संरचना।`
  line `5. सदस्यों की वसफाररश करने के वलए चयन सवमवत का गठन।`
  line `6. अध्य ि और सदस्यों की पदािवि और सेिा की अन्य शतें, आदद।`
  line `7. अध्य ि की शवत।`
  line `8. सदस्यों का हटाया जाना और वनलंबन।`
  line `9. प्र ाविकरण के सवचि, विशेषज्ञों, िृवत्तकों और अविका ररयों तथा अन्य कमिचाररयों की वनयुवत।`
  line `10. अवििेशन।`
  line `11. अविप्रमाणन।`
  line `12. ररवत यों, आदद से प्र ाविकरण की कायििावहयों का अविविमान्य न होना।`
  line `अध्या य 3 प्र`
  line `ाविकरण की शवत यां और कृत्य`
  line `13. प्र ाविकरण के कृत्य।`
  line `14. जानकारी मांगने, अन्िे षण करने आदद की प्र ाविकरण की शवत यां।`
  line `15. कवतपय वनदेश देने की प्र ाविकरण की शवत।`
  line `16. अवभग्रहण की शवत।`
  line `अध्या य 4`
  line `अपील अविकरण`
  line `17. अपील अविकरण की स् था पना।`
  line `18. वििाद के वनपटारे के वलए आिेदन और अपील अविकरण को अपील।`
  line `19. अपील अविकरण की संरचना।`
  line `20. अध्य ि और सदस्यों की वनयुवत के वलए अहिताएं।`
  line `21. पदािवि।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `22. सेिा के वनबंिन और शतें।`
  line `23. ररवत यां।`
  line `24. पद से हटाया जाना और त् या गपत्र।`
  line `25. अपील अविकरण के कमिचाररिृन्द।`
  line `26. बहुमत द्व ारा विवनश्च य दकया जाना।`
  line `27. सदस्यों आदद का लोक सेिक होना।`
  line `28. वसविल न् या यालय की अविकाररता का न होना।`
  line `29. अपील अविकरण की प्र दक्रया और शवत यां।`
  line `30. विविक प्र वतवनवित्ि का अविकार।`
  line `31. उच्च तम न् या यालय को अपील।`
  line `32. अपील अविकरण द्व ारा पाररत आदेश का विक्री के रू प में वनष्पा दनीय होना।`
  line `अध्या य 5`
  line `वित्त, लेखा और संपरी िा`
  line `33. बजट।`
  line `34. केन्री य सरकार द्व ारा अनुदान।`
  line `35. लेखाओं का िार्षिक वििरण।`
  line `36. वििरवणयों आदद का केन्री य सरकार को ददया जाना।`
  line `अध्या य 6`
  line `अपराि और शावस्त यां`
  line `37. अपील अविकरण के आदेशों के अनुपालन में जानबूझकर असफल रहने के वलए शावस्त।`
  line `38. इस अविवनय म के अिीन आदेशों और वनदेशों के अननुपालन के वलए दंि।`
  line `39. प्र ाविकरण या अपील अविकरण के आदेश के अननुपालन के वलए दंि।`
  line `40. कंपवनयों द्व ारा अपराि।`
  line `41. सरकारी विभागों द्व ारा अपराि।`
  line `अध्या य 7 प्र`
  line कीणि
  line `42. केन्री य सरकार द्व ारा वनदेश।`
  line `43. प्र ाविकरण के सदस्यों, अविकाररयों और कमिचाररयों का लोक सेिक होना।`
  line `44. अविकाररता का िजिन।`
  line `45. सद्भािपूििक की गई कारििाई के वलए संरिण।`
  line `46. िन और आय पर कर से छूट।`
  line `47. अपरािों का संज्ञान।`
  line `48. शवत यों का प्रत् या योजन।`
  line `49. केन्री य सरकार की प्र ाविकरण को अवतवष्ठ त कर ने की शवत।`
  line `50. अन्य विवियों का लागू होना, िर्जित न होना।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
