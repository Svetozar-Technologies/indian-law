obj_root_law_sections_1:
  sectionId (32010)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00034_199325_1517807323419&sectionId=32010&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00034_199325_1517807323419
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Gold Bonds (Immunities and`
  line `Exemptions) Act, 1993.`
  line
  line `(2) It shall be deemed to have come into force on the 31st day of January, 1993.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (32011)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00034_199325_1517807323419&sectionId=32011&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00034_199325_1517807323419
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Gold Bonds" means the Gold Bonds, 1998, issued by the Central Government in accordance`
  line `with the scheme framed by that Government under section 3;`
  line
  line `(b) "subscriber" means an individual, a Hindu undivided family, trustees of a trust, a firm or a`
  line `company, being a resident or residents in India, who has or have initially subscribed to the Gold`
  line Bonds.
  line
  line `Explanation.-- For the purposes of this clause, the expression "individual" shall also include,--`
  line
  line `(i) his legal heirs; or`
  line
  line `(ii) where a partition has taken place among the members of the Hindu undivided family,`
  line `every member of such family having a share in the Gold Bonds;`
  line
  line `(c) all other words and expressions used in this Act but not defined and defined in the Income-tax`
  line `Act, 1961 (43 of 1961) shall have the meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (32012)
  sectionNo (3)
  orderNo 3
  title `Gold Bonds Scheme.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00034_199325_1517807323419&sectionId=32012&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00034_199325_1517807323419
obj_root_law_sections_3_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `frame a scheme for subscription to the Gold Bonds, 1998, on or after the date of commencement of this`
  line `Act, but before the specified date.`
  line
  line `Explanation.-- For the purposes of this sub-section, "specified date" means the 31st day of March,`
  line `1993 or such other later date as the Central Government may, by notification in the Official Gazette,`
  line `specify in this behalf.`
  line
  line `(2) The scheme framed under sub-section (1) shall be laid, as soon as may be after it is framed, before`
  line `each House of Parliament.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (32013)
  sectionNo (4)
  orderNo 4
  title Immunities.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00034_199325_1517807323419&sectionId=32013&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00034_199325_1517807323419
obj_root_law_sections_4_content:
  string
  line `(1) Notwithstanding anything contained in the Wealth-tax Act, 1957 (27 of 1957),`
  line `the Gift-tax Act, 1958 (18 of 1958), the Income-tax Act, 1961 (43 of 1961), the Customs Act, 1962 (52 of`
  line `1962), the Foreign Exchange Regulation Act, 1973 (46 of 1973) and the Foreign Contribution`
  line `(Regulation) Act, 1976 (49 of 1976),--`
  line
  line `(a) no subscriber shall be required to disclose, for any purpose whatsoever, the nature and source`
  line `of acquisition of the gold subscribed for the Gold Bonds, including the source of money with which`
  line `the gold was acquired;`
  line
  line `(b) no inquiry or investigation shall be commenced against any subscriber under any of the said`
  line `Acts on the ground that such subscriber owns the Gold Bonds; and`
  line
  line `(c) the fact that any subscriber owns the Gold Bonds shall not be taken into account for the`
  line `purposes of, and shall be inadmissible as evidence in, any proceedings under any of the said Acts:`
  line
  line `Provided that nothing contained in this sub-section shall apply where any proceedings in respect of`
  line `the gold subscribed by the subscriber have already been initiated before the commencement of this Act in`
  line `accordance with the provisions of any of the aforesaid Acts.`
  line
  line `(2) Nothing in sub-section (1) shall apply in relation to prosecution for any offence punishable under`
  line `Chapter IX or Chapter XVII of the Indian Penal Code (45 of 1860), the Narcotic Drugs and Psychotropic`
  line `Substances Act, 1985 (61 of 1985), the Terrorist and Disruptive Activities (Prevention) Act, 1987 (28 of`
  line `1987), the Prevention of Corruption Act, 1988 (49 of 1988) or for the purposes of enforcement of any`
  line `civil liability.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (32014)
  sectionNo (5)
  orderNo 5
  title `Gold Bonds not to be taken into account in certain cases.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00034_199325_1517807323419&sectionId=32014&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00034_199325_1517807323419
obj_root_law_sections_5_content:
  string
  line `Without prejudice to the generality`
  line `of the provisions of section 4,--`
  line
  line `(a) the provisions of the Income-tax Act, 1961 (43 of 1961) shall not apply to--`
  line
  line `(i) any interest accruing to the subscriber from the Gold Bonds;`
  line
  line `(ii) any long-term capital gains arising to the subscriber;`
  line
  line `(b) the provisions of the Gift-tax Act, 1958 (18 of 1958) shall not apply where the gift of the Gold`
  line `Bonds is made by a subscriber, being an individual, to his spouse, child or parent.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (32015)
  sectionNo (6)
  orderNo 6
  title `Repeal and savings.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00034_199325_1517807323419&sectionId=32015&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00034_199325_1517807323419
obj_root_law_sections_6_content:
  string
  line `(1) The Gold Bonds (Immunities and Exemptions) Ordinance, 1993 (Ord.`
  line `22 of 1993) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance, shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
