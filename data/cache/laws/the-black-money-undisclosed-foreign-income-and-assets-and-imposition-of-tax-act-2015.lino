obj_root_law:
  slug the-black-money-undisclosed-foreign-income-and-assets-and-imposition-of-tax-act-2015
  handle (2147)
  collectionHandle 123456789/1362
  title `The Black Money (Undisclosed Foreign Income and Assets) and Imposition of Tax Act, 2015`
  actNumber (22)
  enactmentDate 2015-05-26
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2147`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `काला धन (अप्रकटित विदेशी आय और आस्तिअ) और कर अधिरोपण अधिनियम, 2015`
  actYear (2015)
  ministry `Ministry of Finance`
  department `Department of Revenue`
  longTitle `An Act to make provisions to deal with the problem of the Black money that is undisclosed foreign income and assets, the procedure for dealing with such income and assets and to provide for imposition of tax on any undisclosed foreign income and asset held outside India and for matters connected therewith or incidental thereto.`
  enforcementDate 01-04-2016
  notification undefined
  fetchedAt `2026-05-09T19:19:06.618Z`
  translations obj_root_law_translations
