  (str slug) (str the-black-money-undisclosed-foreign-income-and-assets-and-imposition-of-tax-act-2015)
  (str handle) (str 2147)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Black Money (Undisclosed Foreign Income and Assets) and Imposition of Tax Act, 2015`)
  (str actNumber) (str 22)
  (str enactmentDate) (str 2015-05-26)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2147`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `काला धन (अप्रकटित विदेशी आय और आस्तिअ) और कर अधिरोपण अधिनियम, 2015`)
  (str actYear) (str 2015)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Revenue`)
  (str longTitle) (str `An Act to make provisions to deal with the problem of the Black money that is undisclosed foreign income and assets, the procedure for dealing with such income and assets and to provide for imposition of tax on any undisclosed foreign income and asset held outside India and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-04-2016)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T19:19:06.618Z`)
