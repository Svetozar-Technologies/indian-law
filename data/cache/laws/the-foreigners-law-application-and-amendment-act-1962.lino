  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00045_196242_1673602097671&sectionId=72572&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00045_196242_1673602097671
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Foreigners Law (Application and Amendment)`
  line `Act, 1962.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (72573)
  sectionNo (2)
  orderNo 2
  title `Application of Act 16 of 1939 and Act 31 of 1946 to certain persons.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00045_196242_1673602097671&sectionId=72573&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00045_196242_1673602097671
obj_root_law_sections_2_content:
  string
  line Notwithstanding
  line `anything contained in any other law for the time being in force, the provisions of the Registration of`
  line `Foreigners Act, 1939, and the Foreigners Act, 1946, and of the rules and orders made thereunder shall`
  line `apply to and in relation to any person who, or either of whose parents, or any of whose grand-parents`
  line `was at any time a citizen or subject of any country at war with, or committing external aggression`
  line `against, India or of any other country assisting the country at war with, or committing such aggression`
  line `against, India, as they apply to and in relation to foreigners as defined for the purposes of those Acts.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (72574)
  sectionNo (3)
  orderNo 3
  title Repealed.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00045_196242_1673602097671&sectionId=72574&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00045_196242_1673602097671
obj_root_law_sections_3_content:
  string
  line `[Amendment of Act of 31 of 1946.—Section 3 rep. by Repealing and Amending Act 56 of 1974,`
  line `s. 2 and the First Schedule, (w.e.f. 20-12-1974).`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (72575)
  sectionNo (4)
  orderNo 4
  title `Repeal and saving.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00045_196242_1673602097671&sectionId=72575&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00045_196242_1673602097671
obj_root_law_sections_4_content:
  string
  line `(1) The Foreigners Law (Application and Amendment) Ordinance,`
  line `1962 (5 of 1962), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall`
  line `be deemed to have been done or taken under this Act, as if this Act and commenced on the 26th`
  line `October, 1962.`
obj_root_law_sections_4_footnotes:
  string
  line
