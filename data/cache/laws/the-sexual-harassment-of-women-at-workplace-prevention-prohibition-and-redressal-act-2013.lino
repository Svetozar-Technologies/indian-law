  object
  (str title) (str `महिलाओं का कार्यस्थल पर लैंगिक उत्पीड़न (निवारण, प्रतिषेध और प्रतितोष) अधिनियम, 2013`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2104/3/H2013-14.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:52:09.019Z`)
