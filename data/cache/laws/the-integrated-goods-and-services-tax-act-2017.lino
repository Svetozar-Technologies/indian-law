obj_root_law:
  slug the-integrated-goods-and-services-tax-act-2017
  handle (2251)
  collectionHandle 123456789/1362
  title `The Integrated Goods and Services Tax Act, 2017`
  actNumber (13)
  enactmentDate 2017-04-12
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2251`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `एकीकृत माल और सेवा कर अधिनियम,2017`
  actYear (2017)
  ministry `Ministry of Finance`
  department `Department of Revenue`
  longTitle `An Act to make a provision for levy and collection of tax on inter-State supply of goods or services or both by the Central Government and for matters connected therewith or incidental thereto.`
  enforcementDate `22nd June, 2017 for sections 1, 2, 3, 14, 20 and 22. 1st July, 2017 for sections 4 to 13, 16 to 19, 21, 23 to 25`
  notification `G.S.R. 603(E) dated the 19th June, 2017, Gazette of India, Extraordinary, Part II, sec. 3(i). G.S.R. 662(E) dated the 28th June, 2017, Gazette of India, Extraordinary, Part II, sec. 3(i)`
  fetchedAt `2026-05-09T14:53:06.914Z`
