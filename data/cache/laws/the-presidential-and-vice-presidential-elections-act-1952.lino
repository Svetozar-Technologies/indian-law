obj_root_law_sections_1:
  sectionId (1064)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Presidential and Vice-Presidential Elections Act, 1952.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1064&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (1065)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1065&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the contest otherwise requires,--`
  line
  line `(a) "article" means an article of the Constitution;`
  line
  line `(b) "election" means a Presidential election or Vice-Presidential election;`
  line
  line `(c) "election Commission" means the Election Commission appointed by the President under`
  line `article 324;`
  line
  line `(d) "Elector", in relation to a Presidential election, means a member of the electoral college`
  line `referred to in article 54, and in relation to a Vice-Presidential election, means ^1[a member of the`
  line `electoral college referred to in article 66;]`
  line
  line `(e) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(f) "Presidential election" means an election to fill the office of the President of India;`
  line
  line `^2[(ff) "public holiday" means any day which is a public holiday for the purposes of section 25 of`
  line `the Negotiable Instruments Act, 1881 (26 of 1881);]`
  line
  line `(g) "Returning Officer" includes an Assistant Returning Officer performing any function which`
  line `he is ^3[competent] to perform under sub-section (2) of section 3;`
  line
  line `(h) "Vice-Presidential election" means an election to fill the office of the Vice-President of India.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 5 of 1974, s. 2, for "a member of either House of Parliament" (w.e.f. 23-3-1974).`
  line
  line `2. Ins. by s. 2,ibid. (w.e.f. 23-3-1974).`
  line
  line `3. Subs. by s. 2, ibid., for "authorised" (w.e.f. 23-3-1974).`
obj_root_law_sections_3:
  sectionId (1066)
  sectionNo (3)
  orderNo 3
  title `Returning Officer and his assistants.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1066&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_3_content:
  string
  line `(1) For the purposes of each election the Election`
  line `Commission shall, in consultation with the Central Government, appoint a Returning Officer who shall`
  line `have his office in New Delhi and may also appoint one or more Assistant Returning Officers.`
  line
  line `(2) Subject to rules made under this Act, every Assistant Returning Officer shall be competent to`
  line `perform all or any of the functions of the Returning Officer.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (1067)
  sectionNo (4)
  orderNo 4
  title `Appointment of dates for nominations, etc.`
  content obj_root_law_sections_4_content
  footnotes `1.Subs. by Act 5 of 1974, s. 3, for sub-section (1) (w.e.f. .23-3-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1067&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_4_content:
  string
  line `^1[(1) The Election Commission shall, by`
  line `notification in the Official Gazette, appoint for every election--`
  line
  line `(a) the last date for making nominations, which shall be the fourteenth day after the date of`
  line `publication of the notification under this sub-section, or, if that day is a public holiday, the next`
  line `succeeding day which is not a public holiday;`
  line
  line `(b) the date for the scrutiny of nominations, which shall be the day immediately following the last`
  line `date for making nominations or, if that day is a public holiday, the next succeeding day which is not a`
  line `public holiday;`
  line
  line `(c) the last date for the withdrawal of candidatures, which shall be the second day after the date`
  line `for the scrutiny of nominations or, if that day is a public holiday, the next succeeding day which is not`
  line `a public holiday;`
  line
  line `(d) the date on which a poll shall, if necessary, be taken, which shall be a date not earlier than the`
  line `fifteenth day after the last date for the withdrawal of the candidatures.]`
  line
  line `(2) In the case of the first Presidential and Vice-Presidential elections, the notifications under`
  line `sub-section (1) shall be issued as soon as may be after both Houses of Parliament have been constituted.`
  line
  line `(3) In the case of an election to fill a vacancy caused by the expiration of the term of office of the`
  line `President or Vice-President, the notification under sub-section (1) shall be issued on, or as soon as`
  line `conveniently may be after, the sixtieth day before the expiration of the term of office of the outgoing`
  line `President or Vice-President, as the case may be, and the dates shall be so appointed under the said`
  line `sub-section that the election will be completed at such time as will enable the President or the`
  line `Vice-President thereby elected to enter upon his office on the day following the expiration of the term of`
  line `office of the outgoing President or Vice-President, as the case may be.`
  line
  line `(4) In the case of an election to fill a vacancy in the office of President or Vice-President occurring by`
  line `reason of his death, resignation or removal or otherwise, the notification under sub-section (1) shall be`
  line `issued as soon as may be after the occurrence of such vacancy`
obj_root_law_sections_5:
  sectionId (1068)
  sectionNo (5)
  orderNo 5
  title `Public notice of election.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by s. 4, ibid., for section 5 (w.e.f. 23-3-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1068&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_5_content:
  string
  line `^1[5. Public notice of election.-- On the issue of a notification under sub-section (1) of section 4, the`
  line `Returning Officer for the election shall give public notice of the intended election in such form and in`
  line `such manner as may be prescribed, inviting nominations of candidates for such election and specifying`
  line `the place at which the nomination papers are to be delivered.]`
obj_root_law_sections_5_a:
  sectionId (1069)
  sectionNo 5A
  orderNo 6
  title `Nomination of candidates.`
  content obj_root_law_sections_5_a_content
  footnotes `1. Subs. by s. 4, ibid., for section 5 (w.e.f. 23-3-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1069&sectionno=5A&orderno=6&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_5_a_content:
  string
  line `^1[5A. Nomination of candidates.-- Any person may be nominated as a candidate for election to the`
  line `office of President or Vice-President if he is qualified to be elected to that office under the Constitution.]`
obj_root_law_sections_5_b:
  sectionId (1070)
  sectionNo 5B
  orderNo 7
  title `Presentation of nomination papers and requirements for a valid nomination.`
  content obj_root_law_sections_5_b_content
  footnotes obj_root_law_sections_5_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1070&sectionno=5B&orderno=7&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_5_b_content:
  string
  line `^1[5B. Presentation of nomination papers and requirements for a valid nomination.-- (1) On or`
  line `before the date appointed under clause (a) of sub-section (1) of section 4, each candidate shall, either in`
  line `person or by any of his proposers or seconders, between the hours of eleven o'clock in the forenoon and`
  line `three o'clock in the afternoon, deliver to the returning officer at the place specified in this behalf in the`
  line `public notice issued under section 5 a nomination paper completed in the prescribed form and subscribed`
  line `by the candidate as assenting to the nomination, and`
  line
  line `(a) in the case of Presidential election, also by at least ^2[fifty electors] as proposers and at least`
  line `^2[fifty electors] as seconders;`
  line
  line `(b) in the case of Vice-Presidential election, also by at least ^3[twenty electors] as proposers and at`
  line `least ^3[twenty electors] as seconders:`
  line
  line `Provided that no nomination paper shall be presented to the Returning Officer on a day which is a`
  line `public holiday.`
  line
  line `(2) Each nomination paper shall be accompanied by a certified copy of the entry relating to the`
  line `candidate in the electoral roll for the parliamentary constituency in which the candidate is registered as an`
  line elector.
  line
  line `(3) The Returning Officer shall not accept any nomination paper which is presented on any day`
  line `before eleven oclock in the forenoon and after three o'clock in the afternoon.`
  line
  line `(4) Any nomination paper which is not received before three o'clock in the afternoon on the last date`
  line `appointed under clause (a) of sub-section (1) of section 4 or to which the certified copy referred to in`
  line `sub-section (2) of this section is not attached shall be rejected and a brief note relating to such rejection`
  line `shall be recorded on the nomination paper itself.`
  line
  line `(5) No elector shall subscribe, whether as proposer or as seconder, more than one nomination paper at`
  line `the same election and, if he does, his signature shall be inoperative on any paper other than the one first`
  line delivered.
  line
  line `(6) Nothing in this section shall prevent any candidate from being nominated by more than one`
  line `nomination paper for the same election:`
  line
  line `Provided that not more than four nomination papers shall be presented by or on behalf of any`
  line `candidate or accepted by the Returning Officer.]`
obj_root_law_sections_5_b_footnotes:
  string
  line `1. Subs. by s. 4, ibid., for section 5 (w.e.f. 23-3-1974).`
  line
  line `2. Subs. by Act 35 of 1997, s. 2, for "ten electors" (w.e.f. 5-6-1997).`
  line
  line `3. Subs. by Act 35 of 1997, s. 2, for "five electors" (w.e.f. 5-6-1997)`
obj_root_law_sections_5_c:
  sectionId (1071)
  sectionNo 5C
  orderNo 8
  title Deposit.
  content obj_root_law_sections_5_c_content
  footnotes obj_root_law_sections_5_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1071&sectionno=5C&orderno=8&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_5_c_content:
  string
  line `^1[5C. Deposit.-- (1) A candidate shall not be deemed to be duly nominated for election unless he`
  line `deposits or causes to be deposited a sum of ^2[fifteen thousand rupees]:`
  line
  line `Provided that where a candiate has been nominated by more than one nomination paper for the same`
  line `election, not more than one deposit shall be required or him under this sub-section.`
  line
  line `(2) The sum required to be deposited under sub-section (1) shall not be deemed to have been`
  line `deposited under that sub-section unless at the time of presentation of the nomination paper under`
  line `sub-section (1) of section 5B, the candidate has either deposited or caused to be deposited that sum with`
  line `the Returning Officer in cash or enclosed with the nomination paper a receipt showing that the said sum`
  line `has been deposited by him or on his behalf in the Reserve Bank of India or in a Government Treasury.]`
obj_root_law_sections_5_c_footnotes:
  string
  line `1. Subs. by s. 4, ibid., for section 5 (w.e.f. 23-3-1974).`
  line
  line `2. Subs. by s. 3, ibid., for "two thousand five hundred rupees" (w.e.f. 5-6-1997).`
obj_root_law_sections_5_d:
  sectionId (1072)
  sectionNo 5D
  orderNo 9
  title `Notice of nominations and the time and place for their scrutiny.`
  content obj_root_law_sections_5_d_content
  footnotes `1. Subs. by s. 4, ibid., for section 5 (w.e.f. 23-3-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1072&sectionno=5D&orderno=9&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_5_d_content:
  string
  line `^1[5D. Notice of nominations and the time and place for their scrutiny.-- On the presentation of a`
  line `nomination paper, the Returning Officer shall--`
  line
  line `(a) sign thereon a certificate stating the date and time of presentation of the nomination paper and`
  line `enter thereon its serial number;`
  line
  line `(b) inform the person or persons presenting the nomination paper of the date, time and place fixed`
  line `for the scrutiny of nominations; and`
  line
  line `(c) cause to be affixed in some conspicuous place in his office a copy of the nomination paper as`
  line `certified and numbered under clause (a).]`
obj_root_law_sections_5_e:
  sectionId (1073)
  sectionNo 5E
  orderNo 10
  title `Scrutiny of nominations.`
  content obj_root_law_sections_5_e_content
  footnotes `1. Subs. by s. 4, ibid., for section 5 (w.e.f. 23-3-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1073&sectionno=5E&orderno=10&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_5_e_content:
  string
  line `^1[5E. Scrutiny of nominations.-- (1) On the date fixed for the scrutiny of nominations under`
  line `sub-section (1) of section 4, the candidates, one proposer or one seconder of each candidate and one other person duly authorised in writing by each candidate, but no other person, shall be entitled to be present at`
  line `the time of scrutiny of nominations and the Returning Officer shall give them all reasonable facilities for`
  line `examining the nomination papers of all candidates which have not been rejected under sub-section (4) of`
  line `section 5B.`
  line
  line `(2) For the removal of doubts, it is hereby declared that it shall not be necessary to scrutinise on the`
  line `date fixed for the scrutiny of nominations the nomination papers already rejected under sub-section (4) of`
  line `section 5B.`
  line
  line `(3) The Returning Officer shall then examine the nomination papers and shall decide all objections`
  line `which may be made to any nomination paper and may either on such objection or on his own motion,`
  line `after such summary inquiry if any, as he thinks necessary, reject any nomination on any of the following`
  line `grounds:--`
  line
  line `(a) that, on the date fixed for the scrutiny of nominations, the candidate is not eligible for election`
  line `as President or Vice-President, as the case may be, under the Constitution; or`
  line
  line `(b) that any of the proposers or seconders is not qualified to subscribe a nomination paper under`
  line `sub-section (1) of section 5B; or`
  line
  line `(c) that the nomination paper is not subscribed by the required number of proposers or seconders;`
  line or
  line
  line `(d) that the signature of the candidate or any of the proposers or seconders is not genuine or has`
  line `been obtained by fraud; or`
  line
  line `(e) that there has been a failure to comply with any of the provisions of section 5B or section 5C.`
  line
  line `(4) Nothing contained in clauses (b) to (e) of sub-section (3) shall be deemed to authorise the`
  line `rejection of the nomination of any candidate on the ground of any irregularity in respect of a nomination`
  line `paper, if the candidate has been duly nominated by means of another nomination paper in respect of`
  line `which no irregularity has been committed.`
  line
  line `(5) The Returning Officer shall not reject any nomination paper on the ground of any defect which is`
  line `not of a substantial character.`
  line
  line `(6) The Returning Officer shall hold the scrutiny on the date appointed in this behalf under clause (b)`
  line `of sub-section (1) of section 4 and shall not allow any adjournment of the proceedings except when such`
  line `proceedings are interrupted or obstructed by riot or open violence or by causes beyond his control:`
  line
  line `Provided that in case an objection is raised by the Returning Officer or is made by any other person`
  line `the candidate concerned may be allowed time to rebut it not later than the next day but one following the`
  line `date fixed for scrutiny, and the Returning Officer shall record his decision on the date to which the`
  line `proceedings have been adjourned.`
  line
  line `(7) The Returning Officer shall endorse on each nomination paper his decision accepting or rejecting`
  line `the same and if the nomination paper is rejected, shall record in writing a brief statement of his reasons`
  line `for such rejection.`
  line
  line `(8) For the purposes of this section, a certified copy of an entry in the electoral roll for the time being`
  line `in force shall be conclusive evidence of the fact that the person referred to in that entry is an elector for`
  line `that constituency, unless it is proved that he is subject to any of the disqualifications mentioned in`
  line `section 16 of the Representation of the People Act, 1950 (43 of 1950).]`
obj_root_law_sections_6:
  sectionId (1074)
  sectionNo (6)
  orderNo 11
  title `Withdrawal of candidature.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1074&sectionno=6&orderno=11&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_6_content:
  string
  line `(1) Any candidate may withdraw his candidature by a notice in`
  line `writing in the prescribed form subscribed by him and delivered before three o'clock in the afternoon on`
  line `the date fixed under clause (c) of sub section (1) of section 4, to the Returning Officer either by such candidate in person or ^1[by any one of his proposers or seconders] who has been authorised in this behalf`
  line `in writing by such candidate.`
  line
  line `(2) No person who has given notice of withdrawal of his candidature under sub-section (1) shall be`
  line `allowed to cancel the notice.`
  line
  line `^2[(3) The Returning Officer shall, on being satisfied as to the genuineness of a notice of withdrawal`
  line `and the identity of the person delivering it under sub-section (1), cause the notice to be affixed in some`
  line `conspicuous place in his office.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 5 of 1974, s. 5, for "by his proposer or seconder".`
  line
  line `2. Subs. by s. 5, ibid., for sub-section (3).`
obj_root_law_sections_7:
  sectionId (1075)
  sectionNo (7)
  orderNo 12
  title `Death of candidate before poll.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1075&sectionno=7&orderno=12&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_7_content:
  string
  line `If a candidate, whose nomination has been made and is found`
  line `to be in order on scrutiny, dies after the time fixed for nomination and a report of his death is received by`
  line `the Returning Officer before the commencement of the poll, the Returning Officer shall, upon being`
  line `satisfied of the fact of the death of the candidate, countermand the poll and report the fact to the Election`
  line `Commission, and all proceedings with reference to the election shall be commenced a new in all respects`
  line `as if for a new election:`
  line
  line `Provided that no further nomination shall be necessary in the case of a candidate whose nomination`
  line `was valid at the time of the countermanding of the poll:`
  line
  line `Provided further that no person who has under sub-section (1) of section 6 given a notice of`
  line `withdrawal of his candidature before the countermanding of the poll shall be ineligible for being`
  line `nominated as a candidate for the election after such countermanding.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (1076)
  sectionNo (8)
  orderNo 13
  title `Procedure in contested and uncontested elections.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1076&sectionno=8&orderno=13&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_8_content:
  string
  line `If after the expiry of the period within`
  line `which candidatures may be withdrawn under sub-section (1) of section 6--`
  line
  line `(a) there is only one candidate who has been validly nominated and has not withdrawn his`
  line `candidature in the manner and within the time specified in that sub-section, the Returning Officer`
  line `shall forthwith declare such candidate to be duly elected to the office of President or Vice-President,`
  line `as the case may be;.`
  line
  line `(b) the number of candidates who have been duly nominated but have not so withdrawn their`
  line `candidatures exceeds one, the Returning Officer shall forthwith publish in such form and manner as`
  line `may be prescribed a list containing the names in alphabetical order and addresses of candidates as`
  line `given in the nomination papers, together with such other particulars as may be prescribed, and a poll`
  line `shall be taken;.`
  line
  line `(c) there is no candidate who has been duly nominated and has not so withdrawn his candidature,`
  line `the Returning Officer shall report the fact to the Election Commission and thereafter all the`
  line `proceedings in relation to the election shall be commenced afresh and for that purpose the Election`
  line `Commission shall cancel the notification issued under sub-section (1) of section 4 in respect of such`
  line `election and issue another notification under that sub-section appointing the dates referred to in that`
  line `sub-section for the purposes of such fresh election.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (1077)
  sectionNo (9)
  orderNo 14
  title `Manner of voting at elections.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1077&sectionno=9&orderno=14&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_9_content:
  string
  line `At every election where a poll is taken, votes shall be given by`
  line `ballot in such manner as may be prescribed, and no votes shall he received by proxy.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (1078)
  sectionNo (10)
  orderNo 15
  title `Counting of votes.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1078&sectionno=10&orderno=15&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_10_content:
  string
  line `At every election where a poll is taken, votes shall be counted by, or under`
  line `the supervision of, the Returning Officer, and each candidate and one representative of each candidate`
  line `authorised in writing by the candidate, shall have a right to be present at the time of counting.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (1079)
  sectionNo (11)
  orderNo 16
  title `Declaration of results.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1079&sectionno=11&orderno=16&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_11_content:
  string
  line `When the counting of the votes has been completed, the Returning`
  line `Officer shall forthwith declare the result of the election in the manner provided by this Act or the rules`
  line `made thereunder.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (1080)
  sectionNo (12)
  orderNo 17
  title `Report of the result.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1080&sectionno=12&orderno=17&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_12_content:
  string
  line `As soon as may be after the result of an election has been declared, the`
  line `Returning Officer shall report the result to the Central Government and the Election Commission, and the`
  line `Central Government shall cause to be published in the Official Gazette the declaration containing the`
  line `name of the person elected to the office of President or Vice-President, as the case may be.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (1081)
  sectionNo (13)
  orderNo 18
  title Definitions.
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1081&sectionno=13&orderno=18&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_13_content:
  string
  line `^1[13. Definitions.-- In this Part, unless the context otherwise requires,--`
  line
  line `(a) "candidate" means a person who has been or claims to have been duly nominated as a`
  line `candidate at an election;`
  line
  line `(b) "costs" means all costs, charges and expenses of, or incidental to, a trial of an election`
  line petition;
  line
  line `(c) "returned candidate" means a candidate whose name has been published under section 12 as`
  line `duly elected.]`
obj_root_law_sections_14:
  sectionId (1082)
  sectionNo (14)
  orderNo 19
  title `Authority to try election petitions.`
  content obj_root_law_sections_14_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1082&sectionno=14&orderno=19&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_14_content:
  string
  line `^1[14. Authority to try election petitions.-- (1) No election shall be called in question except by`
  line `presenting an election petition to the authority specified in sub-section (2).`
  line
  line `(2) The authority having jurisdiction to try an election petition shall be the Supreme Court.`
  line
  line `(3) Every election petition shall be presented to such authority in accordance with the provisions of`
  line `this Part and of the rules made by the Supreme Court under article 145.]`
obj_root_law_sections_14_a:
  sectionId (1083)
  sectionNo 14A
  orderNo 20
  title `Presentation of petition.`
  content obj_root_law_sections_14_a_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1083&sectionno=14A&orderno=20&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_14_a_content:
  string
  line `^1[14A. Presentation of petition0.-- (1) An election petition calling in question an election may be`
  line `presented on one or more of the grounds specified in sub-section (1) of section 18 and section 19, to the`
  line `Supreme Court by any candidate at such election or--`
  line
  line `(i) in the case of Presidential election, by twenty or more electors joined together as petitioners;`
  line
  line `(ii) in the case of Vice-Presidential election, by ten or more electors joined together as petitioners.`
  line
  line `(2) Any such petition may be presented at any time after the date of publication of the declaration`
  line `containing the name of the return candidate at the election under section 12, but not later than thirty days`
  line `from the date of such publication.]`
obj_root_law_sections_15:
  sectionId (1084)
  sectionNo (15)
  orderNo 21
  title `Form of petitions, etc., and procedure.`
  content obj_root_law_sections_15_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1084&sectionno=15&orderno=21&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_15_content:
  string
  line `^1[15. Form of petitions, etc., and procedure.-- Subject to the provisions of this Part, rules made`
  line `whether before or after the commencement of the Presidential and Vice-Presidential Elections`
  line `(Amendment) Act, 1977(20 of 1977) by the Supreme Court under Article 145 may regulate the form of`
  line `election petitions, the manner in which they are to be presented, the persons who are to be made parties`
  line `thereto, the procedure to be adopted in connection therewith and the circumstances in which petitions are`
  line `to abate, or may be withdrawn, and in which new petitioners may be substituted, and may require security`
  line `to be given for costs.]`
obj_root_law_sections_16:
  sectionId (1085)
  sectionNo (16)
  orderNo 22
  title `Relief that may be claimed by the petitioner.`
  content obj_root_law_sections_16_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1085&sectionno=16&orderno=22&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_16_content:
  string
  line `^1[16. Relief that may be claimed by the petitioner.-- A petitioner may claim either of the following`
  line `declarations:--`
  line
  line `(a) that the election of the returned candidate is void;`
  line
  line `(b) that the election of the returned candidate is void and that he himself or any other candidate`
  line `has been duly elected.]`
obj_root_law_sections_17:
  sectionId (1086)
  sectionNo (17)
  orderNo 23
  title `Orders of the Supreme Court.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1086&sectionno=17&orderno=23&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_17_content:
  string
  line `^1[17. Orders of the Supreme Court.-- (1) At the conclusion of the trial of the election petition, the`
  line `Supreme Court shall make an order--`
  line
  line `(a) dismissing the election petition; or`
  line
  line `(b) declaring the election of the returned candidate to be void; or`
  line
  line `(c) declaring the election of the returned candidate to be void and the petitioner or any other`
  line `candidate to have been duly elected.`
  line
  line `(2) At the time of making an order under sub-section (1), the Supreme Court shall also make an order`
  line `fixing the total amount of costs payable and specifying the persons by and to whom costs shall be paid.]`
obj_root_law_sections_18:
  sectionId (1087)
  sectionNo (18)
  orderNo 24
  title `Grounds for declaring the election of a returned candidate to be void.`
  content obj_root_law_sections_18_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1087&sectionno=18&orderno=24&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_18_content:
  string
  line `^1[18. Grounds for declaring the election of a returned candidate to be void.-- (1) If the Supreme`
  line `Court is of opinion,--`
  line
  line `(a) that the offence of bribery or undue influence at the election has been committed by the`
  line `returned candidate or by any person with the consent of the returned candidate; or`
  line
  line `(b) that the result of the election has been materially affected--`
  line
  line `(i) by the improper reception or refusal of a vote; under this Act; or`
  line
  line `(ii) by any non-compliance with the provisions of the Constitution or of this Act or of any`
  line `rules or orders made;`
  line
  line `(iii) by reason of the fact that the nomination of any candidate (other than the successful`
  line `candidate), who has not withdrawn his candidature, has been wrongly accepted; or`
  line
  line `(c) that the nomination of any candidate has been wrongly rejected or the nomination of the`
  line `successful candidate has been wrongly accepted;`
  line
  line `the Supreme Court shall declare the election of the returned candidate to be void.`
  line
  line `(2) For the purposes of this section, the offences of bribery and undue influence at an election have`
  line `the same meaning as in Chapter IXA of the Indian Penal Code (45 of 1860).]`
obj_root_law_sections_19:
  sectionId (1088)
  sectionNo (19)
  orderNo 25
  title `Grounds for which a candidate other than the returned candidate may he declared to have been elected.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1088&sectionno=19&orderno=25&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_19_content:
  string
  line `^1[19. Grounds for which a candidate other than the returned candidate may he declared to have`
  line `been elected.-- If any person who has lodged an election petition has, in addition to calling in question`
  line `the election of the returned candidate, claimed a declaration that he himself or any other candidate has`
  line `been duly elected and the Supreme Court is of opinion that in fact the petitioner or such other candidate`
  line `received a majority of the valid votes, the Supreme Court shall, after declaring the election of the returned`
  line `candidate to be void, declare the petitioner or such other candidate, as the case may be, to have been duly`
  line `elected:`
  line
  line `Provided that the petitioner or such other candidate shall not be declared to be duly elected if it is`
  line `proved that the election of such candidate would have been void if he had been the returned candidate and`
  line `a petition had been presented calling in question his election.]`
obj_root_law_sections_20:
  sectionId (1089)
  sectionNo (20)
  orderNo 26
  title `Transmission of orders to the Central Government and its publication`
  content obj_root_law_sections_20_content
  footnotes `1. Subs. by Act 20 of 1977, s. 2, for Part III.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1089&sectionno=20&orderno=26&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_20_content:
  string
  line `^1[20. Transmission of orders to the Central Government and its publication.--The Supreme Court`
  line `shall, after announcing the orders made under section 17, send a copy thereof to the Central Government,`
  line `and on receipt of such copy the Central Government shall forthwith cause the order to be published in the`
  line `Official Gazette.]`
obj_root_law_sections_20_a:
  sectionId (1090)
  sectionNo 20A
  orderNo 27
  title `Return or forfeiture of candidate‟s deposit.`
  content obj_root_law_sections_20_a_content
  footnotes `1. Ins. by Act 5 of 1974, s. 8 (w.e.f. 23-3-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1090&sectionno=20A&orderno=27&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_20_a_content:
  string
  line `^1[20A. Return or forfeiture of candidate's deposit.-- (1) The deposit made under section 5C shall`
  line `either be returned to the person making it or his legal representative or be forfeited to the Central`
  line `Government in accordance with the provisions of this section.`
  line
  line `(2) Except in cases hereafter mentioned in this section, the deposit shall be returned as soon as`
  line `practicable after the result of the election is declared.`
  line
  line `(3) If the candidate is not shown in the list referred to in clause (b) of section 8, or if he dies before`
  line `the commencement of the poll, the deposit shall be returned as soon as practicable after the publication of`
  line `the list or after his death, as the case may be.`
  line
  line `(4) Subject to the provisions of sub-section (3), the deposit shall be forfeited if at the election where`
  line `the poll has been taken, the candidate is not elected, and the number of valid votes polled by such`
  line `candidate does not exceed one-sixth of the number of votes necessary to secure the return of a candidate`
  line `at such election.]`
obj_root_law_sections_21:
  sectionId (1091)
  sectionNo (21)
  orderNo 28
  title `Power to make rules.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1091&sectionno=21&orderno=28&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_21_content:
  string
  line `(1) The Central Government may, after consulting the Election`
  line `Commission, by notification in the Official Gazette, make rulesfor carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the maintenance of a list of members of the electoral college referred to in article 54 with their`
  line `addresses corrected up to date for the purposes of Presidential elections;`
  line
  line `(b) the maintenance of a list of ^1[members of the electoral college referred to in article 66] with`
  line `their addresses corrected up to date for the purposes of Vice-Presidential elections;`
  line
  line `(c) the powers and duties of a Returning Officer and the performance by any officer appointed to`
  line `assist the Returning Officer of any function of the Returning Officer;`
  line
  line `^2[(cc) the form and manner in which public notice under section 5 shall be given by the Returning`
  line Officer.]
  line
  line `(d) the form and manner in which nominations may be made and the procedure to be followed in`
  line `respect of the presentation of nomination papers;`
  line
  line `(e) the scrutiny of nominations and, in particular, the manner in which such scrutiny shall be`
  line `conducted and the conditions and circumstances under which any person may be present or may enter`
  line `objections thereat;`
  line
  line `(f) the publication of a list of valid nominations;`
  line
  line `^3[(g) the place and hours of polling, the manner in with votes are to be given both generally and in`
  line `the case of illiterate voters or voters not conversant with the language in which ballot papers are`
  line `printed or voter under physical or other disability and the procedure as to voting to be followed at`
  line elections;]
  line
  line `(h) the scrutiny and counting of votes including cases in which a re-count of the votes may be`
  line `made before the declaration of the result of the election;`
  line
  line `(i) the safe custody of ballot boxes, ballot papers and other election papers, the period for which`
  line `such papers shall be preserved and the inspection and production of such papers;`
  line
  line `(j) any other matter required to be prescribed by this Act.`
  line
  line `^4[(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament while it is in session, for a total period of thirty days which may be comprised in one`
  line `session or in two or more successive sessions and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form, or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.]`
obj_root_law_sections_21_footnotes:
  string
  line `1. Subs. by s. 9, ibid., for "members of both Houses of Parliament".`
  line
  line `2. Ins. by s. 9, ibid.`
  line
  line `3. Subs. by s. 9, ibid., for clause (g).`
  line
  line `4. Ins. by Act 5 of 1974, s. 9.`
obj_root_law_sections_22:
  sectionId (1092)
  sectionNo (22)
  orderNo 29
  title `Maintenance of secrecy of voting.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1092&sectionno=22&orderno=29&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_22_content:
  string
  line `(1) Every officer, clerk or other person who performs any`
  line `duty in connection with the recording or counting of votes at an election shall maintain, and aid in`
  line `maintaining, the secrecy of the voting and shall not (except for some purpose authorised by or under any`
  line `law) communicate to any person any information calculated to violate such secrecy.`
  line
  line `(2) Any person who contravenes the provisions of sub-section (1) shall be punishable with`
  line `imprisonment for a term which may extend to three months, or with fine, or with both.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (1093)
  sectionNo (23)
  orderNo 30
  title `Jurisdiction of civil courts barred`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00036_195231_1517807328441&sectionId=1093&sectionno=23&orderno=30&orgactid=AC_CEN_3_20_00036_195231_1517807328441
obj_root_law_sections_23_content:
  string
  line `Save as provided in Part III, no Civil Court shall have`
  line `jurisdiction to question the legality of any action taken or of any decision given by the Returning Officer`
  line `or by any other person appointed under this Act in connection with an election.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
