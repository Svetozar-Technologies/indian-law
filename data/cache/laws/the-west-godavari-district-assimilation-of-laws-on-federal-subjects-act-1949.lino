obj_root_law_sections_1:
  object
  (str sectionId) (str 47671)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the West Godavari District
(Assimilation of Laws on Federal Subjects) Act, 1949.

(2) It shall come into force on such date^1
as the Central Government may, by notification in the
Official Gazette, appoint.`)
  (str footnotes) (str `1. 1st July, 1949, see Gazette of India, 1949, Extraordinary.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47671&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00041_194920_1517807323713)
obj_root_law_sections_2:
  object
  (str sectionId) (str 47672)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Interpretation.)
  (str content) (str `In this Act—

(a) "appointed day" means the date appointed under sub-section (2) of section 1 for the coming
into force of this Act;

(b) "Eluru Taluk" means the taluk of that name in the West Godavari district of the State of
Madras;

(c) "law" means any Act, Ordinance, Regulation, rule, order or bye-law, relating to any of the
matters enumerated in List I in the Seventh Schedule to the Government of India Act, 1935 (25 and
26 Geo. 5, c. 2); and

(d) "Scheduled area" means the area comprised in the villages which are specified in the
Schedule to this Act`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47672&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00041_194920_1517807323713)
obj_root_law_sections_3:
  object
  (str sectionId) (str 47673)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Assimilation of laws.`)
  (str content) (str `(1) All laws which immediately before the appointed day extend to, or are
in force in, the Eluru Taluk, but not in the scheduled area, shall, as from that day, extend to, or as the case
may be, come into force in, the scheduled area.

(2) All laws which immediately before the appointed day are in force in the scheduled area, but not in
the Eluru Taluk, shall on that day cease to be in force in the scheduled area, except as respects things done
or omitted to be done before that day.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47673&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00041_194920_1517807323713)
obj_root_law_sections_4:
  object
  (str sectionId) (str 47674)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Provision for removal of difficulties.`)
  (str content) (str `If any difficulty arises in relation to the transition from the
laws mentioned in sub-section (2) of section 3 to the laws mentioned in sub-section (1) thereof, the
Central Government may, by order notified in the Official Gazette, make such provision as it considers
necessary for the removal of such difficulty.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47674&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00041_194920_1517807323713)
