obj_root_law_sections_1:
  sectionId (47671)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 1st July, 1949, see Gazette of India, 1949, Extraordinary.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47671&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00041_194920_1517807323713
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the West Godavari District`
  line `(Assimilation of Laws on Federal Subjects) Act, 1949.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_2:
  sectionId (47672)
  sectionNo (2)
  orderNo 2
  title Interpretation.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47672&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00041_194920_1517807323713
obj_root_law_sections_2_content:
  string
  line `In this Act—`
  line
  line `(a) "appointed day" means the date appointed under sub-section (2) of section 1 for the coming`
  line `into force of this Act;`
  line
  line `(b) "Eluru Taluk" means the taluk of that name in the West Godavari district of the State of`
  line Madras;
  line
  line `(c) "law" means any Act, Ordinance, Regulation, rule, order or bye-law, relating to any of the`
  line `matters enumerated in List I in the Seventh Schedule to the Government of India Act, 1935 (25 and`
  line `26 Geo. 5, c. 2); and`
  line
  line `(d) "Scheduled area" means the area comprised in the villages which are specified in the`
  line `Schedule to this Act`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47673)
  sectionNo (3)
  orderNo 3
  title `Assimilation of laws.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47673&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00041_194920_1517807323713
obj_root_law_sections_3_content:
  string
  line `(1) All laws which immediately before the appointed day extend to, or are`
  line `in force in, the Eluru Taluk, but not in the scheduled area, shall, as from that day, extend to, or as the case`
  line `may be, come into force in, the scheduled area.`
  line
  line `(2) All laws which immediately before the appointed day are in force in the scheduled area, but not in`
  line `the Eluru Taluk, shall on that day cease to be in force in the scheduled area, except as respects things done`
  line `or omitted to be done before that day.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47674)
  sectionNo (4)
  orderNo 4
  title `Provision for removal of difficulties.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00041_194920_1517807323713&sectionId=47674&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00041_194920_1517807323713
obj_root_law_sections_4_content:
  string
  line `If any difficulty arises in relation to the transition from the`
  line `laws mentioned in sub-section (2) of section 3 to the laws mentioned in sub-section (1) thereof, the`
  line `Central Government may, by order notified in the Official Gazette, make such provision as it considers`
  line `necessary for the removal of such difficulty.`
obj_root_law_sections_4_footnotes:
  string
  line
