obj_root_law_sections_1:
  sectionId (72833)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72833&sectionno=1&orderno=1&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Women’s and Children’s`
  line `Institutions (Licensing) Act, 1956.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir.`
  line
  line `(3) It shall come into force in a State on such date as the State Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (72834)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72834&sectionno=2&orderno=2&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,―`
  line
  line `(a) “child” means a boy or girl who has not completed the age of eighteen years;`
  line
  line `(b) “institution” means an institution established and maintained for the reception, care,`
  line `protection and welfare of women or children;`
  line
  line `(c) “licensing authority” means the State Government or such officer or authority as may be`
  line prescribed;
  line
  line `(d) “prescribed” means prescribed by rules made by the State Government under this Act;`
  line
  line `(e) “woman” means a female who has completed the age of eighteen years.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (72835)
  sectionNo (3)
  orderNo 3
  title `Licensing of institutions.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72835&sectionno=3&orderno=3&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_3_content:
  string
  line `After the commencement of this Act, no person shall establish or`
  line `maintain an institution except under and in accordance with the conditions of a licence granted under this`
  line Act.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (72836)
  sectionNo (4)
  orderNo 4
  title `Application for licence.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72836&sectionno=4&orderno=4&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_4_content:
  string
  line `Every person desiring to establish an institution shall make an`
  line `application to the licensing authority in such form and containing such particulars as may be prescribed:`
  line
  line `Provided that a person maintaining an institution at the commencement of this Act shall be allowed a`
  line `period of three months from such commencement to make an application for a licence.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (72837)
  sectionNo (5)
  orderNo 5
  title `Grant of licence.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72837&sectionno=5&orderno=5&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_5_content:
  string
  line `(1) On receipt of an application under section 4, the licensing authority, after`
  line `making such inquiry as it considers necessary, shall, by order in writing, either grant thelicence or refuse`
  line `to grant it.`
  line
  line `(2) Where a licence is refused, the grounds for such refusal shall be communicated to the applicant in`
  line `the prescribed manner.`
  line
  line `(3) A licence, unless sooner revoked, shall remain in force for such period as may be specified in the`
  line `licence and may, on application made in this behalf sixty days before the date of its expiration, be`
  line `renewed for such period as the licensing authority may deem proper:`
  line
  line `Provided that a licence may be renewed on an application made within sixty days before the date of`
  line `its expiration if the licensing authority is satisfied that there was sufficient cause for not making the`
  line `application earlier.`
  line
  line `(4) Every licence granted under this Act shall be in the prescribed form and shall be subject to such`
  line `conditions as may be prescribed:`
  line
  line `Provided that any such condition may require that the management of an institution shall, wherever`
  line `practicable, be entrusted to women.`
  line
  line `(5) No fee shall be charged for the grant of a licence under this Act.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (72838)
  sectionNo (6)
  orderNo 6
  title `Licence not transferable.`
  content `A licence granted under this Act shall not be transferable.`
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72838&sectionno=6&orderno=6&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (72839)
  sectionNo (7)
  orderNo 7
  title `Revocation of licence.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72839&sectionno=7&orderno=7&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_7_content:
  string
  line `(1) Where any person to whom a licence has been granted under this Act,`
  line `or any agent or servant of such person commits a breach of any of the conditions thereof, or any of the`
  line `provisions of this Act, or any of the rules made thereunder, or where the licensing authority is not`
  line `satisfied with the condition, management or superintendence of an institution, the licensing authority may,`
  line `without prejudice to any other penalty which may have been incurred under this Act, for reasons to be`
  line `recorded, revoke the licence by order in writing:`
  line
  line `Provided that no such order shall be made until an opportunity is given to the holder of the licence to`
  line `show cause why the licence should not be revoked.`
  line
  line `(2) Where a licence in respect of an institution has been revoked under the foregoing sub-section,`
  line `such institution shall cease to function from the date of such revocation:`
  line
  line `Provided that where an appeal lies under section 8 against the order of revocation, such institution`
  line `shall cease to function―`
  line
  line `(a) where no such appeal has been preferred, immediately on the expiration of the period`
  line `prescribed for the filing of such appeal;`
  line
  line `(b) where such appeal has been preferred but the order of revocation has been upheld, from the`
  line `date of the appellate order.`
  line
  line `(3) On the revocation of a licence in respect of an institution, the licensing authority may direct that`
  line `any woman or child who is an inmate of such institution on the date of such revocation shall be―`
  line
  line `(a) restored to the custody of her or his parent, husband or lawful guardian, as the case may be; or`
  line
  line `(b) transferred to another institution.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (72840)
  sectionNo (8)
  orderNo 8
  title Appeals.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72840&sectionno=8&orderno=8&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_8_content:
  string
  line `(1) Where the licensing authority is other than the State Government, any person`
  line `aggrieved by an order of the licensing authority refusing to grant a licence or revoking a licence, may`
  line `within such period as may be prescribed, prefer an appeal to the State Government against such refusal or`
  line revocation.
  line
  line `(2) The order of the State Government on such appeal and subject only to such order, the order of the`
  line `licensing authority shall be final.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (72841)
  sectionNo (9)
  orderNo 9
  title Penalty.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72841&sectionno=9&orderno=9&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_9_content:
  string
  line `Any person who contravenes any of the provisions of this Act or of any rule made`
  line `thereunder, or any of the conditions of a licence shall be punishable with imprisonment for a term which`
  line `may extend to three months, or with fine which may extend to two hundred and fifty rupees, or with both.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (72842)
  sectionNo (10)
  orderNo 10
  title `Act not to apply to certain institutions.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72842&sectionno=10&orderno=10&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_10_content:
  string
  line `Nothing in this Act shall apply to―`
  line
  line `(a) hostels, or boarding houses attached to, or controlled or recognised by educational`
  line `institutions; or`
  line
  line `(b) any protective home established under the Suppression of Immoral Traffic in Women and`
  line `Girls Act, 1956 (104 of 1956).`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (72843)
  sectionNo (11)
  orderNo 11
  title `Power to make rules.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72843&sectionno=11&orderno=11&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_11_content:
  string
  line `(1) The State Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for--`
  line
  line `(a) the form of application for licence and the particulars to be contained therein;`
  line
  line `(b) the form of licence and the conditions subject to which such licence may be granted;`
  line
  line `(c) the management of institutions;`
  line
  line `(d) the reception, care, protection and welfare of women and children in institutions, including all`
  line `matters relating to their diet, clothing, accommodation, training and general conduct;`
  line
  line `(e) the inspection of institutions;`
  line
  line `(f) the maintenance of registers and account and submission of returns and audit of such accounts;`
  line
  line `(g) the discharge from institutions of women and children and their transfer from one institution`
  line `to another;`
  line
  line `(h) the manner of filing appeals under this Act and the time within which such appeals shall be`
  line filed;
  line
  line `(i) the manner of service of orders and notices Under this Act;`
  line
  line `(j) any other matter which is to be or may be prescribed.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (72844)
  sectionNo (12)
  orderNo 12
  title `Repeal and savings.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00014_1956105_1675763662048&sectionId=72844&sectionno=12&orderno=12&orgactid=AC_CEN_13_0_00014_1956105_1675763662048
obj_root_law_sections_12_content:
  string
  line `(1) As from the date of commencement in any State of this Act, any State`
  line `Act corresponding to this Act in force in that State immediately before such commencement shall stand`
  line repealed.
  line
  line `(2) Notwithstanding the repeal by this Act of any State Act referred to in sub-section (1), anything`
  line `done or any action taken (including any direction given, any register, rule or order made or any restriction`
  line `imposed) under the provisions of such State Act shall in so far as such thing or action is not inconsistent`
  line `with the provisions of this Act be deemed to have been done or taken under the provisions of this Act as if`
  line `the said provisions were in force when such thing was done or such action was taken and shall continue in`
  line `force accordingly until superseded by anything done or any action taken under this Act.`
  line
  line `Explanation.---In this section, the expression "State Act" includes a "Provincial Act".`
obj_root_law_sections_12_footnotes:
  string
  line
