obj_root_law_sections_1:
  sectionId (25666)
  sectionNo (1)
  orderNo 1
  title `Short title, extent, application and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25666&sectionno=1&orderno=1&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the`
  line `Maintenance and Welfare of Parents and Senior Citizens Act, 2007.`
  line
  line `(2) It extends to the whole of India ^1*** and it applies also it citizens of India outside India.`
  line
  line `(3) It shall come into force in a State on such date as the State Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule (w.e.f. 31-10-`
  line `2019).`
obj_root_law_sections_2:
  sectionId (25667)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25667&sectionno=2&orderno=2&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "children" includes son, daughter, grandson and grand-daughter but does not include a minor;`
  line
  line `(b) "maintenance" includes provisions for food, clothing, residence and medical attendance and`
  line treatment;
  line
  line `(c) "minor" means a person who, under the provisions of the Majority Act, 1875 (9 of 1875) is`
  line `deemed not to have attained the age of majority;`
  line
  line `(d) "parent" means father or mother whether biological, adoptive or step father or step mother, as`
  line `the case may be, whether or not the father or the mother is a senior citizen;`
  line
  line `(e) "prescribed" means prescribed by rules made by the State Government under this Act;`
  line
  line `(f) "property" means property of any kind, whether movable or immovable, ancestral or self`
  line `acquired, tangible or intangible and includes rights or interests in such property;`
  line
  line `(g) "relative" means any legal heir of the childless senior citizen who is not a minor and is in`
  line `possession of or would inherit his property after his death;`
  line
  line `(h) "senior citizen" means any person being a citizen of India, who has attained the age of sixty`
  line `years or above;`
  line
  line `(i) "State Government", relation to a Union territory, means the administrator thereof appointed`
  line `under article 239 of the Constitution;`
  line
  line `(j) "Tribunal' means the Maintenance Tribunal constituted under section 7;`
  line
  line `(k) "welfare" means provision for food, health care, recreation centres and other amenities`
  line `necessary for the senior citizens.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (25668)
  sectionNo (3)
  orderNo 3
  title `Act to have overriding effect.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25668&sectionno=3&orderno=3&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_3_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any enactment other than this Act, or in any instrument`
  line `having effect by virtue of any enactment other than this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (25669)
  sectionNo (4)
  orderNo 4
  title `Maintenance of parents and senior citizens.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25669&sectionno=4&orderno=4&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_4_content:
  string
  line `(1) A senior citizen including parent who is unable`
  line `to maintain himself from his own earning or out of the property owned by him, shall be entitled to make`
  line `an application under section 5 in case of--`
  line
  line `(i) parent or grand-parent, against one or more of his children not being a minor;`
  line
  line `(ii) a childless senior citizen, against such of his relative referred to in clause (g) of section 2.`
  line
  line `(2) The obligation of the children or relative, as the case may be, to maintain a senior citizen extends`
  line `to the needs of such citizen so that senior citizen may lead a normal life.`
  line
  line `(3) The obligation of the children to maintain his or her parent extends to the needs of such parent`
  line `either father or mother or both, as the case may be, so that such parent may lead a normal life.`
  line
  line `(4) Any person being a relative of a senior citizen and having sufficient means shall maintain such`
  line `senior citizen provided he is in possession of the property of such citizen or he would inherit the property`
  line `of such senior citizen:`
  line
  line `Provided that where more than one relatives are entitled to inherit the property of a senior citizen, the`
  line `maintenance shall be payable by such relative in the proportion in which they would inherit his property.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (25670)
  sectionNo (5)
  orderNo 5
  title `Application for maintenance.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25670&sectionno=5&orderno=5&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_5_content:
  string
  line `(1) An application for maintenance under section 4, may be`
  line made--
  line
  line `(a) by a senior citizen or a parent, as the case may be; or`
  line
  line `(b) if he is incapable, by any other person or organisation authorised by him; or`
  line
  line `(c) the Tribunal may take cognizance suo motu.`
  line
  line `Explanation.--For the purposes of this section "organisation" means any voluntary association`
  line `registered under the Societies Registration Act, 1860 (21 of 1860) or any other law for the time being in`
  line force.
  line
  line `(2) The Tribunal may, during the pendency of the proceeding regarding monthly allowance for the`
  line `maintenance under this section, order such children or relative to make a monthly allowance for the`
  line `interim maintenance of such senior citizen including parent and to pay the same to such senior citizen`
  line `including parent as the Tribunal may from time to time direct.`
  line
  line `(3) On receipt of an application for maintenance under subsection (1), after giving notice of the`
  line `application to the children or relative and after giving the parties an opportunity of being heard, hold an`
  line `inquiry for determining the amount of maintenance.`
  line
  line `(4) An application filed under sub-section (2) for the monthly allowance for the maintenance and`
  line `expenses for proceeding shall be disposed of within ninety days from the date of the service of notice of`
  line `the application to such person:`
  line
  line `Provided that the Tribunal may extend the said period, once for a maximum period of thirty days in`
  line `exceptional circumstances for reasons to be recorded in writing.`
  line
  line `(5) An application for maintenance under sub-section (1) may be filled against one or more persons:`
  line
  line `Provided that such children or relative may implead the other person liable to maintain parent in the`
  line `application for maintenance.`
  line
  line `(6) Where a maintenance order was made against more than one person, the death of one of them`
  line `does not affect the liability of others to continue paying maintenance.`
  line
  line `(7) Any such allowance for the maintenance and expenses for proceeding shall be payable from the`
  line `date of the order, or, if so ordered, from the date of the application for maintenance or expenses of`
  line `proceeding, as the case may be.`
  line
  line `(8) If, children or relative so ordered fail, without sufficient cause to comply with the order, any such`
  line `Tribunal may, for every breach of the order, issue a warrant for levying the amount due in the manner`
  line `provided for levying fines, and may sentence such person for the whole, or any part of each month's allowance for the maintenance and expenses of proceeding, as the case be, remaining unpaid after the`
  line `execution of the warrant, to imprisonment for a term which may extend to one month or until payment if`
  line `sooner made whichever is earlier:`
  line
  line `Provided that no warrant shall be issued for the recovery of any amount due under this section unless`
  line `application be made to the Tribunal to levy such amount within a period of three months from the date on`
  line `which it became due.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (25671)
  sectionNo (6)
  orderNo 6
  title `Jurisdiction and procedure.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25671&sectionno=6&orderno=6&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_6_content:
  string
  line `(1) The proceedings under section 5 may be taken against any`
  line `children or relative in any district--`
  line
  line `(a) where he resides or last resided; or`
  line
  line `(b) where children or relative resides.`
  line
  line `(2) On receipt of the application under section 5, the Tribunal shall issues a process for procuring the`
  line `presence of children or relative against whom the application is filed.`
  line
  line `(3) For securing the attendance of children or relative the Tribunal shall have the power of a Judicial`
  line `Magistrate of first class as provided under the Code of Criminal Procedure, 1973 (2 of 1974).`
  line
  line `(4) All evidence to such proceedings shall be taken in the presence of the children or relative against`
  line `whom an order for payment of maintenance is proposed to be made, and shall be recorded in the manner`
  line `prescribed for summons cases:`
  line
  line `Provided that if the Tribunal is satisfied that the children or relative against whom an order for`
  line `payment of maintenance is proposed to be made is willfully avoiding service, or willfully neglecting to`
  line `attend the Tribunal, the Tribunal may proceed to hear and determine the case ex parte.`
  line
  line `(5) Where the children or relative is residing out of India, the summons shall be served by the`
  line `Tribunal through such authority, as the Central Government may by notification in the official Gazette,`
  line `specify in this behalf.`
  line
  line `(6) The Tribunal before hearing an application under section 5 may, refer the same to a Conciliation`
  line `Officer and such Conciliation Officer shall submit his findings within one month and if amicable`
  line `settlement has been arrived at, the Tribunal shall pass an order to that effect.`
  line
  line `Explanation.--For the purposes of this sub-section "Conciliation Officer" means any person or`
  line `representative of an organisation referred to in Explanation to sub-section (1) of section 5 or the`
  line `Maintenance Officers designated by the State Government under sub-section (1) of section 18 or any`
  line `other person nominated by the Tribunal for this purpose.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (25672)
  sectionNo (7)
  orderNo 7
  title `Constitution of Maintenance Tribunal.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25672&sectionno=7&orderno=7&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_7_content:
  string
  line `(1) The State Government shall within a period of six`
  line `months from the date of the commencement of this Act, by notification in Official Gazette, constitute for`
  line `each Sub-division one or more Tribunals as may be specified in the notification for the purpose of`
  line `adjudicating and deciding upon the order for maintenance under section 5.`
  line
  line `(2) The Tribunal shall be presided over by an officer not below the rank of Sub- Divisional Officer of`
  line `a State.`
  line
  line `(3) Where two or more Tribunals are constituted for any area, the State Government may, by general`
  line `or special order, regulate the distribution of business among them.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (25673)
  sectionNo (8)
  orderNo 8
  title `Summary procedure in case of inquiry.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25673&sectionno=8&orderno=8&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_8_content:
  string
  line `(1) In holding any inquiry under section 5, the Tribunal`
  line `may, subject to any rules that may be prescribed by the State Government in this behalf, follow such`
  line `summary procedure as it deems fit.`
  line
  line `(2) The Tribunal shall have all the powers of a Civil Court for the purpose of taking evidence on oath`
  line `and of enforcing the attendance of witnesses and of compelling the discovery and production of`
  line `documents and material objects and for such other purposes as may be prescribed; and the Tribunal shall`
  line `be deemed to be a Civil Court for all the purposes of section 195 and Chapter XXVI of the Code of`
  line `Criminal Procedure, 1973 (2 of 1974).`
  line
  line `(3) Subject to any rule that may be made in this behalf, the Tribunal may, for the purpose of`
  line `adjudicating and deciding upon any claim for maintenance, choose one or more persons possessing`
  line `special knowledge of any matter relevant to the inquiry to assist it in holding the inquiry.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (25674)
  sectionNo (9)
  orderNo 9
  title `Order for maintenance.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25674&sectionno=9&orderno=9&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_9_content:
  string
  line `(1) If children or relatives, as the case may be, neglect or refuse to`
  line `maintain a senior citizen being unable to maintain himself, the Tribunal may, on being satisfied of such`
  line `neglect or refusal, order such children or relatives to make a monthly allowance at such monthly rate for`
  line `the maintenance of such senior citizen, as the Tribunal may deem fit and to pay the same to such senior`
  line `citizen as the Tribunal may, from time to time, direct.`
  line
  line `(2) The maximum maintenance allowance which may be ordered by such Tribunal shall be such as`
  line `may be prescribed by the State Government which shall not exceed ten thousand rupees per month.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (25675)
  sectionNo (10)
  orderNo 10
  title `Alteration in allowance.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25675&sectionno=10&orderno=10&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_10_content:
  string
  line `(1) On proof of misrepresentation or mistake of fact or a change in the`
  line `circumstances of any person, receiving a monthly allowance under section 9, for the maintenance ordered`
  line `under that section to pay a monthly allowance for the maintenance, the Tribunal may make such`
  line `alteration, as it thinks fit, in the allowance for the maintenance.`
  line
  line `(2) Where it appears to the Tribunal that, in consequence of any decision of a competent Civil Court,`
  line `any order made under section 9 should be cancelled or varied, it shall cancel the order or, as the case may`
  line `be, vary the same accordingly.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (25676)
  sectionNo (11)
  orderNo 11
  title `Enforcement of order of maintenance.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25676&sectionno=11&orderno=11&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_11_content:
  string
  line `(1) A copy of the order of maintenance and including`
  line `the order regarding expenses of proceedings, as the case may be, shall be given without payment of any`
  line `fee to the senior citizen or to parent, as the case may be, in whose favour it is made and such order may`
  line `be enforced by any Tribunal in any place where the person against whom it is made, such Tribunal on`
  line `being satisfied as to the identity of the parties and the non-payment of the allowance, or as the case may`
  line `be, expenses, due.`
  line
  line `(2) A maintenance order made under this Act shall have the same force and effect as an order passed`
  line `under Chapter IX of the Code of Criminal Procedure, 1973 (2 of 1974) and shall be executed in the`
  line `manner prescribed for the execution of such order by that Code.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (25677)
  sectionNo (12)
  orderNo 12
  title `Option regarding maintenance in certain cases.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25677&sectionno=12&orderno=12&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_12_content:
  string
  line `Notwithstanding anything contained in`
  line `Chapter IX of the Code of Criminal Procedure 1973 (2 of 1974) where a senior citizen or a parent is`
  line `entitled for maintenance under the said Chapter and also entitled for maintenance under this Act may,`
  line `without prejudice to the provisions of Chapter IX of the said Code, claim such maintenance under either`
  line `of those Acts but not under both.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (25678)
  sectionNo (13)
  orderNo 13
  title `Deposit of maintenance amount.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25678&sectionno=13&orderno=13&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_13_content:
  string
  line `When an order is made under this Chapter, the children or`
  line `relative who is required to pay any amount in terms of such order shall within thirty days of the date of`
  line `announcing the order by the Tribunal, deposit the entire amount ordered in such manner as the Tribunal`
  line `may direct.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (25679)
  sectionNo (14)
  orderNo 14
  title `Award of interest where any claim is allowed.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25679&sectionno=14&orderno=14&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_14_content:
  string
  line `Where any Tribunal makes an order for`
  line `maintenance made under this Act, such Tribunal may direct that in addition to the amount of`
  line `maintenance, simple interest shall also be paid at such rate and from such date not earlier than the date of`
  line `making the application as may be determined by the Tribunal which shall not be less than five per cent.`
  line `and not more than eighteen per cent.:`
  line
  line `Provided that where any application for maintenance under Chapter IX of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974) is pending before a Court at the commencement of this Act, then the Court`
  line `shall allow the withdrawal of such application on the request of the parent and such parent shall be`
  line `entitled to file an application for maintenance before the Tribunal.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (25680)
  sectionNo (15)
  orderNo 15
  title `Constitution of Appellate Tribunal.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25680&sectionno=15&orderno=15&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_15_content:
  string
  line `(1)The State Government may, by notification in the`
  line `Official Gazette, constitute one Appellate Tribunal for each district to hear the appeal against the order of`
  line `the Tribunal.`
  line
  line `(2) The Appellate Tribunal shall be presided over by an officer not below the rank of District`
  line Magistrate.
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (25681)
  sectionNo (16)
  orderNo 16
  title Appeals.
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25681&sectionno=16&orderno=16&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_16_content:
  string
  line `(1) Any senior citizen or a parent, as the case may be, aggrieved by an order of a`
  line `Tribunal may, within sixty days from the date of the order, prefer an appeal to the Appellate Tribunal:`
  line
  line `Provided that on appeal, the children or relative who is required to pay any amount in terms of such`
  line `maintenance order shall continue to pay to such parent the amount so ordered, in the manner directed by`
  line `the Appellate Tribunal:`
  line
  line `Provided further that the Appellate Tribunal may, entertain the appeal after the expiry of the said`
  line `period of sixty days, if it is satisfied that the appellant was prevented by sufficient cause from preferring`
  line `the appeal in time.`
  line
  line `(2) On receipt of an appeal, the Appellate Tribunal shall, cause a notice to be served upon the`
  line respondent.
  line
  line `(3) The Appellate Tribunal may call for the record of proceedings from the Tribunal against whose`
  line `order the appeal is preferred.`
  line
  line `(4) The Appellate Tribunal may, after examining the appeal and the records called for either allow or`
  line `reject the appeal.`
  line
  line `(5) The Appellate Tribunal shall, adjudicate and decide upon the appeal filed against the order of the`
  line `Tribunal and the order of the Appellate Tribunal shall be final:`
  line
  line `Provided that no appeal shall be rejected unless an opportunity has been given to both the parties of`
  line `being heard in person or through a dully authorised representative.`
  line
  line `(6) The Appellate Tribunal shall make an endeavour to pronounce its order in writing within one`
  line `month of the receipt of an appeal.`
  line
  line `(7) A copy of every order made under sub-section (5) shall be sent to both the parties free of cost.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (25682)
  sectionNo (17)
  orderNo 17
  title `Right to legal representation.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25682&sectionno=17&orderno=17&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_17_content:
  string
  line `Notwithstanding anything contained in any law, no party to a`
  line `proceeding before a Tribunal or Appellate Tribunal shall be represented by a legal practitioner.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (25683)
  sectionNo (18)
  orderNo 18
  title `Maintenance Officer.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25683&sectionno=18&orderno=18&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_18_content:
  string
  line `(1) The State Government shall designate the District Social Welfare or`
  line `an officer not below the rank of a District Social Welfare Officer, by whatever name called as`
  line `Maintenance Officer.`
  line
  line `(2) The Maintenance Officer referred to in sub-section (1), shall represent a parent if he so desires,`
  line `during the proceedings of the Tribunal, or the Appellate Tribunal, as the case may be.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (25684)
  sectionNo (19)
  orderNo 19
  title `Establishment of oldage homes.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25684&sectionno=19&orderno=19&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_19_content:
  string
  line `(1) The State Government may establish and maintain such`
  line `number of oldage homes at accessible places, as it may deem necessary, in a phased manner, beginning`
  line `with at least one in each district to accommodate in such homes a minimum of one hundred fifty senior`
  line `citizens who are indigent.`
  line
  line `(2) The State Government may, prescribe a scheme for management of old age homes, including the`
  line `standards and various types of services to be provided by them which are necessary for medical care and`
  line `means of entertainment to the inhabitants of such homes.`
  line
  line `Explanation.--For the purposes of this section, "indigent" means any senior citizen who is not having`
  line `sufficient means, as determined by the State Government, from time to time, to maintain himself.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (25685)
  sectionNo (20)
  orderNo 20
  title `Medical support for senior citizens.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25685&sectionno=20&orderno=20&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_20_content:
  string
  line `The State Government shall ensure that,--`
  line
  line `(i) the Government hospitals or hospitals funded fully or partially by the Government shall`
  line `provide beds for all senior citizens as far as possible;`
  line
  line `(ii) separate queues be arranged for senior citizens;`
  line
  line `(iii) facility for treatment of chronic, terminal and degenerative diseases is expanded for senior`
  line citizens;
  line
  line `(iv) research activities for chronic elderly diseases and ageing expanded;`
  line
  line `(v) there are earmarked facilities for geriatric patients in every district hospital dully headed by a`
  line `medical officer with experience in geriatric care.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (25686)
  sectionNo (21)
  orderNo 21
  title `Measures for publicity, awareness, etc., for welfare of senior citizens.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25686&sectionno=21&orderno=21&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_21_content:
  string
  line `The State`
  line `Government shall, take all measures to ensure that--`
  line
  line `(i) the provisions of this Act are given wide publicity through public media including the`
  line `television, radio and the print, at regular intervals;`
  line
  line `(ii) the Central Government and State Government Officers, including the police officers and the`
  line `members of the judicial service, are given periodic sensitization and awareness training on the issues`
  line `relating to this Act;`
  line
  line `(iii) effective co-ordination between the services provided by the concerned Ministries or`
  line `Departments dealing with law, home affairs, health and welfare, to address the issues relating to the`
  line `welfare of the senior citizens and periodical review of the same is conducted.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (25687)
  sectionNo (22)
  orderNo 22
  title `Authorities who may be specified for implementing the provisions of this Act.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25687&sectionno=22&orderno=22&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_22_content:
  string
  line `(1) The State`
  line `Government may, confer such powers and impose such duties on a District Magistrate as may be`
  line `necessary, to ensure that the provisions of this Act are properly carried out and the District Magistrate`
  line `may specify the officer, subordinate to him, who shall exercise all or any of the powers, and perform all`
  line `or any of the duties, so conferred or imposed and the local limits within which such powers or duties shall`
  line `be carried out by the officer as may be prescribed.`
  line
  line `(2) The State Government shall prescribe a comprehensive action plan for providing protection of life`
  line `and property of senior citizens.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (25688)
  sectionNo (23)
  orderNo 23
  title `Transfer of property to be void in certain circumstances.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25688&sectionno=23&orderno=23&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_23_content:
  string
  line `(1) Where any senior citizen who,`
  line `after the commencement of this Act, has transferred by way of gift or otherwise, his property, subject to`
  line `the condition that the transferee shall provide the basic amenities and basic physical needs to the`
  line `transferor and such transferee refuses or fails to provide such amenities and physical needs, the said`
  line `transfer of property shall be deemed to have been made by fraud or coercion or under undue influence`
  line `and shall at the option of the transferor be declared void by the Tribunal.`
  line
  line `(2) Where any senior citizen has a right to receive maintenance out of an estate and such estate or part`
  line `thereof is transferred, the right to receive maintenance may be enforced against the transferee if the`
  line `transferee has notice of the right, or if the transfer is gratuitous; but not against the transferee for`
  line `consideration and without notice of right.`
  line
  line `(3) If, any senior citizen is incapable of enforcing the rights under sub-sections (1) and (2), action`
  line `may be taken on his behalf by any of the organisation referred to in Explanation to sub-section (1) of`
  line `section 5.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (25689)
  sectionNo (24)
  orderNo 24
  title `Exposure and abandonment of senior citizen.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25689&sectionno=24&orderno=24&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_24_content:
  string
  line `Whoever, having the care or protection of`
  line `senior citizen leaves, such senior citizen in any place with the intention of wholly abandoning such senior`
  line `citizen, shall be punishable with imprisonment of either description for a term which may extend to three`
  line `months or fine which may extend to five thousands rupees or with both.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (25690)
  sectionNo (25)
  orderNo 25
  title `Cognizance of offences.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25690&sectionno=25&orderno=25&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_25_content:
  string
  line `(1) Notwithstanding anything contained in the Code of Criminal`
  line `Procedure, 1973 (2 of 1974), every offence under this Act shall be cognizable and bailable.`
  line
  line `(2) An offence under this Act shall be tried summarily by a Magistrate.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (25691)
  sectionNo (26)
  orderNo 26
  title `Officers to be public servants.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25691&sectionno=26&orderno=26&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_26_content:
  string
  line `Every officer or staff appointed to exercise functions under this`
  line `Act shall be deemed to be a public servant within the meaning of section 21 of the Indian Penal Code(45`
  line `of 1860).`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (25692)
  sectionNo (27)
  orderNo 27
  title `Jurisdiction of civil courts barred.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25692&sectionno=27&orderno=27&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_27_content:
  string
  line `No Civil Court shall have jurisdiction in respect of any`
  line `matter to which any provision of this Act applies and no injunction shall be granted by any Civil Court in`
  line `respect of anything which is done or intended to be done by or under this Act.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (25693)
  sectionNo (28)
  orderNo 28
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25693&sectionno=28&orderno=28&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_28_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government, the State Governments or the local authority or any officer of the`
  line `Government in respect of anything which is done in good faith or intended to be done in pursuance of this`
  line `Act and any rules or orders made thereunder.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (25694)
  sectionNo (29)
  orderNo 29
  title `Power to remove difficulties.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25694&sectionno=29&orderno=29&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_29_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the State Government may, by order published in the Official Gazette, make such provisions not`
  line `inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of two years from the date of`
  line `the commencement of this Act.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (25695)
  sectionNo (30)
  orderNo 30
  title `Power of Central Government to give directions.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25695&sectionno=30&orderno=30&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_30_content:
  string
  line `The Central Government may give`
  line `directions to State Governments as to the carrying into execution of the provisions of this Act.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (25696)
  sectionNo (31)
  orderNo 31
  title `Power of Central Government to review.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25696&sectionno=31&orderno=31&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_31_content:
  string
  line `The Central Government may make periodic review`
  line `and monitor the progress of the implementation of the provisions of this Act by the State Governments.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (25697)
  sectionNo (32)
  orderNo 32
  title `Power of State Government to make rules.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_25_35_00007_200756_1517807326382&sectionId=25697&sectionno=32&orderno=32&orgactid=AC_CEN_25_35_00007_200756_1517807326382
obj_root_law_sections_32_content:
  string
  line `(1) The State Government may, by notification in`
  line `the Official Gazette, make rules for carrying out the purposes of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may provide for--`
  line
  line `(a) the manner of holding inquiry under section 5 subject to such rules as may be prescribed`
  line `under sub-section (1) of section 8;`
  line
  line `(b) the power and procedure of the Tribunal for other purposes under sub-section (2) of section 8;`
  line
  line `(c) the maximum maintenance allowance which may be ordered by the Tribunal under subsection`
  line `(2) of section 9;`
  line
  line `(d) the scheme for management of old age homes, including the standards and various types of`
  line `services to be provided by them which are necessary for medical care and means of entertainment to`
  line `the inhabitants of such homes under sub-section (2) of section 19;`
  line
  line `(e) the powers and duties of the authorities for implementing the provisions of this Act, under`
  line `sub-section (1) of section 22;`
  line
  line `(f) a comprehensive action plan for providing protection of life and property of senior citizens`
  line `under sub-section (2) of section 22;`
  line
  line `(g) any other matter which is to be, or may be, prescribed.`
  line
  line `(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each`
  line `House of State Legislature, where it consists of two Houses or where such legislature consists of one`
  line `House, before that House.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `माता-पिता और वरिष्ठौ नागरिकों का भरणपोषण तथा कल्यांण अधिनियम, 2007`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/2033/3/H2007-56.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T09:51:48.867Z`
  pageCount 9
  sections obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
  obj_root_law_translations_hi_sections_3
  obj_root_law_translations_hi_sections_4
  obj_root_law_translations_hi_sections_5
  obj_root_law_translations_hi_sections_6
