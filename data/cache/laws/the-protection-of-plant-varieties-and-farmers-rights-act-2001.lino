  (str actNumber) (str 53)
  (str enactmentDate) (str 2001-10-30)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1909`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `पौधा किस्‍म और कृषक अधिकार संरक्षणअधिनियम, 2001`)
  (str actYear) (str 2001)
  (str ministry) (str `Ministry of Agriculture and Farmers Welfare`)
  (str department) (str `Department of Agriculture, Cooperation and Farmers Welfare`)
  (str longTitle) (str `An Act to provide for the establishment of an effective system for protection of plant varieties, the rights of farmers and plant breeders and to encourage the development of new varieties of plants.`)
