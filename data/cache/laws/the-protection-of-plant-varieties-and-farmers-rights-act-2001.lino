obj_root_law_sections_97:
  sectionId (1925)
  sectionNo (97)
  orderNo 97
  title `Rules, regulations and schemes to be laid before Parliament.`
  content obj_root_law_sections_97_content
  footnotes obj_root_law_sections_97_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_31_00002_200153_1517807322692&sectionId=1925&sectionno=97&orderno=97&orgactid=AC_CEN_23_31_00002_200153_1517807322692
obj_root_law_sections_97_content:
  string
  line `Every rule and every regulation`
  line `and every scheme made under this Act shall be laid, as soon as may be after it is made, before each House`
  line `of Parliament, while it is in session, for a total period of thirty days which may be comprised in one`
  line `session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or regulation or scheme or both Houses agree that the rule or regulation or scheme should not`
  line `be made, the rule or regulation or scheme shall thereafter have effect only in such modified form or be of`
  line `no effect, as the case may be; so, however, that any such modification or annulment shall be without`
  line `prejudice to the validity of anything previously done under that rule or regulation or scheme.`
obj_root_law_sections_97_footnotes:
  string
  line
