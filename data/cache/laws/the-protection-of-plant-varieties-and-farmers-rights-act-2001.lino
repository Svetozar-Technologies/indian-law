  slug the-protection-of-plant-varieties-and-farmers-rights-act-2001
  handle (1909)
  collectionHandle 123456789/1362
  title `The Protection of Plant Varieties and Farmers Rights Act, 2001`
  actNumber (53)
  enactmentDate 2001-10-30
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1909`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `पौधा किस्‍म और कृषक अधिकार संरक्षणअधिनियम, 2001`
  actYear (2001)
  ministry `Ministry of Agriculture and Farmers Welfare`
  department `Department of Agriculture, Cooperation and Farmers Welfare`
  longTitle `An Act to provide for the establishment of an effective system for protection of plant varieties, the rights of farmers and plant breeders and to encourage the development of new varieties of plants.`
  enforcementDate 11-11-2005
