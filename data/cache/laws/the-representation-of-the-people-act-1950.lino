  (str slug) (str the-representation-of-the-people-act-1950)
  (str handle) (str 1663)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Representation of the People Act, 1950`)
  (str actNumber) (str 43)
  (str enactmentDate) (str 1950-05-12)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1663`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `लोकप्रतिनिधित्वअधिनियम, 1950`)
  (str actYear) (str 1950)
  (str ministry) (str `Ministry of Law and Justice`)
  (str department) (str `Legislative Department`)
  (str longTitle) (str `An Act to provide the allocation of seats in, and the delimitation of constituencies for the purpose of election to, the House of the People and the Legislatures of States, the qualifications of voters at such elections, the preparation of electoral rolls, the manner of filling seats in the Council of States to be filled by representatives of Union territories, and matters connected therewith.`)
  (str enforcementDate) (str 12-05-1950)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T11:58:11.632Z`)
  (str translations) obj_root_law_translations
