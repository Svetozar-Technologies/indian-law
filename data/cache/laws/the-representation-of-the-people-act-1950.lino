obj_root_law_sections_3_a_content:
  string
  line `3A. Reservation of Seats in the House of People for Scheduled Castes and Scheduled Tribes`
  line `in certain Part C States.---[Rep. by the Representation of the People Amendment) Act, 1958`
  line `(58 of 1958), s. 3 (w.e.f. 30-12-1958).]]`
obj_root_law_sections_4:
  sectionId (1097)
  sectionNo (4)
  orderNo 5
  title `Filling of seats in the House of the People and Parliamentary constituencies.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00016_195043_1517807321506&sectionId=1097&sectionno=4&orderno=5&orgactid=AC_CEN_3_20_00016_195043_1517807321506
obj_root_law_sections_4_content:
  string
  line `^1[4. Filling of seats in the House of the People and parliamentary constituencies. -- ^2***`
  line
  line `^3[(2) All the seats in the House of the People allotted to the States under section 3 shall be seats to`
  line `be filled by persons chosen by direct election from parliamentary constituencies in the States.]`
  line
  line `(3) Every parliamentary constituency referred to in sub-section (2) shall be a single-member`
  line constituency.
  line
  line `(4) Every State to which only one seat is allotted under section 3 shall form one parliamentary`
  line constituency.
  line
  line `^4[(5) Save as provided in sub-section (4), the extent of all parliamentary constituencies except the`
  line `parliamentary constituencies in the States of Arunachal Pradesh, Assam, Jharkhand, Manipur and`
  line `Nagaland shall be as determined by the orders of the Delimitation Commission made under the`
  line `provisions of the Delimitation Act, 2002 (33 of 2002) and the extent of the parliamentary`
  line `constituencies in the States of Arunachal Pradesh, Assam, Jharkhand, Manipur and Nagaland shall be`
  line `as provided for in the Delimitation of Parliamentary and Assembly Constituencies Order, 2008 having`
  line `regard to the provisions of sections 10A and 10B of the Delimitation Act, 2002.]]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 47 of 1966, s. 2, for sections 3 and 4 (w.e.f. 14-12-1966).`
  line
  line `2. Omitted by Act 29 of 1975, s. 11 (w.e.f. 15-8-1975).`
  line
  line `3. Subs. by s. 11, ibid., for sub-section (2) (w.e.f. 15-8-1975).`
  line
  line `4. Subs. by Act 10 of 2008, s. 2, for sub-section (5) (w.e.f. 16-4-2008).`
