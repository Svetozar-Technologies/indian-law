obj_root_law_sections_27_g:
  sectionId (1139)
  sectionNo 27G
  orderNo 47
  title `Termination of membership of electoral college for certain disqualifications.`
  content obj_root_law_sections_27_g_content
  footnotes obj_root_law_sections_27_g_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00016_195043_1517807321506&sectionId=1139&sectionno=27G&orderno=47&orgactid=AC_CEN_3_20_00016_195043_1517807321506
obj_root_law_sections_27_g_content:
  string
  line `If a`
  line `person who is a member of an electoral college becomes subject to any disqualification for`
  line `membership of Parliament under the provisions of any law relating to corrupt and illegal practices`
  line `and other offences in connection with elections to Parliament, he shall thereupon cease to be such`
  line `member of the electoral college.`
obj_root_law_sections_27_g_footnotes:
  string
  line
obj_root_law_sections_27_h:
  sectionId (1140)
  sectionNo 27H
  orderNo 48
  title `Manner of filling of seats in the Council of States allotted to Union territories.`
  content obj_root_law_sections_27_h_content
  footnotes obj_root_law_sections_27_h_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00016_195043_1517807321506&sectionId=1140&sectionno=27H&orderno=48&orgactid=AC_CEN_3_20_00016_195043_1517807321506
obj_root_law_sections_27_h_content:
  string
  line `^1* * *The seat or seats in the Council of States allotted to any ^2`
  line `[Union territory] ^3* * * in the Fourth`
  line `Schedule to the Constitution shall be filled by a person or persons elected by the members of the electoral college for ^4[that territory] ^5* * * in accordance with the system of proportional representation by means of the single transferable vote:`
  line
  line `^6[Provided that the person who immediately before the commencement of the Constitution`
  line `(Seventh Amendment) Act, 1956, is filling the seat allotted to the Part C States of Manipur and Tripura shall, as from such commencement, be deemed to have been duly elected to fill the seat allotted to the Union territory of Tripura.]`
obj_root_law_sections_27_h_footnotes:
  string
  line `1. Certain words omitted by the Adaptation of Laws (No. 2) Order, 1956.`
  line
  line `2. Subs., ibid., for "Part C State".`
  line
  line `3. The words "or group of such States" omitted, ibid.`
  line
  line `4. Subs., ibid., for "such State".`
  line
  line `5. The words "or group of States" omitted by Act 2 of 1956, s. 23.`
  line
  line `6. Ins. by the Adaptation of Laws (No. 2) Order, 1956.`
