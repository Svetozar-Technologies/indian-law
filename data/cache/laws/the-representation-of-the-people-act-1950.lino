  sectionId (1095)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00016_195043_1517807321506&sectionId=1095&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00016_195043_1517807321506
obj_root_law_sections_2_content:
  string
  line `^1*** In this Act, unless the context otherwise requires,--`
  line
  line `(a) "article" means an article of the Constitution;`
  line
  line `(b) "Assembly constituency" means a constituency provided ^2[by law] for the purpose of`
  line `elections to the Legislative Assembly of a State;`
  line
  line `(c) "Council constituency" means a constituency provided ^3[by law] for the purpose of`
  line `elections to the Legislative Council of a State;`
  line
  line `^4* * * *`
  line
  line `(d) "Election Commission" means the Election Commission appointed by the President under`
  line `article 324;`
  line
  line `(e) "order" means an order published in the Official Gazette;`
  line
  line `(f) "Parliamentary constituency" means a constituency provided ^5[by law for the purpose of`
  line `elections to the House of the People;`
  line
  line `^6* * * *`
  line
  line `(g) "person" does not include a body of persons;`
  line
  line `(h) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^7[(i) "State" includes a Union territory;]`
  line
  line `(j) "State Government", in relation to a Union territory, means the administrator thereof.`
  line
  line `^8* * * * *`
obj_root_law_sections_2_footnotes:
  string
  line `1. The brackets and figure "(1)" omitted by Act 103 of 1956, s. 65 (w.e.f. 1-1-1957).`
  line
  line `2. Subs. by Act 2 of 1956, s. 2, for "by order made under section 9" (w.e.f. 1-3-1956).`
  line
  line `3. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "by order made under section 11" (w.e.f.1-11-1956).`
  line
  line `4. Omitted by Act 103 of 1956, s. 65 (1-1-1957).`
  line
  line `5. Subs. by Act 2 of 1956, s. 2, for "by section 6 or by order made thereunder" (1-3-1956).`
  line
  line `6. Omitted by the North-Eastern Areas (Reorganisation) (Adaptation of Laws on Union Subjects) Order, 1974, s. 3 and the`
  line `Schedule (w.e.f. 21-1-1972).`
  line
  line `7. Subs. by s. 3 and the Schedule, ibid., for clause (i) (w.e.f. 21-1-1972).`
  line
  line `8. Omitted by the Adaptation of Laws (No. 2) Order, 1956 (w.e.f. 1-11-1956).`
