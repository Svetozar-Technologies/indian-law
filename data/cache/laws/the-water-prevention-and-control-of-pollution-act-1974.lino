  string
  line
obj_root_law_sections_45_a:
  sectionId (4137)
  sectionNo 45A
  orderNo 52
  title `Penalty for contravention of certain provisions of the Act.`
  content obj_root_law_sections_45_a_content
  footnotes `1. Subs. by Act 5 of 2024, s. 10, for section 45A (w.e.f. 15-2-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4137&sectionno=45A&orderno=52&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_45_a_content:
  string
  line `^1[45A. Penalty for contravention of certain provisions of the Act.-- If any person contravenes any of`
  line `the provisions of this Act or any order or direction issued thereunder, for which no penalty has been`
  line `provided for in this Act, shall be liable to pay the penalty which shall not be less than ten thousand rupees,`
  line `but which may extend to fifteen lakh rupees, and where such contravention continues, he shall be liable to`
  line `pay an additional penalty which may extend to ten thousand rupees for every day during which such`
  line `contravention continues.]`
obj_root_law_sections_45_b:
  sectionId (83515)
  sectionNo 45B
  orderNo 53
  title `Adjudicating officer.`
  content obj_root_law_sections_45_b_content
  footnotes `1. Subs. by Act 5 of 2024, s. 10, for section 45A (w.e.f. 15-2-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=83515&sectionno=45B&orderno=53&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_45_b_content:
  string
  line `^1[45B. Adjudicating officer.(1) The Central Government, for the purposes of determining the`
  line `penalties under the provisions of this Act shall appoint an officer not below the rank of Joint Secretary to`
  line `the Government of India or a Secretary to the State Government to be the adjudicating officer, to hold an`
  line `inquiry and to impose the penalty in the manner, as may be prescribed:`
  line
  line `Provided that the Central Government may appoint as many adjudicating officers as may be required.`
  line
  line `(2) The adjudicating officer may summon and enforce the attendance of any person acquainted with`
  line `the facts and circumstances of the case to give evidence or to produce any document, which in the opinion`
  line `of the adjudicating officer, may be useful for or relevant to the subject-matter of the inquiry and if, on such`
  line `inquiry, he is satisfied that the person concerned has contravened the provisions of this Act, he may`
  line `determine such penalty as he thinks fit under the provisions of this Act:`
  line
  line `Provided that no such penalty shall be imposed without giving the person concerned an opportunity of`
  line `being heard in the matter.`
  line
  line `(3) The amount of penalty imposed under the provisions of sections 41, 41A, 42, 43, 44, 45A and 48,`
  line `shall be in addition to the liability to pay relief or compensation under section 15 read with section 17 of`
  line `the National Green Tribunal Act, 2010 (19 of 2010).]`
obj_root_law_sections_45_c:
  sectionId (83516)
  sectionNo 45C
  orderNo 54
  title Appeal.
  content obj_root_law_sections_45_c_content
  footnotes `1. Subs. by Act 5 of 2024, s. 10, for section 45A (w.e.f. 15-2-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=83516&sectionno=45C&orderno=54&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_45_c_content:
  string
  line `^145C. Appeal.-- (1) Any person aggrieved by the order passed by the adjudicating officer under`
  line `section 45B may prefer an appeal to the National Green Tribunal established under section 3 of the`
  line `National Green Tribunal Act, 2010 (19 of 2010).`
  line
  line `(2) Every appeal under sub-section (1) shall be filed within sixty days from the date on which the copy`
  line `of the order made by the adjudicating officer is received by the aggrieved person.`
  line
  line `(3) The National Green Tribunal may, after giving the parties to the appeal an opportunity of being`
  line `heard, pass such order as it thinks fit, confirming, modifying or setting aside the order appealed against.`
  line
  line `(4) Where an appeal is preferred against any order of the adjudicating officer under sub-section (1), such appeal shall not be entertained by the Tribunal unless such person has deposited with the Tribunal ten`
  line `per cent. of the amount of the penalty imposed by the adjudicating officer.]`
obj_root_law_sections_45_d:
  sectionId (83517)
  sectionNo 45D
  orderNo 55
  title `Penalty amount to be credited to Environmental Protection Fund.`
  content `^1[45D. Penalty amount to be credited to Environmental Protection Fund.--Where an adjudicating officer imposes penalty or additional penalty, as the case may be, under the provisions of this Act, the amount of such penalty shall be credited to the Environmental Protection Fund established under section 16 of the Environment (Protection) Act, 1986 (29 of 1986).]`
  footnotes `1. Subs. by Act 5 of 2024, s. 10, for section 45A (w.e.f. 15-2-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=83517&sectionno=45D&orderno=55&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_45_e:
  sectionId (83518)
  sectionNo 45E
  orderNo 56
  title `Offences for failure to comply with provisions of section 25 or 26 and for failure to pay penalty.`
  content obj_root_law_sections_45_e_content
  footnotes `1. Subs. by Act 5 of 2024, s. 10, for section 45A (w.e.f. 15-2-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=83518&sectionno=45E&orderno=56&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_45_e_content:
  string
  line `@span^1[@45E. Offences for failure to comply with provisions of section 25 or 26 and for failure to pay penalty.--(1) Whoever fails to comply with the provisions of section 25 or section 26, in respect of each`
  line `such failure, shall be punishable with imprisonment for a term which shall not be less than one year and six`
  line `months but which may extend to six years and with fine, and in case the failure continues, with an`
  line `additional fine which may extend to fifty thousand rupees for every day during which such failure`
  line `continues after the conviction for the first such failure.`
  line
  line `@span(2) If the failure referred to in sub-section (1) continues beyond a period of one year after the date of`
  line `conviction, the offender shall be punishable with imprisonment for a term which shall not be less than two`
  line `years but which may extend to seven years and with fine.`
  line
  line `@span(3) Where any person fails to pay the penalty or the additional penalty, as the case may be, imposed`
  line `under the provisions of this Act within ninety days of such imposition, he shall be punishable with`
  line `imprisonment for a term which may extend to three years, or with fine which may extend to twice the`
  line `amount of the penalty or additional penalty so imposed or with both.`
  line
  line `@span(4) Where any offence under sub-section (1) or sub-section (2) or sub-section (3) has been committed`
  line `by a company, every person who, at the time the offence was committed, was directly in charge of, and`
  line `was responsible to, the company for the conduct of the business of the company, as well as the company,`
  line `shall be deemed to be guilty of such offence and he shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `@spanProvided that nothing in this sub-section shall render any such person liable to any punishment`
  line `provided in sub-section (1) or sub-section (2) or sub-section (3), if he proves that the offence was`
  line `committed without his knowledge or that he exercised all due diligence to prevent the commission of such`
  line offence.
  line
  line `@span(5) Notwithstanding anything in sub-section (4), where an offence has been committed by a company`
  line `and it is proved that the offence has been committed with the consent or connivance of, or is attributable to`
  line `any neglect on the part of, any director, manager, secretary or other officer of the company, such director,`
  line `manager, secretary or other officer shall also be deemed to be guilty of that offence and shall be liable to be`
  line `proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) “company” includes body corporate, firm, trust, society and any other association of`
  line individuals;
  line
  line `(b) “director”, includes director of the company, partner of the firm, members of the society or`
  line `trust or member of any association of individuals, as the case may be.]`
obj_root_law_sections_46:
  sectionId (4138)
  sectionNo (46)
  orderNo 57
  title `Publication of names of offenders.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4138&sectionno=46&orderno=57&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_46_content:
  string
  line `If any person convicted of an offence under this Act`
  line `commits a like offence afterwards it shall be lawful for the court before which the second or subsequent`
  line `conviction takes place to cause the offender's name and place of residence, the offence and the penalty`
  line `imposed to be published at the offender's expense in such newspapers or in such other manner as the`
  line `court may direct and the expenses of such publication shall be deemed to be part of the cost attending the`
  line `conviction and shall be recoverable in the same manner as a fine.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (4139)
  sectionNo (47)
  orderNo 58
  title Omitted.
  content `"47. Offences by companies."--Omitted by the Water (Prevention and Control of Pollution Amendment) Act, 2024 (5 of 2024), s. 11, (w.e.f. 15-2-2024)`
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4139&sectionno=47&orderno=58&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (4140)
  sectionNo (48)
  orderNo 59
  title `Penalty for contravention by Government Department.`
  content obj_root_law_sections_48_content
  footnotes `1. Subs. by Act 5 of 2024, s. 12, for section 48, (w.e.f. 15-2-2024)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4140&sectionno=48&orderno=59&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_48_content:
  string
  line `^1[48. Penalty for contravention by Government Department.-- (1) Where contravention of any`
  line `provision of this Act has been committed by any Department of the Central Government or State Government, the Head of the Department shall be liable to pay the penalty equal to one month of his basic salary:`
  line
  line `Provided that such Head of the Department shall not be liable for such contravention, if he proves that`
  line `the contravention was committed without his knowledge or instructions or that he exercised all due`
  line `diligence to prevent such contravention.`
  line
  line `(2) Where any contravention under sub-section (1) is attributable to any neglect on the part of, any`
  line `officer, other than the Head of the Department, such officer shall be liable to pay the penalty equal to one`
  line `month of his basic salary:`
  line `Provided that such officer shall not be liable for the contravention, if he proves that he exercised all`
  line `due diligence to avoid such contravention.]`
obj_root_law_sections_49:
  sectionId (4141)
  sectionNo (49)
  orderNo 60
  title `Cognizance of offences.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4141&sectionno=49&orderno=60&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_49_content:
  string
  line ^1
  line `[(1) No court shall take cognizance of any offence under this Act`
  line `except on a complaint made by--`
  line
  line `(a) a Board or any officer authorised in this behalf by it; or`
  line
  line `^2[(aa) the adjudicating officer or any officer authorised by him in this behalf; or]`
  line
  line `(b) any person who has given notice of not less than sixty days, in the manner prescribed, of the`
  line `alleged offence and of his intention to make a complaint, to the Board or officer authorised as`
  line aforesaid,
  line
  line `and no court inferior to that of a Metropolitan Magistrate or a Judicial Magistrate of the first class shall`
  line `try any offence punishable under this Act.]`
  line
  line ^3
  line `[(2) Where a complaint has been made under clause (b) of sub-section (1), the Board shall, on`
  line `demand by such person, make available the relevant reports in its possession to that person:`
  line
  line `Provided that the Board may refuse to make any such report available to such person if the same is, in`
  line `its opinion, against the public interest.]`
  line
  line ^4
  line `[(3)] Notwithstanding anything contained in ^5`
  line `[section 29 of the Code of Criminal`
  line `Procedure, 1973 (2 of 1974)], it shall be lawful for any ^6`
  line `[Judicial Magistrate of the first class or for any`
  line `Metropolitan Magistrate] to pass a sentence of imprisonment for a term exceeding two years or of fine`
  line `exceeding two thousand rupees on any person convicted of an offence punishable under this Act.`
obj_root_law_sections_49_footnotes:
  string
  line `1. Subs. by Act 53 of 1988, s. 26, for sub-section (1) (w.e.f. 29-9-1988).`
  line
  line `2. Ins. by Act 5 of 2024, s. 13, (w.e.f. 15-2-2024).`
  line
  line `3. Ins. by s. 26, ibid. (w.e.f. 29-9-1988).`
  line
  line `4. Sub-section (2) renumbered as sub-section (3) thereof by s. 26, ibid. (w.e.f. 29-9-1988).`
  line
  line `5 Subs. by Act 44 of 1978, s. 19, for "section 32 of the Code of Criminal Procedure, 1898 (5 of 1898)" (w.e.f. 12-12-1978).`
  line
  line `6. Subs. by s. 19, ibid., for "Magistrate of the first class or for any Presidency Magistrate" (w.e.f. 12-12-1978).`
obj_root_law_sections_50:
  sectionId (4142)
  sectionNo (50)
  orderNo 61
  title `Members, officers and servants of Board to be public servants.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4142&sectionno=50&orderno=61&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_50_content:
  string
  line `All members, officers and`
  line `servants of a Board when acting or purporting to act in pursuance of any of the provisions of this Act and`
  line `the rules made thereunder shall be deemed to be public servants within the meaning of section 21 of the`
  line `Indian Penal Code (45 of 1860).`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (4143)
  sectionNo (51)
  orderNo 62
  title `Central Water Laboratory.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4143&sectionno=51&orderno=62&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_51_content:
  string
  line `(1) The Central Government may, by notification in the Official`
  line Gazette,--
  line
  line `(a) establish a Central Water Laboratory; or`
  line
  line `(b) specify any laboratory or institute as a Central Water Laboratory, to carry out the functions`
  line `entrusted to the Central Water Laboratory under this Act.`
  line
  line `(2) The Central Government may, after consultation with the Central Board, make rules prescribing--`
  line
  line `(a) the functions of the Central Water Laboratory;`
  line
  line `(b) the procedure for the submission to the said laboratory of samples of water or of sewage or`
  line `trade effluent for analysis or tests, the form of the laboratorys report thereunder and the fees payable`
  line `in respect of such report;`
  line
  line `(c) such other matters as may be necessary or expedient to enable that laboratory to carry out its`
  line functions.
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (4144)
  sectionNo (52)
  orderNo 63
  title `State Water Laboratory.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4144&sectionno=52&orderno=63&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_52_content:
  string
  line `(1) The State Government may, by notification in the Official`
  line Gazette,--
  line
  line `(a) establish a State Water Laboratory; or`
  line
  line `(b) specify any laboratory or institute as a State Water Laboratory, to carry out the`
  line `functions entrusted to the State Water Laboratory under this Act.`
  line
  line `(2) The State Government may, after consultation with the State Board, make rules prescribing--`
  line
  line `(a) the functions of the State Water Laboratory;`
  line
  line `(b) the procedure for the submission to the said laboratory of samples of water or of sewage or`
  line `trade effluent for analysis or tests, the form of the laboratorys report thereon and the fees payable in`
  line `respect of such report;`
  line
  line `(c) such other matters as may be necessary or expedient to enable that laboratory to carry out its`
  line functions.
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (4145)
  sectionNo (53)
  orderNo 64
  title Analysts.
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4145&sectionno=53&orderno=64&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_53_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette, appoint such`
  line `persons as it thinks fit and having the prescribed qualifications to be Government analysts for the purpose`
  line `of analysis of samples of water or of sewage or trade effluent sent for analysis to any laboratory`
  line `established or specified under sub-section (1) of section 51.`
  line
  line `(2) The State Government may, by notification in the Official Gazette, appoint such persons as it`
  line `thinks fit and having the prescribed qualifications to be Government analysts for the purpose of analysis`
  line `of samples of water or of sewage or trade effluent sent for analysis to any laboratory established or`
  line `specified under sub-section (1) of section 52.`
  line
  line `(3) Without prejudice to the provisions of sub-section (3) of section 12, the Central Board or, as the`
  line `case may be, the State Board may, by notification in the Official Gazette, and with the approval of the`
  line `Central Government or the State Government, as the case may be, appoint such persons as it thinks fit and`
  line `having the prescribed qualifications to be Board analysts for the purpose of analysis of samples of water`
  line `or of sewage or trade effluent sent for analysis to any laboratory established or recognised under`
  line `section 16, or, as the case may be, under section 17.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (4146)
  sectionNo (54)
  orderNo 65
  title `Reports of analysts.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4146&sectionno=54&orderno=65&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_54_content:
  string
  line `Any document purporting to be a report signed by a Government analyst`
  line `or, as the case may be, a Board analyst may be used as evidence of the facts stated therein in any`
  line `proceeding under this Act.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (4147)
  sectionNo (55)
  orderNo 66
  title `Local authorities to assist.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4147&sectionno=55&orderno=66&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_55_content:
  string
  line `All local authorities shall render such help and assistance and`
  line `furnish such information to the Board as it may require for the discharge of its functions, and shall make`
  line `available to the Board for inspection and examination such records, maps, plans and other documents as`
  line `may be necessary for the discharge of its functions.`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (4148)
  sectionNo (56)
  orderNo 67
  title `Compulsory acquisition of land for the State Board.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4148&sectionno=56&orderno=67&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_56_content:
  string
  line `Any land required by a State Board for`
  line `the efficient performance of its functions under this Act shall be deemed to be needed for a public purpose`
  line `and such land shall be acquired for the State Board under the provisions of the Land Acquisition`
  line `Act, 1894 (1 of 1894), or under any other corresponding law for the time being in force.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (4149)
  sectionNo (57)
  orderNo 68
  title `Returns and reports.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4149&sectionno=57&orderno=68&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_57_content:
  string
  line `The Central Board shall furnish to the Central Government, and a`
  line `State Board shall furnish to the State Government and to the Central Board such reports, returns,`
  line `statistics, accounts and other information with respect to its fund or activities as that Government, or, as`
  line `the case may be, the Central Board may, from time to time, require.`
obj_root_law_sections_57_footnotes:
  string
  line
obj_root_law_sections_58:
  sectionId (4150)
  sectionNo (58)
  orderNo 69
  title `Bar of jurisdiction.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4150&sectionno=58&orderno=69&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_58_content:
  string
  line `No civil court shall have jurisdiction to entertain any suit or proceeding in`
  line `respect of any matter which an appellate authority constituted under this Act is empowered by or under`
  line `this Act to determine, and no injunction shall be granted by any court or other authority in respect of any`
  line `action taken or to be taken in pursuance of any power conferred by or under this Act.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_59:
  sectionId (4151)
  sectionNo (59)
  orderNo 70
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4151&sectionno=59&orderno=70&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_59_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `the Government or any officer of Government or any member or officer of a Board in respect of anything`
  line `which is in good faith done or intended to be done in pursuance of this Act or the rules made thereunder.`
obj_root_law_sections_59_footnotes:
  string
  line
obj_root_law_sections_60:
  sectionId (4152)
  sectionNo (60)
  orderNo 71
  title `Overriding effect.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4152&sectionno=60&orderno=71&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_60_content:
  string
  line `The provisions of this Act shall have effect notwithstanding anything`
  line `inconsistent therewith contained in any enactment other than this Act.`
obj_root_law_sections_60_footnotes:
  string
  line
obj_root_law_sections_61:
  sectionId (4153)
  sectionNo (61)
  orderNo 72
  title `Power of Central Government to supersede the Central Board and Joint Boards.`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4153&sectionno=61&orderno=72&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_61_content:
  string
  line `(1) If at`
  line `any time the Central Government is of opinion--`
  line
  line `(a) that the Central Board or any Joint Board has persistently made default in the performance of`
  line `the functions imposed on it by or under this Act; or`
  line
  line `(b) that circumstances exist which render it necessary in the public interest so to do,`
  line
  line `the Central Government may, by notification in the Official Gazette, supersede the Central Board or such`
  line `Joint Board, as the case may be, for such period, not exceeding one year, as may be specified in the`
  line `notification:`
  line
  line `Provided that before issuing a notification under this sub-section for the reasons mentioned in`
  line `clause (a), the Central Government shall give a reasonable opportunity to the Central Board or such`
  line `Joint Board, as the case may be, to show cause why it should not be superseded and shall consider the`
  line `explanations and objections, if any, of the Central Board or such Joint Board, as the case may be.`
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the Central Board or any`
  line `Joint Board,--`
  line
  line `(a) all the members shall, as from the date of supersession vacate their offices as such;`
  line
  line `(b) all the powers, functions and duties which may, by or under this Act, be exercised, performed`
  line `or discharged by the Central Board or such Joint Board shall, until the Central Board or the`
  line `Joint Board, as the case may be, is reconstituted under sub-section (3) be exercised, performed or`
  line `discharged by such person or persons as the Central Government may direct;`
  line
  line `(c) all property owned or controlled by the Central Board or such Joint Board shall, until the`
  line `Central Board or the Joint Board, as the case may be, is reconstituted under sub-section (3) vest in the`
  line `Central Government.`
  line
  line `(3) On the expiration of the period of supersession specified in the notification issued under`
  line `sub-section (1), the Central Government may--`
  line
  line `(a) extend the period of supersession for such further term, not exceeding six months, as it may`
  line `consider necessary; or`
  line
  line `(b) reconstitute the Central Board or the Joint Board, as the case may be, by fresh nomination or`
  line `appointment, as the case may be, and in such case any person who vacated his office under clause (a)`
  line `of sub-section (2) shall not be deemed disqualified for nomination or appointment:`
  line
  line `Provided that the Central Government may at any time before the expiration of the period of`
  line `supersession, whether originally specified under sub-section (1) or as extended under this sub-section,`
  line `take action under clause (b) of this sub-section.`
obj_root_law_sections_61_footnotes:
  string
  line
obj_root_law_sections_62:
  sectionId (4154)
  sectionNo (62)
  orderNo 73
  title `Power of State Government to supersede State Board.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4154&sectionno=62&orderno=73&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_62_content:
  string
  line `(1) If at any time the State`
  line `Government is of opinion--`
  line
  line `(a) that the State Board has persistently made default in the performance of the functions imposed`
  line `on it by or under this Act; or`
  line
  line `(b) that circumstances exist which render it necessary in the public interest so to do,`
  line
  line `the State Government may, by notification in the Official Gazette, supersede the State Board for such`
  line `period, not exceeding one year, as may be specified in the notification:`
  line
  line `Provided that before issuing a notification under this sub-section for the reasons mentioned in`
  line `clause (a), the State Government shall give a reasonable opportunity to the State Board to show cause`
  line `why it should not be superseded and shall consider the explanations and objections, if any, of the`
  line `State Board.`
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the State Board, the`
  line `provisions of sub-sections (2) and (3) of section 61 shall apply in relation to the supersession of the`
  line `State Board as they apply in relation to the supersession of the Central Board or a Joint Board by the`
  line `Central Government.`
obj_root_law_sections_62_footnotes:
  string
  line
obj_root_law_sections_63:
  sectionId (4155)
  sectionNo (63)
  orderNo 74
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4155&sectionno=63&orderno=74&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_63_content:
  string
  line `(1) The Central Government may,`
  line `simultaneously with the constitution of the Central Board, make rules in respect of the matters specified`
  line `in sub-section (2):`
  line
  line `Provided that when the Central Board has been constituted, no such rule shall be made, varied,`
  line `amended or repealed without consulting the Board.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the terms and conditions of service of the members (other than the chairman`
  line `and member-secretary) of the Central Board under sub-section (8) of section 5;`
  line
  line `^1[(aa) the manner of nomination of the chairman of the State Board and the terms and conditions of service of the chairman of the State Board under clause (a) of sub-section (2) of section 4 and under sub-section (9) of section 5;]`
  line
  line `(b) the intervals and the time and place at which meetings of the Central Board or of any`
  line `committee thereof constituted under this Act, shall be held and the procedure to be followed at`
  line `such meetings, including the quorum necessary for the transaction of business under section 8, and`
  line `under sub-section (2) of section 9;`
  line
  line `(c) the fees and allowances to be paid to such members of a committee of the Central Board as`
  line `are not members of the Board under sub-section (3) of section 9;`
  line
  line `^2[(d) the manner in which and the purposes for which persons may be associated with the`
  line `Central Board under sub-section (1) of section 10 and the fees and allowances payable to`
  line `such persons;]`
  line
  line `(e) the terms and conditions of service of the chairman and the member-secretary of the`
  line `Central Board under sub-section (9) of section 5 and under sub-section (1) of section 12;`
  line
  line `(f) conditions subject to which a person may be appointed as a consulting engineer to the`
  line `Central Board under sub-section (4) of section 12;`
  line
  line `(g) the powers and duties to be exercised and performed by the chairman and`
  line `the member-secretary of the Central Board;`
  line
  line `^3* * * * *`
  line
  line `(j) the form of the report of the Central Board analyst under sub-section (1) of section 22;`
  line
  line `(k) the form of the report of the Government analyst under sub-section (3) of section 22;`
  line
  line ^4
  line `[(l) the form in which and the time within which the budget of the Central Board may be`
  line `prepared and forwarded to the Central Government under section 38;`
  line
  line `(ll) the form in which the annual report of the Central Board may be prepared under section 39;]`
  line
  line `(m) the form in which the accounts of the Central Board may be maintained under section 40;`
  line
  line `^5 [(ma) the manner of holding inquiry and imposing penalties by the adjudicating officer under section 45B;]`
  line
  line `^6[(mm) the manner in which notice of intention to make a complaint shall be given to the`
  line `Central Board or officer authorised by it under section 49;]`
  line
  line `(n) any other matter relating to the Central Board, including the powers and functions of`
  line `that Board in relation to Union territories;`
  line
  line `(o) any other matter which has to be, or may be, prescribed.`
  line
  line `(3) Every rule made by the Central Government under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament while it is in session for a total period of thirty days which may`
  line `be comprised in one session or in two or more successive sessions, and if, ^7`
  line `[before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid], both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.`
obj_root_law_sections_63_footnotes:
  string
  line `1. Ins. by Act 5 of 2024, s. 14, (w.e.f. 15-2-2024).`
  line
  line `2. Subs. by Act 44 of 1978, s. 20, for clause (d) (w.e.f. 12-12-1978).`
  line
  line `3. Clauses (h) and (i) omitted by s. 20, ibid. (w.e.f. 12-12-1978).`
  line
  line `4. Subs. by Act 53 of 1988, s. 27, for clause (l) (w.e.f. 29-9-1988).`
  line
  line `5. Ins. by Act 5 of 2024, s. 14, (w.e.f. 15-2-2024).`
  line
  line `6. Ins. by s. 27, ibid. (w.e.f. 29-9-1988).`
  line
  line `7 Subs. by Act 44 of 1978, s. 20, for certain words (w.e.f. 12-12-1978).`
obj_root_law_sections_64:
  sectionId (4156)
  sectionNo (64)
  orderNo 75
  title `Power of State Government to make rules.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00003_197606_1517807320722&sectionId=4156&sectionno=64&orderno=75&orgactid=AC_CEN_16_18_00003_197606_1517807320722
obj_root_law_sections_64_content:
  string
  line `(1) The State Government may, simultaneously`
  line `with the constitution of the State Board, make rules to carry out the purposes of this Act in respect of`
  line `matters not falling within the purview of section 63:`
  line
  line `Provided that when the State Board has been constituted, no such rule shall be made, varied, amended`
  line `or repealed without consulting that Board.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the terms and conditions of service of the members (other than the chairman and`
  line `the member-secretary) of the State Board under sub-section (8) of section 5;`
  line
  line `(b) the time and place of meetings of the State Board or of any committee of that Board`
  line `constituted under this Act and the procedure to be followed at such meeting, including the quorum`
  line `necessary for the transaction of business under section 8 and under sub-section (2) of section 9;`
  line
  line `(c) the fees and allowances to be paid to such members of a committee of the State Board as are`
  line `not members of the Board under sub-section (3) of section 9;`
  line
  line `(d) the manner in which and the purposes for which persons may be associated with the`
  line `State Board under sub-section (1) of section 10 ^1`
  line `[and the fees and allowances payable to such`
  line persons;]
  line
  line `(e) the terms and conditions of service of ^2[the member-secretary of the State Board] under sub-section (1) of section 12;`
  line
  line `(f) the conditions subject to which a person may be appointed as a consulting engineer to the`
  line `State Board under sub-section (4) of section 12;`
  line
  line `(g) the powers and duties to be exercised and discharged by the chairman and`
  line `the member-secretary of the State Board;`
  line
  line `(h) the form of the notice referred to in section 21;`
  line
  line `(i) the form of the report of the State Board analyst under sub-section (1) of section 22;`
  line
  line `(j) the form of the report of the Government analyst under sub-section (3) of section 22;`
  line
  line `(k) the form of application for the consent of the State Board under sub-section (2) of section 25,`
  line `and the particulars it may contain;`
  line
  line `(l) the manner in which inquiry under sub-section (3) of section 25 may be made in respect of an`
  line `application for obtaining consent of the State Board and the matters to be taken into account in`
  line `granting or refusing such consent;`
  line
  line `(m) the form and manner in which appeals may be filed, the fees payable in respect of such`
  line `appeals and the procedure to be followed by the appellate authority in disposing of the appeals under`
  line `sub-section (3) of section 23;`
  line
  line `^3[(n) the form in which and the time within which the budget of the State Board may be prepared`
  line `and forwarded to the State Government under section 38;`
  line
  line `(nn) the form in which the annual report of the State Board may be prepared under section 39;]`
  line
  line `(o) the form in which the accounts of the State Board may be maintained under sub-section (1) of`
  line `section 40;`
  line
  line `^4[(oo) the manner in which notice of intention to make a complaint shall be given to the`
  line `State Board or officer authorised by it under section 49;]`
  line
  line `(p) any other matter which has to be, or may be, prescribed.`
obj_root_law_sections_64_footnotes:
  string
  line `1. Ins. by s. 21, ibid. (w.e.f. 12-12-1978).`
  line
  line `2. Subs. by Act 53 of 1988, s. 28, for clause (n) (w.e.f. 29-9-1988).`
  line
  line `3. Subs. by Act 5 of 2024, s. 15, ibid., for certain words (w.e.f. 15-2-2024).`
  line
  line `4. Ins. by s. 28, ibid. (w.e.f. 29-9-1988).`
