  slug the-water-prevention-and-control-of-pollution-act-1974
  handle (1612)
  collectionHandle 123456789/1362
  title `The Water (Prevention and Control of Pollution) Act, 1974`
  actNumber (6)
  enactmentDate 1974-03-23
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1612`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `जल (प्रदूषण निवारण तथा नियंत्रण) अधिनियम,1974`
  actYear (1974)
  ministry `Ministry of Environment, Forest and Climate Change`
  department undefined
  longTitle `An Act to provide for the prevention and control of water pollution and the maintaining or restoring of wholesomeness of water, for the establishment, with a view to carrying out the purposes aforesaid, of Boards for the prevention and control of water pollution, for conferring on and assigning to such Boards powers and functions relating thereto and for matters connected therewith.`
  enforcementDate 23-03-1974
  notification `States Governments notifications`
  fetchedAt `2026-05-10T12:08:55.739Z`
  translations obj_root_law_translations
