  (str slug) (str the-water-prevention-and-control-of-pollution-act-1974)
  (str handle) (str 1612)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Water (Prevention and Control of Pollution) Act, 1974`)
  (str actNumber) (str 6)
  (str enactmentDate) (str 1974-03-23)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1612`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `जल (प्रदूषण निवारण तथा नियंत्रण) अधिनियम,1974`)
  (str actYear) (str 1974)
  (str ministry) (str `Ministry of Environment, Forest and Climate Change`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the prevention and control of water pollution and the maintaining or restoring of wholesomeness of water, for the establishment, with a view to carrying out the purposes aforesaid, of Boards for the prevention and control of water pollution, for conferring on and assigning to such Boards powers and functions relating thereto and for matters connected therewith.`)
  (str enforcementDate) (str 23-03-1974)
  (str notification) (str `States Governments notifications`)
  (str fetchedAt) (str `2026-05-10T12:08:55.739Z`)
  (str translations) obj_root_law_translations
