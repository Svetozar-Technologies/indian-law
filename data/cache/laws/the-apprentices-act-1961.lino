  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36719&sectionno=5A&orderno=8&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_5_a_content:
  string
  line ^1
  line `[5A. Regulation of optional trade.--The qualification, period of apprenticeship training, holding of`
  line `test, grant of certificate and other conditions relating to the apprentices in optional trade shall be such as`
  line `may be prescribed.]`
obj_root_law_sections_5_b:
  sectionId (36720)
  sectionNo 5B
  orderNo 9
  title `Engagement of apprentices from other States.`
  content obj_root_law_sections_5_b_content
  footnotes `1. Ins. by s. 5, ibid. (w.e.f. 22-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36720&sectionno=5B&orderno=9&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_5_b_content:
  string
  line `^15B. Engagement of apprentices from other States.--The employer may engage apprentices from`
  line `other States for the purpose of providing apprenticeship training to the apprentices.]`
obj_root_law_sections_6:
  sectionId (36721)
  sectionNo (6)
  orderNo 10
  title `Period of apprenticeship training.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36721&sectionno=6&orderno=10&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_6_content:
  string
  line `The period of apprenticeship training, which shall be`
  line `specified in the contract of apprenticeship, shall be as follows:--`
  line
  line `(a) in the case of ^1[trade apprentices] who, having undergone institutional training in a school or`
  line `other institution recognised by the National Council], have passed the trade tests ^2[or examinations]`
  line `conducted by ^3[that Council or by an institution recognised by that Council, the period of`
  line `apprenticeship training shall be such as may be ^4[prescribed];`
  line
  line `^5[(aa) in the case of trade apprentices who, having undergone institutional training in a school or`
  line `other institution affiliated to or recognised by a Board or State Council of Technical Education or any`
  line `other authority or courses approved under any scheme which the Central Government may, by`
  line `notification in the Official Gazette specify in this behalf, have passed the trade tests or examinations`
  line `conducted by that Board or State Council or authority or by any other agency authorised by the`
  line `Central Government, the period of apprenticeship training shall be such as may be prescribed;]`
  line
  line `(b) in the case of other ^1[trade apprentices], the period of apprenticeship training shall be such as`
  line `may be prescribed;`
  line
  line `^6[(c) in the case of graduate or technician apprentices ^7[technician (vocational) apprentices], the`
  line `period of apprenticeship training shall be such as may be prescribed.]`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra
  line
  line `In section 6 of the Apprentices Act, 1961 (52 of 1961), in its application to the State of Maharashtra (hereinafter referred to as the principal Act), for the existing clause (b), the following clause shall be substituted, namely:--`
  line
  line `(b) in the case of other apprentices, the period of apprenticeship training shall be such as may be specified by the State Apprenticeship Council;--.`
  line
  line `[Vide Maharashtra Act 17 of 2018, s. 2].`
  line
  line Rajasthan
  line
  line `Amendment of section 6, Central Act No. 52 of 1961.--In the Apprentices Act, 1961 (Central Act`
  line `No. 52 of 1961), in its application to the State of Rajasthan, hereinafter referred to as the principal Act,`
  line `for the existing clause (b) of section 6, the following shall be substituted, namely:-`
  line
  line `(b) in the case of other apprentices, the period of apprenticeship training shall be such as may be`
  line `prescribed by State Apprenticeship Council;--.`
  line
  line `[Vide Rajasthan Act 2 of 2015, s. 2.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 27 of 1973, s. 8, for apprentices (w.e.f. 1-12-1974).`
  line
  line `2. Ins. by Act 41 of 1986, s. 5 (w.e.f. 16-12-1987).`
  line
  line `3. Subs. by Act 27 of 1973, s. 8, for that Council (w.e.f. 1-12-1974).`
  line
  line `4. Subs. by Act 29 of 2014, s. 6, for determined by that Council (w.e.f. 22-12-2014).`
  line
  line `5. Subs. by s. 6, ibid., for clause (aa) (w.e.f. 22-12-2014).`
  line
  line `6. Ins. by Act 27 of 1973, s. 8 (w.e.f. 1-12-1974).`
  line
  line `7. Ins. by Act 41 of 1986, s. 3 (w.e.f. 16-12-1987).`
obj_root_law_sections_7:
  sectionId (36722)
  sectionNo (7)
  orderNo 11
  title `Termination of apprenticeship contract.`
  content obj_root_law_sections_7_content
  footnotes `1. Ins. by Act 4 of 1997, s. 3 (w.e.f. 8-1-1997)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36722&sectionno=7&orderno=11&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_7_content:
  string
  line `(1) The contract of apprenticeship shall terminate on`
  line `the expiry of the period of apprenticeship training.`
  line
  line `(2) Either party to a contract of apprenticeship may make an application to the Apprenticeship`
  line `Adviser for the termination of the contract, and when such application is made, shall send by post a copy`
  line `thereof to the other party to the contract.`
  line
  line `(3) After considering the contents of the application and the objections, if any, filed by the other`
  line `party, the Apprenticeship Adviser may, by order in writing, terminate the contract if he is satisfied that the`
  line `parties to the contract or any of them have or has failed to carry out the terms and conditions of the`
  line `contract and that it is desirable in the interests of the parties or any of them to terminate the same:`
  line
  line `Provided that where a contract is terminated--`
  line
  line `(a) for failure on the part of the employer to carry out the terms and conditions of the contract, the`
  line `employer shall pay to the apprentice such compensation as may be prescribed;`
  line
  line `(b) for such failure on the part of the apprentice, the apprentice or his guardian shall refund to the`
  line `employer as cost of training such amount as may be determined by the Apprenticeship Adviser.`
  line
  line `^1[(4) Notwithstanding anything contained in any other provision of this Act, where a contract of`
  line `apprenticeship has been terminated by the Apprenticeship Adviser before the expiry of the period of`
  line `apprenticeship training and a new contract of apprenticeship is being entered into with a new employer,`
  line `the Apprenticeship Adviser may, if he is satisfied that the contract of apprenticeship with the previous`
  line `employer could not be completed because of any lapse on the part of the previous employer, permit the`
  line `period of apprenticeship training already undergone by the apprentice with his previous employer to be`
  line `included in the period of apprenticeship training to be undertaken with the new employer.]`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra.
  line
  line `In section 7 of the principal Act, in sub-section (3), for the existing proviso, the following proviso shall be substituted, namely:--`
  line
  line `Provided that, where a contract is terminated--`
  line
  line `(a) for failure on the part of the employer to carry out the terms and conditions of the contract, the employer shall pay to the apprentice one month's stipend for which he is entitled as a compensation;`
  line
  line `(b) for such failure on the part of the apprentice, the apprentice or his guardian shall refund to the employer as cost of training one month's stipend for which he is entitled.--.`
  line
  line `[Vide Maharashtra Act 17 of 2018, s. 3].`
  line
  line Rajasthan
  line
  line `Amendment of section 7, Central Act No. 52 of 1961.--For the existing proviso to sub-section (3)`
  line `of section 7 of the principal Act, the following shall be substituted, namely:--`
  line
  line `Provided that where a contract is terminated-`
  line
  line `(a) for failure on the part of the employer to carry out the terms and conditions of the`
  line `contract, the employer shall pay to the apprentice such compensation as may be determined by`
  line `the State Apprenticeship Adviser;-`
  line
  line `(b) for such failure on the part of the apprentice, the apprentice shall refund to the employer`
  line `as cost of training, such amount as may be determined by the State Apprenticeship Adviser.-`
  line
  line `[Vide Rajasthan Act 2 of 2015, s. 3]`
obj_root_law_sections_8:
  sectionId (36723)
  sectionNo (8)
  orderNo 12
  title `Number of apprentices for a designated trade.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 29 of 2014, s. 7, for section 8 (w.e.f. 22-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36723&sectionno=8&orderno=12&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_8_content:
  string
  line `^1[8. Number of apprentices for a designated trade.--(1) The Central Government shall prescribe`
  line `the number of apprentices to be engaged by the employer for designated trade and optional trade.`
  line
  line `(2) Several employers may join together either themselves or through an agency, approved by the`
  line `Apprenticeship Adviser, according to the guidelines issued from time to time by the Central Government`
  line `in this behalf, for the purpose of providing apprenticeship training to the apprentices under them.]`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra.
  line
  line `In section 8 of the principal Act, after the existing sub-section (1), the following sub-section shall be inserted, namely:--`
  line
  line `(1A) Notwithstanding anything contained in sub-section (1), the establishment shall have to engage trade apprentices to the extent of minimum 2.5 per cent. and maximum 25 per cent. of the total strength of the employees of establishment including contractual or daily wages or whose services have been available through third party in any designated trades or optional trades for which activities are carried out in that establishment..`
  line
  line `[Vide Maharashtra Act 17 of 2018, s. 4].`
  line
  line Rajasthan
  line
  line `Amendment of section 8, Central Act No. 52 of 1961.—For the existing section 8 of the principal`
  line `Act, the following shall be substituted, namely:-`
  line
  line `“8. Number of apprentices for a designated trade.- (1) The State Government`
  line `shall, after consulting the State Apprenticeship Council, by order notified in the Official`
  line `Gazette, determine for each designated trade the ratio of trade apprentices to workers`
  line `other than unskilled workers in that trade:`
  line
  line `Provided that nothing contained in this sub-section shall be deemed to prevent any`
  line `employer from engaging a number of trade apprentices in excess of the ratio determined`
  line `under this sub-section.`
  line
  line `(2) In determining the ratio under sub-section (1), the State Government shall have`
  line `regard to the facilities available for apprenticeship training under this Act in the`
  line `designated trade concerned as well as to the facilities that may have to be made available`
  line `by an employer for the training of graduate or technician apprentices or technician`
  line `(vocational) apprentices, if any, in pursuance of a notice issued to him under sub-section(3A) by the State Apprenticeship Adviser or such other person referred to in that subsection.`
  line
  line `(3) The State Apprenticeship Adviser may, by notice in writing, require an employer`
  line `to engage such number of trade apprentices within the ratio determined by the State`
  line `Government for any designated trade in his establishment, to undergo apprenticeship`
  line `training in that trade and the employer shall comply with such requisition:`
  line
  line `Provided that in making any requisition under this sub-section, the State`
  line `Apprenticeship Adviser shall have regard to the facilities actually available in the`
  line `establishment concerned:`
  line
  line `Provided further that the State Apprenticeship Adviser may, on a representation made`
  line `to him by an employer and keeping in view the more realistic employment potential,`
  line `training facilities and other relevant factors, permit him to engage such number of`
  line `apprentices for a designated trade as is lesser than the number arrived at by the ratio for`
  line `that trade, not being lesser than thirty percent of the number so arrived at, subject to the`
  line `condition that the employer shall engage apprentices in other trades in excess in number`
  line `equivalent to such shortfall.`
  line
  line `(3A) The State Apprenticeship Adviser or any other person not below the rank of an`
  line `Assistant Apprenticeship Adviser authorised by the State Apprenticeship Adviser in`
  line `writing in this behalf shall, having regard to-`
  line `(i) the number of managerial person (including technical and supervisory`
  line `persons) employed in a designated trade;`
  line
  line `(ii) the number of management trainees engaged in the establishment;`
  line
  line `(iii) the totality of the training facilities available in a designated trade; and`
  line
  line `(iv) such other factors as he may consider fit in the circumstances of the case;`
  line
  line `by notice in writing, require an employer to impart training to such number of graduate or`
  line `technician apprentices or technician (vocational) apprentices in such trade in his`
  line `establishment as may be specified in such notice and the employer shall comply with`
  line `such requisition.`
  line
  line `Explanation.-In this sub-section the expression “management trainee” means a`
  line `person who is engaged by an employer for undergoing a course of training in the`
  line `establishment of the employer (not being apprenticeship training under this Act) subject`
  line `to the condition that on successful completion of such training, such person shall be`
  line `employed by the employer on a regular basis.`
  line
  line `(4) Several employers may join together for the purpose of providing practical`
  line `training to the apprentices under them by moving them between their respective`
  line establishments.
  line
  line `(5) Where, having regard to the public interest, a number of apprentices in excess of`
  line `the ratio determined by the State Government or in excess of the number specified in a`
  line `notice issued under sub-section (3A) should in the opinion of the State Government be`
  line `trained, the State Apprenticeship Adviser may require employers to train the additional`
  line `number of apprentices.`
  line
  line `(6) Every employer to whom such requisition as aforesaid is made, shall comply with`
  line `the requisition if the State Government concerned makes available such additional facilities and such additional financial assistance as are considered necessary by the State`
  line `Apprenticeship Adviser for the training of the additional number of apprentices.`
  line
  line `(7) Any employer not satisfied with the decision of the State Apprenticeship Adviser under`
  line `sub-section (6), may make a reference to the State Apprenticeship Council and such reference`
  line `shall be decided by a Committee thereof appointed by the State Apprenticeship Council for the`
  line `purpose and the decision of that Committee shall be final.”.`
  line
  line `[Vide Rajasthan Act 2 of 2015, s. 4]`
obj_root_law_sections_9:
  sectionId (36724)
  sectionNo (9)
  orderNo 13
  title `Practical and basic training of apprentices.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36724&sectionno=9&orderno=13&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_9_content:
  string
  line ^1
  line `[(1) Every employer shall make suitable`
  line `arrangements in his workplace for imparting a course of practical training to every apprentice engaged by`
  line him.]
  line
  line `(2)`
  line ^2
  line `[The Central Apprenticeship Adviser or any other person not below the rank of an Assistant`
  line `Apprenticeship Adviser authorised by the Central Apprenticeship Adviser in writing in this behalf] shall`
  line `be given all reasonable facilities for access to each such apprentice with a view to test his work and to`
  line `ensure that the practical training is being imparted in accordance with the approved programme:`
  line
  line `Provided that ^3`
  line `[the State Apprenticeship Adviser or any other person not below the rank of an`
  line `Assistant Apprenticeship Adviser authorised by the State Apprenticeship Adviser in writing in this`
  line `behalf] shall also be given such facilities in respect of apprentices undergoing training in establishments`
  line `in relation to which the appropriate Government is the State Government.`
  line
  line ^4
  line `[(3) Such of the trade apprentices who have not undergone institutional training in a school or other`
  line `institution recognised by the National Council or any other institution affiliated to or recognised by a`
  line `Board or State Council of Technical Education or any other authority which the Central Government may,`
  line `by notification in the Official Gazette, specify in this behalf, shall, before admission in the workplace for`
  line `practical training, undergo a course of basic training and the course of basic training shall be given to the`
  line `trade apprentices in any institute having adequate facilities.]`
  line
  line `(4) Where an employer employs in his establishment five hundred or more workers, the basic training`
  line `shall be imparted to ^5`
  line `[the trade apprentices] either in separate parts of the workshop building or in a`
  line `separate building which shall be set up by the employer himself, but the appropriate Government may`
  line `grant loans to the employer on easy terms and repayable by easy instalments to meet the cost of the land,`
  line `construction and equipment for such separate building.`
  line
  line ^6
  line `* * * * *`
  line
  line ^7
  line `[(7) In the case of an apprentice other than a graduate or technician apprentice technician`
  line `(vocational) apprentice, the syllabus of and the equipment to be utilised for, practical training including`
  line `basic training in any designated trade shall be such as may be approved by the Central Government in`
  line `consultation with the Central Apprenticeship Council.`
  line
  line `(7A) In the case of graduate or technician apprentices or technician (vocational) apprentices, the`
  line `programme of apprenticeship training and the facilities required for such training in any designated trade`
  line `shall be such as may be approved by the Central Government in consultation with the Central`
  line `Apprenticeship Council.]`
  line
  line `(8)(a) Recurring costs (including the cost of stipends) incurred by an employer in connection`
  line `with ^8`
  line [
  line ^9
  line `[basic training] imparted to trade apprentices other than those referred to in clauses (a) and (aa)]`
  line `of section 6 shall be borne--`
  line
  line `(i) if such employer employs ^10`
  line `[two hundred and fifty] workers or more, by the employer;`
  line
  line `(ii) if such employer employs less than ^10`
  line `[two hundred and fifty] workers, by the employer and the`
  line `Government in equal shares up to such limit as may be laid down by the Central Government and`
  line `beyond that limit, by the employer alone; and`
  line
  line `(b) recurring costs (including the cost of stipends), if any, incurred by an employer in connection`
  line `with ^11`
  line `[practical training including basic training, imparted to trade apprentices referred to in`
  line `clauses (a) and (aa)] of section 6 shall, in every case, be borne by the employer;`
  line
  line ^12
  line `[(c) recurring costs (excluding the cost of stipends) incurred by an employer in connection with`
  line `the practical training imparted to graduate or technician apprentices ^13`
  line `[technician (vocational)`
  line `apprentices] shall be borne by the employer and the cost of stipends shall be borne by the Central`
  line `Government and the employer in equal shares up to such limit as may be laid down by the Central`
  line `Government and beyond that limit by the employer alone ^14[except apprentices who holds degree or`
  line `diploma in non-engineering.]`
  line
  line `STATE AMENDMENT`
  line
  line Rajasthan
  line
  line `Amendment of section 9, Central Act No. 52 of 1961.— In section 9 of the principal`
  line Act,-
  line
  line `(i) for the existing sub-section (1), the following shall be substituted, namely:-`
  line
  line `“(1) Every employer shall, make suitable arrangements in his establishment or, outsource`
  line `the same to a suitable third party training provider for imparting a course of practical training to`
  line `every apprentice engaged by it in accordance with the programme approved by the State`
  line `Apprenticeship Adviser.”; and`
  line
  line `(ii) for the existing sub-clauses (i) and (ii) of clause (a) of sub-section (8), the following shall be`
  line `substituted, namely:-`
  line
  line `“(i) if such employer employs two hundred and fifty workers or more, by the`
  line `employer and the Government in equal shares up to such a limit as may be laid down by`
  line `the State Government and such amount shall be reimbursed by the State Government in`
  line `each case of completion of successful training by the apprentice;`
  line
  line `(ii) if such employer employs less than two hundred and fifty workers, by`
  line `the State Government alone and such amount up to such a limit as may be laid`
  line `down by the State Government shall be reimbursed by the State Government, and`
  line `beyond that limit by the employer in each case of completion of successful training`
  line `by the apprentice; and”.`
  line
  line `[Vide Rajasthan Act 2 of 2015, s. 5]`
obj_root_law_sections_9_footnotes:
  string
  line `1. Subs. by s. 8, ibid., for sub-section (1) (w.e.f. 22-12-2014).`
  line
  line `2. Subs. by Act 27 of 1973, s. 10, for The Central Apprenticeship Adviser (w.e.f. 1-12-1974).`
  line
  line `3. Subs. by s. 10, ibid., for The State Apprenticeship Adviser (w.e.f. 1-12-1974).`
  line
  line `4. Subs. by Act 29 of 2014, s. 8, for sub-section (3) (w.e.f. 22-12-2014).`
  line
  line `5. Subs. by Act 27 of 1973, s. 10, for the apprentices (w.e.f. 1-12-1974).`
  line
  line `6. Sub-sections (4A), (4B), (5) and (6) omitted by Act 29 of 2014, s. 8 (w.e.f. 22-12-2014).`
  line
  line `7. Subs. by s. 8, ibid., for sub-sections (7) and (7A) (w.e.f. 22-12-2014).`
  line
  line `8. Subs. by Act 27 of 1973, s. 10, for practical training imparted to apprentices other than those referred to in clause (a)`
  line `(w.e.f. 1-12-1974).`
  line
  line `9. Subs. by Act 4 of 1997, s. 5, for practical training, including basic training (w.e.f. 8-1-1997).`
  line
  line `10. Subs. by s. 5, ibid., for five hundred (w.e.f. 8-1-1997).`
  line
  line `11. Subs. by Act 27 of 1973, s. 10, for practical training imparted to apprentices referred to in clause (a) (w.e.f. 1-12-1974).`
  line
  line `12. Ins. by s. 10, ibid. (w.e.f. 1-12-1974).`
  line
  line `13. Ins. by Act 41 of 1986, s. 3 (w.e.f. 16-12-1987).`
  line
  line `14. Ins. by Act 29 of 2014, s. 8 (w.e.f. 22-12-2014).`
obj_root_law_sections_10:
  sectionId (36725)
  sectionNo (10)
  orderNo 14
  title `Related instruction of apprentices.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36725&sectionno=10&orderno=14&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_10_content:
  string
  line `(1)`
  line `^1[A trade apprentice] who is undergoing practical`
  line `training in an establishment shall, during the period of practical training, be given a course of related`
  line `instruction (which shall be appropriate to the trade) approved by the Central Government in consultation`
  line `with the Central Apprenticeship Council, with a view to giving ^2[the trade apprentice] such theoretical`
  line `knowledge as he needs in order to become fully qualified as a skilled craftsman.`
  line `^3[(2) Related instruction shall be imparted at the cost of employer and the employer shall, when so`
  line `required, afford all facilities for imparting such instruction.]`
  line `(3) Any time spent by ^4`
  line `[a trade apprentice] in attending classes on related instruction shall be treated`
  line `as part of his paid period of work.`
  line ^5
  line `[(4) In the case of trade apprentices who, after having undergone a course of institutional training,`
  line `have passed the trade tests conducted by the National Council or have passed the trade tests and`
  line `examinations conducted by a Board or State Council of Technical Education or any other authority which`
  line `the Central Government may, by notification in the Official Gazette, specify in this behalf, the related`
  line `instruction may be given on such reduced or modified scale as may be prescribed.`
  line `(5) Where any person has, during his course in a technical institution, become a graduate or`
  line `technician apprentice ^6`
  line `[technician (vocational) apprentice] and during his apprenticeship training he has`
  line `to receive related instruction, then, the employer shall release such person from practical training to`
  line `receive the related instruction in such institution, for such period as may be specified by the Central`
  line `Apprenticeship Adviser or by any other person not below the rank of an Assistant Apprenticeship Adviser`
  line `authorised by the Central Apprenticeship Adviser in writing in this behalf.]`
obj_root_law_sections_10_footnotes:
  string
  line `1. Subs. by Act 27 of 1973, s. 11, for "An apprentice" (w.e.f. 1-12-1974).`
  line
  line `2. Subs. by s. 11, ibid., for "the apprentice" (w.e.f. 1-12-1974).`
  line
  line `3. Subs. by Act 36 of 2007, s. 4 (w.e.f. 1-2-2008).`
  line
  line `4. Subs. by Act 27 of 1973, s. 11, for "an apprentice" (w.e.f. 1-12-1974).`
  line
  line `5. Subs. by s. 11, ibid., for sub-section (4) (w.e.f. 1-12-1974).`
  line
  line `6. Ins. by Act 41 of 1986, s. 3 (w.e.f. 16-12-1987).`
obj_root_law_sections_11:
  sectionId (36726)
  sectionNo (11)
  orderNo 15
  title `Obligations of employers.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36726&sectionno=11&orderno=15&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_11_content:
  string
  line `Without prejudice to the other provisions of this Act, every`
  line `employer shall have the following obligations in relation to an apprentice, namely:--`
  line
  line `(a) to provide the apprentice with the training in his trade in accordance with the provisions of`
  line `this Act, and the rules made thereunder;`
  line
  line `(b) if the employer is not himself qualified in the trade, to ensure that a person ^1`
  line `[who possesses`
  line `the prescribed qualifications] is placed in charge of the training of the apprentice;^2`
  line ***
  line
  line ^3
  line `[(bb) to provide adequate instructional staff, possessing such qualifications as may be prescribed,`
  line `prescribed, for imparting practical and theoretical training and facilities for trade test of apprentices;`
  line and]
  line
  line `(c) to carry out his obligations under the contract of apprenticeship`
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by Act 27 of 1973, s. 12, for "duly qualified" (w.e.f. 1-12-1974).`
  line
  line `2. The word and omitted by Act 4 of 1997, s. 6 (w.e.f. 8-1-1997).`
  line
  line `3. Ins. by s. 6, ibid. (w.e.f. 8-1-1997).`
obj_root_law_sections_12:
  sectionId (36727)
  sectionNo (12)
  orderNo 16
  title `Obligations of apprentices.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36727&sectionno=12&orderno=16&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_12_content:
  string
  line ^2
  line `[(1)] ^3`
  line `[Every trade apprentice] undergoing apprenticeship training`
  line `training shall have the following obligations, namely:--`
  line
  line `(a) to learn his trade conscientiously and diligently and endeavour to qualify himself as a skilled`
  line `craftsman before the expiry of the period of training;`
  line
  line `(b) to attend practical and instructional classes regularly;`
  line
  line `(c) to carry out all lawful orders of his employer and superiors in the establishment; and`
  line
  line `(d) to carry out his obligations under the contract of apprenticeship.`
  line
  line ^4
  line `[(2) Every graduate or technician apprentice ^1`
  line `[technician (vocational) apprentice] undergoing`
  line `apprenticeship training shall have the following obligations, namely:--`
  line
  line `(a) to learn his subject field in engineering or technology ^1`
  line `[or vocational course] conscientiously`
  line `and diligently at his place of training;`
  line
  line `(b) to attend the practical and instructional classes regularly;`
  line
  line `(c) to carry out all lawful orders of his employer and superiors in the establishment;`
  line
  line `(d) to carry out his obligations under the contract of apprenticeship which shall include the`
  line `maintenance of such records of his work as may be prescribed.]`
obj_root_law_sections_12_footnotes:
  string
  line `1. Ins. by Act 41 of 1986, s. 3 (w.e.f. 16-12-1987).`
  line
  line `2. Section 12 re-numbered as sub-section (1) thereof by Act 27 of 1973, s. 13 (w.e.f. 1-12-1974).`
  line
  line `3. Subs. by s. 13, ibid., for "Every apprentice" (w.e.f. 1-12-1974).`
  line
  line `4. Ins. by s. 13, ibid. (w.e.f. 1-12-1974).`
obj_root_law_sections_13:
  sectionId (36728)
  sectionNo (13)
  orderNo 17
  title `Payment to apprentices.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36728&sectionno=13&orderno=17&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_13_content:
  string
  line `(1) The employer shall pay to every apprentice during the period of`
  line `apprenticeship training such stipend at a rate not less than the ^1[prescribed minimum rate, or the rate`
  line `which was being paid by the employer on 1st January, 1970 to the category of apprentices under which`
  line `such apprentice falls, whichever is higher,] as may be specified in the contract of apprenticeship and the`
  line `stipend so specified shall be paid at such intervals and subject to such conditions as may be prescribed.`
  line `^2[(2) An apprentice shall not be paid by his employer on the basis of piece work nor shall he be`
  line `required to take part in any output bonus or other incentive scheme.]`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra.
  line
  line `In section 13 of the principal Act, after the existing sub-section (1), the following sub-sections shall be inserted, namely:--`
  line
  line `(1A) The minimum rate of stipend per month payable to trade apprentices who do training for eight hours per day shall be as follows, namely:--`
  line
  line `(a) During the first year of training	. . Seventy per cent. of minimum wages of semi-skilled workers notified by the State.`
  line
  line `(b) During the second year of training	. .Eighty per cent. of minimum wages of semi-skilled workers notified by the State.`
  line
  line `(c) During the third year of training	. .Ninety per cent. of minimum wages of semi-skilled workers notified by the State.`
  line
  line `(1B) The trade apprentices who do training for minimum four hours per day, the rate of stipend per month shall be fifty per cent. of the rates mentioned in clauses (a), (b) and (c) of sub-section (1A), respectively:`
  line
  line `Provided that, in the case where the minimum rate of wage for a trade is not notified by the State, then the maximum of minimum wages of the Scheduled Employment notified by the State for semi-skilled workers shall be taken into account for paying the stipend in respect of that trade:`
  line
  line `Provided further that, in the case of trade apprentices referred to in clause (a) of section 6 of the Act, the period of training already undergone by them in a school or other institution recognized by the State Council, shall be taken into account for the purpose of determining the rate of stipend payable..`
  line
  line `[Vide Maharashtra Act 17 of 2018, s. 5].`
  line
  line Rajasthan
  line `Amendment of section 13, Central Act No. 52 of 1961.— For the existing section 13 of the`
  line `principal Act, the following shall be substituted, namely:-`
  line
  line `“13. Payment to apprentices.- The employer shall pay to every apprentice during the period of`
  line `apprenticeship training such stipend at a rate not less than the minimum wages notified by State`
  line `Government under the Minimum Wages Act, 1948 (Central Act No. 11 of 1948) for unskilled worker`
  line `category, as may be specified in the contract of apprenticeship and the stipend so specified shall be`
  line `paid at such intervals and subject to such conditions as may be prescribed.”.`
  line
  line `[Vide Rajasthan Act 2 of 2015, s. 6]`
obj_root_law_sections_13_footnotes:
  string
  line `1. Subs. by Act 27 of 1973, s. 14, for prescribed minimum rate (w.e.f. 1-12-1974).`
  line
  line `2. Subs. by s. 14, ibid., for sub-section (2) (w.e.f. 1-12-1974).`
obj_root_law_sections_14:
  sectionId (36729)
  sectionNo (14)
  orderNo 18
  title `Health, safety and welfare of apprentices.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36729&sectionno=14&orderno=18&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_14_content:
  string
  line `Where any apprentices are undergoing training in a`
  line `factory, the provisions of Chapters III, IV and V of the Factories Act, 1948 (63 of 1948), shall apply in`
  line `relation to the health, safety and welfare of the apprentices as if they were workers within the meaning of`
  line `that Act and when any apprentices are undergoing training in a mine, the provisions of Chapter V of the`
  line `Mines Act, 1952 (35 of 1952), shall apply in relation to the health and safety of the apprentices as if they`
  line `were persons employed in the mine.`
  line
  line `STATE AMENDMENT`
  line
  line Rajasthan
  line
  line `Amendment of section 14, Central Act No. 52 of 1961. For the existing section 14 of the`
  line `principal Act, the following shall be substituted, namely:-`
  line
  line `14. Health, safety and welfare of apprentices.- Where any apprentices are undergoing training in`
  line `a factory, the provisions of Chapters III, IV and V of the Factories Act, 1948 (Central Act No. 63 of`
  line `1948), shall apply in relation to the health, safety and welfare of the apprentices as if they were`
  line `workers within the meaning of that Act and when any apprentices are undergoing training in a mine,`
  line `the provisions of Chapter V of the Mines Act, 1952 (Central Act No. 35 of 1952), shall apply in`
  line `relation to the health, safety and welfare of the apprentices as if they were persons employed in the`
  line `mine and when any apprentices are undergoing training in a shop or commercial establishment, the`
  line `provisions of the Rajasthan Shops and Commercial Establishments Act,1958 (Act No. 31 of 1958),`
  line `shall apply in relation to the health, safety and welfare of the apprentices as if they were persons`
  line `employed in the shop or establishment..`
  line
  line `[Vide Rajasthan Act 2 of 2015, s. 7]`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (36730)
  sectionNo (15)
  orderNo 19
  title `Hours of work, overtime, leave and holidays.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36730&sectionno=15&orderno=19&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_15_content:
  string
  line `^1[(1) The weekly and daily hours of work of an`
  line `apprentice while undergoing practical training in a workplace shall be as determined by the employer`
  line `subject to the compliance with the training duration, if prescribed.]`
  line
  line `(2) No apprentice shall be required or allowed to work overtime except with the approval of the`
  line `Apprenticeship Adviser who shall not grant such approval unless he is satisfied that such overtime is in`
  line `the interest of the training of the apprentice or in the public interest.`
  line
  line `^2[(3) An apprentice shall be entitled to such leave and holidays as are observed in the establishment in`
  line `in which he is undergoing training.]`
obj_root_law_sections_15_footnotes:
  string
  line `1. Subs. by Act 29 of 2014, s. 9, for sub-section (1) (w.e.f. 22-12-2014).`
  line
  line `2. Subs. by s. 9, ibid., for sub-section (3) (w.e.f. 22-12-2014).`
obj_root_law_sections_16:
  sectionId (36731)
  sectionNo (16)
  orderNo 20
  title `Employer‟s liability for compensation for injury.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36731&sectionno=16&orderno=20&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_16_content:
  string
  line `If personal injury is caused to an apprentice`
  line `by accident arising out of and in the course of his training as an apprentice, his employer shall be liable to`
  line `pay compensation which shall be determined and paid, so far as may be, in accordance with the`
  line `provisions of the Workmen's Compensation Act, 1923 (8 of 1923), subject to the modifications specified`
  line `in the Schedule.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (36732)
  sectionNo (17)
  orderNo 21
  title `Conduct and discipline.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by Act 27 of 1973, s. 15, for "applicable to workers in the trade" (w.e.f. 1-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36732&sectionno=17&orderno=21&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_17_content:
  string
  line `In all matters of conduct and discipline, the apprentice shall be`
  line `governed by the rules and regulations ^1[applicable to employees of the corresponding category] in the`
  line `establishment in which the apprentice is undergoing training.`
obj_root_law_sections_18:
  sectionId (36733)
  sectionNo (18)
  orderNo 22
  title `Apprentices are trainees and not workers.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36733&sectionno=18&orderno=22&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_18_content:
  string
  line `Save as otherwise provided in this Act,--`
  line
  line `(a) every apprentice undergoing apprenticeship training in a designated trade in an establishment`
  line `shall be a trainee and not a worker; and`
  line
  line `(b) the provisions of any law with respect to labour shall not apply to or in relation to such`
  line apprentice
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (36734)
  sectionNo (19)
  orderNo 23
  title `Records and returns.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by Act 29 of 2014, s. 10, for sub-section (2) (w.e.f. 22-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36734&sectionno=19&orderno=23&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_19_content:
  string
  line `(1) Every employer shall maintain records of the progress of training of`
  line `each apprentice undergoing apprenticeship training in his establishment in such form as may be`
  line prescribed.
  line
  line `^1[(2) Until a portal-site is developed by the Central Government, every employer shall furnish such`
  line `information and return in such form as may be prescribed, to such authorities at such intervals as may be`
  line prescribed.
  line
  line `(3) Every employer shall also give trade-wise requirement and engagement of apprentices in respect`
  line `of apprenticeship training on portal-site developed by the Central Government in this regard.]`
obj_root_law_sections_20:
  sectionId (36735)
  sectionNo (20)
  orderNo 24
  title `Settlement of disputes.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36735&sectionno=20&orderno=24&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_20_content:
  string
  line `(1) Any disagreement or dispute between an employer and an`
  line `apprentice arising out of the contract of apprenticeship shall be referred to the Apprenticeship Adviser for`
  line decision.
  line
  line `(2) Any person aggrieved by the decision of the Apprenticeship Adviser under sub-section (1) may,`
  line `within thirty days from the date of communication to him of such decision, prefer an appeal against the`
  line `decision to the Apprenticeship Council and such appeal shall be heard and determined by a Committee of`
  line `that Council appointed for the purpose.`
  line
  line `(3) The decision of the Committee under sub-section (2) and subject only to such decision, the`
  line `decision of the Apprenticeship Adviser under sub-section (1) shall be final.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (36736)
  sectionNo (21)
  orderNo 25
  title `Holding of test and grant of certificate and conclusion of training.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36736&sectionno=21&orderno=25&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_21_content:
  string
  line `^1[(1) Every trade`
  line `apprentice who has completed the period of training may appear for a test to be conducted by the National`
  line `Council or any other agency authorised by the Central Government to determine his proficiency in the`
  line `designated trade in which he has undergone apprenticeship training].`
  line
  line `(2) Every ^2[trade apprentice] who passes the test referred to in sub-section (1) shall be granted a`
  line `certificate of proficiency in the trade by the National Council ^3[or by the other agency authorised by the`
  line `Central Government].`
  line
  line `^4[(3) The progress in apprenticeship training of every graduate or technician apprentice ^5[technician`
  line `(vocational) apprentice] shall be assessed by the employer from time to time.`
  line
  line `^6[(4) Every graduate or technician apprentice or technician (vocational) apprentice, who completes his`
  line `his apprenticeship training to the satisfaction of the concerned Regional Board, shall be granted a`
  line `certificate of proficiency by that Board.]]`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra.
  line
  line `In section 21 of the principal Act,--`
  line
  line `(i) after the existing sub-section (1), the following sub-section shall be inserted, namely:--`
  line
  line `“(1A) For apprentices successfully completed the training period in the trade designated by the State Apprenticeship Council (other than the trade designated and prescribed by the Central Government), may appear for a test to be conducted by the State Council of Vocational Training or any other agency authorised by the State Government to determine his proficiency in the trade designated by the State Apprenticeship Council in which he has undergone apprenticeship training.”;`
  line
  line `(ii) after the existing sub-section (2), the following sub-section shall be inserted, namely:--`
  line
  line `“(2A) Every apprentice, who passes the test referred to in sub-section (1A) shall be granted a certificate of proficiency in the trade by the State Council of Vocational Training or by the other agency authorised by the State Government.”.`
  line
  line `[Vide Maharashtra Act 17 of 2018, s. 6].`
obj_root_law_sections_21_footnotes:
  string
  line `1. Subs. by Act 29 of 2014, s. 11, for sub-section (1) (w.e.f. 22-12-2014).`
  line
  line `2. Subs. by Act 27 of 1973, s. 16, for "apprentice" (w.e.f. 1-12-1974).`
  line
  line `3. Ins. by Act 29 of 2014, s. 11 (w.e.f. 22-12-2014).`
  line
  line `4. Ins. by Act 27 of 1973, s. 16 (w.e.f. 1-12-1974).`
  line
  line `5. Ins. by Act 41 of 1986, s. 3 (w.e.f. 16-12-1987).`
  line
  line `6. Subs. by s. 6, ibid., for sub-section (4) (w.e.f. 16-12-1987).`
obj_root_law_sections_22:
  sectionId (36737)
  sectionNo (22)
  orderNo 26
  title `Offer and acceptance of employment.`
  content obj_root_law_sections_22_content
  footnotes `1. Subs. by Act 29 of 2014, s. 12, for sub-section (1) (w.e.f. 22-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36737&sectionno=22&orderno=26&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_22_content:
  string
  line `^1[(1) Every employer shall formulate its own policy for`
  line `recruiting any apprentice who has completed the period of apprenticeship training in his establishment.]`
  line
  line `(2) Notwithstanding anything in sub-section (1), where there is a condition in a contract of`
  line `apprenticeship that the apprentice shall, after the successful completion of the apprenticeship training,`
  line `serve the employer, the employer shall, on such completion, be bound to offer suitable employment to the`
  line `apprentice, and the apprentice shall be bound to serve the employer in that capacity for such period and`
  line `on such remuneration as may be specified in the contract:`
  line
  line `Provided that where such period or remuneration is not, in the opinion of the Apprenticeship Adviser,`
  line `reasonable, he may revise such period or remuneration so as to make it reasonable, and the period or`
  line `remuneration so revised shall be deemed to be the period or remuneration agreed to between the`
  line `apprentice and the employer.`
obj_root_law_sections_23:
  sectionId (36738)
  sectionNo (23)
  orderNo 27
  title Authorities.
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36738&sectionno=23&orderno=27&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_23_content:
  string
  line `(1) In addition to the Government there shall be the following authorities under`
  line `this Act, namely:--`
  line
  line `(a) The National Council,`
  line
  line `(b) The Central Apprenticeship Council,`
  line
  line `(c) The State Council,`
  line
  line `(d) The State Apprenticeship Council,`
  line
  line `^1[(e)] The All India Council,`
  line
  line `(f) The Regional Boards,`
  line
  line `(g) The Boards or State Councils of Technical Education,`
  line
  line `^2[(h)] The Central Apprenticeship Adviser, and`
  line
  line `^3[(i)] The State Apprenticeship Adviser.`
  line
  line `(2) Every State Council shall be affiliated to the National Council and every State Apprenticeship`
  line `Council shall be affiliated to the Central Apprenticeship Council.`
  line
  line `^1[(2A) Every Board or State Council of Technical Education and every Regional Board shall be`
  line `affiliated to the Central Apprenticeship Council.]`
  line
  line `(3) Each of the authorities specified in sub-section (1) shall, in relation to apprenticeship training`
  line `under this Act, perform such functions as are assigned to it by or under this Act or by the Government:`
  line
  line `Provided that a State Council shall also perform such functions as are assigned to it by the National`
  line `Council and the State Apprenticeship Council ^1[and the Board or State Council of Technical Education]`
  line `shall also perform such functions as are assigned to it by the Central Apprenticeship Council.`
  line
  line `STATE AMENDMENT`
  line
  line Rajasthan
  line
  line `Amendment of section 23, Central Act No. 52 of 1961.— For the existing sub-section (2)`
  line `of section 23 of the principal Act, the following shall be substituted, namely:-`
  line
  line `“(2) Every State Council may be affiliated to the National Council and every State`
  line `Apprenticeship Council may be affiliated to the Central Apprenticeship Council.”.`
  line
  line `[Vide Rajasthan Act 2 of 2015, s. 7]`
obj_root_law_sections_23_footnotes:
  string
  line `1. Ins. by Act 27 of 1973, s. 17 (w.e.f. 1-12-1974).`
  line
  line `2. Item (e) re-lettered as item (h) thereof by s. 17, ibid. (w.e.f. 1-12-1974).`
  line
  line `3. Item (f) re-lettered as item (i) thereof by s. 17, ibid. (w.e.f. 1-12-1974).`
obj_root_law_sections_24:
  sectionId (36739)
  sectionNo (24)
  orderNo 28
  title `Constitution of Councils.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36739&sectionno=24&orderno=28&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_24_content:
  string
  line `(1) The Central Government shall, by notification in the Official`
  line `Gazette, establish the Central Apprenticeship Council and the State Government shall, by notification in`
  line `the Official Gazette, establish the State Apprenticeship Council.`
  line
  line `(2) The Central Apprenticeship Council shall consist of ^1`
  line `[a Chairman and a Vice-Chairman] and such`
  line `such number of other members as the Central Government may think expedient, to be appointed by that`
  line `Government by notification in the Official Gazette from among the following categories of persons,`
  line `namely:--`
  line
  line `(a) representatives of employers in establishments in the public and private sectors,`
  line
  line `(b) representatives of the Central Government and of the State Governments, ^2`
  line ***
  line
  line `(c) persons having special knowledge and experience on matters relating to ^3`
  line `[industry, labour and`
  line `and technical education, and]`
  line
  line ^4
  line `[(d) representatives of the All India Council and of the Regional Boards.]`
  line
  line `(3) The number of persons to be appointed as members of the Central Apprenticeship Council from`
  line `each of the categories specified in sub-section (2), the term of office of, the procedure to be followed in`
  line `the discharge of their functions by, and the manner of filling vacancies among, the members of the`
  line `Council shall be such as may be prescribed.`
  line
  line `(4) The State Apprenticeship Council shall consist of ^1`
  line `[a Chairman and a Vice-Chairman] and such`
  line `number of other members as the State Government may think expedient, to be appointed by that`
  line `Government by notification in the Official Gazette from among the following categories of persons,`
  line `namely:--`
  line
  line `(a) representatives of employers in establishments in the public and private sectors,`
  line
  line `(b) representatives of the Central Government and of the State Government ^2`
  line ***
  line
  line `(c) persons having special knowledge and experience of matters relating to ^3`
  line `[industry, labour and`
  line `technical education, and]`
  line
  line ^4
  line `[(d) representatives of the Board or of the State Council of Technical Education.]`
  line
  line `(5) The number of persons to be appointed as members of the State Apprenticeship Council from`
  line `each of the categories specified in sub-sections (4), the term of office of, the procedure to be followed in`
  line `the discharge of their functions by, and the manner of filling vacancies among, the members of the`
  line `Council shall be such as the State Government may, by notification in the Official Gazette, determine.`
  line
  line `(6) The fees and allowances, if any, to be paid to ^5`
  line `[the Chairman and the Vice-Chairman] and the`
  line `other members of the Central Apprenticeship Council, shall be such as may be determined by the Central`
  line `Government and the fees and allowances, if any, to be paid to ^5`
  line `[the Chairman and the Vice-Chairman]`
  line `and the other members of the State Apprenticeship Council shall be such as may be determined by the`
  line `State Government.`
obj_root_law_sections_24_footnotes:
  string
  line `1 Subs. by s. 18, ibid., for "a Chairman" (w.e.f. 1-12-1974).`
  line
  line `2. The word "and" omitted by s. 18, ibid. (w.e.f. 1-12-1974).`
  line
  line `3. Subs. by s. 18, ibid., for "industry and labour" (w.e.f. 1-12-1974).`
  line
  line `4. Ins. by s. 18, ibid. (w.e.f. 1-12-1974).`
  line
  line `5. Subs. by Act 27 of 1973, s. 18, for "the Chairman" (w.e.f. 1-12-1974)`
obj_root_law_sections_25:
  sectionId (36740)
  sectionNo (25)
  orderNo 29
  title `Vacancies not to invalidate acts and proceedings.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36740&sectionno=25&orderno=29&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_25_content:
  string
  line `No act done or proceeding taken by the`
  line `National Council, the Central Apprenticeship Council, the State Council or the State Apprenticeship`
  line `Council under this Act shall be questioned on the ground merely of the existence of any vacancy in, or`
  line `defect in the constitution of, such Council.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (36741)
  sectionNo (26)
  orderNo 30
  title `Apprenticeship Advisers.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36741&sectionno=26&orderno=30&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_26_content:
  string
  line `(1) The Central Government shall, by notification in the Official`
  line `Gazette, appoint a suitable person as the Central Apprenticeship Adviser.`
  line
  line `(2) The State Government shall, by notification in the Official Gazette, appoint a suitable person as`
  line `the State Apprenticeship Adviser.`
  line
  line `(3) The Central Apprenticeship Adviser shall be the Secretary to the Central Apprenticeship Council`
  line `and the State Apprenticeship Adviser shall be Secretary to the State Apprenticeship Council.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (36742)
  sectionNo (27)
  orderNo 31
  title `Deputy and Assistant Apprenticeship Advisers.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36742&sectionno=27&orderno=31&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_27_content:
  string
  line `(1) The Government ^1[may appoint suitable`
  line `persons as Additional, Joint, Regional, Deputy and Assistant Apprenticeship Advisers] to assist the`
  line `Apprenticeship Adviser in the performance of his functions.`
  line
  line `(2)`
  line `^2[Every Additional, Joint, Regional, Deputy or Assistant Apprenticeship Adviser shall, subject to`
  line `the control of the Apprenticeship Adviser], perform such functions as may be assigned to him by the`
  line `Apprenticeship Adviser.`
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by s. 19, ibid., for "may appoint suitable persons as Deputy and Assistant Apprenticeship Advisers" (w.e.f. 1-12-1974).`
  line
  line `2. Subs. by s. 19, ibid., for "Every Deputy or Assistant Apprenticeship Advisers" (w.e.f. 1-12-1974).`
obj_root_law_sections_28:
  sectionId (36743)
  sectionNo (28)
  orderNo 32
  title `Apprenticeship Advisers to be public servants.`
  content obj_root_law_sections_28_content
  footnotes `1. Subs. by s. 20, ibid., for "every Deputy or Assistant Apprenticeship Advisers" (w.e.f. 1-12-1974).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36743&sectionno=28&orderno=32&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_28_content:
  string
  line `Every Apprenticeship Adviser and ^1[every`
  line `Additional, Joint, Regional, Deputy or Assistant Apprenticeship Adviser] appointed under this Act shall`
  line `be deemed to be a public servant within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_29:
  sectionId (36744)
  sectionNo (29)
  orderNo 33
  title `Powers of entry, inspection, etc.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36744&sectionno=29&orderno=33&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_29_content:
  string
  line `(1) Subject to any rules made in this behalf, the ^1[Central`
  line `Apprenticeship Adviser or such other person, not below the rank of an Assistant Apprenticeship Adviser,`
  line `as may be authorised by the Central Apprenticeship Adviser in writing in this behalf] may--`
  line
  line `(a) with such assistants, if any, as he thinks fit, enter, inspect and examine any establishment or`
  line `part thereof at any reasonable time;`
  line
  line `(b) examine any apprentice employed therein or require the production of any register, record or`
  line `other documents maintained in pursuance of this Act and take on the spot or otherwise statements of`
  line `any person which he may consider necessary for carrying out the purposes of this Act;`
  line
  line `(c) make such examination and inquiry as he thinks fit in order to ascertain whether the`
  line `provisions of this Act and the rules made thereunder are being observed in the establishment;`
  line
  line `(d) exercise such other powers as may be prescribed:`
  line
  line `Provided that ^2[a State Apprenticeship Adviser or such other person, not below the rank of an`
  line `Assistant Apprenticeship Adviser, as may be authorised by the State Apprenticeship Adviser in writing in this behalf] may also exercise any of the powers specified in clause (a), (b), (c) or (d) of this`
  line `sub-section in relation to establishments for which the appropriate Government is the State Government.`
  line
  line `(2) Notwithstanding anything in sub-section (1), no person shall be compelled under this section to`
  line `answer any question or make any statement which may tend directly or indirectly to incriminate him.`
obj_root_law_sections_29_footnotes:
  string
  line `1. Subs. by s. 21, ibid., for "Central Apprenticeship Adviser" (w.e.f. 1-12-1974).`
  line
  line `2. Subs. by s. 21, ibid., for "a State Apprenticeship Advisers" (w.e.f. 1-12-1974)`
obj_root_law_sections_30:
  sectionId (36745)
  sectionNo (30)
  orderNo 34
  title `Offences and penalties.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36745&sectionno=30&orderno=34&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_30_content:
  string
  line `^1[(1) If any employer contravenes the provisions of this Act relating to`
  line `the number of apprentices which he is required to engage under those provisions, he shall be given a`
  line `month's notice in writing, by an officer duly authorised in this behalf by the appropriate Government, for`
  line `explaining the reasons for such contravention.`
  line
  line `(1A) In case the employer fails to reply the notice within the period specified under sub-section (1), or`
  line `the authorised officer, after giving him an opportunity of being heard, is not satisfied with the reasons`
  line `given by the employer, he shall be punishable with fine of five hundred rupees per shortfall of`
  line `apprenticeship month for first three months and thereafter one thousand rupees per month till such`
  line `number of seats are filled up.]`
  line
  line `(2) If any employer or any other person--`
  line
  line `(a) required to furnish any information or return--`
  line
  line `(i) refuses or neglects to furnish such information or return, or`
  line
  line `(ii) furnishes or causes to be furnished any information or return which is false and which he`
  line `either knows or believes to be false or does not believe to be true, or`
  line
  line `(iii) refuses to answer, or gives a false answer to any question necessary for obtaining any`
  line `information required to be furnished by him, or`
  line
  line `(b) refuses or wilfully neglects to afford ^2[the Central or the State Apprenticeship Adviser or such`
  line `other person, not below the rank of an Assistant Apprenticeship Adviser, as may be authorised by the`
  line `Central or the State Apprenticeship Adviser in writing in this behalf], any reasonable facility for`
  line `making any entry, inspection, examination or inquiry authorised by or under this Act, or`
  line
  line `(c) requires an apprentice to work overtime without the approval of the Apprenticeship`
  line `Adviser, or`
  line
  line `(d) employs an apprentice on any work which is not connected with his training, or`
  line
  line `(e) makes payment to an apprentice on the basis of piecework, or`
  line
  line `(f) requires an apprentice to take part in any output bonus or incentive scheme,`
  line
  line `^3[(g) engages as an apprentice a person who is not qualified for being so engaged, or`
  line
  line `(h) fails to carry out the terms and conditions of a contract of apprenticeship.]`
  line
  line `he shall be punishable with ^4`
  line `[fine of one thousand rupees for every occurrence].`
  line
  line `^3[(2A) The provisions of this section shall not apply to any establishment or industry which is under`
  line `the Board for Industrial and Financial Reconstruction established under the Sick Industrial Companies`
  line `(Special Provisions) Act, 1985 (1 of 1986).]`
obj_root_law_sections_30_footnotes:
  string
  line `1. Subs. by Act 29 of 2014, s. 13, for sub-section (1) (w.e.f. 22-12-2014).`
  line
  line `2. Subs. by Act 27 of 1973, s. 22, for "the Central or the State Apprenticeship Advisers" (w.e.f. 1-12-1974).`
  line
  line `3. Ins. by Act 29 of 2014, s. 13 (w.e.f. 22-12-2014).`
  line
  line `4. Subs. by s. 13, ibid., for "imprisonment for a term which may extend to six months or with fine or with both"`
  line `(w.e.f. 22-12-2014).`
obj_root_law_sections_31:
  sectionId (36746)
  sectionNo (31)
  orderNo 35
  title `Penalty where no specific penalty is provided.`
  content obj_root_law_sections_31_content
  footnotes `1. Subs. by Act 4 of 1997, s. 7, for "which may extend to five hundred rupees" (w.e.f. 8-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36746&sectionno=31&orderno=35&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_31_content:
  string
  line `If any employer or any other person`
  line `contravenes any provision of this Act for which no punishment is provided in section 30, he shall be`
  line `punishable with fine ^1[which shall not be less than one thousand rupees but may extend to three thousand`
  line rupees].
obj_root_law_sections_32:
  sectionId (36747)
  sectionNo (32)
  orderNo 36
  title `Offences by companies.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36747&sectionno=32&orderno=36&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_32_content:
  string
  line `(1) If the person committing an offence under this Act is a company,`
  line `every person who, at the time the offence was committed was in charge of, and was responsible to, the company for the conduct of business of the company, as well as the company, shall be deemed to be`
  line `guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to such`
  line `punishment provided in this Act if he proves that the offence was committed without his knowledge or`
  line `that he exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any negligence on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary, or other officer shall also be deemed to be`
  line `guilty of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means a body corporate and includes a firm or other association of`
  line `individuals; and`
  line
  line `(b) "director" in relation to a firm means a partner in the firm`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (36748)
  sectionNo (33)
  orderNo 37
  title `Cognizance of offences.`
  content obj_root_law_sections_33_content
  footnotes `!. Ins. by Act 4 of 1997, s. 8 (w.e.f. 8-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36748&sectionno=33&orderno=37&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_33_content:
  string
  line `No court shall take cognizance of any offence under this Act or`
  line `the rules made thereunder except on a complaint thereof in writing made by the Apprenticeship`
  line `Adviser ^1[or the officer of the rank of Deputy Apprenticeship Adviser and above] within six months from`
  line `the date on which the offence is alleged to have been committed.`
obj_root_law_sections_34:
  sectionId (36749)
  sectionNo (34)
  orderNo 38
  title `Delegation of powers.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36749&sectionno=34&orderno=38&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_34_content:
  string
  line `The appropriate Government may, by notification in the Official`
  line `Gazette, direct that any power exercisable by it under this Act or the rules made thereunder shall, in`
  line `relation to such matters and subject to such conditions, if any, as may be specified in the direction, be`
  line `exercisable also--`
  line
  line `(a) where the appropriate Government is the Central Government, by such officer or authority`
  line `subordinate to the Central Government or by the State Government or by such officer or authority`
  line `subordinate to the State Government, as may be specified in the notification; and`
  line
  line `(b) where the appropriate Government is the State Government, by such officer or authority`
  line `subordinate to the State Government as may be specified in the notification.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (36750)
  sectionNo (35)
  orderNo 39
  title `Construction of references.`
  content obj_root_law_sections_35_content
  footnotes `1. Subs. by Act 27 of 1973, s. 23, for "a Deputy or Assistant Apprenticeship Adviser" (w.e.f. 1-12-1974)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36750&sectionno=35&orderno=39&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_35_content:
  string
  line `(1) Any reference in this Act or in the rules made thereunder to the`
  line `Apprenticeship Council shall, unless the context otherwise requires, mean in relation to apprenticeship`
  line `training in a designated trade in an establishment in relation to which the Central Government is the`
  line `appropriate Government, the Central Apprenticeship Council and in relation to apprenticeship training in`
  line `a designated trade in an establishment in relation to which the State Government is the appropriate`
  line `Government, the State Apprenticeship Council.`
  line
  line `(2) Any reference in this Act or in the rules made thereunder to the Apprenticeship Adviser shall,`
  line `unless the context otherwise requires,--`
  line
  line `(a) mean in relation to apprenticeship training in a designated trade in an establishment in relation`
  line `to which the Central Government is the appropriate Government, the Central Apprenticeship Adviser`
  line `and in relation to apprenticeship training in a designated trade in an establishment in relation to which`
  line `the State Government is the appropriate Government, the State Apprenticeship Adviser;`
  line
  line `(b) be deemed to include ^1[an Additional, a Joint, a Regional, a Deputy or an Assistant`
  line `Apprenticeship Adviser] performing the functions of the Apprenticeship Adviser assigned to him`
  line `under sub-section (2) of section 27.`
obj_root_law_sections_36:
  sectionId (36751)
  sectionNo (36)
  orderNo 40
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36751&sectionno=36&orderno=40&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_36_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against any person for anything which is in good faith done or intended to be done under this Act.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (36752)
  sectionNo (37)
  orderNo 41
  title `Power to make rules.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_6_6_00016_196152_1517807321778&sectionId=36752&sectionno=37&orderno=41&orgactid=AC_CEN_6_6_00016_196152_1517807321778
obj_root_law_sections_37_content:
  string
  line `(1) The Central Government may, after consulting the Central`
  line `Apprenticeship Council, by notification in the Official Gazette, make rules for carrying out the purposes`
  line `of this Act.`
  line
  line `^1[(1A) The powers to make rules under this section shall include the power to make such rules or any`
  line `of them retrospectively from a date not earlier than the date on which this Act received the assent of the`
  line `President, but no such retrospective effect shall be given to any such rule so as to prejudicially affect the`
  line `interests of any person to whom such rule may be applicable.]`
  line
  line `(2) Rules made under this Act may provide that a contravention of any such rule shall be punishable`
  line `with fine which may extend to fifty rupees.`
  line
  line `(3) Every rule made under this section shall be laid as soon as may be after it is made before each`
  line `House of Parliament which it is in session for a total period of thirty days which may be comprised in one`
  line `session ^2[or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid] both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so however that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_37_footnotes:
  string
  line `1. Ins. by Act 29 of 2014, s. 14 (w.e.f. 22-12-2014).`
  line
  line `2. Subs. by Act 27 of 1973, s. 24, for certain words (w.e.f. 1-12-1974).`
