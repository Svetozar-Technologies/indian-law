obj_root_law_sections_27:
  sectionId (38418)
  sectionNo (27)
  orderNo 30
  title `Repeal and saving.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00005_200345_1517807323069&sectionId=38418&sectionno=27&orderno=30&orgactid=AC_CEN_26_36_00005_200345_1517807323069
obj_root_law_sections_27_content:
  string
  line `(1) The Government of India in the Ministry of Personnel, Public`
  line `Grievances and Pensions (Department of Personnel and Training) Resolution No. 371/20/99-AVD. III,`
  line `dated the 4th April, 1999 as amended vide Resolution of even number, dated the 13th August, 2002 is`
  line `hereby repealed.`
  line
  line `(2) Notwithstanding such repeal and the cesser of operation of the Central Vigilance Commission`
  line `Ordinance, 1999 (Ord. 4 of 1999), anything done or any action taken under the said Resolution and the`
  line `said Ordinance including the appointments made and other actions taken or anything done or any action`
  line `taken or any appointment made under the Delhi Special Police Establishment Act, 1946 (25 of 1946) and`
  line `the Foreign Exchange Regulation Act, 1973 (46 of 1973) as amended by the said Ordinance shall be`
  line `deemed to have been made or done or taken under this Act or the Delhi Special Police Establishment Act,`
  line `1946 and the Foreign Exchange Regulation Act, 1973 as if the amendments made in those Acts by this`
  line `Act were in force at all material times.`
obj_root_law_sections_27_footnotes:
  string
  line
