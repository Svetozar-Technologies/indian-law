  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `18. जािकारी मांगिे की शधक्त।`
  line `19. कधतपय मामिों में आयोग से परामशक ककया जािा।`
  line `20. धियम बिािे की शधक्त।`
  line `21. धवधियम बिािे की शधक्त।`
  line `22. अधिसूचिा, धियम आकद का संसद् के समि रखा जािा।`
  line `23. करठिाइयों को दूर करिे की शधक्त।`
  line `24. धवद्यमाि सतककता आयोग से संबंधित उपबंि।`
  line `25. प्र वतकि धिदेशािय के अधिकाररयों की धियुधक्त, आकद।`
  line `26. 1946 के अधिधियम संखयां क 25 का संशोिि।`
  line `27. धिरसि और व् या व धि।`
  line अिुसूची।
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
