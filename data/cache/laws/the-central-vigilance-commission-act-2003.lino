  (str title) (str `The Central Vigilance Commission Act, 2003`)
  (str actNumber) (str 45)
  (str enactmentDate) (str 2003-09-11)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2067`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `केन्द्रीय सतर्कता आयोग अधिनियम, 2003`)
  (str actYear) (str 2003)
  (str ministry) (str `Ministry of Personnel, Public Grievances and Pensions`)
  (str department) (str `Department of Personnel and Training`)
  (str longTitle) (str `An Act to provide for the constitution of a Central Vigilance Commission to inquire or cause inquiries to be conducted into offences alleged to have been committed under the Prevention of Corruption Act, 1988 by certain categories of public servants of the Central Government, corporations established by or under any Central Act, Government companies, societies and local authorities owned or controlled by the Central Government and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 11-09-2003)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T12:04:57.476Z`)
