obj_root_law_sections_1:
  object
  (str sectionId) (str 39000)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Title, extent and saving.`)
  (str content) (str `(1) This Act may be called the Partition Act, 1893.

(2) It extends to the whole of India ^1*** ^2***.

^3*****

(4) But nothing herein contained shall be deemed to affect any local law providing for the partition of immoveable property paying revenue to Government.`)
  (str footnotes) (str `1. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule
(w.e.f. 31-10-2019)..

2. The word "and" rep. by Act 10 of 1914, s. 3 and the Second Schedule.

3. Sub-section (3) rep. by s. 3 and the Second Schedule, ibid.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39000&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_2:
  object
  (str sectionId) (str 39001)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Power to court to order sale instead of division in partition suits.`)
  (str content) (str `Whenever in any suit for
partition in which, if instituted prior to the commencement of this Act, a decree for partition might have
been made, it appears to the court that, by reason of the nature of the properly to which the suit relates, or
of the number of the shareholders therein, or of any other special circumstance, a division of the property
cannot reasonably or conveniently be made, and that a sale of the property and distribution of the
proceeds would be more beneficial for all the shareholders, the court may, if it thinks fit, on the request of
any of such shareholders interested individually or collectively to the extent of one moiety or upwards,
direct a sale of the property and a distribution of the proceeds.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39001&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_3:
  object
  (str sectionId) (str 39002)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Procedure when sharer undertakes to buy.`)
  (str content) (str `(1) If, in any case in which the court is requested
under the last foregoing section to direct a sale, any other shareholder applies for leave to buy at a
valuation the share or shares of the party or parties asking for a sale, the court shall order a valuation of
the share or shares in such manner as it may think fit and offer to sell the same to such shareholder at the
price so ascertained, and may give all necessary and proper directions in that behalf.

(2) If two or more shareholders severally apply for leave to buy as provided in sub-section (1), the
court shall order a sale of the share or shares to the shareholder who offers to pay the highest price above
the valuation made by the court.

(3) If no such shareholder is willing to buy such share or shares at the price so ascertained, the
applicant or applicants shall be liable to pay all costs of or incident to the application or applications.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39002&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_4:
  object
  (str sectionId) (str 39003)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Partition suit by transferee of share in dwelling-house.`)
  (str content) (str `(1) Where a share of a dwelling-house
belonging to an undivided family has been transferred to a person who is not a member of such family
and such transferee sues for partition, the court shall, if any member of the family being a shareholder
shall undertake to buy the share of such transferee, make a valuation of such share in such manner as it
thinks fit and direct the sale of such share to such shareholder, and may give all necessary and proper
directions in that behalf.

(2) If in any case described in sub-section (1) two or more members of the family being such
shareholders severally undertake to buy such share, the court shall follow the procedure prescribed by
sub-section (2) of the last foregoing section.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39003&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_5:
  object
  (str sectionId) (str 39004)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Representation of parties under disability.`)
  (str content) (str `In any suit for partition a request for sale may be
made or an undertaking, or application for leave, to buy may be given or made on behalf of any party
under disability by any person authorised to act on behalf of such party in such suit, but the court shall not
be bound to comply with any such request, undertaking or application unless it is of opinion that the sale
or purchase will be for the benefit of the party under such disability.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39004&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_6:
  object
  (str sectionId) (str 39005)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Reserved bidding and bidding by shareholders.`)
  (str content) (str `(1) Every sale under section 2 shall be subject
to a reserved bidding, and the amount of such bidding shall be fixed by the court in such manner as it may
think fit and may be varied from time to time.

(2) On any such sale any of the shareholders shall be at liberty to bid at the sale on such terms as to
non-payment of deposit or as to setting off or accounting for the purchase-money or any part thereof
instead of paying the same as to the court may seem reasonable.

(3) If two or more persons, of whom one is a shareholder in the property, respectively advance the
same sum at any bidding at such sale, such bidding shall be deemed to be the bidding of the shareholder.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39005&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_7:
  object
  (str sectionId) (str 39006)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Procedure to be followed in case of sales.`)
  (str content) (str `Save as hereinbefore provided, when any property is
directed to be sold under this Act, the following procedure shall, as far as practicable, be adopted,
namely:--

(a) if the property be sold under a decree or order of the High Court of Calcutta, Madras or
Bombay, in the exercise of its original jurisdiction, ^1*** the procedure of such court in its original
civil jurisdiction for the sale of property by the Registrar;

(b) if the property be sold under a decree or order of any other court, such procedure as the High
Court may from time to time by rules prescribe in this behalf, and until such rules-art made the
procedure prescribed in the Code of Civil Procedure in respect of sales in execution of decrees.`)
  (str footnotes) (str `1 The words "or of the Court of the Recorder of Rangoon" omitted by the A.O. 1937.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39006&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_8:
  object
  (str sectionId) (str 39007)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str `Orders for sale to be deemed decrees.`)
  (str content) (str `Any order for sale made by the court under section 2, 3
or 4 shall be deemed to be a decree within the meaning of section 2 of the ^1Code of Civil Procedure (14 of
1882).`)
  (str footnotes) (str `1 . See now the Code of Civil Procedure, 1908 (Act 5 of 1908).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39007&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_9:
  object
  (str sectionId) (str 39008)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str `Saving of power to order partly partition and partly sale.`)
  (str content) (str `In any suit for partition the court
may, if it shall think fit, make a decree for a partition of part of the property to which the suit relates and a
sale of the remainder under this Act`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39008&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
obj_root_law_sections_10:
  object
  (str sectionId) (str 39009)
  (str sectionNo) (str 10)
  (str orderNo) (int 10)
  (str title) (str `Application of Act to pending suits.`)
  (str content) (str `This Act shall apply to suits instituted before the
commencement thereof, in which no scheme for the partition of the partition has been finally approved by
the court`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00070_189304_1547448130517&sectionId=39009&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00070_189304_1547448130517)
