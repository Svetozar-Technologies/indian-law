obj_root_law_sections_32:
  sectionId (34415)
  sectionNo (32)
  orderNo 32
  title `Appointment of places for confinement of persons under sentence of transportation and removal thereto.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00018_190003_1523339448591&sectionId=34415&sectionno=32&orderno=32&orgactid=AC_CEN_5_40_00018_190003_1523339448591
obj_root_law_sections_32_content:
  string
  line ^1
  line `[(1)] The ^2`
  line `[State Government] may appoint places`
  line `within ^3`
  line `[the State] to which persons under sentence of transportation shall be sent; and the ^2`
  line [State
  line `Government], or some officer duly authorised in this behalf by the ^2`
  line `[State Government], shall give`
  line `orders for the removal of such persons to the places so appointed, except when sentence of`
  line `transportation is passed on a person already undergoing transportation under a sentence previously`
  line `passed for another offence.`
  line
  line ^4
  line `[(2) In any case in which the State Government is competent under sub-section (1) to appoint`
  line `places within the States and to order the removal thereto of persons under sentence of transportation,`
  line `the State Government may appoint such places in any other State by agreement with State`
  line `Government of that State, and may by like agreement give orders or duly authorise some officer to`
  line `give orders for the removal thereto of such persons.]`
obj_root_law_sections_32_footnotes:
  string
  line `1. Section 32 was re-numbered as sub-section (1) of that section by Act 38 of 1920, s. 2 and the First Schedule.`
  line
  line `2. Subs. by s. 2, and the First Schedule, Pt. I, ibid., for G.G. in C.`
  line
  line `3. Subs. by s. 2 and the First Schedule, Pt. I, ibid., for "British India".`
  line
  line `4. Ins. by s. 2 and the First Schedule, ibid.`
