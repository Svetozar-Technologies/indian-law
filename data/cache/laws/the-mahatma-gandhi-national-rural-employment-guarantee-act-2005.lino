obj_root_law:
  slug the-mahatma-gandhi-national-rural-employment-guarantee-act-2005
  handle (2014)
  collectionHandle 123456789/1362
  title `The Mahatma Gandhi National Rural Employment Guarantee Act, 2005`
  actNumber (42)
  enactmentDate 2005-09-05
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2014`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (2005)
  ministry `Ministry of Rural Development`
  department `Department of Rural Development`
  longTitle `An Act to provide for the enhancement of livelihood security of the households in rural areas of the country by providing at least one hundred days of guaranteed wage employment in every financial year to every household whose adult members volunteer to do unskilled manual work and for matters connected therewith or incidental thereto..`
  enforcementDate 02-02-2006
  notification `2nd February, 2006, vide notification No. S.O. 87(E), dated 24th January, 2006, see Gazette of India, Extraordinary, Part II sec.3 (ii).`
  fetchedAt `2026-05-09T21:40:45.707Z`
