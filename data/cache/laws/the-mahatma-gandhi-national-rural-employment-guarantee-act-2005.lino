obj_root_law:
  object
  (str slug) (str the-mahatma-gandhi-national-rural-employment-guarantee-act-2005)
  (str handle) (str 2014)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Mahatma Gandhi National Rural Employment Guarantee Act, 2005`)
  (str actNumber) (str 42)
  (str enactmentDate) (str 2005-09-05)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2014`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (undefined)
  (str actYear) (str 2005)
  (str ministry) (str `Ministry of Rural Development`)
  (str department) (str `Department of Rural Development`)
  (str longTitle) (str `An Act to provide for the enhancement of livelihood security of the households in rural areas of the country by providing at least one hundred days of guaranteed wage employment in every financial year to every household whose adult members volunteer to do unskilled manual work and for matters connected therewith or incidental thereto..`)
  (str enforcementDate) (str 02-02-2006)
  (str notification) (str `2nd February, 2006, vide notification No. S.O. 87(E), dated 24th January, 2006, see Gazette of India, Extraordinary, Part II sec.3 (ii).`)
  (str fetchedAt) (str `2026-05-09T21:40:45.707Z`)
