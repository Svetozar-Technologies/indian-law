  object
  (str sectionId) (str 578)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Repeal of Act XXXV of 1948.`)
  (str content) (str `[Repeal of Act 35 of 1948.]---Rep. by the Repealing and Amending Act, 1957 (36 of 1957), s. 2
and Schedule I.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_0_00013_195154_1523604737656&sectionId=578&sectionno=4&orderno=4&orgactid=AC_CEN_22_0_00013_195154_1523604737656)
