obj_root_law_sections_1:
  sectionId (575)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_0_00013_195154_1523604737656&sectionId=575&sectionno=1&orderno=1&orgactid=AC_CEN_22_0_00013_195154_1523604737656
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Companies (Donations to National Funds) Act, 1951.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
obj_root_law_sections_1_footnotes:
  string
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (576)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_0_00013_195154_1523604737656&sectionId=576&sectionno=2&orderno=2&orgactid=AC_CEN_22_0_00013_195154_1523604737656
obj_root_law_sections_2_content:
  string
  line `In this Act,--`
  line
  line `(a) "company" means a company as defined in section 2 of ,the companies Act, and includes a company deemed to be incorporated and registered under that Act by virtue of section 2B thereof;`
  line
  line `(b) "the Companies Act" means the Indian Companies Act, 1913 (VII of 1913).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (577)
  sectionNo (3)
  orderNo 3
  title `Power of companies to make donations to certain National Funds.`
  content `Any company may, notwithstanding anything contained in the Companies Act or in any other law for the time being in force regulating the affairs thereof, and notwithstanding that the memorandum or articles of association of the company do not enable it so to do, by an extraordinary resolution passed in accordance with the provisions contained in section 81 of the Companies Act, authorise the making of donations to the Gandhi National Memorial Fund or the Sardar Vallabhbhai National Memorial Fund, or to any other Fund established for a charitable purpose which by reason of its national importance has been approved by the Central Government for the purposes of this section.`
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_0_00013_195154_1523604737656&sectionId=577&sectionno=3&orderno=3&orgactid=AC_CEN_22_0_00013_195154_1523604737656
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (578)
  sectionNo (4)
  orderNo 4
  title `Repeal of Act XXXV of 1948.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_0_00013_195154_1523604737656&sectionId=578&sectionno=4&orderno=4&orgactid=AC_CEN_22_0_00013_195154_1523604737656
obj_root_law_sections_4_content:
  string
  line `[Repeal of Act 35 of 1948.]---Rep. by the Repealing and Amending Act, 1957 (36 of 1957), s. 2`
  line `and Schedule I.`
obj_root_law_sections_4_footnotes:
  string
  line
