obj_root_law_sections_1:
  sectionId (4465)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4465&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Coinage Act, 2011.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 28th March, 2012, vide notification No. S.O. 628(E), dated 28th March, 2012, see Gazette of India, Extraordinary,`
  line `Part II, sec.. 3 (ii).`
obj_root_law_sections_2:
  sectionId (4466)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4466&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "coin" means any coin which is made of any metal or any other material stamped by the`
  line `Government or any other authority empowered by the Government in this behalf and which is a legal`
  line `tender including commemorative coin and Government of India one rupee note.`
  line
  line `Explanation.--For the removal of doubts, it is hereby clarified that a "coin" does not include the`
  line `credit card, debit card, postal order and e-money issued by any bank, post office or financial`
  line institution;
  line
  line `(b) "commemorative coin" means any coin stamped by the Government or any other authority`
  line `empowered by the Government in this behalf to commemorate any specific occasion or event and`
  line `expressed in Indian currency;`
  line
  line `(c) "deface" means any type of clipping, filing, stamping, or such other alteration of the surface`
  line `or shape of a coin as is readily distinguishable from the effects or reasonable wear;`
  line
  line `(d) "Government" means the Central Government;`
  line
  line `(e) "issue" means to put a coin into circulation for use as money;`
  line
  line `(f) "metal" means any metal, base metal, alloy, gold, silver or any other material which may be`
  line `prescribed by the Government for the purpose of any coin;`
  line
  line `(g) "Mint" means the Security Printing and Minting Corporation of India Limited formed and`
  line `incorporated under the Companies Act, 1956 (1 of 1956) or any other organisation established by or`
  line `under the authority of the Government to make a coin by stamping metal;`
  line
  line `(h) "notification" means notification published in the Official Gazette;`
  line
  line `(i) "per cent." means the percentage of metals prescribed for any coin;`
  line
  line `(j) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(k) "remedy" means variation from the standard weight and fineness;`
  line
  line `(l) "standard weight" means the weight prescribed for any coin.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (4467)
  sectionNo (3)
  orderNo 3
  title `Power to establish and abolish Mints.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4467&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_3_content:
  string
  line `The Government may, by notification,--`
  line
  line `(a) establish a Mint at any place which may be managed by it or by any other person, which may`
  line `be authorised for this purpose:`
  line
  line `Provided that the Mints established before the commencement of this Act shall be deemed to`
  line `have been established by the Government under this section:`
  line
  line `Provided further that where the Government is of the opinion that it is necessary or expedient in`
  line `the public interest so to do, it may authorise the minting of coins by any organisation or Government`
  line `of any foreign country, within or beyond the limits of India and acquire such coins either by way of`
  line `import or otherwise for issue under its authority;`
  line
  line `(b) abolish any Mint.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (4468)
  sectionNo (4)
  orderNo 4
  title `Denominations, dimensions, designs and composition of coins.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4468&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_4_content:
  string
  line `Coins may be minted at the`
  line `Mints or at any other place authorised under the proviso to section 3 of such denominations not higher`
  line `than one thousand rupees and of such dimensions and designs and containing such metals or mixed`
  line `metals of such composition or any other material as may be prescribed by the Government.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (4469)
  sectionNo (5)
  orderNo 5
  title `Standard weight and remedy.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4469&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_5_content:
  string
  line `The standard weight of the coin of any denomination, minted`
  line `under the provisions of section 4, and the remedy allowed in making of such coins, shall be such as may`
  line `be prescribed in this behalf by the Government from time to time.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (4470)
  sectionNo (6)
  orderNo 6
  title `Coin when a legal tender.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4470&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_6_content:
  string
  line `(1) The coins issued under the authority of section 4 shall be a legal`
  line `tender in payment or on account, in case of--`
  line
  line `(a) a coin of any denomination not lower than one rupee, for any sum not exceeding one`
  line `thousand rupees;`
  line
  line `(b) a half-rupee coin, for any sum not exceeding ten rupees;`
  line
  line `(c) any other coin, for any sum not exceeding one rupee:`
  line
  line `Provided that the coin has not been defaced and has not lost weight so as to be less than such weight`
  line `as may be prescribed in its case.`
  line
  line `(2) All new coins in the naya paisa series, designated as such under the notification of the`
  line `Government of India in the Ministry of Finance, Department of Economic Affairs, Number S.R.O. 1120,`
  line `dated the 11th May, 1956 issued prior to the commencement of the Indian Coinage (Amendment) Act,`
  line `1964 (17 of 1964), shall continue to be a legal tender in payment or on account, in case of,--`
  line
  line `(a) a half-rupee or fifty naye paise coin, for any sum not exceeding ten rupees;`
  line
  line `(b) any other coin, for any sum not exceeding one rupee.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (4471)
  sectionNo (7)
  orderNo 7
  title `Decimal system of coinage.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4471&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_7_content:
  string
  line `(1) The rupee shall be divided into one hundred units and any such`
  line `unit may be designated by the Government, by notification, under such name as it thinks fit.`
  line
  line `(2) All references in any enactment or in any notification, rule or order under any enactment or in any`
  line `contract, deed or other instrument to any value expressed in annas, paisa and pies shall be construed as`
  line `references to that value expressed in units referred to in sub-section (1) converted thereto at the rate of`
  line `sixteen anna, sixty-four paise or one hundred and ninety-two pies to one hundred units referred to in subsection`
  line `(1).`
  line
  line `(3) All references in any enactment or in any notification, rule or order under any enactment or in any`
  line `contract, deed or other instrument to any value in naya paisa or naye paise shall be construed as`
  line `references to that value expressed respectively in units referred to in sub-section (1).`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (4472)
  sectionNo (8)
  orderNo 8
  title `Power to call in coin.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4472&sectionno=8&orderno=8&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_8_content:
  string
  line `Notwithstanding anything contained in section 6, the Government may, by`
  line `notification, call in with effect from such date as may be specified in the notification, any coin, of`
  line `whatever date or denomination and on and from the date so specified, such coin shall cease to be a legal`
  line `tender, save to such extent as may be specified in the notification.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (4473)
  sectionNo (9)
  orderNo 9
  title `Power to certain persons to cut, diminished or defaced coins.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4473&sectionno=9&orderno=9&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_9_content:
  string
  line `(1) Where any coin which has`
  line `been minted and issued by or under the authority of the Government is tendered to any person authorised`
  line `by it to act under this section, and such person has reason to believe that the coin--`
  line
  line `(a) has been diminished in weight so as to be more than such per cent. below standard weight as`
  line `provided in section 5; or`
  line
  line `(b) has been defaced,`
  line
  line `he shall, by himself or through another person, cut or break the coin.`
  line
  line `(2) A person cutting or breaking coin under the provisions of clause (a) of sub-section (1) shall`
  line `receive and pay for the coin at its face value.`
  line
  line `(3) A person cutting or breaking coin under the provisions of clause (b) of sub-section (1) shall`
  line `observe the following procedure, namely:--`
  line
  line `(a) if such person has reason to believe, that the coin has been fraudulently defaced, he shall`
  line `return the pieces to the person tendering the coin, who shall bear the loss caused by such cutting or`
  line breaking;
  line
  line `(b) if such person has reason to believe, that the coin has not been fraudulently defaced, he shall`
  line `receive and pay for the coin at its face value.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (4474)
  sectionNo (10)
  orderNo 10
  title `Power to certain persons to cut counterfeit coins.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4474&sectionno=10&orderno=10&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_10_content:
  string
  line `Where any coin minted or issued by or`
  line `under the authority of the Government is tendered to any person authorised by the Government under`
  line `section 9 and such person has reason to believe that the coin is counterfeit, he shall by himself or through`
  line `another person cut or break the coin, and the tenderer shall bear the loss caused by such cutting or`
  line breaking.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (4475)
  sectionNo (11)
  orderNo 11
  title `Power of Mint to delegate its functions.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4475&sectionno=11&orderno=11&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_11_content:
  string
  line `The Mint may in writing authorise any other`
  line `organisation of the Government to melt withdrawn coins or take any help of such organisation for the said`
  line purpose.
  line
  line `Explanation.--For the purposes of this section "organisation" means any Government industrial unit`
  line `or public sector undertaking possessing melting facilities.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (4476)
  sectionNo (12)
  orderNo 12
  title `Prohibition of making or melting or destruction of coins.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4476&sectionno=12&orderno=12&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_12_content:
  string
  line `(1) No person shall--`
  line
  line `(i) use any metal piece as coin whether stamped or unstamped, intended to be used as money`
  line `except by the authority of the Government, or`
  line
  line `(ii) melt or destroy any coin, or`
  line
  line `(iii) use coin other than as a medium of exchange, or`
  line
  line `(iv) have in his possession, custody or control,--`
  line
  line `(a) any melted coin, whether in the molten state or in a solid state, or`
  line
  line `(b) any coin in a destroyed or mutilated state, or`
  line
  line `(c) coins substantially in excess of his reasonable requirements for the purpose of selling such`
  line `coins for value other than their face value or for melting or for destroying or for disposing these`
  line `coins other than as a medium of exchange.`
  line
  line `Explanation.--For the purposes of determining the reasonable requirements of coins of a`
  line `person, due regard shall be had to--`
  line
  line `(i) his total daily requirements of coins;`
  line
  line `(ii) the nature of his business, occupation or profession;`
  line
  line `(iii) the mode of his acquisition of coins; and`
  line
  line `(iv) the manner in which, and the place at which, such coins are being possessed, held or`
  line `controlled by him.`
  line
  line `(2) Whoever is found to be in possession of any metal or material which contains alloys in the same`
  line `proportions in which they have been used in the manufacture of any coin shall be presumed, until the`
  line `contrary is proved, to have contravened the provisions of sub-section (1).`
  line
  line `(3) Nothing in this section shall apply--`
  line
  line `(i) to any person who is found in possession of any metal or scraps or scissel, etc., of nonrecyclable`
  line `coinage metal, which he may so possess as a result of valid disposal by auctions by a Mint;`
  line
  line `(ii) to the Mint, Reserve Bank of India and its authorised agents, and suppliers of coins or coin`
  line `blanks to the extent of orders placed by or under the authority of the Government until their supply or`
  line `completion of orders placed by the Government;`
  line
  line `(iii) to any prospective supplier who intends to supply coin or coin blanks as samples against a`
  line `valid tender documents purchased by him provided that quantity is in reasonable agreement with`
  line `quantity of samples to be supplied.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (4477)
  sectionNo (13)
  orderNo 13
  title `Penalty for contravention of section 12.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4477&sectionno=13&orderno=13&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_13_content:
  string
  line `Whoever contravenes any provisions of section 12`
  line `shall be punishable with imprisonment which may extend to seven years and with fine.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (4478)
  sectionNo (14)
  orderNo 14
  title `Prohibition and penalty for unlawful making, issue or possession of pieces of metal to be used as money.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4478&sectionno=14&orderno=14&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_14_content:
  string
  line `(1) No person shall--`
  line
  line `(a) make or issue or attempt to issue any metal piece except as provided under section 4 for the`
  line `purpose of coin;`
  line
  line `(b) possess, custody or control of any metal piece with the intent to issue the piece for use as`
  line `money for a medium of exchange.`
  line
  line `(2) Whoever contravenes the provisions of sub-section (1) shall be punishable with imprisonment`
  line `which may extend to one year or with fine or with both:`
  line
  line `Provided that if any person convicted under this section is again convicted, he shall be punishable`
  line `with imprisonment which may extend to three years or with fine or with both.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (4479)
  sectionNo (15)
  orderNo 15
  title `Prohibition and penalty for bringing metal piece for use as coin.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4479&sectionno=15&orderno=15&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_15_content:
  string
  line `(1) No person shall bring`
  line `by sea or by land or by air into India of any piece of metal to be used as coin except with the authority or`
  line `permission of the Government.`
  line
  line `(2) Whoever contravenes the provisions of sub-section (1) shall be punishable with imprisonment`
  line `which may extend to seven years and with fine.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (4480)
  sectionNo (16)
  orderNo 16
  title `Offences by companies.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4480&sectionno=16&orderno=16&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_16_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed was in charge of, and was responsible`
  line `to, the company for the conduct of its business, shall be deemed to be guilty of the offence and shall be`
  line `liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any person liable to any punishment,`
  line `if he proves that the offence was committed without his knowledge or that he exercised all due diligence`
  line `to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding, anything contained in sub-section (1), where any offence under this Act has`
  line `been committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to, any neglect on the part of any director, manager, secretary or other`
  line `officer, such director, manager, secretary or other officer of the company shall be deemed to be guilty of`
  line `that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm, society or other association of`
  line `individuals; and`
  line
  line `(b) "director", in relation to--`
  line
  line `(i) a firm, means a partner or proprietor of the firm;`
  line
  line `(ii) a society or other association of individuals, means the person who is entrusted, under the`
  line `rules of the society or other association, with the management of the affairs of the society or other`
  line `association of the individuals, as the case may be.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (4481)
  sectionNo (17)
  orderNo 17
  title Forfeiture.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4481&sectionno=17&orderno=17&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_17_content:
  string
  line `Any coin or metal in relation to which any offence under this Act has been`
  line `committed shall be forfeited to the Government.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (4482)
  sectionNo (18)
  orderNo 18
  title `Probation of Offenders Act, 1958 not to apply to offences under this Act.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4482&sectionno=18&orderno=18&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_18_content:
  string
  line `Nothing in the`
  line `Probation of Offenders Act, 1958 (20 of 1958) shall apply to offences under this Act.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (4483)
  sectionNo (19)
  orderNo 19
  title `Offences to be cognizable, bailable and non-compoundable.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4483&sectionno=19&orderno=19&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_19_content:
  string
  line `Notwithstanding anything`
  line `contained in the Code of Criminal Procedure, 1973 (2 of 1974), offences under this Act shall be`
  line `cognizable and bailable, but shall not be compoundable.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (4484)
  sectionNo (20)
  orderNo 20
  title `Amendment of Act 2 of 1934.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4484&sectionno=20&orderno=20&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_20_content:
  string
  line `In the Reserve Bank of India Act, 1934,--`
  line
  line `(i) in section 2, in clause (d), for the words and figures the Indian Coinage Act, 1906 (3 of 1906),`
  line `the words and figures the Coinage Act, 2011shall be substituted;`
  line
  line `(ii) in section 39, for the words and figures "the Indian Coinage Act, 1906 (3 of 1906)", at both`
  line `the places where they occur, the words and figures "the Coinage Act, 2011" shall be substituted.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (4485)
  sectionNo (21)
  orderNo 21
  title `Offences may be tried summarily.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4485&sectionno=21&orderno=21&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_21_content:
  string
  line `Notwithstanding anything contained in section 260 of the`
  line `Code of Criminal Procedure, 1973 (2 of 1974), offences under this Act may be tried summarily by a`
  line `Judicial Magistrate of the first class or a Metropolitan Magistrate.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (4486)
  sectionNo (22)
  orderNo 22
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4486&sectionno=22&orderno=22&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_22_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any person in respect of anything which is in good faith done, or intended to be done, under or in`
  line `pursuance of the provisions of this Act.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (4487)
  sectionNo (23)
  orderNo 23
  title `Power to remove difficulties.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4487&sectionno=23&orderno=23&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_23_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Government may, by order published in the Official Gazette, make such provisions, not`
  line `inconsistent with the provisions of this Act as may appear it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of five years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (4488)
  sectionNo (24)
  orderNo 24
  title `Power to make rules.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4488&sectionno=24&orderno=24&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_24_content:
  string
  line `(1) The Government may, by notification, make rules to carry out the`
  line `purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the use of metal for the purpose of making any coin under clause (f) of section 2;`
  line
  line `(b) the per cent. of metals for any coin under clause (i) of section 2;`
  line
  line `(c) the standard weight for any coin under clause (l) of section 2;`
  line
  line `(d) the dimensions, designs, metals, mixed metals or their composition, for coins under section 4;`
  line
  line `(e) the standard weight of coins and the remedy allowed in making such coins under section 5`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (4489)
  sectionNo (25)
  orderNo 25
  title `Rules to be laid before Parliament.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4489&sectionno=25&orderno=25&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_25_content:
  string
  line `Every rule made under this Act shall be laid, as soon as`
  line `may be after it is made, before each House of Parliament, while it is in session for a total period of thirty`
  line `days which may be comprised in one session or in two or more successive sessions, and if, before the`
  line `expiry of the session immediately following the session or the successive sessions aforesaid, both Houses`
  line `agree in making any modification in the rule or both Houses agree that the rule should not be made, the`
  line `rule shall thereafter have effect only in such modified form or be of no effect, as the case may be; so,`
  line `however, that any such modification or annulment shall be without prejudice to the validity of anything`
  line `previously done under that rule.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (4490)
  sectionNo (26)
  orderNo 26
  title `Saving of making other coins at Mints.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4490&sectionno=26&orderno=26&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_26_content:
  string
  line `Nothing in this Act shall be deemed to prohibit or`
  line `restrict the making at any Mint in India of coins intended for issue as money by the foreign Government`
  line `of any territories beyond the limits of India.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (4491)
  sectionNo (27)
  orderNo 27
  title `Repeal and savings.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4491&sectionno=27&orderno=27&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_27_content:
  string
  line `(1) The following enactments are hereby repealed--`
  line
  line `(a) the Metal Tokens Act, 1889 (1 of 1889);`
  line
  line `(b) the Coinage Act, 1906 (3 of 1906);`
  line
  line `(c) the Bronze Coin (Legal Tender) Act, 1918 (22 of 1918);`
  line
  line `(d) the Currency Ordinance, 1940 (Ord. IV of 1940);`
  line
  line `(e) the Small Coins (Offences) Act, 1971 (52 of 1971).`
  line
  line `(2) The repeal by this Act of the enactments and Ordinance specified in sub-section (1) shall not--`
  line
  line `(a) affect any other enactment in which the repealed enactment or Ordinance has been applied,`
  line `incorporated or referred to;`
  line
  line `(b) affect the validity, invalidity, effect or consequences of anything already done or suffered, or`
  line `any right, title, obligation or liability already acquired, accrued or incurred or any remedy or`
  line `proceeding in respect thereof, or any release or discharge of or from any debt, penalty, obligation,`
  line `liability, claim or demand, or any indemnity already granted, or the proof of any past act or thing;`
  line
  line `(c) affect any principle or rule of law, or established jurisdiction, form or course of pleading,`
  line `practice or procedure, or existing usage, custom, privilege, restriction, exemption, office or`
  line `appointment, notwithstanding that the same respectively may have been in any manner affirmed or`
  line `recognised or derived by, in or from any enactment or Ordinance hereby repealed;`
  line
  line `(d) revive or restore any jurisdiction, office, custom, liability, right, title, privilege, restriction,`
  line `exemption, usage, practice, procedure or other matter or thing not now existing or in force.`
  line
  line `(3) The mention of particular matters in sub-section (1) shall not be held to prejudice or affect the`
  line `general application of section 6 of the General Clauses Act, 1897 (10 of 1897), with regard to the effect of`
  line repeals.
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (4492)
  sectionNo (28)
  orderNo 28
  title `Continuance of existing coins.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00052_201111_1517807327275&sectionId=4492&sectionno=28&orderno=28&orgactid=AC_CEN_2_11_00052_201111_1517807327275
obj_root_law_sections_28_content:
  string
  line `Notwithstanding the repeal of the enactments and the`
  line `Ordinance specified in sub-section (1) of section 27,--`
  line
  line `(a) all coins issued under the said enactments; and`
  line
  line `(b) Government of India one rupee note issued under the Currency Ordinance, 1940 (Ord. IV of`
  line `1940),`
  line
  line `which are legal tender immediately before the commencement of the Coinage Act, 2011 shall be deemed`
  line `to be the coin and continue to be legal tender in payment or on account under the corresponding`
  line `provisions of this Act.`
obj_root_law_sections_28_footnotes:
  string
  line
