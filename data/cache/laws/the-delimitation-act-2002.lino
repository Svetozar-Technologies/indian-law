  (str hindiTitle) (str `परिसीमन अधिनियम, 2002`)
  (str actYear) (str 2002)
  (str ministry) (str `Ministry of Law and Justice`)
  (str department) (str `Legislative Department`)
  (str longTitle) (str `An Act to provide for the readjustment of the allocation of seats in the House of the People to the States, the total number of seats in the Legislative Assembly of each State, the division of each State and each Union territory having a Legislative Assembly into territorial constituencies for elections to the House of the People and Legislative Assemblies of the States and Union territories and for matters connected therewith.`)
  (str enforcementDate) (str 03-06-2002)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T12:49:27.391Z`)
  (str translations) obj_root_law_translations
