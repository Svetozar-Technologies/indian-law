obj_root_law_translations_hi_sections_1_content:
  string
  line `परिसीमन अधिधनयम, 2002`
  line _________
  line `िािाओं का क्र म`
  line _________
  line `ि ाािाएं`
  line `1. संधिप् त नाम।`
  line `2. परिभाषाएं।`
  line `3. परिसीमन आयोग का गठन।`
  line `4. आयोग के कततव्य।`
  line `5. सहयुक्त सदस्य।`
  line `6. आकधस्म क रिधक् त यां।`
  line `7. आयोग की प्रक्रक्र या औि शधक्त यां।`
  line `8. स् था नों की संख्या का पु न: समायोजन।`
  line `9. धनर्ातचन - िेत्रों का परिसीमन।`
  line `10. आदेशों का प्र काशन औि उनके प्रर् ततन की तािीख।`
  line `10 क. कधतपय मामलों में परिसीमन का आस्थ गन।`
  line `10 ख. झािखंड िाज्य की बाबत परिसीमन आयोग के आदेश का कोई धर्धिक प्र भार् न होना।`
  line `11. परिसीमन आदेशों को अद्यतन बनाए िखने की शधक्त।`
  line `12. धनिसन।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
