obj_root_law_sections_1:
  sectionId (81340)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81340&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Chief Election Commissioner and`
  line `other Election Commissioners (Appointment, Conditions of Service and Term of Office) Act, 2023.`
  line
  line `(2) It shall come into force on such date^1 as the Central Government may, by notification in the Official`
  line `Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 2nd day of January, 2024, vide notification No. S.O. 35 (E), dated 2nd day of January, 2024, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3 (ii).`
obj_root_law_sections_2:
  sectionId (81341)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81341&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Chief Election Commissioner" means the Chief Election Commissioner appointed under clause (2)`
  line `of article 324 of the Constitution and in accordance with this Act;`
  line
  line `(b) "Election Commission" means the Election Commission referred to in clause (1) of article 324 of the`
  line Constitution;
  line
  line `(c) "Election Commissioner" means any other Election Commissioner appointed under clause (2) of`
  line `article 324 of the Constitution and in accordance with this Act;`
  line
  line `(d) "Search Committee" means the Search Committee for preparation of panel of persons for`
  line `consideration for appointment as Chief Election Commissioner and other Election Commissioners; and`
  line
  line `(e) "Selection Committee" means the Selection Committee that recommends appointment of Chief`
  line `Election Commissioner and other Election Commissioners.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (81342)
  sectionNo (3)
  orderNo 3
  title `Election Commission.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81342&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_3_content:
  string
  line `The Election Commission shall consist of--`
  line
  line `(a) Chief Election Commissioner; and`
  line
  line `(b) such number of other Election Commissioners as the President may fix from time to time.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (81343)
  sectionNo (4)
  orderNo 4
  title `Appointment of Chief Election Commissioner and other Election Commissioners.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81343&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_4_content:
  string
  line `The Chief`
  line `Election Commissioner and other Election Commissioners shall be appointed by the President by warrant`
  line `under his hand and seal.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (81344)
  sectionNo (5)
  orderNo 5
  title `Qualifications of Chief Election Commissioner and other Election Commissioners.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81344&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_5_content:
  string
  line `The Chief`
  line `Election Commissioner and other Election Commissioners shall be appointed from amongst persons who`
  line `are holding or have held a post equivalent to the rank of Secretary to the Government of India and shall be`
  line `persons of integrity, who have knowledge of and experience in management and conduct of elections.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (81345)
  sectionNo (6)
  orderNo 6
  title `Search Committee.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81345&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_6_content:
  string
  line `A Search Committee headed by the Minister of Law and Justice and`
  line `comprising two other members not below the rank of Secretary to the Government of India, shall prepare a`
  line `panel of five persons for consideration of the Selection Committee, for appointment as the Chief Election`
  line `Commissioner and other Election Commissioners.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (81346)
  sectionNo (7)
  orderNo 7
  title `Selection Committee.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81346&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_7_content:
  string
  line `(1) The Chief Election Commissioner and other Election Commissioners`
  line `shall be appointed by the President on the recommendation of a Selection Committee consisting of--`
  line
  line `(a) the Prime Minister---Chairperson;`
  line
  line `(b) the Leader of Opposition in the House of the People---Member;`
  line
  line `(c) a Union Cabinet Minister to be nominated by the Prime Minister---Member.`
  line
  line `Explanation.---For the purposes of removal of doubts, it is hereby declared that where the Leader of`
  line `Opposition in the House of the People has not been recognised as such, the leader of the single largest party`
  line `in opposition of the Government in the House of the People shall be deemed to be the Leader of`
  line Opposition.
  line
  line `(2) The appointment of Chief Election Commissioner and other Election Commissioners shall not be`
  line `invalid merely by reason of any vacancy in or any defect in the constitution of, the Selection Committee.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (81347)
  sectionNo (8)
  orderNo 8
  title `Power of Selection Committee to regulate its own procedure.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81347&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_8_content:
  string
  line `(1) The Selection Committee shall`
  line `regulate its own procedure in a transparent manner for selecting the Chief Election Commissioner or other`
  line `Election Commissioners.`
  line
  line `(2) The Selection Committee may also consider any other person than those included in the panel by the`
  line `Search Committee.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (81348)
  sectionNo (9)
  orderNo 9
  title `Term of office.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81348&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_9_content:
  string
  line `(1) The Chief Election Commissioner and other Election Commissioners shall hold`
  line `office for a term of six years from the date on which he assumes his office or till he attains the age of`
  line `sixty-five years, whichever is earlier.`
  line
  line `(2) The Chief Election Commissioner and other Election Commissioners shall not be eligible for`
  line re-appointment.
  line
  line `(3) Where an Election Commissioner is appointed as Chief Election Commissioner, his term of office`
  line `shall not be more than six years in aggregate as the Election Commissioner and the Chief Election`
  line Commissioner.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (81349)
  sectionNo (10)
  orderNo 10
  title `Salary, etc.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81349&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_10_content:
  string
  line `(1) The Chief Election Commissioner and other Election Commissioners shall be paid`
  line `a salary which is equal to the salary of a Judge of the Supreme Court:`
  line
  line `Provided that the salary, allowances and other conditions of service of the Chief Election Commissioner`
  line `and other Election Commissioners, holding office immediately before the date of commencement of this`
  line `Act shall not be varied to their disadvantage.`
  line
  line `(2) If a person who, immediately before the date of assuming office as the Chief Election Commissioner`
  line `or an Election Commissioner, was in receipt of, or being eligible so to do, had elected to draw, a pension`
  line `(other than a disability or wound pension) in respect of any previous service under the Central Government`
  line `or a State Government, his salary in respect of service as the Chief Election Commissioner or an Election`
  line `Commissioner shall be reduced--`
  line
  line `(a) by the amount of that pension; and`
  line
  line `(b) if he had, before assuming office, received, in lieu of a portion of the pension due to him in`
  line `respect of such previous service, the commuted value thereof, by the amount of that portion of the`
  line pension.
  line
  line `(3) The Chief Election Commissioner and other Election Commissioners shall be entitled to dearness`
  line `allowance as may be admissible to Judge of the Supreme Court.`
  line
  line `(4) The Chief Election Commissioner and other Election Commissioners shall be entitled to encashment`
  line `of fifty per cent. of earned leave to his credit at the time of completion of tenure.`
  line
  line `(5) Where the Chief Election Commissioner or an Election Commissioner had retired from the service`
  line `of the Central Government or a State Government prior to appointment as such, the aggregate period for`
  line `which the encashment of unutilised earned leave he shall be entitled, shall be subject to a maximum period`
  line `as admissible in accordance with the rules for the time being applicable to the service to which he belonged`
  line `before his appointment as Chief Election Commissioner or an Election Commissioner.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (81350)
  sectionNo (11)
  orderNo 11
  title `Resignation and removal.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81350&sectionno=11&orderno=11&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_11_content:
  string
  line `(1) The Chief Election Commissioner or an Election Commissioner`
  line `may, at any time, by writing under his hand addressed to the President, resign his office.`
  line
  line `(2) The Chief Election Commissioner shall not be removed from his office except in like manner and on`
  line `the like grounds as a Judge of the Supreme Court.`
  line
  line `(3) The other Election Commissioners shall not be removed from office except on the recommendation`
  line `of the Chief Election Commissioner.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (81351)
  sectionNo (12)
  orderNo 12
  title Leave.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81351&sectionno=12&orderno=12&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_12_content:
  string
  line `(1) The Chief Election Commissioner or an Election Commissioner may be granted leave`
  line `in accordance with the rules for the time being applicable to the service to which he belonged before the`
  line `date of his appointment and he shall be entitled to carry forward the leave standing at his credit on such`
  line `date, irrespective of the provisions contained in section 13.`
  line
  line `(2) The power to grant or refuse leave to the Chief Election Commissioner or an Election`
  line `Commissioner and to revoke or curtail leave granted to him, shall vest in the President.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (81352)
  sectionNo (13)
  orderNo 13
  title Pension.
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81352&sectionno=13&orderno=13&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_13_content:
  string
  line `(1) Where the Chief Election Commissioner or an Election Commissioner was in service`
  line `of Government, he shall be deemed to have retired from the service on the date on which he enters upon`
  line `office as the Chief Election Commissioner or an Election Commissioner, as the case may be.`
  line
  line `(2) The Chief Election Commissioner or other Election Commissioners who at the time of his`
  line `appointment as such, was in service of the Central Government or a State Government, shall at his option to`
  line `be exercised within a period of six months from the date of such appointment, be entitled to draw his`
  line `pension and other retirement benefits under the rules applicable to the service to which he belonged, with`
  line `effect from the date of his appointment as the Chief Election Commissioner or other Election`
  line Commissioner.
  line
  line `(3) Except where the Chief Election Commissioner or an Election Commissioner demits office by`
  line `resignation, he shall be deemed, for the purposes of this Act, to have demitted his office only if,--`
  line
  line `(a) he has completed the term of office specified in section 9; or`
  line
  line `(b) he has attained the age of sixty-five years; or`
  line
  line `(c) his demission of office is medically certified to be necessitated by ill-health.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (81353)
  sectionNo (14)
  orderNo 14
  title `Right to subscribe to General Provident Fund.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81353&sectionno=14&orderno=14&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_14_content:
  string
  line `Every person holding office as the Chief`
  line `Election Commissioner or an Election Commissioner shall be entitled to subscribe to the General Provident`
  line `Fund under the General Provident Fund (Central Services) Rules, 1960.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (81354)
  sectionNo (15)
  orderNo 15
  title `Other conditions of service.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81354&sectionno=15&orderno=15&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_15_content:
  string
  line `Save as otherwise provided in this Act, the President may by rules`
  line `determine the conditions of service relating to travelling allowance, medical facilities, leave travel`
  line `concession, conveyance facilities, and such other conditions of service relating to the Chief Election`
  line `Commissioner and other Election Commissioners.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (81355)
  sectionNo (16)
  orderNo 16
  title `Protection of Chief Election Commissioner and other Election Commissioners.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81355&sectionno=16&orderno=16&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_16_content:
  string
  line `Notwithstanding anything contained in any other law for the time being in force, no`
  line `Court shall entertain or continue any civil or criminal proceedings against any person who is or was a Chief`
  line `Election Commissioner or an Election Commissioner for any act, thing or word, committed, done or spoken`
  line `by him when, or in the course of acting or purporting to act in the discharge of his official duty or function.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (81357)
  sectionNo (17)
  orderNo 17
  title `Transaction of business.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81357&sectionno=17&orderno=17&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_17_content:
  string
  line `The business of the Election Commission shall be transacted in`
  line `accordance with the provisions of this Act.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (81358)
  sectionNo (18)
  orderNo 18
  title `Disposal of business.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81358&sectionno=18&orderno=18&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_18_content:
  string
  line `(1) The Election Commission may, by unanimous decision, regulate the`
  line `procedure for transaction of its business and also allocation of its business amongst the Chief Election`
  line `Commissioner and other Election Commissioners.`
  line
  line `(2) All business of the Election Commission shall, as far as possible, be transacted unanimously, and if`
  line `the Chief Election Commissioner and other Election Commissioners differ in opinion on any matter, such`
  line `matter shall be decided according to the opinion of the majority.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (81359)
  sectionNo (19)
  orderNo 19
  title `Power to remove difficulties.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81359&sectionno=19&orderno=19&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_19_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, within a period of five years from the date of commencement of`
  line `this Act, by order not inconsistent with the provisions of this Act, remove the difficulty.`
  line
  line `(2) Every order made under sub-section (1) shall, as soon as may be after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (81360)
  sectionNo (20)
  orderNo 20
  title Laying.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00080_A2023-49_1704690560714&sectionId=81360&sectionno=20&orderno=20&orgactid=AC_CEN_3_20_00080_A2023-49_1704690560714
obj_root_law_sections_20_content:
  string
  line `Every rule and order made under this Act shall be laid, as soon as may be after it is made,`
  line `before each House of Parliament, while it is in session, for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or order, or both Houses agree that the rule or order should not be made, the rule or`
  line `order shall thereafter have effect only in such modified form or be of no effect, as the case may be; so,`
  line `however, that any such modification or annulment shall be without prejudice to the validity of anything`
  line `previously done under that rule or order.`
