  object
  (str sectionId) (str 71721)
  (str sectionNo) (str 38)
  (str orderNo) (int 41)
  (str title) (str [Repealed.].)
  (str content) (str `Repealed by the Punjab Court of Wards Act, 1903 (Punjab Act 2 of 1903), Section
2(1).`)
