obj_root_law_sections_1:
  object
  (str sectionId) (str 71684)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called “The Panjab Laws Act, 1872.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71684&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00101_187204_1663830323109)
obj_root_law_sections_2:
  object
  (str sectionId) (str 71685)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Local extent.`)
  (str content) (str `It extends to the territories ^1which immediately before the 1st
November, 1956, were comprised in the States of Panjab and Delhi, but not so as to alter the effect of any
regulations made for any parts of the said territories under the ^2Statute 33 Vict, Section 1;

And it shall come into force on the first day of June, 1872.`)
  (str footnotes) (str `1. Subs. for "constituting the States of Punjab and Delhi" by 2 A.L.O., 1956 (w.e.f. 1-11-1956).

2. Rep. by the Government of India Act, 1915.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71685&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00101_187204_1663830323109)
obj_root_law_sections_3:
  object
  (str sectionId) (str 71686)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Enactments in force.`)
  (str content) (str `The Regulations, Acts and orders specified in the First Schedule hereto
annexed are in force in the ^1territories to which this Act extends to the extent specified in the third column of the said Schedule.`)
  (str footnotes) (str `1. Subs. for “States of Punjab and Delhi” by 2 A.L.O., 1956 (w.e.f. 1-11-1956).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71686&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00101_187204_1663830323109)
obj_root_law_sections_4:
  object
  (str sectionId) (str 71687)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str [Repealed.].)
  (str content) (str `[Repealed by the Second Repealing and Amending Act, 1914 (17 of
1914), Section 3 and Schedule II.]`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71687&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00101_187204_1663830323109)
obj_root_law_sections_5:
  object
  (str sectionId) (str 71688)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Decisions in certain cases to be according to Native law.`)
  (str content) (str `^1[5. Decisions in certain cases to be according to Native law.---In questions regarding succession,
special property of females, betrothal, marriage, divorce, dower, adoption, guardianship, minority, bastardy,
family relations, wills, legacies, gifts, partitions, or any religious usage or institution,
the rule of decision shall be---

(1) any custom applicable to the parties concerned, which is not contrary to justice, equity or good
conscience, and has not been by this or any other enactment altered or abolished and has not been
declared to be void by any competent authority;

(2) the Muhammadan law, in cases where the parties are Muhammadans, and the Hindu law, in cases
where the parties are Hindus, except in so far as such law has been altered or abolished by legislative
enactment, or is opposed to the provisions of this Act, or has been modified by any such custom as is
above referred to].`)
  (str footnotes) (str `1. Subs. by Act 12 of 1878, s. 1, for the section 5.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71688&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00101_187204_1663830323109)
obj_root_law_sections_6:
  object
  (str sectionId) (str 71689)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Decisions in cases not specially provided for.`)
  (str content) (str `In cases not otherwise specially provided for, the
Judges shall decide according to justice, equity and good conscience.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71689&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00101_187204_1663830323109)
obj_root_law_sections_7:
  object
  (str sectionId) (str 71690)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Local customs and mercantile usages when valid.`)
  (str content) (str `All local customs and mercantile usages shall
be regarded as valid, unless they are contrary to justice, equity or good conscience, or have, before the
passing of this Act, been declared to be void by any competent authority.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71690&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00101_187204_1663830323109)
