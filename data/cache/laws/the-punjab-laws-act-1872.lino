obj_root_law_sections_1:
  sectionId (71684)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called “The Panjab Laws Act, 1872.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71684&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00101_187204_1663830323109
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (71685)
  sectionNo (2)
  orderNo 2
  title `Local extent.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71685&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00101_187204_1663830323109
obj_root_law_sections_2_content:
  string
  line `It extends to the territories ^1which immediately before the 1st`
  line `November, 1956, were comprised in the States of Panjab and Delhi, but not so as to alter the effect of any`
  line `regulations made for any parts of the said territories under the ^2Statute 33 Vict, Section 1;`
  line
  line `And it shall come into force on the first day of June, 1872.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. for "constituting the States of Punjab and Delhi" by 2 A.L.O., 1956 (w.e.f. 1-11-1956).`
  line
  line `2. Rep. by the Government of India Act, 1915.`
obj_root_law_sections_3:
  sectionId (71686)
  sectionNo (3)
  orderNo 3
  title `Enactments in force.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. for “States of Punjab and Delhi” by 2 A.L.O., 1956 (w.e.f. 1-11-1956).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71686&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00101_187204_1663830323109
obj_root_law_sections_3_content:
  string
  line `The Regulations, Acts and orders specified in the First Schedule hereto`
  line `annexed are in force in the ^1territories to which this Act extends to the extent specified in the third column of the said Schedule.`
obj_root_law_sections_4:
  sectionId (71687)
  sectionNo (4)
  orderNo 4
  title [Repealed.].
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71687&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00101_187204_1663830323109
obj_root_law_sections_4_content:
  string
  line `[Repealed by the Second Repealing and Amending Act, 1914 (17 of`
  line `1914), Section 3 and Schedule II.]`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (71688)
  sectionNo (5)
  orderNo 5
  title `Decisions in certain cases to be according to Native law.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by Act 12 of 1878, s. 1, for the section 5.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71688&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00101_187204_1663830323109
obj_root_law_sections_5_content:
  string
  line `^1[5. Decisions in certain cases to be according to Native law.---In questions regarding succession,`
  line `special property of females, betrothal, marriage, divorce, dower, adoption, guardianship, minority, bastardy,`
  line `family relations, wills, legacies, gifts, partitions, or any religious usage or institution,`
  line `the rule of decision shall be---`
  line
  line `(1) any custom applicable to the parties concerned, which is not contrary to justice, equity or good`
  line `conscience, and has not been by this or any other enactment altered or abolished and has not been`
  line `declared to be void by any competent authority;`
  line
  line `(2) the Muhammadan law, in cases where the parties are Muhammadans, and the Hindu law, in cases`
  line `where the parties are Hindus, except in so far as such law has been altered or abolished by legislative`
  line `enactment, or is opposed to the provisions of this Act, or has been modified by any such custom as is`
  line `above referred to].`
obj_root_law_sections_6:
  sectionId (71689)
  sectionNo (6)
  orderNo 6
  title `Decisions in cases not specially provided for.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71689&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00101_187204_1663830323109
obj_root_law_sections_6_content:
  string
  line `In cases not otherwise specially provided for, the`
  line `Judges shall decide according to justice, equity and good conscience.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (71690)
  sectionNo (7)
  orderNo 7
  title `Local customs and mercantile usages when valid.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00101_187204_1663830323109&sectionId=71690&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00101_187204_1663830323109
obj_root_law_sections_7_content:
  string
  line `All local customs and mercantile usages shall`
  line `be regarded as valid, unless they are contrary to justice, equity or good conscience, or have, before the`
  line `passing of this Act, been declared to be void by any competent authority.`
obj_root_law_sections_7_footnotes:
  string
  line
