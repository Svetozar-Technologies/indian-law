obj_root_law_sections_1:
  sectionId (100254)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00006_2025-18_1758263039996&sectionId=100254&sectionno=1&orderno=1&orgactid=AC_CEN_198_0_00006_2025-18_1758263039996
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Bills of Lading Act, 2025.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 10th day of September, 2025, vide notification No. S.O. 4083 (E), dated 8th September, 2025, see Gazette of India,`
  line `Extraordinary, Part II, s. 3 (ii)`
obj_root_law_sections_2:
  sectionId (100255)
  sectionNo (2)
  orderNo 2
  title `Rights under bills of lading to vest in consignee or endorsee.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00006_2025-18_1758263039996&sectionId=100255&sectionno=2&orderno=2&orgactid=AC_CEN_198_0_00006_2025-18_1758263039996
obj_root_law_sections_2_content:
  string
  line `(1) Every consignee of goods`
  line `named in a bill of lading and every endorsee of a bill of lading, to whom the property in the goods`
  line `therein mentioned shall pass, upon or by reason of such consignment or endorsement, shall have`
  line `transferred to and vested in him all rights of suit, and be subject to the same liabilities in respect of such`
  line `goods as if the contract contained in the bill of lading had been made with such consignee or endorsee.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (100256)
  sectionNo (3)
  orderNo 3
  title `Right of stoppage in transit or claims for freight not to be affected.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00006_2025-18_1758263039996&sectionId=100256&sectionno=3&orderno=3&orgactid=AC_CEN_198_0_00006_2025-18_1758263039996
obj_root_law_sections_3_content:
  string
  line `Nothing contained`
  line `in this Act shall prejudice or affect---`
  line
  line `(a) any right of stoppage in transit; or`
  line
  line `(b) any right to claim freight against the original shipper or owner; or`
  line
  line `(c) any liability of the consignee or endorsee by reason or in consequence of his being such`
  line `consignee or endorsee, or of his receipt of the goods by reason or in consequence of such`
  line `consignment or endorsement.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (100257)
  sectionNo (4)
  orderNo 4
  title `Bill of lading in hands of consignee, etc., conclusive evidence of shipment as against master, etc.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00006_2025-18_1758263039996&sectionId=100257&sectionno=4&orderno=4&orgactid=AC_CEN_198_0_00006_2025-18_1758263039996
obj_root_law_sections_4_content:
  string
  line `(1) Every bill of lading in the hands of a consignee or endorsee for valuable consideration,`
  line `representing goods to have been shipped on board a vessel, shall be conclusive evidence of such`
  line `shipment as, against the master or other person signing the same, notwithstanding that such goods or`
  line `some part thereof may not have been so shipped:`
  line
  line `Provided that the master or other person so signing may exonerate himself in respect of such`
  line `misrepresentation, by showing that it was caused without any default on his part, and wholly by the`
  line `fraud of the shipper, or of the holder, or some person under whom the holder claims.`
  line
  line `(2) Nothing in sub-section (1) shall apply where the holder of the bill of lading shall have had actual`
  line `notice at the time of receiving such bill of lading that the goods had not been laden on board.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (100258)
  sectionNo (5)
  orderNo 5
  title `Power of Central Government to give directions.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00006_2025-18_1758263039996&sectionId=100258&sectionno=5&orderno=5&orgactid=AC_CEN_198_0_00006_2025-18_1758263039996
obj_root_law_sections_5_content:
  string
  line `The Central Government may give such`
  line `directions, as it may deem necessary, for carrying out all or any of the provisions of this Act.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (100259)
  sectionNo (6)
  orderNo 6
  title `Repeal and savings.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_198_0_00006_2025-18_1758263039996&sectionId=100259&sectionno=6&orderno=6&orgactid=AC_CEN_198_0_00006_2025-18_1758263039996
obj_root_law_sections_6_content:
  string
  line `(1) The Indian Bills of Lading Act, 1856 (9 of 1856) is hereby repealed.`
  line
  line `(2) Notwithstanding the repeal of the Act referred to in sub-section (1), it shall not affect,---`
  line
  line `(a) the previous operation of the Act so repealed or anything done or any action taken or purported`
  line `to have been or taken or suffered thereunder under the Act so repealed; or`
  line
  line `(b) any right, privilege, obligation or liability acquired, accrued or incurred under the Act so`
  line `repealed; or`
  line
  line `(c) the operation of any rule, notification, order, notice or direction issued, or exemption granted`
  line `thereunder, in so far as it is not inconsistent with the provisions of this Act, and shall be in force until`
  line `it is repealed or superseded under the corresponding provisions of this Act; or`
  line
  line `(d) any penalty incurred in respect of any contravention under the Act so repealed; or`
  line
  line `(e) any proceeding or remedy in respect of any such right, privilege, obligation, liability, penalty`
  line `as aforesaid, and any such proceeding or remedy may be instituted, continued or enforced, and any`
  line `such penalty may be imposed as if that Act had not been repealed;`
  line
  line `(f) the reference made to the repealed Act under any other legislation, rule, order, or any other`
  line `legal instrument and any such reference shall, in so far as it is not inconsistent with the provisions`
  line `of this Act, be construed as a reference to this Act or its corresponding provisions.`
  line
  line `(3) Without prejudice to the provisions of sub-section (2), the provisions of section 6 of the General`
  line `Clauses Act, 1897 (10 of 1897) shall apply with regard to the effect of repeal.`
obj_root_law_sections_6_footnotes:
  string
  line
