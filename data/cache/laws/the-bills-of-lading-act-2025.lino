  (str slug) (str the-bills-of-lading-act-2025)
  (str handle) (str 21919)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Bills of Lading Act, 2025`)
  (str actNumber) (str 18)
  (str enactmentDate) (str 2025-06-17)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/21919`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (undefined)
  (str actYear) (str 2025)
  (str ministry) (str `Ministry of Ports, Shipping and Waterways`)
  (str department) (undefined)
  (str longTitle) (str `An Act to make provisions for the transfer of rights of suit and all liabilities to the consignee named in a bill of lading and every endorsee of a bill of lading, to whom the property in the goods mentioned in the bill of lading shall pass, upon or by reason of a consignment or an endorsement, and for matters connected therewith or related thereto.`)
