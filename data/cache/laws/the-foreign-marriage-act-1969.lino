obj_root_law_sections_1:
  sectionId (15796)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Foreign Marriage Act, 1969.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15796&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (15797)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15797&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "degrees of prohibited relationship" shall have the same meaning as in the Special Marriage`
  line `Act, 1954 (43 of 1954);`
  line
  line `(b) "district", in relation to a Marriage Officer, means the area within which the duties of his`
  line `office are to be discharged;`
  line
  line `(c) "foreign country" means a country or place outside India, and includes a ship which is for the`
  line `time being in the territorial waters of such a country or place;`
  line
  line `(d) "Marriage Officer" means a person appointed under section 3 to be a Marriage Officer;`
  line
  line `(e) "official house", in relation to a Marriage Officer, means--`
  line
  line `(i) the official house of residence of the officer;`
  line
  line `(ii) the office in which the business of the officer is transacted;`
  line
  line `(iii) a prescribed place; and`
  line
  line `(f) "prescribed" means prescribed by rules made under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (15798)
  sectionNo (3)
  orderNo 3
  title `Marriage Officers.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15798&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_3_content:
  string
  line `For the purposes of this Act, the Central Government may, by notification in`
  line `the Official Gazette, appoint such of its diplomatic or consular officers as it may think fit to be Marriage`
  line `Officers for any foreign country.`
  line
  line `Explanation.--In this section, "diplomatic officer" means an ambassador, envoy, minister, high`
  line `commissioner, commissioner, charge d' affairs or other diplomatic representative or a counsellor or`
  line `secretary of an embassy, legation or high commission.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (15799)
  sectionNo (4)
  orderNo 4
  title `Conditions relating to solemnization of foreign marriages.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15799&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_4_content:
  string
  line `A marriage between parties one of`
  line `whom at least is a citizen of India may be solemnized under this Act by or before a Marriage Officer in a`
  line `foreign country, if, at the time of the marriage, the following conditions are fulfilled, namely:--`
  line
  line `(a) neither party has a spouse living,`
  line
  line `(b) neither party is an idiot or a lunatic,`
  line
  line `(c) the bridegroom has completed the age of twenty-one years and the bride the age of eighteen`
  line `years at the time of the marriage, and`
  line
  line `(d) the parties are not within the degrees of prohibited relationship:`
  line
  line `Provided that where the personal law or a custom governing at least one of the parties permits of a`
  line `marriage between them, such marriage may be solemnized, notwithstanding that they are within the`
  line `degrees of prohibited relationship.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (15800)
  sectionNo (5)
  orderNo 5
  title `Notice of intended marriage.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15800&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_5_content:
  string
  line `When a marriage is intended to be solemnized under this Act, the`
  line `parties to the marriage shall give notice thereof in writing in the form specified in the First Schedule to`
  line `the Marriage Officer of the district in which at least one of the parties to the marriage has resided for a`
  line `period of not less than thirty days immediately preceding the date on which such notice is given, and the`
  line `notice shall state that the party has so resided.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (15801)
  sectionNo (6)
  orderNo 6
  title `Marriage Notice Book.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15801&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_6_content:
  string
  line `The Marriage Officer shall keep all notices given under section 5 with`
  line `the records of his office and shall also forthwith enter a true copy of every such notice in a book`
  line `prescribed for that purpose, to be called the "Marriage Notice Book", and such book shall be open, for`
  line `inspection at all reasonable times, without fee, by any person desirous of inspecting the same.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (15802)
  sectionNo (7)
  orderNo 7
  title `Publication of notice.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15802&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_7_content:
  string
  line `Where a notice under section 5 is given to the Marriage Officer, he shall`
  line `cause it to be published--`
  line
  line `(a) in his own office, by affixing a copy thereof to a conspicuous place, and`
  line
  line `(b) in India and in the country or countries in which the parties are ordinarily resident, in the`
  line `prescribed manner.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (15803)
  sectionNo (8)
  orderNo 8
  title `Objection to marriage.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15803&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_8_content:
  string
  line `(1) Any person may, before the expiration of thirty days from the date of`
  line `publication of the notice under section 7, object to the marriage on the ground that it would contravene`
  line `one or more of the conditions specified in section 4.`
  line
  line `Explanation.--Where the publication of the notice by affixation under clause (a) of section 7 and in`
  line `the prescribed manner under clause (b) of that section is on different dates, the period of thirty days shall,`
  line `for the purposes of this sub-section, be computed from the later date.`
  line
  line `(2) Every such objection shall be in writing signed by the person making it or by any person duly`
  line `authorised to sign on his behalf, and shall state the ground of objection; and the Marriage Officer shall`
  line `record the nature of the objection in his Marriage Notice Book.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (15804)
  sectionNo (9)
  orderNo 9
  title `Solemnization of marriage where no objection made.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15804&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_9_content:
  string
  line `If no objection is made within the period`
  line `specified in section 8 to an intended marriage, then, on the expiry of that period, the marriage may be`
  line solemnized.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (15805)
  sectionNo (10)
  orderNo 10
  title `Procedure on receipt of objection.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15805&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_10_content:
  string
  line `(1) If an objection is made under section 8 to an intended`
  line `marriage, the Marriage Officer shall not solemnize the marriage until he has inquired into the matter of`
  line `the objection in such manner as he thinks fit and is satisfied that it ought not to prevent the solemnization`
  line `of the Marriage or the objection is withdrawn by the person making it.`
  line
  line `(2) Where a Marriage Officer after making any such inquiry entertains a doubt in respect of any`
  line `objection, he shall transmit the record with such statement respecting the matter as he thinks fit to the`
  line `Central Government; and the Central Government, after making such further inquiry into the matter and`
  line `after obtaining such advice as it thinks fit, shall give its decision thereon in writing to the Marriage`
  line `Officer, who shall act in conformity with the decision of the Central Government.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (15806)
  sectionNo (11)
  orderNo 11
  title `Marriage not to be in contravention of local laws.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15806&sectionno=11&orderno=11&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_11_content:
  string
  line `(1) The Marriage Officer may, for reasons`
  line `to be recorded in writing, refuse to solemnize a marriage under this Act if the intended marriage is`
  line `prohibited by any law in force in the foreign country where it is to be solemnized.`
  line
  line `(2) The Marriage Officer may, for reasons to be recorded in writing, refuse to solemnize a marriage`
  line `under this Act on the ground that in his opinion, the solemnization of the marriage would be inconsistent`
  line `with international law or the comity of nations.`
  line
  line `(3) Where a Marriage Officer refuses to solemnize a marriage under this section, any party to the`
  line `intended marriage may appeal to the Central Government in the prescribed manner within a period of`
  line `thirty days from the date of such refusal; and the Marriage Officer shall act in conformity with the`
  line `decision of the Central Government on such appeal.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (15807)
  sectionNo (12)
  orderNo 12
  title `Declaration by parties and witnesses.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15807&sectionno=12&orderno=12&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_12_content:
  string
  line `Before the marriage is solemnized, the parties and three`
  line `witnesses shall, in the presence of the Marriage Officer, sign a declaration in the form specified in the`
  line `Second Schedule, and the declaration shall be countersigned by the Marriage Officer.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (15808)
  sectionNo (13)
  orderNo 13
  title `Place and form of solemnization.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15808&sectionno=13&orderno=13&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_13_content:
  string
  line `(1) A marriage by or before a Marriage Officer under this`
  line `Act shall be solemnized at the official house of the Marriage Officer with open doors between the`
  line `prescribed hours in the presence of at least three witnesses.`
  line
  line `(2) The marriage may be solemnized in any form which the parties may choose to adopt:`
  line
  line `Provided that it shall not be complete and binding on the parties unless each party declares to the`
  line `other in the presence of the Marriage Officer and the three witnesses and in any language understood by`
  line `the parties,-- "I, (A) take the (B), to be my lawful wife (or husband)":`
  line
  line `Provided further that where the declaration referred to in the preceding proviso is made in any`
  line `language which is not understood by the Marriage Officer or by any of the witnesses, either of the parties`
  line `shall interpret or cause to be interpreted the declaration in a language which the Marriage Officer, or, as`
  line `the case may be, such witness understands.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (15809)
  sectionNo (14)
  orderNo 14
  title `Certificate of marriage.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15809&sectionno=14&orderno=14&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_14_content:
  string
  line `(1) Whenever a marriage is solemnized under this Act, the Marriage`
  line `Officer shall enter a certificate thereof in the form specified in the Third Schedule in a book to be kept by`
  line `him for that purpose and to be called the Marriage Certificate Book, and such certificate shall be signed`
  line `by the parties to the marriage and the three witnesses.`
  line
  line `(2) On a certificate being entered in the Marriage Certificate Book by the Marriage Officer, the`
  line `certificate shall be deemed to be conclusive evidence of the fact that a marriage under this Act has been`
  line `solemnized, and that all formalities respecting the residence of the party concerned previous to the`
  line `marriage and the signatures of witnesses have been complied with.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (15810)
  sectionNo (15)
  orderNo 15
  title `Validity of foreign marriages in India.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15810&sectionno=15&orderno=15&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_15_content:
  string
  line `Subject to the other provisions contained in this Act, a`
  line `marriage solemnized in the manner provided in this Act shall be good and valid in law.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (15811)
  sectionNo (16)
  orderNo 16
  title `New notice when marriage not solemnized within six months.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15811&sectionno=16&orderno=16&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_16_content:
  string
  line `Whenever a marriage is not`
  line `solemnized within six months from the date on which notice thereof has been given to the Marriage`
  line `Officer as required under section 5 or where the record of a case has been transmitted to the Central`
  line `Government under section 10, or where an appeal has been preferred to the Central Government under`
  line `section 11, within three months from the date of decision of the Central Government in such case or`
  line `appeal, as the case may be, the notice and all other proceedings arising therefrom shall be deemed to have`
  line `lapsed, and no Marriage Officer shall solemnize the marriage until new notice has been given in the`
  line `manner laid down in this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (15812)
  sectionNo (17)
  orderNo 17
  title `Registration of foreign marriages.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15812&sectionno=17&orderno=17&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_17_content:
  string
  line `(1) Where--`
  line
  line `(a) a Marriage Officer is satisfied that a marriage has been duly solemnized in a foreign country`
  line `in accordance with the law of that country between parties of whom one at least was a citizen of`
  line `India; and`
  line
  line `(b) a party to the marriage informs the Marriage Officer in writing that he or she desires the`
  line `marriage to be registered under this section,`
  line `the Marriage Officer may, upon payment of the prescribed fee, register the marriage.`
  line
  line `(2) No marriage shall be registered under the section unless at the time of registration it satisfies the`
  line `conditions mentioned in section 4.`
  line
  line `(3) The Marriage Officer may, for reasons to be recorded in writing, refuse to register a marriage`
  line `under this section on the ground that in his opinion the marriage is inconsistent with international law or`
  line `the comity of nations.`
  line
  line `(4) Where a Marriage Officer refuses to register a marriage under this section the party applying for`
  line `registration may appeal to the Central Government in the prescribed manner within a period of thirty days`
  line `from the date of such refusal; and the Marriage Officer shall act in conformity with the decision of the`
  line `Central Government on such appeal.`
  line
  line `(5) Registration of a marriage under this section shall be effected by the Marriage Officer by entering`
  line `a certificate of the marriage in the prescribed form and in the prescribed manner in the Marriage`
  line `Certificate Book, and such certificate shall be signed by the parties to the marriage and by three`
  line witnesses.
  line
  line `(6) A marriage registered under this section shall, as from the date of registration, be deemed to have`
  line `been solemnized under this Act.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (15813)
  sectionNo (18)
  orderNo 18
  title `Matrimonial reliefs to be under Special Marriage Act, 1954.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15813&sectionno=18&orderno=18&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_18_content:
  string
  line `(1) Subject to the other`
  line `provisions contained in this section, the provisions of Chapters IV, V, VI and VII of the Special Marriage`
  line `Act, 1954 (43 of 1954) shall apply in relation to marriages solemnized under this Act and to any other`
  line `marriage solemnized in a foreign country between parties of whom one at least is a citizen of India as`
  line `they apply in relation to marriages solemnized under that Act.`
  line
  line `Explanation.--In its application to the marriages referred to in this sub-section, section 24 of the`
  line `Special Marriage Act, 1954 (43 of 1954), shall be subject to the following modifications, namely:--`
  line
  line `(i) the reference in sub-section (1) thereof to clauses (a), (b), (c) and (d) of section 4 of that Act`
  line `shall be construed as a reference to clauses (a), (b), (c) and (d) respectively of section 4 of this`
  line `Act, and`
  line
  line `(ii) nothing contained in section 24 aforesaid shall apply to any marriage--`
  line
  line `(a) which is not solemnized under this Act; or`
  line
  line `(b) which is deemed to be solemnized under this Act by reason of the provisions contained in`
  line `section 17:`
  line
  line `Provided that the registration of any such marriage as is referred to in sub-clause (b) may be declared`
  line `to be of no effect if the registration was in contravention of sub-section (2) of section 17.`
  line
  line `(2) Every petition for relief under Chapter V or Chapter VI of the Special Marriage`
  line `Act, 1954 (43 of 1954) as made applicable to the marriages referred to in sub-section (1) shall be`
  line `presented to the district court within the local limits of whose ordinary civil jurisdiction--`
  line
  line `(a) the respondent is residing at the time of the presentation of the petition; or`
  line
  line `(b) the husband and wife last resided together; or`
  line
  line `(c) the petitioner is residing at the time of the presentation of the petition, provided that the`
  line `respondent is at that time residing outside India.`
  line
  line `Explanation.--In this section, "district court" has the same meaning as in the Special Marriage`
  line `Act, 1954 (43 of 1954).`
  line
  line `(3) Nothing contained in this section shall authorise any court--`
  line
  line `(a) to make any decree of dissolution of marriage, except where--`
  line
  line `(i) the parties to the marriage are domiciled in India at the time of the presentation of the`
  line `petition; or`
  line
  line `(ii) the petitioner, being the wife, was domiciled in India immediately before the marriage`
  line `and has been residing in India for a period of not less than three years immediately preceding the`
  line `presentation of the petition;`
  line
  line `(b) to make any decree annulling avoidable marriage, except where--`
  line
  line `(i) the parties to the marriage are domiciled in India at the time of the presentation of the`
  line `petition; or`
  line
  line `(ii) the marriage was solemnized under this Act and the petitioner being the wife, has been`
  line `ordinarily resident in India for a period of three years immediately preceding the presentation of`
  line `the petition;`
  line
  line `(c) to make any decree of nullity of marriage in respect of a void marriage, except where--`
  line
  line `(i) either of the parties to the marriage is domiciled in India at the time of the presentation of`
  line `the petition; or`
  line
  line `(ii) the marriage was solemnized under this Act and the petitioner is residing in India at the`
  line `time of the presentation of the petition;`
  line
  line `(d) to grant any other relief under Chapter V or Chapter VI of the Special Marriage`
  line `Act, 1954 (43 of 1954), except where the petitioner is residing in India at the time of the presentation`
  line `of the petition.`
  line
  line `(4) Nothing contained in sub-section (1) shall authorise any court to grant any relief under this Act in`
  line `relation to any marriage in a foreign country not solemnized under it, if the grant of relief in respect of`
  line `such marriage (whether on any of the grounds specified in the Special Marriage Act, 1954 (43 of 1954),`
  line `or otherwise) is provided for under any other law for the time being in force.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (15814)
  sectionNo (19)
  orderNo 19
  title `Punishment for bigamy.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15814&sectionno=19&orderno=19&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_19_content:
  string
  line `(1) Any person whose marriage is solemnized or deemed to have`
  line `been solemnized under this Act and who, during the subsistence of his marriage, contracts any other`
  line `marriage in India shall be subject to the penalties provided in section 494 and section 495 of the Indian`
  line `Penal Code (45 of 1860) and the marriage so contracted shall be void.`
  line
  line `(2) The provisions of sub-section (1) apply also to any such offence committed by any citizen of India`
  line `without and beyond India.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (15815)
  sectionNo (20)
  orderNo 20
  title `Punishment for contravention of certain other conditions for marriage.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15815&sectionno=20&orderno=20&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_20_content:
  string
  line `Any citizen of India`
  line `who procures a marriage of himself or herself be solemnized under this Act in contravention of the`
  line `condition specified in clause (c) or clause (d) of section 4 shall be punishable--`
  line
  line `(a) in the case of a contravention of the condition specified in clause (c) of section 4, with simple`
  line `imprisonment which may extend to fifteen days, or with the fine which may extend to one thousand`
  line `rupees, or with both; and`
  line
  line `(b) in the case of a contravention of the condition specified in clause (d) of section 4, with simple`
  line `imprisonment which may extend to one month, or with fine which may extend to one thousand`
  line `rupees, or with both.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (15816)
  sectionNo (21)
  orderNo 21
  title `Punishment for false declaration.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15816&sectionno=21&orderno=21&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_21_content:
  string
  line `If any citizen of India for the purpose of procuring a`
  line `marriage, intentionally--`
  line
  line `(a) where a declaration is required by this Act, makes a false declaration; or`
  line
  line `(b) where a notice or certificate is required by this Act, signs a false notice or certificate,`
  line
  line `he shall be punishable with imprisonment for a term which may extend to three years and shall also be`
  line `liable to fine.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (15817)
  sectionNo (22)
  orderNo 22
  title `Punishment for wrongful action of Marriage Officer.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15817&sectionno=22&orderno=22&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_22_content:
  string
  line `Any Marriage Officer who knowingly`
  line `and wilfully solemnizes a marriage under this Act in contravention of any of the provisions of this Act`
  line `shall be punishable with simple imprisonment which may extend to one year, or with fine which may`
  line `extend to five hundred rupees, or with both.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (15818)
  sectionNo (23)
  orderNo 23
  title `Recognition of marriages solemnized under law of other countries.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15818&sectionno=23&orderno=23&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_23_content:
  string
  line `If the Central`
  line `Government is satisfied that the law in force in any foreign country for the solemnization of marriages`
  line `contains provisions similar to those contained in this Act, it may, by notification in the Official Gazette,`
  line `declare that marriages solemnized under the law in force in such foreign country shall be recognized by`
  line `courts in India as valid.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (15819)
  sectionNo (24)
  orderNo 24
  title `Certification of documents of marriages solemnized in accordance with local law in a foreign country.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15819&sectionno=24&orderno=24&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_24_content:
  string
  line `(1) Where--`
  line
  line `(a) a marriage is solemnized in any foreign country specified in this behalf by the Central`
  line `Government, by notification in the Official Gazette, in accordance with the law of that country`
  line `between parties of whom one at least is a citizen of India; and`
  line
  line `(b) a party to the marriage who is such citizen produces to a Marriage Officer in the country in`
  line `which the marriage was solemnized--`
  line
  line `(i) a copy of the entry in respect of the marriage in the marriage register of that country`
  line `certified by the appropriate authority in that country to be a true copy of that entry; and`
  line
  line `(ii) if the copy of that entry is not in the English language, a translation into the prescribed`
  line `language of that copy; and`
  line
  line `(c) the Marriage Officer is satisfied that the copy of the entry in the marriage register is a true`
  line `copy and that the translation, if any, is a true translation;`
  line
  line `the Marriage Officer, upon the payment of the prescribed fee, shall certify upon the copy that he is`
  line `satisfied that the copy is a true copy of the entry in the marriage register and upon the translation that he is`
  line `satisfied that the translation is a true translation of the copy and shall issue the copy and the translation to`
  line `the said party.`
  line
  line `(2) A document relating to a marriage in a foreign country issued under sub-section (1) shall be`
  line `admitted in evidence in any proceedings as if it were a certificate duly issued by the appropriate authority`
  line `of that country.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (15820)
  sectionNo (25)
  orderNo 25
  title `Certified copy of entries to be evidences.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15820&sectionno=25&orderno=25&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_25_content:
  string
  line `Every certified copy purporting to be signed by the`
  line `Marriage Officer of an entry of a marriage in the Marriage Certificate Book shall be received in evidence`
  line `without production or proof of the original.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (15821)
  sectionNo (26)
  orderNo 26
  title `Correction of errors.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15821&sectionno=26&orderno=26&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_26_content:
  string
  line `(1) Any Marriage Officer who discovers any error in the form or`
  line `substance of any entry in the Marriage Certificate Book may, within one month next after the discovery of`
  line `such error, in the presence of the persons married, or, in case of their death or absence, in the presence of`
  line `two other witnesses, correct the error by entry in the margin without any alteration of the original entry`
  line `and add thereto the date of such correction.`
  line
  line `(2) Every correction made under this section shall be attested by the witnesses in whose presence it`
  line `was made.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (15822)
  sectionNo (27)
  orderNo 27
  title `Act not to affect validity of marriages outside it.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15822&sectionno=27&orderno=27&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_27_content:
  string
  line `Nothing in this Act shall in any way affect`
  line `the validity of a marriage solemnized in a foreign country otherwise than under this Act.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (15823)
  sectionNo (28)
  orderNo 28
  title `Power to make rules.`
  content obj_root_law_sections_28_content
  footnotes `1. Subs. by Act 20 of 1983, s. 2 and the schedule., for certain words (w.e.f. 15-3-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15823&sectionno=28&orderno=28&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_28_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the duties and powers of Marriage Officers and their districts;`
  line
  line `(b) the manner in which a Marriage Officer may hold any inquiry under this Act;`
  line
  line `(c) the manner in which notices of marriage shall be published;`
  line
  line `(d) the places in which and the hours between which marriages under this Act may be`
  line solemnized;
  line
  line `(e) the form and the manner in which any books required by or under this Act to be kept shall be`
  line maintained;
  line
  line `(f) the form and manner in which certificates of marriages may be entered under sub-section (5)`
  line `of section 17;`
  line
  line `(g) the fees that may be levied for the performance of any duty imposed upon a Marriage Officer`
  line `under this Act;`
  line
  line `(h) the authorities to which, the form in which and the intervals within which copies of entries in`
  line `the Marriage Certificate Book shall be sent, and, when corrections are made in the Marriage`
  line `Certificate Book, the manner in which Certificates of such corrections shall be sent to the authorities;`
  line
  line `(i) the inspection of any books required to be kept under this Act and the furnishing of certified`
  line `copies of entries therein;`
  line
  line `(j) the manner in which and the conditions subject to which any marriage may be recognised`
  line `under section 23;`
  line
  line `(k) any other matter which may be, or requires to be, prescribed.`
  line
  line `(3) Every rule made under this section shall be laid as soon as may be after it is made before each`
  line `House of Parliament while it is in session for a total period of thirty days which may be comprised in one`
  line `session or ^1`
  line `[in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid] both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_29:
  sectionId (15824)
  sectionNo (29)
  orderNo 29
  title `Amendment of Act 43 of 1954.`
  content obj_root_law_sections_29_content
  footnotes `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15824&sectionno=29&orderno=29&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_29_content:
  string
  line `In the Special Marriage Act, 1954,--`
  line
  line `(a) in section 1, in sub-section (2), for the words "outside the said territories, the words "in the`
  line `State of Jammu and Kashmir*" shall be substituted;`
  line
  line `(b) in section 2, clauses (a) and (c) shall be omitted;`
  line
  line `(c) in section 3, for sub-section (2), the following sub-section shall be substituted, namely:--`
  line
  line `"(2) For the purposes of this Act, in its application to citizens of India domiciled in the`
  line `territories to which this Act extends who are in the State of Jammu and Kashmir*, the Central`
  line `Government may, by notification in the Official Gazette, specify such officers of the Central`
  line `Government as it may think fit to be the Marriage Officers for the State or any part thereof.";`
  line
  line `(d) in section 4, for clause (e), the following clause shall be substituted, namely:--`
  line
  line `"(e) where the marriage is solemnized in the State of Jammu and Kashmir*, both parties are`
  line `citizens of India domiciled in the territories to which this Act extends.";`
  line
  line `(e) in section 10, for the words "outside the territories to which this Act extends in respect of an`
  line `intended marriage outside and said territories", the words "in the State of Jammu and Kashmir* in`
  line `respect of an intended marriage in the State" shall be substituted;`
  line
  line `(f) in section 50, in sub-section (1), the words "Diplomatic and consular officers and other" shall`
  line `be omitted.`
obj_root_law_sections_30:
  sectionId (15825)
  sectionNo (30)
  orderNo 30
  title Repeal.
  content `The Indian Foreign Marriage Act, 1903 (14 of 1903), is hereby repealed.`
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00029_196933_1517807324405&sectionId=15825&sectionno=30&orderno=30&orgactid=AC_CEN_3_20_00029_196933_1517807324405
obj_root_law_sections_30_footnotes:
  string
  line
