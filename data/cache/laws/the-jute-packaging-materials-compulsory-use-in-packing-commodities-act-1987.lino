obj_root_law:
  slug the-jute-packaging-materials-compulsory-use-in-packing-commodities-act-1987
  handle (1882)
  collectionHandle 123456789/1362
  title `The Jute Packaging Materials (Compulsory Use in Packing Commodities) Act, 1987`
  actNumber (10)
  enactmentDate 1987-05-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1882`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `जूट पैकेज सामग्री (वस्‍तु पैकिंग अनिवार्य प्रयोग)अधिनियम, 1987`
  actYear (1987)
  ministry `Ministry of Textiles`
  department undefined
  longTitle `An Act to provide for the compulsory use of jute packaging material in the supply and distribution of certain commodities in the interests of production of raw jute and jute packaging material, and of persons engaged in the production thereof, and for matters connected therewith.`
