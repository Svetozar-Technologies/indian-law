  (str slug) (str the-jute-packaging-materials-compulsory-use-in-packing-commodities-act-1987)
  (str handle) (str 1882)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Jute Packaging Materials (Compulsory Use in Packing Commodities) Act, 1987`)
  (str actNumber) (str 10)
  (str enactmentDate) (str 1987-05-09)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1882`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `जूट पैकेज सामग्री (वस्‍तु पैकिंग अनिवार्य प्रयोग)अधिनियम, 1987`)
  (str actYear) (str 1987)
  (str ministry) (str `Ministry of Textiles`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the compulsory use of jute packaging material in the supply and distribution of certain commodities in the interests of production of raw jute and jute packaging material, and of persons engaged in the production thereof, and for matters connected therewith.`)
  (str enforcementDate) (str 14-05-1987)
  (str notification) (str `14th May, 1987, vide notification No. S.O. 467(E), dated 14th May, 1987, see Gazette of India, Extraordinary, Part II, sec. 3 (ii).`)
  (str fetchedAt) (str `2026-05-09T21:34:47.838Z`)
