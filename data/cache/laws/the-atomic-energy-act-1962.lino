obj_root_law_sections_1:
  sectionId (1332)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1332&sectionno=1&orderno=1&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Atomic Energy`
  line `Act, 1962.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 21st September, 1962, vide notification No. G.S.R. 1254, dated 18th September, 1962, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3 (i).`
obj_root_law_sections_2:
  sectionId (1333)
  sectionNo (2)
  orderNo 2
  title `Definitions and interpretation.`
  content obj_root_law_sections_2_content
  footnotes `1.Subs. by Act 5 of 2016, s. 2, for clause (bb) (w.e.f. 15-05-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1333&sectionno=2&orderno=2&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) atomic energy means energy released from atomic nuclei as a result of any process,`
  line `including the fission and fusion processes;`
  line
  line `(b) fissile material means uranium 233, uranium 235, plutonium or any material containing`
  line `these substances or any other material that may be declared as such by notification by the Central`
  line Government;
  line
  line `^1[(bb) Government company means a company in which-`
  line
  line `(i) not less than fifty-one per cent. of the paid-up share capital is held by the Central Government; or`
  line
  line `(ii) the whole of the paid-up share capital is held by one or more of the companies specified in sub-clause (i) and which, by its articles of association, empowers the Central Government to constitute and reconstitute its Board of Directors;`
  line
  line `(c) minerals include all substances obtained or obtainable from the soil (including alluvium or`
  line `rocks) by underground or surface working;`
  line
  line `(d) notification means notification published in the Official Gazette;`
  line
  line `(e) Plant includes machinery, equipment or appliance, whether affixed to land or not;`
  line
  line `(f) prescribed equipment means any property which the Central Government may, by`
  line `notification, prescribe, being a property which in its opinion is specially designed or adapted or which`
  line `is used or intended to be used for the production or utilisation of any prescribed substance, or for the`
  line `production or utilisation of atomic energy, radioactive substances, or radiation, but does not include`
  line `mining, milling, laboratory and other equipment not so specially designed or adapted and not`
  line `incorporated in equipment used or intended to be used for any of the purposes aforesaid;`
  line
  line `(g) prescribed substance means any substance including any mineral which the Central`
  line `Government may, by notification, prescribe, being a substance which in its opinion is or may be used`
  line `for the production or use of atomic energy or research into matters connected therewith and includes`
  line `uranium, plutonium, thorium, beryllium, deuterium or any of their respective derivatives or`
  line `compounds or any other materials containing any of the aforesaid substances;`
  line
  line `(h) radiation means gamma rays, X-rays, and rays consisting of alpha particles, beta particles,`
  line `neutrons, protons and other nuclear and sub-atomic particles; but not sound or radio waves, or visible,`
  line `infrared or ultraviolet light;`
  line
  line `(i) radioactive substance or radioactive material means any substance or material which`
  line `spontaneously emits radiation in excess of the levels prescribed by notification by the Central`
  line Government.
  line
  line `(2) Any reference in this Act to the working of minerals shall be construed as including a reference to`
  line `the mining, getting, carrying away, transporting, sorting, extracting or otherwise treating of minerals.`
  line
  line `(3) Any reference in this Act to the production or use of atomic energy shall be construed as including`
  line `a reference to the carrying out of any process, preparatory or ancillary to such production or use.`
obj_root_law_sections_3:
  sectionId (1334)
  sectionNo (3)
  orderNo 3
  title `General powers of the Central Government.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1334&sectionno=3&orderno=3&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_3_content:
  string
  line `Subject to the provisions of this Act, the Central`
  line `Government shall have power--`
  line
  line `(a) to produce, develop, use and dispose of atomic energy ^1[either by itself or through any`
  line `authority or corporation established by it or a Government company] and carry out research into any`
  line `matters connected therewith;`
  line
  line `^2[(b) to manufacture or otherwise produce any prescribed or radioactive substance and any`
  line `articles which in its opinion are, or are likely to be, required for or in connection with, the production,`
  line `development or use of atomic energy or such research as aforesaid and to dispose of such prescribed`
  line `or radioactive substance or any articles manufactured or otherwise produced;`
  line
  line `(bb) (i) to buy or otherwise acquire, store and transport any prescribed or radioactive`
  line `substance and any articles which in its opinion are, or are likely to be, required for, or in`
  line `connection with, the production, development or use of atomic energy; and`
  line
  line `(ii) to dispose of such prescribed or radioactive substance or any articles bought or otherwise`
  line `acquired by it,`
  line
  line `either by itself or through any authority or corporation established by it, or a Government company;]`
  line
  line `(c) to declare as “restricted information” any information not so far published or otherwise made`
  line `public relating to--`
  line
  line `(i) the location, quality and quantity of prescribed substances and transactions for their`
  line `acquisition, whether by purchase or otherwise, or disposal, whether by sale or otherwise;`
  line
  line `(ii) the processing or prescribed substances and the extraction or production of fissile`
  line `materials from them;`
  line
  line `(iii) the theory, design, construction and operation of plants for the treatment and production`
  line `of any of the prescribed substances and for the separation or isotopes;`
  line
  line `(iv) the theory, design, construction and operation of nuclear reactors;`
  line
  line `(v) research and technological work on materials and processes involved in or derived from`
  line `items (i) to (iv);`
  line
  line `(d) to declare as “prohibited area” any area or premises where work including research, design or`
  line `development is carried on in respect of the production, treatment, use, application or disposal of`
  line `atomic energy or of any prescribed substances;`
  line
  line `(e) to provide for control over radioactive substances or radiation generating plant in order to--`
  line
  line `(i) prevent radiation hazards;`
  line
  line `(ii) secure public safety and safety or persons handling radioactive substances or radiation`
  line `generating plant; and`
  line
  line `(iii) ensure safe disposal of radioactive wastes;`
  line
  line `(f) to provide for the production and supply of electricity from atomic energy and for taking`
  line `measures conducive to such production and supply and for all matters incidental thereto ^1[either by`
  line `itself or through any authority or corporation established by it or a Government company]; and`
  line
  line `(g) to do all such things (including the erection of buildings and execution of works and the`
  line `working of minerals) as the Central Government considers necessary or expedient for the exercise of`
  line `the foregoing powers.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Ins. by Act 29 of 1987, s. 3 (w.e.f. 8-9-1987).`
  line
  line `2. Subs. by s. 3, ibid., for clause (b) (w.e.f. 8-9-1987).`
obj_root_law_sections_4:
  sectionId (1335)
  sectionNo (4)
  orderNo 4
  title `Notification of discovery of uranium or thorium.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1335&sectionno=4&orderno=4&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_4_content:
  string
  line `(1) Every person who, whether before or`
  line `after the commencement of this Act, has discovered or discovers that uranium or thorium occurs at any`
  line `place in India shall, within three months after the date of commencement of this Act or after the`
  line `discovery, whichever is later, report the discovery in writing to the Central Government or to any person`
  line `or authority authorised by the Central Government in this behalf.`
  line
  line `(2) Every person who has reason to believe that uranium or thorium occurs at any place in India shall,`
  line `without delay, send intimation of such belief and the reasons therefor to the Central Government or to any`
  line `such person or authority as aforesaid.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (1336)
  sectionNo (5)
  orderNo 5
  title `Control over mining or concentration of substances containing uranium.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1336&sectionno=5&orderno=5&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_5_content:
  string
  line `(1) If the Central`
  line `Government is satisfied that any person is mining or is about to mine any substance from which, in the`
  line `opinion of the Central Government, uranium can be or may reasonably be expected to be, isolated or`
  line `extracted, or is engaged or is about to be engaged in treating or concentrating by any physical, chemical`
  line `or metallurgical process any substance from which, in the opinion of the Central Government, uranium`
  line `can be or may reasonably be expected to be, isolated or extracted, the Central Government may be notice`
  line `in writing given to that person either--`
  line
  line `(a) require him in conducting the mining operations or in treating or concentrating the substance`
  line `aforesaid to comply with such terms and conditions and adopt such processes as the Central`
  line `Government may in the notice, or from time to time thereafter, think fit to specify, or`
  line
  line `(b) totally prohibit him from conducting the mining operations or treating or concentrating the`
  line `substance aforesaid.`
  line
  line `(2) Where any terms and conditions are imposed on any person conducting any mining operations or`
  line `treating or concentrating any substance under clause (a) of sub-section (1), the Central Government may,`
  line `having regard to the nature of the terms and conditions, decide as to whether or not to pay any`
  line `compensation to that person and the decision of the Central Government shall be final:`
  line
  line `Provided that where the Central Government decides not to pay any compensation, it shall record in`
  line `writing a brief statement giving the reasons for such decision.`
  line
  line `(3) Where the Central Government decides to pay any compensation under sub-section (2), the`
  line `amount thereof shall be determined in accordance with section 21 but in calculating the compensation`
  line `payable, no account shall be taken of the value of any uranium contained in the substance referred to in`
  line `sub-section (1).`
  line
  line `(4) Where any mining operation or any process of treatment or concentration of any substance is`
  line `prohibited under clause (b) of sub-section (1), the Central Government shall pay compensation to the`
  line `person conducting the mining operations or using the process of treatment or concentration and the`
  line `amount of such compensation shall be determined in accordance with section 21 but in calculating the`
  line `compensation payable, no account shall be taken of the value of any uranium contained in the substance.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (1337)
  sectionNo (6)
  orderNo 6
  title `Disposal of uranium.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1337&sectionno=6&orderno=6&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_6_content:
  string
  line `(1) No minerals, concentrates and other materials which contain uranium`
  line `in its natural state in excess of such proportion as may be prescribed by notification by the Central`
  line `Government shall be disposed of except with the previous permission in writing of the Central`
  line `Government and in accordance with such terms and conditions as it may impose.`
  line
  line `(2) The Central Government may serve notice on any person who has produced any mineral,`
  line `concentrate or other material referred to in sub-section (1) that the Central Government ^1[proposes to`
  line `compulsorily acquire it and upon the service of the notice], the mineral, concentrate or other material`
  line `shall become the property of the Central Government and shall be delivered to the Central Government or`
  line `as it may direct:`
  line
  line `^2* * * * *`
  line
  line `^3[(3) Compensation in respect of acquisition under sub-section (2) shall be paid in accordance with`
  line `section 21 and in determining such compensation regard shall be had to the cost of production of such`
  line `mineral, concentrate or other material and such other factors as may be relevant but no account shall be`
  line `taken of the value of uranium in its natural state contained therein.]`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 59 of 1986, s. 2, for certain words (w.e.f. 21-9-1962),`
  line
  line `2. The proviso omitted by Act 59 of 1986, s. 2 (w.e.f. 21-9-1962).`
  line
  line `3. Ins. by s. 2, ibid. (w.e.f. 21-9-1962).`
obj_root_law_sections_7:
  sectionId (1338)
  sectionNo (7)
  orderNo 7
  title `Powers to obtain information regarding materials, plant or processes.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1338&sectionno=7&orderno=7&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_7_content:
  string
  line `The Central`
  line `Government may, by notice in writing served on any person, require him to make such periodical and`
  line `other returns, or statements at such times and containing such particulars and accompanied by such plans,`
  line `drawings, and other documents as may be specified in the notice relating to--`
  line
  line `(a) any prescribed substance, specified in the notice, in his possession or under his control or`
  line `present in or on any land or mine owned or occupied by him which in the opinion of the Central`
  line `Government is or can be a source of any of the prescribed substances, including returns in respect of`
  line `any such land or mine;`
  line
  line `(b) any plant in his possession or under his control designed for mining or processing of minerals`
  line `so specified, or adapted for the production or use of atomic energy or research into matters connected`
  line therewith;
  line
  line `(c) any contract entered into by him or any licence granted by or to him relating to prospecting or`
  line `mining of minerals so specified or the production or use of atomic energy or research into matters`
  line `connected therewith;`
  line
  line `(d) any other information in his possession relating to any work carried out by him or on his`
  line `behalf or under his directions, in connection with prospecting or mining of materials so specified or`
  line `the production or use of atomic energy or research into matters connected therewith.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (1339)
  sectionNo (8)
  orderNo 8
  title `Powers of entry and inspection.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1339&sectionno=8&orderno=8&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_8_content:
  string
  line `(1) Any person authorised by the Central Government may, on`
  line `producing, if so required, a duly authenticated document showing his authority, enter any mine, premises`
  line `or land--`
  line
  line `(a) where he has reason to believe that work is being carried out for the purpose of or in`
  line `connection with production and processing of any prescribed substances or substances from which a`
  line `prescribed substance can be obtained or production, development or use of atomic energy or research`
  line `into matters connected therewith, or`
  line
  line `(b) where any such plant as is mentioned in clause (b) of section 7 is situate,`
  line
  line `and may inspect the mine, premises or land and any articles contained therein.`
  line
  line `(2) The person carrying out the inspection may make copies of or extracts from any drawing, plan or`
  line `other document found in the mine, premises or land and for the purpose of making such copies or`
  line `extracts, may remove any such drawing, plan or other document after giving a duly signed receipt for the`
  line `same and retain possession thereof for a period not exceeding seven days.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (1340)
  sectionNo (9)
  orderNo 9
  title `Power to do work for discovering minerals.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1340&sectionno=9&orderno=9&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government may, subject to the`
  line `provisions of this section, do on, over or below the surface of any land such work as it considers`
  line `necessary for the purpose of discovering whether there is present in or on the land, either in a natural state`
  line `or in a deposit of waste material obtained from any underground or surface working, any substance from`
  line `which in its opinion any of the prescribed substances can be obtained, and the extent to which such`
  line `substance is so present.`
  line
  line `(2) Before any powers are exercised under sub-section (1) in relation to any land, the Central`
  line `Government shall serve on every owner, lessee and occupier of the land a notice in writing specifying the`
  line `nature of the work proposed to be done and the extent of the land affected, and the time, not being less`
  line `than twenty-eight days, within which and the manner in which objections can be made thereto, and no`
  line `such powers shall be exercised otherwise than in pursuance of the notice or before the expiration of the`
  line `time specified therein for making objections.`
  line
  line `(3) The Central Government may, after giving the person making the objection an opportunity of`
  line `appearing before and being heard by a person appointed by the Central Government for the purpose, and`
  line `after considering any such objection and the report of the person so appointed, make such orders as it may`
  line `deem proper but not so as to increase the extent of the land affected.`
  line
  line `(4) Compensation shall be determined and paid in accordance with section 21 in respect of any`
  line `diminution in the value of any land or property situate thereon resulting from the exercise of powers`
  line `under this section.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (1341)
  sectionNo (10)
  orderNo 10
  title `Compulsory acquisition of rights to work minerals.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1341&sectionno=10&orderno=10&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_10_content:
  string
  line `(1) Where it appears to the Central`
  line `Government that any minerals from which in its opinion any of the prescribed substances can be obtained`
  line `are present in or on any land, either in a natural state or in a deposit of waste material obtained from any`
  line `underground or surface working, it may by order provide for compulsorily vesting in the Central`
  line `Government the exclusive right, so long as the order remains in force to work those minerals and any`
  line `other minerals which it appears to the Central Government to be necessary to work with those minerals,`
  line `and may also provide, by that order or a subsequent order, for compulsorily vesting in the Central`
  line `Government any other ancillary rights which appear to the Central Government to be necessary for the`
  line `purpose of working the minerals aforesaid including (without prejudice to the generality of the foregoing`
  line `provisions) --`
  line
  line `(a) rights to withdraw support;`
  line
  line `(b) rights necessary for the purpose of access to or conveyance of the minerals aforesaid or the`
  line `ventilation or drainage of the working;`
  line
  line `(c) rights to use and occupy the surface of any land for the purpose of erecting any necessary`
  line `buildings and installing any necessary plant in connection with the working of the minerals aforesaid;`
  line
  line `(d) rights to use and occupy for the purpose of working the minerals aforesaid any land forming`
  line `part of or used in connection with an existing mine or quarry, and to use or acquire any plant used in`
  line `connection with any such mine or quarry; and`
  line
  line `(e) rights to obtain a supply or water for any of the purposes connected with the working of the`
  line `minerals aforesaid, or to dispose of water or other liquid matter obtained in consequence of working`
  line `such minerals.`
  line
  line `(2) Notice of any order proposed to be made under this section shall be served by the Central`
  line Government--
  line
  line `(a) on all persons who, but for the order, would be entitled to work the minerals affected; and`
  line
  line `(b) on every owner, lessee and occupier (except tenants for a month or for less than a month) of`
  line `any land in respect of which rights are proposed to be acquired under the order.`
  line
  line `(3) Compensation in respect of any right acquired under this section shall be paid in accordance with`
  line `section 21, but in calculating the compensation payable, no account shall be taken of the value of any`
  line `minerals present in or on land affected by the order, being minerals specified in the order as those from`
  line `which in the opinion of the Central Government uranium or any concentrate or derivative of uranium can`
  line `be obtained`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (1342)
  sectionNo (11)
  orderNo 11
  title `Compulsory acquisition of prescribed substances, minerals and plants.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1342&sectionno=11&orderno=11&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_11_content:
  string
  line `(1) Save as`
  line `otherwise provided in any other provision of this Act, the Central Government may compulsorily acquire`
  line `in accordance with the provisions of this section--`
  line
  line `(a) any prescribed substance;`
  line
  line `(b) any minerals from which in the opinion of the Central Government any of the prescribed`
  line `substances can be obtained;`
  line
  line `(c) any prescribed equipment;`
  line
  line `(d) any plant which is designed or adapted for the mining or processing of any minerals referred`
  line `to in clause (b) or substances obtained therefrom or for the production or use of any prescribed`
  line `substance or a radioactive substance or for the production, use or disposal of such articles as are or`
  line `are likely to be required for or in connection with the production, use or disposal of atomic energy or`
  line `for research into matters connected therewith.`
  line
  line `(2) Where the Central Government acquires any plant referred to in clause (d) of sub-section (1), it`
  line `shall also have the right to acquire any buildings, railway sidings, tramway lines, or aerial ropeways`
  line `serving such plant.`
  line
  line `(3) Where the Central Government proposes to acquire any property under sub-section (1), it shall`
  line `serve upon the person appearing to be the owner thereof, a notice in writing specifying the property to be`
  line `acquired and requiring that person to make to the Central Government within the time specified in the`
  line `notice a written declaration containing such particulars as may be so specified regarding the ownership of`
  line `such property and any agreement or charge by virtue of which any other person has an interest in such`
  line property.
  line
  line `(4) Upon the service of a notice under sub-section (3), no property to which the notice relates shall be`
  line `disposed of without the previous permission in writing of the Central Government.`
  line
  line `(5) If it appears to the Central Government in consequence of any written declaration made to`
  line `it in pursuance of sub-section (3) that any person other than the person on whom the notice under`
  line `sub-section (3) was served is the owner of, or has any interest in, the property to which the notice relates,`
  line `the Central Government shall serve a copy of the notice on that other person.`
  line
  line `(6) A notice served under sub-section (3) shall contain a statement to the effect that an objection may`
  line `be made thereto within such time and in such manner as may be specified, and if any such objection is`
  line `duly made and not withdrawn, the Central Government shall afford an opportunity to the person making`
  line `the objection of appearing before and being heard by a person appointed by the Central Government for`
  line `the purpose.`
  line
  line `(7) After considering any such objection, and the report of the person appointed by it under`
  line `sub-section (6), the Central Government may serve on the persons upon whom the notice under`
  line `sub-section (3) or a copy thereof was served a further notice in writing either withdrawing the notice of`
  line `acquisition or confirming the said notice as respects the property to which it relates or such part of the`
  line `property as may be specified.`
  line
  line `(8) Any property with respect to which a notice of acquisition is served under this section shall--`
  line
  line `(a) if no objection is duly made to the notice, vest in the Central Government at the expiration of`
  line `the time for making such objection;`
  line
  line `(b) if such an objection is duly made and the notice is confirmed as respect the whole or any part`
  line `of that property by a notice served under sub-section (7), vest accordingly in the Central Government`
  line `on the service of the last mentioned notice;`
  line
  line `and shall in either case vest free from all encumbrances.`
  line
  line `(9) Compensation in respect of acquisition under this section shall be paid in accordance with`
  line `section 21.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_11_a:
  sectionId (1343)
  sectionNo 11A
  orderNo 12
  title `Removal of doubts.`
  content obj_root_law_sections_11_a_content
  footnotes `1. Ins. by Act 59 of 1986, s. 3 (w.e.f. 21-9-1962).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1343&sectionno=11A&orderno=12&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_11_a_content:
  string
  line `^1[11A. Removal of doubts.-- For the removal of doubts, it is hereby declared that the compulsory`
  line `acquisition of any mineral, concentrate or other material under sub-section (2) of section 6, or of any`
  line `substance, minerals, equipment or plant under sub-section (1) of section 11, shall not be deemed to be a`
  line `sale for any purpose whatsoever.]`
obj_root_law_sections_12:
  sectionId (1344)
  sectionNo (12)
  orderNo 13
  title `Compensation in case of compulsory acquisition of a mine.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1344&sectionno=12&orderno=13&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_12_content:
  string
  line `Where the Central Government`
  line `acquires, in accordance with any law, any mine or part of a mine from which in the opinion of the Central`
  line `Government any of the prescribed substances can be obtained, compensation in respect of such`
  line `acquisition shall be paid in accordance with section 21:`
  line
  line `Provided that in determining the amount of such compensation, no account shall be taken of the value`
  line `of uranium which may be obtained from such mine or part of a mine`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (1345)
  sectionNo (13)
  orderNo 14
  title `Novation of certain contracts.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1345&sectionno=13&orderno=14&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_13_content:
  string
  line `(1) The Central Government may serve on the parties to a`
  line `contract relating to prospecting or mining of any substance from which any of the prescribed substances`
  line `can be obtained or to production or use of atomic energy or to research into matters connected therewith,`
  line `not being a contract for the rendering of personal services, a notice in writing stating that on such date as`
  line `may be specified in the notice the rights and liabilities of any of the parties to the contract specified in the`
  line `notice (hereinafter referred to as the specified party) will be transferred to the Central Government, and`
  line `thereupon subject to any withdrawal of the notice under the following provisions of this section, the`
  line `contract shall, as regards any rights exercisable, or liabilities incurred, on or after the said date, have`
  line `effects as if the Central Government were a party to the contract instead of the specified party and as if`
  line `for any reference in the contract to the specified party there were substituted a reference to the Central`
  line Government.
  line
  line `(2) A notice served under sub-section (1) shall contain a statement to the effect that an objection may`
  line `be made thereto within such time and in such manner as may be specified, and if any such objection is`
  line `duly made and not withdrawn, the Central Government shall afford an opportunity to the person making`
  line `the objection of appearing before and being heard by person appointed by the Central Government for the`
  line purpose.
  line
  line `(3) After considering any such objection and the report of the person appointed by it under`
  line `sub-section (2), the Central Government may make such order as it may deem proper.`
  line
  line `(4) Where the rights and liabilities of a party to a contract are transferred to the Central Government`
  line `under this section, there shall be paid to that party such compensation in respect of any loss suffered by`
  line `that party as may be agreed between him and the Central Government, and in default of such agreement,`
  line `as may be determined by arbitration.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (1346)
  sectionNo (14)
  orderNo 15
  title `Control over production and use of atomic energy.`
  content obj_root_law_sections_14_content
  footnotes `1. Ins. by Act 5 of 2016, s. 3 (w.e.f. 15-05-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1346&sectionno=14&orderno=15&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_14_content:
  string
  line `(1) The Central Government may, subject`
  line `to such rules as may be made in this behalf, by order prohibit except under a licence granted by it--`
  line
  line `(i) the working of any mine or minerals specified in the order, being a mine or minerals from`
  line `which in the opinion of the Central Government any of the prescribed substances can be obtained;`
  line
  line `(ii) the acquisition, production, possession, use, disposal, export or import`
  line
  line `(a) of any of the prescribed substances; or`
  line
  line `(b) of any minerals or other substances specified in the rules, from which in the opinion of the`
  line `Central Government any of the prescribed substances can be obtained; or`
  line
  line `(c) of any plant designed or adopted or manufactured for the production, development and`
  line `use of atomic energy or for research into matters connected therewith; or`
  line
  line `(d) of any prescribed equipment.`
  line
  line ^1
  line `[(1A) No licence under sub-clause (c) of clause (ii) of sub-section (1) shall be granted to a person`
  line `other than a Department of the Central Government or any authority or an institution or a corporation`
  line `established by the Central Government, or a Government company.`
  line
  line `(1B) Any licence granted to a Government company under sub-section (1) shall stand cancelled in`
  line `case the licensee ceases to be a Government company and, notwithstanding anything contained in any`
  line `other law for the time being in force, all assets thereof shall vest in the Central Government free from any`
  line `liability and the Central Government shall take such measures for safe operation of the plant and disposal`
  line `of nuclear material so vested in it, as may be necessary in accordance with the provisions of section 3.]`
  line
  line `(2) Nothing in this section shall affect the authority of the Central Government to refuse a licence for`
  line `the purpose of this section or to include in a licence such conditions as the Central Government thinks fit`
  line `or to revoke a licence and the Central Government may take any action as aforesaid.`
  line
  line `(3) Without prejudice to the generality of the foregoing provisions, the rules referred to in this section`
  line `may provide for--`
  line
  line `(a) the extent to which information in the possession of, or which has been made available to, the`
  line `person granted a licence for purposes of this section, should be regarded as restricted information;`
  line
  line `(b) the extent to which the area or premises under the control of the person to whom a licence has`
  line `been granted for purposes of this section, should be regarded as a prohibited area;`
  line
  line `(c) the conditions and criteria for location of any installation or operation of any plant in respect`
  line `of which a licence has been granted or is intended to be granted for the purposes of this section`
  line `including those necessary for protection against radiation and safe disposal of harmful by-products or`
  line wastes;
  line
  line `(d) the extent of the licensee's liability in respect of any hurt to any person or any damage to`
  line `property caused by ionising radiations or any radioactive contamination either at the plant under`
  line `licence or in the surrounding area;`
  line
  line `(e) provision by licensee either by insurance or by such other means as the Central Government`
  line `may approve, of sufficient funds to be available at all times to ensure settlement of any claims in`
  line `connection with the use of the site or the plant under licence which have been or may be duly`
  line `established against the licensee in respect of any hurt to any person or any damage to any property`
  line `caused by ionising radiations emitted at the plant under licence or radioactive contamination either at`
  line `the plant under licence or in surrounding areas;`
  line
  line `(f) obligatory qualifications, security clearances, hours of employment, minimum leave and`
  line `periodical medical examination of the persons employed and any other requirement or restriction or`
  line `prohibition on the employer, employed persons and other persons; and`
  line
  line `(g) such other incidental and supplementary provisions including provisions for inspection and`
  line `also for the sealing or premises and seizure, retention and disposal of any article in respect of which`
  line `there are reasonable grounds for suspecting that a contravention of the rules has been committed, as`
  line `the Central Government considers necessary.`
  line
  line `(4) The Central Government may also prescribe the fees payable for issue of licences under`
  line `sub-section (1).`
obj_root_law_sections_15:
  sectionId (1347)
  sectionNo (15)
  orderNo 16
  title `Requisitioning of any substance for extracting uranium or plutonium.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1347&sectionno=15&orderno=16&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_15_content:
  string
  line `(1) The Central`
  line `Government shall have the right to require that any substance which, in the opinion of the Central`
  line `Government, contains uranium, plutonium or any of their isotopes, shall be delivered to it and the Central`
  line `Government may extract from that substance the uranium, plutonium or any of their isotopes contained`
  line `therein and return the substance to the person concerned on payment of compensation which shall be`
  line `determined in accordance with section 21:`
  line
  line `Provided that such compensation shall not, in any case, exceed the cost incurred by the person in the`
  line `production, mining or irradiation of the substance and in determining the same no account shall be taken`
  line `on the value of the uranium, plutonium or any of their isotopes extracted from the substance.`
  line
  line `(2) Nothing in this section shall prevent the Central Government from permitting, subject to such`
  line `conditions as it may deem fit to impose, the use of small quantities of natural uranium for the purpose of`
  line `examination, test or analysis.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (1348)
  sectionNo (16)
  orderNo 17
  title `Control over radioactive substances.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1348&sectionno=16&orderno=17&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_16_content:
  string
  line `The Central Government may prohibit the manufacture,`
  line `possession, use, transfer by sale or otherwise, export and import and in any emergency, transport and`
  line `disposal, of any radioactive substances without its written consent.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (1349)
  sectionNo (17)
  orderNo 18
  title `Special provisions as to safety.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1349&sectionno=17&orderno=18&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_17_content:
  string
  line `(1) The Central Government may, as regards any class or`
  line `description of premises or places, being premises, or places, in which radioactive substances are`
  line `manufactured, produced, mined, treated, stored or used or any radiation generating plant, equipment or`
  line `appliance is used, make such provision by rules as appear to the Central Government to be necessary--`
  line
  line `(a) to prevent injury being caused to the health of persons employed at such premises or places or`
  line `other persons either by radiations, or by the ingestion of any radioactive substance;`
  line
  line `(b) to secure that any radioactive waste products resulting from such manufacture, production,`
  line `mining, treatment, storage, or use as aforesaid are disposed of safely;`
  line
  line `(c) to prescribe qualifications of the persons for employment at such premises or places and the`
  line `regulation of their hours of employment, minimum leave and periodical medical examination;`
  line
  line `and the rules may, in particular and without prejudice to the generality of this sub-section, provide for`
  line `imposing requirements as to the erection or structural alterations of buildings or the carrying out of works.`
  line
  line `(2) The Central Government may, as respects the transport of any radioactive substance or any`
  line `prescribed substance specified by an order issued under this Act as being dangerous to health, make such`
  line `rules as appear to be necessary to prevent injury being caused by such transport to the health of persons`
  line `engaged therein and other persons.`
  line
  line `(3) Rules made under this section may provide for imposing requirements, prohibitions and`
  line `restrictions on employers, employed persons and other persons.`
  line
  line `(4) Any person authorised by the Central Government under this section, may, on producing, if so`
  line `required, a duly authenticated document showing his authority, enter at all reasonable hours any premises,`
  line `or any vehicle, vessel or aircraft for the purpose of ascertaining whether there has been committed, or is`
  line `being committed, in or in connection with the premises, vehicle, vessel or aircraft, any contravention of`
  line `the rules made under this section.`
  line
  line `(5) In the event of any contravention of the rules made under this section, the Central Government`
  line `shall have the right to take such measures as it may deem necessary to prevent further injury to persons or`
  line `damage to property arising from radiation or contamination by radioactive substances including, without`
  line `prejudice to the generality of the foregoing provisions, and to the right to take further action for the`
  line `enforcement of penalties under section 24, the sealing or premises, vehicle, vessel, or aircraft, and the`
  line `seizure of radioactive substances and contaminated equipment.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (1350)
  sectionNo (18)
  orderNo 19
  title `Restriction on disclosure of information.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1350&sectionno=18&orderno=19&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_18_content:
  string
  line `(1) The Central Government may by order restrict`
  line `the disclosure of information, whether contained in a document, drawing, photograph, plan, model, or in`
  line `any other form whatsoever, which relates to, represents or illustrates--`
  line
  line `(a) an existing or proposed plant used or proposed to be used for the purpose of producing,`
  line `developing or using atomic energy, or`
  line
  line `(b) the purpose or method of operation of any such existing or proposed plant, or`
  line
  line `(c) any process operated or proposed to be operated in any such existing or proposed plant.`
  line
  line `(2) No person shall--`
  line
  line `(a) disclose, or obtain or attempt to obtain any information restricted under sub-section (1), or`
  line
  line `(b) disclose, without the authority of the Central Government, any information obtained in the`
  line `discharge of any functions under this Act or in the performance of his official duties.`
  line
  line `(3) Nothing in this section shall apply--`
  line
  line `(i) to the disclosure of information with respect to any plant of a type in use for purposes other`
  line `than the production, development or use of atomic energy, unless the information disclose that plant`
  line `of that type is used or proposed to be used for the production, development or use of atomic energy or`
  line `research into any matters connected therewith; or`
  line
  line `(ii) where any information has been made available to the general public otherwise than in`
  line `contravention of this section, to any subsequent disclosure of that information.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (1351)
  sectionNo (19)
  orderNo 20
  title `Prevention of entry into prohibited areas.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1351&sectionno=19&orderno=20&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_19_content:
  string
  line `The Central Government may by order prohibit--`
  line
  line `(a) entry of any person, without obtaining permission, into a prohibited area, and`
  line
  line `(b) taking by any persons, without permission, of any photograph, sketch, pictures, drawing, map`
  line `or other document from a prohibited area and any permission, if given to do these things, may be`
  line `subject to stipulations which the Central Government may consider necessary.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (1352)
  sectionNo (20)
  orderNo 21
  title `Special Provisions as to inventions.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1352&sectionno=20&orderno=21&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_20_content:
  string
  line `(1) As from the commencement of this Act, no patents`
  line `shall be granted for inventions which in the opinion of the Central Government are useful for or relate to`
  line `the production, control, use or disposal of atomic energy or the prospecting, mining, extraction,`
  line `production, physical and chemical treatment, fabrication, enrichment, canning or use of any prescribed`
  line `substance or radioactive substance or the ensuring of safety in atomic energy operations.`
  line
  line `(2) The prohibition under sub-section (1) shall also apply to any invention of the nature specified in`
  line `that sub-section in respect of which an application for the grant of a patent has been made to the`
  line `Controller of Patents and Designs appointed under the Indian Patents and Designs Act, 1911 (2 of 1911),`
  line `before the commencement of this Act and is pending with him at such commencement.`
  line
  line `(3) The Central Government shall have the power to inspect at any time any pending patent`
  line `application and specification before its acceptance and if it considers that the invention relates to atomic`
  line `energy, to issue directions to the Controller of Patents and Designs to refuse the application on that`
  line ground.
  line
  line `(4) Any person, who has made an invention which he has reason to believe relates to atomic energy,`
  line `shall communicate to the Central Government the nature and description of the invention.`
  line
  line `(5) Any person desiring to apply for a patent abroad for an invention relating to or which he has`
  line `reason to believe relates to atomic energy shall obtain prior permission from the Central Government`
  line `before making the application abroad or communicating the invention to any person abroad, unless three`
  line `months have elapsed since his request for permission was made to the Central Government and no reply`
  line `was received by him.`
  line
  line `(6) The Controller of Patents and Designs shall have the power to refer any application to the Central`
  line `Government for direction as to whether the invention is one relating to atomic energy and the direction`
  line `given by the Central Government shall be final.`
  line
  line `(7) Any invention in the field of atomic energy conceived whether in establishments controlled by the`
  line `Central Government or under any contract, sub-contract, arrangement or other relationship with the`
  line `Central Government shall be deemed to have been made or conceived by the Central Government,`
  line `irrespective of whether such contract, sub-contract, arrangement or other relationship involves financial`
  line `participation of or assistance from the Central Government.`
  line
  line `(8) Notwithstanding anything contained in the Indian Patents and Designs Act, 1911 (2 of 1911), the`
  line `decision of the Central Government on points connected with or arising out of this section shall be final.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (1353)
  sectionNo (21)
  orderNo 22
  title `Principles relating to payment of compensation.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1353&sectionno=21&orderno=22&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_21_content:
  string
  line `(1) Save as otherwise provided in this Act,`
  line `where by reason of exercise of any powers under this Act, any compensation is payable, the amount of`
  line `such compensation shall be determined in the manner and in accordance with the principles hereinafter`
  line `set out, that is to say--`
  line
  line `(a) where the amount of compensation is fixed by agreement, it shall be paid in accordance with`
  line `such agreement;`
  line
  line `(b) where no such agreement is reached, the Central Government shall appoint as arbitrator a`
  line `person having expert knowledge as to the nature of the right affected who shall determine the amount`
  line `of compensation payable.`
  line
  line `(2) In making his award, the arbitrator appointed under sub-section (1) shall have regard--`
  line
  line `(a) in the case of any compensation payable under section 9--`
  line
  line `(i) to the nature of the work done;`
  line
  line `(ii) the manner, extent and duration of the exercise of any powers under that section;`
  line
  line `(iii) the diminution in the rent of the land and of the property situated thereon, which might`
  line `reasonably be expected over any period or diminution in the market value of the land and`
  line `property on the date when the exercise of powers comes to an end; and`
  line
  line `(iv) the provisions of sub-section (1) of section 23 of the Land Acquisition`
  line `Act, 1894 (1 of 1894), in so far as such provisions can be made applicable to the exercise of`
  line `powers under section 9; and`
  line
  line `(b) in the case of any compensation payable under section 11 or under section 12, to the price`
  line `which the owner might reasonably have been expected to obtain on a sale of the property effected by`
  line `him immediately before the date of the acquisition.`
  line
  line `(3) An appeal shall lie to the High Court against an award of the arbitrator except in cases where the`
  line `amount claimed thereof does not exceed an amount prescribed in this behalf by the Central Government.`
  line
  line `(4) The Central Government may make rules prescribing the procedure to be followed in arbitrations`
  line `under this Act and the principles to be followed in the apportionment of the cost of proceedings before the`
  line `arbitrator and on appeal.`
  line
  line `(5) Save as provided in this Act, nothing in any law for the time being in force relating to arbitration`
  line `shall apply to arbitrations under this Act.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (1354)
  sectionNo (22)
  orderNo 23
  title `Special provisions as to electricity.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1354&sectionno=22&orderno=23&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_22_content:
  string
  line `(1) Notwithstanding anything contained in the Electricity`
  line `(Supply) Act, 1948 (54 of 1948), the Central Government shall have authority--`
  line
  line `(a) to develop a sound and adequate national policy in regard to atomic power, to co-ordinate`
  line `such policy with the Central Electricity Authority and the State Electricity Boards constituted under`
  line `sections 3 and 5 respectively of that Act and other similar statutory corporations concerned with the`
  line `control and utilisation of other power resources, to implement schemes for the generation of`
  line `electricity in pursuance of such policy and to operate ^1[,either by itself or through any authority or`
  line `corporation established by it or a Government company,] atomic power stations in the manner`
  line `determined by it in consultation with the Boards or Corporations concerned, with whom it shall enter`
  line `into agreement regarding the supply or electricity so produced;`
  line
  line `(b) to fix rates for and regulate the supply of electricity from atomic power stations^2[either by`
  line `itself or through any authority or corporation established by it or a Government company, in`
  line `consultation with] of the Central Electricity Authority;`
  line
  line `(c) to enter into arrangements with the Electricity Board of the State in which an atomic power`
  line `station is situated ^1[either by itself or through any authority or corporation established by it or`
  line `a Government company] for the transmission of electricity to any other State:`
  line
  line `Provided that in case there is difference of opinion between the Central Government ^1[or such`
  line `authority or corporation or Government company, as the case may be,] and any State Electricity Board in`
  line `regard to the construction of necessary transmission lines, the matter shall be referred to the Central`
  line `Electricity Authority whose decision shall be binding on the parties concerned.`
  line
  line `(2) No provision of the Indian Electricity Act, 1910 (9 of 1910), or any rule made thereunder or of`
  line `any instrument having effect by virtue of such law or rule shall have any effect so far as it is inconsistent`
  line `with any of the provisions of this Act.`
  line
  line `(3) Save as otherwise provided in this Act, the provisions of this Act shall be in addition to, and`
  line `not in derogation of, the Indian Electricity Act, 1910 (9 of 1910), and the Electricity (Supply)`
  line `Act, 1948 (54 of 1948)`
obj_root_law_sections_22_footnotes:
  string
  line `1. Ins. by Act 29 of 1987, s. 4 (w.e.f. 8-9-1987).`
  line
  line `2. Subs. by s. 4, ibid., for "with the concurrence of" (w.e.f. 8-9-1987).`
obj_root_law_sections_23:
  sectionId (1355)
  sectionNo (23)
  orderNo 24
  title `Administration of Factories Act, 1948.`
  content obj_root_law_sections_23_content
  footnotes `1. Ins. by s. 5, ibid. (w.e.f. 8-9-1987).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1355&sectionno=23&orderno=24&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_23_content:
  string
  line `Notwithstanding anything contained in the Factories`
  line `Act, 1948 (63 of 1948), the authority to administer the said Act and to do all things for the enforcement of`
  line `its provisions, including the appointment of inspecting staff and the making of rules thereunder, shall vest`
  line `in the Central Government in relation to any factory owned by the Central Government ^1[or any authority`
  line `or corporation established by it or a Government company] and engaged in carrying out the purposes of`
  line `this Act.`
obj_root_law_sections_24:
  sectionId (1356)
  sectionNo (24)
  orderNo 25
  title `Offences and penalties.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1356&sectionno=24&orderno=25&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_24_content:
  string
  line `(1) Whoever--`
  line
  line `(a) contravenes any order made under section 14 or any condition subject to which a licence is`
  line `granted under that section; or`
  line
  line `(b) contravenes any rule made under section 17 or any requirement, prohibition or restriction`
  line `imposed under any such rule; or`
  line
  line `(c) obstructs any person authorised by the Central Government under sub-section (4) of`
  line `section 17 in the exercise of powers under that sub-section; or`
  line
  line `(d) contravenes sub-section (2) of section 18;`
  line
  line `shall be punishable with imprisonment for a term which may extend to five years, or with fine, or with`
  line both.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (1357)
  sectionNo (25)
  orderNo 26
  title `Offences by companies.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1357&sectionno=25&orderno=26&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_25_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed was in charge of, and was responsible`
  line `to, the company for the conduct of the business of the company as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he exercised all`
  line `due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to, any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary, or other officer shall be deemed to be guilty of`
  line `that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm and other association of`
  line `individuals; and`
  line
  line `(b) "director" in relation to a firm, means a partner in the firm`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (1358)
  sectionNo (26)
  orderNo 27
  title `Cognizance of offences.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1358&sectionno=26&orderno=27&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_26_content:
  string
  line `(1) All offences under this Act shall be cognizable under the Code of`
  line `Criminal Procedure, 1898 (5 of 1898), but no action shall be taken in respect of any person for any`
  line `offence under this Act except on the basis of a written complaint made--`
  line
  line `(a) in respect of contravention of section 8, 14 or 17 or any rule or order made thereunder, by the`
  line `person authorised to exercise powers of entry and inspection;`
  line
  line `(b) in respect of any other contravention, by a person duly authorised to make such complaints by`
  line `the Central Government.`
  line
  line `(2) Proceedings in respect of contravention of section 18 shall not be instituted except with the`
  line `consent of the Attorney General of India.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (1359)
  sectionNo (27)
  orderNo 28
  title `Delegation of powers.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1359&sectionno=27&orderno=28&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_27_content:
  string
  line `The Central Government may, by order, direct that any power conferred`
  line `or any duty imposed on it by this Act shall, in such circumstances and subject to such conditions as may`
  line `be specified in the direction, be exercised or discharged also by--`
  line
  line `(a) such officer or authority subordinate to the Central Government, or`
  line
  line `(b) such State Government or such officer or authority subordinate to a State Government as may`
  line `be specified in the direction.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (1363)
  sectionNo (28)
  orderNo 29
  title `Effect of other laws`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1363&sectionno=28&orderno=29&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_28_content:
  string
  line `The provisions of this Act shall have effect notwithstanding anything`
  line `inconsistent therewith contained in any enactment other than this Act or any other instrument having`
  line `effect by virtue of any enactment other than this Act.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (1364)
  sectionNo (29)
  orderNo 30
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1364&sectionno=29&orderno=30&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_29_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Government or any person or authority in respect of anything done by it or him in good`
  line `faith in pursuance of this Act or of any rule of order made thereunder.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (1365)
  sectionNo (30)
  orderNo 31
  title `Power to make rules.`
  content obj_root_law_sections_30_content
  footnotes `1. Subs. by Act 4 of 1986, s. 2 and the Schedule, for "before the expiry of the session in which it is so laid" (w.e.f. 15-5-1986).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1365&sectionno=30&orderno=31&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_30_content:
  string
  line `(1) The Central Government may, by notification, make rules for`
  line `carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing powers, such rules may`
  line `provide for--`
  line
  line `(a) declaring any information not so far published or otherwise made public as restricted`
  line `information and prescribing the measures to be taken to guard against unauthorised dissemination or`
  line `use thereof;`
  line
  line `(b) declaring any area or premises as prohibited area and prescribing the measures to be taken to`
  line `provide against unauthorised entry into or departure from such prohibited area;`
  line
  line `(c) reporting of information relating to the discovery of uranium, thorium and other prescribed`
  line `substances and for payment of rewards for such discoveries;`
  line
  line `(d) control over mining or concentration of substances containing uranium;`
  line
  line `(e) regulating by licensing and encouraging by award of concessions including rewards, floor`
  line `prices and guarantees, mining of and prospecting for other prescribed substances;`
  line
  line `(f) compulsory acquisition of prescribed substances, minerals and plants;`
  line
  line `(g) regulating the production, import, export, transfer, refining, possession, ownership, sale, use`
  line `or disposal of the prescribed substances and any other articles that in the opinion of the Central`
  line `Government may be used for, or may result as a consequence of, the production, use or application of`
  line `atomic energy;`
  line
  line `(h) regulating the use of prescribed equipment;`
  line
  line `(i) regulating the manufacture, custody, transport, transfer, sale, export, import, use or disposal of`
  line `any radioactive substance;`
  line
  line `(j) regulating the transport of such prescribed substances as are declared dangerous to health`
  line `under sub-section (2) of section 17;`
  line
  line `(k) developing, controlling, supervising and licensing the production, application and use of`
  line `atomic energy;`
  line
  line `(l) fees for issue of licences under this Act;`
  line
  line `(m) the manner of serving notices under this Act;`
  line
  line `(n) generally promoting co-operation among person, institutions and countries in the production,`
  line `use, application of atomic energy and in research and investigations in that field.`
  line
  line `(3) Rules made under this Act may provide that a contravention of the rules shall, save as otherwise`
  line `expressly provided in this Act, be punishable with fine which may extend to five hundred rupees.`
  line
  line `(4) Every rule made under this Act shall be laid as soon as may be after it is made, before each House`
  line `of Parliament while it is in session for a total period of thirty days which may be comprised in one session`
  line `or in two or more successive sessions, and if ^1[before the expiry of the session immediately following the`
  line `session] or the successive sessions aforesaid, both Houses agree in making any modification in the rule or`
  line `both Houses agree that the rule should not be made, the rule shall thereafter have effect only in such`
  line `modified form or be of no effect, as the case may be; so however that any such modification or annulment`
  line `shall be without prejudice to the validity of anything previously done under that rule`
obj_root_law_sections_31:
  sectionId (1366)
  sectionNo (31)
  orderNo 32
  title `Act binding on Government.`
  content `The provisions of this Act shall be binding on Government.`
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1366&sectionno=31&orderno=32&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (1367)
  sectionNo (32)
  orderNo 33
  title Repealed.
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_38_63_00001_196233_1517807321654&sectionId=1367&sectionno=32&orderno=33&orgactid=AC_CEN_38_63_00001_196233_1517807321654
obj_root_law_sections_32_content:
  string
  line `[Repeal of Act 29 of 1948].--Rep. by Repealing and Amending Act, 1974 (56 of 1974), s. 2 and`
  line `the First Schedule (w.e.f. 20-12-1974).`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_translations:
