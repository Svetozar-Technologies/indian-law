obj_root_law_sections_5:
  object
  (str sectionId) (str 38999)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Saving as to present Legislative Assembly.`)
  (str content) (str `Nothing in this Act shall affect any representation
in the present Legislative Assembly of Nagaland until its dissolution.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00011_196861_1517807320262&sectionId=38999&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00011_196861_1517807320262)
