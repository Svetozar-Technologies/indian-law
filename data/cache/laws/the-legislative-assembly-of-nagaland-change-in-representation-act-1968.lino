obj_root_law_sections_1:
  sectionId (38995)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00011_196861_1517807320262&sectionId=38995&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00011_196861_1517807320262
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Legislative Assembly of Nagaland (Change in`
  line `Representation) Act, 1968.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (38996)
  sectionNo (2)
  orderNo 2
  title `Change in representation in the Legislative Assembly of Nagaland.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00011_196861_1517807320262&sectionId=38996&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00011_196861_1517807320262
obj_root_law_sections_2_content:
  string
  line `For the period referred to`
  line `in clause (2) of article 371A of the Constitution, the total number of seats allotted to the Legislative`
  line `Assembly of Nagaland shall be increased from forty-six to fifty-two, of which--`
  line
  line `(a) the seats allotted to the Tuensang district shall be increased from six to twelve and shall be`
  line `filled by persons chosen by the members of the regional council, referred to in that article, from`
  line `amongst themselves in such manner as the Governor of Nagaland, after consulting that council may,`
  line `by notification in the Official Gazette, specify, and`
  line
  line `(b) the remaining forty seats shall be filled by persons chosen by direct elections from assembly`
  line `constituencies in the rest of the State of Nagaland.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (38997)
  sectionNo (3)
  orderNo 3
  title [Repealed.].
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00011_196861_1517807320262&sectionId=38997&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00011_196861_1517807320262
obj_root_law_sections_3_content:
  string
  line `[Amendment of Act 27of 1962.] Rep. by the Repealing and Amending Act, 1974 (56 of 1974), s. 2`
  line `and the First Schedule (w.e.f. 20-12-1974).`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (38998)
  sectionNo (4)
  orderNo 4
  title [Repealed.].
  content `[Amendment of Act 43 of 1950.] Rep. by s. 2 and the First Schedule, ibid. (w.e.f. 20-12-1974).`
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00011_196861_1517807320262&sectionId=38998&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00011_196861_1517807320262
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (38999)
  sectionNo (5)
  orderNo 5
  title `Saving as to present Legislative Assembly.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00011_196861_1517807320262&sectionId=38999&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00011_196861_1517807320262
obj_root_law_sections_5_content:
  string
  line `Nothing in this Act shall affect any representation`
  line `in the present Legislative Assembly of Nagaland until its dissolution.`
obj_root_law_sections_5_footnotes:
  string
  line
