obj_root_law_sections_1:
  sectionId (30766)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00005_200236_1517807324544&sectionId=30766&sectionno=1&orderno=1&orgactid=AC_CEN_36_56_00005_200236_1517807324544
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Foreign Aircraft (Exemption from Taxes`
  line `and Duties on Fuel and Lubricants) Act, 2002.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (30767)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00005_200236_1517807324544&sectionId=30767&sectionno=2&orderno=2&orgactid=AC_CEN_36_56_00005_200236_1517807324544
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Agreements" means the Air Services Agreements or Air Transport Agreements entered into`
  line `by India with parties to the Convention;`
  line
  line `(b) "Convention" means the Convention on International Civil Aviation opened for signatures at`
  line `Chicago on the 7th December, 1944.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (30768)
  sectionNo (3)
  orderNo 3
  title `Exemption from levy of taxes and duties on fuel and lubricants supplied to aircraft of other countries.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_36_56_00005_200236_1517807324544&sectionId=30768&sectionno=3&orderno=3&orgactid=AC_CEN_36_56_00005_200236_1517807324544
obj_root_law_sections_3_content:
  string
  line `Where, in pursuance of the Convention or Agreement with any other country or countries, it`
  line `is necessary to grant exemption from levy of taxes and duties on fuel and lubricants filled into receptacles`
  line `forming part of any aircraft of any other country or countries under any law of a State or Union territory`
  line `in India, the Central Government may, by notification in the Official Gazette, make such provisions as`
  line `may be necessary for giving effect to the said Convention or Agreement and thereupon the said provision`
  line `shall apply accordingly and, notwithstanding anything contrary contained in any other law, shall in such`
  line `application have the force of law in India.`
obj_root_law_sections_3_footnotes:
  string
  line
