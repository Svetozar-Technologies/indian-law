obj_root_law_sections_1:
  object
  (str sectionId) (str 26788)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Orissa (Alteration of Name)
Act, 2011.

(2) It shall come into force on such date^1
as the Central Government may, by notification in the
Official Gazette, appoint.`)
  (str footnotes) (str `1. 1st November, 2011, vide notification No. G.S.R. 791(E), dated 1st November, 2011, see Gazette of India,
Extraordinary, Part II, sec. 3 (i).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26788&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_2:
  object
  (str sectionId) (str 26789)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act, unless the context otherwise requires,—

(a) "appointed day" means the date appointed under sub-section (2) of section 1 for the coming
into force of this Act;

(b) "appropriate Government" means, as respects a law relating to a matter enumerated in List I
in the Seventh Schedule to the Constitution, the Central Government, and as respects any other law,
the State Government;

(c) "law" includes any enactment, Ordinance, regulation, order, bye-law, rule, scheme,
notification or other instrument having the force of law in the whole or any part of the State of Orissa.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26789&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_3:
  object
  (str sectionId) (str 26790)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Alteration of name of State of Orissa.`)
  (str content) (str `As from the appointed day, the State of Orissa shall be
known as the State of Odisha.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26790&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_4:
  object
  (str sectionId) (str 26791)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Amendment of article 164.`)
  (str content) (str `In article 164 of the Constitution, in clause (1), in the proviso, for
the word "Orissa", the word "Odisha" shall be substituted.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26791&sectionno=4&orderno=4&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_5:
  object
  (str sectionId) (str 26792)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Amendment of article 273.`)
  (str content) (str `In article 273, in clause (1), for the word "Orissa", the word
"Odisha" shall be substituted.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26792&sectionno=5&orderno=5&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_6:
  object
  (str sectionId) (str 26793)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Amendment of First Schedule to the Constitution.`)
  (str content) (str `In the First Schedule to the Constitution,
under the heading "I. THE STATES", in entry 10, under the column "Name", for the word "Orissa", the
word "Odisha" shall be substituted.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26793&sectionno=6&orderno=6&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_7:
  object
  (str sectionId) (str 26794)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Amendment of Fourth Schedule to the Constitution.`)
  (str content) (str `In the Fourth Schedule to the
Constitution, under the heading "TABLE", in entry 14, in the second column, for the word "Orissa", the
word "Odisha" shall be substituted.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26794&sectionno=7&orderno=7&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_8:
  object
  (str sectionId) (str 26795)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str `Power to adapt laws.`)
  (str content) (str `(1) For the purpose of giving effect to the alteration of the name of the
State of Orissa by section 3, the appropriate Government may, before the expiration of one year from the
appointed day, by order, make such adaptations and modifications of any law made before the appointed
day, whether by way of repeal or amendment, as may be necessary or expedient, and thereupon every
such law shall have effect subject to the adaptations and modifications so made.

(2) Nothing in sub-section (1) shall be deemed to prevent a competent Legislature or other competent
authority from repealing or amending any law adapted or modified by the appropriate Government under
the said sub-section.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26795&sectionno=8&orderno=8&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_9:
  object
  (str sectionId) (str 26796)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str `Power to construe laws.`)
  (str content) (str `Notwithstanding that no provision or insufficient provision has been
made under section 8 for the adaptation of a law made before the appointed day, any court, tribunal or
authority, required or empowered to enforce such law, may construe the law in such manner, without
affecting the substance, as may be necessary or proper in regard to the matter before the court, tribunal or
authority.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26796&sectionno=9&orderno=9&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
obj_root_law_sections_10:
  object
  (str sectionId) (str 26797)
  (str sectionNo) (str 10)
  (str orderNo) (int 10)
  (str title) (str `Legal proceedings.`)
  (str content) (str `Where immediately before the appointed day any legal proceedings are
pending to which the State of Orissa is a party, the State of Odisha shall be deemed to have been
substituted for the State of Orissa in those proceedings.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26797&sectionno=10&orderno=10&orgactid=AC_CEN_5_24_00021_201115_1517807326989)
