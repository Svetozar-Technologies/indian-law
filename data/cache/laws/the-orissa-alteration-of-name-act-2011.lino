obj_root_law_sections_1:
  sectionId (26788)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26788&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Orissa (Alteration of Name)`
  line `Act, 2011.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st November, 2011, vide notification No. G.S.R. 791(E), dated 1st November, 2011, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3 (i).`
obj_root_law_sections_2:
  sectionId (26789)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26789&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "appointed day" means the date appointed under sub-section (2) of section 1 for the coming`
  line `into force of this Act;`
  line
  line `(b) "appropriate Government" means, as respects a law relating to a matter enumerated in List I`
  line `in the Seventh Schedule to the Constitution, the Central Government, and as respects any other law,`
  line `the State Government;`
  line
  line `(c) "law" includes any enactment, Ordinance, regulation, order, bye-law, rule, scheme,`
  line `notification or other instrument having the force of law in the whole or any part of the State of Orissa.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (26790)
  sectionNo (3)
  orderNo 3
  title `Alteration of name of State of Orissa.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26790&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_3_content:
  string
  line `As from the appointed day, the State of Orissa shall be`
  line `known as the State of Odisha.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (26791)
  sectionNo (4)
  orderNo 4
  title `Amendment of article 164.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26791&sectionno=4&orderno=4&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_4_content:
  string
  line `In article 164 of the Constitution, in clause (1), in the proviso, for`
  line `the word "Orissa", the word "Odisha" shall be substituted.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (26792)
  sectionNo (5)
  orderNo 5
  title `Amendment of article 273.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26792&sectionno=5&orderno=5&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_5_content:
  string
  line `In article 273, in clause (1), for the word "Orissa", the word`
  line `"Odisha" shall be substituted.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (26793)
  sectionNo (6)
  orderNo 6
  title `Amendment of First Schedule to the Constitution.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26793&sectionno=6&orderno=6&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_6_content:
  string
  line `In the First Schedule to the Constitution,`
  line `under the heading "I. THE STATES", in entry 10, under the column "Name", for the word "Orissa", the`
  line `word "Odisha" shall be substituted.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (26794)
  sectionNo (7)
  orderNo 7
  title `Amendment of Fourth Schedule to the Constitution.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26794&sectionno=7&orderno=7&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_7_content:
  string
  line `In the Fourth Schedule to the`
  line `Constitution, under the heading "TABLE", in entry 14, in the second column, for the word "Orissa", the`
  line `word "Odisha" shall be substituted.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (26795)
  sectionNo (8)
  orderNo 8
  title `Power to adapt laws.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26795&sectionno=8&orderno=8&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_8_content:
  string
  line `(1) For the purpose of giving effect to the alteration of the name of the`
  line `State of Orissa by section 3, the appropriate Government may, before the expiration of one year from the`
  line `appointed day, by order, make such adaptations and modifications of any law made before the appointed`
  line `day, whether by way of repeal or amendment, as may be necessary or expedient, and thereupon every`
  line `such law shall have effect subject to the adaptations and modifications so made.`
  line
  line `(2) Nothing in sub-section (1) shall be deemed to prevent a competent Legislature or other competent`
  line `authority from repealing or amending any law adapted or modified by the appropriate Government under`
  line `the said sub-section.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (26796)
  sectionNo (9)
  orderNo 9
  title `Power to construe laws.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26796&sectionno=9&orderno=9&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_9_content:
  string
  line `Notwithstanding that no provision or insufficient provision has been`
  line `made under section 8 for the adaptation of a law made before the appointed day, any court, tribunal or`
  line `authority, required or empowered to enforce such law, may construe the law in such manner, without`
  line `affecting the substance, as may be necessary or proper in regard to the matter before the court, tribunal or`
  line authority.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (26797)
  sectionNo (10)
  orderNo 10
  title `Legal proceedings.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00021_201115_1517807326989&sectionId=26797&sectionno=10&orderno=10&orgactid=AC_CEN_5_24_00021_201115_1517807326989
obj_root_law_sections_10_content:
  string
  line `Where immediately before the appointed day any legal proceedings are`
  line `pending to which the State of Orissa is a party, the State of Odisha shall be deemed to have been`
  line `substituted for the State of Orissa in those proceedings.`
obj_root_law_sections_10_footnotes:
  string
  line
