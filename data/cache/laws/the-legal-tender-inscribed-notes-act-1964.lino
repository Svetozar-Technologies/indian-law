  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00025_196428_1517807321930&sectionId=32058&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00025_196428_1517807321930
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Legal Tender (Inscribed Notes) Act, 1964.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (32059)
  sectionNo (2)
  orderNo 2
  title `Notes bearing messages of a political character not to be legal tender.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00025_196428_1517807321930&sectionId=32059&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00025_196428_1517807321930
obj_root_law_sections_2_content:
  string
  line Notwithstanding
  line `anything contained in the Reserve Bank of India Act, 1934 (2 of 1934), or in the Currency`
  line `Ordinance, 1940 (Ord. 4 of 1940), or in any other law for the time being in force, a currency note of the`
  line `Government of India, a bank note issued by the Reserve Bank of India, or a Government of India`
  line `one-rupee note issued under the Currency Ordinance, 1940, which bears written upon it any extrinsic`
  line `words or visible representations intended to convey or capable of conveying a message of a political`
  line `character, shall not be legal tender; and the Reserve Bank of India shall not be under any legal obligation`
  line `to receive any such note, or to issue rupee coin or other coin or currency notes or bank notes in exchange`
  line `for any such note, or to refund the value of any such note:`
  line
  line `Provided that the Reserve Bank of India may refund as of grace the whole or part of the value of any`
  line `such note.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (32060)
  sectionNo (3)
  orderNo 3
  title `Repeal and savings.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00025_196428_1517807321930&sectionId=32060&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00025_196428_1517807321930
obj_root_law_sections_3_content:
  string
  line `(1) The Legal Tender (Inscribed Notes) Ordinance, 1942 (Ord. 59 of 1942),`
  line `is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance, shall be`
  line `deemed to have been done or taken under this Act as if this Act were in force on the day on which such`
  line `thing was done or such action was taken.`
obj_root_law_sections_3_footnotes:
  string
  line
