  object
  (str title) (str `हाथ से मैला उठाने वाले कर्मियों के नियोजन का प्रतिषेध और उनका पुनर्वास अधिनियम, 2013`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2119/3/H2013-25.pdf`)
