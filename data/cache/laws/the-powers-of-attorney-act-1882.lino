  object
  (str title) (str `मुख्‍तारनामा अधिनयम, 1882`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2360/2/H1882-07.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:44:04.512Z`)
