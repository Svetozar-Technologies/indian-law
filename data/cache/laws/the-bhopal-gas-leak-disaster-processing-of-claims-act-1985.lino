obj_root_law:
  slug the-bhopal-gas-leak-disaster-processing-of-claims-act-1985
  handle (1855)
  collectionHandle 123456789/1362
  title `The Bhopal Gas Leak Disaster (Processing of Claims) Act, 1985`
  actNumber (21)
  enactmentDate 1985-03-29
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1855`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भोपाल गैस विभीषिका (दावा-कार्यवाही) अधिनियम, 1985`
  actYear (1985)
  ministry `Ministry of Chemicals and Fertilizers`
  department `Department of Chemicals and Petro-Chemicals`
  longTitle `An Act to confer certain powers on the Central Government to secure that claims arising out of, or connected with, the Bhopal gas leak disaster are dealt with speedily, effectively, equitably and to the best advantage of the claimants and for matters incidental thereto.`
  enforcementDate 20-02-1985
