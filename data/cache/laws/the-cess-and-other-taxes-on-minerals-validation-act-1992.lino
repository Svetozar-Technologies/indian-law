obj_root_law_sections_1:
  sectionId (42639)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00003_199216_1517807322780&sectionId=42639&sectionno=1&orderno=1&orgactid=AC_CEN_15_16_00003_199216_1517807322780
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Cess and Other Taxes on`
  line `Minerals (Validation) Act, 1992.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall be deemed to have come into force on the 15th day of February, 1992.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (42640)
  sectionNo (2)
  orderNo 2
  title `Validation of certain State laws and actions taken and things done thereunder.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00003_199216_1517807322780&sectionId=42640&sectionno=2&orderno=2&orgactid=AC_CEN_15_16_00003_199216_1517807322780
obj_root_law_sections_2_content:
  string
  line `(1) The laws`
  line `specified in the Schedule to this Act shall be, and shall be deemed always to have been, as valid as if the`
  line `provisions contained therein relating to cesses or other taxes on minerals had been enacted by Parliament`
  line `and such provisions shall be deemed to have remained in force up to the 4th day of April, 1991.`
  line
  line `(2) Notwithstanding any judgment, decree or order of any court, all actions taken, things done, rules`
  line `made, notifications issued or purported to have been taken, done, made or issued and cesses or other taxes`
  line `on minerals realised under any such laws shall be deemed to have been validly taken, done, made, issued`
  line `or realised, as the case may be, as if this section had been in force at all material times when such actions`
  line `were taken, things were done, rules were made, notifications were issued, or cesses or other taxes were`
  line `realised, and no suit or other proceeding shall be maintained or continued in any court for the refund of`
  line `the cesses or other taxes realised under any such laws.`
  line
  line `(3) For the removal of doubts, it is hereby declared that nothing in sub-section (2) shall be construed`
  line `as preventing any person from claiming refund of any cess or tax paid by him in excess of the amount due`
  line `from him under any such laws.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (42641)
  sectionNo (3)
  orderNo 3
  title `Repeal and savings.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_15_16_00003_199216_1517807322780&sectionId=42641&sectionno=3&orderno=3&orgactid=AC_CEN_15_16_00003_199216_1517807322780
obj_root_law_sections_3_content:
  string
  line `(1) The Cess and Other Taxes on Minerals (Validation) Ordinance, 1992`
  line `(Ord. 7 of 1992) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
