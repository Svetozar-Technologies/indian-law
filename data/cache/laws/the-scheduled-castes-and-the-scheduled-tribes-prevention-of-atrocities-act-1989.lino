obj_root_law:
  object
  (str slug) (str the-scheduled-castes-and-the-scheduled-tribes-prevention-of-atrocities-act-1989)
  (str handle) (str 1920)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Scheduled Castes and the Scheduled Tribes (Prevention of Atrocities) Act, 1989`)
  (str actNumber) (str 33)
  (str enactmentDate) (str 1989-09-11)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1920`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `अनुसूचित जाति और अनुसूचित जनजाति (अत्यातचार निवारण) अधिनियम,1989`)
  (str actYear) (str 1989)
  (str ministry) (str `Ministry of Social Justice and Empowerment`)
  (str department) (str `Department of Social Justice and Empowerment`)
  (str longTitle) (str `An Act to prevent the commission of offences of atrocities against the members of the Scheduled Castes and the Scheduled Tribes, to provide for Special Courts and the Exclusive Special Courts for the trial of such offences and for the relief and rehabilitation of the victims of such offences and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 30-01-1990)
  (str notification) (str `30th January, 1990, vide notification No. S.O. 106(E), dated 29th January, 1990, See Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
