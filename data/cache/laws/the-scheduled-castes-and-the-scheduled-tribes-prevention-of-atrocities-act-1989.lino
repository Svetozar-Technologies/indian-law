obj_root_law:
  slug the-scheduled-castes-and-the-scheduled-tribes-prevention-of-atrocities-act-1989
  handle (1920)
  collectionHandle 123456789/1362
  title `The Scheduled Castes and the Scheduled Tribes (Prevention of Atrocities) Act, 1989`
  actNumber (33)
  enactmentDate 1989-09-11
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1920`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `अनुसूचित जाति और अनुसूचित जनजाति (अत्यातचार निवारण) अधिनियम,1989`
  actYear (1989)
  ministry `Ministry of Social Justice and Empowerment`
  department `Department of Social Justice and Empowerment`
  longTitle `An Act to prevent the commission of offences of atrocities against the members of the Scheduled Castes and the Scheduled Tribes, to provide for Special Courts and the Exclusive Special Courts for the trial of such offences and for the relief and rehabilitation of the victims of such offences and for matters connected therewith or incidental thereto.`
  enforcementDate 30-01-1990
  notification `30th January, 1990, vide notification No. S.O. 106(E), dated 29th January, 1990, See Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T18:02:01.822Z`
  translations obj_root_law_translations
