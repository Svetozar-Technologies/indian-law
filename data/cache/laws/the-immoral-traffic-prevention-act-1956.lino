  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00015_1956104_1673601098535&sectionId=72606&sectionno=10&orderno=11&orgactid=AC_CEN_13_0_00015_1956104_1673601098535
obj_root_law_sections_10_content:
  string
  line `^1[10. [Release on probation of good conduct or after due admonition.] Omitted by the Suppression of`
  line `Immoral Traffic in Women and Girls (Amendment) Act, 1986 (44 of 1986), s. 13 (w.e.f. 26-1-1987).`
obj_root_law_sections_10_a:
  sectionId (72607)
  sectionNo 10A
  orderNo 12
  title `Detention in a corrective institution.`
  content obj_root_law_sections_10_a_content
  footnotes obj_root_law_sections_10_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00015_1956104_1673601098535&sectionId=72607&sectionno=10A&orderno=12&orgactid=AC_CEN_13_0_00015_1956104_1673601098535
obj_root_law_sections_10_a_content:
  string
  line `(1) Where—`
  line
  line `(a) a female offender is found guilty of an offence under section 7 or section 8, ^1***; and`
  line
  line `(b) the character, state of health and mental condition of the offender and the other circumstances`
  line `of the case are such that it is expedient that she should be subject to detention for such term and such`
  line `instruction and discipline as are conducive to her correction,`
  line
  line `it shall be lawful for the court to pass, in lieu of a sentence of imprisonment, an order for detention in a`
  line `corrective institution for such term, not being less than two years and not being more than five years, as`
  line `the court thinks fit:`
  line
  line `Provided that before passing such an order—`
  line
  line `(i) the court shall give an opportunity to the offender to be heard and shall also consider any`
  line `representation which the offender may make to the court as to the suitability of the case for treatment`
  line `in such an institution, as also the report of the probation officer appointed under the Probation of`
  line `Offenders Act, 1958 (20 of 1958); and`
  line
  line `(ii) the court shall record that it is satisfied that the character, state of health and mental condition`
  line `of the offender and the other circumstances of the case are such that the offender is likely to benefit`
  line `by such instruction and discipline as aforesaid.`
  line
  line `(2) Subject to the provisions of sub-section (3), the provisions of the Code of Criminal Procedure,`
  line `1973 (2 of 1974), relating to appeal, reference and revision and of the Limitation Act, 1963 (36 of 1963),`
  line `as to the period within which an appeal shall be filed, shall apply in relation to an order of detention under`
  line `sub-section (1) as if the order had been a sentence of imprisonment for the same period as the period for`
  line `which the detention was ordered.`
  line
  line `(3) Subject to such rules as may be made in this behalf, the State Government or authority, authorised`
  line `in this behalf may, at any time after the expiration of six months from the date of an order for detention in`
  line `a corrective institution, if it is satisfied that there is a reasonable probability that the offender will lead a`
  line `useful and industrious life, discharge her from such an institution, without condition or with such`
  line `conditions as may be considered fit, and grant her a written licence in such form as may be prescribed.`
  line
  line `(4) The conditions on which an offender is discharged under sub-section (3), may include`
  line `requirements relating to residence of the offender and supervision over the offender's activities and`
  line movements.]
obj_root_law_sections_10_a_footnotes:
  string
  line `1. The words, brackets and figures “and is not released under sub-section (1) or sub-section (2) of section 10” omitted byAct 44`
  line `of 1986, s. 14, (w.e.f. 26-1-1987).`
obj_root_law_sections_11:
  sectionId (72587)
  sectionNo (11)
  orderNo 13
  title `Notification of address of previously convicted offenders.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00015_1956104_1673601098535&sectionId=72587&sectionno=11&orderno=13&orgactid=AC_CEN_13_0_00015_1956104_1673601098535
obj_root_law_sections_11_content:
  string
  line `(1) When any person having been`
  line convicted--
  line
  line `(a) by a court in India of an offence punishable under this Act or punishable under section 363,`
  line `section 365, section 366, section 366A, section 366B, section 367, section 368, section 370, section`
  line `371, section 372 or section 373 of the Indian Penal Code (45 of 1860), with imprisonment for a term`
  line `of two years or upwards; or`
  line
  line `(b) by a court or tribunal in any other country of an offence which would, if committed in India,`
  line `have been punishable under this Act or under any of the aforesaid sections with imprisonment for a`
  line `like term,`
  line `is within a period of five years after release from prison, again convicted of any offence punishable under`
  line `this Act or under any of those sections with imprisonment for a term of two years or upwards by a court,`
  line `such court may, if it thinks fit, at the time of passing the sentence of imprisonment on such person, also`
  line `order that his residence, and any change of, or absence from such residence after release be notified`
  line `according to rules made under section 23 for a period not exceeding five years from the date of expiration`
  line `of that sentence.`
  line
  line `(2) If such conviction is set aside on appeal or otherwise, such order shall become void.`
  line
  line `(3) An order under this section may also be made by an Appellate Court or by the High Court when`
  line `exercising its powers of revision.`
  line
  line `(4) Any person charged with a breach of any rule referred to in sub-section (1) may be tried by a`
  line `Magistrate of competent jurisdiction in the district in which the place last notified, as his residence is`
  line situated.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (72608)
