obj_root_law_sections_1:
  sectionId (72576)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00015_1956104_1673601098535&sectionId=72576&sectionno=1&orderno=1&orgactid=AC_CEN_13_0_00015_1956104_1673601098535
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called ^1[the Immoral Traffic`
  line `(Prevention)] Act, 1956.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) This section shall come into force at once; and the remaining provisions of this Act shall come`
  line `into force on such date^2`
  line `as the Central Government may, by notification in the Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 44 of 1986,for "the Suppression of Immoral Traffic in Women and Girls" (w.e.f. 26-1-1987).`
  line
  line `2. 1st May, 1958, vide notification No. G.S.R. 269, dated 16th April, 1958, see Gazette of India, Part II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (72577)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_0_00015_1956104_1673601098535&sectionId=72577&sectionno=2&orderno=2&orgactid=AC_CEN_13_0_00015_1956104_1673601098535
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,`
  line
  line `(a) "brothel" includes any house, room ^1[, conveyance] or place or any portion of any house, room ^1[ , conveyance] or place, which is used for purposes ^2[ of sexual exploitation or abuse] for the gain of another person or for the mutual gain of two or more prostitutes;`
  line
  line `^3[(aa) "child" means a person who has not completed the age of sixteen years;]`
  line
  line `^1[^4[ (b)["corrective institution" means an institution, by whatever name called (being an institution established or licensed as such under section 21), in which ^5[persons], who are in need of correction, may be detained under this Act, and includes a shelter where ^6[undertrials] may be kept in pursuance of this Act;]`
  line
  line `^7** ** *`
  line
  line `^8[(c) "magistrate" means a magistrate specified in the second column of the Schedule as being competent to exercise the powers conferred by the section in which the expression occours and which is specified in the first column of the Schedule;]`
  line
  line `^3[(ca) "major" means a person who has completed the age of eighteen years;`
  line
  line `(cb) "minor" means a person who has completed the age of sixteen years but has not completed the age of eighteen years;]`
  line
  line `(d) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^9* * * * *`
  line
  line `^10[^11[(f) "prostitution" means the sexual exploitation or abuse of persons for commercial purpose,and the expression prostitute shall be construed accordingly;]`
  line
  line `(g) "protective home" means an institution, by whatever name called (being an institution established or licensed as such under section 21), in which ^12[persons], who are in need of care andprotection, may be kept under this Act ^13[and where appropriate technically qualified persons,equipment and other facilities have been provided,] but does not include`
  line
  line `(i) a shelter where ^14[undertrials] may be kept in pursuance of this Act, or`
  line
  line `(ii) a corrective institution;]`
  line
  line `(h) "public place" means any place intended for use by, or accessible to, the public and includes any public conveyance;`
  line
  line `(i) "special police officer" means a police officer appointed by or on behalf of the State Government to be in charge of police duties within a specified area for the purpose of this Act;`
  line
  line `^15[(j) "trafficking police officer" means a police officer appointed by the Central Government under sub-section (4), of section 13.]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Ins. by Act 46 of 1978, s. 2 (w.e.f. 2-10-1979).`
  line
  line `2. Subs. by Act 44 of 1986, s. 5, for prostitution (w.e.f. 26-1-1987).`
  line
  line `3. Ins. by s. 5, ibid. (w.e.f. 26-1-1987).`
  line
  line `4. Clause (aa) relettered as Clause (b) by s. 5, ibid. (w.e.f. 26-1-1987).`
  line
  line `5. Subs. by s. 4, ibid., for women and girls (w.e.f. 26-1-1987).`
  line
  line `6. Subs. by s. 5, ibid., for female undertrials (w.e.f. 26-1-1987).`
  line
  line `7. Omitted by s. 5, ibid. (w.e.f. 26-1-1987).`
  line
  line `8. Subs. by Act 46 of 1978, s. 2, for clause (c) (w.e.f. 26-1-1987).`
  line
  line `9. Omitted s. 2, ibid. (w.e.f. 26-1-1987).`
  line
  line `10. Subs. by Act 46 of 1978, s. 2, for clauses (f) and (g) (w.e.f. 2-10-1979).`
  line
  line `11. Subs. by Act 44 of 1986, s. 5, for clause (f) (w.e.f. 26-1-1987).`
  line
  line `12. Subs. by s. 2, ibid., for women and girls (w.e.f. 26-1-1987).`
  line
  line `13. Ins. by s. 5, ibid. (w.e.f. 26-1-1987).`
  line
  line `14. Subs. by s. 5, ibid., for female undertrials (w.e.f. 26-1-1987).`
  line
  line `15. Subs. by s. 5, ibid., for clause (j) (w.e.f. 26-1-1987).`
