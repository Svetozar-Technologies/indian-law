  object
  (str slug) (str the-commissions-for-protection-of-child-rights-act-2005)
  (str handle) (str 2056)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Commissions for Protection of Child Rights Act, 2005`)
  (str actNumber) (str 04)
  (str enactmentDate) (str 2006-01-20)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2056`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बालक अधिकार संरक्षण आयोग अधिनियम, 2005`)
  (str actYear) (str 2006)
  (str ministry) (str `Ministry of Women and Child Development`)
  (str longTitle) (str `An Act to provide for the constitution of a National Commission and State Commissions for Protection of Child Rights and Children's Courts for providing speedy trial of offences against children or of violation of child rights and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 05-02-2007)
  (str notification) (str `5th February, 2007, vide notification No. S.O. 229(E), dated 15th February, 2007, see Gazette of India, Extraordinary, Part II, sec.3(ii).`)
