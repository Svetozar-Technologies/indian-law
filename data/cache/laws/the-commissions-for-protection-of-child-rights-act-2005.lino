obj_root_law:
  slug the-commissions-for-protection-of-child-rights-act-2005
  handle (2056)
  collectionHandle 123456789/1362
  title `The Commissions for Protection of Child Rights Act, 2005`
  actNumber (04)
  enactmentDate 2006-01-20
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2056`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `बालक अधिकार संरक्षण आयोग अधिनियम, 2005`
  actYear (2006)
  ministry `Ministry of Women and Child Development`
  longTitle `An Act to provide for the constitution of a National Commission and State Commissions for Protection of Child Rights and Children's Courts for providing speedy trial of offences against children or of violation of child rights and for matters connected therewith or incidental thereto.`
  enforcementDate 05-02-2007
  notification `5th February, 2007, vide notification No. S.O. 229(E), dated 15th February, 2007, see Gazette of India, Extraordinary, Part II, sec.3(ii).`
  fetchedAt `2026-05-08T19:36:27.803Z`
  translations obj_root_law_translations
