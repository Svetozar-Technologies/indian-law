obj_root_law:
  slug the-national-green-tribunal-act-2010
  handle (2025)
  collectionHandle 123456789/1362
  title `The National Green Tribunal Act, 2010`
  actNumber (19)
  enactmentDate 2010-06-02
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2025`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्‍ट्रीय हरित अधिकरण अधिनियम, 2010`
  actYear (2010)
  ministry `Ministry of Environment, Forest and Climate Change`
  department undefined
  longTitle `An Act to provide for the establishment of a National Green Tribunal for the effective and expeditious disposal of cases relating to environmental protection and conservation of forests and other natural resources including enforcement of any legal right relating to environment and giving relief and compensation for damages to persons and property and for matters connected therewith or incidental thereto.`
  enforcementDate 18-10-2010
  notification `18th October, 2010, vide notification No. S.O 2569(E), dated 18th October, 2010, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T10:04:02.338Z`
  translations obj_root_law_translations
