obj_root_law_sections_1:
  sectionId (19132)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19132&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Diplomatic and Consular Officers (Oaths and Fees)`
  line `Act, 1948.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (19133)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Omitted by Act 2 of 1973, s. 2.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19133&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_2_content:
  string
  line `In this Act,--`
  line
  line `(a) "consular officer" includes consul-general, consul, vice-consul, consular agent, pro-consul`
  line `and any other person authorised to perform the duties of consul-general, consul, vice-consul or`
  line `consular agent;`
  line
  line `(b) "diplomatic officer" means any ambassador, envoy, minister, charge d'affaires, or secretary`
  line `of embassy or legation; and`
  line
  line `(c) "prescribed" means prescribed by rules made under this Act.`
  line
  line `^1* * * * *`
obj_root_law_sections_3:
  sectionId (19134)
  sectionNo (3)
  orderNo 3
  title `Powers as to oaths and notarial acts abroad.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19134&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_3_content:
  string
  line `(1) Every diplomatic or consular officer may, in`
  line `any foreign country or place where he is exercising his functions, administer any oath and take any`
  line `affidavit and also do any notarial act which any notary public may do within ^1[a State]; and every oath,`
  line `affidavit and notarial act administered, sworn or done by or before any such person shall be as effectual`
  line `as if duly administered, sworn or done by or before any lawful authority in ^2[a State].`
  line
  line `(2) Any document purporting to have affixed, impressed or subscribed thereon or thereto the seal and`
  line `signature of any person authorised by this Act to administer an oath in testimony of any oath, affidavit or`
  line `act, being administered, taken or done by or before him, shall be admitted in evidence without proof of`
  line `the seal or signature being the seal or signature of that person, or of the official character of that person.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by the Adaptation of Laws (No. 3) Order, 1956.`
  line
  line `2. Subs., ibid., for "any Part A State".`
obj_root_law_sections_4:
  sectionId (19135)
  sectionNo (4)
  orderNo 4
  title `Punishment for offences under this Act.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19135&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_4_content:
  string
  line `(1) Whoever swears falsely in any oath or affidavit`
  line `taken or made in accordance with the provisions of this Act shall be punished with imprisonment for a`
  line `term which may extend to three years and shall also be liable to fine.`
  line
  line `(2) Whoever forges or fraudulently alters the seal or signature of any person authorised by or under`
  line `this Act to administer an oath or tenders in evidence, or otherwise uses, any affidavit having any seal or`
  line `signature so forged or counterfeited or fraudulently altered knowing the same to be forged, counterfeited`
  line `or fraudulently altered, shall be punished with imprisonment for a term which may extend to three years`
  line `and shall also be liable to fine.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (19136)
  sectionNo (5)
  orderNo 5
  title `Trial of offences.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19136&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_5_content:
  string
  line `Any offence under this Act may be inquired into, dealt with, tried and`
  line `punished in ^1[any ^2[State]] in which the person charged with the offence was apprehended or is in`
  line `custody, in the same manner and to the same extent as if the offence had been committed within the State`
  line `where he was apprehended or is in custody`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for "any Province of India".`
  line
  line `2. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Part A or Part C State".`
obj_root_law_sections_6:
  sectionId (19137)
  sectionNo (6)
  orderNo 6
  title `Power to prescribe fees.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19137&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_6_content:
  string
  line `(1) The Central Government may, from time to time, prescribe the fees`
  line `to be levied in respect of any matter or thing done by a diplomatic or consular officer in the execution of`
  line `his office.`
  line
  line `(2) All such fees shall be levied, accounted for and applied and may be remitted in such manner as`
  line `may be prescribed.`
  line
  line `(3) A diplomatic or consular officer shall not, save as may be provided by any rules made in this`
  line `behalf, ask for or take any fee or reward for or on account of any act or thing, or service done, performed`
  line `or rendered by him in the execution of his office.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (19138)
  sectionNo (7)
  orderNo 7
  title `Publication and issue of tables of fees.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19138&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_7_content:
  string
  line `(1) Tables of the fees which may, for the time being, be`
  line `levied under the rules shall be published in such manner and copies thereof shall be issued gratuitously to`
  line `such persons as may be prescribed.`
  line
  line `(2) Every consular officer, and every diplomatic officer in any: foreign country or place where there`
  line `is no consular officer, shall keep exhibited in a conspicuous place in his office a copy of the table of fees`
  line `to be levied under this Act and shall permit the same to be inspected by any person interested therein.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (19139)
  sectionNo (8)
  orderNo 8
  title `Power to make rules.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00033_194841_1517807325277&sectionId=19139&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00033_194841_1517807325277
obj_root_law_sections_8_content:
  string
  line `(1) The Central Government may ^1[, by notification in the Official`
  line `Gazette,] make rules to carry out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line prescribe--
  line
  line `(a) the scale of fees leviable under this Act and the manner in which such fees shall be levied and`
  line collected;
  line
  line `(b) the remuneration, if any, payable to a diplomatic or consular officer in the execution of any of`
  line `the duties vested in him by this Act;`
  line
  line `(c) the registers to be kept and the returns to be made in pursuance of this Act; and`
  line
  line `(d) the manner in which copies of tables of fees may be published and distributed.`
  line
  line `^2[(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament while it is in session for a total period of thirty days which may be comprised in one`
  line `session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.]`
obj_root_law_sections_8_footnotes:
  string
  line `1. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
  line
  line `2. Ins. by Act 2 of 1973, s. 3.`
