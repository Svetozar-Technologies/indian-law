  obj_root_law_sections_24
  obj_root_law_sections_25
  obj_root_law_sections_26
obj_root_law_sections_1:
  sectionId (25545)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25545&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Union Territory Goods and`
  line `Services Tax Act, 2017.`
  line
  line `(2) It extends to the Union territories of the Andaman and Nicobar Islands, Lakshadweep, ^1[Dadra`
  line `and Nagar Haveli and Daman and Diu, Ladakh], Chandigarh and other territory.`
  line
  line `(3) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act and any reference`
  line `in any such provision to the commencement of this Act shall be construed as a reference to the coming`
  line `into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 12 of 2020, s. 136, for "Dadra and Nagar Haveli, Daman and Diu".`
  line
  line `2. 22nd, June, 2017 for sections 1, 2, 3,4,5, 17, 21 and 22 vide notification No. G.S.R. 616(E) dated the 21st June, 2017, see`
  line `Gazette of India, Extraordinary, Part II, sec. 3(i).`
  line
  line `1st July, 2017 for sections 6 to 16, 18 to 20 and 23 to 26 vide notification No. G.S.R. 701(E) dated the 28th June, 2017, see`
  line `Gazette of India, Extraordinary, Part II, sec. 3(i) .`
obj_root_law_sections_2:
  sectionId (25546)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Subs. by Act 12 of 2020, s. 137, for sub-clauses (iii) and (iv).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25546&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,---`
  line
  line `(1) "appointed day" means the date on which the provisions of this Act shall come into force;`
  line
  line `(2) "Commissioner" means the Commissioner of Union territory tax appointed under section 3;`
  line
  line `(3) "designated authority" means such authority as may be notified by the Commissioner;`
  line
  line `(4) "exempt supply" means supply of any goods or services or both which attracts nil rate of tax`
  line `or which may be exempt from tax under section 8, or under section 6 of the Integrated Goods and`
  line `Services Tax Act, and includes non-taxable supply;`
  line
  line `(5) "existing law" means any law, notification, order, rule or regulation relating to levy and`
  line `collection of duty or tax on goods or services or both passed or made before the commencement of`
  line `this Act by Parliament or any Authority or person having the power to make such law, notification,`
  line `order, rule or regulation;`
  line
  line `(6) "Government" means the Administrator or any Authority or officer authorised to act as`
  line `Administrator by the Central Government;`
  line
  line `(7) "output tax" in relation to a taxable person, means the Union territory tax chargeable under`
  line `this Act on taxable supply of goods or services or both made by him or by his agent but excludes tax`
  line `payable by him on reverse charge basis;`
  line
  line `(8) "Union territory" means the territory of,---`
  line
  line `(i) the Andaman and Nicobar Islands;`
  line
  line `(ii) Lakshadweep;`
  line
  line `^1[(iii) Dadra and Nagar Haveli and Daman and Diu;`
  line
  line `(iv) Ladakh;]`
  line
  line `(v) Chandigarh; or`
  line
  line `(vi) other territory.`
  line
  line `Explanation.---For the purposes of this Act, each of the territories specified in sub-clauses (i) to (vi)`
  line `shall be considered to be a separate Union territory;`
  line
  line `(9) "Union territory tax" means the tax levied under this Act;`
  line
  line `(10) words and expressions used and not defined in this Act but defined in the Central Goods and`
  line `Services Tax Act, the Integrated Goods and Services Tax Act, the State Goods and Services Tax Act, and`
  line `the Goods and Services Tax (Compensation to States) Act, shall have the same meaning as assigned to`
  line `them in those Acts.`
obj_root_law_sections_3:
  sectionId (25547)
  sectionNo (3)
  orderNo 3
  title `Officers under this Act.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25547&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_3_content:
  string
  line `The Administrator may, by notification, appoint Commissioners and such`
  line `other class of officers as may be required for carrying out the purposes of this Act and such officers shall be`
  line `deemed to be proper officers for such purposes as may be specified therein:`
  line
  line `Provided that the officers appointed under the existing law shall be deemed to be the officers`
  line `appointed under the provisions of this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (25548)
  sectionNo (4)
  orderNo 4
  title `Authorisation of officers.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25548&sectionno=4&orderno=4&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_4_content:
  string
  line `The Administrator may, by order, authorise any officer to appoint`
  line `officers of Union territory tax below the rank of Assistant Commissioner of Union territory tax for the`
  line `administration of this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (25549)
  sectionNo (5)
  orderNo 5
  title `Powers of officers.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25549&sectionno=5&orderno=5&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_5_content:
  string
  line `(1) Subject to such conditions and limitations as the Commissioner may`
  line `impose, an officer of the Union territory tax may exercise the powers and discharge the duties conferred`
  line `or imposed on him under this Act.`
  line
  line `(2) An officer of a Union territory tax may exercise the powers and discharge the duties conferred or`
  line `imposed under this Act on any other officer of a Union territory tax who is subordinate to him.`
  line
  line `(3) The Commissioner may, subject to such conditions and limitations as may be specified in this behalf`
  line `by him, delegate his powers to any other officer subordinate to him.`
  line
  line `(4) Notwithstanding anything contained in this section, an Appellate Authority shall not exercise the`
  line `powers and discharge the duties conferred or imposed on any other officer of Union territory tax.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (25550)
  sectionNo (6)
  orderNo 6
  title `Authorisation of officers of central tax as proper officer in certain circumstances.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25550&sectionno=6&orderno=6&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_6_content:
  string
  line `(1) Without`
  line `prejudice to the provisions of this Act, the officers appointed under the Central Goods and Services Tax Act`
  line `are authorised to be the proper officers for the purposes of this Act, subject to such conditions as the`
  line `Government shall, on the recommendations of the Council, by notification, specify.`
  line
  line `(2) Subject to the conditions specified in the notification issued under sub-section (1),--`
  line
  line `(a) where any proper officer issues an order under this Act, he shall also issue an order under the`
  line `Central Goods and Services Tax Act, as authorised by the said Act under intimation to the`
  line `jurisdictional officer of central tax;`
  line
  line `(b) where a proper officer under the Central Goods and Services Tax Act has initiated any`
  line `proceedings on a subject matter, no proceedings shall be initiated by the proper officer under this Act`
  line `on the same subject matter.`
  line
  line `(3) Any proceedings for rectification, appeal and revision, wherever applicable, of any order passed`
  line `by an officer appointed under this Act, shall not lie before an officer appointed under the Central Goods`
  line `and Services Tax Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (25551)
  sectionNo (7)
  orderNo 7
  title `Levy and collection.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25551&sectionno=7&orderno=7&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of sub-section (2), there shall be levied a tax`
  line `called the Union territory tax on all intra-State supplies of goods or services or both, except on the supply of`
  line `alcoholic liquor for human consumption ^1[and un-denatured extra neutral alcohol or rectified spirit which is`
  line `used for manufacture of alcoholic liquor, for human consumption], on the value determined under section 15 of the Central Goods and`
  line `Services Tax Act and at such rates, not exceeding twenty per cent., as may be notified by the Central`
  line `Government on the recommendations of the Council and collected in such manner as may be prescribed and`
  line `shall be paid by the taxable person.`
  line
  line `(2) The Union territory tax on the supply of petroleum crude, high speed diesel, motor spirit (commonly`
  line `known as petrol), natural gas and aviation turbine fuel shall be levied with effect from such date as may be`
  line `notified by the Central Government on the recommendations of the Council.`
  line
  line `(3) The Central Government may, on the recommendations of the Council, by notification, specify`
  line `categories of supply of goods or services or both, the tax on which shall be paid on reverse charge basis`
  line `by the recipient of such goods or services or both and all the provisions of this Act shall apply to such`
  line `recipient as if he is the person liable for paying the tax in relation to the supply of such goods or services`
  line `or both.`
  line
  line `^1[(4) The Government may, on the recommendations of the Council, by notification, specify a class of registered persons who shall, in respect of supply of specified categories of goods or services or both received from an unregistered supplier, pay the tax on reverse charge basis as the recipient of such supply of goods or services or both, and all the provisions of this Act shall apply to such recipient as if he is the person liable for paying the tax in relation to such supply of goods or services or both.]`
  line
  line `(5) The Central Government may, on the recommendations of the Council, by notification, specify`
  line `categories of services the tax on intra-State supplies of which shall be paid by the electronic commerce`
  line `operator if such services are supplied through it, and all the provisions of this Act shall apply to such`
  line `electronic commerce operator as if he is the supplier liable for paying the tax in relation to the supply of`
  line `such services:`
  line
  line `Provided that where an electronic commerce operator does not have a physical presence in the`
  line `taxable territory, any person representing such electronic commerce operator for any purpose in the`
  line `taxable territory shall be liable to pay tax:`
  line
  line `Provided further that where an electronic commerce operator does not have a physical presence in`
  line `the taxable territory and also he does not have a representative in the said territory, such electronic`
  line `commerce operator shall appoint a person in the taxable territory for the purpose of paying tax and such`
  line `person shall be liable to pay tax.`
obj_root_law_sections_7_footnotes:
  string
  line `1. Ins. by Act 15 of 2024, s. 155 (w.e.f. 1-11-2024).`
  line
  line `2. Subs. by Act 33 of 2018, s. 2 for sub-section (4) (w.e.f. 1-2-2019).`
obj_root_law_sections_8:
  sectionId (25552)
  sectionNo (8)
  orderNo 8
  title `Power to grant exemption from tax.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25552&sectionno=8&orderno=8&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_8_content:
  string
  line `(1) Where the Central Government is satisfied that it is`
  line `necessary in the public interest so to do, it may, on the recommendations of the Council, by notification,`
  line `exempt generally either absolutely or subject to such conditions as may be specified therein, goods or`
  line `services or both of any specified description from the whole or any part of the tax leviable thereon with`
  line `effect from such date as may be specified in such notification.`
  line
  line `(2) Where the Central Government is satisfied that it is necessary in the public interest so to do, it`
  line `may, on the recommendations of the Council, by special order in each case, under circumstances of an`
  line `exceptional nature to be stated in such order, exempt from payment of tax any goods or services or both`
  line `on which tax is leviable.`
  line
  line `(3) The Central Government may, if it considers necessary or expedient so to do for the purpose of`
  line `clarifying the scope or applicability of any notification issued under sub-section (1) or order issued under`
  line `sub-section (2), insert an explanation in such notification or order, as the case may be, by notification at`
  line `any time within one year of issue of the notification under sub-section (1) or order under sub-section (2),`
  line `and every such explanation shall have effect as if it had always been the part of the first such notification`
  line `or order, as the case may be.`
  line
  line `(4) Any notification issued by the Central Government under sub-section (1) of section 11 or order`
  line `issued under sub-section (2) of the said section of the Central Goods and Services Tax Act shall be`
  line `deemed to be a notification or, as the case may be, an order issued under this Act.`
  line
  line `Explanation.--For the purposes of this section, where an exemption in respect of any goods or services`
  line `or both from the whole or part of the tax leviable thereon has been granted absolutely, the registered person`
  line `supplying such goods or services or both shall not collect the tax, in excess of the effective rate, on such`
  line `supply of goods or services or both.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_8_a:
  sectionId (98251)
  sectionNo 8A
  orderNo 9
  title `Power not to recover Goods and Services Tax not levied or short-levied as a result of general practice.`
  content obj_root_law_sections_8_a_content
  footnotes `1. Ins. by Act 15 of 2024, s. 156 (w.e.f. 1-11-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=98251&sectionno=8A&orderno=9&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_8_a_content:
  string
  line `^1[8A. Power not to recover Goods and Services Tax not levied or short-levied as a result of`
  line `general practice.--- Notwithstanding anything contained in this Act, if the Government is satisfied that---`
  line
  line `(a) a practice was, or is, generally prevalent regarding levy of Union territory tax (including nonlevy thereof) on any supply of goods or services or both; and`
  line
  line `(b) such supplies were, or are, liable to---`
  line
  line `(i) Union territory tax, in cases where according to the said practice, Union territory tax was`
  line `not, or is not being, levied; or`
  line
  line `(ii) a higher amount of Union territory tax than what was, or is being, levied, in accordance`
  line `with the said practice,`
  line
  line `the Government may, on the recommendation of the Council, by notification in the Official Gazette,`
  line `direct that the whole of the Union territory tax payable on such supplies, or, as the case may be, the`
  line `Union territory tax in excess of that payable on such supplies, but for the said practice, shall not be`
  line `required to be paid in respect of the supplies on which the Union territory tax was not, or is not being,`
  line `levied, or was, or is being, short-levied, in accordance with the said practice.]`
obj_root_law_sections_9:
  sectionId (25553)
  sectionNo (9)
  orderNo 10
  title `Payment of tax.`
  content obj_root_law_sections_9_content
  footnotes `1. Ins. by Act 33 of 2018, s. 3 (w.e.f. 1-2-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25553&sectionno=9&orderno=10&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_9_content:
  string
  line `The amount of input tax credit available in the electronic credit ledger of the`
  line `registered person on account of,--`
  line
  line `(a) integrated tax shall first be utilised towards payment of integrated tax and the amount`
  line `remaining, if any, may be utilised towards the payment of central tax and State tax, or as the case may`
  line `be, Union territory tax, in that order;`
  line
  line `(b) the Union territory tax shall first be utilised towards payment of Union territory tax and the`
  line `amount remaining, if any, may be utilised towards payment of integrated tax;`
  line
  line `^1[Provided that the input tax credit on account of Union territory tax shall be utilised towards`
  line `payment of integrated tax only where the balance of the input tax credit on account of central tax is`
  line `not available for payment of integrated tax.]`
  line
  line `(c) the Union territory tax shall not be utilised towards payment of central tax.`
obj_root_law_sections_9_a:
  sectionId (48988)
  sectionNo 9A
  orderNo 11
  title `Utilisation of input tax credit.`
  content obj_root_law_sections_9_a_content
  footnotes `1. Ins. by Act 33 of 2018, s. 4, (w.e.f. 1-2-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=48988&sectionno=9A&orderno=11&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_9_a_content:
  string
  line `^1[9A. Utilisation of input tax credit.--- Notwithstanding anything contained in section 9, the input`
  line `tax credit on account of Union territory tax shall be utilised towards payment of integrated tax or Union`
  line `territory tax, as the case may be, only after the input tax credit available on account of integrated tax has`
  line `first been utilised towards such payment.]`
obj_root_law_sections_9_b:
  sectionId (48989)
  sectionNo 9B
  orderNo 12
  title `Order of utilisation of input tax credit.`
  content obj_root_law_sections_9_b_content
  footnotes `1. Ins. by Act 33 of 2018, s. 4 (w.e.f. 1-2-2019).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=48989&sectionno=9B&orderno=12&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_9_b_content:
  string
  line `^1[9B. Order of utilisation of input tax credit.--- Notwithstanding anything contained in this Chapter`
  line `and subject to the provisions of clause (c) of section 9, the Government may, on the recommendations of`
  line `the Council, prescribe the order and manner of utilisation of the input tax credit on account of integrated`
  line `tax, Central tax, State tax or Union territory tax, as the case may be, towards payment of any such tax.]`
obj_root_law_sections_10:
  sectionId (25554)
  sectionNo (10)
  orderNo 13
  title `Transfer of input tax credit.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25554&sectionno=10&orderno=13&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_10_content:
  string
  line `On utilisation of input tax credit of Union territory tax for payment`
  line `of tax dues under the Integrated Goods and Services Tax Act in accordance with the provisions of subsection`
  line `(5) of section 49 of the Central Goods and Services Tax Act, as reflected in the valid return`
  line `furnished under sub-section (1) of section 39 of the Central Goods and Services Tax Act, the amount`
  line `collected as Union territory tax shall stand reduced by an amount equal to such credit so utilised and the`
  line `Central Government shall transfer an amount equal to the amount so reduced from the Union territory tax`
  line `account to the integrated tax account in such manner and within such time as may be prescribed.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (25555)
  sectionNo (11)
  orderNo 14
  title `Officers required to assist proper officers.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25555&sectionno=11&orderno=14&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_11_content:
  string
  line `(1) All officers of Police, Railways, Customs, and`
  line `those officers engaged in the collection of land revenue, including village officers, and officers of central`
  line `tax and officers of the State tax shall assist the proper officers in the implementation of this Act.`
  line
  line `(2) The Government may, by notification, empower and require any other class of officers to assist`
  line `the proper officers in the implementation of this Act when called upon to do so by the Commissioner.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (25556)
  sectionNo (12)
  orderNo 15
  title `Tax wrongfully collected and paid to Central Government or Union territory Government.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25556&sectionno=12&orderno=15&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_12_content:
  string
  line `(1) A registered person who has paid the central tax and the Union territory tax on a`
  line `transaction considered by him to be an intra-State supply, but which is subsequently held to be an interState`
  line `supply, shall be refunded the amount of taxes so paid in such manner and subject to such conditions`
  line `as may be prescribed.`
  line
  line `(2) A registered person who has paid integrated tax on a transaction considered by him to be an interState`
  line `supply, but which is subsequently held to be an intra-State supply, shall not be required to pay any`
  line `interest on the amount of the central tax and the Union territory tax payable.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (25557)
  sectionNo (13)
  orderNo 16
  title `Recovery of tax.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25557&sectionno=13&orderno=16&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_13_content:
  string
  line `(1) Where any amount of tax, interest or penalty is payable by a person to the`
  line `Government under any of the provisions of this Act or the rules made thereunder and which remains`
  line `unpaid, the proper officer of central tax, during the course of recovery of said tax arrears, may recover the`
  line `amount from the said person as if it were an arrear of central tax and credit the amount so recovered to the`
  line `account of the Government under the appropriate head of Union terrirtory tax.`
  line
  line `(2) Where the amount recovered under sub-section (1) is less than the amount due to the Government`
  line `under this Act and the Central Goods and Services Tax Act, the amount to be credited to the account of`
  line `the Government shall be in proportion to the amount due as Union territory tax and central tax.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (25558)
  sectionNo (14)
  orderNo 17
  title Definitions.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25558&sectionno=14&orderno=17&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_14_content:
  string
  line `In this Chapter, unless the context otherwise requires,—`
  line
  line `(a) "advance ruling" means a decision provided by the Authority or the Appellate Authority to an`
  line `applicant on matters or on questions specified in sub-section (2) of section 97 or sub-section (1) of`
  line `section 100 of the Central Goods and Services Tax Act, in relation to the supply of goods or services or`
  line `both being undertaken or proposed to be undertaken by the applicant;`
  line
  line `(b) "Appellate Authority" means the Appellate Authority for Advance Ruling constituted under`
  line `section 16;`
  line
  line `(c) "applicant" means any person registered or desirous of obtaining registration under this Act;`
  line
  line `(d) "application" means an application made to the Authority under sub-section (1) of section 97`
  line `of the Central Goods and Services Tax Act;`
  line
  line `(e) "Authority" means the Authority for Advance Ruling, constituted under section 15.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (25559)
  sectionNo (15)
  orderNo 18
  title `Constitution of Authority for Advance Ruling.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25559&sectionno=15&orderno=18&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_15_content:
  string
  line `(1) The Central Government shall, by`
  line `notification, constitute an Authority to be known as the (name of the Union territory) Authority for`
  line `Advance Ruling:`
  line
  line `Provided that the Central Government may, on the recommendations of the Council, notify any`
  line `Authority located in any State or any other Union territory to act as the Authority for the purposes of this`
  line Act.
  line
  line `(2) The Authority shall consist of--`
  line
  line `(i) one member from amongst the officers of central tax; and`
  line
  line `(ii) one member from amongst the officers of Union territory tax,`
  line
  line `to be appointed by the Central Government.`
  line
  line `(3) The qualifications, the method of appointment of the members and the terms and conditions of`
  line `their service shall be such as may be prescribed.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (25560)
  sectionNo (16)
  orderNo 19
  title `Constitution of Appellate Authority for Advance Ruling.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25560&sectionno=16&orderno=19&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_16_content:
  string
  line `(1) The Central Government shall,`
  line `by notification, constitute an Appellate Authority to be known as the (name of the Union territory) Appellate`
  line `Authority for Advance Ruling for Goods and Services Tax for hearing appeals against the advance ruling`
  line `pronounced by the Advance Ruling Authority:`
  line
  line `Provided that the Central Government may, on the recommendations of the Council, notify any`
  line `Appellate Authority located in any State or any other Union territory to act as the Appellate Authority for`
  line `the purposes of this Act.`
  line
  line `(2) The Appellate Authority shall consist of--`
  line
  line `(i) the Chief Commissioner of central tax as designated by the Board; and`
  line
  line `(ii) the Commissioner of Union territory tax having jurisdiction over the applicant.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (25561)
  sectionNo (17)
  orderNo 20
  title `Migration of existing tax payers.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25561&sectionno=17&orderno=20&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_17_content:
  string
  line `(1) On and from the appointed day, every person registered`
  line `under any of the existing laws and having a valid Permanent Account Number shall be issued a certificate`
  line `of registration on provisional basis, subject to such conditions and in such form and manner as may be`
  line `prescribed, which unless replaced by a final certificate of registration under sub-section (2), shall be liable`
  line `to be cancelled if the conditions so prescribed are not complied with.`
  line
  line `(2) The final certificate of registration shall be granted in such form and manner and subject to such`
  line `conditions as may be prescribed.`
  line
  line `(3) The certificate of registration issued to a person under sub-section (1) shall be deemed to have not`
  line `been issued if the said registration is cancelled in pursuance of an application filed by such person that he`
  line `was not liable to registration under section 22 or section 24 of the Central Goods and Services Tax Act.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (25562)
  sectionNo (18)
  orderNo 21
  title `Transitional arrangements for input tax credit.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25562&sectionno=18&orderno=21&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_18_content:
  string
  line `(1) A registered person, other than a person`
  line `opting to pay tax under section 10 of the Central Goods and Services Tax Act, shall be entitled to take, in`
  line `his electronic credit ledger, credit of the amount of Value Added Tax and Entry Tax, if any, carried`
  line `forward in the return relating to the period ending with the day immediately preceding the appointed day,`
  line `furnished by him under the existing law, not later than ninety days after the said day, in such manner as`
  line `may be prescribed:`
  line
  line `Provided that the registered person shall not be allowed to take credit in the following circumstances,`
  line `namely:--`
  line
  line `(i) where the said amount of credit is not admissible as input tax credit under this Act; or`
  line
  line `(ii) where he has not furnished all the returns required under the existing law for the period of six`
  line `months immediately preceding the appointed day; or`
  line
  line `(iii) where the said amount of credit relates to goods sold under such exemption notifications as`
  line `are notified by the Government:`
  line
  line `Provided further that so much of the said credit as is attributable to any claim related to section 3,`
  line `sub-section (3) of section 5, section 6 or section 6A or sub-section (8) of section 8 of the Central Sales Tax`
  line `Act, 1956 (74 of 1956) that is not substantiated in the manner, and within the period, prescribed in rule 12 of`
  line `the Central Sales Tax (Registration and Turnover) Rules, 1957 shall not be eligible to be credited to the`
  line `electronic credit ledger:`
  line
  line `Provided also that an amount equivalent to the credit specified in the second proviso shall be refunded`
  line `under the existing law when the said claims are substantiated in the manner prescribed in rule 12 of the Central`
  line `Sales Tax (Registration and Turnover) Rules, 1957.`
  line
  line `(2) A registered person, other than a person opting to pay tax under section 10 of the Central Goods`
  line `and Services Tax Act, shall be entitled to take, in his electronic credit ledger, credit of the unavailed input`
  line `tax credit in respect of capital goods, not carried forward in a return, furnished under the existing law by`
  line `him, for the period ending with the day immediately preceding the appointed day in such manner as may`
  line `be prescribed:`
  line
  line `Provided that the registered person shall not be allowed to take credit unless the said credit was`
  line `admissible as input tax credit under the existing law and is also admissible as input tax credit under this`
  line Act.
  line
  line `Explanation.--For the purposes of this section, the expression "unavailed input tax credit" means the`
  line `amount that remains after subtracting the amount of input tax credit already availed in respect of capital`
  line `goods by the taxable person under the existing law from the aggregate amount of input tax credit to which`
  line `the said person was entitled in respect of the said capital goods under the existing law.`
  line
  line `(3) A registered person, who was not liable to be registered under the existing law or who was`
  line `engaged in the sale of exempted goods or tax free goods or goods which have suffered tax at first point of`
  line `their sale in the Union territory and the subsequent sales of which are not subject to tax in the Union`
  line `territory under the existing law but which are liable to tax under this Act or where the person was entitled`
  line `to the credit of input tax at the time of sale of goods, shall be entitled to take, in his electronic credit`
  line `ledger, credit of the value added tax and entry tax, if any, in respect of inputs held in stock and inputs`
  line `contained in semi-finished or finished goods held in stock on the appointed day subject to the following`
  line `conditions, namely:--`
  line
  line `(i) such inputs or goods are used or intended to be used for making taxable supplies under this`
  line Act;
  line
  line `(ii) the said registered person is eligible for input tax credit on such inputs under this Act;`
  line
  line `(iii) the said registered person is in possession of invoice or other prescribed documents`
  line `evidencing payment of tax under the existing law in respect of such inputs; and`
  line
  line `(iv) such invoices or other prescribed documents were issued not earlier than twelve months`
  line `immediately preceding the appointed day:`
  line
  line `Provided that where a registered person, other than a manufacturer or a supplier of services, is not in`
  line `possession of an invoice or any other documents evidencing payment of tax in respect of inputs, then, such`
  line `registered person shall, subject to such conditions, limitations and safeguards as may be prescribed,`
  line `including that the said taxable person shall pass on the benefit of such credit by way of reduced prices to`
  line `the recipient, be allowed to take credit at such rate and in such manner as may be prescribed.`
  line
  line `(4) A registered person, who was engaged in the sale of taxable goods as well as exempted goods or`
  line `tax free goods under the existing law but which are liable to tax under this Act, shall be entitled to take, in`
  line `his electronic credit ledger,--`
  line
  line `(a) the amount of credit of the value added tax and entry tax, if any, carried forward in a return`
  line `furnished under the existing law by him in accordance with the provisions of sub-section (1); and`
  line
  line `(b) the amount of credit of the value added tax and entry tax, if any, in respect of inputs held in`
  line `stock and inputs contained in semi-finished or finished goods held in stock on the appointed day,`
  line `relating to such exempted goods or tax free goods in accordance with the provisions of`
  line `sub-section (3).`
  line
  line `(5) A registered person shall be entitled to take, in his electronic credit ledger, credit of value added`
  line `tax and entry tax, if any, in respect of inputs received on or after the appointed day but the tax in respect`
  line `of which has been paid by the supplier under the existing law, subject to the condition that the invoice or`
  line `any other tax paying document of the same was recorded in the books of account of such person within a`
  line `period of thirty days from the appointed day:`
  line
  line `Provided that the period of thirty days may, on sufficient cause being shown, be extended by the`
  line `Commissioner for a further period not exceeding thirty days:`
  line
  line `Provided further that the said registered person shall furnish a statement, in such manner as may be`
  line `prescribed, in respect of credit that has been taken under this sub-section.`
  line
  line `(6) A registered person, who was either paying tax at a fixed rate or paying a fixed amount in lieu of`
  line `the tax payable under the existing law shall be entitled to take, in his electronic credit ledger, credit of`
  line `value added tax in respect of inputs held in stock and inputs contained in semi-finished or finished goods`
  line `held in stock on the appointed day subject to the following conditions, namely:--`
  line
  line `(i) such inputs or goods are used or intended to be used for making taxable supplies under this`
  line Act;
  line
  line `(ii) the said registered person is not paying tax under section 10 of the Central Goods and`
  line `Services Tax Act;`
  line
  line `(iii) the said registered person is eligible for input tax credit on such inputs under this Act;`
  line
  line `(iv) the said registered person is in possession of invoice or other prescribed documents evidencing`
  line `payment of tax under the existing law in respect of inputs; and`
  line
  line `(v) such invoices or other prescribed documents were issued not earlier than twelve months`
  line `immediately preceding the appointed day.`
  line
  line `(7) The amount of credit under sub-sections (3), (4) and (6) shall be calculated in such manner as may`
  line `be prescribed.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (25563)
  sectionNo (19)
  orderNo 22
  title `Transitional provisions relating to job work.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25563&sectionno=19&orderno=22&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_19_content:
  string
  line `(1) Where any inputs received at a place of`
  line `business had been dispatched as such or dispatched after being partially processed to a job worker for`
  line `further processing, testing, repair, reconditioning or any other purpose in accordance with the provisions of`
  line `existing law prior to the appointed day and such inputs are returned to the said place on or after the appointed day, no tax shall be payable if such inputs, after completion of the job work or otherwise, are`
  line `returned to the said place within six months from the appointed day:`
  line
  line `Provided that the period of six months may, on sufficient cause being shown, be extended by the`
  line `Commissioner for a further period not exceeding two months:`
  line
  line `Provided further that if such inputs are not returned within a period of six months or the extended`
  line `period from the appointed day, the input tax credit shall be liable to be recovered in accordance with the`
  line `provisions of clause (a) of sub-section (8) of section 142 of the Central Goods and Services Tax Act.`
  line
  line `(2) Where any semi-finished goods had been despatched from any place of business to any other premises`
  line `for carrying out certain manufacturing processes in accordance with the provisions of existing law prior to the`
  line `appointed day and such goods (hereinafter in this section referred to as “the said goods”) are returned to the`
  line `said place on or after the appointed day, no tax shall be payable if the said goods, after undergoing`
  line `manufacturing processes or otherwise, are returned to the said place within six months from the appointed day:`
  line
  line `Provided that the period of six months may, on sufficient cause being shown, be extended by the`
  line `Commissioner for a further period not exceeding two months:`
  line
  line `Provided further that if the said goods are not returned within a period specified in this sub-section,`
  line `the input tax credit shall be liable to be recovered in accordance with the provisions of clause (a) of`
  line `sub-section (8) of section 142 of the Central Goods and Services Tax Act:`
  line
  line `Provided also that the person despatching the goods may, in accordance with the provisions of the`
  line `existing law, transfer the said goods to the premises of any registered person for the purpose of supplying`
  line `therefrom on payment of tax in India or without payment of tax for exports within six months or the`
  line `extended period, as the case may be, from the appointed day.`
  line
  line `(3) Where any goods had been despatched from the place of business without payment of tax for`
  line `carrying out tests or any other process to any other premises, whether registered or not, in accordance`
  line `with the provisions of existing law prior to the appointed day and such goods are returned to the said`
  line `place of business on or after the appointed day, no tax shall be payable if the said goods, after undergoing`
  line `tests or any other process, are returned to such place within six months from the appointed day:`
  line
  line `Provided that the period of six months may, on sufficient cause being shown, be extended by the`
  line `Commissioner for a further period not exceeding two months:`
  line
  line `Provided further that if the said goods are not returned within the period specified in this sub-section,`
  line `the input tax credit shall be liable to be recovered in accordance with the provisions of clause (a) of`
  line `sub-section (8) of section 142 of the Central Goods and Services Tax Act:`
  line
  line `Provided also that the person despatching the goods may, in accordance with the provisions of the`
  line `existing law, transfer the said goods from the said other premises on payment of tax in India or without`
  line `payment of tax for exports within six months or the extended period, as the case may be, from the`
  line `appointed day.`
  line
  line `(4) The tax under sub-sections (1), (2) and (3) shall not be payable only if the person despatching the`
  line `goods and the job worker declare the details of the inputs or goods held in stock by the job worker on`
  line `behalf of the said person on the appointed day in such form and manner and within such time as may be`
  line prescribed.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (25564)
  sectionNo (20)
  orderNo 23
  title `Miscellaneous transitional provisions.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25564&sectionno=20&orderno=23&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_20_content:
  string
  line `(1) Where any goods on which tax, if any, had been`
  line `paid under the existing law at the time of sale thereof, not being earlier than six months prior to the`
  line `appointed day, are returned to any place of business on or after the appointed day, the registered person shall`
  line `be eligible for refund of the tax paid under the existing law where such goods are returned`
  line `by a person, other than a registered person, to the said place of business within a period of six months`
  line `from the appointed day and such goods are identifiable to the satisfaction of the proper officer:`
  line
  line `Provided that if the said goods are returned by a registered person, the return of such goods shall be`
  line `deemed to be a supply.`
  line
  line `(2) (a) Where, in pursuance of a contract entered into prior to the appointed day, the price of any goods`
  line `is revised upwards on or after the appointed day, the registered person who had sold such goods shall issue`
  line `to the recipient a supplementary invoice or debit note, containing such particulars as may be prescribed,`
  line `within thirty days of such price revision and for the purposes of this Act, such supplementary invoice or`
  line `debit note shall be deemed to have been issued in respect of an outward supply made under this Act.`
  line
  line `(b) Where, in pursuance of a contract entered into prior to the appointed day, the price of any goods is`
  line `revised downwards on or after the appointed day, the registered person who had sold such goods may`
  line `issue to the recipient a credit note, containing such particulars as may be prescribed, within thirty days of`
  line `such price revision and for the purposes of this Act such credit note shall be deemed to have been issued`
  line `in respect of an outward supply made under this Act:`
  line
  line `Provided that the registered person shall be allowed to reduce his tax liability on account of issue of`
  line `the credit note only if the recipient of the credit note has reduced his input tax credit corresponding to`
  line `such reduction of tax liability.`
  line
  line `(3) Every claim for refund filed by any person before, on or after the appointed day, for refund of any`
  line `amount of input tax credit, tax, interest or any other amount paid under the existing law, shall be disposed`
  line `of in accordance with the provisions of existing law and any amount eventually accruing to him shall be`
  line `refunded to him in cash in accordance with the provisions of the said law:`
  line
  line `Provided that where any claim for refund of the amount of input tax credit is fully or partially`
  line `rejected, the amount so rejected shall lapse:`
  line
  line `Provided further that no refund shall be allowed of any amount of input tax credit where the balance`
  line `of the said amount as on the appointed day has been carried forward under this Act.`
  line
  line `(4) Every claim for refund filed after the appointed day for refund of any tax paid under the existing`
  line `law in respect of the goods exported before or after the appointed day shall be disposed of in accordance`
  line `with the provisions of the existing law:`
  line
  line `Provided that where any for refund of input tax credit is fully or partially rejected, the amount so`
  line `rejected shall lapse:`
  line
  line `Provided further that no refund shall be allowed of any amount of input tax credit where the balance`
  line `of the said amount as on the appointed day has been carried forward under this Act.`
  line
  line `(5) (a) Every proceeding of appeal, revision, review or reference relating to a claim for input tax`
  line `credit initiated whether before, on or after the appointed day, under the existing law shall be disposed of`
  line `in accordance with the provisions of the existing law, and any amount of credit found to be admissible to`
  line `the claimant shall be refunded to him in cash in accordance with the provisions of the existing law and the`
  line `amount rejected, if any, shall not be admissible as input tax credit under this Act:`
  line
  line `Provided that no refund shall be allowed of any amount of input tax credit where the balance of the said`
  line `amount as on the appointed day has been carried forward under this Act.`
  line
  line `(b) Every proceeding of appeal, revision, review or reference relating to recovery of input tax credit`
  line `initiated whether before, on or after the appointed day, under the existing law shall be disposed of in`
  line `accordance with the provisions of the existing law, and if any amount of credit becomes recoverable as a`
  line `result of such appeal, revision, review or reference, the same shall, unless recovered under the existing`
  line `law, be recovered as an arrear of tax under this Act and the amount so recovered shall not be admissible`
  line `as input tax credit under this Act.`
  line
  line `(6) (a) Every proceeding of appeal, revision, review or reference relating to any output tax liability`
  line `initiated whether before, on or after the appointed day under the existing law, shall be disposed of in`
  line `accordance with the provisions of the existing law, and if any amount becomes recoverable as a result of such`
  line `appeal, revision, review or reference, the same shall, unless recovered under the existing law, be recovered as`
  line `an arrear of tax under this Act and amount so recovered shall not be admissible as input tax credit under this`
  line Act.
  line
  line `(b) Every proceeding of appeal, revision, review or reference relating to any output tax liability initiated`
  line `whether before, on or after the appointed day under the existing law, shall be disposed of in accordance with`
  line `the provisions of the existing law, and any amount found to be admissible to the claimant shall be refunded to`
  line `him in cash in accordance with the provisions of the existing law and the amount rejected, if any, shall not be`
  line `admissible as input tax credit under this Act.`
  line
  line `(7) (a) Where in pursuance of an assessment or adjudication proceedings instituted, whether before, on`
  line `or after the appointed day, under the existing law, any amount of tax, interest, fine or penalty becomes`
  line `recoverable from the person, the same shall, unless recovered under the existing law, be recovered as an`
  line `arrear of tax under this Act and the amount so recovered shall not be admissible as input tax credit under`
  line `this Act.`
  line
  line `(b) Where in pursuance of an assessment or adjudication proceedings instituted, whether before, on or`
  line `after the appointed day under the existing law, any amount of tax, interest, fine or penalty becomes`
  line `refundable to the taxable person, the same shall be refunded to him in cash under the said law and the`
  line `amount rejected, if any, shall not be admissible as input tax credit under this Act.`
  line
  line `(8) (a) Where any return, furnished under the existing law, is revised after the appointed day and if,`
  line `pursuant to such revision, any amount is found to be recoverable or any amount of input tax credit is found to`
  line `be inadmissible, the same shall, unless recovered under the existing law, be recovered as an arrear of tax under`
  line `this Act and the amount so recovered shall not be admissible as input tax credit under this Act.`
  line
  line `(b) Where any return, furnished under the existing law, is revised after the appointed day but within`
  line `the time limit specified for such revision under the existing law and if, pursuant to such revision, any`
  line `amount is found to be refundable or input tax credit is found to be admissible to any taxable person, the`
  line `same shall be refunded to him in cash under the existing law and the amount rejected, if any, shall not be`
  line `admissible as input tax credit under this Act.`
  line
  line `(9) Save as otherwise provided in this Chapter, the goods or services or both supplied on or after the`
  line `appointed day in pursuance of a contract entered into prior to the appointed day shall be liable to tax`
  line `under the provisions of this Act.`
  line
  line `(10) (a) Notwithstanding anything contained in section 12 of the Central Goods and Services Tax`
  line `Act, no tax shall be payable on goods under this Act to the extent the tax was leviable on the said goods`
  line `under the existing law.`
  line
  line `(b) Notwithstanding anything contained in section 13 of the Central Goods and Services Tax Act, no`
  line `tax shall be payable on services under this Act to the extent the tax was leviable on the said services under`
  line `Chapter V of the Finance Act, 1994 (32 of 1994).`
  line
  line `(c) Where tax was paid on any supply, both under any existing law relating to sale of goods and under`
  line `Chapter V of the Finance Act, 1994 (32 of 1994), tax shall be leviable under this Act and the taxable`
  line `person shall be entitled to take credit of value added tax or service tax paid under the existing law to the`
  line `extent of supplies made after the appointed day and such credit shall be calculated in such manner as may`
  line `be prescribed.`
  line
  line `(11) Where any goods sent on approval basis, not earlier than six months before the appointed day,`
  line `are rejected or not approved by the buyer and returned to the seller on or after the appointed day, no tax`
  line `shall be payable thereon if such goods are returned within six months from the appointed day:`
  line
  line `Provided that the said period of six months may, on sufficient cause being shown, be extended by the`
  line `Commissioner for a further period not exceeding two months:`
  line
  line `Provided further that the tax shall be payable by the person returning the goods if such goods are`
  line `liable to tax under this Act and are returned after the period specified in this sub-section:`
  line
  line `Provided also that tax shall be payable by the person who has sent the goods on approval basis if such`
  line `goods are liable to tax under this Act, and are not returned within the period specified in this sub-section.`
  line
  line `(12) Where a supplier has made any sale of goods in respect of which tax was required to be deducted at`
  line `source under any existing law relating to sale of goods and has also issued an invoice for the same before the appointed day, no deduction of tax at source under section 51 of the Central Goods and Services Tax Act, as`
  line `made applicable to this Act, shall be made by the deductor under the said section where payment to the said`
  line `supplier is made on or after the appointed day.`
  line
  line `Explanation.--- For the purposes of this Chapter, the expression "capital goods" shall have the same`
  line `meaning as assigned to it in any existing law relating to sale of goods.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (25565)
  sectionNo (21)
  orderNo 24
  title `Application of provisions of Central Goods and Services Tax Act.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25565&sectionno=21&orderno=24&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_21_content:
  string
  line `Subject to the provisions`
  line `of this Act and the rules made thereunder, the provisions of the Central Goods and Services Tax Act,`
  line `relating to,--`
  line
  line `(i) scope of supply;`
  line
  line `(ii) composition levy;`
  line
  line `(iii) composite supply and mixed supply;`
  line
  line `(iv) time and value of supply;`
  line
  line `(v) input tax credit;`
  line
  line `(vi) registration;`
  line
  line `(vii) tax invoice, credit and debit notes;`
  line
  line `(viii) accounts and records;`
  line
  line `(ix) returns;`
  line
  line `(x) payment of tax;`
  line
  line `(xi) tax deduction at source;`
  line
  line `(xii) collection of tax at source;`
  line
  line `(xiii) assessment;`
  line
  line `(xiv) refunds;`
  line
  line `(xv) audit;`
  line
  line `(xvi) inspection, search, seizure and arrest;`
  line
  line `(xvii) demands and recovery;`
  line
  line `(xix) advance ruling;`
  line
  line `(xx) appeals and revision;`
  line
  line `(xxi) presumption as to documents;`
  line
  line `(xxii) offences and penalties;`
  line
  line `(xxiii) job work;`
  line
  line `(xxiv) electronic commerce;`
  line
  line `(xxv) settlement of funds;`
  line
  line `(xxvi) transitional provisions; and`
  line
  line `(xxvii) miscellaneous provisions including the provisions relating to the imposition of interest and penalty,`
  line
  line `shall, mutatis mutandis, apply,--`
  line
  line `(a) so far as may be, in relation to Union territory tax as they apply in relation to central tax as if`
  line `they were enacted under this Act;`
  line
  line `(b) subject to the following modifications and alterations which the Central Government`
  line `considers necessary and desirable to adapt those provisions to the circumstances, namely:--`
  line
  line `(i) references to "this Act" shall be deemed to be references to "the Union Territory Goods`
  line `and Services Tax Act, 2017";`
  line
  line `(ii) references to "Commissioner" shall be deemed to be references to "Commissioner" of`
  line `Union territory tax as defined in clause (2) of section 2 of this Act;`
  line
  line `(iii) references to "officers of central tax" shall be deemed to be references to "officers of`
  line `Union territory tax";`
  line
  line `(iv) references to "central tax" shall be deemed to be references to "Union territory tax" and`
  line `vice versa;`
  line
  line `(v) references to "Commissioner of State tax or Commissioner of Union territory tax" shall be`
  line `deemed to be references to "Commissioner of central tax";`
  line
  line `(vi) references to "State Goods and Services Tax Act or Union Territory Goods and Services`
  line `Tax Act" shall be deemed to be references to "Central Goods and Services Tax Act";`
  line
  line `(vii) references to "State tax or Union territory tax" shall be deemed to be references to`
  line `"central tax".`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (25566)
  sectionNo (22)
  orderNo 25
  title `Power to make rules.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25566&sectionno=22&orderno=25&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_22_content:
  string
  line `(1) The Central Government may, on the recommendations of the`
  line `Council, by notification, make rules for carrying out the provisions of this Act.`
  line
  line `(2) Without prejudice to the generality of the provisions of sub-section (1), the Central Government`
  line `may make rules for all or any of the matters which by this Act are required to be, or may be, prescribed or`
  line `in respect of which provisions are to be or may be made by rules.`
  line
  line `(3) The power to make rules conferred by this section shall include the power to give retrospective`
  line `effect to the rules or any of them from a date not earlier than the date on which the provisions of this Act`
  line `come into force.`
  line
  line `(4) Any rules made under sub-section (1) may provide that a contravention thereof shall be liable to a`
  line `penalty not exceeding ten thousand rupees.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (25567)
  sectionNo (23)
  orderNo 26
  title `General power to make regulations.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25567&sectionno=23&orderno=26&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_23_content:
  string
  line `The Board may, by notification, make regulations`
  line `consistent with this Act and the rules made thereunder to carry out the purposes of this Act.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (25568)
  sectionNo (24)
  orderNo 27
  title `Laying of rules, regulations and notifications.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25568&sectionno=24&orderno=27&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_24_content:
  string
  line `Every rule made by the Central Government,`
  line `every regulation made by the Board and every notification issued by the Central Government under this Act,`
  line `shall be laid, as soon as may be, after it is made or issued, before each House of Parliament, while it is in`
  line `session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or in`
  line `the notification, as the case may be, or both Houses agree that the rule or regulation or the notification`
  line `should not be made, the rule or regulation or notification, as the case may be, shall thereafter have effect`
  line `only in such modified form or be of no effect, as the case may be; so, however, that any such modification`
  line `or annulment shall be without prejudice to the validity of anything previously done under that rule or`
  line `regulation or notification, as the case may be.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (25569)
  sectionNo (25)
  orderNo 28
  title `Power to issue instructions or directions.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25569&sectionno=25&orderno=28&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_25_content:
  string
  line `The Commissioner may, if he considers it necessary or`
  line `expedient so to do for the purpose of uniformity in the implementation of this Act, issue such orders,`
  line `instructions or directions to the Union territory tax officers as he may deem fit, and thereupon all such`
  line `officers and all other persons employed in the implementation of this Act shall observe and follow such`
  line `orders, instructions or directions.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (25570)
  sectionNo (26)
  orderNo 29
  title `Removal of difficulties.`
  content obj_root_law_sections_26_content
  footnotes `1. Subs. by Act 12 of 2020, s. 138, for "three years" (w.e.f. 27-03-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00044_201714_1517807328128&sectionId=25570&sectionno=26&orderno=29&orgactid=AC_CEN_2_2_00044_201714_1517807328128
obj_root_law_sections_26_content:
  string
  line `(1) If any difficulty arises in giving effect to any provision of this Act, the`
  line `Central Government may, on the recommendations of the Council, by a general or a special order published`
  line `in the Official Gazette, make such provisions not inconsistent with the provisions of this Act or the rules or`
  line `regulations made thereunder, as may be necessary or expedient for the purpose of removing the said`
  line `difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of ^1[five years] from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be, after it is made, before each`
  line `House of Parliament.`
