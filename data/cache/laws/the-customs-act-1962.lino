  line
obj_root_law_sections_80:
  sectionId (30975)
  sectionNo (80)
  orderNo 140
  title `Temporary detention of baggage.`
  content obj_root_law_sections_80_content
  footnotes `1. Ins. by Act 22 of 1995, s. 63 (w.e.f. 26-5-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00042_196252_1534829466423&sectionId=30975&sectionno=80&orderno=140&orgactid=AC_CEN_2_2_00042_196252_1534829466423
obj_root_law_sections_80_content:
  string
  line `Where the baggage of a passenger contains any article`
  line `which is dutiable or the import of which is prohibited and in respect of which a true declaration has been`
  line `made under section 77, the proper officer may, at the request of the passenger, detain such article for the`
  line `purpose of being returned to him on his leaving India ^1[and if for any reason, the passenger is not able to`
  line `collect the article at the time of his leaving India, the article may be returned to him through any other`
  line `passenger authorised by him and leaving India or as cargo consigned in his name].`
obj_root_law_sections_81:
  sectionId (30976)
  sectionNo (81)
  orderNo 141
  title `Regulations in respect of baggage.`
  content obj_root_law_sections_81_content
  footnotes obj_root_law_sections_81_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00042_196252_1534829466423&sectionId=30976&sectionno=81&orderno=141&orgactid=AC_CEN_2_2_00042_196252_1534829466423
obj_root_law_sections_81_content:
  string
  line `The Board may make regulations,--`
  line
  line `(a) providing for the manner of declaring the contents of any baggage;`
  line
  line `(b) providing for the custody, examination, assessment to duty and clearance of baggage;`
  line
  line `(c) providing for the transit or transhipment of baggage from one customs station to another or to`
  line `a place outside India.`
obj_root_law_sections_81_footnotes:
  string
  line
