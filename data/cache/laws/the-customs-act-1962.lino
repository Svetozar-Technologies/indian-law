obj_root_law_sections_75_a:
  sectionId (24940)
  sectionNo 75A
  orderNo 120
  title `Interest on drawback.`
  content obj_root_law_sections_75_a_content
  footnotes obj_root_law_sections_75_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00042_196252_1534829466423&sectionId=24940&sectionno=75A&orderno=120&orgactid=AC_CEN_2_2_00042_196252_1534829466423
obj_root_law_sections_75_a_content:
  string
  line `^1[75A. Interest on drawback.--(1) Where any drawback payable to a claimant under section 74 or`
  line `section 75 is not paid within a ^2[period of ^3[one month]] from the date of filing a claim for payment of`
  line `such drawback, there shall be paid to that claimant in addition to the amount of drawback, interest at the`
  line `rate fixed under section 27A from the date after the expiry of the said ^2[period of ^3[one month]] till the`
  line `date of payment of such drawback:`
  line
  line `^4* * * * *`
  line
  line `^5[(2) Where any drawback has been paid to the claimant erroneously or it becomes otherwise`
  line `recoverable under this Act or the rules made thereunder, the claimant shall, within a period of two months`
  line `from the date of demand, pay in addition to the said amount of drawback, interest at the rate fixed`
  line `under ^6[section 28AA] and the amount of interest shall be calculated for the period beginning from the`
  line `date of payment of such drawback to the claimant till the date of recovery of such drawback.]`
obj_root_law_sections_75_a_footnotes:
  string
  line `1. Ins. by s. 62, ibid. (w.e.f. 26-5-1995).`
  line
  line `2. Subs. by Act 8 of 1999, s. 2, for "period of three months" (w.e.f. 8-1-1999).`
  line
  line `3. Subs. by Act 32 of 2003, s. 115, for "two months" (w.e.f. 14-5-2003).`
  line
  line `4. The proviso omitted by s. 115, ibid. (w.e.f. 14-5-2003).`
  line
  line `5. Subs. by Act 22 of 2007, s. 98, for sub-section (2) (w.e.f. 11-5-2007).`
  line
  line `6. Subs. by Act 23 of 2012, s. 125, for "section 28AB" (w.e.f. 8-4-2011).`
obj_root_law_sections_76:
  sectionId (30956)
  sectionNo (76)
  orderNo 121
  title `Prohibition and regulation of drawback in certain cases.`
  content obj_root_law_sections_76_content
  footnotes obj_root_law_sections_76_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00042_196252_1534829466423&sectionId=30956&sectionno=76&orderno=121&orgactid=AC_CEN_2_2_00042_196252_1534829466423
obj_root_law_sections_76_content:
  string
  line `(1) Notwithstanding`
  line `anything hereinbefore contained, no drawback shall be allowed--`
  line
  line `^1* * * * *`
  line
  line `(b) in respect of any goods the market-price of which is less than the amount of drawback due`
  line thereon;
  line
  line `(c) where the drawback due in respect of any goods is less than ^2[fifty rupees].`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), if the Central Government is of opinion`
  line `that goods of any specified description in respect of which drawback may be claimed under this Chapter`
  line `are likely to be smuggled back into India, it may, by notification in the Official Gazette, direct that`
  line `drawback shall not be allowed in respect of such goods or may be allowed subject to such restrictions and`
  line `conditions as may be specified in the notification.`
  line
  line ^3*****
obj_root_law_sections_76_footnotes:
  string
  line `1. Clause (a) omitted by Act 11 of 1983, s. 53 (w.e.f. 13-5-1983).`
  line
  line `2. Subs. by s. 53, ibid., for five rupees (w.e.f. 13-5-1983).`
  line
  line `3. Chapter XA (containing sections 76A to 76N) omitted by Act 22 of 2007, s. 99 (w.e.f. 11-5-2007). Earlier Chapter XA`
  line `inserted by vide Notification No. 43/2003-Cus. (N.T.) (w.e.f. 11-5-2004) dated 22-7-2003 read with notification No. 62/2003-`
  line `Cus (N.T.), dated 14-8-2003; No. 84/2003-Cus. (N.T.), dated 14-10-2003; No. 105/2003-Cus. (N.T.), dated 29-11-2003 and No.`
  line `116/2003-Cus. (N.T.), dated 31-12-2003; No. 25/2004-Cus. (N.T.), dated 28-2-2004; No. 46/2004-Cus. (N.T.), dated 31-3-2004`
  line `and No. 57/2004-Cus. (N.T.), dated 30-4-2004) by s. 126 of the Finance Act, 2002 (20 of 2002).`
