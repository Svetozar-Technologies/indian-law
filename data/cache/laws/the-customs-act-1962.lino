  object
  (str sectionId) (str 30968)
  (str sectionNo) (str 76L)
  (str orderNo) (int 133)
  (str title) (str Omitted..)
  (str content) (str `[Transfer of ownership.] Omitted by s. 99, ibid. (w.e.f. 11-5-2007).`)
