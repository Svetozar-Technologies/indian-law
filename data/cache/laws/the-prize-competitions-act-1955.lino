  object
  (str hi) obj_root_law_translations_hi
obj_root_law_translations_hi:
  object
  (str title) (str `पुरस्‍कार प्रतियोगिता अधिनियम, 1955`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1515/3/H1955-42.pdf`)
  (str sourceKind) (str pdf)
