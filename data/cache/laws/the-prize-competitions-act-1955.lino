obj_root_law_sections_1:
  sectionId (32508)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32508&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Prize Competitions`
  line `Act, 1955.`
  line
  line `(2) It extends to ^1[the territories which, immediately before the 1st November, 1956, were`
  line `comprised in] the States of Andhra, Bombay, Madras, Orissa, Uttar Pradesh, Hyderabad, Madhya`
  line `Bharat, Patiala and East Punjab States Union and Saurashtra and all Part C States.`
  line
  line `(3) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Ins. by A. O. (No. 3), 1956.`
  line
  line `2. 1st April, 1956, vide Notification No. S.R.O. 766, dated 31st March, 1956, Gazette of India, Extraordinary, Part II,`
  line `sec. 3.`
obj_root_law_sections_2:
  sectionId (32509)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32509&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "licensing authority" means any officer or authority appointed by the State Government,`
  line `by notification in the Official Gazette, for the purpose of granting licences under this Act;`
  line
  line `(b) "money" includes a cheque, postal-order or money-order;`
  line
  line `(c) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(d) "prize competition" means any competition (whether called a cross-word prize`
  line `competition, a missing-word prize competition, a picture prize competition or by any other name)`
  line `in which prizes are offered for the solution of any puzzle based upon the building up,`
  line `arrangement, combination or permutation, of letters, words, or figures.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (32510)
  sectionNo (3)
  orderNo 3
  title Interpretation.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32510&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_3_content:
  string
  line `For the purposes of this Act,--`
  line
  line `(a) references to printing shall be construed as including references to writing and other`
  line `modes of representing or re-producing letters, words or figures in a visible form; and`
  line
  line `(b) documents or other matters shall be deemed to be distributed if they are distributed to`
  line `persons or places within or outside the territories to which this Act extends and the word`
  line `distribution' shall be construed accordingly.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (32511)
  sectionNo (4)
  orderNo 4
  title `Prohibition of prize competitions where the prize offered exceeds one thousand rupees a month.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32511&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_4_content:
  string
  line `No person shall promote or conduct any prize competition or competitions in which the`
  line `total value of the prize or prizes (whether in cash or otherwise) to be offered in any month exceeds`
  line `one thousand rupees; and in every prize competition, the number of entries shall not exceed two`
  line thousand.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (32512)
  sectionNo (5)
  orderNo 5
  title `Licensing of prize competitions where the prize offered does not exceed one thousand rupees a month.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32512&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_5_content:
  string
  line `Subject to the provisions of section 4, no person shall promote or conduct any`
  line `prize competition or competitions in which the total value of the prize or prizes (whether in cash or`
  line `otherwise) to be offered in any month does not exceed one thousand rupees unless he has obtained in`
  line `this behalf a licence granted in accordance with the provisions of this Act and the rules made`
  line thereunder.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (32513)
  sectionNo (6)
  orderNo 6
  title `Licences for prize competitions.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32513&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_6_content:
  string
  line `(1) Every person desiring to obtain a licence referred to in`
  line `section 5 shall make an application in writing to the licensing authority in such form and manner as`
  line `may be prescribed.`
  line
  line `(2) On the receipt of such application, the licensing authority, after making such inquiry as it`
  line `considers necessary, shall, by order in writing, either grant the licence or refuse to grant the licence.`
  line
  line `(3) Where the licensing authority refuses to grant a licence it shall record a brief statement of the`
  line `reasons for such refusal and furnish a copy thereof to the applicant.`
  line
  line `(4) The fees on payment of which, the period for which, the conditions subject to which, and the`
  line `form in which, a licence may be granted shall be such as may be prescribed.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (32514)
  sectionNo (7)
  orderNo 7
  title `Promoters of prize competitions to keep accounts and submit the same to the licensing authority.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32514&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_7_content:
  string
  line `Every person who promotes or conducts a prize competition in accordance with the`
  line `provisions of this Act and the rules made thereunder shall keep accounts relating to such competition`
  line `and submit to the licensing authority a statement of accounts in such form and at such intervals as`
  line `may be prescribed.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (32515)
  sectionNo (8)
  orderNo 8
  title `Power to cancel or suspend licences.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32515&sectionno=8&orderno=8&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_8_content:
  string
  line `(1) The licensing authority may, after giving the`
  line `holder of any licence under this Act a reasonable opportunity of being heard, cancel or suspend the`
  line `licence on any one or more of the following grounds, namely:--`
  line
  line `(a) that there has been a breach of any of the conditions subject to which the licence was`
  line granted;
  line
  line `(b) that the holder of the licence has contravened any of the provisions of section 7.`
  line
  line `(2) Whenever a licence is cancelled or suspended the licensing authority shall record a brief`
  line `statement of the reasons for such cancellation or suspension and furnish a copy thereof to the person`
  line `whose licence has been cancelled or suspended.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (32516)
  sectionNo (9)
  orderNo 9
  title `Penalty for promoting or conducting any prize competition in contravention of the provisions of sections 4 and 5.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32516&sectionno=9&orderno=9&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_9_content:
  string
  line `If any person promotes or conducts any prize competition in`
  line `contravention of the provisions of section 4 or section 5, he shall be punishable with imprisonment for`
  line `a term which may extend to three months, or with fine which may extend to one thousand rupees, or`
  line `with both.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (32517)
  sectionNo (10)
  orderNo 10
  title `Penalty for failure to keep and submit accounts.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32517&sectionno=10&orderno=10&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_10_content:
  string
  line `If any person liable under section 7 to`
  line `keep accounts or to submit statements of accounts fails to keep accounts or to submit statements of`
  line `accounts as required by that section or keeps accounts or submits statements of accounts which are`
  line `false and which he either knows or believes to be false or does not believe to be true, he shall be`
  line `punishable with imprisonment for a term which may extend to one month, or with fine which may`
  line `extend to five hundred rupees, or with both, but nothing contained in this section shall affect the`
  line `provisions contained in section 8.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (32518)
  sectionNo (11)
  orderNo 11
  title `Penalty for other offences in connection with prize competitions.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32518&sectionno=11&orderno=11&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_11_content:
  string
  line `If any person with a`
  line `view to the promotion or conduct of any prize competition except in accordance with the provisions`
  line `of a licence under this Act or in contravention of the provisions of this Act or in connection with any`
  line `prize competition promoted or conducted except in accordance with such provisions--`
  line
  line `(a) prints or publishes any ticket, coupon or other document for use in the prize competition;`
  line or
  line
  line `(b) sells or distributes or offers or advertises for sale or distribution, or has in his possession`
  line `for the purpose of sale or distribution any ticket, coupon or other document for use in the prize`
  line `competition; or`
  line
  line `(c) prints, publishes or distributes, or has in his possession for the purpose of publication or`
  line distribution,
  line
  line `(i) any advertisement of the prize competition, or`
  line
  line `(ii) any list (whether complete or not) of prize winners in the prize competition, or`
  line
  line `(iii) any such matter descriptive of, or otherwise relating to, the prize competition as is`
  line `calculated to act as an inducement to persons to participate in that prize competition or any`
  line `other prize competition ; or`
  line
  line `(d) brings, or invites any person to send, into the territories to which this Act extends, for the`
  line `purpose of sale or distribution, any ticket, coupon or other document for use in, or any`
  line `advertisement of, the prize competition ; or`
  line
  line `(e) sends, or attempts to send, out of the territories to which this Act extends any money or`
  line `valuable thing received in respect of the sale or distribution of any ticket, coupon or other`
  line `document for use in the prize competition ; or`
  line
  line `(f) uses any premises, or causes or knowingly permits any premises to be used, for purposes`
  line `connected with the promotion or conduct of the prize competition ; or`
  line
  line `(g) causes or procures or attempts to procure any person to do any of the above-mentioned`
  line acts,
  line
  line `he shall be punishable with imprisonment for a term which may extend to three months, or with fine`
  line `which may extend to five hundred rupees, or with both.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (32519)
  sectionNo (12)
  orderNo 12
  title `Offences by Corporations.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32519&sectionno=12&orderno=12&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_12_content:
  string
  line `(1) If any person guilty of an offence under this, Act is a`
  line `company, every person who at the time the offence was committed was in charge of, and was`
  line `responsible to, the company, as well as the company, shall be deemed to be guilty of that offence and`
  line `shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act if he proves that the offence was committed without his knowledge`
  line `or that he exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has`
  line `been committed with the consent or connivance of, or is attributable to gross neglect on the part of,`
  line `any director, manager, secretary or other officer of the company, such director, manager, secretary or`
  line `other officer shall also be deemed to be guilty of that offence and shall be liable to be proceeded`
  line `against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means a body corporate and includes a firm or other association of`
  line `individuals ; and`
  line
  line `(b) "director" in relation to a firm means a partner in the firm.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (32520)
  sectionNo (13)
  orderNo 13
  title `Power of licensing authority to call for and inspect accounts and documents.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32520&sectionno=13&orderno=13&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_13_content:
  string
  line The
  line `licensing authority may--`
  line
  line `(a) require any person promoting or conducting a prize competition to produce before it the`
  line `accounts and other documents kept by such person or to furnish to it such other information`
  line `relating to the prize competition as it may require;`
  line
  line `(b) inspect at all reasonable times the accounts and other documents kept by such person.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (32521)
  sectionNo (14)
  orderNo 14
  title `Power of entry and search.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32521&sectionno=14&orderno=14&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_14_content:
  string
  line `(1) It shall be lawful for any police-officer not below the rank`
  line `of Sub-inspector authorised by the State Government in this behalf by general or special order in`
  line writing,--
  line
  line `(a) to enter if necessary by force, whether by day or night, with such assistants as he`
  line `considers necessary, any premises which he has reason to suspect, are being used for purposes`
  line `connected with the promotion or conduct of any prize competition in contravention of the`
  line `provisions of this Act;`
  line
  line `(b) to search the premises and the persons whom he may find herein;`
  line
  line `(c) to take into custody and produce before a Magistrate all such persons as are concerned or`
  line `against whom a reasonable complaint has been made or credible information has been received or`
  line `a reasonable suspicion exists of their having been concerned with the user of such premises for`
  line `purposes connected with, or with the promotion or conduct of, any prize competition in`
  line `contravention of the provisions of this Act; and`
  line
  line `(d) to seize all things found therein which are intended to be used or reasonably suspected to`
  line `have been used in connection with such prize competition.`
  line
  line `(2) All searches under this section shall be made in accordance with the provisions of the Code of`
  line `Criminal Procedure, 1898 (5 of 1898).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (32522)
  sectionNo (15)
  orderNo 15
  title `Forfeiture newspapers and publications containing prize competitions.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32522&sectionno=15&orderno=15&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_15_content:
  string
  line `Where any`
  line `newspaper or other publication contains any prize competition promoted or conducted in`
  line `contravention of the provisions of this Act or except in accordance with the provisions of licence`
  line `under this Act or any advertisement in relation thereto, the State Government may, by notification in`
  line `the Official Gazette, declare every copy of the newspaper and every copy of the publication`
  line `containing the prize competition or the advertisement, to be forfeited to Government.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (32523)
  sectionNo (16)
  orderNo 16
  title Appeals.
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32523&sectionno=16&orderno=16&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_16_content:
  string
  line `Any person aggrieved by the decision of the licensing authority refusing to grant a`
  line `licence or cancelling or suspending a licence may, within such time as may be prescribed, prefer an`
  line `appeal to the State Government and the decision of the State Government on such appeal shall be`
  line final.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (32524)
  sectionNo (17)
  orderNo 17
  title `Licensing authority and other officers to be public servants.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32524&sectionno=17&orderno=17&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_17_content:
  string
  line `The licensing authority and`
  line `any other officer acting under this Act shall be deemed to be public servants within the meaning of`
  line `section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (32525)
  sectionNo (18)
  orderNo 18
  title `Jurisdiction to try offences.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32525&sectionno=18&orderno=18&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_18_content:
  string
  line `No Court inferior to that of a Presidency Magistrate or a`
  line `Magistrate of the first class shall try any offence under this Act.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (32526)
  sectionNo (19)
  orderNo 19
  title `Protection of action taken under this act.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32526&sectionno=19&orderno=19&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_19_content:
  string
  line `No suit, prosecution or other legal proceeding`
  line `shall lie against the licensing authority or any other officer of the Government for anything which is in`
  line `good faith done or intended to be done under this Act or the rules made thereunder.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (32527)
  sectionNo (20)
  orderNo 20
  title `Power to make rules.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00011_195542_1517807319341&sectionId=32527&sectionno=20&orderno=20&orgactid=AC_CEN_2_11_00011_195542_1517807319341
obj_root_law_sections_20_content:
  string
  line `(1) The State Government may, by notification in the Official`
  line `Gazette, and subject to the condition of previous publication, make rules for carrying out the purposes`
  line `of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the form and manner of application for a licence and the fees, if any, for such licence;`
  line
  line `(b) the period for which, the conditions subject to which and the form in which, a licence may`
  line `be granted;`
  line
  line `(c) the form in which and the intervals at which statements of accounts shall be submitted to`
  line `the licensing authority;`
  line
  line `(d) the time within which an appeal against a decision of the licensing authority may be`
  line `preferred to the State Government;`
  line
  line `(e) any other matter which is to be or may be prescribed.`
obj_root_law_sections_20_footnotes:
  string
  line
