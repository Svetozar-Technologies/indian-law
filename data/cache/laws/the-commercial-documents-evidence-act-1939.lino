obj_root_law_sections_1:
  sectionId (29804)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes `1. Subs. by the A.O. (No. 3) 1956, for "Part B States".`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00065_193930_1523352708381&sectionId=29804&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00065_193930_1523352708381
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Commercial Documents Evidence`
  line `Act, 1939.`
  line
  line `(2) It extends to the whole of India except ^1[the territories which, immediately before the1st November, 1956, were comprised in Part B States].`
  line
  line `STATE AMENDMENT`
  line
  line Karnataka
  line
  line `Amendment of Central Act XXX of 1939.--In sub-section (2) of section 1 of the Commercial`
  line `Documents Evidence Act, 1939 (Central Act XXX of 1939), after the words and letter “in Part B States”`
  line `the words, brackets, figures and letters “other than the territories specified in clause (a) and clause (c) of`
  line `sub-section (1) of section 7 of the [States Re-organisation Act, 1956 (Central Act XXXVII of 1956)”]`
  line `shall be added.`
  line
  line `[Vide Karnataka Act 33 of 1978, s. 7].`
obj_root_law_sections_2:
  sectionId (29805)
  sectionNo (2)
  orderNo 2
  title `Statements of relevant facts in scheduled documents to be themselves relevant facts.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00065_193930_1523352708381&sectionId=29805&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00065_193930_1523352708381
obj_root_law_sections_2_content:
  string
  line `Notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872), statements`
  line `of facts in issue or of relevant fact made in any document included in the Schedule as to matters usually`
  line `stated in such document shall be themselves relevant facts within the meaning of that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (29806)
  sectionNo (3)
  orderNo 3
  title `Presumption as to genuineness of documents.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00065_193930_1523352708381&sectionId=29806&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00065_193930_1523352708381
obj_root_law_sections_3_content:
  string
  line `For the purposes of the Indian`
  line `Evidence Act, 1872 (1 of 1872), and notwithstanding anything contained therein, a Court--`
  line
  line `(a) shall presume, within the meaning of that Act, in relation to documents included in`
  line `Part I of the Schedule, and`
  line
  line `(b) may presume, within the meaning of that Act, in relation to documents included in`
  line `Part II of the Schedule,--`
  line
  line `that any document purporting to be a document included in Part I or Part II of the Schedule, as`
  line `the case may be, and to have been duly made by or under the appropriate authority, was so made`
  line `and that the statements contained therein are accurate.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (29807)
  sectionNo (4)
  orderNo 4
  title Definition.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00065_193930_1523352708381&sectionId=29807&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00065_193930_1523352708381
obj_root_law_sections_4_content:
  string
  line `In the Schedule the expression "recognised Chamber of Commerce" means a`
  line `Chamber of Commerce recognised by the Government of its country as being competent to issue certificates of origin, and includes any other association similarly recognised.`
obj_root_law_sections_4_footnotes:
  string
  line
