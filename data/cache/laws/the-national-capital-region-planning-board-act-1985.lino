obj_root_law_sections_1:
  sectionId (8575)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8575&sectionno=1&orderno=1&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Capital Region`
  line `Planning Board Act, 1985.`
  line
  line `(2) It shall be deemed to have come into force on the 19th day of October, 1984.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (8576)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8576&sectionno=2&orderno=2&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,`
  line
  line `(a) "Board" means the National Capital Region Planning Board constituted under sub-section (1)`
  line `of section 3;`
  line
  line `(b) "Committee" means the Planning Committee constituted under sub-section (1) of section 4;`
  line
  line `(c) "counter-magnet area" means an urban area selected by the Board under clause (f) of`
  line `section 8;`
  line
  line `(d) "Functional Plan" means a plan prepared to elaborate one or more elements of the Regional`
  line Plan;
  line
  line `(e) "land" includes benefits to arise out of land, and things attached to the earth or permanently`
  line `fastened to anything attached to the earth;`
  line
  line `(f) "National Capital Region" means the areas specified in the Schedule:`
  line
  line `Provided that the Central Government with the consent of the Government of the concerned`
  line `participating State and in consultation with the Board, may, by notification in the Official Gazette,`
  line `add any area to the Schedule or exclude any area therefrom;`
  line
  line `(g) "participating States" means the States of Haryana, Rajasthan and Uttar Pradesh;`
  line
  line `(h) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(i) "Project Plan" means a detailed plan prepared to implement one or more elements of the`
  line `Regional Plan, Sub-Regional Plan or Functional Plan;`
  line
  line `(j) "Regional Plan" means the plan prepared under this Act for the development of the National`
  line `Capital Region and for the control of land-uses and the development of infrastructure in the National`
  line `Capital Region;`
  line
  line `(k) "regulations" means regulations made by the Board under this Act;`
  line
  line `(l) "sub-region" means such part of the National Capital Region as falls entirely within the limits`
  line `of a participating State or the Union territory;`
  line
  line `(m) "Sub-Regional Plan" means a plan prepared for a sub-region; and`
  line
  line `(n) "Union territory" means the Union territory of Delhi.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (8577)
  sectionNo (3)
  orderNo 3
  title `Constitution and incorporation of the Board.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8577&sectionno=3&orderno=3&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_3_content:
  string
  line `(1) The Central Government shall, by`
  line `notification in the Official Gazette, constitute for the purposes of this Act, a Board, to be called the`
  line `National Capital Region Planning Board.`
  line
  line `(2) The Board shall be a body corporate by the name aforesaid, having perpetual succession and a`
  line `common seal with power, subject to the provisions of this Act, to contract and shall, by the said name, sue`
  line `and be sued.`
  line
  line `(3) The Board shall consist of such number of members, not exceeding twenty-one, as may be`
  line `prescribed, and unless the rules made in this behalf otherwise provide, the Board shall consist of the`
  line `following members, namely:--`
  line
  line `(a) the Union Minister for Works and Housing, who shall be the Chairman of the Board;`
  line
  line `(b) the Chief Minister of the State of Haryana;`
  line
  line `(c) the Chief Minister of the State of Rajasthan;`
  line
  line `(d) the Chief Minister of the State of Uttar Pradesh;`
  line
  line `(e) the Administrator of the Union territory;`
  line
  line `(f) eight members, to be nominated by the Central Government, on the recommendation of the`
  line `participating States and the Administrator of the Union territory:`
  line
  line `Provided that not more than two members shall be nominated on the recommendation of a`
  line `participating State, or, as the case may be, the Administrator of the Union territory;`
  line
  line `(g) three other members, of whom one shall be a person having knowledge and experience in`
  line `town planning, to be nominated by the Central Government;`
  line
  line `(h) a full-time Member-Secretary of the Board, to be nominated by the Central Government from`
  line `amongst officers of, or above, the rank of a Joint Secretary to the Government of India:`
  line
  line `Provided that no change shall be made in the composition of the Board by rules except with the`
  line `consent of the Government of each of the participating States and of the Administrator of the Union`
  line territory.
  line
  line `(4) The terms and conditions of office of the members nominated under clause (f), clause (g) or`
  line `clause (h) of sub-section (3) shall be such as may be prescribed.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (8578)
  sectionNo (4)
  orderNo 4
  title `Composition of the Planning Committee.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8578&sectionno=4&orderno=4&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_4_content:
  string
  line `(1) The Board shall, as soon as may be, after the`
  line `commencement of this Act, constitute a Committee, to be called the Planning Committee, for assisting the`
  line `Board in the discharge of its functions.`
  line
  line `(2) The Committee shall consist of such members as may be prescribed and unless the rules made in`
  line `this behalf otherwise provide, the Committee shall consist of the following members, namely:--`
  line
  line `(a) the Member-Secretary to the Board, who shall be the ex officio Chairman of the Committee;`
  line
  line `(b) the Joint Secretary to the Government of India in the Ministry of Works and Housing,`
  line `in-charge of Housing and Urban Development, ex officio;`
  line
  line `(c) Secretary-in-charge of Urban Development in each participating State and the Union territory,`
  line `ex officio;`
  line
  line `(d) the Vice-Chairman, Delhi Development Authority, ex officio;`
  line
  line `(e) the Chief Planner, Town and Country Planning Organisation, New Delhi, ex officio; and`
  line
  line `(f) the Chief Town Planner of each participating State, ex officio.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (8579)
  sectionNo (5)
  orderNo 5
  title `Power to co-opt, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8579&sectionno=5&orderno=5&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_5_content:
  string
  line `(1) The Board or the Committee may, at any time and for such period as it`
  line `thinks fit, co-opt any person or persons as a member or members of the Board or of the Committee.`
  line
  line `(2) A person co-opted under sub-section (1) shall exercise and discharge all the powers and functions`
  line `of a member of the Board or of the Committee, as the case may be, but shall not be entitled to vote.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (8580)
  sectionNo (6)
  orderNo 6
  title `Vacancies, etc., not to invalidate proceedings of the Board or the Committee.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8580&sectionno=6&orderno=6&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_6_content:
  string
  line `No act or`
  line `proceeding of the Board of the Committee shall be invalid merely by reason of--`
  line
  line `(a) the existence of any vacancy in, or any defect in the constitution of, the Board or the`
  line `Committee; or`
  line
  line `(b) any irregularity in the procedure of the Board or of the Committee not affecting the merits of`
  line `the case.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (8581)
  sectionNo (7)
  orderNo 7
  title `Functions of the Board.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8581&sectionno=7&orderno=7&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_7_content:
  string
  line `The functions of the Board shall be--`
  line
  line `(a) to prepare the Regional Plan and the Functional Plans;`
  line
  line `(b) to arrange for the preparation of Sub-Regional Plans and Project Plans by each of the`
  line `participating States and the Union territory;`
  line
  line `(c) to co-ordinate the enforcement and implementation of the Regional Plan, Functional Plans,`
  line `Sub-Regional Plans and Project Plans through the participating States and the Union territory;`
  line
  line `(d) to ensure proper and systematic programming by the participating States and the Union`
  line `territory in regard to project formulation, determination of priorities in the National Capital Region or`
  line `sub-regions and phasing of development of the National Capital Region in accordance with stages`
  line `indicated in the Regional Plan;`
  line
  line `(e) to arrange for, and oversee, the financing of selected development projects in the National`
  line `Capital Region through Central and State plan funds and other sources of revenue.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (8582)
  sectionNo (8)
  orderNo 8
  title `Powers of the Board.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8582&sectionno=8&orderno=8&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_8_content:
  string
  line `The powers of the Board shall include the powers to--`
  line
  line `(a) call for reports and information from the participating States and the Union territory with`
  line `regard to preparation, enforcement and implementation of Functional Plans and Sub-Regional Plans;`
  line
  line `(b) ensure that the preparation, enforcement and implementation of Functional Plan or`
  line `Sub-Regional Plan, as the case may be, is in conformity with the Regional Plan;`
  line
  line `(c) indicate the stages for the implementation of the Regional Plan;`
  line
  line `(d) review the implementation of the Regional Plan, Functional Plan, Sub-Regional Plan and`
  line `Project Plan;`
  line
  line `(e) select and approve comprehensive projects, call for priority development and provide such`
  line `assistance for the implementation of those projects as the Board may deem fit;`
  line
  line `(f) select, in consultation with the State Government concerned, any urban area, outside the`
  line `National Capital Region having regard to its location, population and potential for growth, which may`
  line `be developed in order to achieve the objectives of the Regional Plan; and`
  line
  line `(g) entrust to the Committee such other functions as it may consider necessary to carry out the`
  line `provisions of this Act.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (8583)
  sectionNo (9)
  orderNo 9
  title `Functions of the Committee.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8583&sectionno=9&orderno=9&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_9_content:
  string
  line `(1) The functions of the Committee shall be to assist the Board`
  line in--
  line
  line `(a) the preparation and co-ordinated implementation of the Regional Plan and the Functional`
  line `Plans; and`
  line
  line `(b) scrutinising the Sub-Regional Plans and all Project Plans to ensure that the same are in`
  line `conformity with the Regional Plan.`
  line
  line `(2) The Committee may also make such recommendation to the Board as it may think necessary to`
  line `amend or modify any Sub-Regional Plan or any Project Plan.`
  line
  line `(3) The Committee shall perform such other functions as may be entrusted to it by the Board.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (8584)
  sectionNo (10)
  orderNo 10
  title `Contents of the Regional Plan.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8584&sectionno=10&orderno=10&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_10_content:
  string
  line `(1) The Regional Plan shall be a written statement and shall be`
  line `accompanied by such maps, diagrams, illustrations and descriptive matters, as the Board may deem`
  line `appropriate for the purpose of explaining or illustrating the proposals contained in the Regional Plan and`
  line `every such map, diagram, illustration and descriptive matter shall be deemed to be a part of the Regional`
  line Plan.
  line
  line `(2) The Regional Plan shall indicate the manner in which the land in the National Capital Region shall`
  line `be used, whether by carrying out development thereon or by conservation or otherwise, and such other`
  line `matters as arc likely to have any important influence on the development of the National Capital Region`
  line `and every such Plan shall include the following elements needed to promote growth and balanced`
  line `development of the National Capital Region, namely:--`
  line
  line `(a) the policy in relation to land-use and the allocation of land for different uses;`
  line
  line `(b) the proposals for major urban settlement pattern;`
  line
  line `(c) the proposals for providing suitable economic base for future growth;`
  line
  line `(d) the proposals regarding transport and communications including railways and arterial roads`
  line `serving the National Capital Region;`
  line
  line `(e) the proposals for the supply of drinking water and for drainage;`
  line
  line `(f) indication of the areas which require immediate development as "priority areas"; and`
  line
  line `(g) such other matters as may be included by the Board with the concurrence of the participating`
  line `States and the Union territory for the proper planning of the growth and balanced development of the`
  line `National Capital Region.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (8585)
  sectionNo (11)
  orderNo 11
  title `Surveys and studies.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8585&sectionno=11&orderno=11&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_11_content:
  string
  line `For the preparation of the Regional Plan, the Board may cause such`
  line `surveys and studies, as it may consider necessary, to be made by such person or group of persons as it`
  line `may appoint in this behalf and may also associate such experts or consultants for carrying out studies in`
  line `relation to such specified matters as may be determined by the Board.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (8586)
  sectionNo (12)
  orderNo 12
  title `Procedure to be followed for the preparation of Regional Plan.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8586&sectionno=12&orderno=12&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_12_content:
  string
  line `(1) Before preparing any`
  line `Regional Plan finally, the Board shall prepare, with the assistance of the Committee, a Regional Plan in`
  line `draft and publish it by making a copy thereof available for inspection and publishing a notice in such form`
  line `and in such manner as may be prescribed, inviting objections and suggestions from any person with`
  line `respect to the draft Regional Plan before such date as may be specified in the notice.`
  line
  line `(2) The Board shall also give reasonable opportunities to every local authority, within whose local`
  line `limits any land touched by the Regional Plan is situate, to make any representation with respect to the`
  line `draft Regional Plan.`
  line
  line `(3) After considering all objections, suggestions and representations that may have been received by`
  line `the Board, the Board shall finally prepare the Regional Plan.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (8587)
  sectionNo (13)
  orderNo 13
  title `Date of coming into operation of the Regional Plan.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8587&sectionno=13&orderno=13&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_13_content:
  string
  line `(1) Immediately after the Regional Plan`
  line `has been finally prepared, the Board shall publish, in such manner as may be prescribed, a notice stating`
  line `that the Regional Plan has been finally prepared by it and naming the places where a copy of the Regional`
  line `Plan may be inspected at all reasonable hours and upon the date of first publication of the aforesaid`
  line `notice, the Regional Plan shall come into operation.`
  line
  line `(2) The publication of the Regional Plan, after previous publication, as required by section 12, shall`
  line `be conclusive proof that the Regional Plan has been duly prepared.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (8588)
  sectionNo (14)
  orderNo 14
  title `Modifications of the Regional Plan.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8588&sectionno=14&orderno=14&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_14_content:
  string
  line `(1) The Board may, subject to the provisions of`
  line `sub-section (2), make such modifications in the Regional Plan as finally prepared by it, as it may think fit,`
  line `being modifications which, in its opinion, do not effect important alterations in the character of the`
  line `Regional Plan and which do not relate to the extent of land-uses or the standards of population density.`
  line
  line `(2) Before making any modifications in the finally prepared Regional Plan, the Board shall publish a`
  line `notice, in such form and in such manner as may be prescribed, indicating therein the modifications which`
  line `are proposed to be made in the finally prepared Regional Plan, and inviting, objections and suggestions`
  line `from any person with respect to the proposed modifications before such date as may be specified in the`
  line `notice and shall consider all objections and suggestions that may be received by it on or before the date so`
  line specified.
  line
  line `(3) Every modification made under this section shall be published in such manner as the Board may`
  line `specify and the modifications shall come into operation either on the date of such publication or on such`
  line `later date as the Board may fix.`
  line
  line `(4) If any question arises whether the modifications proposed to be made are modifications which`
  line `effect important alterations in the character of the Regional Plan or whether they relate to the extent of`
  line `land-uses or the standards of population density, it shall be decided by the Board whose decision thereon`
  line `shall be final.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (8589)
  sectionNo (15)
  orderNo 15
  title `Review and revision of the Regional Plan.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8589&sectionno=15&orderno=15&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_15_content:
  string
  line `(1) After every five years from the date of coming`
  line `into operation of the finally prepared Regional Plan, the Board shall review such Regional Plan in its`
  line `entirety and may, after such review, substitute it by a fresh Regional Plan or may make such`
  line `modifications or alterations therein as may be found by it to be necessary.`
  line
  line `(2) Where it is proposed to substitute a fresh Regional Plan in place of the Regional Plan which was`
  line `previously finally prepared or where it is proposed to make any modifications or alterations in the finally`
  line `prepared Regional Plan, such fresh Plan or, as the case may be, modifications or alterations, shall be`
  line `published and dealt with in the same manner as if it were the Regional Plan referred to in sections 12`
  line `and 13 or as if they were the modifications or alterations in the Regional Plan made under section 14.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (8590)
  sectionNo (16)
  orderNo 16
  title `Preparation of Functional Plans.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8590&sectionno=16&orderno=16&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_16_content:
  string
  line `After the Regional Plan has come into operation, the Board`
  line `may prepare, with the assistance of the Committee, as many Functional Plans as may be necessary for the`
  line `proper guidance of the participating States and of the Union territory.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (8591)
  sectionNo (17)
  orderNo 17
  title `Preparation of Sub-Regional Plans.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8591&sectionno=17&orderno=17&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_17_content:
  string
  line `(1) Each participating State shall prepare a Sub-Regional`
  line `Plan for the sub-region within the State and the Union territory shall prepare a Sub-Regional Plan for the`
  line `sub-region within the Union territory.`
  line
  line `(2) Each Sub-Regional Plan shall be a written statement and shall be accompanied by such maps,`
  line `diagrams, illustrations and descriptive matters as the participating State or the Union territory may deem`
  line `appropriate for the purpose of explaining or illustrating the proposals contained in such Sub-Regional`
  line `Plan and every such map, document, illustration and descriptive matter shall be deemed to be a part of the`
  line `Sub-Regional Plan.`
  line
  line `(3) A Sub-Regional Plan may indicate the following elements to elaborate the Regional Plan at the`
  line `sub-regional level, namely:--`
  line
  line `(a) reservation of areas for specific land-uses which are of the regional or sub-regional`
  line importance;
  line
  line `(b) future urban and major rural settlements indicating their area, projected population,`
  line `predominant economic functions, approximate site and location;`
  line
  line `(c) road net-work up to the district roads and roads connecting major rural settlements;`
  line
  line `(d) proposals for the co-ordination of traffic and transportation, including terminal facilities;`
  line
  line `(e) priority areas at sub-regional level for which immediate plans are necessary;`
  line
  line `(f) proposals for the supply of drinking water and for drainage; and`
  line
  line `(g) any other matter which is necessary for the proper development of the sub-region.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (8592)
  sectionNo (18)
  orderNo 18
  title `Preparation of Project Plans.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8592&sectionno=18&orderno=18&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_18_content:
  string
  line `A participating State, or the Union territory, may, by itself or in`
  line `collaboration with one or more of the participating States or the Union territory, as the case may be,`
  line `prepare Project Plans for one or more elements of the Regional Plan, Functional Plan or Sub-Regional`
  line Plan.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (8593)
  sectionNo (19)
  orderNo 19
  title `Submission of Sub-Regional Plans to the Board.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8593&sectionno=19&orderno=19&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_19_content:
  string
  line `(1) Before publishing any Sub-Regional`
  line `Plan, each participating State or, as the case may be, the Union territory, shall, refer such Plan to the`
  line `Board to enable the Board to ensure that such Plan is in conformity with the Regional Plan.`
  line
  line `(2) The Board shall, after examining a Sub-Regional Plan, communicate, within sixty days from the`
  line `date of receipt of such Plan, its observations with regard to the Sub-Regional Plan to the participating`
  line `State or the Union territory by which such Plan was referred to it.`
  line
  line `(3) The participating State, or, as the case may be, the Union territory, shall, after due consideration`
  line `of the observations made by the Board, finalise the Sub-Regional Plan after ensuring that it is in`
  line `conformity with the Regional Plan.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (8594)
  sectionNo (20)
  orderNo 20
  title `Implementation of Sub-Regional Plans, etc.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8594&sectionno=20&orderno=20&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_20_content:
  string
  line `Each participating State, or, as the case may be,`
  line `the Union territory shall be responsible for the implementation of the Sub-Regional Plan, as finalised by it`
  line `under sub-section (3) of section 19, and Project Plans prepared by it.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (8595)
  sectionNo (21)
  orderNo 21
  title `Grants and loans by the Central Government.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8595&sectionno=21&orderno=21&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_21_content:
  string
  line `(1) The Central Government may, after due`
  line `appropriation made by Parliament by law in this behalf, make to the Board grants and loans of such sums`
  line `of money as that Government may consider necessary to enable the Board to carry out its functions under`
  line `this Act.`
  line
  line `(2) The Central Government shall also, after due appropriation made by Parliament by law in this`
  line `behalf, pay to the Board such other sums as may be necessary for meeting the salaries, allowances and`
  line `other remuneration of the Member-Secretary, officers and other employees of the Board and such`
  line `amounts as may be necessary to meet the other administrative expenses of the Board.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (8596)
  sectionNo (22)
  orderNo 22
  title `Constitution of the Fund.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8596&sectionno=22&orderno=22&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_22_content:
  string
  line `(1) There shall be constituted a Fund to be called the National`
  line `Capital Regional Planning Board Fund and there shall be credited there to--`
  line
  line `(a) any grants and loans made to the Board by the Central Government under section 21;`
  line
  line `(b) all sums paid to the Board by the participating States and the Union territory; and`
  line
  line `(c) all sums received by the Board from such other sources as may be decided upon by the`
  line `Central Government in consultation with the participating States and the Union territory.`
  line
  line `(2) The sums credited to the said Fund referred to in sub-section (1) shall be applied for--`
  line
  line `(a) meeting the salaries, allowances and other remuneration of the Member-Secretary, officers`
  line `and other employees of the Board and for meeting other administrative expenses of the Board, so,`
  line `however, that the total expenses shall not exceed the amount appropriated for this purpose under`
  line `sub-section (2) of section 21;`
  line
  line `(b) conducting surveys, preliminary studies and drawing up of plans for the National Capital`
  line Region;
  line
  line `(c) providing financial assistance to the participating States and the Union territory for the`
  line `implementation of Sub-Regional Plans and Project Plans; and`
  line
  line `(d) providing financial assistance to the State concerned for the development of the`
  line `counter-magnet area subject to such terms and conditions as may be agreed upon between such State`
  line `and the Board.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (8597)
  sectionNo (23)
  orderNo 23
  title Budget.
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8597&sectionno=23&orderno=23&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_23_content:
  string
  line `The Board shall, in each financial year, prepare in such form and at such time as may`
  line `be prescribed its budget for the next financial year and forward the same to the Central Government at`
  line `least three months prior to the commencement of the next financial year.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (8598)
  sectionNo (24)
  orderNo 24
  title `Annual report.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8598&sectionno=24&orderno=24&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_24_content:
  string
  line `The Board shall prepare in each financial year its annual report in such form`
  line `and at such time as may be prescribed, giving a full account of its activities during the financial year`
  line `immediately preceding the financial year in which such report is prepared and forward, before such date`
  line `as may be prescribed, copies thereof to the Central Government, the participating States and the Union`
  line territory.
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (8599)
  sectionNo (25)
  orderNo 25
  title `Accounts and audit.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8599&sectionno=25&orderno=25&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_25_content:
  string
  line `The accounts of the Board shall be maintained and audited in such manner`
  line `as may be prescribed in consultation with the Comptroller and Auditor-General of India and the Board`
  line `shall furnish, to the Central Government, before such date as may be prescribed, a copy of its audited`
  line `accounts together with the auditors report thereon.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (8600)
  sectionNo (26)
  orderNo 26
  title `Annual report and auditors’ report to be laid before Parliament.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8600&sectionno=26&orderno=26&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_26_content:
  string
  line `The Central Government`
  line `shall cause the annual report and the auditors' report to be laid as soon as may be after their receipt, on the`
  line `Table of each House of Parliament while it is in session, for a total period of thirty days, which may be`
  line `comprised in one session or in two more successive sessions.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (8601)
  sectionNo (27)
  orderNo 27
  title `Act to have overriding effect.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8601&sectionno=27&orderno=27&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_27_content:
  string
  line `The provisions of this Act shall have effect notwithstanding`
  line `anything inconsistent therewith contained in any other law for the time being in force or in any instrument`
  line `having effect by virtue of any law other than this Act; or in any decree or order of any court, tribunal or`
  line `other authority.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (8602)
  sectionNo (28)
  orderNo 28
  title `Power of the Central Government to give directions.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8602&sectionno=28&orderno=28&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_28_content:
  string
  line `The Central Government may, from`
  line `time to time, give such directions to the Board as it may think fit for the efficient administration of this`
  line `Act and when any such direction is given, the Board shall carry out such directions.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (8603)
  sectionNo (29)
  orderNo 29
  title `Violation of Regional Plan.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8603&sectionno=29&orderno=29&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_29_content:
  string
  line `(1) On and from the coming into operation of the finally published`
  line `Regional Plan, no development shall be made in the region which is inconsistent with the Regional Plan`
  line `as finally published.`
  line
  line `(2) Where the Board is satisfied that any participating State or the Union territory has carried out, or`
  line `is carrying out, any activity which amounts to a violation of the Regional Plan, it may, by a notice in`
  line `writing, direct the concerned participating State or the Union territory, as the case may be, to stop such`
  line `violation of the Regional Plan within such time as may be specified in the said notice and in case of any omission or refusal on the part of the concerned participating State or the Union territory to stop activity,`
  line `withhold such financial assistance to the concerned participating State or the Union territory, as the Board`
  line `may consider necessary.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (8604)
  sectionNo (30)
  orderNo 30
  title `Technical assistance to the Board.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8604&sectionno=30&orderno=30&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_30_content:
  string
  line `(1) The Central Government may direct its Town and`
  line `Country Planning Organisation to provide, on such terms and conditions as may be mutually agreed upon,`
  line `such technical assistance to the Board as that Government may consider necessary and the Government of`
  line `a participating State may direct the Town Planning Department of that Government to make such`
  line `technical assistance to the Board as that Government may consider necessary.`
  line
  line `(2) With a view to enabling the Committee to discharge its functions, the Board shall, out of the`
  line `technical assistance received by it under sub-section (1) make available to the Committee such technical`
  line `assistance as the Committee may require.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (8605)
  sectionNo (31)
  orderNo 31
  title `Officers and employees of the Board.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8605&sectionno=31&orderno=31&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_31_content:
  string
  line `(1) The Board may appoint such other officers and`
  line `employees as it considers necessary for the efficient discharge of its functions under this Act.`
  line
  line `(2) The terms and conditions of the officers and employees of the Board shall be such as may be`
  line `determined by regulations.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (8606)
  sectionNo (32)
  orderNo 32
  title `Power to delegate.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8606&sectionno=32&orderno=32&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_32_content:
  string
  line `The Board may, by notification in the Official Gazette, direct that any`
  line `function or power (other than the power to approve the Regional Plan and to make regulations), or duty`
  line `which the Board may perform, exercise or discharge under this Act shall subject to such conditions, if`
  line `any, as may be specified in the notification, be performed, exercised or discharged also by such person or`
  line `persons as may be specified in the notification and where any such delegation of power is made the`
  line `person or persons to whom such power is delegated shall perform, exercise or discharge those powers in`
  line `the same manner and to the same extent as if they were conferred on him or them directly by this Act and`
  line `not by way of delegation.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (8607)
  sectionNo (33)
  orderNo 33
  title `Power of entry.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8607&sectionno=33&orderno=33&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_33_content:
  string
  line `Subject to any rules made in this behalf, any person generally or specially`
  line `authorised by the Board in this behalf, may, at all reasonable times, enter upon any land or premises and`
  line `do such things thereon as may be necessary for the purpose of lawfully carrying out any works or for`
  line `making any survey, examination or investigation, preliminary or incidental to the exercise of any power`
  line `or performance of any function by the Board under this Act:`
  line
  line `Provided that no such person shall enter any building or any enclosed courtyard or garden attached to`
  line `a dwelling-house without previously giving the occupier thereof at least three days notice in writing of`
  line `his intention to do so.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (8608)
  sectionNo (34)
  orderNo 34
  title `Member-Secretary, officers and other employees of the Board to be public servants.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8608&sectionno=34&orderno=34&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_34_content:
  string
  line The
  line `Member-Secretary, officers and other employees of the Board shall be deemed, when acting or purporting`
  line `to act in pursuance of any of the provisions of this Act, to be public servants within the meaning of`
  line `section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (8609)
  sectionNo (35)
  orderNo 35
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8609&sectionno=35&orderno=35&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_35_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Board or any member or any officer or any other employee of the Board including any`
  line `other person authorised by the Board to exercise any power or to discharge any function under this Act, or`
  line `for anything which is in good faith done or intended to be done under this Act.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (8610)
  sectionNo (36)
  orderNo 36
  title `Power to make rules.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8610&sectionno=36&orderno=36&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_36_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the provisions of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may provide for all or any`
  line `of the following matters, namely:--`
  line
  line `(a) the composition and number of the members of the Board and of the Committee, as required`
  line `by sub-section (3) of section 3 and sub-section (2) of section 4, respectively, to be prescribed;`
  line
  line `(b) the terms and conditions of the office of the members as required by sub-section (4) of`
  line `section 3, to be prescribed;`
  line
  line `(c) the form and manner in which notice under sub-section (1) of section 12 and sub-section (2)`
  line `of section 14 shall be published;`
  line
  line `(d) the manner in which notice under sub-section (1) of section 13 shall be published;`
  line
  line `(e) the form in which and the time at which the Board shall prepare its budget under section 23`
  line `and its annual report under section 24 and the manner in which the accounts of the Board shall be`
  line `maintained and audited under section 25;`
  line
  line `(f) the conditions and restrictions with respect to the exercise of the powers to enter under`
  line `section 33 and other matters relating thereto; and`
  line
  line `(g) any other matters which is to be, or may be, prescribed or in respect of which provision is to`
  line `be, or may be, made by rules.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (8611)
  sectionNo (37)
  orderNo 37
  title `Power to make regulations.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8611&sectionno=37&orderno=37&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_37_content:
  string
  line `(1) The Board may, with the previous approval of the Central`
  line `Government, by notification in the Official Gazette, make regulations not inconsistent with this Act and`
  line `the rules made thereunder to carry out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner in which and the purposes for which the Board may associate with itself any`
  line `person under section 11;`
  line
  line `(b) the terms and conditions of service of the officers and employees of the Board under`
  line `sub-section (2) of section 31; and`
  line
  line `(c) any other matter in respect of which provision is to be, or may be, made by regulations.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (8612)
  sectionNo (38)
  orderNo 38
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8612&sectionno=38&orderno=38&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_38_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation, as`
  line `the case may be, or both Houses agree that the rule or regulation, as the case may be, should not be made,`
  line `the rule or regulation shall thereafter have effect only in such modified form or be of no effect, as the case`
  line `may be; so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that rule or regulation.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (8613)
  sectionNo (39)
  orderNo 39
  title `Dissolution of the Board.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8613&sectionno=39&orderno=39&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_39_content:
  string
  line `(1) Where the Central Government is satisfied that the purposes for`
  line `which the Board was established under this Act have been substantially achieved or the Board has failed`
  line `in its objectives, so as to render the continued existence of the Board in the opinion of the Central`
  line `Government unnecessary, that Government may, by notification in the Official Gazette, declare that the`
  line `Board shall be dissolved with effect from such date as may be specified in the notification; and the Board`
  line `shall be deemed to be dissolved accordingly.`
  line
  line `(2) From the said date--`
  line
  line `(a) all properties, funds and dues which are vested in or realisable by the Board shall vest in, or`
  line `be realisable by, the Central Government;`
  line
  line `(b) all liabilities which are enforceable against the Board shall be enforceable against the Central`
  line Government;
  line
  line `(c) for the purpose of carrying out any development which has not been fully carried out by the`
  line `Board and for the purpose of realising properties, funds and dues referred to in clause (a) the`
  line `functions of the Board shall be discharged by the Central Government.`
  line
  line `(3) Nothing in this section shall be construed as preventing the Central Government from`
  line `reconstituting the Board in accordance with the provisions of this Act.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (8614)
  sectionNo (40)
  orderNo 40
  title `Acquisition of land and determination of rights in relation to land to be made by the Government of the participating State or Union territory.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8614&sectionno=40&orderno=40&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_40_content:
  string
  line `For the removal of doubts, it is hereby`
  line `declared that the acquisition of land or the determination of any right or interest in, or in relation to, any`
  line `land or other property, where necessary to give effect to any Regional Plan, Functional Plan,`
  line `Sub-Regional Plan or Project Plan, shall be made by the Government of the concerned participating State,`
  line `or, as the case may be, the Union territory, in accordance with the law for the time being in force in that`
  line `State or Union territory.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (8615)
  sectionNo (41)
  orderNo 41
  title `Repeal and saving.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00024_198502_1517807326741&sectionId=8615&sectionno=41&orderno=41&orgactid=AC_CEN_17_19_00024_198502_1517807326741
obj_root_law_sections_41_content:
  string
  line `(1) The National Capital Region Planning Board Ordinance,`
  line `1984 (Ord. 11 of 1984), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `राष्‍ट्रीय राजधानी क्षेत्र योजना बोर्ड अधिनियम,1985`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1847/3/H1985-2.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T09:52:11.306Z`
