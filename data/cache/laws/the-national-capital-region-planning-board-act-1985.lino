obj_root_law:
  slug the-national-capital-region-planning-board-act-1985
  handle (1847)
  collectionHandle 123456789/1362
  title `The National Capital Region Planning Board Act, 1985`
  actNumber (02)
  enactmentDate 1985-02-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1847`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्‍ट्रीय राजधानी क्षेत्र योजना बोर्ड अधिनियम,1985`
  actYear (1985)
  ministry `Ministry of Housing and Urban Affairs`
  longTitle `An Act to provide for the constitution of a Planning Board for the preparation of a plan for the development of the National Capital Region and for co-ordinating and monitoring the implementation of such plan and for evolving harmonized policies for the control of land-uses and development of infrastructure in the National Capital Region so as to avoid any haphazard development of that region and for matters connected therewith or incidental thereto.`
  enforcementDate 19-10-1984
  fetchedAt `2026-05-08T23:41:31.711Z`
  translations obj_root_law_translations
