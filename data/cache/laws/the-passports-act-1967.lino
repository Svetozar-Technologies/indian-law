  orderNo 29
  title `Repeal and saving.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4391&sectionno=27&orderno=29&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_27_content:
  string
  line `(1) The Passports Ordinance, 1967 (4 of 1967) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken or purporting to have been done`
  line `or taken under the said Ordinance shall be deemed to have been done or taken under this Act as if this Act`
  line `had commenced on the 5th day of May, 1967.`
obj_root_law_sections_27_footnotes:
  string
  line
