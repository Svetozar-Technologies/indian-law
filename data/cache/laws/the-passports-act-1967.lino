obj_root_law_sections_1:
  sectionId (4362)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4362&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Passports Act, 1967.`
  line
  line `(2) It extends to the whole of India and applies also to citizens of India who are outside India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (4363)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4363&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "departure", with its grammatical variations and cognate expressions, means departure from`
  line `India by water, land or air;`
  line
  line `(b) "passport" means a passport issued or deemed to have been issued under this Act;`
  line
  line `(c) "passport authority" means an officer or authority empowered under rules made under this`
  line `Act to issue passports or travel documents and includes the Central Government;`
  line
  line `(d) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(e) "travel document" means a travel document issued or deemed to have been issued under`
  line `this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (4364)
  sectionNo (3)
  orderNo 3
  title `Passport or travel document for departure from India.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4364&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_3_content:
  string
  line `No person shall depart from, or`
  line `attempt to depart from India unless he holds in this behalf a valid passport or travel document.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "passport" includes a passport which having been issued by or under the authority of the`
  line `Government of a foreign country satisfies the conditions prescribed under the Passport`
  line `(Entry into India) Act, 1920 (34 of 1920), in respect of the class of passports to which it belongs;`
  line
  line `(b) "travel document" includes a travel document which having been issued by or under the`
  line `authority of the Government of a foreign country satisfies the conditions prescribed.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (4365)
  sectionNo (4)
  orderNo 4
  title `Classes of passports and travel documents.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4365&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_4_content:
  string
  line `(1) The following classes of passports may be`
  line `issued under this Act, namely:--`
  line
  line `(a) ordinary passport;`
  line
  line `(b) Official passport;`
  line
  line `(c) diplomatic passport.`
  line
  line `(2) The following classes of travel documents may be issued under this Act, namely:--`
  line
  line `(a) emergency certificate authorising a person to enter India;`
  line
  line `(b) certificate of identity for the purpose of establishing the identity of a person;`
  line
  line `(c) such other certificate or document as may be prescribed.`
  line
  line `(3) The Central Government shall, in consonance with the usage and practice followed by it in this`
  line `behalf, prescribe the classes of persons to whom the classes of passports and travel documents referred to`
  line `respectively in sub-section (1) and sub-section (2) may be issued under this Act.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (4366)
  sectionNo (5)
  orderNo 5
  title `Applications for passports, travel documents, etc, and orders thereon.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4366&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_5_content:
  string
  line ^1
  line `[(1) An application`
  line `for the issue of a passport under this Act for visiting such foreign country or countries (not being a named`
  line `foreign country) as may be specified in the application may be made to the passport authority and shall be accompanied by ^2`
  line `[such fee as may be prescribed to meet the expenses incurred on special security paper,`
  line `printing, lamination and other connected miscellaneous services in issuing passports and other travel`
  line documents.]
  line
  line `Explanation.--In this section, "named foreign country" means such foreign country as the Central`
  line `Government may, by rules made under this Act, specify in this behalf.`
  line
  line `(1A) An application for the issue of--`
  line
  line `(i) a passport under this Act for visiting a named foreign country; or`
  line
  line `(ii) a travel document under this Act, for visiting such foreign country or countries`
  line `(including a named foreign country) as may be specified in the application or for an endorsement`
  line `on the passport or travel document referred to in this section,`
  line
  line `may be made to the passport authority and shall be accompanied by such fee (if any) not exceeding`
  line `rupees fifty, as may be prescribed.`
  line
  line `(1B) Every application under this section shall be in such form and contain such particulars as`
  line `may be prescribed.]`
  line
  line `(2) On receipt of an application ^3`
  line `[under this section], the passport authority, after making such`
  line `inquiry, if any, as it may consider necessary, shall, subject to the other provisions of this Act, by order`
  line `in writing,--`
  line
  line `(a) issue the passport or travel document with endorsement ,or, as the case may be, make on the`
  line `passport or travel document the endorsement, in respect of the foreign country or countries specified`
  line `in the application; or`
  line
  line `(b) issue the passport or travel document with endorsement, or, as the case may be, make on the`
  line `passport or travel document the endorsement, in respect of one or more of the foreign countries`
  line `specified in the application and refuse to make an endorsement in respect of the other country or`
  line `countries; or`
  line
  line `(c) refuse to issue the passport or travel document or, as the case may be, refuse to make on the`
  line `passport or travel document any endorsement.`
  line
  line `(3) Where the passport authority makes an order under clause (b) or clause (c) of sub-section (2) on`
  line `the application of any person, it shall record in writing a brief statement of its reasons for making such`
  line `order and furnish to that person on demand a copy of the same unless in any case the passport authority is`
  line `of the opinion that it will not be in the interests of the sovereignty and integrity of India, the security of`
  line `India, friendly relations of India with any foreign country or in the interests of the general public to`
  line `furnish such copy.`
obj_root_law_sections_5_footnotes:
  string
  line `1 Subs. by Act 31 of 1978, s. 2, for sub-section (1) (w.e.f. 18-8-1978).`
  line
  line `2 Subs. by Act 35 of 1993, s. 2, for "a fee of rupees fifty" (w.e.f. 1-7-1993).`
  line
  line `3 Ins. by Act 31 of 1978 s. 2 (w.e.f. 18-8-1978).`
obj_root_law_sections_6:
  sectionId (4367)
  sectionNo (6)
  orderNo 6
  title `Refusal of passports, travel documents, etc.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4367&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_6_content:
  string
  line `(1) Subject to the other provisions of this Act, the`
  line `passport authority shall refuse to make an endorsement for visiting any foreign country under clause`
  line `(b) or clause (c) of sub-section (2) of section 5 on any one or more of the following grounds, and on no`
  line `other ground, namely:--`
  line
  line `(a) that the applicant may, or is likely to, engage in such country in activities prejudicial to the`
  line `sovereignty and integrity of India;`
  line
  line `(b) that the presence of the applicant in such country may, or is likely to, be detrimental to the`
  line `security of India;`
  line
  line `(c) that the presence of the applicant in such country may, or is likely to, prejudice the friendly`
  line `relations of India with that or any other country;`
  line
  line `(d) that in the opinion of the Central Government the presence of the applicant in such country is`
  line `not in the public interest.`
  line
  line `(2) Subject to the other provisions of this Act, the passport authority shall refuse to issue a passport or`
  line `travel document for visiting any foreign country under clause (c) of sub-section (2) of section 5 on any`
  line `one or more of the following grounds, and on no other ground, namely:--`
  line
  line `(a) that the applicant is not a citizen of India;`
  line
  line `(b) that the applicant may, or is likely to, engage outside India in activities prejudicial to the`
  line `sovereignty and integrity of India;`
  line
  line `(c) that the departure of the applicant from India may, or is likely to, be detrimental to the`
  line `security of India;`
  line
  line `(d) that the presence of the applicant outside India may, or is likely to, prejudice the friendly`
  line `relations of India with any foreign country;`
  line
  line `(e) that the applicant has, at any time during the period of five years immediately preceding the`
  line `date of his application, been convicted by a court in India for any offence involving moral turpitude`
  line `and sentenced in respect thereof to imprisonment for not less than two years;`
  line
  line `(f) that proceedings in respect of an offence alleged to have been committed by the applicant are`
  line `pending before a criminal court in India;`
  line
  line `(g) that a warrant or summons for the appearance, or a warrant for the arrest, of the applicant has`
  line `been issued by a court under any law for the time being in force or that an order prohibiting the`
  line `departure from India of the applicant has been made by any such court;`
  line
  line `(h) that the applicant has been repatriated and has not reimbursed the expenditure incurred in`
  line `connection with such repatriation;`
  line
  line `(i) that in the opinion of the Central Government the issue of a passport or travel document to the`
  line `applicant will not be in the public interest.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (4368)
  sectionNo (7)
  orderNo 7
  title `Duration of passports travel documents.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4368&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_7_content:
  string
  line `A passport or travel document shall, unless`
  line `revoked earlier, continue in force for such period as may be prescribed and different periods may be`
  line `prescribed for different classes of passports or travel documents or for different categories of passports or`
  line `travel documents under each such class:`
  line
  line `Provided that a passport or travel document may be issued for a shorter period than the`
  line `prescribed period--`
  line
  line `(a) if the person by whom it is required so desires; or`
  line
  line `(b) if the passport authority, for reasons to be communicated in writing to the applicant, considers`
  line `in any case that the passport or travel document should be issued for a shorter period.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (4369)
  sectionNo (8)
  orderNo 8
  title `Extension of period of Passport.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 35 of 1993, s. 3, for section 8 (w.e.f. 1-7-1993).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4369&sectionno=8&orderno=8&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_8_content:
  string
  line ^1
  line `[8. Extension of period of Passport.--Where a passport is issued for a shorter period than the`
  line `prescribed period under section 7, such shorter period shall, unless the passport authority for reasons to be`
  line `recorded in writing otherwise determines, be extendable for a further period (which together with the`
  line `shorter period shall not exceed the prescribed period) and the provisions of this Act shall apply to such`
  line `extension as they apply to the issue thereof.]`
obj_root_law_sections_9:
  sectionId (4370)
  sectionNo (9)
  orderNo 9
  title `Conditions and forms of passports and travel documents.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4370&sectionno=9&orderno=9&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_9_content:
  string
  line `The conditions subject to which,`
  line `and the form in which, a passport or travel document shall be issued or renewed shall be such as may be`
  line `prescribed:`
  line
  line `Provided that different conditions and different forms may be prescribed for different classes of`
  line `passports or travel documents or for different categories of passports or travel documents under each such`
  line `class:`
  line
  line `Provided further that a passport or travel document may contain in addition to the prescribed`
  line `conditions such other conditions as the passport authority may, with the previous approval of the Central`
  line `Government, impose in any particular case.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (4371)
  sectionNo (10)
  orderNo 10
  title `Variation, impounding and revocation of passports and travel documents.`
  content obj_root_law_sections_10_content
  footnotes `1. The proviso ins. by Act 35 of 1993, s. 4 (w.e.f. 1-7-1993).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4371&sectionno=10&orderno=10&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_10_content:
  string
  line `(1) The passport`
  line `authority may, having regard to the provisions of sub-section (1) of section 6 or any notification under`
  line `section 19, vary or cancel the endorsements on a passport or travel document or may, with the previous`
  line `approval of the Central Government, vary or cancel the conditions (other than the prescribed conditions)`
  line `subject to which a passport or travel document has been issued and may, for that purpose, require the`
  line `holder of a passport or a travel document, by notice in writing, to deliver up the passport or travel`
  line `document to it within such time as may be specified in the notice and the holder shall comply with such`
  line notice.
  line
  line `(2) The passport authority may, on the application of the holder of a passport or a travel document,`
  line `and with the previous approval of the Central Government also vary or cancel the conditions`
  line `(other than the prescribed conditions) of the passport or travel document.`
  line
  line `(3) The passport authority may impound or cause to be impounded or revoke a passport or travel`
  line document,--
  line
  line `(a) if the passport authority is satisfied that the holder of the passport or travel document is in`
  line `wrongful possession thereof;`
  line
  line `(b) if the passport or travel document was obtained by the suppression of material information or`
  line `on the basis of wrong information provided by the holder of the passport or travel document or any`
  line `other person on his behalf:`
  line
  line ^1
  line `[Provided that if the holder of such passport obtains another passport, the passport authority shall`
  line `also impound or cause to be impounded or revoke such other passport.]`
  line
  line `(c) if the passport authority deems it necessary so to do in the interests of the sovereignty and`
  line `integrity of India, the security of India, friendly relations of India with any foreign country, or in the`
  line `interests of the general public;`
  line
  line `(d) if the holder of the passport or travel document has, at any time after the issue of the passport`
  line `or travel document, been convicted by a court in India for any offence involving moral turpitude and`
  line `sentenced in respect thereof to imprisonment for not less than two years;`
  line
  line `(e) if proceedings in respect of an offence alleged to have been committed by the holder of the`
  line `passport or travel document are pending before a criminal court in India;`
  line
  line `(f) if any of the conditions of the passport or travel document has been contravened;`
  line
  line `(g) if the holder of the passport or travel document has failed to comply with a notice under`
  line `sub-section (1) requiring him to deliver up the same;`
  line
  line `(h) if it is brought to the notice of the passport authority that a warrant or summons for the`
  line `appearance, or a warrant for the arrest, of the holder of the passport or travel document has been`
  line `issued by a court under any law for the time being in force or if an order prohibiting the departure`
  line `from India of the holder of the passport or other travel document has been made by any such court`
  line `and the passport authority is satisfied that a warrant or summons has been so issued or an order has`
  line `been so made.`
  line
  line `(4) The passport authority may also revoke a passport or travel document on the application of the`
  line `holder thereof.`
  line
  line `(5) Where the passport authority makes an order varying or cancelling the endorsements on, or`
  line `varying the conditions of, a passport or travel document under sub-section (1) or an order impounding or`
  line `revoking a passport or travel document under sub-section (3), it shall record in writing a brief statement`
  line `of the reasons for making such order and furnish to the holder of the passport or travel document on demand a copy of the same unless in any case, the passport authority is of the opinion that it will not be in`
  line `the interests of the sovereignty and integrity of India, the security of India, friendly relations of India with`
  line `any foreign country or in the interests of the general public to furnish such a copy.`
  line
  line `(6) The authority to whom the passport authority is subordinate may, by order in writing, impound or`
  line `cause to be impounded or revoke a passport or travel document on any ground on which it may be`
  line `impounded or revoked by the passport authority and the foregoing provisions of this section shall, as far`
  line `as may be, apply in relation to the impounding or revocation of a passport or travel document by such`
  line authority.
  line
  line `(7) A court convicting the holder of a passport or travel document of any offence under this Act or the`
  line `rules made thereunder may also revoke the passport or travel document:`
  line
  line `Provided that if the conviction is set aside on appeal or otherwise the revocation shall become void.`
  line
  line `(8) An order of revocation under sub-section (7) may also be made by an appellate court or by the`
  line `High Court when exercising its powers of revision.`
  line
  line `(9) On the revocation of a passport or travel document under this section the holder thereof shall,`
  line `without delay, surrender the passport or travel document, if the same has not already been impounded, to`
  line `the authority by whom it has been revoked or to such other authority as may be specified in this behalf in`
  line `the order of revocation.`
obj_root_law_sections_10_a:
  sectionId (4372)
  sectionNo 10A
  orderNo 11
  title `Suspension of passports or travel documents in certain cases.`
  content obj_root_law_sections_10_a_content
  footnotes `1. Ins by Act 17 of 2002, s. 2 (w.e.f. 23-10-2002).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4372&sectionno=10A&orderno=11&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_10_a_content:
  string
  line `^1[10A. Suspension of passports or travel documents in certain cases.--(1) Without prejudice`
  line `to the generality of the provisions contained in section 10, if the Central Government or any`
  line `designated officer is satisfied that the passport or travel document is likely to be impounded or caused`
  line `to be impounded or revoked under clause (c) of sub-section (3) of section 10 and it is necessary in the`
  line `public interest so to do, it or he may,--`
  line
  line `(a) by order, suspend, with immediate effect, any passport or travel document;`
  line
  line `(b) pass such other appropriate order which may have the effect of rendering any passport or`
  line `travel document invalid,`
  line
  line `for a period not exceeding four weeks:`
  line
  line `Provided that the Central Government or the designated officer may, if it or he considers`
  line `appropriate, extend, by order and for reasons to be recorded in writing, the said period of four weeks`
  line `till the proceedings relating to variation, impounding or revocation of passport or travel document`
  line `under section 10 are concluded:`
  line
  line `Provided further that every holder of the passport or travel document, in respect of whom an`
  line `order under clause (a) or clause (b) of this sub-section had been passed, shall be given an opportunity`
  line `of being heard within a period of not later than eight weeks reckoned from the date of passing of such`
  line `order and thereupon the Central Government may, if necessary, by order in writing, modify or revoke`
  line `the order passed under this sub-section.`
  line
  line `(2) The designated officer shall immediately communicate the order passed under sub-section (1),`
  line `to the concerned authority at an airport or any other point of embarkation or immigration, and to the`
  line `passport authority.`
  line
  line `(3) Every authority referred to in sub-section (2) shall, immediately on receipt of the order passed`
  line `under sub-section (1), give effect to such order.]`
obj_root_law_sections_10_b:
  sectionId (4373)
  sectionNo 10B
  orderNo 12
  title `Validation of intimations.`
  content obj_root_law_sections_10_b_content
  footnotes obj_root_law_sections_10_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4373&sectionno=10B&orderno=12&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_10_b_content:
  string
  line `^1[10B. Validation of intimations.--Every intimation given by the Central Government or the`
  line `designated officer, before the commencement of the Passports (Amendment) Act, 2002 (17 of 2002),`
  line `to any immigration authority at an airport or any other point of embarkation or immigration,`
  line `restricting or in any manner prohibiting the departure from India of any holder of the passport or`
  line `travel document under sub-section (3) of section 10, shall be deemed to be an order under subsection`
  line `(1) of section 10A and such order shall continue to be in force for a period of three months from the date of commencement of the Passports (Amendment) Act, 2002, or the date of giving such`
  line `intimation, whichever is later.`
  line
  line `Explanation.--For the purposes of sections 10A and 10B, the expression "designated officer"`
  line `means such officer or authority designated, by order in writing, as such by the Central Government.]`
obj_root_law_sections_10_b_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (4374)
  sectionNo (11)
  orderNo 13
  title Appeals.
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4374&sectionno=11&orderno=13&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_11_content:
  string
  line `(1) Any person aggrieved by an order of the passport authority under clause (b) or`
  line `clause (c) of sub-section (2) of section 5 or clause (b) of the proviso to section 7 or sub-section (1), or`
  line `sub-section (3) of section 10 or by an order under sub-section (6) of section 10 of the authority to whom`
  line `the passport authority is subordinate, may prefer an appeal against that order to such authority (hereinafter`
  line `referred to as the appellate authority) and within such period as may be prescribed:`
  line
  line `Provided that no appeal shall lie against any order made by the Central Government.`
  line
  line `(2) No appeal shall be admitted if it is preferred after the expiry of the period prescribed therefor:`
  line
  line `Provided that an appeal may be admitted after the expiry of the period prescribed therefor if the`
  line `appellant satisfied the appellate authority that he had sufficient cause for not preferring the appeal within`
  line `that period.`
  line
  line `(3) The period prescribed for an appeal shall be computed in accordance with the provisions of the`
  line `Limitation Act, 1963 (36 of 1963), with respect to the computation of the periods of`
  line `limitation thereunder.`
  line
  line `(4) Every appeal under this section shall be made by a petition in writing and shall be accompanied`
  line `by a copy of the statement of the reasons for the order appealed against where such copy has been`
  line `furnished to the appellant and ^1`
  line `[by such fee as may be prescribed for meeting the expenses that may be`
  line `incurred in calling for relevant records and for connected services].`
  line
  line `(5) In disposing of an appeal, the appellate authority shall follow such procedure as may be`
  line `prescribed:`
  line
  line `Provided that no appeal shall be disposed of unless the appellant has been given a reasonable`
  line `opportunity or representing his case.`
  line
  line `(6) Every order of the appellate authority confirming, modifying or reversing the order appealed`
  line `against shall be final.`
obj_root_law_sections_11_footnotes:
  string
  line `1 Subs. by Act 35 of 1993, s. 5, for "by such fee (if any) not exceeding rupees twenty-five as may be prescribed"`
  line `(w.e.f. 1-7-1993).`
obj_root_law_sections_12:
  sectionId (4375)
  sectionNo (12)
  orderNo 14
  title `Offences and penalties.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4375&sectionno=12&orderno=14&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_12_content:
  string
  line `(1) Whoever--`
  line
  line `(a) contravenes the provisions of section 3; or`
  line
  line `(b) knowingly furnishes any false information or suppresses any material information with a view`
  line `to obtaining a passport or travel document under this Act or without lawful authority alters or`
  line `attempts to alter or causes to alter the entries made in a passport or travel document; or`
  line
  line `(c) fails to produce for inspection his passport or travel document (whether issued under this`
  line `Act or not) when called upon to do so by the prescribed authority; or`
  line
  line `(d) knowingly uses a passport or travel document issued to another person; or`
  line
  line `(e) knowingly allows another person to use a passport or travel document issued to him,`
  line
  line `shall be punishable with imprisonment for a term which may extend to ^1`
  line `[two years or with fine which`
  line `may extend to five thousand rupees] or with both.`
  line
  line ^2
  line `[(1A) Whoever, not being a citizen of India,--`
  line
  line `(a) makes an application for a passport or obtains a passport by suppressing information about his`
  line `nationality, or`
  line
  line `(b) holds a forged passport or any travel document,`
  line
  line `shall be punishable with imprisonment for a term which shall not be less than one year but which may`
  line `extend to five years and with fine which shall not be less than ten thousand rupees but which may extend`
  line `to fifty thousand rupees.]`
  line
  line `(2) Whoever abets any offence punishable under ^3`
  line `[sub-section (1) or sub-section (1A)] shall, if the`
  line `act abetted is committed in consequence of the abetment, be punishable with the punishment provided in`
  line `that sub-section for that offence.`
  line
  line `(3) Whoever contravenes any condition of a passport or travel document or any provision of this Act`
  line `or any rule made thereunder for which no punishment is provided elsewhere in this Act shall be`
  line `punishable with imprisonment for a term which may extend to three months or with fine which may`
  line `extend to five hundred rupees or with both.`
  line
  line `(4) Whoever, having been convicted of an offence under this Act, is again convicted of an offence`
  line `under this Act shall be punishable with double the penalty provided for the latter offence.`
obj_root_law_sections_12_footnotes:
  string
  line `1. Subs. by s. 6, ibid., for "six months or with fine which may extend to two thousand rupees" (w.e.f. 1-7-1993).`
  line
  line `2. Ins. by Act 35 of 1993 s. 6, (w.e.f. 1-7-1993).`
  line
  line `3. Subs. by s. 6, ibid., for "sub-section (1)" (w.e.f. 1-7-1993)`
obj_root_law_sections_13:
  sectionId (4376)
  sectionNo (13)
  orderNo 15
  title `Power to arrest.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4376&sectionno=13&orderno=15&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_13_content:
  string
  line `(1) Any officer of customs empowered by a general or special order of the`
  line `Central Government in this behalf and any ^1`
  line `[officer of police or emigration officer] not below the rank of`
  line `a sub-inspector may arrest without warrant any person against whom a reasonable suspicion exists that he`
  line `has committed any offence punishable under section 12 and shall, as soon as may be, inform him of the`
  line `grounds for such arrest.`
  line
  line `(2) Every officer making an arrest under this section shall, without unnecessary delay, take or send`
  line `the person arrested before a magistrate having jurisdiction in the case or to the officer in charge of the`
  line `nearest police station and the provisions of ^2`
  line `[section 57 of the Code of Criminal procedure, 1973`
  line `(2 of 1974)] shall, so far as may be, apply in the case of any such arrest.`
obj_root_law_sections_13_footnotes:
  string
  line `1. Subs. by s. 7, ibid., for Officer of police (w.e.f. 1-7-1993).`
  line
  line `2. Subs. by Act 31 of 1978, s. 3, for "section 61 of the Code of Criminal Procedure, 1898 (5 of 1898)" (w.e.f. 18-8-1978).`
obj_root_law_sections_14:
  sectionId (4377)
  sectionNo (14)
  orderNo 16
  title `Power of search and seizure.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4377&sectionno=14&orderno=16&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_14_content:
  string
  line `(1) Any officer of customs empowered by a general or special`
  line `order of the Central Government in this behalf and any ^1`
  line `[officer of police or emigration officer] not below`
  line `the rank of a sub-inspector may search any place and seize any passport or travel document from any`
  line `person against whom a reasonable suspicion exists that he has committed any offence punishable under`
  line `section 12.`
  line
  line `(2) The provisions of the ^2`
  line `[Code of Criminal Procedure, 1973 (2 of 1974)], relating to searches and`
  line `seizures shall, so far as may be, apply to searches and seizures under this section.`
obj_root_law_sections_14_footnotes:
  string
  line `1. Subs. by s. 7, ibid., for 'Officer of police" (w.e.f. 1-7-1993).`
  line
  line `2. Subs. by s. 4, ibid., for "Code of Criminal Procedure, 1898 (5 of 1898)" (w.e.f. 18-8-1978).`
obj_root_law_sections_15:
  sectionId (4378)
  sectionNo (15)
  orderNo 17
  title `Previous sanction of Central Government necessary.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4378&sectionno=15&orderno=17&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_15_content:
  string
  line `No prosecution shall be instituted`
  line `against any person in respect of any offence under this Act without the previous sanction of the Central`
  line `Government or such officer or authority as may be authorised by that Government by order in writing in`
  line `this behalf.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (4379)
  sectionNo (16)
  orderNo 18
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4379&sectionno=16&orderno=18&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_16_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Government or any officer or authority for anything which is in good faith done or`
  line `intended to be done under this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (4380)
  sectionNo (17)
  orderNo 19
  title `Passports and travel documents to be property of Central Government.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4380&sectionno=17&orderno=19&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_17_content:
  string
  line `A passport or travel`
  line `document issued under this Act shall at all times remain the property of the Central Government.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (4381)
  sectionNo (18)
  orderNo 20
  title [Omitted].
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4381&sectionno=18&orderno=20&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_18_content:
  string
  line `[Passports, etc., not to be issued to persons who cannot emigrate under Act 7 of 1922].--Omitted`
  line `by the Passports (Amendment) Act, 1993 (35 of 1993), s. 8 (w.e.f. 1-7-1993).`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (4382)
  sectionNo (19)
  orderNo 21
  title `Passports and travel documents to be invalid for travel to certain countries.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4382&sectionno=19&orderno=21&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_19_content:
  string
  line `Upon the issue`
  line `of a notification by the Central Government that a foreign country is--`
  line
  line `(a) a country which is committing external aggression against India; or`
  line
  line `(b) a country assisting the country committing external aggression against India; or`
  line
  line `(c) a country where armed hostilities are in progress; or`
  line
  line `(d) a country to which travel must be restricted in the public interest because such travel would`
  line `seriously impair the conduct of foreign affairs of the Government of India,`
  line
  line `a passport or travel document for travel through or visiting such country shall cease to be valid for such`
  line `travel or visit unless in any case a special endorsement in that behalf is made in the prescribed form by`
  line `the prescribed authority.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (4383)
  sectionNo (20)
  orderNo 22
  title `Issue of passports and travel documents to persons who are not citizens of India.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4383&sectionno=20&orderno=22&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_20_content:
  string
  line `Notwithstanding anything contained in the foregoing provisions relating to issue of a passport or`
  line `travel document, the Central Government may issue, or cause to be issued, a passport or travel document`
  line `to a person who is not a citizen of India if that Government is of the opinion that it is necessary so to do in`
  line `the public interest.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (4384)
  sectionNo (21)
  orderNo 23
  title `Power to delegate.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4384&sectionno=21&orderno=23&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_21_content:
  string
  line `The Central Government may, by notification in the Official Gazette, direct`
  line `that any power or function which may be exercised or performed by it under this Act other than the power`
  line `under clause (d) of sub-section (1) of section 6 or the power under clause (i) of sub-section (2) of that`
  line `section or the power under section 24, may, in relation to such matters and subject to such conditions, if`
  line `any, as it may specify in the notification, be exercised or performed--`
  line
  line `(a) by such officer or authority subordinate to the Central Government; or`
  line
  line `(b) by any State Government or by any officer or authority subordinate to such Government; or`
  line
  line `(c) in any foreign country in which there is no diplomatic mission of India, by such foreign`
  line `Consular Officer; as may be specified in the notification.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (4385)
  sectionNo (22)
  orderNo 24
  title `Power to exempt.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4385&sectionno=22&orderno=24&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_22_content:
  string
  line `Where the Central Government is of the opinion that it is necessary or`
  line `expedient in the public interest so to do, it may, by notification in the Official Gazette and subject to such`
  line `conditions, if any, as it may specify in the notification,--`
  line
  line `(a) exempt any person or class of persons from the operation of all or any of the provisions of this`
  line `Act or the rules made thereunder; and`
  line
  line `(b) as often as may be, cancel any such notification and again subject, by a like notification, the`
  line `person or class of persons to the operation of such provisions.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (4386)
  sectionNo (23)
  orderNo 25
  title `Act to be in addition to certain enactments.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4386&sectionno=23&orderno=25&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_23_content:
  string
  line `The provisions of this Act shall be in addition to`
  line `and not in derogation of the provisions of the Passport (Entry into India) Act, 1920 (34 of 1920), ^14`
  line [the
  line `Emigration Act, 1983 (31 of 1983)] the Registration of Foreigners Act, 1939 (16 of 1939), the Foreigners`
  line `Act, 1946 (31 of 1946), Trading with the Enemy (Continuance of Emergency Provisions)`
  line `(16 of 1947), the Foreigners Law (Application and Amendment) Act, 1962 (42 of 1962), ^15`
  line `the Foreign`
  line `Exchange Regulation Act, 1973 (46 of 1973) and other enactments relating to foreigners and foreign`
  line exchange.
obj_root_law_sections_23_footnotes:
  string
  line `1 Subs. by Act 35 of 1993, s. 9, for "the Emigration Act, 1922 (7 of 1922)" (w.e.f. 1-7-1993).`
  line
  line `2 Ins. by Act 31 of 1978, s. 5, ibid. (w.e.f. 18-8-1978).`
obj_root_law_sections_24:
  sectionId (4387)
  sectionNo (24)
  orderNo 26
  title `Power to make rules.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4387&sectionno=24&orderno=26&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_24_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the appointment, jurisdiction, control and functions of passport authorities;`
  line
  line `(b) the classes of persons to whom passports and travel documents referred to respectively in`
  line `sub-section (1) and sub-section (2) of section 4 may be issued;`
  line
  line `(c) the form and particulars of application for the issue or renewal of a passport or travel`
  line `document or for endorsement on a passport or travel document and where the application is for the`
  line `renewal, the time within which it shall be made;`
  line
  line `(d) the period for which passports and travel documents shall continue in force;`
  line
  line `(e) the form in which and the conditions subject to which the different classes of passports and`
  line `travel documents may be issued, renewed or varied;`
  line
  line `^1[(ee) specifying the foreign country for the purposes of the Explanation to sub-section (1) of`
  line `section 5;]`
  line
  line `(f) the fees payable in respect of ^2[any application for the issue of a passport under sub-section (1)`
  line `of section 5 or issue of a passport for visiting a foreign country referred to in sub-section (1A) of`
  line `section 5] or travel document or for varying any endorsement or making a fresh endorsement on a`
  line `passport or a travel document and the fees payable in respect of any appeal under this Act;`
  line
  line `(g) the appointment of appellate authorities under sub-section (1) of section 11, the jurisdiction`
  line `of, and the procedure which may be followed by, such appellate authorities;`
  line
  line `(h) the services (including the issue of a duplicate passport or travel document in lieu of a`
  line `passport or travel document lost, damaged or destroyed) which may be rendered in relation to a`
  line `passport or travel document and the fees therefor;`
  line
  line `(i) any other matter which is to be or may be prescribed or in respect of which this Act makes no`
  line `provision or makes insufficient provision and provision is, in the opinion of the Central Government,`
  line `necessary for the proper implementation of the Act.`
  line
  line `(3) Every rule made under this Act shall be laid as soon as may be after it is made, before each House`
  line `of Parliament while it is in session for a total period of thirty days which may be comprised in one session`
  line `or ^18`
  line `in two or more successive sessions and if, before the expiry of the session immediately following the`
  line `session or the successive sessions aforesaid, both Houses agree in making any modification in the rule or`
  line `both Houses agree that the rule should not be made, the rule shall thereafter have effect only in such`
  line `modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_24_footnotes:
  string
  line `1 Ins. by Act 31 of 1978, s. 6 (w.e.f. 18-8-1978).`
  line
  line `2 The words "issue or renewal of a passport" of clause (f) were subs. by Act 31 of 1978, s. 6 (w.e.f.18-8-1978) to read as`
  line `issue or renewal of a passport for visiting a foreign country referred to in sub-section (1A) of section 5and the words`
  line `any application for the issue or renewal of a passport were further subs. by Act 35 of 1993, s.10 to read as above`
  line `(w.e.f.1-7-1993).`
  line
  line `3 Subs. by Act 31 of 1978, s. 6, for certain words (w.e.f. 18-8-1978).`
obj_root_law_sections_25:
  sectionId (4388)
  sectionNo (25)
  orderNo 27
  title `Change of short title of Act 34 of 1920.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4388&sectionno=25&orderno=27&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_25_content:
  string
  line `In the Indian Passport Act, 1920, in sub-section (1) of`
  line `section 1, for the words and figures the Indian Passport Act, 1920," the words, brackets and figures "the`
  line `Passport (Entry into India) Act, 1920 shall be substituted.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (4390)
  sectionNo (26)
  orderNo 28
  title Omitted.
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00008_196715_1517807321481&sectionId=4390&sectionno=26&orderno=28&orgactid=AC_CEN_10_10_00008_196715_1517807321481
obj_root_law_sections_26_content:
  string
  line `[Saving as to certain passports and applications.]--Omitted by the Passports (Amendment) Act,`
  line `1993 (35 of 1993), s. 8 (w.e.f. 1-7-1993).`
