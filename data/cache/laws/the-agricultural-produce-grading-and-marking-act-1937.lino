obj_root_law_sections_7_content:
  string
  line 7
  line `32. Raw Jute.`
  line `33. Paddy.`
  line `34. Millets.`
  line `35. Mesta.`
  line `36. Chilies.`
  line `37. Turmeric.`
  line `38. Tapioca Chips and Tapioca Flour`
  line `39. Sisal and Aloe Fibres.`
  line `40. Oil cakes.`
  line `41. Condiments and Spices.`
  line `(Other than pepper, ginger, cashewnut, cardamom, chillies and turmeric, to which the provisions`
  line `of the Act have already been applied.)`
  line `42. Pulses.`
  line `43. Walnut.`
  line `44. Animal casings (cattle, buffaloes, sheep, goats and pigs).`
  line `45. Guar Gum.`
  line `46. Karaya Gum.`
  line `47. Senna Leaves and Pods.`
  line `48. Palmyra fibre.`
  line `49. Catechu.`
  line `50. Tendu Leaves.`
  line `51. Water Chest - nut.`
  line `52. Mushrooms.`
  line `53. Poppy seed.`
  line `54. Cashew - shell Oil (Liquid).`
  line `55. Beeswax.`
  line `56. Gram (Cicer arietinum).`
  line `57. Jowar (Sorghum vulgare).`
  line `58. Maize (Zea mays).`
  line `59. Barley (Hordeum vulgare).`
  line `60. Ragi (Eleusio coracana).`
  line `61. Bajra (Pennisetum typhoides).`
  line `62. Sheekakai powder.`
  line `63. Compounded asafoetida.`
  line —————
