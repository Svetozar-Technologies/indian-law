  (str slug) (str the-bonded-labour-system-abolition-act-1976)
  (str handle) (str 1491)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Bonded Labour System (Abolition) Act, 1976`)
  (str actNumber) (str 19)
  (str enactmentDate) (str 1976-02-09)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1491`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बंधित श्रम पद्धति (उत्‍सादन) अधिनियम, 1976`)
  (str actYear) (str 1976)
  (str ministry) (str `Ministry of Labour and Employment`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the abolition of bonded labour system with a view to preventing the economic and physical exploitation of the weaker sections of the people and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 25-10-1975)
  (str notification) (undefined)
