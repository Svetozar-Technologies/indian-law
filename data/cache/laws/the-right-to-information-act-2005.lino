obj_root_law:
  slug the-right-to-information-act-2005
  handle (2065)
  collectionHandle 123456789/1362
  title `The Right to Information Act, 2005`
  actNumber (22)
  enactmentDate 2005-06-15
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2065`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `सूचना का अधिकार अधिनियम, 2005`
  actYear (2005)
  ministry `Ministry of Personnel, Public Grievances and Pensions`
  department `Department of Personnel and Training`
  longTitle `An Act to provide for setting out the practical regime of right to information for citizens to secure access to information under the control of public authorities, in order to promote transparency and accountability in the working of every public authority, the constitution of a Central Information Commission and State Information Commissions and for matters connected therewith or incidental thereto.`
  enforcementDate `Ss. 4(1), 5(1) (2), 12, 13, 15, 16, 24, 27, 28 (15-06-2005) and rest provisions on 120th day of its enactment.`
  fetchedAt `2026-05-08T21:24:57.679Z`
  translations obj_root_law_translations
