obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `सूचना का अधिकार अधिधनयम, 2005`
  line _________
  line `िाराओं का क्र म`
  line _________
  line `ि ााराएं`
  line `अध्या य 1 प्र`
  line `ारधि क`
  line `1. संधिप् त नाम, धिस्तार और प्र ारंि।`
  line `2. पररिाषाएं।`
  line `अध्याय 2`
  line `सूचना का अधिकार और लोक प्र ाधिकाररयों की बाध्यताएं`
  line `3. सूचना का अधिकार।`
  line `4. लोक प्र ाधिकाररयों की बा ध् यताएं।`
  line `5. लोक सूचना अधिकाररयों का पदनाम।`
  line `6. सूचना अधिप्राप्त करने के धलए अनुरोि।`
  line `7. अनुरोि का धनपटारा।`
  line `8. सूचना के प्र कट ककए जाने से छूट।`
  line `9. कधतपय मामलों में पहंच के धलए अस्िीकृधत के आिार।`
  line `10. पृथक्क रणीयता।`
  line `11. पर व् य धक् त सूचना।`
  line `अध्याय 3`
  line `केन्द्री य सूचना आयोग`
  line `12. केन्द्रीय सूचना आयोग का गठन।`
  line `13. पदािधि और सेिा शतें।`
  line `14. सूचना आयुक्त या मुख्य सूचना आयुक्त का हटाया जाना।`
  line `अध्याय 4`
  line `राज्य सूचना आयोग`
  line `15. राज्य सूचना आयोग का गठन।`
  line `16. पदािधि और सेिा की शतें।`
  line `17. राज्य मुख्य सूचना आयुक्त या राज्य सूचना आयुक्त का हटाया जाना।`
  line `अध्याय 5`
  line `सूचना आयोगों की शधक्त यां और कृत्य, अपील तथा शाधस्तयां`
  line `18. सूचना आयोगों की शधक्त यां और कृत्य।`
  line `19. अपील।`
  line `20. शाधस्त।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line `ि ााराएं`
  line `अध्याय 6 प्र`
  line कीणण
  line `21. सद्भािपूिणक की गई कारणिाई के धलए संरिण।`
  line `22. अधिधनयम का अध्यारोही प्र िाि होना।`
  line `23. न्द् यायालयों की अधिकाररता का िजणन।`
  line `24. अधिधनयम का कधतपय संगठनों को लागू न होना।`
  line `25. मानीटर करना और ररपोटण करना।`
  line `26. समुधचत सरकार द्व ारा कायणक्रम तैयार ककया जाना।`
  line `27. धनयम बनाने की समुधचत सरकार की शधक्त।`
  line `28. धनयम बनाने की सिम प्र ाधिकारी की शधक्त।`
  line `29. धनयमों का रखा जाना।`
  line `30. करठनाइयों को दूर करने की शधक् त।`
  line `31. धनरसन।`
  line `पहली अनुसूची।`
  line `दूसरी अनुसूची।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line `सूचना का अधिकार अधिधनयम, 2005`
  line `( 2005 का अधिधनयम संख्यां क 22 )`
  line `[15 जून, 2005 ] प्रत्`
  line `ये क लोक प्र ाधिकारी के कायणकरण में पारदर्शणता और उत्तरदाधयत्ि के संििणन के धलए,`
  line `लोक प्र ाधिकारी के धनयंत्रणािीन सूचना तक पहंच सुधन धच त करने`
  line `के धलए नागररकों के सूचना के अधिकार की व् या िहाररक शासन`
  line `पद्धधत स् था धपत करने, एक केन्द्री य सूचना आयोग तथा`
  line `राज्य सूचना आयोग का गठन करने के और उन से`
  line `संबंधित या उनके आनुषंधगक`
  line `धिषयों का उपबंि`
  line `करने के धलए`
  line अधिधनयम
  line `िारत के संधििान ने लोकतंत्रात्म क गणराज्य की स् था पना की है;`
  line `और लोकतंत्र धशधित नागररक िगण तथा ऐसी सूचना की पारदर्शणता की अपेिा करता है, जो उसके कायणकरण तथा भ्रष् टा चार`
  line `को रोकने के धलए िी और सरकारों तथा उनके पररकरणों को शासन के प्र धत उत्तरदायी बनाने के धलए अधनिायण है;`
  line `और िास्तधिक व्य िहार में सूचना के प्र कटन से संिितः अन्द्य लोक धहतों, धजनके अंतगणत सरकारों के दि प्र चालन, सी धमत`
  line `राज्य धित्तीय संसािनों के अधिकतम उपयोग और संिेदनशील सूचना की गोपनीयता को बनाए रखना िी है, के साथ धिरोि हो`
  line `सकता है;`
  line `और लोकतंत्रात्मक आदशण की प्र िुता को बनाए रखते हए इन धिरोिी धहतों के बीच सामंजस्य बनाना आिय क है;`
  line `अतः, अब यह समीचीन है कक ऐसे नागररकों को, कधतपय सूचना देने के धलए, जो उसे पाने के इच्छुक हैं, उपबंि`
  line `ककया जाए;`
  line `िारत गणराज्य के छप्पनिें िषण में संसद् द्व ारा धनन धलधखत रू प में यह अधिधनयधमत हो: ––`
  line `अध्या य 1 प्र`
  line `ारधि क`
  line `1. संधिप्त नाम, धिस्तार और प्र ारंि –– (1) इस अधिधनयम का संधिप् त नाम सूचना का अधिकार अधिधनयम, 2005 है।`
  line `(2) इसका धिस्ता र 1 *** सपूणण िारत पर है।`
  line `(3) िारा 4 की उपिारा (1), िारा 5 की उपिारा (1) और उपिारा (2), िारा 12, िारा 13, िारा 15, िारा 16, िारा 24,`
  line `िारा 27 और िारा 28 के उपबंि तुरंत प्र िािी होंगे और इस अधिधनयम के शेष उपबंि इसके अधिधनयमन के एक सौ बीसिें कदन * को प्र`
  line `िृत्त होंगे।`
  line `2. पररिाषाएं –– इस अधिधनयम में, जब तक कक संदिण से अन्द्यथा अपेधित न हो, ––`
  line `( क ) “ समुधचत सरकार ” से ककसी ऐसे लोक प्र ाधिकरण के संबंि में जो – –`
  line `(i) केन्द्रीय सरकार या संघ राज्यिेत्र प्र शासन द्व ारा स् थाधपत, गरठत, उसके स् िाधमत्िािीन, धनयंत्रणािीन`
  line `या उस के द्व ारा प्रत् यि रू प से या अप्रत्यि रू प से उपलब्ि कराई गई धनधियों द्व ारा सारिूत रू प से धि त्त पोधषत ककया`
  line `जाता है, केन्द्रीय सरकार अधिप्रेत है;`
  line `(ii) राज्य सरकार द्व ारा स् थाधपत, गरठत उसके स् िाधमत्िािीन, धनयंत्रणािीन या उसके द्व ारा प्रत् यि रू प से`
  line `या अप्र त् यि रू प से उपलब्ि कराई गई धनधियों द्व ारा सारिूत रू प से धित्तपोधषत ककया जाता है, राज्य सरका र`
  line `अधिप्रेत है;`
  line `( ख ) “ केन्द्रीय सूचना आयोग ” से िारा 12 की उपिारा (1) के अिीन गरठत केन्द्रीय सूचना आयोग अधिप्रेत है;`
  line `1 2019 के अधिधनयम सं ० 34 की िारा 95 और पांचिी अनुसूची द्व ारा (31 - 10 - 2019 से ) “ जमू - कमीर राज्य के धसिाय ” शब्दों का लोप ककया गया।`
  line `* 12 अक्तू बर, 2005.`
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
  orderNo 4
  title `Page 4`
  content obj_root_law_translations_hi_sections_4_content
  footnotes obj_root_law_translations_hi_sections_4_footnotes
  sourcePage 4
obj_root_law_translations_hi_sections_4_content:
  string
  line 2
  line `( ग ) “ केन्द्रीय लोक सूचना अधिकारी ” से उपिारा (1 ) के अिीन पदाधिधहत केन्द्रीय लोक सूचना अधिकारी अधिप्रेत`
  line `है और इसके अंतगणत िारा 5 की उपिारा (2) के अिीन इस प्र कार पदाधिधहत कोई केन्द्रीय सहायक लोक सूचना अधिकारी`
  line `िी है;`
  line `( घ ) “ मुख्य सूचना आयुक्त ” और “ सूचना आयुक्त ” से िारा 12 की उपिारा (3) के अिीन धनयुक्त मुख्य सूचना`
  line `आयुक्त और सूचना आयुक्त अधिप्रेत हैं;`
  line `( ङ ) “ सिम प्र ाधिकारी ” से अधिप्रेत है ––`
  line `(i) लोक सिा या ककसी राज्य की धििान सिा की या ककसी ऐसे संघ राज्यिेत्र की, धजसमें ऐसी सिा है,`
  line `दशा में अध्यि और राज्य सिा या ककसी राज्य की धििान पररषद् की दशा में सिापधत;`
  line `(ii) उच्च तम न्द् यायालय की दशा में िारत का मुख्य न्द् यायमूर्तण;`
  line `(iii) ककसी उच्च न्द् यायालय की दशा में उच्च न्द् यायालय का मुख्य न्द् यायमूर्तण;`
  line `(iv) संधििान द्व ारा या उसके अिीन स् थाधपत या गरठत अन्द्य प्र ाधिकरणों की दशा में, यथाधस्थधत,`
  line `रा ष् र पधत या राज्य पाल;`
  line `(v) संधििान के अनुच्छेद 239 के अिीन धनयुक्त प्र शासक;`
  line `( च ) “ सूचना ” से ककसी इलैक्राधनक रू प में िाररत अधिलेख, दस्तािेज, ज्ञ ापन, ई - मेल, मत, सलाह, प्रे स धिज्ञधि,`
  line `पररपत्र, आदेश, लागबुक, संधिदा, ररपोटण, कागजपत्र, नमूने, माडल, आंकडों संबंिी सामग्री और ककसी प्र ाइिेट धनका य से`
  line `संबंधित ऐसी सूचना सधहत, धजस तक तत्समय प्र िृत्त ककसी अन्द्य धिधि के अिीन ककसी लोक प्र ाधिकारी की पहंच हो सकती है,`
  line `ककसी रू प में कोई सामग्री, अधिप्रेत है;`
  line `( छ ) “ धिधहत ” से, यथाधस्थधत, समुधचत सरकार या सिम प्र ाधिकारी द्व ारा इस अधिधनयम के अिीन बनाए गए`
  line `धनयमों द्व ारा धिधहत अधिप्रेत है;`
  line `( ज ) “ लोक प्र ाधिकारी ” से, ––`
  line `( क ) संधििान द्व ारा या उसके अिीन;`
  line `( ख ) संसद् द्व ारा बनाई गई ककसी अन्द्य धिधि द्व ारा;`
  line `( ग ) राज्य धििान - मंडल द्व ारा बनाई गई ककसी अन्द्य धिधि द्व ारा;`
  line `( घ ) समुधचत सरकार द्व ारा जारी की गई अ धिसूचना या ककए गए आदेश द्व ारा, स् थाधपत या गरठत कोई प्र`
  line `ाधिकारी या धनकाय या स् िायत्त सरकारी संस्था अधिप्रेत है,`
  line `और इसके अन्द्तगणत, —`
  line `(i) कोई ऐसा धनकाय है जो समुधचत सरकार के स् िाधमत्िािीन, धनयंत्रणािीन या उसके द्व ारा प्रत् यि या`
  line `अप्रत्यि रू प से उपलब्ि कराई ग ई धनधियों द्व ारा सारिूत रू प से धित्तपोधषत है;`
  line `(ii) कोई ऐसा गैर - सरकारी संगठन है जो समुधचत सरकार, द्व`
  line `ारा प्रत् यि या अप्रत्यि रू प से उपलब्ि कराई गई धनधियों द्व ारा सारिूत रू प से धित्तपोधषत है।`
  line `( झ ) “ अधिलेख ” में धनन धलधखत सधमधलत हैं ––`
  line `( क ) कोई दस्तािेज, पाण्डुधलधप और फाइल;`
  line `( ख ) ककसी दस्तािेज की कोई माइक्रोकफल्म, माइक्रोकफशे और प्र धतकृधत प्र धत;`
  line `( ग ) ऐसी माइक्रोकफल्म में सधन्द्न धिष्ट प्र धतधबब या प्र धतधबबों का पुनरुत्पादन ( चाहे िर्िणत रू प में हो या`
  line `न हो ); और`
  line `( घ ) ककसी कप्यूटर द्व ारा या ककसी अन्द्य यु धक् त द्व ारा उत्पाकदत कोई अन्द्य सामग्री;`
  line `( ञ ) “ सूचना का अधिकार ” से इस अधिधनयम के अिीन पहंच योग्य सूचना का, जो ककसी लोक प्र ाधिकारी द्व ारा या`
  line `उसके धनयंत्रणािीन िाररत है, अधिकार अधिप्रेत है और धजसमें धनन धलधखत का अधिकार सधमधलत है —`
  line `(i) कृधत, दस्तािेजों, अधिले खों का धनरीिण;`
  line `(ii) दस्तािेजों या अधिलेखों के रटप्पण, उद्धरण या प्र माधणत प्र धतधलधप लेना;`
  line `(iii) सामग्री के प्र माधणत नमूने लेना;`
obj_root_law_translations_hi_sections_4_footnotes:
  string
  line
obj_root_law_translations_hi_sections_5:
  kind page
  sectionId pdf-page-5
  sectionNo (5)
  orderNo 5
  title `Page 5`
  content obj_root_law_translations_hi_sections_5_content
  footnotes obj_root_law_translations_hi_sections_5_footnotes
  sourcePage 5
obj_root_law_translations_hi_sections_5_content:
  string
  line 3
  line `(iv) धडस्केट, फ् लापी, टेप, िीधडयो कैसेट के रू प में या ककसी अन्द्य इलैक्राधनक रीधत में या प्प्रं टआऊट के`
  line `माध्यम से सूचना को, जहां ऐसी सूचना ककसी कप्यूटर या ककसी अन्द्य युधि में िण्डाररत है, अधि प्र ाप्त करना;`
  line `( ट ) “ राज्य सूचना आयोग ” से िारा 15 की उपिारा (1) के अिीन गरठत राज्य सूचना आयोग अधिप्रेत है;`
  line `( ठ ) “ राज्य मुख्य सूचना आयुक्त ” और “ राज्य सूचना आयुक्त ” से िारा 15 की उपिारा (3 ) के अिीन धनयुक्त राज्य`
  line `मुख्य सूचना आयुक्त और राज्य सूचना आयुक्त अधिप्रेत है;`
  line `( ड ) “ राज्य लोक सूचना अधिकारी ” से उपिारा (1) के अिीन पदाधिधहत राज्य लोक सूचना अधिकारी अधिप्रेत है`
  line `और इसके अंतगणत िारा 5 की उपिारा (2) के अिीन उस रू प में पदाधिधहत राज्य सहायक लोक सूचना अधिकारी िी है;`
  line `( ढ ) “ पर व् य धक् त ” से सूचना के धलए अनुरोि करने िाले नागररक से धिन्द् न कोई व् य धक्त अधिप्रेत है, और इसके`
  line `अंतगणत कोई लोक प्र ाधिकारी िी है।`
  line `अध्याय 2`
  line `सूचना का अधिकार और लोक प्र ाधिकाररयों की बाध्यताएं`
  line `3. सूचना का अधिकार –– इस अधिधनयम के उपबन्द्िों के अिीन रहते हए, सिी नागररकों को सूचना का अधिकार होगा।`
  line `4. लोक प्र ाधिकाररयों की बाध्यताएं –– ( 1) प्रत् येक लोक प्र ाधिकारी ––`
  line `( क ) अपने सिी अधिलेखों को सयक् रू प से सूचीपधत्रत और अनुक्रमधणकाबद्ध ऐसी रीधत और रू प में रखेगा, जो इस`
  line `अधिधनयम के अिीन सूच ना के अधिकार को सुकर बनाता है और सुधन धच त करेगा कक ऐसे सिी अधिलेख, जो कंप्यूटरीकृत`
  line `ककए जाने के धलए समुधचत हैं, युधक्त युक्त समय के िीतर और संसािनों की उपलभ्यता के अिीन रहते हए, कं प् यूटरीकृत और`
  line `धि धिन्द् न प्र णाधलयों पर संपूणण देश में नेटिकण के माध्यम से संबद्ध हैं धजससे कक ऐसे अधिलेख तक पहंच को सु कर बनाया`
  line `जा सके;`
  line `( ख ) इस अधिधनयम के अधिधनयमन से एक सौ बीस कदन के िीतर, —`
  line `(i) अपने संगठन की धिधशधष्ट यां, कृत्य और कतणव्य;`
  line `(ii) अपने अधिकाररयों और कमणचाररयों की शधक्त यां और कतणव्य;`
  line `(iii) धिधनच य करने की प्र कक्रया में पालन की जाने िाली प्र कक्रया धजसमें पयणिेिण और उत्तरदाधयत्ि के`
  line `माध्यम सधमधलत हैं;`
  line `(iv) अपने कृत्यों के धनिणहन के धलए स् ियं द्व ारा स् थाधपत मा नदंड;`
  line `(v) अपने द्व ारा या अपने धनयंत्रणािीन िाररत या अपने कमणचाररयों द्व ारा अपने कृत्यों के धनिणहन के धलए प्र`
  line `योग ककए गए धनयम, धिधनयम, अनुदेश, धनदेधशका और अधिलेख;`
  line `(vi) ऐसे दस्तािेजों के, जो उसके द्व ारा िाररत या उसके धनयंत्रणािीन हैं, प्र िगो का धििरण;`
  line `(vii) ककसी व्य िस्था की धिधशधष्ट यां, जो उसकी नीधत की संरचना या उसके कायाणन्द्ियन के संबंि में`
  line `जनता के सदस्यों से परामशण के धलए या उनके द्व ारा अभ्यािेदन के धलए धिद्यमान हैं;`
  line `(viii) ऐसे बोडों, पररषदों, सधमधतयों और अन्द्य धनकायों के, धजनमें दो या अधिक व् य धक् त हैं, धजनका उसके`
  line `िागरूप में या इस बारे में सलाह देने के प्र योजन के धलए गठन ककया गया है और इस बारे में कक क् या उन बोडों,`
  line `पररषदों, सधमधतयों और अन्द्य धनकायों की बैठकें जनता के धलए खुली होंगी या ऐसी बैठकों के कायणिृत्त तक ज नता`
  line `की पहंच होगी, धििरण;`
  line `(ix) अपने अधिकाररयों और कमणचाररयों की धनदेधशका;`
  line `(x) अपने प्रत् येक अधिकारी और कमण चारी द्व ारा प्र ाप्त माधसक पाररश्रधमक, धजसके अन्द्तगणत प्र धतकर की प्र`
  line `णाली िी है, जो उसके धिधनयमों में यथाउपबंधित हो;`
  line `(xi) सिी योजनाओं, प्रस् ताधित व्य यों और ककए गए संधितरणों पर ररपोटों की धिधशधष्ट यां उपदर्शणत`
  line `करते हए अपने प्रत् येक अधिकरण को आबंरटत बजट;`
  line `(xii) सहाधयकी कायणक्रमों के धनष्पादन की रीधत धजसमें आबंरटत राधश और ऐसे कायणक्रमों के`
  line `फायदाग्राधहयों के ब् यौरे सधमधलत हैं;`
  line `(xiii) अपने द्व ारा अनुदत्त ररयायतों, अनुज्ञापत्रों या प्र ाधिकारों के प्र ाधप्त कताणओं की धिधशधष्ट यां;`
obj_root_law_translations_hi_sections_5_footnotes:
  string
  line
obj_root_law_translations_hi_sections_6:
  kind page
  sectionId pdf-page-6
  sectionNo (6)
  orderNo 6
  title `Page 6`
  content obj_root_law_translations_hi_sections_6_content
  footnotes obj_root_law_translations_hi_sections_6_footnotes
  sourcePage 6
obj_root_law_translations_hi_sections_6_content:
  string
  line 4
  line `(xiv) ककसी इलैक्रा धनक रू प में सूचना के संबंि में ब् यौरे, जो उसको उपलब्ि हों या उसके द्व ारा`
  line `िाररत हों;`
  line `(xv) सूचना अधि प्र ाप्त करने के धलए नागररकों को उपलब्ि सुधििाओं की धिधशधष्ट यां, धजनमें ककसी`
  line `पुस्तकालय या िाचन कि के, यकद लोक उपयोग के धलए अनुरधित हैं तो, कायणक रण घंटे सधमधलत हैं;`
  line `(xvi) लोक सूचना अधिकाररयों के नाम, पदनाम और अन्द्य धिधशधष्ट यां;`
  line `(xvii) ऐसी अन्द्य सूचना, जो धिधहत की जाए, प्र`
  line `काधशत करेगा और तत्प चा त् इन प्र काशनों को प्रत् येक िषण में अद्यतन करेगा;`
  line `( ग ) महत्िपूणण नीधतयों की धिरचना करते समय या ऐसे धिधनच यों की घोषणा करते समय, जो जनता को प्र िाधित`
  line `करते हों, सिी सुसंगत तथ्यों को प्र काधशत करेगा;`
  line `( घ ) प्र िाधित व् य धक् त यों को अपने प्र शासधनक या न्द् याधयककल्प धिधनच यों के धलए कारण उपलब्ि कराएगा।`
  line `(2) प्रत् येक लोक अधिकारी का धनरंतर यह प्र यास होगा कक िह उपिारा (1) के खंड ( ख ) की अपेिाओं के अनुसार, स् िप्रेरणा से,`
  line `जनता को धनयधमत अन्द्तरालों पर संसूचना के धि धिन्द् न सािनों के माध्यम से, धजनके अन्द्तगणत इंटरनेट िी है, इतनी अधिक सूचना`
  line `उपलब्ि कराने के धलए उपाय करे धजससे कक जनता को सूचना प्र ाप्त करने के धलए इस अ धिधनयम का कम से कम अिलंब लेना पडे।`
  line `(3) उपिारा (1) के प्र योजन के धलए, प्रत् येक सूचना को धिस्तृत रू प से और ऐसे प्ररू प और रीधत में प्र साररत ककया जाएगा, जो`
  line `जनता के धलए सहज रू प से पहंच योग्य हो।`
  line `(4) सिी सामग्री को, लागत प्र िािशीलता, स् थानीय िाषा और उस िेत्र में संसूचना की अत्यंत प्र िािी पद्धधत को ध् यान में`
  line `रखते हए, प्र साररत ककया जाएगा तथा सूचना, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी के पास`
  line `इलैक्राधनक रू प में संिि सीमा तक धन: शुल्क या माध्यम की ऐसी लागत पर या ऐसी मुरण लागत की मत पर, जो धिधहत की जाए, स हज रू`
  line `प से पहंच योग्य होनी चाधहए। स्`
  line `प ष् टी करण –– उपिारा (3) और उपिारा (4) के प्र योजनों के धलए, “ प्र साररत ” से सूचना पट्टों, समाचारपत्रों, लोक उद्घोषणाओं,`
  line `मीधडया प्र सारणों, इंटरनेट या ककसी अन्द्य माध्यम से, धजसमें ककसी लोक प्र ाधिकारी के कायाणलयों का धनरीिण सधमधलत है, जनता को`
  line `सूचना की जानकारी देना या संसूधचत कराना अधिप्रेत है।`
  line `5. लोक सूचना अधिकाररयों का पदनाम –– (1) प्रत् येक लोक प्र ाधिकारी, इस अधिधनयम के अधिधनयमन के सौ कदन के िीतर`
  line `सिी प्र शासधनक एककों या उसके अिीन कायाणलयों में, यथाधस्थ धत, केन्द्रीय लोक सूचना अधिकाररयों या राज्य लोक सूचना अधिका ररयों`
  line `के रू प में उतने अधिकाररयों को अधिधहत करेगा, धजतने इस अधिधनयम के अिीन सूचना के धलए अनुरोि करने िाले व् य धक् त यों को`
  line `सूचना प्र दान करने के धलए आियक हों।`
  line `(2) उपिारा (1) के उपबंिों पर प्र धतकू ल प्र िाि डाले धबना, प्रत् येक लोक प्र ाधिकारी, इस अधिधनयम के अधिधनयमन के सौ कदन`
  line `के िीतर ककसी अधिकारी को प्रत् येक उपमंडल स् तर या अन्द्य उप धजला स् तर पर, यथाधस्थधत, केंरीय सहायक लोक सूचना अधिकारी या`
  line `ककसी राज्य सहायक लोक सूचना अधिकारी के रू प में इस अधिधनयम के अ िीन सूचना के धलए आिेदन या अपील प्र ाप्त करने और उसे`
  line `तत्काल, यथाधस्थधत, केंरीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी या िारा 19 की उपिारा (1) के अिीन धि धनर्दण ष् ट`
  line `िररष्ठ अधिकारी या केंरीय सूचना आयोग अथिा राज्य सूचना आयोग को िेजने के धलए, पदाधिधह त करेगा:`
  line `परंतु यह कक जहां सूचना या अपील के धलए कोई आिेदन यथाधस्थधत, ककसी केन्द्रीय सहायक लोक सूचना अधिकारी या ककसी`
  line `राज्य सहायक लोक सूचना अधिकारी को कदया जाता है, िहां िारा 7 की उपिारा (1) के अिीन धि धनर्दणष्ट उत्तर के धलए अिधि की`
  line `संगणना करने में पांच कदन की अिधि जोड दी जाएगी।`
  line `(3) यथाधस्थधत, प्रत् येक केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी, सूचना की मांग करने िाले व् य धक्त यों`
  line `के अनुरोिों पर कारणिाई करेगा और ऐसी सूचना की मांग करने िाले व् य धक् त यों को युधक्त युक्त सहायता प्र दान करेगा।`
  line `( 4) यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी, ऐसे ककसी अन्द्य अधिकारी की सहायता की मांग कर सकेगा, धजसे िह अपने`
  line `कृत्यों के समुधचत धनिणहन के धलए आियक समझे।`
  line `(5) कोई अधिकारी, धजसकी उपिारा (4) के अिीन सहायता चाही गई है, उसकी सहायता चाहने िाले यथाधस्थधत, केन्द्री य`
  line `लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी को सिी सहायता प्र दान करेगा और इस अधिधनयम के उपबंिों के ककसी उल्लंघन`
  line `के प्र योजनों के धलए ऐसे अन्द्य अधिकारी को, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी समझा`
  line जाएगा।
  line `6. सूचना अधि प्र ा प् त करने के धलए अनुरोि –– (1) कोई व् य धक् त, जो इस अधिधनयम के अिीन कोई सूचना अधि प्र ाप्त करना`
  line `चाहता है, धलधखत में या इलैक्राधनक युधि के माध्यम से अंग्रेजी या धहन्द्दी में या उस िेत्र की धजसमें आिेदन ककया जा रहा है, राजिाषा`
  line `में ऐसी फीस के साथ, जो धिधहत की जाए, ––`
obj_root_law_translations_hi_sections_6_footnotes:
  string
  line
obj_root_law_translations_hi_sections_7:
  kind page
  sectionId pdf-page-7
  sectionNo (7)
  orderNo 7
  title `Page 7`
  content obj_root_law_translations_hi_sections_7_content
  footnotes obj_root_law_translations_hi_sections_7_footnotes
  sourcePage 7
obj_root_law_translations_hi_sections_7_content:
  string
  line 5
  line `( क ) संबंधित लोक प्र ाधिकरण के, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी;`
  line `( ख ) यथाधस्थधत, केन्द्रीय सहायक लोक सूचना अधिकारी या राज्य सहायक लोक सूचना अधिकारी,`
  line `को, उसके द्व ारा मांगी गई सूचना की धिधशधष्ट यां धि धनर्दणष्ट करते हए अनुरोि करेगा:`
  line `परंतु जहां ऐसा अनुरोि धलधखत में नहीं ककया जा सकता है, िहां, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक`
  line `सूचना अधिकारी अनुरोि करने िाले व् य धक् त को सिी युधक्त युक्त सहायता मौधखक रू प से देगा, धजससे कक उ से लेखबद्ध ककया जा सके।`
  line `(2) सूचना के धलए अनुरोि करने िाले आिेदक से सूचना का अनुरोि करने के धलए ककसी कारण को या ककसी अन्द्य व् य धक् त गत ब्`
  line `यौरे को, धसिाय उसके जो उससे संपकण करने के धलए आियक हों, देने की अपेिा नहीं की जाएगी।`
  line `(3) जहां, कोई आिेदन ककसी लोक प्र ाधिकारी को ककसी ऐसी सू चना के धलए अनुरोि करते हए ककया जाता है, ––`
  line `(i) जो ककसी अन्द्य लोक प्र ाधिकारी द्व ारा िाररत है; या`
  line `(ii) धजसकी धिषय - िस्तु ककसी अन्द्य लोक प्र ाधिकारी के कृत्यों से अधिक धनकट रू प से संबंधित है,`
  line `िहां, िह लोक प्र ाधिकारी, धजसको ऐसा आिेदन ककया जाता है, ऐसे आिेदन या उ सके ऐसे िाग को, जो समुधचत हो, उस अन्द्य लोक प्र`
  line `ाधिकारी को अंतररत करेगा और ऐसे अंतरण के बारे में आिेदक को तु रं त सूचना देगा:`
  line `परंतु यह कक इस उपिारा के अनुसरण में ककसी आिेदन का अंतरण यथासाध्य शीघ्रता से ककया जाएगा, ककंतु ककसी िी दशा में`
  line `आिेदन की प्र ाधप्त की ता रीख से पांच कदनों के प चा त् नहीं ककया जाएगा।`
  line `7. अनुरोि का धनपटारा –– (1) िारा 5 की उपिारा (2) के परंतुक या िारा 6 की उपिारा (3) के परंतुक के अिीन रहते हए,`
  line `िारा 6 के अिीन अनुरोि के प्र ाप्त होने पर, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूच ना अधिकारी,`
  line `यथासंििशीघ्रता से, और ककसी िी दशा में अनुरोि की प्र ाधप्त के तीस कदन के िीतर, ऐसी फीस के संदाय पर, जो धिधहत की जा ए, या`
  line `तो सूचना उपलब्ि कराएगा या िारा 8 और िारा 9 में धि धनर्दणष्ट कारणों में से ककसी कारण से अनुरोि को अस्िीकार करेगा:`
  line `परंतु जहां मांगी गई जानकारी का संबंि ककसी व् य धक् त के जीिन या स् ितंत्रता से है, िहां िह अनुरोि प्र ा प् त होने के अडतालीस`
  line `घंटे के िीतर उपलब्ि कराई जाएगी।`
  line `(2) यकद, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी उपिारा (1) के अिीन धि धनर्दणष्ट`
  line `अि धि के िीतर सूचना के धलए अनुरोि पर धिधनच य करने में असफल रहता है तो, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य`
  line `लोक सूचना अधिकारी के बारे में यह समझा जाएगा कक उसने अनुरोि को नामंजूर कर कदया है।`
  line `(3) जहां, सूचना उपलब्ि कराने की लागत के रू प में ककसी और फीस के संदाय पर सूचना उपलब्ि कराने का धिधनच य ककया`
  line `जाता है, िहां यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी अनुरोि करने िाले व् य धक् त को, ––`
  line `( क ) उसके द्व ारा यथाअििाररत सूचना उपलब्ि कराने की लागत के रू प में और फीस के ब् यौरे, धजनके साथ उपिारा`
  line `(1) के अिीन धिधहत फीस के अनुसार रकम धनकालने के धलए की गई संगणनाएं होंगी, देते हए उससे उस फीस को जमा करने`
  line `का अनुरोि करते हए कोई संसूचना िेजेगा और उक्त संसूचना के प्रे षण और फीस के संदाय के बीच मध्यिती अिधि को उस`
  line `िारा में धनर्दणष्ट तीस कदन की अिधि की संगणना करने के प्र योजन के धलए अपिर्जणत ककया जाएगा;`
  line `( ख ) प्र िाररत फीस की रकम या उपलब्ि कराई गई पहंच के प्ररू प के बारे में, धजसके अंतगणत अपील प्र ाधिकारी की`
  line `धिधशधष्ट यां, समय - सीमा, प्र कक्रया और कोई अन्द्य प्ररू प िी हैं, धिधनच य करने का पुनर्िणलोकन करने के सं बंि में उसके`
  line `अधिकार से संबंधित सूचना देते हए, कोई संसूचना िेजेगा।`
  line `(4) जहां, इस अधिधनयम के अिीन अधिलेख या उसके ककसी िाग तक पहंच अपेधित है और ऐसा व् य धक् त, धजसको पहंच`
  line `उपलब्ि कराई जानी है, संिेदनात्मक रू प से धन: शक्त है, िहां यथाधस्थधत, केन्द्री य लोक सूचना अधिकारी या राज्य लोक सूच ना`
  line `अधिकारी सूचना तक पहंच को समथण बनाने के धलए सहायता उपलब्ि कराएगा धजसमें धनरीिण के धलए ऐसी सहायता कराना िी`
  line `सधमधलत है, जो समुधचत हो।`
  line `(5) जहां, सूचना तक पहंच मुकरत या ककसी इलैक्राधनक रू पधििान में उपलब्ि करा ई जानी है, िहां आिेदक, उपिारा (6) के`
  line `अिीन रहते हए, ऐसी फीस का संदाय करेगा, जो धिधहत की जाए:`
  line `परन्द्तु िारा 6 की उपिारा (1) और िारा 7 की उपिारा (1) और उपिारा (5) के अिीन धिधहत फीस युधक्त युक्त होगी और`
  line `ऐसे व् य धक् त यों से, जो गरीबी की रेखा के नीचे हैं, जैसा समुधचत सरकार द्व ारा अििाररत ककया जाए, कोई फीस प्र िा ररत नहीं`
  line `की जाएगी।`
  line `(6) उपिारा (5) में ककसी बात के होते हए िी, जहां कोई लोक प्र ाधिकारी उपिारा (1) में धि धनर्दणष्ट समय - सीमा का`
  line `अनुपालन करने में असफल रहता है, िहां सूचना के धलए अनुरोि करने िा ले व् य धक् त को प्र िार के धबना सूचना उपलब्ि कराई जाएगी।`
obj_root_law_translations_hi_sections_7_footnotes:
  string
  line
obj_root_law_translations_hi_sections_8:
  kind page
  sectionId pdf-page-8
  sectionNo (8)
  orderNo 8
  title `Page 8`
  content obj_root_law_translations_hi_sections_8_content
  footnotes obj_root_law_translations_hi_sections_8_footnotes
  sourcePage 8
obj_root_law_translations_hi_sections_8_content:
  string
  line 6
  line `(7) उपिारा (1) के अिीन कोई धिधनच य करने से पूिण, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना`
  line `अधिकारी िारा 11 के अिीन पर व् य धक् त द्व ारा ककए गए अभ्यािेदन को ध् यान में रखेगा।`
  line `(8) जहां, ककसी अनुरोि को उपिारा (1) के अिीन अस्िीकृत ककया गया है, िहां, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी`
  line `या राज्य लोक सूचना अधिकारी अनुरोि करने िाले व् य धक् त को, ––`
  line `(i) ऐसी अस्िीकृधत के धलए कारण;`
  line `(ii) िह अिधि, धजसके िीतर ऐसी अस्िीकृधत के धिरुद्ध कोई अपील की जा सकेगी; और`
  line `(iii) अपील प्र ाधिकारी की धिधशधष्ट यां,`
  line `संसूधचत करेगा।`
  line `(9) ककसी सूचना को सािारणतया उसी प्ररू प में उपलब्ि कराया जाएगा, धजसमें उसे मांगा गया है, जब तक कक िह लोक प्र`
  line `ाधिकारी के स्र ो तों को अननुपाती रू प से धिचधलत न करता हो या प्र न गत अधिलेख की सुरिा या संरिण के प्र धतकूल न हो।`
  line `8. सूचना के प्र कट ककए जाने से छूट — ( 1 ) इस अधिधनयम में अंतर्िणष्ट ककसी बात के होते हए िी, ककसी नागररक को`
  line `धनन धलधखत सूचना देने की बाध्यता नहीं होगी —`
  line `( क ) सूचना, धजसके प्र कटन से िारत की प्र िुता और अखण्डता, राज्य की सुरिा, रणनीधत, िैज्ञाधनक या आर्थणक`
  line `धहत, धिदेश से संबंि पर प्र धतकूल प्र िाि पडता हो या ककसी अपराि को करने का उद्दीपन होता हो;`
  line `( ख ) सूचना, धजसके प्र काशन को ककसी न्द् यायालय या अधिकरण द्व ारा अधिव्यि रू प से धनधषद्ध ककया गया है या`
  line `धजसके प्र कटन से न्द् यायालय का अिमान होता है;`
  line `( ग ) सूचना, धजसके प्र कटन से संसद् या ककसी राज्य के धििान - मंडल के धिशेषाधिकार का िंग काररत होगा;`
  line `( घ ) सूचना, धजसमें िाधणधज्यक धि िा स, व्य ापार गोपनीयता या बौधद्धक संपदा सधमधलत है, धजसके प्र कटन से`
  line `ककसी पर व् य धक् त की प्र धतयोगी धस्थधत को नुकसान होता है, जब तक कक सिम प्र ाधिकारी का यह समािान नहीं हो जाता है`
  line `कक ऐसी सूचना के प्र कटन से धिस्तृत लोक धहत का समथणन होता है;`
  line `( ङ ) ककसी व् य धक् त को उसकी िै िा धसक नातेदारी में उपलब्ि सूचना, जब तक कक सिम प्र ाधिकारी का यह समािान`
  line `नहीं हो जाता है कक ऐसी सूच ना के प्र कटन से धिस्तृत लोक धहत का समथणन होता है;`
  line `( च ) ककसी धिदेशी सरकार से धि िा स में प्र ाप्त सूचना;`
  line `( छ ) सूचना धजसको प्र कट करना ककसी व् य धक् त के जीिन या शारीररक सुरिा को खतरे में डालेगा या जो धिधि प्र`
  line `ितणन या सुरिा प्र योजनों के धलए धि िा स में दी गई ककसी सूचना या सहायता के स्र ोत की पहचान करेगा;`
  line `( ज ) सूचना, धजससे अपराधियों के अन्द्िेषण, पकडे जाने या अधियोजन की प्र कक्रया में अडचन पडेगी;`
  line `( झ ) मंधत्रमंडल के कागजपत्र, धजसमें मंधत्रपररषद्, सधचिों और अन्द्य अधिकाररयों के धिचार - धिमशण के अधिलेख`
  line `सधमधल त हैं:`
  line `परन्द्तु यह कक मंधत्रपररषद् के धिधनच य, उनके कारण तथा िह सामग्री, धजसके आिार पर धिधनच य ककए गए थे, धि धनच य`
  line `ककए जाने और धिषय के पूरा या समाि होने के प चा त् जनता को उपलब्ि कराए जाएंगे:`
  line `परन्द्तु यह और कक िे धिषय जो इस िारा में धि धनर्दणष्ट छू टों के अंतगणत आते हैं, प्र कट नहीं ककए जाएंगे;`
  line `( ञ ) सूचना, जो व् य धक् त गत सूचना से संबंधित है, धजसका प्र कटन ककसी लोक कक्रयाकलाप या धहत से संबंि नहीं`
  line `रखता है या धजससे व् य धष्ट की एकांतता पर अनाियक अधतक्रमण होगा, जब तक कक, यथाधस्थधत, केन्द्रीय लो क सूचना`
  line `अ धिकारी या राज्य लोक सूचना अधिकारी या अपील प्र ाधिकारी का यह समािान नहीं हो जाता है कक ऐसी सूचना का प्र कटन`
  line `धिस्तृत लोक धहत में न्द् यायोधचत है:`
  line `परन्द्तु ऐसी सूचना के धलए, धजसको, यथाधस्थधत, संसद् या ककसी राज्य धििान - मंडल को देने से इंकार नहीं ककया जा सक ता है,`
  line `ककसी व् य धक् त को इंकार नहीं ककया जा सकेगा।`
  line `(2) शासकीय गुप्त बात अधिधनयम, 1923 (1923 का 19) में, उपिारा (1) के अनुसार अनुज्ञेय ककसी छूट में ककसी बात के होते`
  line `हए िी, ककसी लोक प्र ाधिकारी को सूचना तक पहंच अनुज्ञात की जा सकेगी, यकद सूचना के प्र कटन में लोक धहत, संरधित धहतों के`
  line `नुकसान से अधिक है।`
  line `(3) उपिारा (1) के खण्ड ( क ), खंड ( ग ) और खण्ड ( झ ) के उपबंिों के अिीन रहते हए, ककसी ऐसी घटना, िृत्तांत या धिषय से`
  line `संबंधित कोई सूचना, जो उस तारीख से, धजसको िारा 6 के अिीन कोई अनुरोि ककया जाता है, बीस िषण पूिण घरटत हई थी या हआ था,`
  line `उस िारा के अिीन अनुरोि करने िाले ककसी व् य धक् त को उपलब्घ कराई जाएगी:`
obj_root_law_translations_hi_sections_8_footnotes:
  string
  line
obj_root_law_translations_hi_sections_9:
  kind page
  sectionId pdf-page-9
  sectionNo (9)
  orderNo 9
  title `Page 9`
  content obj_root_law_translations_hi_sections_9_content
  footnotes obj_root_law_translations_hi_sections_9_footnotes
  sourcePage 9
obj_root_law_translations_hi_sections_9_content:
  string
  line 7
  line `परन्द्तु यह कक जहां उस तारीख के बारे में, धजससे बीस िषण की उक्त अिधि को संगधणत ककया जाता है, कोई प्र न उद्िूत होता`
  line `है, िहां इस अधिधनयम में उसके धलए उपबंधित प्र ाधयक अपीलों के अिीन रहते हए केन्द्रीय सरकार का धिधनच य अंधतम होगा।`
  line `9. कधतपय मामलों में पहंच के धलए अस्िीकृधत के आिार — िारा 8 के उपबन्द्िों पर प्र धतकूल प्र िाि डाले धबना, यथाधस्थधत,`
  line `कोई केन्द्रीय लोक सूचना अधिकारी या कोई राज्य लोक सूचना अधिकारी सूचना के ककसी अनुरोि को िहां अस्िीकार कर सकेगा, जहां`
  line `पहंच उपलब्ि कराने के धलए ऐसा अनुरोि राज्य से धिन्द् न ककसी व् य धक् त के अधस्त त् ि युक्त प्र धतधलप्यधिकार का उल्लंघन अन्द्तिणधलत`
  line करेगा।
  line `10. पृथक्क रणीयता — ( 1 ) जहां सूचना तक पहंच के अनुरोि को इस आिार पर अस्िीकार ककया जाता है कक िह ऐसी सूचना`
  line `के संबंि में है, जो प्र कट ककए जाने से छूट प्र ाप्त है, िहां इस अधिधनयम में ककसी बात के होते हए िी, पहंच अधिलेख के उस िाग तक`
  line `उपलब्ि कराई जा सकेगी धजसमें कोई ऐसी सूचना अन्द्त र् िणष्ट नहीं है, जो इस अधिधनयम के अिीन प्र कट ककए जाने से छूट प्र ा प् त है और`
  line `जो ककसी ऐसे िाग से, धजसमें छूट प्र ाप्त सूचना अन्द्त र् िणष्ट है, युधक्त युक्त रू प से पृथक्त की जा सकती है।`
  line `( 2 ) जहां उपिारा ( 1 ) के अिीन अधिलेख के ककसी िाग तक पहंच अनुदत्त की जाती है, िहां, यथाधस्थधत, केन्द्रीय लोक सूचना`
  line `अधिकारी या राज्य लोक सूचना अधिकारी धनन धलधखत सूचना देते हए, आिेदक को एक सूचना देगा कक —`
  line `( क ) अनुरोि ककए गए अधिलेख का केिल एक िाग ही, उस अधिलेख से उस सूचना को जो प्र कटन से छूट प्र ाप्त है`
  line `पृथक्त करने के प चा त्, उपलब्ि कराया जा रहा है;`
  line `( ख ) धिधनच य के धलए कारण, धजनके अंतगण त तथ्य के ककसी महत्िपूणण प्र न पर उस सामग्री के प्र धत, धजस पर िे`
  line `धनष्कषण आिाररत थे, धनदेश करते हए कोई धनष्कषण िी हैं;`
  line `( ग ) धिधनच य करने िाले व् य धक् त का नाम और पदनाम;`
  line `( घ ) उसके द्व ारा संगधणत फीस के ब् यौरे और फीस की िह रकम धजसकी आिेदक से धनिेप करने की अपेिा की जाती`
  line `है; और`
  line `( ङ ) सूचना के िाग को प्र कट न ककए जाने के संबंि में धिधनच य के पुनर्िणलोकन के बारे में उसके अधिकार, प्र िाररत`
  line `फीस की रकम या उपलब्ि कराया गया पहंच का प्ररू प, धजसके अन्द्तगणत, यथाधस्थधत, िारा 19 की उपिारा (1) के अिीन`
  line `धि धनर्दणष्ट िररष्ठ अधिकारी या केन्द्रीय सूचना अधिकारी या राज्य सूचना अधिकारी की धिधशधष्ट यां, समय - सीमा, प्र कक्रया`
  line `और कोई अन्द्य पहंच का प्ररू प िी है।`
  line `11. पर व् य धक्त सूचना — ( 1 ) जहां, यथाधस्थधत, ककसी केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी का, इस`
  line `अ धिधनयम के अिीन ककए गए अनुरोि पर कोई ऐसी सूचना या अधिलेख या उसके ककसी िाग को प्र कट करने का आशय है, जो ककसी पर व्`
  line `य धक् त से संबंधित है या उसके द्व ारा इसका प्र दाय ककया गया है और उस पर व् य धक् त द्व ारा उसे गोपनी य माना गया है, िहां, यथाधस्थधत,`
  line `केन्द्रीय लोक सूच ना अधिकारी या राज्य लोक सूचना अधिकारी अनुरोि प्र ाप्त होने से पांच कदन के िीतर, ऐसे पर व् य धक्त को अनुरोि की`
  line `और इस तथ्य की धलधखत रू प में सूचना देगा कक, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी का उक्त`
  line `सूचना या अधिलेख या उसके ककसी िाग को प्र कट करने का आशय है, और इस बारे में कक सूचना प्र कट की जानी चाधहए या नहीं,`
  line `धलधखत में या मौधखक रू प से धनिेदन करने के धलए पर व् य धक् त को आमंधत्रत करेगा तथा सूचना के प्र कटन के बारे में कोई धिधनच य करते`
  line `समय पर व् य धक् त के ऐसे धनिेदन को ध् यान में रखा जाएगा:`
  line `परन्द्तु धिधि द्व ारा संरधित व्य ापार या िाधणधज्यक गुप्त बातों की दशा में के धसिाय, यकद ऐसे प्र कटन में लोकधह त, ऐसे पर व्`
  line `य धक् त के धहतों की ककसी संिाधित अपहाधन या िधत से अधिक महत्िपूणण है तो प्र कटन अनुज्ञात ककया जा सकेगा।`
  line `(2) जहां उपिारा (1) के अिीन, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी द्व ारा पर व् य धक् त`
  line `पर ककसी सूचना या अधिलेख या उसके ककसी िाग के बारे में ककसी सूचना की तामील की जाती है, िहां ऐसे पर व् य धक् त को, ऐसी सूचना`
  line `की प्र ाधप्त की तारीख से दस कदन के िीतर, प्रस् ताधित प्र कटन के धिरुद्ध अभ्यािेदन करने का अिसर कदया जाएगा।`
  line `(3) िारा 7 में ककसी बात के होते हए िी, यथाधस्थधत, केन्द्रीय लोक सूचना अधिकारी या राज्य लोक सूचना अधिकारी िारा 6`
  line `के अिीन अनुरोि प्र ाप्त होने के पचा त् चालीस कदन के िीतर, यकद पर व् य धक् त को उपिारा ( 2 ) के अिीन अभ्या िेदन करने का अिसर दे`
  line `कदया गया है, तो इस बारे में धिधनच य करेगा कक उक्त सूचना या अधिलेख या उसके िाग का प्र कटन ककया जाए या नहीं और अ पने`
  line `धिधनच य की सूचना धलधखत में पर व् य धक् त को देगा।`
  line `(4) उपिारा (3) के अिीन दी गई सूचना में यह कथन िी सधमधलत होगा कक िह पर व् य धक्त, धजसे सूचना दी गई है, िारा 19`
  line `के अिीन उक्त धिधनच य के धिरुद्ध अपील करने का हकदार है।`
  line `अध्याय 3`
  line `केन्द्रीय सूचना आयोग`
  line `12. केन्द्रीय सूचना आयोग का गठन — ( 1 ) केन्द्रीय सरकार, राजपत्र में अधिसूचना द्व ारा, केन्द्रीय सूचना आयोग के नाम से ज्ञ ात`
  line `एक धनकाय का गठन करेगी, जो ऐसी शधक्त यों का प्र योग और ऐसे कृत्यों का पालन करेगा, जो उसे इस अधिधनयम के अिीन सौंपे जा एं।`
obj_root_law_translations_hi_sections_9_footnotes:
  string
  line
obj_root_law_translations_hi_sections_10:
  kind page
  sectionId pdf-page-10
  sectionNo (10)
  orderNo 10
  title `Page 10`
  content obj_root_law_translations_hi_sections_10_content
  footnotes obj_root_law_translations_hi_sections_10_footnotes
  sourcePage 10
obj_root_law_translations_hi_sections_10_content:
  string
  line 8
  line `(2) केन्द्रीय सूचना आयोग धनन धलधखत से धमलकर बनेगा —`
  line `( क ) मुख्य सूचना आयुक्त; और`
  line `( ख ) दस से अनधिक उतनी संख्या में केन्द्रीय सूचना आयुक्त, धजतने आियक समझे जाएं।`
  line `(3) मुख्य सूचना आयुक्त और सूचना आयुक्तों की धनयुधक् त, रा ष् र पधत द्व ारा धनन धलधखत से धमलकर बनी सधमधत की`
  line `धसफाररश पर की जाएगी —`
  line `(i) प्र िानमंत्री, जो सधमधत का अध्यि होगा;`
  line `(ii) लोकसिा में धिपि का नेता; और`
  line `(iii) प्र िानमंत्री द्व ारा नाम धनर्दणष्ट संघ मंधत्रमण्डल का एक मंत्री। स्`
  line `प ष् टी करण — शंकाओं के धनिारण के प्र योजन के धलए यह घोधषत ककया जाता है कक जहां लोक सिा में धिपि के नेता को उस रू`
  line `प में मान्द्यता नहीं दी गई है, िहां लोक सिा में सरकार के धिपिी एक ल सबसे बडे समूह के नेता को धिपि का नेता समझा जाएगा।`
  line `(4) केन्द्रीय सूचना आयोग के कायों का सािारण अिीिण, धनदेशन और प्र बंिन, मुख्य सूचना आयुक्त में धनधहत होगा, धजसकी`
  line `सहायता सूचना आयुक्तों द्व ारा की जाएगी और िह ऐसी सिी शधक्त यों का प्र योग और ऐसे सिी कायण और बातें कर सकेगा, धज नका`
  line `केन्द्रीय सूचना आयोग द्व ारा स् ितंत्र रू प से इस अधिधनयम के अिीन ककसी अन्द्य प्र ाधिकारी के धनदेशों के अिीन रहे धबना प्र योग ककया जा`
  line `सकता है या जो की जा सकती है।`
  line `(5) मुख्य सूचना आयुक्त और सूचना आयुक्त धिधि, धिज्ञान और प्र ौद्योधग की, समाज सेिा, प्र बंि, पत्रकाररता, जनसंपकण`
  line `माध्यम या प्र शासन तथा शासन का व्य ापक ज्ञ ान और अनुिि रखने िाले जनजीिन में प्रख् यात व् य धक् त होंगे।`
  line `(6) मुख्य सूचना आयुक्त या कोई सूचना आयुक्त, यथाधस्थधत, संसद् का सदस्य या ककसी राज्य या संघ राज्यिेत्र के`
  line `धििान - मंडल का सदस्य नहीं होगा या कोई अन्द्य लाि का पद िाररत नहीं करेगा या ककसी राजनैधतक दल से संबद्ध नहीं होगा अथिा`
  line `कोई कारबार नहीं करेगा या कोई िृधत्त नहीं करेगा।`
  line `(7) केन्द्रीय सूचना आयोग का मुख्यालय, कदल्ली में होगा और केन्द्रीय सूचना आयोग, केन्द्रीय सर कार के पूिण अनुमोदन से,`
  line `िारत में अन्द्य स् थानों पर कायाणलय स् थाधपत कर सकेगा।`
  line `13. पदािधि और सेिा शतें — (1) मुख्य सूचना आयुक्त, 1 [ ऐसी अिधि के धलए जो केन्द्री य सरकार द्व ारा धिधहत की जाए ] पद`
  line `िारण करेगा और पुनर्नणयुधक्त के धलए पात्र नहीं होगा:`
  line `परन्द्तु यह कक कोई मुख्य सूचना आयुक्त पैंसठ िषण की आयु प्र ाप्त करने के प चा त् उस रू प में पद िारण न हीं करेगा।`
  line `(2) प्रत् येक सूचना आयुक्त, 1 [ ऐसी अिधि के धलए जो केन्द्री य सरकार द्व ारा धिधहत की जाए ] या पैंसठ िषण की आयु प्र ाप्त करने`
  line `तक, इनमें से जो िी पूिणतर हो, पद िारण करेगा और ऐसे सूचना आयुक्त के रू प में पुनर्नणयुधक्त के धलए पात्र नहीं हो गा:`
  line `परन्द्तु प्रत् येक सूचना आयुक्त, इस उपिारा के अिीन अपना पद ररि करने पर, िारा 12 की उपिारा (3) में धि धनर्दण ष् ट रीधत से`
  line `मुख्य सूचना आयुक्त के रू प में धनयुधक् त के धलए पा त्र होगा:`
  line `परन्द्तु यह और कक जहां सूचना आयुक्त को मुख्य सूचना आयुक्त के रू प में धनयुक्त ककया जाता है िहां उसकी पदा िधि सूचना`
  line `आयुक्त और मुख्य सूचना आयुक्त के रू प में कुल धमलाकर पांच िषण से अधिक नहीं होगी।`
  line `(3) मुख्य सूचना आयुक्त या कोई सूचना आयुक्त, अ पना पद ग्र हण करने से पूिण रा ष् र पधत या उ स के द्व ारा इस धनधमत्त प्र ाधिकृत`
  line `ककसी अन्द्य व् य धक् त के समि, पहली अनुसूची में इस प्र योजन के धलए उपिर्णणत प्ररू प के अनुसार एक शपथ या प्र धत ज्ञ ान लेगा और उस पर`
  line `हस्तािर करेगा।`
  line `(4) मुख्य सूचना आयुक्त या कोई सूचना आयुक्त, ककसी िी समय, रा ष् र पधत को संबोधित अपने हस्तािर सधहत लेख द्व ारा`
  line `अपना पद त् याग सकेगा:`
  line `परन्द्तु मुख्य सूचना आयुक्त या ककसी सूचना आयुक्त को िारा 14 में धि धनर्दणष्ट रीधत से हटाया जा सकेगा।`
  line `1 [(5) मुख्य सूचना आयुक्त और सूचना आयुक्तों को संदेय िेतन और ित्ते तथा सेिा के अन्द्य धनबंिन और शतें, िे होंगी, जो`
  line `केन्द्री य सराकर द्व ारा धिधहत की जाएं:`
  line `परन्द् तु मुख्य सूचना आयुक्त या सूचना आयुक्तों के िेतन, ित्तों और सेिा की अन्द्य शतों में, उनकी धनयुधक् त के प चा त्, उनके`
  line `धलए अलािकर रू प से कोई पररि तणन नहीं ककया जाएगा:`
  line `1 2019 के अधिधनयम सं ० 24 की िारा 2 द्व ारा प्र धतस्था धपत।`
obj_root_law_translations_hi_sections_10_footnotes:
  string
  line
obj_root_law_translations_hi_sections_11:
  kind page
  sectionId pdf-page-11
  sectionNo (11)
  orderNo 11
  title `Page 11`
  content obj_root_law_translations_hi_sections_11_content
  footnotes obj_root_law_translations_hi_sections_11_footnotes
  sourcePage 11
obj_root_law_translations_hi_sections_11_content:
  string
  line 9
  line `परंतु यह और कक सूचना का अधिकार ( संशोिन ) अधिधनयम, 2019 के प्र ारंि से पूिण धनयुक्त मुख्य सूचना आयुक्त और सूचना`
  line `आयुक्तों का इस अधिधनयम और तद्धीन बनाए गए धनयमों के उपबंिों द्व ारा शाधसत होना उसी प्र कार जारी रहेगा मानो सूचना का`
  line `अधिका र ( संशोिन ) अधिधनयम, 2019 लागू ही नहीं हआ था। ]`
  line `14. सूचना आयुक्त या मुख्य सूचना आयुक्त का हटाया जाना — ( 1 ) उपिारा ( 3 ) के उपबंिों के अिीन रहते हए, मुख्य सूचना`
  line `आयुक्त या ककसी सूचना आयुक्त को रा ष् र पधत के आदेश द्व ारा साधबत कदाचार या असमथणता के आिार पर उसके पद से तिी हटाया`
  line `जाएगा, जब उच्च तम न्द् यायालय ने, रा ष् र पधत द्व ारा उसे ककए गए ककसी धनदेश पर जांच के पचा त् यह ररपोटण दी हो कक, यथाधस्थधत,`
  line `मुख्य सूचना आयुक्त या सूचना आयुक्त को उस आिार पर हटा कदया जाना चाधहए।`
  line `( 2 ) रा ष् र पधत, उस मुख्य सूचना आयु क् त या सूचना आयुक्त को, धजसके धिरुद्ध उपिारा ( 1 ) के अिीन उच्च तम न्द् यायालय को`
  line `धनदेश ककया गया है, ऐसे धनदेश पर उच्च तम न्द् यायालय की ररपोटण प्र ाप्त होने पर रा ष् र पधत द्व ारा आदेश पा ररत ककए जाने तक पद से`
  line `धनलंधबत कर सकेगा और यकद आियक समझे तो, जांच के दौरान कायाणलय में उपधस्थत होने से िी प्र धतधषद्ध कर सकेगा।`
  line `( 3 ) उपिारा ( 1 ) में अंतर्िणष्ट ककसी बात के होते हए िी रा ष् र पधत, मुख्य सूचना आयुक्त या ककसी सूचना आयुक्त को आदेश द्व`
  line `ारा पद से हटा सकेगा, यकद, यथाधस्थधत, मुख्य सूचना आयुक्त या सूचना आयुक्त, —`
  line `( क ) कदिाधलया न्द् यायधनणीत ककया गया है; या`
  line `( ख ) िह ऐसे अपराि के धलए दोषधसद्ध ठहराया गया है, धजसमें रा ष् र पधत की राय में, नैधतक अिमता अन्द्तिणधलत`
  line `है; या`
  line `( ग ) अपनी पदािधि के दौरान, अपने पद के कतणव्यों से परे ककसी िैतधनक धनयोजन में लगा हआ है; या`
  line `( घ ) रा ष् र पधत की राय में, मानधसक या शारीररक अिमता के कारण पद पर बने रहने के अयोग्य है; या`
  line `( ङ ) उसने ऐसे धित्तीय और अन्द्य धहत अर्जणत ककए हैं, धजनसे मुख्य सूचना आयुक्त या ककसी सूचना आयुक्त के रू प में`
  line `उसके कृत्यों पर प्र धतकूल प्र िाि पडने की संिािना है।`
  line `( 4 ) यकद मुख्य सूचना आयुक्त या कोई सूचना आयुक्त, ककसी प्र कार िारत सरकार द्व ारा या उसकी ओर से की गई ककसी`
  line `संधिदा या करार से संबद्ध या उसमें धहतबद्ध है या ककसी धनगधमत कंपनी के ककसी सदस्य के रू प में से अन्द्यथा और उसके अन्द्य स दस्यों के`
  line `साथ सामान्द्यतः उसके लाि में या उससे प्र ोद्िूत होने िाले ककसी फायदे या पररलधब्ियों में धहस्सा लेता है तो िह, उपिारा ( 1 ) के प्र`
  line `योजनों के धलए, कदाचार का दोषी समझा जाएगा।`
  line `अध्याय 4`
  line `राज्य सूचना आयोग`
  line `15. राज्य सूचना आयोग का गठन — (1) प्रत् येक राज्य सरकार राजपत्र में अधिसूचना द्व ारा............. ( राज्य का नाम ) सूचना`
  line `आयोग के नाम से ज्ञ ात एक धनकाय का गठन करेगी, जो ऐसी शधक्त यों का प्र योग और ऐसे कृत्यों का पालन करेगा, जो उसे इस अ धिधनयम`
  line `के अिीन सौंपे जाएं।`
  line `(2) राज्य सूचना आयोग धनन धलधखत से धमलकर बनेगा —`
  line `( क ) राज्य मुख्य सूचना आयुक्त; और`
  line `( ख ) दस से अनधिक उतनी संख्या में राज्य सूचना आयुक्त, धजतने आियक समझे जाएं।`
  line `(3) राज्य मुख्य सूचना आयुक्त और राज्य सूचना आयुक्तों की धनयुधक्त राज्यपाल द्व ारा धनन धलधखत से धमलकर बनी ककसी`
  line `सधमधत की धसफाररश पर की जाएगी, —`
  line `(i) मुख्यमंत्री, जो सधमधत का अध्यि हो गा;`
  line `(ii) धििान सिा में धिपि का नेता; और`
  line `(iii) मुख्यमंत्री द्व ारा नामधनदेधशत ककया जाने िाला मंधत्रमंडल का सदस्य। स्`
  line `प ष् टी करण — शंकाओं को दूर करने के प्र योजनों के धलए यह घोधषत ककया जाता है कक जहां धििान सिा में धिपिी द ल के नेता`
  line `को उस रू प में मान्द्यता नहीं दी गई है, िहां धििान सिा में सरकार के धिपिी एकल सबसे बडे समूह के नेता को धिपिी दल का नेता`
  line `समझा जाएगा।`
  line `(4) राज्य सूचना आयोग के कायों का सािारण अिीिण, धनदेशन और प्र बंि राज्य मुख्य सूचना आयुक्त में धनधहत होगा,`
  line `धजसकी राज्य सूचना आयुक्तों द्व ा रा सहायता की जाएगी और िह सिी ऐसी शधक्त यों का प्र योग कर सकेगा और सिी ऐसे कायण और बातें`
  line `कर सकेगा जो राज्य सूचना आयोग द्व ारा इस अधिधनयम के अिीन ककसी अन्द्य प्र ाधिकारी के धनदेशों के अध्यिीन रहे धबना स् ितंत्र रू प से प्र`
  line `योग की जा सकती हैं या की जा सकती हैं।`
obj_root_law_translations_hi_sections_11_footnotes:
  string
  line
obj_root_law_translations_hi_sections_12:
  kind page
  sectionId pdf-page-12
  sectionNo (12)
  orderNo 12
  title `Page 12`
  content obj_root_law_translations_hi_sections_12_content
  footnotes obj_root_law_translations_hi_sections_12_footnotes
  sourcePage 12
obj_root_law_translations_hi_sections_12_content:
  string
  line 10
  line `(5 ) राज्य मुख्य सूचना आयुक्त और राज्य सूचना आयुक्त धिधि, धिज्ञान और प्र ौद्योधगकी, समाजसेिा, प्र बंि, पत्रकाररता,`
  line `जनसंपकण माध्यम या प्र शासन और शासन में व्य ापक ज्ञ ान और अनुिि िाले समाज में प्रख् यात व् य धक् त होंगे।`
  line `(6) राज्य मुख्य सूचना आयुक्त या राज्य सूच ना आयुक्त, यथाधस्थधत, संसद् का सदस्य या ककसी राज्य या संघ राज्यिेत्र के`
  line `धििान - मंडल का सदस्य नहीं होगा या कोई अन्द्य लाि का पद िारण नहीं करेगा या ककसी राजनीधतक दल से संबद्ध नहीं होगा या कोई`
  line `कारबार नहीं करेगा या कोई िृधत्त नहीं करेगा।`
  line `(7) राज्य सूचना आयोग का मुख्यालय राज्य में ऐसे स् थान पर होगा, धजसे राज्य सरकार राजपत्र में अधिसूचना द्व ारा`
  line `धि धनर्दणष्ट करे और राज्य सूचना आयोग, राज्य सरकार के पूिण अनुमोदन से, राज्य में अन्द्य स् थानों पर अपने कायाणलय स् था धपत कर`
  line सकेगा।
  line `16. पदािधि और सेिा की शतें — (1) राज्य मुख्य सूचना आयुक्त 1 [ ऐसी अिधि के धलए जो केन्द्री य सरकार द्व ारा धिधहत की`
  line `जाए ] पद िारण करेगा और पुनर्नणयुधक्त के धलए पात्र नहीं होगा:`
  line `परन्द्तु कोई राज्य मुख्य सूचना आयुक्त पैंसठ िषण की आयु प्र ाप्त करने के प चा त् उस रू प में पद िारण न हीं करेगा।`
  line `(2) प्रत् येक राज्य सूचना आयुक्त 1 [ ऐसी अिधि के धलए जो केन्द्री य सरकार द्व ारा धिधहत की जाए ] या पैंसठ िषण की आयु प्र ाप्त`
  line `करने तक, इनमें से जो िी पूिणतर हो, पद िारण करेगा और राज्य सूचना आयुक्त के रू प में पुनर्नणयुधक्त के धलए पात्र नहीं होगा:`
  line `परन्द्तु प्रत् ये क राज्य सूचना आयुक्त, इस उपिारा के अिीन अपना पद ररि करने पर, िारा 15 की उपिारा (3) में धि धनर्दणष्ट`
  line `रीधत से राज्य मुख्य सूचना आयुक्त के रू प में धनयुधक्त के धलए पात्र होगा:`
  line `परन्द्तु यह और कक जहां राज्य सूचना आयुक्त की राज्य मुख्य सूचना आयुक्त के रू प में धनयुधक्त की जाती है, िहां उसकी`
  line `पदािधि राज्य सूचना आयुक्त और राज्य मुख्य सूचना आयुक्त के रू प में कुल धमलाकर पांच िषण से अधिक नहीं होगी।`
  line `(3) राज्य मुख्य सूचना आयुक्त या कोई राज्य सूचना आयुक्त अपना पद ग्र हण करने से पूिण राज्यपाल या इस धनधमत्त उ सके द्व`
  line `ारा धनयुक्त ककए गए ककसी अन्द्य व् य धक् त के समि पहली अनुसूची में इस प्र योजन के धलए उपिर्णणत प्ररू प के अनुसार शपथ या प्र`
  line `धतज्ञान लेगा और उस पर अपने हस्तािर करेगा।`
  line `(4) राज्य मुख्य सूचना आयुक्त या कोई राज्य सूचना आयुक्त, ककसी िी समय, राज्यपाल को सं बोधित अपने हस्तािर सधहत`
  line `लेख द्व ारा अपने पद का त् याग कर सकेगा:`
  line `परन्द्तु राज्य मुख्य सूचना आयुक्त या ककसी राज्य सूचना आयुक्त को िारा 17 में धि धनर्दणष्ट रीधत से हटाया जा सकेगा।`
  line `1 [(5) राज्य मुख्य सूचना आयुक्त और राज्य सूचना आयुक्तों को संदेय िेतन और ित्ते तथा सेिा के अन्द्य धनबंिन और शतें, िे`
  line `होंगी, जो केन्द्री य सराकर द्व ारा धिधहत की जाएं:`
  line `परन्द् तु राज्य मुख्य सूचना आयुक्त या राज्य सूचना आयुक्तों के िेतन, ित्तों और सेिा की अन्द्य शतों में, उ नकी धनयुधक् त के`
  line `प चा त् उनके धलए अलािकर रू प से कोई पररितणन नहीं ककया जाएगा:`
  line `परंतु यह और कक सूचना का अधिकार ( संशोिन ) अधिधनयम, 2019 के प्र ारंि से पूिण धनयुक्त राज्य मुख्य सूचना आयुक्त और`
  line `राज्य सूचना आयुक्तों का इस अधिधनयम और तद्धीन बनाए गए धनयमों के उपबंिों द्व ारा शाधसत होना उसी प्र कार जारी रहे गा मानो`
  line `सूचना का अधिकार ( संशोिन ) अधिधनयम, 2019 लागू ही नहीं हआ था। ]`
  line `(6) राज्य सरकार, राज्य मुख्य सूचना आयुक्त और राज्य सूचना आयुक्तों को उतने अधिकारी और कमणचारी उपलब्ि कराएगी,`
  line `धजतने इस अधिधनयम के अिीन उनके कृत्यों के दि पालन के धलए आियक हों और इस अधिधनयम के प्र योजन के धलए धनयुक्त ककए गए`
  line `अधिकाररयों और अन्द्य कमणचाररयों को संदेय िेतन और ित्ते तथा सेिा के धनबंिन और शतें ऐसी होंगी, जो धिधहत की जाएं।`
  line `17. राज्य मुख्य सूचना आयुक्त या राज्य सूचना आयुक्त का हटाया जाना — (1) उपिारा (3) के उपबंिों के अिीन रहते हए,`
  line `राज्य मुख्य सूचना आयुक्त या ककसी राज्य सूचना आयुक्त को राज्यपाल के आदेश द्व ारा साधबत कदाचार या असमथणता के आिा र पर`
  line `उसके पद से तिी हटाया जाएगा, जब उच्च तम न्द् यायालय ने, राज्यपाल द्व ारा उसे ककए गए ककसी धनदेश पर जांच के प चा त् यह ररपोटण`
  line `दी हो कक, यथाधस्थधत, राज्य मुख्य सूचना आयुक्त या राज्य सूचना आयुक्त को उस आिार पर हटा कदया जाना चाधहए।`
  line `(2) राज्यपाल, उस राज्य मुख्य सूचना आयुक्त या राज्य सूचना आयुक्त को, धजसके धिरुद्ध उपिारा (1) के अिीन उच्च तम न्द्`
  line `यायालय को धनदेश ककया गया है, ऐसे धनदेश पर उच्च तम न्द् यायालय की ररपोटण की प्र ाधप्त पर राज्यपाल द्व ारा आ देश पाररत ककए जाने`
  line `तक, पद से धनलंधबत कर सकेगा और यकद आियक समझे तो ऐसी जांच के दौरान कायाणलय में उपधस्थत होने से प्र धतधषद्ध िी`
  line `कर सकेगा।`
  line `(3) उपिारा (1) में अंतर्िणष्ट ककसी बात के होते हए िी राज्यपाल, राज्य मुख्य सूचना आयुक्त या ककसी राज्य सूचना आयुक्त`
  line `को, आदेश द्व ारा, पद से हटा सकेगा, यकद, यथाधस्थधत, राज्य मुख्य सूचना आयुक्त या राज्य सूचना आयुक्त —`
  line `1 2019 के अधिधनयम सं ० 24 की िारा 3 द्व ारा प्र धतस्था धपत।`
obj_root_law_translations_hi_sections_12_footnotes:
  string
  line
