obj_root_law:
  object
  (str slug) (str the-right-to-information-act-2005)
  (str handle) (str 2065)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Right to Information Act, 2005`)
  (str actNumber) (str 22)
  (str enactmentDate) (str 2005-06-15)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2065`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `सूचना का अधिकार अधिनियम, 2005`)
  (str actYear) (str 2005)
  (str ministry) (str `Ministry of Personnel, Public Grievances and Pensions`)
  (str department) (str `Department of Personnel and Training`)
  (str longTitle) (str `An Act to provide for setting out the practical regime of right to information for citizens to secure access to information under the control of public authorities, in order to promote transparency and accountability in the working of every public authority, the constitution of a Central Information Commission and State Information Commissions and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str `Ss. 4(1), 5(1) (2), 12, 13, 15, 16, 24, 27, 28 (15-06-2005) and rest provisions on 120th day of its enactment.`)
  (str fetchedAt) (str `2026-05-08T21:24:57.679Z`)
  (str translations) obj_root_law_translations
