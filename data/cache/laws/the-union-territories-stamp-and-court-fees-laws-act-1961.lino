obj_root_law_sections_1:
  object
  (str sectionId) (str 72660)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Union Territories (Stamp and Court-fees Laws)
Act, 1961.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72660&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00028_196133_1673601905242)
obj_root_law_sections_2:
  object
  (str sectionId) (str 72661)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Amendment of Indian Stamp Act, 1899, as in force in Himachal Pradesh.`)
  (str content) (str `On such date as the
Central Government may, by notification in the Official Gazette, appoint, for Schedule I-A of the Indian
Stamp Act, 1899 (2 of 1899), as in force in the Union territory of Himachal Pradesh immediately before
that date, there shall be substituted, with such modifications as may be specified in the notification,
Schedule I-A to the Indian Stamp Act, 1899, as in force in the State of Punjab on the 28th day of
November, 1960.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72661&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00028_196133_1673601905242)
obj_root_law_sections_3:
  object
  (str sectionId) (str 72662)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Repeal of Court-fees Act, 1870, as in force in Himachal Pradesh.`)
  (str content) (str `On the date on which the
Court-fees Act, 1870 (7 of 1870), as in force in the State of Punjab, is extended to the Union territory of
Himachal Pradesh by notification under section 2 of the Union Territories (Laws) Act, 1950 (30 of 1950),
the Court-fees Act, 1870, as in force in that Union territory immediately before the date of such
notification, shall stand repealed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72662&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00028_196133_1673601905242)
obj_root_law_sections_4:
  object
  (str sectionId) (str 72663)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Repeal of Court-fees Act, 1870, as in force in Manipur and Tripura.`)
  (str content) (str `(a) On the date on which
the Court-fees Act, 1870(7 of 1870), as in force in the State of Assam, is extended to the Union territory
of Manipur by notification under section 2 of the Union Territories (Laws) Act, 1950 (30 of 1950), the
Court-fees Act, 1870, as in force in that Union territory immediately before the date of such notification,
shall stand repealed.

(b) On the date on which the Court-fees Act, 1870 (7 of 1870), as in force in the State of Assam, is
extended to the Union territory of Tripura by notification under section 2 of the Union Territories (Laws)
Act, 1950 (30 of 1950), the Court-fees Act, 1870, as in force in that Union territory immediately before
the date of such notification, shall stand repeale`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72663&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00028_196133_1673601905242)
obj_root_law_sections_5:
  object
  (str sectionId) (str 72664)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Repeal of Indian Stamp Act, 1899, as in force in Manipur and Tripura.`)
  (str content) (str `(a) On the date on
which the Indian Stamp Act, 1899 (2 of 1899), as in force in the State of Assam, is extended to the Union
territory of Manipur by notification under section 2 of the Union Territories (Laws)
Act, 1950 (30 of 1950), the Indian Stamp Act, 1899, as in force in that Union territory immediately before
the date of such notification, shall stand repealed.

(b) On the date on which the Indian Stamp Act, 1899 (2 of 1899), as in force in the State of Assam, is
extended to the Union territory of Tripura by notification under section 2 of the Union Territories (Laws)
Act, 1950 (30 of 1950), the Indian Stamp Act, 1899, as in force in that Union territory immediately before
the date of such notification, shall stand repealed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72664&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00028_196133_1673601905242)
obj_root_law_sections_6:
  object
  (str sectionId) (str 72665)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Validation of levy of stamp duties in certain cases.`)
  (str content) (str `Any stamp duties levied and collected in
the Union territory of Manipur during the period commencing on the 16th day of
April, 1950, and ending on the date on which the Indian Stamp Act, 1899 (2 of 1899), as in force in the
State of Assam is extended to that Union territory under section 5, in the belief that the Indian Stamp Act,
1899 , as in force in the State of Assam immediately before the 16th day of April, 1950, was applicable to
that Union territory, shall be deemed always to have been levied and collected in accordance with law.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72665&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00028_196133_1673601905242)
