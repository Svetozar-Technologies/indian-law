  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72660&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00028_196133_1673601905242
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Union Territories (Stamp and Court-fees Laws)`
  line `Act, 1961.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (72661)
  sectionNo (2)
  orderNo 2
  title `Amendment of Indian Stamp Act, 1899, as in force in Himachal Pradesh.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72661&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00028_196133_1673601905242
obj_root_law_sections_2_content:
  string
  line `On such date as the`
  line `Central Government may, by notification in the Official Gazette, appoint, for Schedule I-A of the Indian`
  line `Stamp Act, 1899 (2 of 1899), as in force in the Union territory of Himachal Pradesh immediately before`
  line `that date, there shall be substituted, with such modifications as may be specified in the notification,`
  line `Schedule I-A to the Indian Stamp Act, 1899, as in force in the State of Punjab on the 28th day of`
  line `November, 1960.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (72662)
  sectionNo (3)
  orderNo 3
  title `Repeal of Court-fees Act, 1870, as in force in Himachal Pradesh.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72662&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00028_196133_1673601905242
obj_root_law_sections_3_content:
  string
  line `On the date on which the`
  line `Court-fees Act, 1870 (7 of 1870), as in force in the State of Punjab, is extended to the Union territory of`
  line `Himachal Pradesh by notification under section 2 of the Union Territories (Laws) Act, 1950 (30 of 1950),`
  line `the Court-fees Act, 1870, as in force in that Union territory immediately before the date of such`
  line `notification, shall stand repealed.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (72663)
  sectionNo (4)
  orderNo 4
  title `Repeal of Court-fees Act, 1870, as in force in Manipur and Tripura.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72663&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00028_196133_1673601905242
obj_root_law_sections_4_content:
  string
  line `(a) On the date on which`
  line `the Court-fees Act, 1870(7 of 1870), as in force in the State of Assam, is extended to the Union territory`
  line `of Manipur by notification under section 2 of the Union Territories (Laws) Act, 1950 (30 of 1950), the`
  line `Court-fees Act, 1870, as in force in that Union territory immediately before the date of such notification,`
  line `shall stand repealed.`
  line
  line `(b) On the date on which the Court-fees Act, 1870 (7 of 1870), as in force in the State of Assam, is`
  line `extended to the Union territory of Tripura by notification under section 2 of the Union Territories (Laws)`
  line `Act, 1950 (30 of 1950), the Court-fees Act, 1870, as in force in that Union territory immediately before`
  line `the date of such notification, shall stand repeale`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (72664)
  sectionNo (5)
  orderNo 5
  title `Repeal of Indian Stamp Act, 1899, as in force in Manipur and Tripura.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72664&sectionno=5&orderno=5&orgactid=AC_CEN_3_3_00028_196133_1673601905242
obj_root_law_sections_5_content:
  string
  line `(a) On the date on`
  line `which the Indian Stamp Act, 1899 (2 of 1899), as in force in the State of Assam, is extended to the Union`
  line `territory of Manipur by notification under section 2 of the Union Territories (Laws)`
  line `Act, 1950 (30 of 1950), the Indian Stamp Act, 1899, as in force in that Union territory immediately before`
  line `the date of such notification, shall stand repealed.`
  line
  line `(b) On the date on which the Indian Stamp Act, 1899 (2 of 1899), as in force in the State of Assam, is`
  line `extended to the Union territory of Tripura by notification under section 2 of the Union Territories (Laws)`
  line `Act, 1950 (30 of 1950), the Indian Stamp Act, 1899, as in force in that Union territory immediately before`
  line `the date of such notification, shall stand repealed.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (72665)
  sectionNo (6)
  orderNo 6
  title `Validation of levy of stamp duties in certain cases.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00028_196133_1673601905242&sectionId=72665&sectionno=6&orderno=6&orgactid=AC_CEN_3_3_00028_196133_1673601905242
obj_root_law_sections_6_content:
  string
  line `Any stamp duties levied and collected in`
  line `the Union territory of Manipur during the period commencing on the 16th day of`
  line `April, 1950, and ending on the date on which the Indian Stamp Act, 1899 (2 of 1899), as in force in the`
  line `State of Assam is extended to that Union territory under section 5, in the belief that the Indian Stamp Act,`
  line `1899 , as in force in the State of Assam immediately before the 16th day of April, 1950, was applicable to`
  line `that Union territory, shall be deemed always to have been levied and collected in accordance with law.`
obj_root_law_sections_6_footnotes:
  string
  line
