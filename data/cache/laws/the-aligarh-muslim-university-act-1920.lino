obj_root_law_sections_1:
  sectionId (40714)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40714&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Aligarh Muslim University`
  line `Act, 1920.`
  line
  line `(2) It shall come into force on such date^1as the ^2[Central Government] may, by notification in the`
  line `^3[Official Gazette], appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. This Act was brought into force on the 1st December, 1920, vide Notification No. 1458, dated 1-12-1920, see Gazette of`
  line `India, 1920., Pt. I, p. 2213. (For Notification, see G.S.R.O. Volume VIII, p. 192).`
  line
  line `2. Subs. by the A.O. 1937, for "G.G. in C."`
  line
  line `3. Subs., ibid., for "Gazette of India".`
obj_root_law_sections_2:
  sectionId (40715)
  sectionNo (2)
  orderNo 2
  title `Definit ions.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40715&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_2_content:
  string
  line `^1[2. Definitions.--In this Act and in all Statutes made hereunder, unless the context`
  line `otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "Board of Studies" means the Board of Studies of the University`
  line
  line `(c) "Chancellor", "Pro-Chancellor" and "Vice-Chancellor", mean respectively, the`
  line `Chancellor, Pro-Chancellor and Vice-Chancellor of the University;`
  line
  line `(d) "Court" means the Court of the University;`
  line
  line `(e) "Department" means a Department of Studies and includes a Centre of Studies established`
  line `by the Ordinances;`
  line
  line `(f) "Executive Council" means the Executive Council of the University;`
  line
  line `(g) "Faculty" means a Faculty of the University;`
  line
  line `(h) "Hall" means a unit of residence or of corporate life maintained by the University for its`
  line students;
  line
  line `^2[(hh) "non-teaching staff" means the employees of the University other than the`
  line teachers;]
  line
  line `(i) "Statutes", "Ordinances" and "Regulations" mean respectively, the Statutes, Ordinances and`
  line `Regulations of the University for the time being in force;`
  line
  line `^3* * * * *`
  line
  line `(k) "Teachers" means Professors, Readers, Lectures and such other persons as may be`
  line `appointed for imparting instruction in the University or a hall and are designated as Teachers by`
  line `the Ordinances;`
  line
  line `^4[(l) "University" means the educational institution of their choice established by the Muslims`
  line `of India, which originated as the Muhammadan Anglo-Oriental College, Aligarh, and which was`
  line `subsequently incorporated as the Aligarh Muslim University.]]`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by Act 34 of 1972, s. 2, for section 2 (w.e.f, 17-6-1972).`
  line
  line `2. Ins. by Act 62 of 1981, s. 3 (w.e.f. 10-2-1982).`
  line
  line `3. Clause (j) omitted by s. 3, ibid. (w.e.f. 10-2-1982).`
  line
  line `4. Subs. by Act 62 of 1981, s. 3, for clause (l) (w.e.f. 10-2-1982).`
obj_root_law_sections_3:
  sectionId (40716)
  sectionNo (3)
  orderNo 3
  title Incorporation.
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 34 of 1972, s. 3, for section 3 (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40716&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_3_content:
  string
  line `^1[3. Incorporation.-- The Chancellor, the Pro-Chancellor and the Vice-Chancellor and the`
  line `members of the Court, the Executive Council and the Academic Council, for the time being, shall be a`
  line `body corporate by the name of the Aligarh Muslim University and shall have perpetual succession and`
  line `a common seal and shall sue and be sued by that name.]`
obj_root_law_sections_4:
  sectionId (40760)
  sectionNo (4)
  orderNo 4
  title `Dissolution of the Muhammadan Anglo-Oriental College, Aligarh, and the Muslim UniversityAssociation, and transfer of all property to the University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40760&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_4_content:
  string
  line `From the commencement`
  line `of this Act--`
  line
  line `(i) the Societies known as the Muhammadan Anglo-Oriental College, Aligarh, and the`
  line `Muslim University Association shall be dissolved, and all property, movable and immovable, and`
  line `all rights, powers and privileges of the said Societies and all property, movable and immovable,`
  line `and all rights, powers and privileges of the Muslim University Foundation Committee shall be`
  line `transferred to and vest in the University and shall be applied to the objects and purposes for which`
  line `the University is incorporated;`
  line
  line `(ii) all debts, liabilities and obligations of the said Societies and Committee shall be`
  line `transferred to the University and shall thereafter be discharged and satisfied by it;`
  line
  line `(iii) all references in any enactment to either of the said Societies or to the said Committee`
  line `shall be construed as references to the University;`
  line
  line `(iv) any will, deed or other document, whether made or executed before or after the`
  line `commencement of this Act, which contains any bequest, gift or trust in favour either of the said`
  line `Societies or of the said Committee shall, on the commencement of this Act, be construed as if the`
  line `University was therein named instead of such Society or Committee;`
  line
  line `(v) subject to any orders which the Court may make, the buildings which belonged to the`
  line `Muhammadan Anglo-Oriental College, Aligarh, shall continue to be known and designated`
  line `by the names and styles by which they were known and designated immediately before the`
  line `commencement of this Act;`
  line
  line `(vi) subject to the provisions of this Act, every person employed immediately before`
  line `the commencement of this Act in the Muhammadan Anglo-Oriental College, Aligarh,`
  line `shall hold employment in the University by the same tenure and upon the same terms and`
  line `conditions and with the same rights and privileges as to pension and gratuity as he would have`
  line `held the same under the Muhammadan Anglo-Oriental College, Aligarh, if this Act had not been`
  line passed.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (40718)
  sectionNo (5)
  orderNo 5
  title `Powers of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40718&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_5_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(1) to provide for instruction in such branches of learning as the University may think fit,`
  line `and to make provision for research and for the advancement and dissemination of knowledge;`
  line
  line `(2)`
  line `^1[(a)] to promote Oriental and Islamic studies and give instruction in Muslim theology and`
  line `religion and to impart moral and physical training;`
  line
  line `^2[(b) to promote the study of the religions, civilisation and culture of India;]`
  line
  line `^3[(c) to promote especially the educational and cultural advancement of the Muslims`
  line `Muslims of India;]`
  line
  line `^4[(3) to hold examinations and to grant diplomas or certificates to, and confer degrees and other`
  line `academic distinctions on, persons subject to such conditions as the University may determine and to`
  line `withdraw any such diplomas, certificates, degrees or other academic distinctions for good and`
  line `sufficient cause;]`
  line
  line `(4) to confer honorary degrees or other distinctions ^5*** in the manner laid down inthe Statutes;`
  line
  line `^6[(5) to provide instruction for such persons who are not members of the University, as the`
  line `University may determine;]`
  line
  line `(6) to co-operate ^7[or collaborate] with other Universities and authorities in such manner and for`
  line `such purposes as the University may determine;`
  line
  line `(7) to institute professorships, readerships, lectureships and ^8*** other ^9[teaching or academic`
  line `posts] required by the University, and to appoint persons to such professorships, readerships,`
  line `lectureships ^10[and other posts] ^11[and determine their conditions of service in accordance with the`
  line Statutes];
  line
  line `^7[(7A) to appoint persons working in any other University, institution or organisation as teachers`
  line `of the University for a specified period;]`
  line
  line `(8) to institute and award fellowships (including travelling fellowships), scholarships,`
  line `^12[studentships], exhibitions and prizes in accordance with the statutes and the Ordinances;`
  line
  line `^13[(9) to institute and maintain Halls for the students of the University;]`
  line
  line `^7[(9A) to establish within a radius of twenty-five kilometres of the University Mosque such`
  line `Special Centres, Specialised Laboratories or other units for research and instruction as are, in the`
  line `opinion of the University, necessary for the furtherance of its objects;]`
  line
  line `(10) to demand and receive such fees and other charges as may be prescribed by the Ordinances;`
  line
  line `(11) to supervise and control the residence and ^12[to regulate the] discipline of studentsof the`
  line `University, and to make arrangements for promoting their health; ^14***`
  line
  line `^12[(11A) to make special arrangements in respect of the residence, discipline and teaching of`
  line `women students;`
  line
  line `(11B) to create administrative, ministerial and other ^15*** posts and to make appointments thereto`
  line `^11[and determine their conditions of service in accordance with the Statutes;]`
  line
  line `^7[(11C) to regulate and enforce discipline among the employees of the University and to take such`
  line `disciplinary measures as may be deemed necessary;`
  line
  line `(11D) to acquire, hold, manage and dispose of property, movable or immovable, including trust or`
  line `endowed property for the purposes of the University;`
  line
  line `(11E) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University;`
  line
  line `(11F) to declare a Department of Studies to be an autonomous Department; and]`
  line
  line `(12) to do all such other acts and things whether incidental to the powers aforesaid or not as`
  line `may be requisite in order to further the objects of the University ^16***`
obj_root_law_sections_5_footnotes:
  string
  line `1. Clause (2) relettered as sub-clause (a) thereof by Act 34 of 1972. s. 4 (w.e.f. 17-6-1972).`
  line
  line `2. Ins. by s. 4, ibid. (w.e.f. 17-6-1972).`
  line
  line `3. Ins. by Act 62 of 1981, s. 4 (w.e.f. 10-2-1982).`
  line
  line `4. Subs. by Act 34 of 1972, s. 4, for clause (3) (w.e.f. 17-6-1972).`
  line
  line `5. The words "on approved persons" omitted by Act 62 of 1951, s. 3.`
  line
  line `6. Subs. by Act 34 of 1972. s. 4, for clause (5) (w.e.f. 17-6-1972).`
  line
  line `7. Ins. by s. 4, ibid. (w.e.f. 17-6-1972).`
  line
  line `8. The word "any" omitted by Act 62 of 1951, s. 3.`
  line
  line `9. Subs. by Act 34 of 1972, s. 4, for "teaching posts" (w.e.f. 17-6-1972).`
  line
  line `10. Subs. by Act 62 of 1951, s. 3, for "and posts".`
  line
  line `11. Added by Act 62 of 1981, s. 4 (w.e.f. 10-02-1982).`
  line
  line `12. Ins. by .Act 62 of 1951, s. 3.`
  line
  line `13. Subs. by Act 62 of 1981, s. 4, for clause (9) (w.e.f. 10-02-1982).`
  line
  line `14. The word "and" omitted by Act 62 of 1951, s. 3.`
  line
  line `15. The word "necessary" omitted by Act 34 of 1972, s. 4 (w.e.f. 17-6-1972).`
  line
  line `16. The words the University omitted by Act 62 of 1951, s. 3 (w.e.f. 3-11-1951)`
obj_root_law_sections_6:
  sectionId (40719)
  sectionNo (6)
  orderNo 6
  title `Recognition of degrees.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40719&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_6_content:
  string
  line `The degrees, diplomas and other academic distinctions granted or`
  line `conferred to or on persons by the University shall be recognised by ^1[the Central and ^2[State]`
  line `Governments] as are the corresponding degrees, diplomas and other academic distinctions granted by`
  line `any other University incorporated under any enactment.`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by the A.O. 1948, for "any Government in British India".`
  line
  line `2. Subs. by the A.O. 1950, for "Provincial".`
obj_root_law_sections_7:
  sectionId (40720)
  sectionNo (7)
  orderNo 7
  title `Reserve funds.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40720&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_7_content:
  string
  line `The University shall invest and keep invested in securities in which trust`
  line `funds may be invested in accordance with the law for the time being in force relating to trusts in`
  line `^1[India] a sum of thirty lakhs of rupees as a permanent endowment to meet the recurring charges of`
  line `the University other than charges in respect of fellowships, scholarships, prizes and rewards:`
  line
  line `Provided that--`
  line
  line `(1) any Government securities as defined in the Indian Securities Act, 1920 (10 of 1920), which`
  line `may be held by the University shall, for the purposes of this section, be reckoned at their face value;`
  line and
  line
  line `(2) the aforesaid sum of thirty lakhs shall be reduced by such sums as, at the commencement of`
  line `this Act, the ^2[Central Government] shall, by order in writing, declareto be the total capitalised value,`
  line `for the purpose of this section --`
  line
  line `(a) of all permanent recurring grants of money which have been made either to the`
  line `Muhammadan Anglo-Oriental College, Aligarh, the Muslim University Association or the`
  line `Muslim University Foundation Committee, by any Ruler of a State in India; and`
  line
  line `(b) of the total income accruing from immovable property (not being land or buildings, in the`
  line `occupation and use of the said college) which by the operation of this Act has been transferred to`
  line `the University`
obj_root_law_sections_7_footnotes:
  string
  line `1. Subs. by Act 62 of 1951, s. 4, for "Part A States and Part C States".`
  line
  line `2. Subs. by the A.O. 1937, for "G.G. in C.".`
obj_root_law_sections_8:
  sectionId (40721)
  sectionNo (8)
  orderNo 8
  title `University open to all persons.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 62 of 1981, s. 5, for section 8 (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40721&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_8_content:
  string
  line `^1[8. University open to all persons.--The University shall be open to all persons (including the`
  line `teachers and taught) of either sex and of whatever race, religion, creed, caste or class:`
  line
  line `Provided that nothing in this section shall be deemed to prevent religious instruction being given in`
  line `the manner prescribed by the Ordinances to those who have consented to receive it.]`
obj_root_law_sections_9:
  sectionId (40722)
  sectionNo (9)
  orderNo 9
  title [Omitted.].
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40722&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_9_content:
  string
  line `[Religious instruction.] Rep. by the Aligarh Muslim University (Amendment) Act, 1951 (62 of`
  line `1951), s. 6.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (40723)
  sectionNo (10)
  orderNo 10
  title `Residence of students.`
  content obj_root_law_sections_10_content
  footnotes `1. Ins. by Act 34 of 1972, s. 6 (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40723&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_10_content:
  string
  line `Every student of the University shall reside either in a Hall ^1[or a`
  line `hostel] or under such conditions as may be prescribed by the Ordinances.`
obj_root_law_sections_11:
  sectionId (40724)
  sectionNo (11)
  orderNo 11
  title `Teaching in the University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40724&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_11_content:
  string
  line `^1[11. Teaching in the University.--All recognised teaching for the purpose of University`
  line `degrees, diplomas and certificates shall be conducted ^2[under the supervision of the Academic`
  line `Council and in accordance with the Statutes and Ordinances].]`
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by Act 62 of 1951, s. 7, for section 11.`
  line
  line `2. Subs. by Act 34 of 1972, s. 7, for certain words (w.e.f. 17-6-1972).`
obj_root_law_sections_12:
  sectionId (40725)
  sectionNo (12)
  orderNo 12
  title `Power to establish and maintain high schools and other institutions.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40725&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_12_content:
  string
  line `^1[12. Power to establish and maintain High Schools and other institutions.--(1) The University`
  line `shall, subject to the Statutes, have power to establish and maintain High Schools within a radius of fifteen`
  line `miles from the University Mosque.`
  line
  line `(2) The University may also, with the sanction of the Visitor and subject to the Statutes and the`
  line `Ordinances, ^2[establish and maintain such Special Centres, Specialised Laboratories or such other`
  line `institutions for research or instruction as are necessary for the furtherance of its objects either on its own or`
  line `in co-operation or collaboration with any other institution].`
obj_root_law_sections_12_footnotes:
  string
  line `1. Subs. by Act 62 of 1951, s. 8, for section 12.`
  line
  line `2. Subs. by Act 34 to 1972, s. 8, for certain words (w.e.f. 17-6-1972).`
obj_root_law_sections_12_a:
  sectionId (40726)
  sectionNo 12A
  orderNo 13
  title [Omitted.].
  content obj_root_law_sections_12_a_content
  footnotes obj_root_law_sections_12_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40726&sectionno=12A&orderno=13&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_12_a_content:
  string
  line `Power to recognise colleges and institutions. Rep. by the Aligarh Muslim University`
  line `(Amendment) Act, 1972 (34 of 1972), s. 9 (w.e.f. 17-6-1972).`
obj_root_law_sections_12_a_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (40727)
  sectionNo (13)
  orderNo 14
  title `The Visitor.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40727&sectionno=13&orderno=14&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_13_content:
  string
  line `(1) The ^2[President] shall be the ^1[Visitor] of the University.`
  line
  line `(2) The ^1[Visitor] shall have the right to cause an inspection to be made by such person or persons as`
  line `he may direct, of the University, its buildings, laboratories, and equipment, and of any institution`
  line `maintained by the University, and also of the examinations, teaching and other work conducted or done by`
  line `the University, and to cause an inquiry to be made in like manner in respect of any matter connected with`
  line `^3[the administration or finances of] the University ^4***.`
  line
  line `^5[(2A) The Visitor shall, in every case, give notice to the University of his intention to cause an`
  line `inspection or inquiry to be made and on receipt of such notice, the University shall have the right to make`
  line `such representation to the Visitor as it may consider necessary.`
  line
  line `(2B) After considering the representation, if any, made by the University the Visitor may cause to be`
  line `made such inspection or inquiry as is referred to in sub-section (2).`
  line
  line `(2C) Where any inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative who shall have the right to be present and be heard at such`
  line `inspection or inquiry.]`
  line
  line `(3) The ^1[Visitor] may address the Vice-Chancellor with reference to the result of such inspection`
  line `and inquiry, and the Vice-Chancellor shall communicate to the ^6[Executive Council] the views of the`
  line `^1[Visitor] with such advice as the ^1[Visitor] may be pleased to offer upon the action to be taken thereon.`
  line
  line `(4) The ^4[Executive Council] shall communicate through the Vice-Chancellor to the ^1[Visitor] such`
  line `action, if any, as it is proposed to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(5) Where the ^4[Executive Council] does not, within reasonable time, take action to the satisfaction`
  line `of the ^1[Visitor] may, after considering any explanation furnished or representation made by the`
  line `^4[Executive Council], issue such directions as he may think fit, and the ^4[Executive Council] shall comply`
  line `with such directions.`
  line
  line `^7[(6) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annul any proceeding of the University which is not in conformity with this Act, the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the University to show cause why such`
  line `an order should not be made, and, if any cause is shown within a reasonable time, shall consider the same.]`
  line
  line `^8[(7) The Visitor shall have such other powers as may be prescribed by the Statutes.]`
obj_root_law_sections_13_footnotes:
  string
  line `1. Subs. by Act 62 of 1951, s. 8, for section 12.`
  line
  line `2. Subs. by the A.O. 1950, for "Governor General".`
  line
  line `3. Ins. by Act 34 of 1972, s. 10 (w.e.f. 17-6.1972).`
  line
  line `4. The words "with the university" omitted by Act 62 of 1951, s. 10`
  line
  line `5. Subs. by Act 34 of 1972, s. 10, for sub-section (2A) (w.e.f. 17-6-1972).`
  line
  line `6. Subs. by s. 10, ibid., for "Court" (w.e.f. 17-6-1976).`
  line
  line `7. Ins. by Act 62 of 1951, s. 10. The former sub-section (6) inserted by the A.O. 1937, was rep. by the A.O. 1948.`
  line
  line `8. Ins. by Act 34 of 1972, s. 10 (w.e.f. 17-6-1972).`
