obj_root_law_sections_15:
  sectionId (47402)
  sectionNo (15)
  orderNo 16
  title `Chief Rector.`
  content obj_root_law_sections_15_content
  footnotes `1. Subs. by s. 11, ibid., for the former heading and section 15 (w.e.f. 17-06-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=47402&sectionno=15&orderno=16&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_15_content:
  string
  line `^1[15. Chief Rector.-- The Governor of the State of Uttar Pradesh shall be Chief Rector of the`
  line University.]
obj_root_law_sections_16:
  sectionId (40729)
  sectionNo (16)
  orderNo 17
  title `Officers of the University.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40729&sectionno=16&orderno=17&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_16_content:
  string
  line `The following shall be officers of the University:--`
  line
  line `(1) The Chancellor,`
  line
  line `(2) The Pro-Chancellor,`
  line
  line `(3) The Vice-Chancellor, ^1***`
  line
  line `^2* * * * *`
  line
  line `^3[(3A) The Pro-Vice-Chancellor, if any;`
  line
  line ^4[
  line `^5[(3B) The Honorary Treasurer;]`
  line
  line `^6[(3C)] The Registrar;`
  line
  line `^6[(3D)] The Finance Officer;]`
  line
  line `^6[(3E)] The Deans of the Faculties; and]`
  line
  line `^7[(4)] Such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_16_footnotes:
  string
  line `1. The word "and" ins. by Act 11 of 1945, s. 2, omitted by Act 62 of 1951, section 13.`
  line
  line `2. Clause (4) which read "The Pro-Vice-Chancellor, and" omitted by Act 11 of 1945, section 2.`
  line
  line `3. Ins. by Act 62 of 1951, s. 13 (w.e.f. 3-11-1951).`
  line
  line `4. Subs. by Act 34 of 1972, s. 12, for clauses (B) and (C) (w.e.f. 17-6-1972).`
  line
  line `5. Ins. by Act 62 of 1981, s. 6 (w.e.f. 10-2-1982).`
  line
  line `6. Clauses (3B), (3C) and (3D) renumbered as clauses (3C), (3D) and (3E) thereof by Act 62 of 1981, s. 6 (w.e.f. 10-2-1982).`
  line
  line `7. Clause (5) renumbered as clause (4) by Act 11 of 1945, s. 2.`
obj_root_law_sections_17:
  sectionId (40730)
  sectionNo (17)
  orderNo 18
  title `The Chancellor.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40730&sectionno=17&orderno=18&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_17_content:
  string
  line `^1[17. The Chancellor.--^2[(1) The Chancellor of the University shall be elected by the Court in`
  line `such manner and for such term as may be prescribed by the Statutes.]`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the Head of the University.`
  line
  line `(3) The Chancellor shall, if present, preside at the convocations of the University held for`
  line `conferring degrees.]`
obj_root_law_sections_17_footnotes:
  string
  line `1. Subs. by Act 34 of 1972, s. 13, for section 17 (w.e.f. 17-6-1972).`
  line
  line `2. Subs. by Act 62 of 1981, s. 7, for sub-section (1) (w.e.f. 10-2-1982).`
obj_root_law_sections_18:
  sectionId (40731)
  sectionNo (18)
  orderNo 19
  title `The Pro-Chancellor.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40731&sectionno=18&orderno=19&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_18_content:
  string
  line `^1[18. The Pro-Chancellor. --^2[(1) The Pro-Chancellor shall be elected by the Court in such`
  line `manner and for such term as may be prescribed by the Statutes.]`
  line
  line `(2)The Pro-Chancellor shall, in the absence of the Chancellor, preside over the`
  line `convocations of the University held for conferring degrees.]`
obj_root_law_sections_18_footnotes:
  string
  line `1. Subs. by Act 34 of 1972, s. 14, for section 18 (w.e.f. 17-6-1972).`
  line
  line `2. Subs by Act 62 of 1981, s. 8, for sub-section (1) (w.e.f. 10-2-1982).`
obj_root_law_sections_19:
  sectionId (40732)
  sectionNo (19)
  orderNo 20
  title `The Vice-Chancellor.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by Act 34 of 1972, s. 15, for section 19 (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40732&sectionno=19&orderno=20&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_19_content:
  string
  line `^1[19. The Vice-Chancellor.--(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University,`
  line `and shall exercise general supervision and control over the affairs of the University and give effect to`
  line `the decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report`
  line `to such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been`
  line `taken, it may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action`
  line `taken by the Vice-Chancellor under this sub-section shall have the right to appeal against such action`
  line `to the Executive Council within three months from the date on which decision on such action is`
  line `communicated to him and thereupon the Executive Council may confirm, modify or reverse the action`
  line `taken by the Vice-Chancellor.`
  line
  line `(4) The Vice-Chancellor shall exercise such other powers and perform such other functions as may`
  line `be prescribed by the Statutes or Ordinances.]`
obj_root_law_sections_20:
  sectionId (40733)
  sectionNo (20)
  orderNo 21
  title `The Pro-Vice-Chancellor.`
  content obj_root_law_sections_20_content
  footnotes `1. Ins. by Act 34 of 1972, s. 16, (w.e.f. 17-6-1972). Earlier section 20 was rep. by Act 11 of 1945, s. 3 (w.e.f. 4-9-1945).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40733&sectionno=20&orderno=21&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_20_content:
  string
  line `^1[20. The Pro-Vice-Chancellor.--The Pro-Vice-Chancellor shall be appointed in such manner,`
  line `and shall exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_20_a:
  sectionId (40734)
  sectionNo 20A
  orderNo 22
  title `The Honarary Treasurer.`
  content obj_root_law_sections_20_a_content
  footnotes `1. Ins. by Act 62 of 1981, s. 9 (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40734&sectionno=20A&orderno=22&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_20_a_content:
  string
  line `^1[20A. The Honorary Treasurer.--(1) The Honorary Treasurer shall be elected by the Court in.`
  line `such manner and for such term as may be prescribed by the Statutes.`
  line
  line `(2) The Honorary Treasurer shall exercise such powers and perform such functions as may be`
  line `prescribed by the Statutes.]`
obj_root_law_sections_20_b:
  sectionId (40735)
  sectionNo 20B
  orderNo 23
  title `The Registrar.`
  content obj_root_law_sections_20_b_content
  footnotes `1. Sections 20A and 20B renumbered as sections 20B and 20C by Act 62 of 1981, s. 9 (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40735&sectionno=20B&orderno=23&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_20_b_content:
  string
  line `^1[20B.] The Registrar.--(1) The Registrar shall be appointed in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such other powers and perform such other`
  line `duties as may be prescribed by the Statutes.`
obj_root_law_sections_20_c:
  sectionId (40736)
  sectionNo 20C
  orderNo 24
  title `The Finance Officer.`
  content obj_root_law_sections_20_c_content
  footnotes `1. Section 20B renumbered as section 20C thereof by s. 9 ibid. (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40736&sectionno=20C&orderno=24&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_20_c_content:
  string
  line `^1[20C.] The Finance Officer.--The Finance Officer shall be appointed in such manner and.`
  line `shall exercise such powers and perform such duties as may be prescribed by the Statutes.]`
obj_root_law_sections_21:
  sectionId (40737)
  sectionNo (21)
  orderNo 25
  title `Powers of other officers.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40737&sectionno=21&orderno=25&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_21_content:
  string
  line `^1[21. Powers of other officers.--The powers of officers other than the Chancellor, the ProChancellor, the Vice-Chancellor, the Pro-Vice-Chancellor,`
  line `^2[the Honorary Treasurer,] the Registrar`
  line `and the Finance Officer shall be prescribed by the Statutes.]`
obj_root_law_sections_21_footnotes:
  string
  line `1. Subs. by Act 34 of 1972, s. 17, for section 21 (w.e.f. 17-6-1972).`
  line
  line `2. Ins. by Act 62 of 1981, s. 10 (w.e.f. 10-2-1982).`
obj_root_law_sections_22:
  sectionId (40738)
  sectionNo (22)
  orderNo 26
  title `Authorities of the University.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40738&sectionno=22&orderno=26&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_22_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(1) The Court,`
  line
  line `(2) The Executive Council,`
  line
  line `(3) The Academic Council, ^1***`
  line
  line ^2[
  line `^3[(3A) The Finance Committee,]`
  line
  line `(3B) The Faculties, ^4[and]]`
  line
  line `^5* * * * *`
  line
  line `(4) Such other authorities as may be declared by the Statutes to be authorities of the University.`
obj_root_law_sections_22_footnotes:
  string
  line `1. The word "and" omitted by Act 62 of 1951, s. 16 (w.e.f. 3-11-1951).`
  line
  line `2. Ins. by s. 16, ibid. (w.e.f. 3-11-1951).`
  line
  line `3. Ins. by Act 62 of 1981, s. 11 (w.e.f. 10-2-1982).`
  line
  line `4. Ins. by Act 62 of 1981, s. 11 (w.e.f. 10-2-1982).`
  line
  line `5. Clause (3C) omitted by s. 11, ibid. (w.e.f. 10-2-1982).`
obj_root_law_sections_23:
  sectionId (40739)
  sectionNo (23)
  orderNo 27
  title `The Court.`
  content obj_root_law_sections_23_content
  footnotes `1. Subs. by s. 12, ibid., for s. 23 (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40739&sectionno=23&orderno=27&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_23_content:
  string
  line `^1[23. The Court.--(1) The Court shall consist of the Chancellor, the Pro-Chancellor, the ViceChancellor and the Pro-Vice-Chancellor (if any), for the, time being, and such other persons as may be`
  line `specified in the Statutes.`
  line
  line `(2) The Court shall be the supreme governing body of the University and shall exercise all the`
  line `powers of the University, not otherwise provided for by this Act, the Statutes, the Ordinances and the`
  line `Regulations and it shall have power to review the acts of the Executive and the Academic Councils (save`
  line `where such Councils have acted in accordance with powers conferred on them under this Act, the Statutes`
  line `or the Ordinances).`
  line
  line `(3) Subject to the provisions of this Act, the Court shall exercise the following powers and perform`
  line `the following duties, namely:--`
  line
  line `(a) to make Statutes and to amend or repeal the same;`
  line
  line `(b) to consider Ordinances;`
  line
  line `(c) to consider and pass resolutions on the annual report, the annual accounts and the financial`
  line estimates;
  line
  line `(d) to elect such persons to serve on the authorities of the University and to appoint such officers`
  line `as may be prescribed by this Act or the Statutes; and`
  line
  line `(e) to exercise such other powers and perform such other duties as may be conferred or imposed`
  line `upon it by this Act or the Statutes.]`
obj_root_law_sections_24:
  sectionId (40740)
  sectionNo (24)
  orderNo 28
  title `The Executive Council.`
  content obj_root_law_sections_24_content
  footnotes `1. Subs. by Act 34 of 1972, s. 20, for "the executive body" (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40740&sectionno=24&orderno=28&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_24_content:
  string
  line `The Executive Council shall be ^1[the principal executive body] of`
  line `the University. Its constitution and the term of office of its members and its powers and duties shall be`
  line `prescribed by the Statutes.`
obj_root_law_sections_25:
  sectionId (40741)
  sectionNo (25)
  orderNo 29
  title `The Academic Council.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40741&sectionno=25&orderno=29&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_25_content:
  string
  line `(1) The Academic Council shall be ^1[the principal academic body]`
  line `of the University and shall, subject to the provisions of this Act, the Statutes and the Ordinances, ^2[coordinate and exercise general supervision over the academic policies of the University].`
  line
  line `(2) The constitution of the Academic Council and the term of office of its members and its powers`
  line `and duties shall be prescribed by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line `1. Subs. by s. 21, ibid., for "the academic body" (w.e.f. 17-6-1972).`
  line
  line `2. Subs. by s. 21, ibid., for certain words (w.e.f. 17-6-1972).`
obj_root_law_sections_26:
  sectionId (40742)
  sectionNo (26)
  orderNo 30
  title `Other authorities of the University.`
  content obj_root_law_sections_26_content
  footnotes `1. Subs. by Act 62 of 1981, s. 13, for certain words (w.e.f, 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40742&sectionno=26&orderno=30&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_26_content:
  string
  line `The constitution, powers ^1[and functions of the`
  line `Finance Committee and of the Faculties] and of such other authorities as may be declared by the Statutes`
  line `to be authorities of the University, shall be prescribed by the Statutes.`
obj_root_law_sections_26_a:
  sectionId (40743)
  sectionNo 26A
  orderNo 31
  title `Disqualifications for membership.`
  content obj_root_law_sections_26_a_content
  footnotes `1. Ins. by s. 14, ibid. (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40743&sectionno=26A&orderno=31&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_26_a_content:
  string
  line `^1[26A. Disqualifications for membership.--A person shall be disqualified for being chosen as, and`
  line `and for being, a member of any of the authorities of the University if he is not a citizen of India.]`
obj_root_law_sections_27:
  sectionId (40744)
  sectionNo (27)
  orderNo 32
  title `Power to make Statutes.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40744&sectionno=27&orderno=32&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_27_content:
  string
  line `^1[27. Power to make Statutes.--Subject to the provisions of this Act, the Statutes may provide for`
  line `all or any of the following matters, namely:`
  line
  line `(a) the constitution, powers and functions of the authorities of the University, ^2*** and such other`
  line `other authorities as may be constituted from time to time;`
  line
  line `(b) the election and continuance in office of the members of the said authorities, the filling of`
  line `vacancies of members, and all other matters relative to those authorities for which it may be necessary`
  line `or desirable to provide;`
  line
  line `^3[(c) the manner of election of appointment, as the case may be, of the Chancellor, the ProChancellor, the Vice-Chancellor and other officers of the University;]`
  line
  line `(d) the manner of appointment of teachers and other academic staff and their emoluments;`
  line
  line `(e) the manner of appointment of employees other than teachers and other academic staff of the`
  line `University and their emoluments;`
  line
  line `(f) the manner of appointment of teachers and other academic staff working in any other`
  line `University or institution for a specified period for undertaking a joint project;`
  line
  line `(g) the conditions of service of employees including the provision for pension, insurance and`
  line `provident fund, the manner of termination of service and disciplinary action;`
  line
  line `(h) the principles governing seniority of service of employees;`
  line
  line `(i) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(j) the procedure for appeal to the Executive Council by any employee or student against the action`
  line `of any officer or authority of the University;`
  line
  line `(k) the establishment and recognition of Students Union or associations of teachers, academic staff`
  line `or other employees of the University;`
  line
  line `(l) all other matters which by this Act are to be, or may be, provided by the Statutes.]`
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by Act 34 of 1972, s. 23, for section 27 (w.e.f. 17-6-1972).`
  line
  line `2. The words the Finance Committee omitted by Act 62 of 1981, s. 15 (w.e.f. 10-2-1982).`
  line
  line `3. Subs. by s. 15, ibid., for clause (c) (w.e.f. 10-2-1982).`
obj_root_law_sections_28:
  sectionId (40745)
  sectionNo (28)
  orderNo 33
  title Statutes.
  content obj_root_law_sections_28_content
  footnotes `1. Subs. by Act 62 of 1981, s. 16, for section 28 (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40745&sectionno=28&orderno=33&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_28_content:
  string
  line `^1[28. Statutes.--(1) On the commencement of the Aligarh Muslim University (Amendment) Act,`
  line `1981 (62 of 1981), the Statutes in force immediately before such commencement, as amended by that`
  line `Act, shall be the Statutes of the University.`
  line
  line `(2) After the commencement of the Aligarh Muslim University (Amendment) Act, 1981 (62 of 1981),`
  line `the Court may, notwithstanding anything contained in sub-section (1), make new or additional Statutes or`
  line `may amend or repeal the Statutes referred to in sub-section (1) in the manner hereinafter provided in this`
  line section.
  line
  line `(3) The Executive Council may propose to the Court the draft of any Statute for its consideration and`
  line `such draft shall be considered by the Court at its next meeting:`
  line
  line `Provided that the Executive Council shall not propose the draft of any Statute or of any amendment of`
  line `a Statute affecting the status, powers or constitution of any authority of the University until such authority`
  line `has been given an opportunity of expressing an opinion in writing upon the proposal and any opinion so`
  line `expressed shall be considered by the Court.`
  line
  line `(4) The Court may approve any such draft as is referred to in sub-section (3) or reject it or return it to`
  line `the Executive Council for reconsideration, either in whole or in part, together with any amendments`
  line `which the Court may suggest.`
  line
  line `(5) Any member of the Court may propose to the Court, the draft of any Statute and the Court may`
  line `reject the proposal or refer such draft for consideration to the Executive Council, which may either reject`
  line `the proposal or submit the draft to the Court in such form as the Executive Council may approve and the`
  line `provisions of this section shall apply in the case of any draft so submitted as they apply in the case of a`
  line `draft proposed by the Executive Council.`
  line
  line `(6) No new Statute or amendment or addition or repeal of any Statute shall come into force unless it is`
  line `approved by the Visitor, who may sanction or disallow it, or return it for further consideration.]`
obj_root_law_sections_29:
  sectionId (40746)
  sectionNo (29)
  orderNo 34
  title `Power to make Ordinances.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40746&sectionno=29&orderno=34&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_29_content:
  string
  line `^1[29. Power to make Ordinances.--(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the University;`
  line
  line `(c) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(d) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(e) the conditions of the award of fellowships, scholarships, studentships, exhibitions, medals and`
  line prizes;
  line
  line `(f) the conduct of examinations, including the terms of office and manner of appointment`
  line `and the duties of examining bodies, examiners and moderators;`
  line
  line `^2[(g) the remuneration to be paid to the examiner, moderator, invigilator and tabulator;]`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing for them of special courses of studies;`
  line
  line `(j) the giving of religious instruction;`
  line
  line `(k) the emoluments and the terms and conditions of service of ^3[the academic and other staff of the`
  line University];
  line
  line `(l) the maintenance of high schools and other institutions in accordance with the provisions of`
  line `section 12;`
  line
  line `^4[(m) the establishment of Centres of Study, Boards of Study, Inter-Disciplinary Committees,`
  line `Special Centres, Specialised Laboratories, Committees on Advanced Study and Research, Committees`
  line `of Department and Centres, Admission Committees, Examination Committee, Boards of Residence`
  line `and Halls, Discipline Committee, Cultural Committee, Social Service Committee, Games Committee`
  line `and Student's Advisory Committees;`
  line
  line `(n) the manner of co-operation and collaboration with other Universities and authorities including`
  line `learned bodies or associations;`
  line
  line `(o) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(p) such other terms and conditions of teachers as are not prescribed by the Statutes; and`
  line
  line `(q) all other matters which by this Act or the Statutes may be provided for by the Ordinances.]`
  line
  line `^5[(2) The Ordinances in force immediately before the commencement of the Aligarh Muslim`
  line `University (Amendment) Act, 1972 (34 of 1972), may be amended, repealed or added to at any time by`
  line `the Executive Council, provided that--`
  line
  line `(i) in making the Ordinances in respect of the matters enumerated in sub-section (1) other than`
  line `those enumerated in clauses (k) and (p), the Executive Council shall act on the recommendation of the`
  line `Academic Council.`
  line
  line `^6* * * * *]`
  line
  line `(3) The Executive Council shall not have power to amend any draft proposed by the Academic`
  line `Council under the provisions of sub-section (2) but may reject the proposal or return the draft to the`
  line `Academic Council for reconsideration, either in whole or in part, together with any amendments which`
  line `the Executive Council may suggest.`
  line
  line ^7[
  line `^8[(4) Where the Executive Council has rejected or returned the draft of an Ordinance proposed by`
  line `the Academic Council, the Academic Council may consider the question afresh and in case the original`
  line `draft is re-affirmed by a majority of not less than. two-thirds of the members present and voting and more`
  line `than half the total number of members of the Academic Council, the draft may be sent back to the`
  line `Executive Council which shall either adopt it or refer it to the Visitor whose decision shall be final.`
  line
  line `(5) Every Ordinance made by the Executive Council shall come into effect immediately.`
  line
  line `(6) Every Ordinance made by the Executive Council shall be submitted to the Visitor within two`
  line `weeks. The Visitor shall have the power to direct the University within four weeks of the receipt of the`
  line `Ordinance to suspend the operation of any such Ordinance and he shall, as soon as possible inform the`
  line `Executive Council about his objection to the proposed Ordinance. The Visitor may, after receiving the`
  line `comments of the University, either withdraw the order suspending the Ordinance or disallow the`
  line `Ordinance, and his decision shall be final.]]]`
obj_root_law_sections_29_footnotes:
  string
  line `1. Subs. by Act 62 of 1951, s. 21, for sections 29 and 30.`
  line
  line `2. Subs. by Act 34 of 1972, s. 25, for clause (g) (w.e.f. 17-6-1972).`
  line
  line `3. Subs. by s. 25, ibid., for "teachers of the University" (w.e.f. 17-6-1972).`
  line
  line `4. Subs. by s. 25, ibid., for clauses (m) and (n) (w.e.f. 17-6-1972).`
  line
  line `5. Subs. by s. 25, ibid., for sub-section (2) (w.e.f. 17-6-1972).`
  line
  line `6. Clause (ii) omitted by Act 62 of 1981, s. 17 (w.e.f. 10-2-1982).`
  line
  line `7. Subs. by Act 19 of 1965, s. 4, for sub-sections (4), (5), (6) and (7).`
  line
  line `8. Subs. by Act 34 of 1972, s. 25, for sub-sections (4), (5) and (6) (w.e.f. 17-6-1972).`
obj_root_law_sections_31:
  sectionId (40747)
  sectionNo (31)
  orderNo 35
  title Regulations.
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40747&sectionno=31&orderno=35&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_31_content:
  string
  line `(1) The authorities of the University may make Regulations consistent with this`
  line `Act, the Statutes and the Ordinances--`
  line
  line `(a) laying down the procedure to be observed at their meetings and the number of members`
  line `required to form a quorum;`
  line
  line `(b) providing for all matters which by this Act, the Statutes or the Ordinances, are to be prescribed`
  line `by Regulations; and`
  line
  line `(c) providing for all other matters solely concerning such authorities or committees appointed by`
  line `them not provided for by this Act, the Statutes and the Ordinances.`
  line
  line `(2) Every authority of the University shall make Regulations providing for the giving of notice to the`
  line `members of such authority of the dates of meetings and of the business to be considered at meetings and`
  line `for the keeping of a record of the proceedings of meetings.`
  line
  line `^1[(3) The Executive Council may direct the amendment, in such manner as it may specify, of any`
  line `Regulation made under this section other ^2[than any Regulation made by the Court] or the annulment of`
  line `any such Regulation:`
  line
  line `^3[(4) Every Statute, Ordinance or Regulation made under this Act shall be published in the Official`
  line Gazette.
  line
  line `(5) Every statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session or the successive sessions aforesaid, both houses agree in making, any modification in the Statute,`
  line `Ordinance or Regulation or both Houses agree that the Statute, Ordinance or Regulation shall thereafter`
  line `have effect only in such modified form or, be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `the Statute, Ordinance or Regulation.]`
  line
  line `^4* * * * *`
obj_root_law_sections_31_footnotes:
  string
  line `1Ins. by Act 62 of 1951, s. 22.`
  line
  line `2. Ins. by Act 62 of 1981, s. 18 (w.e.f, 10-2-1982).`
  line
  line `3. Ins. by Act 4 of 2005, s. 2 and the Schedule.`
  line
  line `4. Proviso omitted by Act 19 of 1965, s. 5.`
obj_root_law_sections_32:
  sectionId (40748)
  sectionNo (32)
  orderNo 36
  title [Omitted.].
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40748&sectionno=32&orderno=36&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_32_content:
  string
  line `[Admission to the University.] Rep. by the Aligarh Muslim University (Amendment) Act, 1951`
  line `(62 of 1951), s. 23.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (40749)
  sectionNo (33)
  orderNo 37
  title Examinations.
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40749&sectionno=33&orderno=37&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_33_content:
  string
  line `(1) All arrangements for the conduct of examinations shall be made, and all`
  line `examiners shall be appointed by ^1[the Executive Council on the recommendation of the Academic`
  line Council].
  line
  line `^2* * * * *`
  line
  line `(3) The Academic Council shall appoint examination committees, consisting of members of its own`
  line `body or of other persons or of both, as it thinks fit, to moderate examination question,`
  line `^3[and to prepare`
  line `and publish] the results of the examinations ^4***`
obj_root_law_sections_33_footnotes:
  string
  line `1. Subs. by Act 62 of 1951, s. 24, for "the Academic Council in such manner as may he prescribed by the Ordinances".`
  line
  line `2. Sub-section (2) omitted by s. 24, ibid.`
  line
  line `3. Subs. by Act 62 of 1951, s. 24, for "to prepare".`
  line
  line `4. The words "and to report such results to the Executive Council for publication" omitted by s. 24, ibid.`
obj_root_law_sections_34:
  sectionId (40750)
  sectionNo (34)
  orderNo 38
  title `Annual report.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40750&sectionno=34&orderno=38&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_34_content:
  string
  line `^1[34. Annual report.--(1) The Annual Report of the University shall be prepared under the`
  line `direction of the Executive Council and shall be submitted to the Court on or after such date as may be`
  line `prescribed by the Statutes and the Court shall consider the Report in its annual meeting.`
  line
  line `(2) The Court shall submit the Annual Report to the Visitor and also to the Chancellor along with its`
  line `comments, if any.]`
  line
  line `^2[(3) A copy of the Annual Report as submitted to the Visitor shall also be submitted to the Central`
  line `Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.]
obj_root_law_sections_34_footnotes:
  string
  line `1. Subs. by Act 34 of 1972. s. 26, for s. 34 (w.e.f. 17-6-1972).`
  line
  line `2. Ins. by Act 62 of 1981, s. 19 (w.e.f. (10-2-1982).`
obj_root_law_sections_35:
  sectionId (40751)
  sectionNo (35)
  orderNo 39
  title `Annual accounts.`
  content obj_root_law_sections_35_content
  footnotes `1. Subs. by s. 20, ibid. (w.e.f. 10-2-1982).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40751&sectionno=35&orderno=39&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_35_content:
  string
  line `^1[35. Annual accounts.--(1) The annual accounts and balance sheet of the University shall be`
  line `prepared under the direction of the Executive Council and shall, once at least every year and at intervals`
  line `of not more than fifteen months, be audited by the Comptroller and Auditor-General of India or by such`
  line `person or persons as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts, together with the audit report thereon, shall be submitted to the`
  line `Court and the Visitor along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Court and the observations of the Court, if any, shall, after being considered by the Executive Council, be`
  line `submitted to the Visitor.`
  line
  line `(4) A copy of the annual accounts, together with the audit report, as submitted to the Visitor, shall`
  line `also be submitted to the Central Government, which shall, as soon as may be, cause the same to be laid`
  line `before both Houses of Parliament.`
  line
  line `(5) The audited annual accounts, after having been laid before both the Houses of Parliament, shall be`
  line `published in the Gazette of India.]`
obj_root_law_sections_36:
  sectionId (40752)
  sectionNo (36)
  orderNo 40
  title `Conditions of service of employee.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40752&sectionno=36&orderno=40&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_36_content:
  string
  line `(1) Every ^1[employee] of the University shall be`
  line `appointed on a written contract, which shall be lodged with the University and a copy of which shall be`
  line `furnished to the ^2[employee] concerned.`
  line
  line `(2) Any dispute arising out of a contract between the University and any of its ^3[employees] shall, at`
  line `the request of the ^3[employee] concerned be referred to a Tribunal of Arbitration consisting of one`
  line `member appointed by the Executive Council, one member nominated by the ^3[employee] concerned and`
  line `an umpire appointed by the ^4[Visitor]. The decision of the Tribunal shall be final, and no suit shall lie in`
  line `any Civil Court in respect of the matters decided by the Tribunal. Every such request shall be deemed to`
  line `be a submission to arbitration upon the terms of this section within the meaning of the Indian Arbitration`
  line `Act, 1899^5`
  line `(9 of 1899) , and all the provisions of that Act, with the exception of section 2 thereof shall`
  line `apply accordingly.`
obj_root_law_sections_36_footnotes:
  string
  line `1. Subs. by Act 34 of 1972. s. 28, for "salaried officer and teacher" (w.e.f. 17-6-1972 ).`
  line
  line `2. Subs. by s. 28, ibid. for "officer or teacher" (w.e.f. 17-6-1972).`
  line
  line `3. Subs. by Act 34 of 1972, s. 28, for "officers or teachers" (w.e.f. 17-6-1972)`
  line
  line `4. Subs. by Act 62 of 1951, s. 26, for "Visiting Board".`
  line
  line `5. See now the Arbitration Act, 1940 (10 of 1940).`
obj_root_law_sections_36_a:
  sectionId (40753)
  sectionNo 36A
  orderNo 41
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_36_a_content
  footnotes `1. Ins. by Act 34 of 1972, s. 29 (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40753&sectionno=36A&orderno=41&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_36_a_content:
  string
  line `^1[36A. Procedure of appeal and arbitration in disciplinary cases against students.--(1) Any`
  line `student or candidate for an examination whose name has been removed from the rolls of the University`
  line `by the orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as`
  line `the case may be, and who has been debarred from appearing at the examinations of the University for`
  line `more than a year, may, within ten days of the date of receipt of such order or copy of such resolution by`
  line `him, appeal to the Executive Council and the Executive Council may confirm, modify or reverse the`
  line `decision of the Vice-Chancellor or the Committee, as the ease may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-section`
  line `(2) of section 36 shall, as far as may be, apply to the reference made under this sub-section.]`
obj_root_law_sections_36_b:
  sectionId (40754)
  sectionNo 36B
  orderNo 42
  title `Right to appeal.`
  content obj_root_law_sections_36_b_content
  footnotes `1. Ins. by Act 34 of 1972, s. 29 (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40754&sectionno=36B&orderno=42&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_36_b_content:
  string
  line `^1[36B. Right to appeal.--Every employee or student of the University shall, notwithstanding anything`
  line `contained in this Act, have a right to appeal, within such time as may be prescribed by the Statutes, to the`
  line `Executive Council against the decision of any officer or authority of the University and thereupon the`
  line `Executive Council may confirm, modify or reverse the decision appealed against.]`
obj_root_law_sections_37:
  sectionId (40755)
  sectionNo (37)
  orderNo 43
  title `Provident and pension funds.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40755&sectionno=37&orderno=43&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_37_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `officers, teachers and servants such ^1[pension or provident funds or provide such insurance schemes] as it`
  line `it may deem fit in such manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident or pension fund has been so constituted, the^2[Central Government] may`
  line `declare ^3that the provisions of the Provident Funds Act, ^4[1925] (19 of 1925), shall apply to such fund, as`
  line `as if it were a Government provident fund.`
obj_root_law_sections_37_footnotes:
  string
  line `1. Subs. by Act 62 of 1951, s. 27, for "provident and pension funds".`
  line
  line `2. Subs. by the A.O. 1937, for "G.G. in C.".`
  line
  line `3. For such declaration see Notification No. 151 (5, dated the 14th July, 1927, Gazette of India, 1927, Pt. I, I. 764`
  line `(G.S.R.O. Volume VIII, p. 192).`
  line
  line `4. Subs. by Act 62 of 1951, s. 27, for "1897"`
obj_root_law_sections_38:
  sectionId (40756)
  sectionNo (38)
  orderNo 44
  title `Filling of casual vacancies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40756&sectionno=38&orderno=44&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_38_content:
  string
  line `^1* * * *`
  line
  line `(2) ^2*** ^3*** casual vacancies in ^4[any office or in any authority] shall be filled up by the authority`
  line `which has power to appoint to the office or authority ^5***.`
obj_root_law_sections_38_footnotes:
  string
  line `1. Sub-section (1) omitted by s. 28, ibid.`
  line
  line `2. The words, brackets and figures "Subject to the provisions of sub-section (3) of section 18," omitted by Act 34 of`
  line `1972, s. 30 (w.e.f. 17-6-1972).`
  line
  line `3. The word "other" omitted by Act 62 of 1951, s. 28.`
  line
  line `4. Subs. by s. 28, ibid., for "any office of any authority".`
  line
  line `5. Certain words omitted by Act 19 of 1965, s. 8. 12.`
obj_root_law_sections_39:
  sectionId (40757)
  sectionNo (39)
  orderNo 45
  title `Proceedings of University authorities not invalidated by vacancies.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40757&sectionno=39&orderno=45&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_39_content:
  string
  line `No act or`
  line `proceeding of any authority of the University shall be invalidated merely by reason of the existence of a`
  line `vacancy or vacancies among its members.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (40758)
  sectionNo (40)
  orderNo 46
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_40_content
  footnotes `1.Ins. by Act 34 of 1972, s. 31 (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40758&sectionno=40&orderno=46&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_40_content:
  string
  line `^1[40. Protection of action taken in good faith.--No suit or other legal proceeding shall lie against`
  line `any officer or employee of the University for anything which. is in good faith done or intended to be done`
  line `in pursuance of the provisions of this Act, Statutes or Ordinances.]`
obj_root_law_sections_41:
  sectionId (40759)
  sectionNo (41)
  orderNo 47
  title `Mode of proof of University record.`
  content obj_root_law_sections_41_content
  footnotes `1.Ins. by Act 34 of 1972, s. 31 (w.e.f. 17-6-1972).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00038_192040_1523343938865&sectionId=40759&sectionno=41&orderno=47&orgactid=AC_CEN_9_30_00038_192040_1523343938865
obj_root_law_sections_41_content:
  string
  line `^1[41. Mode of proof of University record.--A copy of any receipt, application, notice, order,`
  line `proceeding, resolution of any authority or Committee of the University or other documents in possession`
  line `of the University or any entry in any register duly maintained by the University, if certified by the`
  line `Registrar, shall be received as prima facie evidence of such receipt, application, notice, order, proceeding`
  line `or resolution, document or the existence of entry in the register and shall be admitted as evidence of the`
  line `matters and transactions therein where the original thereof would, if produced, have been admissible in`
  line `evidence, notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872), or in any`
  line `other law for the time being in force.]`
