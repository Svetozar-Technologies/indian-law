obj_root_law_sections_261:
  object
  (str sectionId) (str 45469)
  (str sectionNo) (str 261)
  (str orderNo) (int 263)
  (str title) (str Repealed..)
  (str content) (str `[Non-liability of deceased partners estate for subsequent obligations.] Rep. by s. 73 and the
