obj_root_law_sections_1:
  sectionId (49369)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00043_201910_1562758090123&sectionId=49369&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00043_201910_1562758090123
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Central Educational Institutions`
  line `(Reservation in Teachers' Cadre) Act, 2019.`
  line
  line `(2) It shall be deemed to have come into force on the 7th day of March, 2019.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (49370)
  sectionNo (2)
  orderNo 2
  title Definitions
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00043_201910_1562758090123&sectionId=49370&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00043_201910_1562758090123
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) “appropriate authority” means the University Grants Commission established under the`
  line `University Grants Commission Act, 1956 (3 of 1956), or any other authority or body established by or`
  line `under a Central Act for the determination, coordination or maintenance of the standards of higher`
  line `education in any Central Educational Institution;`
  line
  line `(b) “branch of study” means a branch of study leading to three principal levels of qualifications at`
  line `bachelors (under graduate), masters (post graduate) and doctoral levels;`
  line
  line `(c) “Central Educational Institution”means—`
  line
  line `(i) a University established or incorporated by or under a Central Act;`
  line
  line `(ii) an institution of national importance established by an Act of Parliament;`
  line
  line `(iii) an institution, declared as an institution deemed to be University under section 3 of the`
  line `University Grants Commission Act, 1956 (3 of 1956),, and maintained by or receiving aid from the`
  line `Central Government;`
  line
  line `(iv) an institution maintained by or receiving aid from the Central Government, whether`
  line `directly or indirectly, and affiliated to an institution referred to in sub-clause (i) or sub-clause (ii), or`
  line `a constituent unit of an institution referred to in sub-clause (iii); and`
  line
  line `(v) an educational institution established by the Central Government under the Societies`
  line `Registration Act, 1860 (21 of 1860);`
  line
  line `(d) “direct recruitment” means the process of appointing faculty by inviting applications against`
  line `public advertisement from persons eligible to teach in aCentral Educational Institution;`
  line
  line `(e) “economically weaker sections” means such weaker sections as are referred to in Explanation`
  line `to clause (6) of article 15 of the Constitution;`
  line
  line `(f) “faculty” means the faculty of a Central Educational Institution;`
  line
  line `(g) “Minority Educational Institution” means an institution established and administered by the`
  line `minorities under clause (1) of article 30 of the Constitution and so declared by an Act of Parliament or by`
  line `the Central Government or declared as a Minority Educational Institution under the National`
  line `Commission for Minority Educational Institutions Act,2004 (2 of 2005);`
  line
  line `(h) “sanctioned strength” means the number of posts in teachers’ cadre approved by the appropriate authority;`
  line
  line `(i) “Scheduled Castes” means the Scheduled Castes notified under article 341 of the Constitution;br`
  line
  line `(j) “Scheduled Tribes” means the Scheduled Tribes notified under article 342 of the Constitution;br`
  line
  line `(k) “socially and educationally backward classes” means such backward classes as are so deemed`
  line `under article 342 A of the Constitution;br`
  line
  line `(l) “teachers’ cadre” means a class of all the teachers of a Central Educational Institution,`
  line `regardless of the branch of study or faculty, who are remunerated at the same grade of pay, excluding`
  line `any allowance or bonus.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (49371)
  sectionNo (3)
  orderNo 3
  title `Reservation of posts in recruitments by Central Educational Institutions.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00043_201910_1562758090123&sectionId=49371&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00043_201910_1562758090123
obj_root_law_sections_3_content:
  string
  line `(1)`
  line `Notwithstanding anything in any other law for the time being in force, there shall be reservation of posts`
  line `in direct recruitment out of the sanctioned strength in teachers' cadre in a Central Educational Institution`
  line `to the extent and in the manner as may be specified by the Central Government by notification in the`
  line `Official Gazette.`
  line
  line `(2) For the purpose of reservation of posts, a Central Educational Institution shall be regarded as one`
  line unit.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (49372)
  sectionNo (4)
  orderNo 4
  title `Act not to apply in certain cases.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00043_201910_1562758090123&sectionId=49372&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00043_201910_1562758090123
obj_root_law_sections_4_content:
  string
  line `The provisions of section 3 shall not apply to---`
  line
  line `(a) the institutions of excellence, research institutions, institutions of national and strategic`
  line `importance specified in the Schedule to this Act;`
  line
  line `(b) a Minority Educational Institution.`
  line
  line `(2) The Central Government may, by notification in the Official Gazette, amend the Schedule referred`
  line `to in clause (a) of sub-section (1) from time to time.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (49373)
  sectionNo (5)
  orderNo 5
  title `Laying of notifications before Parliament.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00043_201910_1562758090123&sectionId=49373&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00043_201910_1562758090123
obj_root_law_sections_5_content:
  string
  line `Every notification made by the Central Government`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament while it is`
  line `in session, for a total period of thirty days which may be comprised in one session or in two or more successive`
  line `sessions, and if, before the expiry of the session immediately following the session or the successive`
  line `sessions aforesaid, both Houses agree in making any modification in the notification or both Houses agree`
  line `that the notification should not be made, the notification shall thereafter have effect only in such modified`
  line `form or be of no effect, as the case may be; so, however, that any such modification or annulment shall be`
  line `without prejudice to the validity of anything previously done under that notification.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (49374)
  sectionNo (6)
  orderNo 6
  title `Repeal and savings.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00043_201910_1562758090123&sectionId=49374&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00043_201910_1562758090123
obj_root_law_sections_6_content:
  string
  line `(1) The Central Educational Institutions (Reservation in Teachers'`
  line `Cadre) Ordinance, 2019 (Ord. 13 of 2019) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
