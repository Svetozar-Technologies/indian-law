obj_root_law:
  object
  (str slug) (str the-gram-nyayalayas-act-2008)
  (str handle) (str 2060)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Gram Nyayalayas Act, 2008`)
  (str actNumber) (str 04)
  (str enactmentDate) (str 2009-01-07)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2060`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `ग्राम न्‍यायालय अधिनियम, 2008`)
  (str actYear) (str 2009)
  (str ministry) (str `Ministry of Law and Justice`)
  (str department) (str `Department of Justice`)
  (str longTitle) (str `An Act to provide for the establishment of Gram Nyayalayas at the grass roots level for the purposes of providing access to justice to the citizens at their doorsteps and to ensure that opportunities for securing justice are not denied to any citizen by reason of social, economic or other disabilities and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 02-10-2009)
  (str notification) (str `2nd October, 2009, vide notification No. S.O. 2313(E), dated 11th November, 2009, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-08T21:12:53.700Z`)
  (str translations) obj_root_law_translations
