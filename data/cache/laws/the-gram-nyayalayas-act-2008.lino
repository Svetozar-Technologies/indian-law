obj_root_law:
  slug the-gram-nyayalayas-act-2008
  handle (2060)
  collectionHandle 123456789/1362
  title `The Gram Nyayalayas Act, 2008`
  actNumber (04)
  enactmentDate 2009-01-07
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2060`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `ग्राम न्‍यायालय अधिनियम, 2008`
  actYear (2009)
  ministry `Ministry of Law and Justice`
  department `Department of Justice`
  longTitle `An Act to provide for the establishment of Gram Nyayalayas at the grass roots level for the purposes of providing access to justice to the citizens at their doorsteps and to ensure that opportunities for securing justice are not denied to any citizen by reason of social, economic or other disabilities and for matters connected therewith or incidental thereto.`
  enforcementDate 02-10-2009
  notification `2nd October, 2009, vide notification No. S.O. 2313(E), dated 11th November, 2009, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T21:12:53.700Z`
  translations obj_root_law_translations
