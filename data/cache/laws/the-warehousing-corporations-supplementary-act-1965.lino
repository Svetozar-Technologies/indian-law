obj_root_law_sections_1:
  object
  (str sectionId) (str 34626)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title, application and commencement.`)
  (str content) (str `(1) This Act may be called the Warehousing
Corporations (Supplementary) Act, 1965.

(2) It shall apply to the State specified in the Schedule:

Provided that the Central Government may, by notification in the Official Gazette, add the name
of any other State to the Schedule in respect whereof resolutions have been passed by the Legislatures
of those States adopting this Act under clause (1) of article 252 of the Constitution in respect of the
storage of commodities other than those covered by the Warehousing Corporations
Act, 1962 (58 of 1962), and on the issue of any such notification the States so added shall be deem to
be States specified in the Schedule within the meaning of this sub-section.

(3) It shall come into force on such date^1 , as the Central Government may, by notification in the
Official Gazette, appoint.`)
  (str footnotes) (str `1. 27th November, 1965, vide notification No. G.S.R. 1713, dated 17th, Nevember, 1965, see Gazette of India, Part II,
sec. 3(i).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_28_00002_196520_1517807319565&sectionId=34626&sectionno=1&orderno=1&orgactid=AC_CEN_21_28_00002_196520_1517807319565)
obj_root_law_sections_2:
  object
  (str sectionId) (str 34627)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Application of the Act with respect to notified commodities.`)
  (str content) (str `The Warehousing Corporations
Act, 1962 (58 of 1962), shall, in its application to the States for the time being specified in the
Schedule, have effect as if in clause (e) of section 2 of that Act the words and figures "being a
commodity with respect to which Parliament has power to make laws by virtue of entry 33 in List III
in the Seventh Schedule to Constitution" had been omitted.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_21_28_00002_196520_1517807319565&sectionId=34627&sectionno=2&orderno=2&orgactid=AC_CEN_21_28_00002_196520_1517807319565)
