  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str Repealed.)
  (str content) (str `[Repeal and saving.]—Rep. by the Repealing and Amending Act, 1957 (36 of 1957), s. 2 and
Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39429&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00032_195010_1517807322055)
