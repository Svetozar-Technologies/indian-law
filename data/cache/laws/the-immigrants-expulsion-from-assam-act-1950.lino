obj_root_law_sections_1:
  object
  (str sectionId) (str 39423)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and extent.`)
  (str content) (str `(1) This Act may be called the Immigrants (Expulsion from Assam)
Act, 1950.

(2) It extends to the whole of India.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39423&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00032_195010_1517807322055)
obj_root_law_sections_2:
  object
  (str sectionId) (str 39424)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Power to order expulsion of certain immigrants.`)
  (str content) (str `If the Central Government is of opinion that
any person or class of persons, having been ordinarily resident in any place outside India, has or have,
whether before or after the commencement of this Act, come into Assam and that the stay of such person
or class of persons in Assam is detrimental to the interests of the general public of India or of any section
thereof or of any Scheduled Tribe in Assam, the Central Government may by order—

(a) direct such person or class of persons to remove himself or themselves from India or Assam
within such time and by such route as may be specified in the order; and

(b) give such further directions in regard to his or their removal from India or Assam as it may
consider necessary or expedient:

Provided that nothing in this section shall apply to any person who on account of civil disturbances or
the fear of such disturbances in any area now forming part of Pakistan has been displaced from or has left
his place of residence in such area and who has been subsequently residing in Assam.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39424&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00032_195010_1517807322055)
obj_root_law_sections_3:
  object
  (str sectionId) (str 39425)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Delegation of power.`)
  (str content) (str `The Central Government may, by notification in the Official Gazette,
direct that the powers and duties conferred or imposed on it by section 2 shall, subject to such conditions,
if any, as may be specified in the notification, be exercised or discharged also by—

(a) any officer subordinate to the Central Government;

(b) the ^1
[
^2
[Government of Assam, Meghalaya or Nagaland] any officer subordinate to that
Government.`)
  (str footnotes) (str `1 Subs. by the State of Nagaland (Adaptation of Laws on Union Subjects) Order, 1965, for "Government of Assam"
(w.e.f. 1-12-1963).

2 Subs. by the North-Eastern Areas (Reorganisation) (Adaptation of Laws on Union Subjects) Order, 1974, for "Government of
Assam" (w.e.f. 21-1-1972).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39425&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00032_195010_1517807322055)
obj_root_law_sections_4:
  object
  (str sectionId) (str 39426)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Power to give effect to orders, etc.`)
  (str content) (str `Any authority empowered by or in pursuance of the
provisions of this Act to exercise any power may, in addition to any other action expressly provided for in
this Act, take or cause to be taken such steps, and use or cause to be used such force, as may in its opinion
be reasonably necessary for the effective exercise of such power.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39426&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00032_195010_1517807322055)
obj_root_law_sections_5:
  object
  (str sectionId) (str 39427)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str Penalties.)
  (str content) (str `Any person who—

(a) contravenes or attempts to contravene or abets the contravention of any order made under
section 2, or

(b) fails to comply with any direction given by any such order, or

(c) harbours any person who has contravened any order made under section 2 or has failed to
comply with any direction given by any such order,

shall be punishable with imprisonment which may extend to three years and shall also be liable to fine.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39427&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00032_195010_1517807322055)
obj_root_law_sections_6:
  object
  (str sectionId) (str 39428)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Protection to persons acting under this Act.`)
  (str content) (str `No suit, prosecution or other legal proceeding
shall lie against any person for anything which is in good faith done or intended to be done under this Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39428&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00032_195010_1517807322055)
