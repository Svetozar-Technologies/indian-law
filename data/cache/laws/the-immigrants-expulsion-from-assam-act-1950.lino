obj_root_law_sections_1:
  sectionId (39423)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39423&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00032_195010_1517807322055
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Immigrants (Expulsion from Assam)`
  line `Act, 1950.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39424)
  sectionNo (2)
  orderNo 2
  title `Power to order expulsion of certain immigrants.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39424&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00032_195010_1517807322055
obj_root_law_sections_2_content:
  string
  line `If the Central Government is of opinion that`
  line `any person or class of persons, having been ordinarily resident in any place outside India, has or have,`
  line `whether before or after the commencement of this Act, come into Assam and that the stay of such person`
  line `or class of persons in Assam is detrimental to the interests of the general public of India or of any section`
  line `thereof or of any Scheduled Tribe in Assam, the Central Government may by order—`
  line
  line `(a) direct such person or class of persons to remove himself or themselves from India or Assam`
  line `within such time and by such route as may be specified in the order; and`
  line
  line `(b) give such further directions in regard to his or their removal from India or Assam as it may`
  line `consider necessary or expedient:`
  line
  line `Provided that nothing in this section shall apply to any person who on account of civil disturbances or`
  line `the fear of such disturbances in any area now forming part of Pakistan has been displaced from or has left`
  line `his place of residence in such area and who has been subsequently residing in Assam.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39425)
  sectionNo (3)
  orderNo 3
  title `Delegation of power.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39425&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00032_195010_1517807322055
obj_root_law_sections_3_content:
  string
  line `The Central Government may, by notification in the Official Gazette,`
  line `direct that the powers and duties conferred or imposed on it by section 2 shall, subject to such conditions,`
  line `if any, as may be specified in the notification, be exercised or discharged also by—`
  line
  line `(a) any officer subordinate to the Central Government;`
  line
  line `(b) the ^1`
  line [
  line ^2
  line `[Government of Assam, Meghalaya or Nagaland] any officer subordinate to that`
  line Government.
obj_root_law_sections_3_footnotes:
  string
  line `1 Subs. by the State of Nagaland (Adaptation of Laws on Union Subjects) Order, 1965, for "Government of Assam"`
  line `(w.e.f. 1-12-1963).`
  line
  line `2 Subs. by the North-Eastern Areas (Reorganisation) (Adaptation of Laws on Union Subjects) Order, 1974, for "Government of`
  line `Assam" (w.e.f. 21-1-1972).`
obj_root_law_sections_4:
  sectionId (39426)
  sectionNo (4)
  orderNo 4
  title `Power to give effect to orders, etc.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39426&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00032_195010_1517807322055
obj_root_law_sections_4_content:
  string
  line `Any authority empowered by or in pursuance of the`
  line `provisions of this Act to exercise any power may, in addition to any other action expressly provided for in`
  line `this Act, take or cause to be taken such steps, and use or cause to be used such force, as may in its opinion`
  line `be reasonably necessary for the effective exercise of such power.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39427)
  sectionNo (5)
  orderNo 5
  title Penalties.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39427&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00032_195010_1517807322055
obj_root_law_sections_5_content:
  string
  line `Any person who—`
  line
  line `(a) contravenes or attempts to contravene or abets the contravention of any order made under`
  line `section 2, or`
  line
  line `(b) fails to comply with any direction given by any such order, or`
  line
  line `(c) harbours any person who has contravened any order made under section 2 or has failed to`
  line `comply with any direction given by any such order,`
  line
  line `shall be punishable with imprisonment which may extend to three years and shall also be liable to fine.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39428)
  sectionNo (6)
  orderNo 6
  title `Protection to persons acting under this Act.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39428&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00032_195010_1517807322055
obj_root_law_sections_6_content:
  string
  line `No suit, prosecution or other legal proceeding`
  line `shall lie against any person for anything which is in good faith done or intended to be done under this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (39429)
  sectionNo (7)
  orderNo 7
  title Repealed.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00032_195010_1517807322055&sectionId=39429&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00032_195010_1517807322055
obj_root_law_sections_7_content:
  string
  line `[Repeal and saving.]—Rep. by the Repealing and Amending Act, 1957 (36 of 1957), s. 2 and`
  line Schedule.
obj_root_law_sections_7_footnotes:
  string
  line
