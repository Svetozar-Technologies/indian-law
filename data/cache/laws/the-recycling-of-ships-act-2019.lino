obj_root_law_sections_1:
  sectionId (51560)
  sectionNo (1)
  orderNo 1
  title `Short title, commencement and application.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51560&sectionno=1&orderno=1&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Recycling of Ships`
  line `Act, 2019.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act and any`
  line `reference in any such provision to the commencement of this Act shall be construed as a reference to the`
  line `coming into force of that provision.`
  line
  line `(3) Unless otherwise expressly provided, the provisions of this Act shall apply to---`
  line
  line `(a) any existing ship which is registered in India wherever it may be;`
  line
  line `(b) any new ship which is required to be registered in India, wherever it may be;`
  line
  line `(c) ships, other than those referred to in clauses (a) and (b), that enter a port, shipyard or off-shore`
  line `terminal or a place in India or within the Exclusive Economic Zone or territorial waters of India or`
  line `any marine areas adjacent thereto over which India has, or may have, exclusive jurisdiction with respect to control of pollution under the provisions of the Territorial Waters, Continental Shelf,`
  line `Exclusive Economic Zone and Other Maritime Zones Act, 1976, or any other law for the time being`
  line `in force;`
  line
  line `(d) any warship, naval auxiliary or other ship owned or operated by an Administration and used`
  line `on Government non-commercial service, and which is destined for recycling in a ship recycling`
  line `facility operating in or within the territorial jurisdiction of India; and`
  line
  line `(e) ship recycling facilities operating in India or within any area falling under the exclusive`
  line `territorial jurisdiction of India.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 27th October, 2020,--- S. 3 Vide notification No. S.O. 3838(E), dated 27th October, 2020, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3 (ii).`
  line
  line `25th February, 2021,--- S. 6, 30 and 42 vide notification No. S.O. 889 (E), dated 25th February, 2021, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (51561)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51561&sectionno=2&orderno=2&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Administration" means the Government of the country whose flag the ship is entitled to fly,`
  line `or under whose authority it is operating;`
  line
  line `(b) "certificate of authorisation of ship recycling facility" means the certificate referred to in`
  line `sub-section (6) of section 12;`
  line
  line `(c) "certificate on inventory of hazardous materials" means the certificate referred to in section 8;`
  line
  line `(d) "Competent Authority" means such Authority designated by the Central Government under`
  line `section 4;`
  line
  line `(e) "hazardous material" means any material or substance, which is liable to cause harm to human`
  line `beings, other living creatures, plants, micro-organisms, property or the environment;`
  line
  line `(f) "National Authority" means such Authority designated by the Central Government under`
  line `section 3;`
  line
  line `(g) "notification" means a notification published in the Official Gazette and the expressions`
  line `"notify" or "notified" shall be construed accordingly;`
  line
  line `(h) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(i) "ready for recycling certificate" means the certificate referred to in section 16;`
  line
  line `(j) "regulations" means the regulations made by the National Authority under this Act;`
  line
  line `(k) "ship" means a vessel and floating structure of any type whatsoever operating or having`
  line `operated in the marine environment and includes submersibles, floating craft, floating platforms, selfelevating platforms, the floating storage units, and the like;`
  line
  line `(l) "ship owner" means--`
  line
  line `(i) a person or an association of persons or body of individuals or a company registered as the`
  line `owner of the ship;`
  line
  line `(ii) any organisation or a person such as the Manager or the Bareboat Charterer, who has`
  line `assumed the responsibility for operation of the ship from the owner of the ship;`
  line
  line `(iii) a company, which is registered as operator and is operating a ship owned by the`
  line `Government; or`
  line
  line `(iv) a person or an association of persons or company owning the ship for a limited period`
  line `pending its sale or handing over to a ship recycling facility;`
  line
  line `(m) "Ship Recycler" means the owner of the ship recycling facility or any other organisation or`
  line `person who has assumed the responsibility for operation of the ship recycling facility and who has`
  line `agreed to take over all duties and responsibilities imposed by or under this Act;`
  line
  line `(n) "ship recycling" means the activity of dismantling of a ship at a ship recycling facility in order`
  line `to recover components and materials for reprocessing and reuse, while taking care of hazardous and`
  line `other materials and includes associated operations such as storage, treatment of components and`
  line `materials on site, but not their further processing or disposal in separate facilities;`
  line
  line `(o) "ship recycling facility" means a defined area that is a site, yard or facility used for the`
  line `recycling of ships and meets such requirements as may be specified by the regulations;`
  line
  line `(p) "ship recycling plan" means a plan specific to a ship developed by the ship recycling facility`
  line `to recycle such a ship in safe and environmentally sound manner;`
  line
  line `(q) "statement of acceptance" means a statement of acceptance referred to in sub-section (4) of`
  line `section 20;`
  line
  line `(r) "statement of completion" means a statement of completion referred to in section 23;`
  line
  line `(s) "Surveyor" means a Surveyor as defined under clause (48) of section 3 of the Merchant`
  line `Shipping Act, 1958 or any other person or body of persons as may be notified by the Central`
  line Government;
  line
  line `(t) "worker" means a person employed, directly or by or through any agency (including a`
  line `contractor) with or without the knowledge of the principal employer, whether for remuneration or not,`
  line `in any ship recycling, or in cleaning any part of the machinery or premises used for ship recycling, or`
  line `in any other kind of work incidental to, or connected with, the ship recycling, or the subject of the`
  line `ship recycling but does not include any member of the armed forces of the Union.`
  line
  line `(2) The words and expressions used and not defined in this Act but defined in the--`
  line
  line `(i) Explosives Act, 1884 (4 of 1884);`
  line
  line `(ii) Inland Vessels Act, 1917 (1 of 1917;`
  line
  line `(iii) Petroleum Act, 1934 (30 of 1934);`
  line
  line `(iv) Factories Act, 1948 (63 of 1948);`
  line
  line `(v) Merchant Shipping Act, 1958 (44 of 1958);`
  line
  line `(vi) Atomic Energy Act, 1962 (33 of 1962);`
  line
  line `(vii) Wildlife (Protection) Act, 1972 (53 of 1972);`
  line
  line `(viii) Water (Prevention and Control of Pollution) Act, 1974 (6 of 1974);`
  line
  line `(ix) Territorial Waters, Continental Shelf, Exclusive Economic Zone and Other Maritime Zones`
  line `Act, 1976 (80 of 1976);`
  line
  line `(x) Forest (Conservation) Act, 1980 (69 of 1980);`
  line
  line `(xi) Air (Prevention and Control of Pollution) Act, 1981 (14 of 1981);`
  line
  line `(xii) Environment (Protection) Act, 1986 (29 of 1986),`
  line
  line `shall have the same meanings respectively assigned to them in those Acts.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (51562)
  sectionNo (3)
  orderNo 3
  title `Designation of National Authority.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51562&sectionno=3&orderno=3&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_3_content:
  string
  line `The Central Government shall, by notification, designate an`
  line `officer not below the rank of Joint Secretary to the Government of India as the National Authority, which`
  line `shall administer, supervise and monitor all activities relating to ship recycling under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (51563)
  sectionNo (4)
  orderNo 4
  title `Designation of Competent Authority.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51563&sectionno=4&orderno=4&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_4_content:
  string
  line `The Central Government shall, by notification, designate`
  line `an Authority to be called the Competent Authority, for performance of such duties within the`
  line `geographical area or areas of expertise as may be prescribed.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (51564)
  sectionNo (5)
  orderNo 5
  title `Non-application of provisions of this Chapter.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51564&sectionno=5&orderno=5&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_5_content:
  string
  line `Nothing contained in this Chapter shall apply`
  line to–
  line
  line `(a) any warship, naval auxiliary, or other ships owned or operated by the Government and used`
  line `for Government non-commercial purpose;`
  line
  line `(b) ships of less than five hundred gross tonnage:`
  line
  line `Provided that the Central Government may notify appropriate measures, not impairing operations`
  line `or operational capabilities of such ships to ensure, as far as practicable, that such ships act in a`
  line `manner consistent with the provisions of this Act.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (51565)
  sectionNo (6)
  orderNo 6
  title `Controls on hazardous materials.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51565&sectionno=6&orderno=6&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_6_content:
  string
  line `(1) No ship shall instal or use such prohibited hazardous`
  line `materials as may be notified by the Central Government:`
  line
  line `Provided that the Central Government may, by notification and for the reasons specified therein,`
  line `exempt certain class or category of ships from the provisions of sub-section (1).`
  line
  line `(2) Every ship shall comply with such restrictions and conditions, as may be prescribed.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (51566)
  sectionNo (7)
  orderNo 7
  title Surveys.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51566&sectionno=7&orderno=7&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_7_content:
  string
  line `(1) The National Authority or such person or organisation, as the Central Government`
  line `may by notification authorise, shall carry out following surveys of the ships--`
  line
  line `(a) an initial survey before the issue of certificate on inventory of hazardous materials, so as to`
  line `verify such requirements as may be prescribed;`
  line
  line `(b) a renewal survey at intervals not exceeding five years as may be prescribed;`
  line
  line `(c) an additional survey either general or partial, at the request of the ship owner after a change,`
  line `replacement or significant repair of the structure, equipment, systems, fittings, arrangements or`
  line material;
  line
  line `(d) a final survey prior to the ship being taken out of service and before the recycling of the ship`
  line `so as to verify such requirements as may be prescribed; and`
  line
  line `(e) such other surveys as may be prescribed.`
  line
  line `(2) The survey shall be conducted and a certificate to this effect shall be issued in accordance with the`
  line `provisions of this Act and the rules or regulations made thereunder.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (51567)
  sectionNo (8)
  orderNo 8
  title `Certificate on inventory of hazardous materials.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51567&sectionno=8&orderno=8&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_8_content:
  string
  line `(1) The owner of every new ship shall make`
  line `an application to the National Authority for a certificate on inventory of hazardous materials for the`
  line `purposes of this Act and such certificate shall be specific to each ship:`
  line
  line `Provided that the existing ships on the date of commencement of this Act and for which the certificate`
  line `on inventory of hazardous materials had not been issued, the owner of such ship shall make an application`
  line `to the National Authority within a period of five years from the date of commencement of this Act:`
  line
  line `Provided further that a certificate on inventory of hazardous materials issued by any Administration`
  line `shall be valid for the purposes of this Act.`
  line
  line `(2) The terms and conditions, the format and the manner for granting the certificate on inventory of`
  line `hazardous materials shall be such as may be prescribed.`
  line
  line `(3) The certificate on inventory of hazardous materials shall be properly maintained and updated`
  line `throughout the operational life of the ship, reflecting the new installations containing hazardous materials`
  line `and relevant changes in the ship structure and equipment.`
  line
  line `Explanation.--For the purposes of this sub-section, the expression new installation includes`
  line `systems, equipment, insulation or other material installed on a ship after the date of coming into force of`
  line `this Act.`
  line
  line `(4) The certificate on inventory of hazardous materials shall be endorsed by the National Authority`
  line `after successful completion of an additional survey conducted in accordance with clause (c) of sub-section`
  line `(1) of section 7.`
  line
  line `Explanation.--For the purposes of this section, the expressions--`
  line
  line `(i) "existing ship" means a ship which is not a new ship;`
  line
  line `(ii) "new ship" means a ship,--`
  line
  line `(a) for which the building contract is placed on or after the date of coming into force of this`
  line `Act; or`
  line
  line `(b) other than the ship referred to in sub-clause (a), the keel of which is laid or which is at a`
  line `similar stage of construction after six months from the date of coming into force of this Act; or`
  line
  line `(c) which is to be delivered after thirty months from the date of coming into force of this Act,`
  line `and which is intended to be registered in India.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (51568)
  sectionNo (9)
  orderNo 9
  title `Validity of certificate.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51568&sectionno=9&orderno=9&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_9_content:
  string
  line `The certificate referred to in sub-section (1) of section 8 shall be issued`
  line `or renewed for such period, not exceeding five years, as may be prescribed:`
  line
  line `Provided that where validity of certificate on inventory of hazardous material expires at a time when a`
  line `ship is not in the port in which it is to be surveyed, the Administration may extend the period of validity`
  line `of such certificate and this extension shall be granted only--`
  line
  line `(a) for the purpose of allowing the ship to complete its voyage to the port in which it is to be`
  line `surveyed; or`
  line
  line `(b) in cases where it appears proper and reasonable to the Administration to do so:`
  line
  line `Provided further that no certificate shall be extended for a period longer than three months, and a ship`
  line `to which an extension is granted shall not, on its arrival on the port in which it is to be surveyed, be`
  line `entitled by virtue of such extension to leave that port without having the certificate renewed.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (51569)
  sectionNo (10)
  orderNo 10
  title `Suspension or cancellation of certificate.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51569&sectionno=10&orderno=10&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_10_content:
  string
  line `The certificate on inventory of hazardous materials`
  line `shall be liable to be suspended or cancelled by the National Authority in any of the following cases,`
  line `namely:--`
  line
  line `(i) if the ship, prima facie, does not comply with the particulars of the certificate;`
  line
  line `(ii) where the inventory of hazardous materials is not properly maintained and updated with such`
  line `changes in the ship structure and equipment as may be prescribed;`
  line
  line `(iii) in case of transfer of the ship to the flag of another State;`
  line
  line `(iv) if the survey specified by the Administration is not completed within the period specified in`
  line `section 7; or`
  line
  line `(v) if endorsement of certificate does not disclose,--`
  line
  line `(a) conduct of an additional survey as required under section 7; or`
  line
  line `(b) extension of the validity of the certificate required under section 9:`
  line
  line `Provided that no certificate under this section shall be suspended or cancelled unless the`
  line `owner of the ship has been given an opportunity of being heard.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (51570)
  sectionNo (11)
  orderNo 11
  title `Authorisation of ship recycling facility.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51570&sectionno=11&orderno=11&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_11_content:
  string
  line `No Ship Recycler shall recycle a ship, unless the ship`
  line `recycling facility is authorised as per the procedure laid down in section 12.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (51606)
  sectionNo (12)
  orderNo 12
  title `Ship recycling facility management plan and procedure for authorisation of ship recycling facility.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51606&sectionno=12&orderno=12&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_12_content:
  string
  line `(1) A Ship Recycler seeking a certificate of authorisation for ship recycling facility from the`
  line `Competent Authority or an organisation recognised by it, shall prepare a ship recycling facility`
  line `management plan as specified by the regulations and submit an application to the Competent Authority.`
  line
  line `(2) Every application for authorisation under sub-section (1), shall be made to the Competent`
  line `Authority in such form and manner and accompanied by such fee as may be prescribed.`
  line
  line `(3) Every ship recycling facility engaged in recycling of ships, immediately before the`
  line `commencement of this Act, shall apply for authorisation within sixty days from the date of such`
  line commencement.
  line
  line `(4) Subject to the provisions of sub-section (3), every ship recycling facility engaged in recycling of`
  line `ships, immediately before the commencement of this Act shall cease to conduct any such recycling on the`
  line `expiry of six months from the date of commencement of this Act unless such ship recycling facility has`
  line `applied for authorisation and is so authorised or till such application is disposed of, whichever is earlier.`
  line
  line `(5) No ship recycling facility shall be authorised under this Act unless the Competent Authority is`
  line `satisfied that such facility maintains such equipment and standards as may be specified by the regulations.`
  line
  line `(6) The Competent Authority shall, after holding an enquiry and after satisfying itself that the`
  line `applicant has complied with all the requirements of this Act and the rules and the regulations made`
  line `thereunder, grant a certificate of authorisation in such format as may be specified by the regulations.`
  line
  line `(7) If, after an enquiry and after giving to the applicant an opportunity of being heard, the Competent`
  line `Authority is satisfied that the applicant has not complied with the requirements of this Act, or the rules or`
  line `regulations made thereunder, it shall, for reasons to be recorded in writing, reject the application for`
  line authorisation.
  line
  line `(8) Every certificate of authorisation for ship recycling facility shall be valid for such period not`
  line `exceeding five years as may be specified by the regulations.`
  line
  line `(9) Every certificate of authorisation shall be renewed in such manner and after such period and on`
  line `payment of such fee as may be prescribed.`
  line
  line `(10) The Competent Authority shall undertake an annual audit of every ship recycling facility to`
  line `satisfy compliance with the requirements of this Act, the rules and regulations made thereunder and`
  line `forward such audit report to the National Authority.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (51572)
  sectionNo (13)
  orderNo 13
  title `Suspension or cancellation of authorisation.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51572&sectionno=13&orderno=13&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_13_content:
  string
  line `(1) The Competent Authority may, whenever it`
  line `considers necessary, for the reasons to be recorded in writing, conduct an enquiry or inspection of a ship`
  line `recycling facility and issue a notice to the Ship Recycler to show cause as to why the authorisation of his`
  line `ship recycling facility should not be suspended or cancelled for the reasons mentioned in the notice.`
  line
  line `(2) The manner of enquiry or inspection by the Competent Authority shall be such as may be`
  line `specified by the regulations.`
  line
  line `(3) If the Competent Authority is satisfied that there has been a breach of the provisions of this Act or`
  line `the rules or the regulations made thereunder, it may, without prejudice to any criminal action that it may`
  line `take against such Ship Recycler, suspend or cancel the authorisation of his ship recycling facility:`
  line
  line `Provided that no such authorisation shall be suspended or cancelled without giving an opportunity of`
  line `being heard in the matter to the Ship Recycler.`
  line
  line `(4) Notwithstanding anything contained in sub-sections (1) and (2), if the Competent Authority is of`
  line `the opinion that it is necessary or expedient so to do in public interest, it may, for reasons to be recorded`
  line `in writing, suspend or cancel the authorisation of any ship recycling facility without issuing any notice`
  line `referred to in sub-section (1).`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (51573)
  sectionNo (14)
  orderNo 14
  title `Emergency preparedness and response.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51573&sectionno=14&orderno=14&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_14_content:
  string
  line `Every Ship Recycler shall maintain adequate`
  line `measures for emergency preparedness and response in accordance with the provisions of the Factories`
  line `Act, 1948 (63 of 1948) in his ship recycling facility.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (51574)
  sectionNo (15)
  orderNo 15
  title `Workers safety, training and insurance.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51574&sectionno=15&orderno=15&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_15_content:
  string
  line `(1) Every Ship Recycler shall provide adequate`
  line `measures for safety, health, training and welfare of workers in his ship recycling facility and for this`
  line `purpose, the provisions of the Factories Act, 1948 (63 of 1948) shall apply.`
  line
  line `(2) Every Ship Recycler shall provide an individual or comprehensive insurance coverage for the`
  line `regular and temporary workers in such manner as may be prescribed.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (51575)
  sectionNo (16)
  orderNo 16
  title `Ready for recycling certificate.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51575&sectionno=16&orderno=16&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_16_content:
  string
  line `(1) The owner of a ship who intends to recycle his ship shall`
  line `make an application to the National Authority for a ready for recycling certificate in such form, manner,`
  line `and accompanied by such fee as may be specified by the regulations or the Administration concerned as`
  line `per the procedure determined by such Administration.`
  line
  line `(2) A ready for recycling certificate referred to in sub-section (1) may be issued after successful`
  line `completion of a survey and shall be valid for a period of three months from the date of its issue:`
  line
  line `Provided that the period of validity may be extended by the National Authority for such reasons as`
  line `may be specified by the regulations or the Administration concerned as per the reasons determined by`
  line `such Administration.`
  line
  line `(3) A ready for recycling certificate shall cease to be valid, if the condition of the ship does not`
  line `correspond with the particulars of the certificate.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (51576)
  sectionNo (17)
  orderNo 17
  title `Ship recycling plan.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51576&sectionno=17&orderno=17&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_17_content:
  string
  line `(1) No Ship Recycler shall recycle any ship without a ship recycling plan`
  line `prepared in accordance with the guidelines issued under sub-section (2) and approved by the Competent`
  line Authority.
  line
  line `(2) The National Authority may specify the guidelines for the preparation of a ship recycling plan for`
  line `different categories of ships:`
  line
  line `Provided that the Competent Authority may, after hearing the Ship Recycler, refuse to approve the`
  line `ship recycling plan if it has reasons to believe that the plan does not comply with the guidelines specified`
  line `by the National Authority.`
  line
  line `(3) Where the Competent Authority fails to convey its decision regarding approval of the ship`
  line `recycling plan within fifteen days of its submission, the plan shall be deemed to have been approved.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (51577)
  sectionNo (18)
  orderNo 18
  title `General requirements.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51577&sectionno=18&orderno=18&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_18_content:
  string
  line `(1) No ship shall be recycled without the written permission or, as the`
  line `case may be, the deemed permission of the Competent Authority obtained in such manner as may be`
  line `specified by the regulations.`
  line
  line `(2) Any ship registered in India and intended to be recycled outside the territory of India shall be`
  line `recycled only at a ship recycling facility duly authorised by such authority as may be specified by the`
  line regulations.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (51578)
  sectionNo (19)
  orderNo 19
  title `Obligations on part of ship owner.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51578&sectionno=19&orderno=19&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_19_content:
  string
  line `(1) The owner of a ship which is intended to be recycled`
  line `within the territory of India shall---`
  line
  line `(i) give an advance intimation to the Maritime Rescue Co-ordination Centre and the Competent`
  line `Authority about the date of arrival, in such manner as may be prescribed;`
  line
  line `(ii) clear all port dues, if any, upon arriving at the port and submit the documents as specified in`
  line `the regulations; and`
  line
  line `(iii) keep the ship clear of cargo residues and shall minimise any remaining fuel oil and wastes on`
  line board.
  line
  line `(2) The owner of a tanker which is intended to be recycled within the territory of India shall fulfil`
  line `such conditions for safe-for-entry or safe-for-hotwork or both, as specified by the regulations.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (51579)
  sectionNo (20)
  orderNo 20
  title `Procedure for grant of permission for ship recycling.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51579&sectionno=20&orderno=20&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_20_content:
  string
  line `(1) The Competent Authority shall`
  line `grant permission for recycling only after physical inspection of the ship and for this purpose it may`
  line `requisition the services of representatives of such agencies as may be prescribed.`
  line
  line `(2) Where the Competent Authority fails to convey its decision regarding grant of permission within`
  line `fifteen days of receipt of application, the permission shall be deemed to have been granted.`
  line
  line `(3) The Competent Authority may deny permission for recycling for reasons to be recorded in writing`
  line `after affording an opportunity of being heard to the ship owner.`
  line
  line `(4) The Ship Recycler, on receipt of a copy of permission to recycle the ship, shall issue a statement`
  line `of acceptance to the ship owner under intimation to the Competent Authority in such form and manner as`
  line `may be specified by the regulations and thereafter the ship owner may get the ship de-registered.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (51580)
  sectionNo (21)
  orderNo 21
  title `Safe and environmentally sound management of hazardous materials.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51580&sectionno=21&orderno=21&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_21_content:
  string
  line `Every Ship Recycler`
  line shall,--
  line
  line `(a) ensure safe and environmentally sound removal and management of hazardous materials from`
  line `a ship; and`
  line
  line `(b) comply with such requirements related to basic infrastructure facilities including those related`
  line `to environmentally safe disposal or management of wastes and hazardous materials, in such manner`
  line `as may be specified by the regulations.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (51581)
  sectionNo (22)
  orderNo 22
  title `Obligation on Ship Recycler to take measures for protection of environment.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51581&sectionno=22&orderno=22&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_22_content:
  string
  line `(1) Every`
  line `Ship Recycler shall,--`
  line
  line `(i) ensure that there is no damage caused to the environment in any form due to the recycling`
  line `activities at the ship recycling facility; and`
  line
  line `(ii) take necessary measures for protection of the environment.`
  line
  line `(2) In case of oil spill in the facility, the Ship Recycler shall be served a notice by the Competent`
  line `Authority to take remedial action in such manner as may be specified by the regulations.`
  line
  line `(3) For contravention of the provisions of this section, the Ship Recycler shall be liable to pay such`
  line `environmental damages and cleanup operation compensation in such manner as may be prescribed.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (51582)
  sectionNo (23)
  orderNo 23
  title `Statement of completion.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51582&sectionno=23&orderno=23&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_23_content:
  string
  line `When a ship is recycled in accordance with the provisions of this`
  line `Act, a statement of completion containing such particulars as may be specified by the regulations shall be`
  line `submitted by the Ship Recycler to the Competent Authority.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (51583)
  sectionNo (24)
  orderNo 24
  title `Report to National Authority.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51583&sectionno=24&orderno=24&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_24_content:
  string
  line `The Competent Authority shall give report to the National`
  line `Authority, from time to time, which shall include information comprising the list of approved facilities,`
  line `list of ships which have not complied with the provisions of this Act and action taken on such ships and`
  line `list of ships recycled, as may be required by the National Authority.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (51584)
  sectionNo (25)
  orderNo 25
  title `Appeal against decision of Competent Authority.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51584&sectionno=25&orderno=25&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_25_content:
  string
  line `(1) Any person who is aggrieved by any`
  line `decision made by the Competent Authority or the authorised surveyor or any authorised organisation or`
  line `authorised person may file an appeal to the National Authority within a period of thirty days from the date`
  line `of receipt of such decision in such manner as may be prescribed:`
  line
  line `Provided that in respect of matters under any other law for the time being in force for which an`
  line `appellate provision exists, in such law, then the appellant shall file the appeal to the authority specified in`
  line `such law.`
  line
  line `(2) The appeal filed under sub-section (1) shall be disposed of in such manner as may be prescribed.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (51585)
  sectionNo (26)
  orderNo 26
  title `Appeal against decision of National Authority.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51585&sectionno=26&orderno=26&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_26_content:
  string
  line `(1) Any person who is aggrieved by any`
  line `decision made by the National Authority may file an appeal to the Central Government within a period of`
  line `thirty days from the date of receipt of such decision in such manner as may be prescribed.`
  line
  line `(2) The appeal filed under sub-section (1) shall be disposed of in such manner as may be prescribed.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (51586)
  sectionNo (27)
  orderNo 27
  title `Power to search and seize records, etc.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51586&sectionno=27&orderno=27&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_27_content:
  string
  line `(1) If the National Authority or the Competent`
  line `Authority has reason to believe that an offence under this Act has been or is being committed at any ship`
  line `recycling facility, such Authority or any officer authorised therefor in this behalf may, subject to the rules`
  line `and regulations made under this Act, enter and search at all reasonable times with such assistance, if any,`
  line `as such Authority or officer considers necessary, such ship recycling facility and examine any record,`
  line `register, document, equipment or any other material object found therein and seize the same if such`
  line `Authority or officer has reason to believe that it may furnish evidence of the commission of an offence`
  line `punishable under this Act.`
  line
  line `(2) The provisions of the Code of Criminal Procedure, 1973 (2 of 1974) relating to searches and`
  line `seizures shall, so far as may be, apply to every search or seizure made under this Act.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (51587)
  sectionNo (28)
  orderNo 28
  title `Power to inspect, dismiss, exclude or detain a ship.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51587&sectionno=28&orderno=28&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_28_content:
  string
  line `(1) The National Authority or`
  line `Administration or any Survey authorised by it, may inspect any ship, at a reasonable time, while at any`
  line `port or within Indian waters:`
  line
  line `Provided that any such inspection shall be only for the purpose of verifying that there is on board`
  line `either a certificate on inventory of hazardous materials or a ready for recycling certificate.`
  line
  line `(2) The National Authority may dismiss, exclude or detain the ship from its ports or within Indian`
  line `waters in case of,--`
  line
  line `(a) failure to carry a valid certificate on inventory of hazardous materials or a valid ready for`
  line `recycling certificate or both, as applicable; or`
  line
  line `(b) non-compliance with the control measures for hazardous materials notified by the Central`
  line Government.
  line
  line `(3) A ship detained under sub-section (2) shall remain under detention till such time until the`
  line `non-compliance is rectified or till such time until permission is granted by the National Authority for such`
  line `detained ship to proceed to an appropriate repair yard or port, without danger to the ship, environment or`
  line `persons on board.`
  line
  line `(4) Any Commissioned Officer of the Indian Navy or Indian Coast Guard or any Port Officer, Pilot,`
  line `Harbour Master, Conservator of Port or Customs Collector may detain the ship, the detention of which is`
  line `authorised or ordered to be detained under this Act.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (51588)
  sectionNo (29)
  orderNo 29
  title `Power to exempt.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51588&sectionno=29&orderno=29&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_29_content:
  string
  line `(1) Notwithstanding anything contained in this Act, the Central Government`
  line `may, by order in writing and upon such conditions, if any, as it may think fit to impose, exempt any`
  line `vessel or any class thereof, ship recycling facility or Ship Recycler from any specified requirement`
  line `contained in or prescribed in pursuance of this Act or dispense with the observance of any such`
  line `requirement, if it is satisfied that the requirement has been substantially complied with or that compliance`
  line `with the requirement is or ought to be dispensed within the circumstances of the case.`
  line
  line `(2) Where an exemption granted under sub-section (1) is subject to any conditions, a breach of any of`
  line `those conditions shall, without prejudice to any other remedy, be deemed to be an offence under this Act.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (51589)
  sectionNo (30)
  orderNo 30
  title `Act not to apply to certain ships.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51589&sectionno=30&orderno=30&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_30_content:
  string
  line `The provisions of this Act shall not apply to such category of`
  line `Indian ships, as the Central Government may, from time to time, by notification specify:`
  line
  line `Provided that such ships shall be required to act in such manner as may be prescribed.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (51590)
  sectionNo (31)
  orderNo 31
  title `Penalty for contravention of provisions of Act or rules or regulations.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51590&sectionno=31&orderno=31&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_31_content:
  string
  line `(1) Whoever instals`
  line `or uses any prohibited hazardous material in a ship in contravention of the provisions of this Act or rules or regulations made thereunder shall be punishable with imprisonment for a term which may extend to`
  line `three months or with fine which may extend to five lakh rupees or with both.`
  line
  line `(2) Whoever contravenes the provisions of section 12 shall be punishable with imprisonment for a`
  line `term which may extend to one year or with fine which may extend to ten lakh rupees or with both.`
  line
  line `(3) Whoever contravenes the provisions of sub-section (1) of section 17 shall be punishable with`
  line `imprisonment for a term which may extend to one year or with fine which may extend to ten lakh rupees`
  line `or with both.`
  line
  line `(4) Whoever contravenes the provisions of sub-section (1) of section 18, shall be punishable with`
  line `imprisonment for a term which may extend to one year or with fine which may extend to ten lakh rupees`
  line `or with both.`
  line
  line `(5) Whoever fails to ensure safe and environmentally sound removal and management of any`
  line `hazardous material from a ship in accordance with the regulations shall be punishable with an`
  line `imprisonment for a term which may extend to six months or with fine which may extend to five lakh`
  line `rupees or with both.`
  line
  line `(6) Whoever fails to respond to the notice issued for oil spill under sub-section (2) of section 22 shall`
  line `be punishable--`
  line
  line `(i) with a fine which may extend to five lakh rupees in case of non response within twelve hours`
  line `of issuance of first notice;`
  line
  line `(ii) with a fine which may extend to ten lakh rupees in case of non response within twenty-four`
  line `hours of issue of second notice; and`
  line
  line `(iii) with an imprisonment which may extend to three months and with a fine which may extend`
  line `to ten lakh rupees in case of non response beyond twenty-four hours of issue of third notice.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (51607)
  sectionNo (32)
  orderNo 32
  title `Penalty for contravention of provisions of this Act or rules or regulations for which no specific punishment is provided.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51607&sectionno=32&orderno=32&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_32_content:
  string
  line `Whoever contravenes any of the provisions of this Act or any rules`
  line `or regulations made thereunder, for which no specific punishment has been provided in this Act, shall be`
  line `punishable with imprisonment for a term which may extend to three months or with fine, which may`
  line `extend to two lakh rupees or with both and, in the case of a continuing contravention, with an additional`
  line `fine which may extend to five thousand rupees for every day during which such contravention continues`
  line `after the conviction for the first such contravention.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (51592)
  sectionNo (33)
  orderNo 33
  title `Punishment for other offences.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51592&sectionno=33&orderno=33&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_33_content:
  string
  line `(1) If any ship, after detention or after service of any notice or`
  line `order for such detention, proceeds to sea before it is released by the National Authority, the owner or`
  line `master of the ship shall be guilty of an offence under this Act.`
  line
  line `(2) Whoever restrains or detains or forcibly takes to sea, any person authorised under this Act to`
  line `detain or survey the ship, on the execution of his duty, the owner, master or agent of such ship shall each`
  line `be liable to pay all expenses of, and incidental to, such person being so taken to sea and shall also be`
  line `guilty of an offence under this Act.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (51593)
  sectionNo (34)
  orderNo 34
  title `Offences by companies.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51593&sectionno=34&orderno=34&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_34_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who, at the time the offence was committed was in charge of, and was responsible`
  line `to the company for the conduct of the business of the company, as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, provided in this Act, if he proves that the offence was committed without his knowledge or`
  line `that he had exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means anybody corporate and includes a co-operative society, firm or other`
  line `association of individuals; and`
  line
  line `(b) "director" means a whole time director in the company and in relation to a firm means a`
  line `partner in the firm.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (51594)
  sectionNo (35)
  orderNo 35
  title `Offences to be non-congnizable, bailable and compoundable.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51594&sectionno=35&orderno=35&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_35_content:
  string
  line `Notwithstanding anything`
  line `contained in the Code of Criminal Procedure, 1973 (2 of 1974), every offence under this Act shall be noncognizable, bailable and compoundable.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (51595)
  sectionNo (36)
  orderNo 36
  title `Cognizance of Offences.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51595&sectionno=36&orderno=36&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_36_content:
  string
  line `No court shall take cognizance of an offence under this Act except on`
  line `a complaint made by--`
  line
  line `(a) the Central Government;`
  line
  line `(b) the National Authority or an officer authorised in this behalf; or`
  line
  line `(c) the Competent Authority or an officer authorised in this behalf.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (51596)
  sectionNo (37)
  orderNo 37
  title `Amount payable by owner, master or agent.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51596&sectionno=37&orderno=37&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_37_content:
  string
  line `When any owner or master or agent is convicted`
  line `of an offence under sub-section (2) of section 33, the amount payable on account of expenses by such`
  line `owner or master or agent shall be determined and recovered in such manner as may be prescribed.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (51597)
  sectionNo (38)
  orderNo 38
  title `Place of trial and jurisdiction of court.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51597&sectionno=38&orderno=38&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_38_content:
  string
  line `Any person committing any offence under this Act or`
  line `any rules made thereunder, may be tried for such offence in any place in which he may be found, or in`
  line `any Court which the Central Government may, by notification, direct in this behalf, or in any Court in`
  line `which he might be tried under any other law for the time being in force.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (51598)
  sectionNo (39)
  orderNo 39
  title Compensation.
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51598&sectionno=39&orderno=39&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_39_content:
  string
  line `(1) Where a ship is unduly detained or delayed as a result of an inspection or`
  line `investigation without any reasonable cause, then, such ship shall be entitled to compensation for any loss`
  line `or damage suffered thereby.`
  line
  line `(2) The rate of compensation referred to in sub-section (1), the method of calculation and the manner`
  line `of payment of such compensation shall be such as may be prescribed.`
  line
  line `(3) For the purpose of adjudging compensation under this section, the Central Government may, by`
  line `notification, nominate an officer of the Central Government, not below the rank of Joint Secretary to the`
  line `Government of India, to be an adjudicating officer for holding an inquiry in the prescribed manner, after`
  line `giving any person concerned an opportunity of being heard.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (51599)
  sectionNo (40)
  orderNo 40
  title `Delegation of powers.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51599&sectionno=40&orderno=40&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_40_content:
  string
  line `(1) The Central Government may, by general or special order, subject to`
  line `such conditions and restrictions as may be provided in such order, direct that any power, authority or`
  line `jurisdiction exercisable by it under or in relation to a provision of this Act (except the power to make`
  line `rules), be exercisable also by the National Authority or Competent Authority or such other officer not`
  line `below the rank of Joint Secretary to the Government of India.`
  line
  line `(2) The National Authority or the Competent Authority may, with the previous approval of the`
  line `Central Government, by general or special order, subject to such conditions and restrictions as may be`
  line `provided in such order, direct that any power, authority or jurisdiction exercisable by it under or in`
  line `relation to a provision of this Act (except the power to make regulations), be exercisable also by such`
  line `officer or other authority as may be specified in such order.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (51600)
  sectionNo (41)
  orderNo 41
  title `Act not in derogation of any other law.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51600&sectionno=41&orderno=41&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_41_content:
  string
  line `The provisions of this Act shall be in addition to and`
  line `not in derogation of any other law for the time being in force.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (51601)
  sectionNo (42)
  orderNo 42
  title `Power to make rules.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51601&sectionno=42&orderno=42&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_42_content:
  string
  line `(1) The Central Government may, by notification, make rules to carry`
  line `out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:---`
  line
  line `(a) the duties of Competent Authority within the geographical area or areas of expertise under`
  line `section 4;`
  line
  line `(b) the restrictions and conditions imposed on installation or use of any hazardous material, to be`
  line `complied by every ship under sub-section (2) of section 6;`
  line
  line `(c) the requirements to be verified for the survey of ships under clauses (a), (b) and (d) of`
  line `sub-section (1) of section 7;`
  line
  line `(d) the other conditions to be required for the survey of ships under clause (e) of sub-section (1)`
  line `of section 7;`
  line
  line `(e) the terms and conditions, validity, the format and manner for granting the certificate on`
  line `inventory of hazardous materials under sub-section (2) of section 8 and section 9;`
  line
  line `(f) the changes in ship structures and equipment under clause (ii) of section 10;`
  line
  line `(g) the form, fees and the manner of making the application for authorisation of ship recycling`
  line `facility under sub-section (2) of section 12;`
  line
  line `(h) the manner, period and fees for renewal of certificate of authorisation under sub-section (9) of`
  line `section 12;`
  line
  line `(i) the manner of providing individual or comprehensive insurance coverage for the regular and`
  line `temporary workers under sub-section (2) of section 15;`
  line
  line `(j) the manner of advance intimation about the arrival of ship under sub-section (1) of section 19;`
  line
  line `(k) the requisition of the services of representatives of agencies for grant of permission under`
  line `sub-section (1) of section 20;`
  line
  line `(l) the liability of the Ship Recycler for environmental damages under sub-section (3) of section`
  line 22;
  line
  line `(m) the manner of filing an appeal against the orders of the Competent Authority and the manner`
  line `of disposal of such appeal under section 25;`
  line
  line `(n) the manner of filing an appeal against the orders of National Authority and the manner of`
  line `disposal of such appeal under section 26;`
  line
  line `(o) the manner in which the ships are required to act for non-application of the provisions of the`
  line `Act under the proviso to section 30;`
  line
  line `(p) the manner of determination and recovery of amount payable under section 37;`
  line
  line `(q) the rate of compensation, method of calculation and the manner of compensation entitled by a`
  line `ship under sub-section (2) of section 39;`
  line
  line `(r) the manner of holding an inquiry for the purpose of payment of compensation under`
  line `sub-section (3) of section 39; and`
  line
  line `(s) any other matter which is to be, or may be, prescribed or in respect of which provision is to be`
  line `made by rules.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (51602)
  sectionNo (43)
  orderNo 43
  title `Power to make regulations.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51602&sectionno=43&orderno=43&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_43_content:
  string
  line `(1) The National Authority with the previous approval of the`
  line `Central Government, by notification in the Official Gazette, may make regulations not inconsistent with`
  line `the provisions of this Act and the rules made thereunder.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the requirements relating to ship recycling facility under clause (o) of sub-section (1) of`
  line `section 2;`
  line
  line `(b) the manner of preparation of a ship recycling facility management plan under sub-section (1)`
  line `of section 12;`
  line
  line `(c) the equipment and other standards to be maintained by the Ship Recycler under`
  line `sub-section (5) of section 12;`
  line
  line `(d) the form in which a certificate of authorisation shall be issued under sub-section (6) of section`
  line 12;
  line
  line `(e) the period of validity of certificate of authorisation for ship recycling facility under`
  line `sub-section (8) of section 12;`
  line
  line `(f) the manner of enquiry or inspection by the Competent Authority under sub-section (2) of`
  line `section 13;`
  line
  line `(g) the manner of making an application to the National Authority for a ready for recycling`
  line `certificate under sub-section (1) of section 16;`
  line
  line `(h) the manner and format for issuing of the ready for recycling certificate under sub-section (2)`
  line `of section 16;`
  line
  line `(i) the manner of obtaining the written permission of the Competent Authority under`
  line `sub-section (1) of section 18;`
  line
  line `(j) the authority to authorise the ship recycling facility under sub-section (2) of section 18;`
  line
  line `(k) submission of documents by ship owner under clause (ii) of sub-section (1) of section 19;`
  line
  line `(l) the conditions for safe-for-entry or safe-for-hotwork or both under sub-section (2) of`
  line `section 19;`
  line
  line `(m) the form and manner of issue of statement of acceptance by the Ship Recycler under`
  line `sub-section (4) of section 20;`
  line
  line `(n) the requirements relating to removal and management of hazardous materials and basic`
  line `infrastructure to be complied with by the Ship Recycler under clause (b) of section 21;`
  line
  line `(o) the manner of serving of notice by the Competent Authority to a Ship Recycler in case of oil`
  line `spill under sub-section (2) of section 22;`
  line
  line `(p) the manner of submission of statement of completion by the Ship Recycler under section 23;`
  line and
  line
  line `(q) any other matter which is required to be, or may be, specified by regulations.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (51603)
  sectionNo (44)
  orderNo 44
  title `Laying of rules and regulations.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51603&sectionno=44&orderno=44&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_44_content:
  string
  line `Every rule made by the Central Government and every`
  line `regulation made by the National Authority under this Act shall be laid, as soon as may be after it is made,`
  line `before each House of Parliament while it is in session for a total period of thirty days which may be`
  line `comprised in one session or in two or more successive sessions, and if, before the expiry of the session`
  line `immediately following the session or the successive sessions aforesaid, both Houses agree in making any`
  line `modification in the rule or regulation or both Houses agree that the rule or regulation should not be made,`
  line `the rule or regulation shall thereafter have effect only in such modified form or be of no effect, as the case`
  line `may be; so, however, any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that rule or regulation.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (51604)
  sectionNo (45)
  orderNo 45
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51604&sectionno=45&orderno=45&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_45_content:
  string
  line `No suit, prosecution or other legal proceeding shall`
  line `lie against the Central Government or the State Government or the National Authority or the Competent`
  line `Authority or any officer authorised by the Central Government or the State Government or the National`
  line `Authority or the Competent Authority for anything done in good faith or intended to be done in pursuance`
  line `of the provisions of this Act.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (51605)
  sectionNo (46)
  orderNo 46
  title `Removal of difficulties.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_0_00023_201949_1604576474487&sectionId=51605&sectionno=46&orderno=46&orgactid=AC_CEN_7_0_00023_201949_1604576474487
obj_root_law_sections_46_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of this Act,`
  line `the Central Government may, by order published in the Official Gazette, make such provisions, not inconsistent with the provisions of this Act, as may appear to it to be necessary for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of a period of three years`
  line `from the date of commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_46_footnotes:
  string
  line
