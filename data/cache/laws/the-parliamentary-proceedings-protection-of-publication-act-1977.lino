obj_root_law_sections_1:
  sectionId (33943)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33943&sectionno=1&orderno=1&orgactid=AC_CEN_33_52_00001_197715_1517807320683
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Parliamentary`
  line `Proceedings (Protection of Publication) Act, 1977.`
  line
  line `(2) It extends to the whole of India except the State of Jammu and Kashmir*.`
  line
  line `(3) It shall be deemed to have come into force on the 25th day of March, 1977.`
obj_root_law_sections_1_footnotes:
  string
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (33944)
  sectionNo (2)
  orderNo 2
  title Definition
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33944&sectionno=2&orderno=2&orgactid=AC_CEN_33_52_00001_197715_1517807320683
obj_root_law_sections_2_content:
  string
  line `In this Act, "newspaper" means any printed periodical work containing public news`
  line `or comments on public news, and includes a news agency supplying material for publication in a`
  line newspaper.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (33945)
  sectionNo (3)
  orderNo 3
  title `Publication of reports of Parliamentary proceedings privileged`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33945&sectionno=3&orderno=3&orgactid=AC_CEN_33_52_00001_197715_1517807320683
obj_root_law_sections_3_content:
  string
  line `(1) Save as otherwise`
  line `provided in sub-section (2), no person shall be liable to any proceedings, civil or criminal, in any court in`
  line `respect of the publication in a newspaper of a substantially true report of any proceedings of either House`
  line `of Parliament, unless the publication is proved to have been made with malice.`
  line
  line `(2) Nothing in sub-section (1) shall be construed as protecting the publication of any matter, the`
  line `publication of which is not for the public good.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (33946)
  sectionNo (4)
  orderNo 4
  title `Act also to apply to Parliamentary proceedings broadcast by wireless telegraphy.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33946&sectionno=4&orderno=4&orgactid=AC_CEN_33_52_00001_197715_1517807320683
obj_root_law_sections_4_content:
  string
  line `This Act`
  line `shall apply in relation to reports or matters broadcast by means of wireless telegraphy as part of any`
  line `programme or service provided by means of a broadcasting station situate within the territories to which`
  line `this Act extends as it applies in relation to reports or matters published in a newspaper.`
obj_root_law_sections_4_footnotes:
  string
  line
