obj_root_law_sections_1:
  object
  (str sectionId) (str 33943)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title, extent and commencement`)
  (str content) (str `(1) This Act may be called the Parliamentary
Proceedings (Protection of Publication) Act, 1977.

(2) It extends to the whole of India except the State of Jammu and Kashmir*.

(3) It shall be deemed to have come into force on the 25th day of March, 1977.`)
  (str footnotes) (str `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu
and Kashmir and the Union territory of Ladakh.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33943&sectionno=1&orderno=1&orgactid=AC_CEN_33_52_00001_197715_1517807320683)
obj_root_law_sections_2:
  object
  (str sectionId) (str 33944)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definition)
  (str content) (str `In this Act, "newspaper" means any printed periodical work containing public news
or comments on public news, and includes a news agency supplying material for publication in a
newspaper.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33944&sectionno=2&orderno=2&orgactid=AC_CEN_33_52_00001_197715_1517807320683)
obj_root_law_sections_3:
  object
  (str sectionId) (str 33945)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Publication of reports of Parliamentary proceedings privileged`)
  (str content) (str `(1) Save as otherwise
provided in sub-section (2), no person shall be liable to any proceedings, civil or criminal, in any court in
respect of the publication in a newspaper of a substantially true report of any proceedings of either House
of Parliament, unless the publication is proved to have been made with malice.

(2) Nothing in sub-section (1) shall be construed as protecting the publication of any matter, the
publication of which is not for the public good.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33945&sectionno=3&orderno=3&orgactid=AC_CEN_33_52_00001_197715_1517807320683)
obj_root_law_sections_4:
  object
  (str sectionId) (str 33946)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Act also to apply to Parliamentary proceedings broadcast by wireless telegraphy.`)
  (str content) (str `This Act
shall apply in relation to reports or matters broadcast by means of wireless telegraphy as part of any
programme or service provided by means of a broadcasting station situate within the territories to which
this Act extends as it applies in relation to reports or matters published in a newspaper.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_33_52_00001_197715_1517807320683&sectionId=33946&sectionno=4&orderno=4&orgactid=AC_CEN_33_52_00001_197715_1517807320683)
