obj_root_law_sections_1:
  sectionId (30852)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Inflammable Substances Act, 1952.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30852&sectionno=1&orderno=1&orgactid=AC_CEN_11_60_00005_195220_1517807328359
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (30853)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30853&sectionno=2&orderno=2&orgactid=AC_CEN_11_60_00005_195220_1517807328359
obj_root_law_sections_2_content:
  string
  line `In this Act,--`
  line
  line `(a) "dangerously inflammable substance" means any liquid or other substance declared to be`
  line `dangerously inflammable by this Act;`
  line
  line `(b) "Petroleum Act" means the Petroleum Act, 1934 (30 of 1934).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (30854)
  sectionNo (3)
  orderNo 3
  title `Declaration of certain substances to be dangerously inflammable.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30854&sectionno=3&orderno=3&orgactid=AC_CEN_11_60_00005_195220_1517807328359
obj_root_law_sections_3_content:
  string
  line `The liquids and other`
  line `substances hereinafter mentioned, namely:--`
  line
  line `(1) acetone,`
  line
  line `(2) calcium phosphide,`
  line
  line `(3) carbide of calcium,`
  line
  line `(4) cinematograph films having a nitro-cellulose base,`
  line
  line `(5) ethyl alcohol,`
  line
  line `(6) methyl alcohol,`
  line
  line `(7) wood naphtha,`
  line
  line `are hereby declared to be dangerously inflammable.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (30855)
  sectionNo (4)
  orderNo 4
  title `Power to apply Petroleum Act to dangerously inflammable substances.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30855&sectionno=4&orderno=4&orgactid=AC_CEN_11_60_00005_195220_1517807328359
obj_root_law_sections_4_content:
  string
  line `(1) The Central`
  line `Government may, by notification in the Official Gazette, apply any or all of the provisions of the`
  line `Petroleum Act and of the rules made thereunder, with such modifications as it may specify, to any`
  line `dangerously inflammable substance, and thereupon the provisions so applied shall have effect as if such`
  line `substance had been included in the definition of "petroleum" under that Act.`
  line
  line `(2) The Central Government may make rules providing specially for the testing of any dangerously`
  line `inflammable substance to which any of the provisions of the Petroleum Act have been applied by`
  line `notification under sub-section (1), and such rules may supplement any of the provisions of Chapter II of`
  line `that Act in order to adapt them to the special needs of such tests.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (30856)
  sectionNo (5)
  orderNo 5
  title `Operation of certain notifications and rules.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30856&sectionno=5&orderno=5&orgactid=AC_CEN_11_60_00005_195220_1517807328359
obj_root_law_sections_5_content:
  string
  line `Notifications or rules issued or purporting to have`
  line `been issued under section 30 of the Petroleum Act between the 1st day of April, 1937, and the date of`
  line `commencement of this Act shall be deemed to have been issued or made under this Act, and continue in`
  line `force accordingly.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (30857)
  sectionNo (6)
  orderNo 6
  title `Validation of certain acts and indemnity in respect thereof.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30857&sectionno=6&orderno=6&orgactid=AC_CEN_11_60_00005_195220_1517807328359
obj_root_law_sections_6_content:
  string
  line `All acts of executive authority,`
  line `proceedings and sentences which have been done, taken or passed with respect to, or on account of, any inflammable substance since the 1st day of April, 1937, and before the commencement of this Act by any`
  line `officer of Government or by any person acting under his authority or otherwise in pursuance of an order`
  line `of the Government in the belief or purported belief that the acts, proceedings or sentences were being`
  line `done, taken or passed under the Petroleum Act shall be as valid and operative as if they had been done,`
  line `taken or passed in accordance with law; and no suit or other legal proceeding shall be maintained or`
  line `continued against any person whatever on the ground that any such acts, proceedings or sentences were`
  line `not done, taken or passed in accordance with law.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (30858)
  sectionNo (7)
  orderNo 7
  title Repealed.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30858&sectionno=7&orderno=7&orgactid=AC_CEN_11_60_00005_195220_1517807328359
obj_root_law_sections_7_content:
  string
  line `[Repeal of section 30, Act 30 of 1934.] Rep. by the Repealing and Amending Act, 1957`
  line `(36 of 1957), s. 2 and the First Schedule (w.e.f. 17-9-1957.)`
obj_root_law_sections_7_footnotes:
  string
  line
