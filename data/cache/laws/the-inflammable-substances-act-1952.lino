obj_root_law_sections_1:
  object
  (str sectionId) (str 30852)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Inflammable Substances Act, 1952.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30852&sectionno=1&orderno=1&orgactid=AC_CEN_11_60_00005_195220_1517807328359)
obj_root_law_sections_2:
  object
  (str sectionId) (str 30853)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act,--

(a) "dangerously inflammable substance" means any liquid or other substance declared to be
dangerously inflammable by this Act;

(b) "Petroleum Act" means the Petroleum Act, 1934 (30 of 1934).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30853&sectionno=2&orderno=2&orgactid=AC_CEN_11_60_00005_195220_1517807328359)
obj_root_law_sections_3:
  object
  (str sectionId) (str 30854)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Declaration of certain substances to be dangerously inflammable.`)
  (str content) (str `The liquids and other
substances hereinafter mentioned, namely:--

(1) acetone,

(2) calcium phosphide,

(3) carbide of calcium,

(4) cinematograph films having a nitro-cellulose base,

(5) ethyl alcohol,

(6) methyl alcohol,

(7) wood naphtha,

are hereby declared to be dangerously inflammable.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30854&sectionno=3&orderno=3&orgactid=AC_CEN_11_60_00005_195220_1517807328359)
obj_root_law_sections_4:
  object
  (str sectionId) (str 30855)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Power to apply Petroleum Act to dangerously inflammable substances.`)
  (str content) (str `(1) The Central
Government may, by notification in the Official Gazette, apply any or all of the provisions of the
Petroleum Act and of the rules made thereunder, with such modifications as it may specify, to any
dangerously inflammable substance, and thereupon the provisions so applied shall have effect as if such
substance had been included in the definition of "petroleum" under that Act.

(2) The Central Government may make rules providing specially for the testing of any dangerously
inflammable substance to which any of the provisions of the Petroleum Act have been applied by
notification under sub-section (1), and such rules may supplement any of the provisions of Chapter II of
that Act in order to adapt them to the special needs of such tests.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30855&sectionno=4&orderno=4&orgactid=AC_CEN_11_60_00005_195220_1517807328359)
obj_root_law_sections_5:
  object
  (str sectionId) (str 30856)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Operation of certain notifications and rules.`)
  (str content) (str `Notifications or rules issued or purporting to have
been issued under section 30 of the Petroleum Act between the 1st day of April, 1937, and the date of
commencement of this Act shall be deemed to have been issued or made under this Act, and continue in
force accordingly.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30856&sectionno=5&orderno=5&orgactid=AC_CEN_11_60_00005_195220_1517807328359)
obj_root_law_sections_6:
  object
  (str sectionId) (str 30857)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Validation of certain acts and indemnity in respect thereof.`)
  (str content) (str `All acts of executive authority,
proceedings and sentences which have been done, taken or passed with respect to, or on account of, any inflammable substance since the 1st day of April, 1937, and before the commencement of this Act by any
officer of Government or by any person acting under his authority or otherwise in pursuance of an order
of the Government in the belief or purported belief that the acts, proceedings or sentences were being
done, taken or passed under the Petroleum Act shall be as valid and operative as if they had been done,
taken or passed in accordance with law; and no suit or other legal proceeding shall be maintained or
continued against any person whatever on the ground that any such acts, proceedings or sentences were
not done, taken or passed in accordance with law.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30857&sectionno=6&orderno=6&orgactid=AC_CEN_11_60_00005_195220_1517807328359)
obj_root_law_sections_7:
  object
  (str sectionId) (str 30858)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str Repealed.)
  (str content) (str `[Repeal of section 30, Act 30 of 1934.] Rep. by the Repealing and Amending Act, 1957
(36 of 1957), s. 2 and the First Schedule (w.e.f. 17-9-1957.)`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_60_00005_195220_1517807328359&sectionId=30858&sectionno=7&orderno=7&orgactid=AC_CEN_11_60_00005_195220_1517807328359)
