obj_root_law_translations_hi:
  object
  (str title) (str `ज्वलनशील पदार्थ अधिनियम, 1952`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2165/2/H1952-20.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:17:41.497Z`)
  (str pageCount) (int 2)
