obj_root_law_sections_1:
  sectionId (68803)
  sectionNo (1)
  orderNo 1
  title `Sections III. and VII., Regulation XI. 1831, repealed`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00083_185416_1660111267890&sectionId=68803&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00083_185416_1660111267890
obj_root_law_sections_1_content:
  string
  line `Section III. and VII., Regulation XI.`
  line `1831 of the Bengal Code are hereby repealed.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (68804)
  sectionNo (2)
  orderNo 2
  title `Darogahs of Police to be subject to Tehseeldars.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00083_185416_1660111267890&sectionId=68804&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00083_185416_1660111267890
obj_root_law_sections_2_content:
  string
  line `Wherever any Tehseeldar shall have Police`
  line `jurisdiction under the provisions of Section II. of the said Regulation XI. 1831, every Darogah of Police`
  line `hereafter appointed within the local limits of the police jurisdiction of such Tehseeldar, shall be`
  line `subordinate to, and subject to the control of such Tehseeldar, in his capacity of Chief Police Thannadar.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (68805)
  sectionNo (3)
  orderNo 3
  title `Regulation XI. 1831, as amended, extended to Benares.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00083_185416_1660111267890&sectionId=68805&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00083_185416_1660111267890
obj_root_law_sections_3_content:
  string
  line `Regulation XI. 1831, as amended`
  line `by this Act, shall extend to the whole of the Province of Benares, and all powers vested by the said`
  line `Regulation in the Governor General in Council, may be exercised by the Lieutenant-Governor of the`
  line `North-Western Provinces.`
obj_root_law_sections_3_footnotes:
  string
  line
