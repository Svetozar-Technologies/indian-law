  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Ancient Monuments and Archaeological Sites and Remains Act, 1958`)
  (str actNumber) (str 24)
  (str enactmentDate) (str 1958-08-28)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/13053`)
  (str sources) obj_root_law_sources
