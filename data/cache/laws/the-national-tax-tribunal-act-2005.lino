obj_root_law:
  object
  (str slug) (str the-national-tax-tribunal-act-2005)
  (str handle) (str 2032)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Tax Tribunal Act, 2005`)
  (str actNumber) (str 49)
  (str enactmentDate) (str 2005-12-20)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2032`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `राष्‍ट्रीय कर अधिकरण अधिनियम, 2005`)
  (str actYear) (str 2005)
  (str ministry) (str `Ministry of Law and Justice`)
  (str department) (str `Department of Legal Affairs`)
  (str longTitle) (str `An Act to provide for the adjudication by the National Tax Tribunal of disputes with respect to levy, assessment, collection and enforcement of direct taxes and also to provide for the adjudication by that Tribunal of disputes with respect to the determination of the rates of duties of customs and central excise on goods and the valuation of goods for the purposes of assessment of such duties as well as in matters relating to levy of tax on service, in pursuance of article 323B of the Constitution and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 28-12-2005)
  (str notification) (str `28th December, 2005, vide notification No. S.O. 1826(E), dated 28 December, 2005, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
