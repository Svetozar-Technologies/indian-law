obj_root_law_sections_1:
  sectionId (48119)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48119&sectionno=1&orderno=1&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Tax Tribunal`
  line `Act, 2005.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1 as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act and any reference`
  line `in any such provision to the commencement of this Act shall be construed as a reference to the coming`
  line `into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 28th December, 2005, vide notification No. S.O. 1826(E), dated 28 December, 2005, see Gazette of India, Extraordinary, Part`
  line `II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (48120)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48120&sectionno=2&orderno=2&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Bench" means a Bench of the National Tax Tribunal;`
  line
  line `(b) "Board of Direct Taxes" means the Central Board of Direct Taxes constituted under the`
  line `Central Boards of Revenue Act, 1963 (54 of 1963);`
  line
  line `(c) "Board of Excise and Customs" means the Central Board of Excise and Customs constituted`
  line `under the Central Boards of Revenue Act, 1963 (54 of 1963);`
  line
  line `(d) "Central Excise Act" means the Central Excise Act, 1944 (1 of 1944);`
  line
  line `(e) "Central Excise Tariff Act" means the Central Excise Tariff Act, 1985 (5 of 1986);`
  line
  line `(f) "Chairperson" means the Chairperson of the National Tax Tribunal;`
  line
  line `(g) "Companies (Profits) Surtax Act" means the Companies (Profits) Surtax Act,`
  line `1964 (7 of 1964);`
  line
  line `(h) "Customs Act" means the Customs Act, 1962 (52 of 1962);`
  line
  line `(i) "Customs, Excise and Service Tax Appellate Tribunal" means the Customs, Excise and`
  line `Service Tax Appellate Tribunal constituted under section 129 of the Customs Act, 1962 (52 of 1962);`
  line
  line `(j) "Customs Tariff Act" means the Customs Tariff Act, 1975 (51 of 1975);`
  line
  line `(k) "Expenditure-tax Act" means the Expenditure-tax Act, 1987 (35 of 1987);`
  line
  line `(l) "Gift-tax Act" means the Gift-tax Act, 1958 (18 of 1958);`
  line
  line `(m) "Income-tax Act" means the Income-tax Act, 1961 (43 of 1961);`
  line
  line `(n) "Income-tax Appellate Tribunal" means the Income-tax Appellate Tribunal constituted under`
  line `section 252 of the Income-tax Act, 1961 (43 of 1961);`
  line
  line `(o) "Interest-tax Act" means the Interest-tax Act, 1974 (45 of 1974);`
  line
  line `(p) "law officer" means the Attorney-General for India, the Solicitor General of India or the`
  line `Additional Solicitor General of India;`
  line
  line `(q) "Member" means a Member of the National Tax Tribunal and includes the Chairperson;`
  line
  line `(r) "National Tax Tribunal" means the National Tax Tribunal established under section 3;`
  line
  line `(s) "notification" means a notification published in the Official Gazette;`
  line
  line `(t) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(u) "Supreme Court" means the Supreme Court of India;`
  line
  line `(v) "Wealth-tax Act" means the Wealth-tax Act, 1957 (27 of 1957);`
  line
  line `(w) words and expressions used in this Act but not defined herein and defined in the Central`
  line `Excise Act, the Central Excise Tariff Act, the Customs Act, the Customs Tariff Act (hereinafter`
  line `referred to as the indirect taxes) or the rules made thereunder or in Chapter V of the Finance Act,`
  line `1994 (32 of 1994) shall have the meanings, respectively, assigned to them in the said Acts or the rules`
  line `made thereunder;`
  line
  line `(x) words and expressions used in this Act but not defined herein and defined in the Income-tax`
  line `Act, the Wealth-tax Act, the Gift-tax Act, the Expenditure-tax Act, the Interest-tax Act or the`
  line `Companies (Profits) Surtax Act (hereinafter referred to as the direct taxes) or the rules made`
  line `thereunder shall have the meanings, respectively, assigned to them in the said Acts or the rules made`
  line thereunder.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (48121)
  sectionNo (3)
  orderNo 3
  title `Establishment of National Tax Tribunal.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48121&sectionno=3&orderno=3&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_3_content:
  string
  line `The Central Government shall, by notification in the`
  line `Official Gazette, establish with effect from such date as may be specified therein, a Tax Tribunal to be`
  line `known as the National Tax Tribunal to exercise the jurisdiction, powers and authority conferred on such`
  line `Tribunal by or under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (48122)
  sectionNo (4)
  orderNo 4
  title `Composition of National Tax Tribunal.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48122&sectionno=4&orderno=4&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_4_content:
  string
  line `The National Tax Tribunal shall consist of a`
  line `Chairperson and such number of Members as the Central Government deems fit, to be appointed by that`
  line `Government, by notification in the Official Gazette.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (48123)
  sectionNo (5)
  orderNo 5
  title `Constitution and jurisdiction of Benches.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48123&sectionno=5&orderno=5&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_5_content:
  string
  line `(1) The jurisdiction of the National Tax Tribunal`
  line `may be exercised by the Benches thereof to be constituted by the Chairperson.`
  line
  line `(2) The Benches of the National Tax Tribunal shall ordinarily sit at any place in the National Capital`
  line `Territory of Delhi or such other places as the Central Government may, in consultation with the`
  line `Chairperson, notify:`
  line
  line `Provided that the Chairperson may for adequate reasons permit a Bench to hold its temporary sitting`
  line `for a period not exceeding fifteen days at a place other than its ordinary place of seat.`
  line
  line `(3) The Central Government shall notify the areas in relation to which each Bench of the National`
  line `Tax Tribunal may exercise its jurisdiction.`
  line
  line `(4) The Central Government shall determine the number of Benches and each Bench shall consist of`
  line `two members.`
  line
  line `(5) The Central Government may ^1`
  line `* * * transfer a Member from headquarters of one Bench in one`
  line `State to the headquarters of another Bench in another State or to the headquarters of any other Bench`
  line `within a State:`
  line
  line ^2
  line `[Provided that no Member shall be transferred without the concurrence of the Chairperson.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. The words "in consultation with the Chairperson" omitted by Act 18 of 2007, s. 2 (w.e.f. 29-1-2007).`
  line
  line `2. Ins. by s. 2. ibid. (w.e.f. 29-1-2007).`
obj_root_law_sections_6:
  sectionId (48124)
  sectionNo (6)
  orderNo 6
  title `Qualifications for appointment of Chairperson and other Members.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by Act 18 of 2007, s. 3, for "seven years" (w.e.f. 29-1-2007).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48124&sectionno=6&orderno=6&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_6_content:
  string
  line `(1) The Chairperson of`
  line `the National Tax Tribunal shall be a person who has been a Judge of the Supreme Court or the Chief`
  line `Justice of a High Court.`
  line
  line `(2) A person shall not be qualified for appointment as Member unless he--`
  line
  line `(a) is, or has been, or is eligible to be, a Judge of a High Court; or`
  line
  line `(b) is, or has been, a Member of the Income-tax Appellate Tribunal or of the Customs, Excise and`
  line `Service Tax Appellate Tribunal for at least ^1[five years].`
obj_root_law_sections_7:
  sectionId (48125)
  sectionNo (7)
  orderNo 7
  title `Appointment of Chairperson and other Members.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48125&sectionno=7&orderno=7&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of sub-section(2), the Chairperson and every other Member shall be appointed by the Central Government.`
  line
  line `(2) The Chairperson and the other Members shall be appointed by the Central Government on the`
  line `recommendations of a Selection Committee consisting of—`
  line
  line `(a) the Chief Justice of India or a Judge of the Supreme Court nominated by him;`
  line
  line `(b) the Secretary in the Ministry of Law and Justice (Department of Legal Affairs);`
  line
  line `(c) the Secretary in the Ministry of Finance (Department of Revenue).`
  line
  line `(3) No appointment of the Chairperson or of any other Member shall be invalidated merely by reason`
  line `of any vacancy or any defect in the constitution of the Selection Committee.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (48126)
  sectionNo (8)
  orderNo 8
  title `Terms of office of Chairperson and other Members.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48126&sectionno=8&orderno=8&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_8_content:
  string
  line `The Chairperson and every other Member`
  line `shall hold office as such for a term of five years from the date on which he enters upon his office but shall`
  line `be eligible for re-appointment:`
  line
  line `Provided that no Chairperson or other Member shall hold office as such after he has attained,—`
  line
  line `(a) in the case of Chairperson, the age of sixty-eight years; and`
  line
  line `(b) in the case of any other Member, the age of sixty-five years.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (48127)
  sectionNo (9)
  orderNo 9
  title `Resignation of Chairperson and other Members.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48127&sectionno=9&orderno=9&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_9_content:
  string
  line `The Chairperson or any other Member may,`
  line `by notice in writing under his hand addressed to the Central Government, resign his office.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (48128)
  sectionNo (10)
  orderNo 10
  title `Salary and allowances.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48128&sectionno=10&orderno=10&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_10_content:
  string
  line `(1) Subject to the provisions of this Act, the salary and allowances and`
  line `other terms and conditions of the Chairperson shall be the same as applicable to a sitting Judge of the`
  line `Supreme Court, but no vacation shall be allowed:`
  line
  line `Provided that if a person who, immediately before the date of assuming the office as the Chairperson`
  line `was in receipt of or being eligible so to do, had elected to draw, a pension in respect of any previous`
  line `service or office held by such person under the Government of the Union or of a State, his salary in`
  line `respect of service as Chairperson shall be reduced by the amount of that pension.`
  line
  line `Explanation.—For the purposes of this sub-section, "vacation" shall have the meaning assigned to it`
  line `in the Supreme Court Judges (Conditions of Service) Act, 1958 (41 of 1958).`
  line
  line `(2) A Member shall draw salary of a High Court Judge and other allowances and the terms and`
  line `conditions of his service shall be the same as applicable to a Secretary to the Government of India:`
  line
  line `Provided that if a person who, immediately before the date of assuming the office as Member was in`
  line `receipt of, or being eligible so to do, had elected to draw, a pension in respect of any previous service held`
  line `by such person in connection with the affairs of the Union or of a State, his salary in respect of service as`
  line `Member shall be reduced to the extent of that pension.`
  line
  line `(3) The salary and allowances and other terms and conditions of service of Chairperson or a Member`
  line `of the Tribunal shall not be varied to his disadvantage after appointment.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (48129)
  sectionNo (11)
  orderNo 11
  title `Removal and suspension of Chairperson and other Members.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48129&sectionno=11&orderno=11&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_11_content:
  string
  line `(1) The Central Government`
  line `may, in consultation with the Chief Justice of India, remove from office the Chairperson or any Member`
  line who—
  line
  line `(a) has been adjudged an insolvent; or`
  line
  line `(b) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(c) has become physically or mentally incapable of acting as such Chairperson or Member of the`
  line `National Tax Tribunal; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions as`
  line `the Chairperson or a Member of the National Tax Tribunal; or`
  line
  line `(e) has so abused his position as to render his continuance in office prejudicial to the public`
  line interest.
  line
  line `(2) The Chairperson or any other Member shall not be removed from his office except by an order`
  line `made by the Central Government on the ground of proved misbehaviour or incapacity after an inquiry`
  line `made by a Judge of the Supreme Court in which such Chairperson or Member had been informed of the`
  line `charges against him and given a reasonable opportunity of being heard in respect of those charges.`
  line
  line `(3) The Central Government may suspend from office the Chairperson or any other Member in`
  line `respect of whom a reference of conducting an inquiry has been made to the Judge of the Supreme Court`
  line `under sub-section (2) until the Central Government has passed orders on receipt of the report of the Judge`
  line `of the Supreme Court on such reference.`
  line
  line `(4) The Central Government may, by rules, regulate the procedure for the investigation of`
  line `misbehaviour or incapacity of the Chairperson or a Member referred to in sub-section (2).`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (48130)
  sectionNo (12)
  orderNo 12
  title `Officers and employees of National Tax Tribunal.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48130&sectionno=12&orderno=12&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_12_content:
  string
  line `(1) The Central Government shall provide`
  line `the National Tax Tribunal with such officers and employees as it may deem fit.`
  line
  line `(2) The salaries and allowances and other conditions of service of officers and employees of the`
  line `National Tax Tribunal shall be such as may be prescribed.`
  line
  line `(3) The officers and employees of the National Tax Tribunal shall discharge their functions under the`
  line `general superintendence of the Chairperson.`
  line
  line `(4) The officers and the other employees shall be appointed on the recommendations of a Selection`
  line `Committee constituted by the Central Government.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (48131)
  sectionNo (13)
  orderNo 13
  title `Appearances before National Tax Tribunal.`
  content obj_root_law_sections_13_content
  footnotes `1 The words "or any person duly authorised by him or it" omitted by Act 18 of 2007, s. 4 (w.e.f. 29-1-2007).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48131&sectionno=13&orderno=13&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_13_content:
  string
  line `(1) A party to an appeal other than Government`
  line `may either appear in person or authorise one or more chartered accountants or legal practitioners ^1* * * to`
  line `present his or its case before the National Tax Tribunal.`
  line
  line `(2) The Government may authorise one or more legal practitioners or any of its officers to present its`
  line `case before the National Tax Tribunal.`
  line
  line `Explanation.-- For the purposes of this section,--`
  line
  line `(a) "chartered accountant" means a chartered accountant as defined in clause (b) of sub-section (1) of section 2 of the Chartered Accountants Act, 1949 (38 of 1949) and who has obtained a`
  line `certificate of practice under sub-section (1) of section 6 of that Act;`
  line
  line `(b) "legal practitioner" means an advocate, a vakil or any attorney of any High Court, and`
  line `includes a pleader in practice.`
obj_root_law_sections_14:
  sectionId (48132)
  sectionNo (14)
  orderNo 14
  title `Member to act as Chairperson or to discharge his functions in certain circumstances.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48132&sectionno=14&orderno=14&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_14_content:
  string
  line `(1) In the event of any vacancy in the office of the Chairperson by reason of his death,`
  line `resignation or otherwise, the Central Government may designate the senior-most Member to act as the`
  line `Chairperson until the day on which a Chairperson, appointed in accordance with the provisions of this Act`
  line `to fill such vacancy, enters upon his office.`
  line
  line `(2) When the Chairperson is unable to discharge his functions owing to absence, illness or any other`
  line `cause, the Central Government may authorise the senior-most Member to discharge the functions of the`
  line `Chairperson until the date on which the Chairperson resumes his duties.`
  line
  line `(3) The senior-most member designated to act under sub-section (1) or to discharge functions of the`
  line `Chairperson under sub-section (2), of the Chairperson shall continue to draw salary and allowances of a`
  line Member.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (48133)
  sectionNo (15)
  orderNo 15
  title `Appeal to National Tax Tribunal.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48133&sectionno=15&orderno=15&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_15_content:
  string
  line `(1) An appeal shall lie to the National Tax Tribunal from`
  line `every order passed in appeal by the Income-tax Appellate Tribunal and the Customs, Excise and Service`
  line `Tax Appellate Tribunal, if the National Tax Tribunal is satisfied that the case involves a substantial`
  line `question of law.`
  line
  line `(2) The Chief Commissioner or the Commissioner of Income-tax or the Chief Commissioner or`
  line `Commissioner of Customs and Central Excise, as the case may be, or an assessee aggrieved by any order`
  line `passed by the Income-tax Appellate Tribunal or any person aggrieved by any order passed by the`
  line `Customs, Excise and Service Tax Appellate Tribunal (hereinafter referred to as aggrieved person), may`
  line `file an appeal to the National Tax Tribunal and such appeal under this sub-section shall--`
  line
  line `(a) be filed within one hundred and twenty days from the date on which the order appealed`
  line `against is received by the assessee or the aggrieved person or the Chief Commissioner or`
  line `Commissioner, as the case may be;`
  line
  line `(b) be in the form of a memorandum of appeal precisely stating therein the substantial question of`
  line `law involved; and`
  line
  line `(c) be accompanied by such fees as may be prescribed:`
  line
  line `Provided that separate form of memorandum of appeal shall be filed for matters involving direct and`
  line `indirect taxes:`
  line
  line `Provided further that the National Tax Tribunal may entertain the appeal within sixty days after the`
  line `expiry of the said period of one hundred and twenty days, if it is satisfied that the appellant was prevented`
  line `by sufficient cause from preferring an appeal in time.`
  line
  line `(3) Where an appeal is admitted under sub-section (1), the National Tax Tribunal--`
  line
  line `(a) shall formulate the question of law for hearing the appeal; and`
  line
  line `(b) may also determine any relevant issue in connection with the question so formulated`
  line
  line `(i) which has not been so determined by the Income-Tax Appellate Tribunal or by the`
  line `Customs, Excise and Service Tax Appellate Tribunal; or`
  line
  line `(ii) which has been wrongly determined by the Income-Tax Appellate Tribunal or by the`
  line `Customs, Excise and Service Tax Appellate Tribunal,`
  line `and shall decide the question of law so formulated and the other relevant issue so determined and deliver`
  line `such judgment thereon containing the grounds on which such decision is founded and may award such`
  line `cost as it deems fit.`
  line
  line `(4) Where in any appeal under this section, the decision of the Income-tax Appellate Tribunal or the`
  line `Customs, Excise and Service Tax Appellate Tribunal involves the payment of any tax or duties, the`
  line `assessee or the aggrieved person, as the case may be, shall not be allowed to prefer such appeal unless he`
  line `deposits at least twenty-five per cent. of such tax or duty payable on the basis of the order appealed`
  line `against:`
  line
  line `Provided that where in a particular case the National Tax Tribunal is of the opinion that the deposit of`
  line `tax or duty under this sub-section would cause undue hardship to such person, it may dispense with such`
  line `deposit subject to such conditions as it may deem fit to impose so as to safeguard the interest of revenue.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (48134)
  sectionNo (16)
  orderNo 16
  title `Procedure and powers of National Tax Tribunal.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48134&sectionno=16&orderno=16&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_16_content:
  string
  line `(1) The National Tax Tribunal shall not be`
  line `bound by the procedure laid down by the Code of Civil Procedure, 1908 (5 of 1908) but shall be guided`
  line `by the principles of natural justice.`
  line
  line `(2) Subject to the other provisions of this Act, the National Tax Tribunal shall have powers to`
  line `regulate its own procedure.`
  line
  line `(3) The National Tax Tribunal shall have, for the purposes of discharging its functions under this Act,`
  line `the same powers as are vested in a civil court under the Code of Civil Procedure, 1908 (5 of 1908) while trying a suit, in respect of the following matters, namely:--`
  line
  line `(a) requiring the discovery and production of books of account and other documents;`
  line
  line `(b) subject to the provisions of sections 123 and 124 of the Indian Evidence Act,`
  line `1872 (1 of 1872), requisitioning any public record or document or a copy of such record or document,`
  line `from any office;`
  line
  line `(c) dismissing an appeal for default or deciding it, ex parte;`
  line
  line `(d) setting aside any order of dismissal of any appeal for default or any order passed by it,`
  line `ex parte;`
  line
  line `(e) rectifying any mistake or error apparent on the face of record; and`
  line
  line `(f) any other matter which may be prescribed.`
  line
  line `(4) All proceedings before the National Tax Tribunal shall be deemed to be judicial proceedings`
  line `within the meaning of sections 193 and 228 and for the purposes of section 196 of the Indian Penal Code`
  line `(45 of 1860) and the National Tax Tribunal shall be deemed to be a civil court for the purposes of section`
  line `195 and Chapter XXVI of the Code of Criminal Procedure, 1973 (2 of 1974).`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (48135)
  sectionNo (17)
  orderNo 17
  title `Finality of orders of National Tax Tribunal.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48135&sectionno=17&orderno=17&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_17_content:
  string
  line `Any order passed by the National Tax Tribunal`
  line `shall be final and shall be given effect to accordingly and no civil court shall have or be entitled to`
  line `exercise any jurisdiction, power or authority with respect to any of the matters falling within the`
  line `jurisdiction of the National Tax Tribunal.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (48136)
  sectionNo (18)
  orderNo 18
  title `Decision by majority.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48136&sectionno=18&orderno=18&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_18_content:
  string
  line `If the Members of a Bench consisting of two Members differ in opinion`
  line `on any point, they shall state the point or points on which they differ, and make a reference to the`
  line `Chairperson, who shall hear the point or points himself or nominate any other Member for such hearing`
  line `and such point or points shall be decided according to the opinion of the majority, who have heard the`
  line `case including those who first heard it.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (48137)
  sectionNo (19)
  orderNo 19
  title `Special Bench.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48137&sectionno=19&orderno=19&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_19_content:
  string
  line `Where a judgment pronounced on a question of law by a Bench subsequently`
  line `comes up for hearing before any Bench, and the latter Bench is of the opinion that the question of law`
  line `requires reconsideration, then the latter Bench shall make a reference to the Chairperson to constitute a`
  line `Special Bench consisting of five Members to hear and decide such question of law.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (48138)
  sectionNo (20)
  orderNo 20
  title `Interim order.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48138&sectionno=20&orderno=20&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_20_content:
  string
  line `Notwithstanding anything contained in any other provisions of this Act or any`
  line `other law for the time being in force, no interim order (whether by way of injunction or stay or otherwise)`
  line `shall be made in relation to any appeal under this Act, unless—`
  line
  line `(a) copies of such appeal and all documents in support of the plea for such interim order are`
  line `furnished to the party against whom the appeal is preferred; and`
  line
  line `(b) opportunity is given to such party to be heard in the matter.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (48139)
  sectionNo (21)
  orderNo 21
  title `Power to punish for contempt.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48139&sectionno=21&orderno=21&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_21_content:
  string
  line `The National Tax Tribunal shall have and exercise the same`
  line `jurisdiction, powers and authority in respect of contempt of itself as the High Court has and may exercise such power or authority, for this purpose under the provisions of the Contempt of Courts Act, 1971 (70 of`
  line `1971), which shall have effect subject to the modification that--`
  line
  line `(a) any reference therein to a High Court shall be construed as including a reference to the`
  line `National Tax Tribunal;`
  line
  line `(b) any reference to the Advocate General in section 15 of the said Act shall be construed as a`
  line `reference to such law officer as the Central Government may specify in this behalf:`
  line
  line `Provided that such matters shall be heard by a Special Bench consisting of five Members constituted`
  line `by the Chairperson.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (48140)
  sectionNo (22)
  orderNo 22
  title `Order of National Tax Tribunal.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48140&sectionno=22&orderno=22&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_22_content:
  string
  line `The National Tax Tribunal may, after giving the parties to`
  line `any proceedings before it, an opportunity of being heard, pass such orders thereon as it thinks fit.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (48141)
  sectionNo (23)
  orderNo 23
  title `Transfer of pending cases from High Court.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48141&sectionno=23&orderno=23&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_23_content:
  string
  line `(1) On and from such date as the Central`
  line `Government may, by notification, specify, all matters and proceedings including appeals and references`
  line `under the direct taxes and indirect taxes pending before any High Court immediately before that date shall`
  line `stand transferred to the National Tax Tribunal.`
  line
  line `(2) Where any matter or proceeding including appeals and references stand transferred from the High`
  line `Court to the National Tax Tribunal under sub-section (1),—`
  line
  line `(a) the High Court shall, as soon as may be after such transfer, forward the records pertaining to`
  line `such matter or proceeding to the National Tax Tribunal;`
  line
  line `(b) the National Tax Tribunal shall, on receipt of such records, proceed to deal with such matter`
  line `or proceeding from the stage at which it is transferred or from an earlier stage or de novo as it may`
  line `deem fit;`
  line
  line `(c) the Chairperson shall constitute a Bench consisting of such number of Members as he deems`
  line `fit for hearing cases transferred under this section.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (48142)
  sectionNo (24)
  orderNo 24
  title `Appeal to Supreme Court.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48142&sectionno=24&orderno=24&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_24_content:
  string
  line `Any person including any department of the Government aggrieved`
  line `by any decision or order of the National Tax Tribunal may file an appeal to the Supreme Court within`
  line `sixty days from the date of communication of the decision or order of the National Tax Tribunal to him:`
  line
  line `Provided that the Supreme Court may, if it is satisfied that the appellant was prevented by sufficient`
  line `cause from filing the appeal within the said period, allow it to be filed within such time as it may deem fit.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (48143)
  sectionNo (25)
  orderNo 25
  title `Members, etc., to be public servants.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48143&sectionno=25&orderno=25&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_25_content:
  string
  line `The Chairperson, Members and other officers and`
  line `employees of the National Tax Tribunal shall be deemed to be public servants within the meaning of`
  line `section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (48144)
  sectionNo (26)
  orderNo 26
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48144&sectionno=26&orderno=26&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_26_content:
  string
  line `No suit, prosecution or other legal proceedings shall`
  line `lie against the National Tax Tribunal or its Chairperson, Member, officer or other employee in the`
  line `discharge of any function for any loss or damage caused or likely to be caused by any act which is, in`
  line `good faith, done or intended to be done in the discharge of any function under this Act.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (48145)
  sectionNo (27)
  orderNo 27
  title `Power to remove difficulties.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48145&sectionno=27&orderno=27&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_27_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of a period of two years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall, as soon as may be, after it is made, be laid before each`
  line `House of Parliament.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (48146)
  sectionNo (28)
  orderNo 28
  title `Power to make rules.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48146&sectionno=28&orderno=28&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_28_content:
  string
  line `(1) The Central Government may, by notification, make rules to carry`
  line `out the provisions of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may provide for all or any`
  line `of the following matters, namely:—`
  line
  line `(a) the procedure under sub-section (4) of section 11 for the investigation of charges of`
  line `misbehaviour or incapacity against the Chairperson or other Members;`
  line
  line `(b) the salaries and allowances and other conditions of service of officers and other employees of`
  line `the National Tax Tribunal under sub-section (2) of section 12;`
  line
  line `(c) the amount of fees payable under clause (c) of sub-section (2) of section 15;`
  line
  line `(d) the other matters in respect of which the National Tax Tribunal may exercise the powers of a`
  line `civil court under clause (f) of sub-section (3) of section 16;`
  line
  line `(e) any other matter which may be prescribed or in respect of which rules are required to be made`
  line `by the Central Government.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (48147)
  sectionNo (29)
  orderNo 29
  title `Laying of rules before Parliament.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48147&sectionno=29&orderno=29&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_29_content:
  string
  line `Every rule made under this Act by the Central Government`
  line `shall be laid, as soon as may be after it is made, before each House of Parliament, while it is in session for`
  line `a total period of thirty days which may be comprised in one session or in two or more successive sessions`
  line `and if, before the expiry of the session immediately following the session or the successive sessions`
  line `aforesaid, both Houses agree in making any modification in the rule or both Houses agree that the rule`
  line `should not be made, the rule shall thereafter have effect only in such modified form or be of no effect, as`
  line `the case may be; so, however, that any such modification or annulment shall be without prejudice to the`
  line `validity of anything previously done under that rule.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (48148)
  sectionNo (30)
  orderNo 30
  title `Consequential amendments.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00006_200549_1517807326331&sectionId=48148&sectionno=30&orderno=30&orgactid=AC_CEN_3_46_00006_200549_1517807326331
obj_root_law_sections_30_content:
  string
  line `On and from such date as the Central Government may, by`
  line `notification, specify, the enactments mentioned in the Schedule shall stand amended in the manner`
  line `specified therein.`
obj_root_law_sections_30_footnotes:
  string
  line
