obj_root_law:
  slug the-national-tax-tribunal-act-2005
  handle (2032)
  collectionHandle 123456789/1362
  title `The National Tax Tribunal Act, 2005`
  actNumber (49)
  enactmentDate 2005-12-20
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2032`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्‍ट्रीय कर अधिकरण अधिनियम, 2005`
  actYear (2005)
  ministry `Ministry of Law and Justice`
  department `Department of Legal Affairs`
  longTitle `An Act to provide for the adjudication by the National Tax Tribunal of disputes with respect to levy, assessment, collection and enforcement of direct taxes and also to provide for the adjudication by that Tribunal of disputes with respect to the determination of the rates of duties of customs and central excise on goods and the valuation of goods for the purposes of assessment of such duties as well as in matters relating to levy of tax on service, in pursuance of article 323B of the Constitution and for matters connected therewith or incidental thereto.`
  enforcementDate 28-12-2005
  notification `28th December, 2005, vide notification No. S.O. 1826(E), dated 28 December, 2005, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T23:09:48.717Z`
  translations obj_root_law_translations
