obj_root_law_sections_1:
  sectionId (4392)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4392&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the South Asian University`
  line `Act, 2008.`
  line
  line `(2) It extends to the whole of India and to campuses and centres established outside India in the`
  line `SAARC region.`
  line
  line `(3) It shall come into force on such date as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (4393)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4393&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Statutes;
  line
  line `(c) "Agreement" means the Agreement for the establishment of the South Asian University;`
  line
  line `(d) "bye-laws" means the bye-laws of the University;`
  line
  line `(e) "Centre" means a unit of the University or of a University Institute providing teaching,`
  line `consultancy and research facilities and includes a Regional Centre;`
  line
  line `(f) "employee" means any person appointed by the University and includes teachers and other`
  line `staff of the University;`
  line
  line `(g) "Executive Council" means the Executive Council of the University;`
  line
  line `(h) "Faculty" means a Faculty of the University;`
  line
  line `(i) "Governing Board" means a Governing Board of the University constituted under section 6;`
  line
  line `(j) "Hall" means a unit of residence, by whatever name called, for students of the University`
  line `provided, maintained or recognised by it;`
  line
  line `(k) "Host Country" means the Republic of India;`
  line
  line `(l) "Host Government" means the Government of the Host Country;`
  line
  line `(m) "Member States" means the Member States of the SAARC;`
  line
  line `(n) "prescribed" means prescribed by Statutes, Regulations or bye-laws;`
  line
  line `(o) "President" means the President of the University appointed under section 12;`
  line
  line `(p) "Project Office" means the project office set up for the purpose of carrying out necessary`
  line `tasks for establishing the main campus of the University;`
  line
  line `(q) "Recognised institution" means an institution of higher learning maintained or recognised by,`
  line `or associated with, the University;`
  line
  line `(r) "Regional Centre" means a centre established or maintained by the University at any place in`
  line `the SAARC region for the purpose of coordinating and supervising the work of campuses or centres`
  line `in such region and for performing such functions as may be conferred on such centre by the`
  line `Governing Board;`
  line
  line `(s) "Regulations" means the Regulations of the University;`
  line
  line `(t) "SAARC" means an organisation known as the South Asian Association for Regional`
  line `Co-operation established by the Charter of the South Asian Association for Regional Co-operation`
  line `signed on eighth day of December, 1985;`
  line
  line `(u) "SAARC region" means the region comprising the territories of the Member States;`
  line
  line `(v) "Schedule" means the Schedule of the Act;`
  line
  line `(w) "Statutes" means the Statutes of the University;`
  line
  line `(x) "teacher" means professor, reader, lecturer and research staff of the University appointed or`
  line `recognised by the University for imparting instructions in the University or for giving guidance to`
  line `students for pursuing any course of study of the University; and`
  line
  line `(y) "University" means the South Asian University incorporated under section 4.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (4394)
  sectionNo (3)
  orderNo 3
  title `Provisions of Agreement to have force of law.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4394&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_3_content:
  string
  line `Notwithstanding anything contrary contained in`
  line `any other law, the provisions of the Agreement set out in the Schedule shall have the force of law in India.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (4395)
  sectionNo (4)
  orderNo 4
  title `Incorporation of South Asian University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4395&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_4_content:
  string
  line `(1) With effect from such date as the Central`
  line `Government may, by notification in the Official Gazette, appoint in this behalf, there shall be established,`
  line `for the purposes of giving effect to provisions of the Agreement, a University to be called as South Asian`
  line University.
  line
  line `(2) The University shall be a body corporate having perpetual succession and a common seal and`
  line `shall sue and be sued by the said name.`
  line
  line `(3) The Headquarters of the University shall be at Delhi.`
  line
  line `(4) The University may establish or maintain campuses and centres at such other places within India`
  line `and outside India in the SAARC region as it may deem fit.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (4396)
  sectionNo (5)
  orderNo 5
  title Jurisdiction.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4396&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_5_content:
  string
  line `The jurisdiction of the University shall extend to whole of India and to campuses`
  line `and centres established outside India in the SAARC region:`
  line
  line `Provided that where the University establishes and maintains any campus or centre outside India at`
  line `any place in the SAARC region, then the jurisdiction of the University shall extend to such campus or`
  line `centre, subject to the provision of the Agreement and laws in force in any of the Member States within`
  line `which such campus or centre is situated.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (4397)
  sectionNo (6)
  orderNo 6
  title `Governing Board.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4397&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_6_content:
  string
  line `(1) There shall be a Governing Board of the University consisting of two`
  line `members from each of the Member States of the SAARC and the President of the University:`
  line
  line `Provided that until the first Governing Board is formed, the Inter-Governmental Steering Committee`
  line `of the SAARC shall function as an interim Governing Board.`
  line
  line `(2) The Governing Board shall be headed by the Chairperson who shall be elected from amongst the`
  line `members of the Governing Board.`
  line
  line `(3) The members of the Governing Board shall be selected in such manner and for such term as`
  line `provided in Article 5 of the Schedule.`
  line
  line `(4) The President of the University shall be the ex officio member of the Governing Board.`
  line
  line `(5) The Governing Board shall be responsible for all the policies and directions of the University and`
  line `management of its affairs.`
  line
  line `(6) The Chairperson of the Board shall exercise such powers as may be prescribed by the Statutes.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (4398)
  sectionNo (7)
  orderNo 7
  title `Objectives of University.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4398&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_7_content:
  string
  line `The objectives of the University shall be--`
  line
  line `(a) to disseminate and advance knowledge, wisdom and understanding by providing instructional`
  line `and research facilities in such branches of learning as it may deem fit;`
  line
  line `(b) to take appropriate measures for promoting innovations in teaching-learning process,`
  line `inter-disciplinary studies and application of knowledge to social advancement, and human welfare`
  line `and to the promotion of regional peace and security;`
  line
  line `(c) to impart liberal and humane education towards capacity building of the South Asian nations`
  line `in the domain of science, technology and other areas of higher learning vital for improving their`
  line `quality of life and to give students the analytical tools needed for the pursuit of profession and`
  line `inculcate in them the quality of leadership;`
  line
  line `(d) to foster in the students sound civic sense and to train them to become useful citizens of`
  line `democratic societies;`
  line
  line `(e) to build a South Asian community of learning where students from countries of South Asia are`
  line `able to develop their fullest intellectual potential and to create a South Asian community by`
  line `strengthening regional consciousness; and`
  line
  line `(f) to harmonise the academic standards and accreditation norms in teaching, research and`
  line `curriculum that are acceptable to all Member States.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (4399)
  sectionNo (8)
  orderNo 8
  title `Powers of University.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4399&sectionno=8&orderno=8&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_8_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provisions for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to establish such special centres and specialised laboratories and such other units for research`
  line `and instruction as are necessary for the furtherance of its objects;`
  line
  line `(iii) to plan and prescribe courses of study for degrees, diplomas, certificates or for any other`
  line purpose;
  line
  line `(iv) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing and to withdraw any such diplomas, certificates, degrees or other academic`
  line `distinctions for good and sufficient cause;`
  line
  line `(v) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(vi) to organise and to undertake open learning programmes, extramural studies, training and`
  line `extension services;`
  line
  line `(vii) to institute Chairs, principalships, professorships, readerships and lecturerships and other`
  line `teaching and academic positions, required by the University and to appoint persons to such Chairs,`
  line `Principalships, Professorships, Readerships and lecturerships and other teaching and academic`
  line positions;
  line
  line `(viii) to appoint visiting professors, Emeritus professors, consultants, scholars and such other`
  line `persons who may contribute to the advancement of the objects of the University;`
  line
  line `(ix) to recognise persons as Professors, Readers or Lecturers or otherwise as teachers of the`
  line University;
  line
  line `(x) to create administrative and other posts as the University may deem necessary from time to`
  line `time and to make appointments thereto;`
  line
  line `(xi) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xii) to establish and maintain campuses, Centres, Regional Centres as may be determined from`
  line `time to time;`
  line
  line `(xiii) to admit to its privileges institutions situated within its jurisdiction as the University`
  line `institutions and to withdraw all or any of those privileges in accordance with such conditions as may`
  line `be prescribed by the Statutes;`
  line
  line `(xiv) to co-operate or collaborate or associate with any other University or authority or institution`
  line `of higher learning or any other public or private body, having in view the promotion of purposes and`
  line `objects similar to those of the University, in such manner as may be prescribed and for such purposes`
  line `as may be determined or agreed upon by the University;`
  line
  line `(xv) to determine standards of admission, including examination, evaluation or any other method`
  line `of testing, to the University, and the institutions maintained by or admitted to the privileges of the`
  line University;
  line
  line `(xvi) to demand and receive payment of fees and other charges as may be prescribed;`
  line
  line `(xvii) to establish Halls and to recognise, guide, supervise and control Halls not maintained by the`
  line `University and other accommodation for students, and to withdraw any such recognition;`
  line
  line `(xviii) to make arrangements for promoting health and general welfare of students and employees`
  line `of the University;`
  line
  line `(xix) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xx) to institute and award Fellowships, Scholarships, Studentships and prizes;`
  line
  line `(xxi) to receive benefactions, donations and gifts in accordance with the regulations made by the`
  line `Governing Board as per norms of the SAARC and to acquire, hold, manage and dispose of any`
  line `property, movable or immovable, including trust and endowment properties, for the purposes or`
  line `objects of the University and to invest funds in such manner as it deems fit;`
  line
  line `(xxii) to borrow, with the approval of the Governing Board, on the security of the University`
  line `property, money for purposes of the University;`
  line
  line `(xxiii) to recognise for any purpose, either in whole or in part, any institution or members or`
  line `students thereof on such terms and conditions as may, from time to time, be prescribed and to`
  line `withdraw such recognition;`
  line
  line `(xxiv) to enter into any agreement for the incorporation of any other institution in the University`
  line `and for taking its rights, properties and liabilities and for any other purpose not repugnant to this Act;`
  line
  line `(xxv) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions or bodies as it may deem necessary;`
  line
  line `(xxvi) to provide for the printing, reproduction and publication of research and other work which`
  line `may be issued by the University;`
  line
  line `(xxvii) to exercise such other powers accorded to it under the Agreement; and`
  line
  line `(xxviii) to do all such other acts as may be necessary, incidental or conducive to the promotion of`
  line `all or any of the objects of the University.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (4400)
  sectionNo (9)
  orderNo 9
  title `University open to all persons.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4400&sectionno=9&orderno=9&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_9_content:
  string
  line `The University shall be open to all persons irrespective of`
  line `gender, caste, creed, disability, ethnicity or socio-economic background and it shall not be lawful for the`
  line `University to adopt or impose on any person, any test whatsoever of religious belief or profession in order`
  line `to entitle him to be appointed as a teacher of the University or to hold any office therein or be admitted as`
  line `a student in the University or to graduate thereat or to enjoy or exercise any privilege thereof.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (4401)
  sectionNo (10)
  orderNo 10
  title Visitor.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4401&sectionno=10&orderno=10&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_10_content:
  string
  line `(1) The Foreign Minister of the current Chair of the SAARC shall be the Visitor of the`
  line University.
  line
  line `(2) The Visitor shall have such powers as may be prescribed by the Statutes.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (4402)
  sectionNo (11)
  orderNo 11
  title `Officers of University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4402&sectionno=11&orderno=11&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_11_content:
  string
  line `(1) There shall be a President of the University, and such other officers`
  line `appointed in such manner as may be prescribed, who shall exercise such powers and functions as may be`
  line prescribed.
  line
  line `(2) The President shall be the Chief Executive Officer of the University.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (4403)
  sectionNo (12)
  orderNo 12
  title `President and its powers.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4403&sectionno=12&orderno=12&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_12_content:
  string
  line `(1) The President shall be appointed by the Governing Board in such`
  line `manner as may be prescribed by the Statutes:`
  line
  line `Provided that until the President is appointed, the Chief Executive Officer of the Project Office shall`
  line `exercise the powers of the President and function as Chief Executive Officer of the University.`
  line
  line `(2) The President shall, as the Chief Executive Officer, exercise general supervision and control over`
  line `the affairs of the University and shall be responsible for implementing the objectives of the University`
  line `and fulfilling the policy directives of the Governing Board.`
  line
  line `(3) The President may, if he is of the opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority at its next meeting the action taken by him on such matter:`
  line
  line `Provided that such exercise of power shall be made only in emergent situations and in no case in`
  line `respect of creation and upgradation of posts, and appointments thereto:`
  line
  line `Provided further that if the authority concerned is of the opinion that such action ought not to have`
  line `been taken, it may refer the matter to the Governing Board whose decision thereon shall be final.`
  line
  line `(4) The President, if he is of the opinion that any decision of any authority of the University is beyond`
  line `the powers of the authority conferred by the provisions of this Act and the Statutes or that any decision`
  line `taken is not in the interest of the University, may ask the authority concerned to review its decision within`
  line `sixty days of such decision and if the authority refuses to review the decision either in whole or in part or`
  line `no decision is taken by it within the said period of sixty days, the matter shall be referred to the`
  line `Governing Board whose decision thereon shall be final.`
  line
  line `(5) The President or any officer of the University, authorised by him in this behalf, shall have the`
  line `power to enter into agreements, sign documents and authenticate records on behalf of the University.`
  line
  line `(6) The President shall exercise such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (4404)
  sectionNo (13)
  orderNo 13
  title `Other officers.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4404&sectionno=13&orderno=13&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_13_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be such as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (4405)
  sectionNo (14)
  orderNo 14
  title `Privileges and immunities of President and academic staff.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4405&sectionno=14&orderno=14&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_14_content:
  string
  line `The University, the President and`
  line `the members of the academic staff and, where applicable, their dependents or members of the family,`
  line `shall enjoy such privileges and immunities as the Central Government may notify under section 3 of the`
  line `United Nations (Privileges and Immunities) Act, 1947 (46 of 1947).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (4406)
  sectionNo (15)
  orderNo 15
  title `Authorities of University.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4406&sectionno=15&orderno=15&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_15_content:
  string
  line `The following shall be the authorities of the University--`
  line
  line `(a) the Executive Council,`
  line
  line `(b) the Academic Council, and`
  line
  line `(c) such other authorities as may be declared by the Governing Board in the Statutes to be the`
  line `authorities of the University.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (4407)
  sectionNo (16)
  orderNo 16
  title `Executive Council.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4407&sectionno=16&orderno=16&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_16_content:
  string
  line `(1) The Executive Council shall be the executive body of the University`
  line `and shall exercise powers to give effect to the directions or decisions of the President and the Governing`
  line Board.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be such as may be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (4408)
  sectionNo (17)
  orderNo 17
  title `Academic Council.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4408&sectionno=17&orderno=17&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_17_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and Regulations, co-ordinate and`
  line `exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of its members and its powers and`
  line `functions shall be such as may be prescribed by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (4409)
  sectionNo (18)
  orderNo 18
  title `Constitution of other authorities.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4409&sectionno=18&orderno=18&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_18_content:
  string
  line `The constitution of the authorities under clause (c) of`
  line `section 15, the terms of the office of the members of such authorities and their powers and duties shall be`
  line `such as may be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (4410)
  sectionNo (19)
  orderNo 19
  title `Faculties and Departments.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4410&sectionno=19&orderno=19&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_19_content:
  string
  line `(1) The University shall have such faculties as may be prescribed`
  line `by the Statutes.`
  line
  line `(2) Each Faculty shall have such Departments or Schools of Studies as are prescribed by the Statutes,`
  line `and each Department or Schools of Studies shall have such subjects of study as may be assigned to it by`
  line Regulations.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (4411)
  sectionNo (20)
  orderNo 20
  title Statutes.
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4411&sectionno=20&orderno=20&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_20_content:
  string
  line `(1) Subject to the provisions of this Act, the Statutes may provide for all or any of the following matters, namely:--`
  line
  line `(a) powers of the Visitor;`
  line
  line `(b) powers of the Chairperson of the Governing Board;`
  line
  line `(c) manner of appointment of the President and its powers;`
  line
  line `(d) the constitution, powers and functions of the Executive Council, Academic Council and other`
  line `authorities and bodies of the University;`
  line
  line `(e) categories of academic staff;`
  line
  line `(f) appointment of teachers, academic staff and other employees of the University;`
  line
  line `(g) establishment of faculties of the University;`
  line
  line `(h) the conditions under which institution may be admitted to the privileges of the University and`
  line `the withdrawal of such privileges;`
  line
  line `(i) the conferment of honorary degrees;`
  line
  line `(j) delegation of powers vested in the authorities or officers of the University;`
  line
  line `(k) setting up of a machinery for redressal of grievances between employees or the students and`
  line `the University; and`
  line
  line `(l) all other matters which by this Act are to be or may be provided for by the Statutes.`
  line
  line `(2) The First Statutes shall be those as may be made for the operation of the University by the`
  line `Inter-Governmental Steering Committee of the SAARC.`
  line
  line `(3) The Governing Board may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (2):`
  line
  line `Provided that the Governing Board shall not make, amend or repeal any Statute affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `has been considered by the Governing Board.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (4412)
  sectionNo (21)
  orderNo 21
  title Regulations.
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4412&sectionno=21&orderno=21&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_21_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the Regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission and enrolment of students to the University and institutions maintained by, or`
  line `admitted to, the privileges of the University;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(f) the institution of, and conditions for award of, fellowships, scholarships, studentships and`
  line prizes;
  line
  line `(g) the conduct of examinations, including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing of special courses of studies for them;`
  line
  line `(j) the establishment of Centres, University Institutes, Departments, Schools of Studies, Boards of`
  line `Studies, specialised laboratories and Committees;`
  line
  line `(k) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(l) the manner of co-operation and collaboration with other Universities, institutions and other`
  line `bodies or associations; and`
  line
  line `(m) all other matters which by this Act or the Statutes are to be or may be provided for by the`
  line Regulations.
  line
  line `(2) The First Regulations shall be made by the Chief Executive Officer of the Project Office with the`
  line `prior approval of the Inter-Governmental Steering Committee and the Regulations so made may be`
  line `amended, repealed or added to any time by the Governing Board in the manner prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (4413)
  sectionNo (22)
  orderNo 22
  title Bye-laws.
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4413&sectionno=22&orderno=22&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_22_content:
  string
  line `The authorities of the University may make bye-laws consistent with this Act, the`
  line `Statutes and the Regulations for the conduct of their own business and not provided for by this Act, the`
  line `Statutes or the Regulations, in the manner as may be prescribed by Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (4414)
  sectionNo (23)
  orderNo 23
  title `Power to give retrospective effect to Statutes and Regulations.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4414&sectionno=23&orderno=23&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_23_content:
  string
  line `The power to make Statutes`
  line `or Regulations shall include the power to give retrospective effect, from a date not earlier than the date of`
  line `commencement of this Act, to the Statutes or Regulations or any of them but no retrospective effect shall`
  line `be given to any Statute or Regulation so as to prejudicially affect the interests of any person to whom`
  line `such Statute or Regulation may be applicable.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (4415)
  sectionNo (24)
  orderNo 24
  title `Annual report.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4415&sectionno=24&orderno=24&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_24_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Governing Board and shall be considered by the University at its annual meeting. The annual report of`
  line `the University shall also be presented to the session of the Council of Ministers of the SAARC.`
  line
  line `(2) The annual report of the University shall be circulated to all the SAARC Member States through`
  line `the SAARC Secretariat.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (4416)
  sectionNo (25)
  orderNo 25
  title `Audit of accounts.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4416&sectionno=25&orderno=25&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_25_content:
  string
  line `(1) The accounts of the University shall, once at least in every year and at intervals of not more than fifteen months, be audited by any person or firm authorised by the Governing`
  line Board.
  line
  line `(2) The accounts of the University shall be audited, as per existing norms as laid down by the`
  line SAARC.
  line
  line `(3) The accounts, when audited shall be published, and a copy of the accounts together with the`
  line `audited report shall be submitted to the Secretary-General of the SAARC.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (4417)
  sectionNo (26)
  orderNo 26
  title `Conditions of service of employees.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4417&sectionno=26&orderno=26&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_26_content:
  string
  line `(1) Every employee of the University shall be appointed`
  line `under a written contract, which shall be lodged with the University and a copy of which shall be furnished`
  line `to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall be referred`
  line `to the Tribunal for Arbitration constituted for that purpose.`
  line
  line `(3) The decision of the Tribunal shall be final and no suit shall lie in any court in respect of the`
  line `matters decided by the Tribunal.`
  line
  line `(4) The procedure for regulating the work of the Tribunal under sub-section (2) shall be prescribed by`
  line `the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (4418)
  sectionNo (27)
  orderNo 27
  title `Procedure of arbitration in disciplinary cases against students.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4418&sectionno=27&orderno=27&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_27_content:
  string
  line `Any dispute arising out of`
  line `any disciplinary action taken by the University against a student shall, at the request of such student, be`
  line `referred to a Tribunal for Arbitration and the provisions of sub-sections (2), (3) and (4) of section 26 shall,`
  line `as far as may be, apply to the reference made under this section.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (4419)
  sectionNo (28)
  orderNo 28
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4419&sectionno=28&orderno=28&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_28_content:
  string
  line `No act or`
  line `proceedings of the University or any of its authorities or bodies shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (4420)
  sectionNo (29)
  orderNo 29
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4420&sectionno=29&orderno=29&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_29_content:
  string
  line `No suit or other legal proceeding shall lie against the`
  line `University, any of its officers or employees for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (4421)
  sectionNo (30)
  orderNo 30
  title `Reference to SAARC Arbitration Council.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4421&sectionno=30&orderno=30&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_30_content:
  string
  line `All differences arising out of the interpretation or`
  line `application of the Agreement shall be referred to the SAARC Arbitration Council, unless in any case it is`
  line `agreed by the parties to have recourse to another mode of settlement.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (4422)
  sectionNo (31)
  orderNo 31
  title `Statutes and Regulations and bye-laws to be published in Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4422&sectionno=31&orderno=31&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_31_content:
  string
  line `(1) The Statutes, Regulations and bye-laws made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Regulation or bye-law made under this Act shall be laid, as soon as may be after it`
  line `is made, before each House of Parliament.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (4423)
  sectionNo (32)
  orderNo 32
  title `Power to remove difficulties.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00018_200908_1517807327343&sectionId=4423&sectionno=32&orderno=32&orgactid=AC_CEN_10_10_00018_200908_1517807327343
obj_root_law_sections_32_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of the period of three`
  line `years from the commencement of this Act.`
  line
  line `(2) Every order made under sub-section (1) shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_translations:
