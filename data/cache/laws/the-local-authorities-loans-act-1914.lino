obj_root_law_sections_1:
  sectionId (68210)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68210&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Local Authorities Loans Act, 1914.`
  line
  line `^1[(2) It extends to the whole of India except ^2[the territories which, immediately before`
  line `the 1^st November, 1956, were comprised in Part B States.]]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by the A.O. 1950, for sub-section (2).`
  line
  line `2. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for Part B States.`
obj_root_law_sections_2:
  sectionId (68211)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Ins. by the A.O. 1937.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68211&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_2_content:
  string
  line `In this Act, “local authority” means any person legally entitled to the control or`
  line `management of any local or municipal fund, or legally entitled to impose any cess, rate, duty or tax within`
  line `any local area;`
  line
  line `“funds”, used with reference to any local authority, includes any local or municipal fund to the`
  line `control or management of which such authority is legally entitled, and any cess rate duty or tax which`
  line `such authority is legally entitled to impose, and any property vested in such authority;`
  line
  line `“prescribed” means prescribed by rules made under this Act; and`
  line
  line `“work” includes a survey, whether incidental to any other work or not`
  line
  line `^1[“The Government” or “the appropriate Government” means, in relation to cantonment authorities`
  line `and in relation to port authorities in major ports, the Central Government, and in relation to other local`
  line `authorities, the State Government.]`
obj_root_law_sections_3:
  sectionId (68212)
  sectionNo (3)
  orderNo 3
  title `Borrowing powers of local authorities.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68212&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_3_content:
  string
  line `(1) A local authority may, subject to the prescribed`
  line `conditions, borrow on the security of its funds or any portion thereof for any of the following purposes,`
  line `namely:-`
  line
  line `(i) the carrying out of any works which it is legally authorized to carry out,`
  line
  line `(ii) the giving of relief and the establishment and maintenance of relief works in times of famine or`
  line scarcity,
  line
  line `(iii) the prevention of the outbreak or spread of any dangerous epidemic disease,`
  line
  line `(iv) any measures which may be connected with or ancillary to any purposes specified in clauses`
  line `(ii) and (iii), (v) the repayment of money previously borrowed in accordance with law:`
  line
  line `Provided that nothing in clause (v) shall be deemed to empower a local authority to fix a period for`
  line `the repayment of any money borrowed thereunder which, when the period fixed for the repayment of`
  line `the money previously borrowed is taken into account, will exceed the maximum period fixed for the`
  line `repayment of a loan by or under any enactment for the time being in force:`
  line
  line `^1[Provided further that, in the case of loans other than loans made by the ^2[appropriate`
  line `Government], no amount exceeding twenty-five lakhs of rupees shall be borrowed unless the terms,`
  line `including the date of flotation, of such loan have been approved by the ^3[appropriate Government].]`
  line
  line `(2) Nothing in this section shall be deemed to authorize any local authority-`
  line
  line `(a) to borrow or spend money for any purpose for which, under the law for the time being in force,`
  line `it is not authorized to apply its funds, or`
  line
  line `(b) to borrow money by means of the issue of bills or promissory notes payable within any period`
  line `not exceeding twelve months.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Ins. by Act 38 of 1920, s. 2 and Sch. I.`
  line
  line `2. Subs. by the A.O. 1937, for "L. G".`
  line
  line `3. Subs., ibid., for "G. G. in C.".`
obj_root_law_sections_4:
  sectionId (68213)
  sectionNo (4)
  orderNo 4
  title `Power to Government to make rules.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68213&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_4_content:
  string
  line `(1) The^1[appropriate Government] may makeles`
  line `consistent with this Act as to-`
  line
  line `(i) the nature of the funds on the security of which money may be borrowed;`
  line
  line `(ii) the works for which money may be borrowed;`
  line
  line `(iii) the manner of making applications for permission to borrow money;`
  line
  line `(iv) the inquiries to be made in relation to such loans, and the manner of conducting such inquiries;`
  line
  line `(v) the cases and the forms in which particulars of applications and proceedings, and orders`
  line `thereon, shall be published;`
  line
  line `(vi) the cases in which the ^1[appropriate Government] may make loans ^2* * *;`
  line
  line `^3[(vii) the cases in which local authorities may take loans from persons other than the ^1[appropriate Government];]`
  line
  line `(viii) the manner of recording and enforcing the conditions on which money is to be borrowed;`
  line
  line `(ix) the manner and time of making or raising loans;`
  line
  line `(x) the inspection of any works carried out by means of loans;`
  line
  line `(xi) the installments, if any, by which loans shall be repaid, the interest to be charged on loans, and the manner and time of repaying loans and of paying the interest thereon;`
  line
  line `(xii) the sum to be charged against the funds which are to form the security for the loan, as costs in`
  line `effecting the loan;`
  line
  line `(xiii) the attachment of such funds, and the manner of disposing of or collecting them;`
  line
  line `(xiv) the accounts to be kept in respect of loans;`
  line
  line `(xv) the utilization of unexpended balances of loans either in the reduction in any way of the debt of`
  line `the local authority, or in carrying out any works which that authority is legally authorized to carry out; and the sanction necessary to such utilization;`
  line
  line `and as to all other matters incidental to carrying this Act into effect`
  line
  line `^4* ***`
  line
  line `(3) All rules made under this Act shall be published ^5[* * *] in the Official Gazette; and on such`
  line `publication, shall have effect as if enacted in this Act.`
  line
  line `^6[(4) Every rule made by the Central Government under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
obj_root_law_sections_4_footnotes:
  string
  line `1.Subs. by the A.O. 1937, for L. G.`
  line
  line `2.Certain word rep. by Act 38 of 1920, s. 2 and Sch. I.`
  line
  line `3.Subs. by s. 2 and Sch. I, ibid., for the original clause.`
  line
  line `4.Sub-section (2) rep. by Act 38 of 1920, s. 2 and Sch. I.`
  line
  line `5. Certain words rep. ibid., s. 2 and Sch. I.`
  line
  line `6. Ins. by 20 of 1983, s. 2 and Sch. (w.e.f 15-3-84)`
obj_root_law_sections_5:
  sectionId (68214)
  sectionNo (5)
  orderNo 5
  title `Remedy by attachment if loan not repaid.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by the A.O. 1937, for L. G..`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68214&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_5_content:
  string
  line `If any money borrowed in accordance with the`
  line `provisions of this Act, or any interest or costs due in respect thereof, is or are not repaid according to the`
  line `conditions of the loan, the4`
  line `^1[appropriate Government], if itself the lender, may and, if the ^1[appropriate`
  line `Government] is not the lender, shall, on the application of the lender, attach the funds on the security of`
  line `which the loan was made. After such attachment, no person, except an officer appointed in this behalf by`
  line `the ^1[appropriate Government], shall in any way deal with the attached funds; but such officer may do all`
  line `acts in respect thereof which the borrowers might have done if such attachment had not taken place, and`
  line `may apply the proceeds in satisfaction of the loan and of all interests and costs due in respect thereof and`
  line `of all expenses caused by the attachment and subsequent proceedings:`
  line
  line `Attachment not to defeat prior charges legally made.—Provided that no such attachment shall`
  line `defeat or prejudice any debt for which the funds attached were previously pledged in accordance with`
  line `law; but all such prior charges shall be paid out of the proceeds of the funds before any part of the`
  line `proceeds is applied to the satisfaction of the liability in respect of which such attachment is made.`
obj_root_law_sections_6:
  sectionId (68215)
  sectionNo (6)
  orderNo 6
  title `Issue of short term bills.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68215&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_6_content:
  string
  line `(1) Subject to the provisions of section 26 of the Indian Paper`
  line `Currency Act, 1910^1 (2 of 1910), the local authorities mentioned in Schedule I and any other local`
  line `authority to which the ^2[appropriate Government] may, by notification in the Official Gazette, extend the`
  line `provisions of this section, may, with the previous sanction of the ^2[appropriate Government], borrow`
  line `money by means of the issue of bills or promissory notes payable within any period, not exceeding twelve months, for any purpose for which such local authority may lawfully borrow money under any law for the`
  line `time being in force:`
  line
  line `Provided that the amount of the bills or promissory notes which may be so issued, shall not exceed,`
  line `when the amount of the other moneys for the time being borrowed by such local authority is taken into`
  line `account, the total amount which such local authority is empowered by law to borrow.`
  line
  line `(2) The ^2[appropriate Government] may, by general or special order, regulate the conditions on which`
  line `money may be borrowed or repaid under this section.`
obj_root_law_sections_6_footnotes:
  string
  line `1.See now s. 31 of the Reserve Bank of India Act, 1934 (2 of 1934).`
  line
  line `2. Subs. by the A. O. 1937, for "G. G. in C".`
obj_root_law_sections_7:
  sectionId (68216)
  sectionNo (7)
  orderNo 7
  title `Loans not to be effected except under this Act.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68216&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_7_content:
  string
  line `Except as provided by or under this Act, no`
  line `local authority shall, for any purpose, borrow money upon, or otherwise charge, its funds; and any`
  line `contract otherwise made for that purpose after the passing of this Act shall be void:`
  line
  line `Provided that nothing herein contained shall be deemed-`
  line
  line `(a) to preclude any local authority from exercising the borrowing powers conferred on it by any`
  line `special enactment now or hereafter in force; or`
  line
  line `(b) to affect the power conferred on any local authority by any such enactment to charge its funds,`
  line `by guaranteeing the payment of interest on money to be applied to any purpose to which the`
  line `funds of the local authority can legally be applied`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (68217)
  sectionNo (8)
  orderNo 8
  title `Application of Act to loans existing previous to the fifth of September, 1871.`
  content obj_root_law_sections_8_content
  footnotes `1.Subs. byAct 38 of 1920, for the original section.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68217&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_8_content:
  string
  line `^1[8. Application of Act to loans existing previous to the fifth of September, 1871.—The remedy`
  line `mentioned in section 5 shall be available for the recovery of any money lent by the Secretary of State in`
  line `Council to any local authority before the fifth day of September, eighteen hundred and seventy-one, and`
  line `the interest due on such money.]`
obj_root_law_sections_9:
  sectionId (68218)
  sectionNo (9)
  orderNo 9
  title Repealed.
  content `[Repealed by the Repealing Act, 1927 (12 of 1927), section 2 and the Schedule.]`
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00104_191409_1663845852095&sectionId=68218&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00104_191409_1663845852095
obj_root_law_sections_9_footnotes:
  string
  line
