obj_root_law:
  slug the-national-council-for-teacher-education-act-1993
  handle (1938)
  collectionHandle 123456789/1362
  title `The National Council for Teacher Education Act, 1993`
  actNumber (73)
  enactmentDate 1993-12-29
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1938`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्ट्री य अध्यापक शिक्षा परिषद्अधिनियम, 1993`
  actYear (1993)
  ministry `Ministry of Education`
  department `Department of School Education and Literacy`
  longTitle `An Act to provide for the establishment of a National Council for Teacher Education with a view to achieving planned and co-ordinated development of the teacher education system throughout the country, the regulation and proper maintenance of norms and standards in the teacher education system including qualifications of school teachers and for matters connected therewith.`
  enforcementDate 01-07-1995
  notification `1st July, 1995, vide notification No. S.O. 620(E), dated 1st July, 1995, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T21:17:20.428Z`
  translations obj_root_law_translations
