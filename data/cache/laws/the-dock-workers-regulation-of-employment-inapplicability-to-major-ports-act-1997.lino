obj_root_law_sections_1:
  sectionId (22924)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00003_199731_1517807322817&sectionId=22924&sectionno=1&orderno=1&orgactid=AC_CEN_30_42_00003_199731_1517807322817
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Dock Workers (Regulation of`
  line `Employment) (Inapplicability to Major Ports) Act, 1997.`
  line
  line `(2) It shall come into force on such date ^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1 5th January, 1998, vide notification No. S.O. 22(E), dated 5th January, 1998, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (22925)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00003_199731_1517807322817&sectionId=22925&sectionno=2&orderno=2&orgactid=AC_CEN_30_42_00003_199731_1517807322817
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day", in relation to a major port, means the date specified under section 3 for that`
  line `major port;`
  line
  line `(b) "Board" has the same meaning as in the Major Port Trusts Act, 1963 (38 of 1963);`
  line
  line `(c) "Dock Labour Board" means a Dock Labour Board established under section 5A of the Dock`
  line `Workers (Regulation of Employment) Act, 1948 (9 of 1948);`
  line
  line `(d) "major port" has the same meaning as in the Indian Ports Act, 1908 (15 of 1908).`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (22926)
  sectionNo (3)
  orderNo 3
  title `Inapplicability of the provisions of the Dock Workers (Regulation of Employment) Act, 1948 to major ports.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00003_199731_1517807322817&sectionId=22926&sectionno=3&orderno=3&orgactid=AC_CEN_30_42_00003_199731_1517807322817
obj_root_law_sections_3_content:
  string
  line `The Central Government may, after settlement is arrived at between the Dock Labour`
  line `Board of any major port, its workmen and the management of that major port in accordance with the`
  line `provisions of the Industrial Disputes Act, 1947 (14 of 1947), direct, by notification in the Official Gazette`
  line `that the provisions of the Dock Workers (Regulation of Employment) Act, 1948 (9 of 1948), shall cease`
  line `to have effect in relation to that major port with effect from the date specified in that notification.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (22927)
  sectionNo (4)
  orderNo 4
  title `Transfer of assets and liabilities of the Dock Labour Board, etc., to the Board.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00003_199731_1517807322817&sectionId=22927&sectionno=4&orderno=4&orgactid=AC_CEN_30_42_00003_199731_1517807322817
obj_root_law_sections_4_content:
  string
  line `(1) On the`
  line `appointed day in relation to a major port,--`
  line
  line `(a) all property, assets and funds vested in the Dock Labour Board immediately before such day,`
  line `shall vest in the Board;`
  line
  line `(b) all debts, obligations and liabilities incurred, all contracts entered into and all matters and`
  line `things engaged to be done, by, with or for the Dock Labour Board immediately before such day, for`
  line `or in connection with the purposes of the Dock Labour Board, shall be deemed to have been incurred,`
  line `entered into and engaged to be done by, with or for the Board;`
  line
  line `(c) all sums of money due to the Dock Labour Board immediately before such day shall be`
  line `deemed to be due to the Board;`
  line
  line `(d) all suits and other legal proceedings instituted by or against the Dock Labour Board`
  line `immediately before such day for any matter in relation to the Dock Labour Board may be continued`
  line `by or against the Board.`
  line
  line `(e) every employee and worker serving under the Dock Labour Board shall hold office or service`
  line `under the Board on the terms and conditions which are not in any way less favourable than those`
  line `which would have been admissible to him if there had not been transfer of his services to the Board`
  line `and shall continue to do so unless and until his employment in the Board is duly terminated or until`
  line `his tenure, remuneration or terms and conditions of service are duly altered by the Board.`
  line
  line `(2) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947), or in any`
  line `other law for the time being in force, the transfer of the services of any employee under this section to the`
  line `Board shall not entitle such employee to any compensation under that Act or any other law, and no such`
  line `claim shall be entertained by any court, tribunal or other authority.`
obj_root_law_sections_4_footnotes:
  string
  line
