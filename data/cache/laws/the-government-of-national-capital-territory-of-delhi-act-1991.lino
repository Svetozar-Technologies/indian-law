  (str actYear) (str 1992)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of States`)
  (str longTitle) (str `An Act to supplement the provisions of the Constitution relating to the Legislative Assembly and a Council of Ministers for the National Capital Territory of Delhi and for matters connected therewith or incidental thereto.`)
