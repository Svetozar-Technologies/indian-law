obj_root_law_sections_1:
  sectionId (8211)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8211&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Government of National`
  line `Capital Territory of Delhi Act, 1991.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act and any reference`
  line `in any such provision to the commencement of this Act shall be construed as a reference to the coming`
  line `into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st February, 1992 (ss. 2, 3, 38, 39, 40 and 53), vide notification No. S.O. 97(E), dated 31st January, 1992, See Gazette of`
  line `India, Extraordinary, Part II, sec. 3( ).`
  line
  line `2nd October, 1993 [ss. 4 to 37 (both inclusive), 43 to 45 (both inclusive), 49 to 52 (both inclusive), 54 and 55], vide notification`
  line `No. S.O. 735(E), dated 30th September, 1993, See Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  line
  line `25th November, 1993 (ss 46, 47 and 48), vide notification No. S.O. 894(E), dated 25th November, 1993, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
  line
  line `29th November, 1993 (s. 56), vide notification No. S.O. 910(E), dated 29th November, 1993, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (8212)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Ins. by Act 19 of 2023, s. 2 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8212&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "article" means an article of the Constitution;`
  line
  line `(b) "assembly constituency" means a constituency provided under this Act for the purpose of`
  line `elections to the Legislative Assembly;`
  line
  line `(c) "Capital" means the National Capital Territory of Delhi;`
  line
  line `(d) "Election Commission" means the Election Commission referred to in article 324;`
  line
  line `(e) "Legislative Assembly" means the Legislative Assembly of the National Capital Territory of`
  line Delhi;
  line
  line `^1[(ea) "Lieutenant Governor" means the administrator appointed under article 239 of the`
  line `Constitution for the National Capital Territory of Delhi and designated as Lieutenant Governor by the`
  line President;
  line
  line `(eb) "Minister" means a member of the Council of Ministers referred to in clause (4) of article`
  line `239AA of the Constitution, by whatever name called and includes a Deputy Minister;]`
  line
  line `(f) "Scheduled Castes", in relation to the Capital, means such castes, races or tribes or parts of or`
  line `groups within such castes, races or tribes as are deemed under article 341 to be Scheduled Castes in`
  line `relation to the Capital.`
obj_root_law_sections_3:
  sectionId (8213)
  sectionNo (3)
  orderNo 3
  title `Legislative Assembly and its composition.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8213&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_3_content:
  string
  line `(1) The total number of seats in the Legislative`
  line `Assembly to be filled by persons chosen by direct election from territorial constituencies shall be seventy.`
  line
  line `(2) For the purpose of elections to the Legislative Assembly, the Capital shall be divided into`
  line `single-member assembly constituencies in accordance with the provisions of Part III in such manner that`
  line `the population of each of the constituencies shall, so far as practicable, be the same throughout the`
  line Capital.
  line
  line `(3) Seats shall be reserved for the Scheduled Castes in the Legislative Assembly, and the number of`
  line `seats so reserved shall bear, as nearly as may be, the same proportion to the total number of seats in the`
  line `Assembly as the population of the Scheduled Castes in the Capital bears to the total population of the`
  line `Capital and the provisions of article 334 shall apply to such reservation.`
  line
  line `Explanation.In this section, the expression population means the population as ascertained in the`
  line `last preceding census of which the relevant figures have been published:`
  line
  line ^1
  line `[Provided that the reference in this Explanation to the last preceding census of which the relevant`
  line `figures have been published shall, until the relevant figures for the first census taken after the year 2026`
  line `have been published, be construed as a reference to the 2001 census:]`
  line
  line ^2
  line `[Provided further that any readjustment in the division of the Capital into territorial constituencies by`
  line `the Delimitation Commission under the Delimitation Act, 2002 (33 of 2002) on the basis of 2001 census`
  line `shall take effect from such date as the Central Government may, by order, published in the Official`
  line `Gazette, specify and until such readjustment takes effect, any election to the Legislative Assembly may be`
  line `held on the basis of the territorial constituencies existing before such readjustment.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 19 of 2005, s. 5, for the proviso (w.e.f. 21-5-2005).`
  line
  line `2. Ins. by Act 5 of 2006, s. 3 (w.e.f. 20-3-2006).`
obj_root_law_sections_4:
  sectionId (8214)
  sectionNo (4)
  orderNo 4
  title `Qualifications for membership of Legislative Assembly.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8214&sectionno=4&orderno=4&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_4_content:
  string
  line `A person shall not be qualified to be`
  line `chosen to fill a seat in the Legislative Assembly unless he—`
  line
  line `(a) is a citizen of India and makes and subscribes before some person authorised in that behalf`
  line `by the Election Commission an oath or affirmation according to the form set out for the purpose in`
  line `the Schedule;`
  line
  line `(b) is not less than twenty-five years of age; and`
  line
  line `(c) possesses such other qualifications as may be prescribed in that behalf by or under any law`
  line `made by parliament.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (8215)
  sectionNo (5)
  orderNo 5
  title `Duration of Legislative Assembly.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8215&sectionno=5&orderno=5&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_5_content:
  string
  line `The Legislative Assembly, unless sooner dissolved, shall`
  line `continue for five years from the date appointed for its first meeting and no longer, and the expiration of`
  line `the said period of five years shall operate as a dissolution of the Assembly:`
  line
  line `Provided that the said period may, while a Proclamation of Emergency issued under clause (1) of`
  line `article 352 is in operation, be extended by the President by order for a period not exceeding one year at a`
  line `time and not extending in any case beyond a period of six months after the Proclamation has ceased to`
  line operate.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (8216)
  sectionNo (6)
  orderNo 6
  title `Sessions of Legislative Assembly, prorogation and dissolution.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8216&sectionno=6&orderno=6&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_6_content:
  string
  line `(1) The Lieutenant Governor`
  line `shall, from time to time, summon the Legislative Assembly to meet at such time and place as he thinks fit,`
  line `but six months shall not intervene between its last sitting in one session and the date appointed for its`
  line `first sitting in the next session.`
  line
  line `(2) The Lieutenant Governor may, from time to time,—`
  line
  line `(a) prorogue the Assembly;`
  line
  line `(b) dissolve the Assembly.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (8217)
  sectionNo (7)
  orderNo 7
  title `Speaker and Deputy Speaker of Legislative Assembly.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8217&sectionno=7&orderno=7&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_7_content:
  string
  line `(1) The Legislative Assembly shall,`
  line `as soon as may be, choose two members of the Assembly to be respectively Speaker and Deputy Speaker`
  line `thereof and, so often as the office of Speaker or Deputy Speaker become vacant, the Assembly shall`
  line `choose another member to be Speaker or Deputy Speaker, as the case may be.`
  line
  line `(2) A member holding office as Speaker or Deputy Speaker of the Legislative Assembly—`
  line
  line `(a) shall vacate his office if he ceases to be a member of the Assembly;`
  line
  line `(b) may, at any time by writing under his hand addressed, if such member is the Speaker, to the`
  line `Deputy Speaker, and if such member is the Deputy Speaker, to the Speaker, resign his office; and`
  line
  line `(c) may be removed from his office by a resolution of the Assembly passed by a majority of all`
  line `the then members of the Assembly:`
  line
  line `Provided that no resolution for the purpose of clause (c) shall be moved unless at least fourteen days'`
  line `notice has been given of the intention to move the resolution:`
  line
  line `Provided further that whenever the Assembly is dissolved, the Speaker shall not vacate his office`
  line `until immediately before the first meeting of the Assembly after the dissolution.`
  line
  line `(3) While the office of Speaker is vacant, the duties of the office shall be performed by the Deputy`
  line `Speaker or, if the office of Deputy Speaker is also vacant, by such member of the Assembly as may be`
  line `determined by the rules of procedure of the Assembly.`
  line
  line `(4) During the absence of the Speaker from any sitting of the Assembly, the Deputy Speaker, or, if`
  line `he is also absent, such person as may be determined by the rules of procedure of the Assembly, or, if no`
  line `such person is present, such other person as may be determined by the Assembly, shall act as Speaker.`
  line
  line `(5) There shall be paid to the Speaker and the Deputy Speaker of the Legislative Assembly such`
  line `salaries and allowances as may be respectively fixed by the Legislative Assembly by law and, until`
  line `provision in that behalf is so made, such salaries and allowances as the Lieutenant Governor may, with`
  line `the approval of the President, by order determine.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (8218)
  sectionNo (8)
  orderNo 8
  title `Speaker or Deputy Speaker not to provide while a resolution for his removal from office is under consideration.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8218&sectionno=8&orderno=8&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_8_content:
  string
  line `(1) At any sitting of the Legislative Assembly, while any resolution for the`
  line `removal of the Speaker from his office is under consideration, the Speaker, or while any resolution for the`
  line `removal of the Deputy Speaker from his office is under consideration, the Deputy Speaker, shall not,`
  line `though he is present, preside and the provisions of sub-section (4) of section 7 shall apply in relation to`
  line `every such sitting as they apply in relation to a sitting from which the Speaker or, as the case may be, the`
  line `Deputy Speaker is absent.`
  line
  line `(2) The Speaker shall have the right to speak in, and otherwise to take part in the proceedings of, the`
  line `Legislative Assembly while any resolution for his removal from office is under consideration in the`
  line `Assembly and shall, notwithstanding anything in section 13, be entitled to vote only in the first instance`
  line `on such resolution or on any other matter during such proceedings but not in the case of an equality of`
  line votes.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (8219)
  sectionNo (9)
  orderNo 9
  title `Right of Lieutenant Governor to address and send messages to Legislative Assembly.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8219&sectionno=9&orderno=9&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_9_content:
  string
  line `(1) The Lieutenant Governor may address the Legislative Assembly and for that purpose`
  line `require the attendance of members.`
  line
  line `(2) The Lieutenant Governor may send messages to the Assembly whether with respect to a Bill then`
  line `pending in the Assembly or otherwise, and when a message is so sent, the Assembly shall with all`
  line `convenient dispatch consider any matter required by the message to be taken into consideration.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (8220)
  sectionNo (10)
  orderNo 10
  title `Special address by the Lieutenant Governor.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8220&sectionno=10&orderno=10&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_10_content:
  string
  line `(1) At the commencement of the first session`
  line `after each general election to the Legislative Assembly and at the commencement of the first session of`
  line `each year, the Lieutenant Governor shall address the Legislative Assembly and inform it of the causes of`
  line `its summons.`
  line
  line `(2) Provision shall be made by rules to be made by the Assembly regulating its procedure for the`
  line `allotment of time for discussion of the matters referred to in such address.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (8221)
  sectionNo (11)
  orderNo 11
  title `Rights of Ministers as respects Legislative Assembly.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8221&sectionno=11&orderno=11&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_11_content:
  string
  line `Every Minister shall have the right to`
  line `speak in, and otherwise to take part in the proceedings of, the Legislative Assembly and to speak in, and`
  line `otherwise to take part in the proceedings of, any committee of the Legislative Assembly of which he may`
  line `be named a member, but shall not by virtue of this section be entitled to vote.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (8222)
  sectionNo (12)
  orderNo 12
  title `Oath or affirmation by members.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8222&sectionno=12&orderno=12&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_12_content:
  string
  line `Every member of the Legislative Assembly shall, before`
  line `taking his seat, make and subscribe before the Lieutenant Governor, or some person appointed in that`
  line `behalf by him, an oath or affirmation according to the form set out for the purpose in the Schedule.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (8223)
  sectionNo (13)
  orderNo 13
  title `Voting in Assembly, power of Assembly to act notwithstanding vacancies and quorum.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8223&sectionno=13&orderno=13&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_13_content:
  string
  line `(1) Save as otherwise provided in this Act, all questions at any sitting of the Legislative`
  line `Assembly shall be determined by a majority of votes of the members present and voting other than the`
  line `Speaker or person acting as such.`
  line
  line `(2) The Speaker or person acting as such shall not vote in the first instance, but shall have and`
  line `exercise a casting vote in the case of an equality of votes.`
  line
  line `(3) The Legislative Assembly shall have power to act notwithstanding any vacancy in the`
  line `membership thereof, and any proceedings in the Legislative Assembly shall be valid notwithstanding that`
  line `it is discovered subsequently that some person who was not entitled so to do, sat or voted or otherwise`
  line `took part in the proceedings.`
  line
  line `(4) The quorum to constitute a meeting of the Legislative Assembly shall be one-third of the total`
  line `number of members of the Assembly.`
  line
  line `(5) If at any time during a meeting of the Legislative Assembly there is no quorum, it shall be the`
  line `duty of the Speaker, or person acting as such, either to adjourn the Assembly or to suspend the meeting`
  line `until there is a quorum.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (8224)
  sectionNo (14)
  orderNo 14
  title `Vacation of seats.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8224&sectionno=14&orderno=14&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_14_content:
  string
  line `(1) No person shall be a member both of Parliament and of the Legislative`
  line `Assembly and if a person is chosen a member both of Parliament and of such Assembly, then, at the`
  line `expiration of such period as is specified in or under the Representation of the People Act,`
  line `1951 (43 of 1951) and the rules made by the President under clause (2) of article 101 and clause (2) of`
  line `article 190, that persons seat in Parliament shall become vacant, unless he has previously resigned his`
  line `seat in the Legislative Assembly.`
  line
  line `(2) If a member of the Legislative Assembly—`
  line
  line `(a) becomes subject to any disqualification mentioned in section 15 or section 16 for`
  line `membership of the Assembly, or`
  line
  line `(b) resigns his seat by writing under his hand addressed to the Speaker and his resignation is`
  line `accepted by the Speaker,`
  line
  line `his seat shall thereupon become vacant:`
  line
  line `Provided that in the case of any resignation referred to in clause (b), if from the information received`
  line `or otherwise and after making such inquiry as he thinks fit, the Speaker is satisfied that such resignation is`
  line `not voluntary or genuine, he shall not accept such resignation.`
  line
  line `(3) If for a period of sixty days a member of the Legislative Assembly is without permission of the`
  line `Assembly absent from all meetings thereof, the Assembly may declare his seat vacant:`
  line
  line `Provided that in computing the said period of sixty days, no account shall be taken of any period`
  line `during which the Assembly is prorogued or is adjourned for more than four consecutive days`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (8225)
  sectionNo (15)
  orderNo 15
  title `Disqualifications for membership.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8225&sectionno=15&orderno=15&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_15_content:
  string
  line `(1) A person shall be disqualified for being chosen as, and`
  line `for being, a member of the Legislative Assembly—`
  line
  line `(a) if he holds any office of profit under the Government of India or the Government of any`
  line `State or the Government of any Union territory other than an office declared by law made by`
  line `Parliament or by the Legislature of any State or by the Legislative Assembly of the Capital or of any`
  line `other Union territory not to disqualify its holder; or`
  line
  line `(b) if he is for the time being disqualified for being chosen as, and for being, a member of either`
  line `House of Parliament under the provisions of sub-clause (b), sub-clause (c) or sub-clause (d) of`
  line `clause (1) of article 102 or of any law made in pursuance of that article.`
  line
  line `(2) For the purposes of this section, a person shall not be deemed to hold an office of profit under the`
  line `Government of India or the Government of any State or the Government of any Union territory by reason`
  line `only that he is a Minister either for the Union or for such State or Union territory`
  line
  line `(3) If any question arises as to whether a member of the Legislative Assembly has become`
  line `disqualified for being such a member under the provisions of sub-section (1), the question shall be`
  line `referred for the decision of the President and his decision shall be final.`
  line
  line `(4) Before giving any decision on any such question, the President shall obtain the opinion of the`
  line `Election Commission and shall act according to such opinion.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (8226)
  sectionNo (16)
  orderNo 16
  title `Disqualification on ground of defection.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8226&sectionno=16&orderno=16&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_16_content:
  string
  line `The provisions of the Tenth Schedule to the`
  line `Constitution shall, subject to the necessary modifications (including modifications for construing`
  line `references therein to the Legislative Assembly of a State, article 188, article 194 and article 212 as`
  line `references, respectively, to the Legislative Assembly, section 12, section 18 and section 37 of this Act),`
  line `apply to and in relation to the members of the Legislative Assembly as they apply to and in relation to the`
  line `members of the Legislative Assembly of a State, and accordingly:—`
  line
  line `(a) the said Tenth Schedule as so modified shall be deemed to form part of this Act; and`
  line
  line `(b) a person shall be disqualified for being a member of the Legislative Assembly if he is so`
  line `disqualified under the said Tenth Schedule as so modified.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (8227)
  sectionNo (17)
  orderNo 17
  title `Penalty for sitting and voting before making oath or affirmation or when not qualified or when disqualified.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8227&sectionno=17&orderno=17&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_17_content:
  string
  line `If a person sits or votes as a member of the Legislative Assembly before he has`
  line `complied with the requirements of section 12 or when he knows that he is not qualified or that he is`
  line `disqualified for membership thereof, he shall be liable in respect of each day on which he so sits or votes`
  line `to a penalty of five hundred rupees to be recovered as a debt due to the Union.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (8228)
  sectionNo (18)
  orderNo 18
  title `Powers, privileges, etc., of members.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8228&sectionno=18&orderno=18&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_18_content:
  string
  line `(1) Subject to the provisions of this Act and to the rules`
  line `and standing orders regulating the procedure of the Legislative Assembly, there shall be freedom of`
  line `speech in the Legislative Assembly.`
  line
  line `(2) No member of the Legislative Assembly shall be liable to any proceedings in any court in respect`
  line `of anything said or any vote given by him in the Assembly or any committee thereof and no person shall`
  line `be so liable in respect of the publication by or under the authority of such Assembly of any report, paper,`
  line `votes or proceedings.`
  line
  line `(3) In other respects, the powers, privileges and immunities of the Legislative Assembly and of the`
  line `members and the committees thereof shall be such as are for the time being enjoyed by the House of the`
  line `People and its members and committees.`
  line
  line `(4) The provisions of sub-sections (1), (2) and (3) shall apply in relation to persons who by virtue of`
  line `this Act have the right to speak in, and otherwise to take part in the proceedings of, the Legislative`
  line `Assembly or any committee thereof as they apply in relation to members of that Assembly.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (8229)
  sectionNo (19)
  orderNo 19
  title `Salaries and allowances of members.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8229&sectionno=19&orderno=19&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_19_content:
  string
  line `Members of the Legislative Assembly shall be entitled`
  line `to receive such salaries and allowances as may from time to time be determined by the Legislative`
  line `Assembly by law and until provision in that behalf is so made, such salaries and allowances as the`
  line `Lieutenant Governor may, with the approval of the President, by order determine.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (8230)
  sectionNo (20)
  orderNo 20
  title `Exemption of property of the Union form taxation.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8230&sectionno=20&orderno=20&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_20_content:
  string
  line `The property of the Union shall, save in`
  line `so far as Parliament may by law otherwise provide, be exempted from all taxes imposed by or under any`
  line `law made by the Legislative Assembly or by or under any other law in force in the Capital:`
  line
  line `Provided that nothing in this section shall, until Parliament by law otherwise provides, prevent any`
  line `authority within the Capital from levying any tax on any property of the Union to which such property`
  line `was immediately before the commencement of the Constitution liable or treated as liable, so long as that`
  line `tax continues to be levied in the Capital.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (8231)
  sectionNo (21)
  orderNo 21
  title `Restrictions on laws passed by Legislative Assembly with respect to certain matters.`
  content obj_root_law_sections_21_content
  footnotes `1. Ins. by Act 15 of 2021, s. 2 (w.e.f. 27-4-2021).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8231&sectionno=21&orderno=21&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_21_content:
  string
  line `passed by the Legislative Assembly with respect to any of the matters referred to in those articles as they`
  line `apply in relation to any law passed by the Legislature of a State with respect to those matters.`
  line
  line `(2) The provisions of article 304 shall, with the necessary modifications, apply in relation to any law`
  line `passed by the Legislative Assembly with respect to any of the matters referred to in that article as they`
  line `apply in relation to any law passed by the Legislature of a State with respect to those matters.`
  line
  line `^1[(3) The expression "Government" referred to in any law to be made by the Legislative Assembly`
  line `shall mean the Lieutenant Governor.]`
obj_root_law_sections_22:
  sectionId (8232)
  sectionNo (22)
  orderNo 22
  title `Special provisions as to financial Bills.`
  content obj_root_law_sections_22_content
  footnotes `1. Subs. by Act 38 of 2001, s. 6, for clause (e) (w.e.f.10-5-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8232&sectionno=22&orderno=22&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_22_content:
  string
  line `(1) A Bill or amendment shall not be introduced into,`
  line `or moved in, the Legislative Assembly except on the recommendation of the Lieutenant Governor, if such`
  line `Bill or amendment makes provision for any of the following matters, namely:—`
  line
  line `(a) the imposition, abolition, remission, alteration or regulation of any tax;`
  line
  line `(b) the amendment of the law with respect to any financial obligations undertaken or to be`
  line `undertaken by the Government of the Capital;`
  line
  line `(c) the appropriation of moneys out of the Consolidated Fund of the Capital;`
  line
  line `(d) the declaring of any expenditure to be expenditure charged on the Consolidated Fund of the`
  line `Capital or the increasing of the amount of any such expenditure;`
  line
  line ^1
  line `[e) the receipt of money on account of the Consolidated Fund of the Capital or the Public`
  line `Account of the Capital or the custody or issue of such money or the audit of the accounts of the`
  line `Capital:]`
  line
  line `Provided that no recommendation shall be required under this sub-section for the moving of an`
  line `amendment making provision for the reduction or abolition of any tax.`
  line
  line `(2) A Bill or amendment shall not be deemed to make provision for any of the matters aforesaid by`
  line `reason only that it provides for the imposition of fines or other pecuniary penalties, or for the demand or`
  line `payment of fees for licences or fees for services rendered, or by reason that it provides for the imposition,`
  line `abolition, remission, alteration or regulation of any tax by any local authority or body for local purposes.`
  line
  line `(3) A Bill which, if enacted and brought into operation, would involve expenditure from the`
  line `Consolidated Fund of the Capital shall not be passed by the Legislative Assembly unless the Lieutenant`
  line `Governor has recommended to that Assembly the consideration of the Bill.`
obj_root_law_sections_23:
  sectionId (8233)
  sectionNo (23)
  orderNo 23
  title `Procedure as to lapsing of Bills.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8233&sectionno=23&orderno=23&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_23_content:
  string
  line `(1) A Bill pending in the Legislative Assembly shall not`
  line `lapse by reason of the prorogation of the Assembly.`
  line
  line `(2) A Bill which is pending in the Legislative Assembly shall lapse on a dissolution of the`
  line Assembly.
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (8234)
  sectionNo (24)
  orderNo 24
  title `Assent to Bills.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8234&sectionno=24&orderno=24&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_24_content:
  string
  line `When a Bill has been passed by the Legislative Assembly, it shall be presented`
  line `to the Lieutenant Governor and the Lieutenant Governor shall declare either that he assents to the Bill or`
  line `that he withholds assent therefrom or that he reserves the Bill for the consideration of the President:`
  line
  line `Provided that the Lieutenant Governor may, as soon as possible after the presentation of the Bill to`
  line `him for assent, return the Bill if it is not a Money Bill together with a message requesting that the`
  line `Assembly will consider the Bill or any specified provisions thereof, and, in particular, will consider the`
  line `desirability of introducing any such amendments as he may recommend in his message and, when a Bill`
  line `is so returned, the Assembly will reconsider the Bill accordingly, and if the Bill is passed again with or`
  line `without amendment and presented to the Lieutenant Governor for assent, the Lieutenant Governor shall`
  line `declare either that he assents to the Bill or that he reserves the Bill for the consideration of the President:`
  line
  line `Provided further that the Lieutenant Governor shall not assent to, but shall reserve for the`
  line `consideration of the President, any Bill which,--`
  line
  line `(a) in the opinion of the Lieutenant Governor would, if it became law, so derogate from the`
  line `powers of the High Court as to endanger the position which that Court is, by the Constitution,`
  line `designed to fill; or`
  line
  line `(b) the President may, by order, direct to be reserved for his consideration; or`
  line
  line `(c) relates to matters referred to in sub-section (5) of section 7 or section 19 or section 34 or`
  line `sub-section (3) of ^1[section 43; or]`
  line
  line `^2[(d) incidentally covers any of the matters which falls outside the purview of the powers`
  line `conferred on the Legislative Assembly.]`
  line
  line `Explanation.--For the purposes of this section and section 25, a Bill shall be deemed to be a Money`
  line `Bill if it contains only provisions dealing with all or any of the matters specified in sub-section (1) of`
  line `section 22 or any matter incidental to any of those matters and, in either case, there is endorsed thereon`
  line `the certificate of the Speaker of the Legislative Assembly signed by him that it is a Money Bill.`
obj_root_law_sections_24_footnotes:
  string
  line `1. Subs. by Act 15 of 2021, s. 3, for "section 43" (w.e.f. 27-4-2021).`
  line
  line `2. Ins. by s. 3, ibid. (w.e.f. 27-4-2021).`
obj_root_law_sections_25:
  sectionId (8235)
  sectionNo (25)
  orderNo 25
  title `Bills reserved for consideration.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8235&sectionno=25&orderno=25&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_25_content:
  string
  line `When a Bill is reserved by the Lieutenant Governor for the`
  line `consideration of the President, the President shall declare either that he assents to the Bill or that he`
  line `withholds assent therefrom:`
  line
  line `Provided that where the Bill is not a Money Bill, the President may direct the Lieutenant Governor to`
  line `return the Bill to the Legislative Assembly together with such a message as is mentioned in the first`
  line `proviso to section 24 and, when a Bill is so returned, the Assembly shall reconsider it accordingly within`
  line `a period of six months from the date of receipt of such message and, if it is again passed by the Assembly`
  line `with or without amendment, it shall be presented again to the President for his consideration.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (8236)
  sectionNo (26)
  orderNo 26
  title `Requirements as to sanction, etc.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8236&sectionno=26&orderno=26&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_26_content:
  string
  line `No Act of the Legislative Assembly, and no provision in`
  line `any such Act, shall be invalid by reason only that some previous sanction or recommendation required by`
  line `this Act was not given, if assent to that Act was given by the Lieutenant Governor, or, on being reserved`
  line `by the Lieutenant Governor for the consideration of the President, by the President.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (8237)
  sectionNo (27)
  orderNo 27
  title `Annual financial statement.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8237&sectionno=27&orderno=27&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_27_content:
  string
  line `(1) The Lieutenant Governor shall in respect of every financial`
  line `year cause to be laid before the Legislative Assembly, with the previous sanction of the President, a`
  line `statement of the estimated receipts and expenditure of the Capital for that year, in this Part referred to as`
  line `the "annual financial statement".`
  line
  line `(2) The estimates of expenditure embodied in the annual financial statement shall show`
  line separately—
  line
  line `(a) the sums required to meet expenditure described by this Act as expenditure charged upon`
  line `the Consolidated Fund of the Capital; and`
  line
  line `(b) the sums required to meet other expenditure proposed to be made from the Consolidated`
  line `Fund of the Capital,`
  line
  line `and shall distinguish expenditure on revenue account from other expenditure.`
  line
  line `(3) Notwithstanding anything contained in any law for the time being in force, the following`
  line `expenditure shall be expenditure charged on the Consolidated Fund of the Capital:—`
  line
  line `(a) the emoluments and allowances of the Lieutenant Governor and other expenditure relating`
  line `to his office as determined by the President by general or special order;`
  line
  line `(b) the charges payable in respect of loans advanced to the Capital from the Consolidated Fund`
  line `of India including interest, sinking fund charges and redemption charges, and other expenditure`
  line `connected therewith;`
  line
  line `(c) the salaries and allowances of the Speaker and the Deputy Speaker of the Legislative`
  line Assembly;
  line
  line `(d) expenditure in respect of the salaries and allowances of Judges of the High Court of Delhi;`
  line
  line `(e) any sums required to satisfy any judgment, decree or award of any court or arbitral tribunal;`
  line
  line `(f) any other expenditure declared by the Constitution or by law made by Parliament or by the`
  line `Legislative Assembly to be so charged.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (8238)
  sectionNo (28)
  orderNo 28
  title `Procedure in Legislative Assembly with respect to estimates.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8238&sectionno=28&orderno=28&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_28_content:
  string
  line `(1) So much of the estimates as`
  line `relates to expenditure charged upon the Consolidated Fund of the Capital shall not be submitted to the`
  line `vote of the Legislative Assembly, but nothing in this sub-section shall be construed as preventing the`
  line `discussion in the Legislative Assembly of any of those estimates.`
  line
  line `(2) So, much of the said estimates as relates to other expenditure shall be submitted in the form of`
  line `demands for grants to the Legislative Assembly, and the Legislative Assembly shall have power to assent,`
  line `or to refuse to assent, to any demand, or to assent to any demand subject to a reduction of the amount`
  line `specified therein.`
  line
  line `(3) No demand for a grant shall be made except on the recommendation of the Lieutenant Governor.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (8239)
  sectionNo (29)
  orderNo 29
  title `Appropriation Bills.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8239&sectionno=29&orderno=29&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_29_content:
  string
  line `(1) As soon as may be after the grants under section 28 have been made`
  line `by the Legislative Assembly, there shall be introduced a Bill to provide for the appropriation out of the`
  line `Consolidated Fund of the Capital of all moneys required to meet—`
  line
  line `(a) the grants so made by the Assembly, and`
  line
  line `(b) the expenditure charged on the Consolidated Fund of the Capital but not exceeding in any`
  line `case the amount shown in the statement previously laid before the assembly.`
  line
  line `(2) No amendment shall be proposed to any such Bill in the Legislative Assembly which will have the`
  line `effect of varying the amount or altering the destination of any grant so made or of varying the amount of`
  line `any expenditure charged on the Consolidated Fund of the Capital and the decision of the person presiding`
  line `as to whether an amendment is inadmissible under this sub-section shall be final.`
  line
  line `(3) Subject to the other provisions of this Act, no money shall be withdrawn from the Consolidated`
  line `Fund of the Capital except under appropriation made by law passed in accordance with the provisions of`
  line `this section.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (8240)
  sectionNo (30)
  orderNo 30
  title `Supplementary, additional or excess grants.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8240&sectionno=30&orderno=30&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_30_content:
  string
  line `(1) The Lieutenant Governor shall,—`
  line
  line `(a) if the amount authorised by any law made in accordance with the provisions of section 29 to`
  line `be expended for a particular service for the current financial year is found to be insufficient for the`
  line `purposes of that year or when a need has arisen during the current financial year for supplementary or`
  line `additional expenditure upon some new service not contemplated in the annual financial statement for`
  line `that year, or`
  line
  line `(b) if any money has been spent on any service during a financial year in excess of the amount`
  line `granted for that service and for that year,`
  line
  line `cause to be laid before the Legislative Assembly, with the previous sanction of the President, another`
  line `statement showing the estimated amount of that expenditure or cause to be presented to the Legislative`
  line `Assembly with such previous sanction a demand for such excess, as the case may be.`
  line
  line `(2) The provisions of sections 27, 28 and 29 shall have effect in relation to any such statement and`
  line `expenditure or demand and also to any law to be made authorising the appropriation of moneys out of the`
  line `Consolidated Fund of the Capital to meet such expenditure or the grant in respect of such demand as they`
  line `have effect in relation to the annual financial statement and the expenditure mentioned therein or to a`
  line `demand for a grant and the law to be made for the authorisation of appropriation of moneys out of the`
  line `Consolidated Fund of the Capital to meet such expenditure or grant.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (8241)
  sectionNo (31)
  orderNo 31
  title `Votes on account.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8241&sectionno=31&orderno=31&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_31_content:
  string
  line `(1) Notwithstanding anything in the foregoing provisions of this Part, the`
  line `Legislative Assembly shall have power to make any grant in advance in respect of the estimated`
  line `expenditure for a part of any financial year pending the completion of the procedure prescribed in`
  line `section 28 for the voting of such grant and the passing of the law in accordance with the provisions of`
  line `section 29 in relation to that expenditure and the Legislative Assembly shall have power to authorise by`
  line `law the withdrawal of moneys from the Consolidated Fund of the Capital for the purposes for which the`
  line `said grant is made.`
  line
  line `(2) The provisions of sections 28 and 29 shall have effect in relation to the making of any grant under`
  line `sub-section (1) or to any law to be made under that sub-section as they have effect in relation to the`
  line `making of a grant with regard to any expenditure mentioned in the annual financial statement and the law`
  line `to be made for the authorisation of appropriation of moneys, out of the Consolidated Fund of the Capital`
  line `to meet such expenditure.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (8242)
  sectionNo (32)
  orderNo 32
  title `Authorisation of expenditure pending its sanction by Legislative Assembly.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8242&sectionno=32&orderno=32&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_32_content:
  string
  line `Notwithstanding anything in the foregoing provisions of this Part, the Lieutenant Governor may authorise`
  line `such expenditure from the Consolidated Fund of the Capital as he deems necessary for a period of not`
  line `more than six months beginning with the date of the constitution of the Consolidated Fund of the Capital,`
  line `pending the sanction of such expenditure by the Legislative Assembly.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (8243)
  sectionNo (33)
  orderNo 33
  title `Rules of procedure.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8243&sectionno=33&orderno=33&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_33_content:
  string
  line `The Legislative Assembly may make rules for regulating, subject to`
  line `the provisions of this Act, its procedure and the conduct of its business ^1[which shall not be inconsistent`
  line `with Rules of Procedure and Conduct of Business in House of the People]:`
  line
  line `^2]Provided that the Legislative Assembly shall not make any rule to enable itself or its committees to`
  line `consider the matters of day-to-day administration of the Capital or conduct inquiries in relation to the`
  line `administrative decisions, and any of the rule made in contravention of this proviso, before the`
  line `commencement of the Government of National Capital Territory of Delhi (Amendment) Act, 2021, shall`
  line `be void:`
  line
  line `Provided further that] the Lieutenant Governor shall, after consultation with the Speaker of the`
  line `Legislative Assembly and with the approval of the President, make rules--`
  line
  line `(a) for securing the timely completion of financial business;`
  line
  line `(b) for regulating the procedure of, and the conduct of business in, the Legislative Assembly in`
  line `relation to any financial matter or to any Bill for the appropriation of moneys out of the Consolidated`
  line `Fund of the Capital;`
  line
  line `(c) for prohibiting the discussion of, or the asking of questions on, any matter which affects the`
  line `discharge of the functions of the Lieutenant Governor in so far as he is required by or under this Act`
  line `or any law to act in his discretion.`
  line
  line `(2) Until rules are made under sub-section (1), the rules of procedure and standing orders with`
  line `respect to the Legislative Assembly of the State of Uttar Pradesh in force immediately before the`
  line `commencement of this Act shall have effect in relation to the Legislative Assembly subject to such`
  line `modifications and adaptations as may be made therein by the Lieutenant Governor.`
obj_root_law_sections_33_footnotes:
  string
  line `1. Ins. by Act 15 of 2021, s. 4 (w.e.f. 27-4-2021).`
  line
  line `2. Subs. by s. 4, ibid., for "Provided that" (w.e.f. 27-4-2021).`
obj_root_law_sections_34:
  sectionId (8244)
  sectionNo (34)
  orderNo 34
  title `Official language or languages of the Capital and language or languages to be used in Legislative Assembly.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8244&sectionno=34&orderno=34&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_34_content:
  string
  line `(1) The Legislative Assembly may by law adopt any one or more of the`
  line `languages in use in the Capital or Hindi as the official language or languages to be used for all or any of`
  line `the official purposes of the Capital:`
  line
  line `Provided that the President may by order direct—`
  line
  line `(i) that the official language of the Union shall be adopted for such of the official purposes of the`
  line `Capital as may be specified in the order;`
  line
  line `(ii) that any other language shall also be adopted throughout the Capital or such part thereof for`
  line `such of the official purposes of the Capital as may be specified in the order, if the President is`
  line `satisfied that a substantial proportion of the population of the Capital desires the use of that other`
  line `language for all or any of such purposes.`
  line
  line `(2) The business in the Legislative Assembly shall be transacted in the official language or`
  line `languages of the Capital or in Hindi or in English:`
  line
  line `Provided that the Speaker of the Legislative Assembly or person acting as such, as the case may be,`
  line `may permit any member who cannot adequately express himself in any of the languages aforesaid to`
  line `address the Assembly in his mother-tongue.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (8245)
  sectionNo (35)
  orderNo 35
  title `Language to be used for Bills, Acts, etc.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8245&sectionno=35&orderno=35&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_35_content:
  string
  line `Notwithstanding anything contained in section 34,`
  line `until Parliament by law otherwise provides, the authoritative texts—`
  line
  line `(a) of all Bills to be introduced or amendments thereto to be moved in the Legislative`
  line Assembly;
  line
  line `(b) of all Acts passed by the Legislative Assembly; and`
  line
  line `(c) of all orders, rules, regulations and bye-laws issued under any law made by the Legislative`
  line Assembly,
  line
  line `shall be in the English language:`
  line
  line `Provided that where the Legislative Assembly has prescribed any language other than the English`
  line `language for use in Bills introduced in, or Acts passed by, the Legislative Assembly or in any order, rule,`
  line `regulation or bye-law issued under any law made by the Legislative Assembly, a translation of the same`
  line `in the English language published under the authority, of the Lieutenant Governor in the Official Gazette`
  line `shall be deemed to be the authoritative text thereof in the English language.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (8246)
  sectionNo (36)
  orderNo 36
  title `Restriction on discussion in the Legislative Assembly.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8246&sectionno=36&orderno=36&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_36_content:
  string
  line `No discussion shall take place in the`
  line `Legislative Assembly with respect to the conduct of any Judge of the Supreme Court or of a High Court`
  line `in the discharge of his duties.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (8247)
  sectionNo (37)
  orderNo 37
  title `Courts not to inquire into proceedings of Legislative Assembly.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8247&sectionno=37&orderno=37&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_37_content:
  string
  line `(1) The validity of any`
  line `proceedings in the Legislative Assembly shall not be called in question on the ground of any alleged`
  line `irregularity of procedure.`
  line
  line `(2) No officer or member of the Legislative Assembly in whom powers are vested by or under this`
  line `Act for regulating procedure or the conduct of business, or for maintaining order in the Legislative`
  line `Assembly shall be subject to the jurisdiction of any court in respect of the exercise by him of those`
  line powers.
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (8248)
  sectionNo (38)
  orderNo 38
  title `Election Commission to delimit constituencies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8248&sectionno=38&orderno=38&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_38_content:
  string
  line `(1) The Election Commission shall, in the`
  line `manner herein provided, distribute the seats assigned to the Legislative Assembly under section 3 to`
  line `single-member territorial constituencies and delimit them having regard to the following provisions,`
  line `namely:—`
  line
  line `(a) all constituencies shall, as far as practicable, be delimited in such manner that the ratio`
  line `between the population of each of such constituencies and the total population of the Capital is the`
  line `same; and`
  line
  line `(b) constituencies in which seats are reserved for the Scheduled Castes shall, as far as`
  line `practicable, be located in areas where the proportion of their population to the total population is`
  line `comparatively large.`
  line
  line `(2) The Election Commission shall—`
  line
  line `(a) publish its proposals for the delimitation of constituencies in the Official Gazette and also in`
  line `such other manner as the Commission may consider fit, together with a notice inviting objections and`
  line `suggestions in relation to the proposals and specifying a date on or after which the proposals will be`
  line `further considered by it;`
  line
  line `(b) consider all objections and suggestions which may have been received by it before the date so`
  line specified;
  line
  line `(c) after considering all objections and suggestions which may have been received by it before`
  line `the date so specified, determine by one or more orders the delimitation of constituencies and cause`
  line `such order or orders to be published in the Official Gazette; and upon such publication, the order or`
  line `orders shall have the full force of law and shall not be called in question in any court.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (8249)
  sectionNo (39)
  orderNo 39
  title `Power of Election Commission to maintain delimitation orders up-to-date.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8249&sectionno=39&orderno=39&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_39_content:
  string
  line `The Election`
  line `Commission may, from time to time, by notification in the Official Gazette,—`
  line
  line `(a) correct any printing mistakes in any order made under section 38 or any error arising therein`
  line `from inadvertent slip or omission; and`
  line
  line `(b) where the boundaries or name of any territorial division mentioned in any such order are or is`
  line `altered, make such amendments as appear to it to be necessary or expedient for bringing such order`
  line up-to-date.
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (8250)
  sectionNo (40)
  orderNo 40
  title `Elections to the Legislative Assembly.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8250&sectionno=40&orderno=40&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_40_content:
  string
  line `(1) For the purpose of constituting the Legislative`
  line `Assembly, a general election will be held as soon as may be, after the delimitation of all the assembly`
  line `constituencies under section 38.`
  line
  line `(2) For the purposes of sub-section (1), the Lieutenant Governor shall, by one or more notifications`
  line `published in the Official Gazette, call upon all the said assembly constituencies to elect members in`
  line `accordance with the provisions of the Representation of the People Act, 1951 (43 of 1951), and of the`
  line `rules and orders made or issued thereunder as applicable under sub-section (3).`
  line
  line `(3) The Representation of the People Act, 1950 (43 of 1950), the Representation of the People`
  line `Act, 1951 (43 of 1951), the rules and orders made or issued under the said Acts and all other laws for the`
  line `time being in force relating to elections shall apply with necessary modifications (including modifications`
  line `for construing references therein to a State, State Government and Governor as including references to`
  line `the Capital, Government of the Capital and Lieutenant Governor, respectively) to, and in relation to, the`
  line `general election referred to in sub-section (1).`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (8251)
  sectionNo (41)
  orderNo 41
  title `Matters in which Lieutenant Governor to act in his sole discretion.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8251&sectionno=41&orderno=41&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_41_content:
  string
  line `41. Matters in which Lieutenant Governor to ^1[act in his sole discretion].--(1) The Lieutenant`
  line `Governor shall ^2[act in his sole discretion] in a matter--`
  line
  line `(i) which falls outside the purview of the powers conferred on the Legislative Assembly but in`
  line `respect of which powers or functions are entrusted or delegated to him by the President; or`
  line
  line `(ii) in which he is required by or under any law to act in his discretion or to exercise any judicial`
  line `or quasi-judicial functions ^3[; or].`
  line
  line `^3[(iii) in discharge of his functions under Part IV-A of this Act.]`
  line
  line `(2) If any question arises as to whether any matter is or is ^4[not a matter in respect of] which the`
  line `Lieutenant Governor is by or under any law required to act in his discretion, the decision of the`
  line `Lieutenant Governor thereon shall be final.`
  line
  line `(3) If any question arises as to whether any matter is or is not a matter as respects which the`
  line `Lieutenant Governor is required by any law to exercise any judicial or quasi-judicial functions, the`
  line `decision of the Lieutenant Governor thereon shall be final.`
obj_root_law_sections_41_footnotes:
  string
  line `1. Subs. by Act 19 of 2023, s. 3, in the marginal heading, for the words "act in his discretion" (w.e.f. 19-5-2023).`
  line
  line `2. Subs. by s. 3, ibid., for "act in his discretion" (w.e.f. 19-5-2023).`
  line
  line `3. Ins. by s. 3, ibid. (w.e.f. 19-5-2023).`
  line
  line `4. Subs. s. 3, ibid, for "not a matter as respects" (w.e.f. 19-5-2023).`
obj_root_law_sections_42:
  sectionId (8252)
  sectionNo (42)
  orderNo 42
  title `Advice by Ministers.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8252&sectionno=42&orderno=42&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_42_content:
  string
  line `The question whether any, and if so what, advice was tendered by`
  line `Ministers to the Lieutenant Governor shall not be inquired into in any court.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (8253)
  sectionNo (43)
  orderNo 43
  title `Other provisions as to Ministers.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8253&sectionno=43&orderno=43&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_43_content:
  string
  line `(1) Before a Minister enters upon his office, the Lieutenant`
  line `Governor shall administer to him the oaths of office and of secrecy according to the forms set out for the`
  line `purpose in the Schedule.`
  line
  line `(2) A Minister who, for any period of six consecutive months, is not a member of the Legislative`
  line `Assembly shall, at the expiration of that period, cease to be a Minister.`
  line
  line `(3) The salaries and allowances of Ministers shall be such as the Legislative Assembly may from time`
  line `to time by law determine and until the Legislative Assembly so determines, shall be determined by the`
  line `Lieutenant Governor with the approval of the President.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (8254)
  sectionNo (44)
  orderNo 44
  title `Conduct of business.`
  content obj_root_law_sections_44_content
  footnotes `1. Ins. by Act 15 of 2021, s. 5 (w.e.f. 27-4-2021).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8254&sectionno=44&orderno=44&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_44_content:
  string
  line `(1) The President shall make rules`
  line
  line `(a) for the allocation of business to the Ministers in so far as it is business with respect to which`
  line `the Lieutenant Governor is required to act on the aid and advice of his Council of Ministers; and`
  line
  line `(b) for the more convenient transaction of business with the Ministers, including the procedure to`
  line `be adopted in the case of a difference of opinion between the Lieutenant Governor and the Council of`
  line `Ministers or a Minister.`
  line
  line `(2) Save as otherwise provided in this Act, all executive action of the Lieutenant Governor whether`
  line `taken on the advice of his Ministers or otherwise shall be expressed to be taken in the name of the`
  line `Lieutenant Governor.`
  line
  line `^1]Provided that before taking any executive action in pursuance of the decision of the Council of`
  line `Ministers or a Minister, to exercise powers of Government, State Government, Appropriate Government,`
  line `Lieutenant Governor, Administrator or Chief Commissioner, as the case may be, under any law in force`
  line `in the Capital, the opinion of Lieutenant Governor in term of proviso to clause (4) of article 239AA of the`
  line `Constitution shall be obtained on all such matters as may be specified, by a general or special order, by`
  line `Lieutenant Governor.]`
  line
  line `(3) Orders and other instruments made and executed in the name of the Lieutenant Governor shall be`
  line `authenticated in such manner as may be specified in rules to be made by the Lieutenant Governor and the`
  line `validity of an order or instrument which is so authenticated shall not be called in question on the ground`
  line `that it is not an order or instrument made or executed by the Lieutenant Governor.`
obj_root_law_sections_45:
  sectionId (8255)
  sectionNo (45)
  orderNo 45
  title `Duties of Chief Minister as respects the furnishing of information to the Lieutenant Governor, etc.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8255&sectionno=45&orderno=45&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_content:
  string
  line `It shall be the duty of the Chief Minister—`
  line
  line `(a) to communicate to the Lieutenant Governor all decisions of the Council of Ministers relating`
  line `to the administration of the affairs of the Capital and proposals for legislation;`
  line
  line `(b) to furnish such information relating to the administration of the affairs of the Capital and`
  line `proposals for legislation as Lieutenant Governor may call for; and`
  line
  line `(c) if the Lieutenant Governor so requires, to submit for the consideration of the Council of`
  line `Ministers any matter on which a decision has been taken by a Minister but which has not been`
  line `considered by the Council.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_45_a:
  sectionId (76555)
  sectionNo 45A
  orderNo 46
  title Definitions.
  content obj_root_law_sections_45_a_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76555&sectionno=45A&orderno=46&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_a_content:
  string
  line `^1[45A. Definitions.--- In this Part, unless the context otherwise requires,--`
  line
  line `(a) "All India Services" means any service created under the All India Services Act, 1951 (61`
  line `of 1951), except the Indian Police Service;`
  line
  line `(b) "Authority" means the National Capital Civil Service Authority constituted under`
  line `sub-section (1) of section 45E;`
  line
  line `(c) "Chairperson" means the Chairperson of the Authority appointed under clause (a) of`
  line `sub-section (2) of section 45E;`
  line
  line `(d) "Chief Secretary" means the Chief Secretary of the Government of National Capital`
  line `Territory of Delhi appointed by the Central Government;`
  line
  line `(e) "Council" means the Council of Ministers referred to in clause (4) of article 239AA of the`
  line Constitution;
  line
  line `(f) "DANICS" means the Delhi, Andaman and Nicobar, Lakshadweep, Daman and Diu and`
  line `Dadra and Nagar Haveli (Civil) Services;`
  line
  line `(g) "Delhi Subordinate Services Selection Board" means the Delhi Subordinate Services`
  line `Selection Board constituted by the Government of National Capital Territory of Delhi through its`
  line `Resolution No. F-3(7)/93-S.III, dated 4th October, 1996 read with Resolution F.`
  line `3(24)/DSSSB/2008-S.III/1764, dated 12th May, 2008;`
  line
  line `(h) "Department" means a Department or office specified in the Schedule to the Business of`
  line `Delhi (Allocation) Rules, 1993;`
  line
  line `(i) "Group 'A' officers" means the officers serving in the affairs of the Government of`
  line `National Capital Territory of Delhi--`
  line
  line `(a) belonging to All India Services, except the officers of the Indian Police Service;`
  line
  line `(b) who are classified as Group 'A' officers, under rule 4 of the Central Civil Services`
  line `(Classification, Control and Appeal) Rules, 1965,`
  line `but shall not include the officers who are serving in connection with any subject matter, whether fully`
  line `or in part connected with Entries 1, 2 and 18 of List II of the Seventh Schedule to the Constitution,`
  line `and Entries 64, 65 and 66 of List II of the Seventh Schedule to the Constitution insofar as they relate`
  line `to Entries 1, 2 and 18 or any other subject matter which is connected therewith or incidental thereto;`
  line
  line `(j) "Group B' officials" means the Group 'B' officials, as such classified under rule 4 of the`
  line `Central Civil Services (Classification, Control and Appeal) Rules, 1965, but shall not include the`
  line `officials who are serving in connection with any subject matter, whether fully or in part connected`
  line `with Entries 1, 2 and 18 of List II of the Seventh Schedule to the Constitution, and Entries 64, 65`
  line `and 66 of List II of the Seventh Schedule to the Constitution insofar as they relate to Entries 1, 2`
  line `and 18 or any other subject matter which is connected therewith or incidental thereto;`
  line
  line `(k) "Group 'C' officials" means Group C officials as such classified under rule 4 of the`
  line `Central Civil Services (Classification, Control and Appeal) Rules, 1965, but shall not include the`
  line `officials who are serving in connection with any subject matter, whether fully or in part connected`
  line `with Entries 1, 2 and 18 of List II of the Seventh Schedule to the Constitution, and Entries 64, 65`
  line `and 66 of List II of the Seventh Schedule to the Constitution insofar as they relate to Entries 1, 2`
  line `and 18 or any other subject matter which is connected therewith or incidental thereto;`
  line
  line `(l) "National Capital Territory of Delhi" means the Union territory of Delhi as defined in`
  line `clause (1) of article 239AA of the Constitution;`
  line
  line `(m) "Member" means a member of the Authority and includes the Chairperson;`
  line
  line `(n) "Principal Home Secretary" means the Additional Chief Secretary or Principal Secretary`
  line `or Secretary, as the case may be, who is Head of the Home Department of the Government of`
  line `National Capital Territory of Delhi; and`
  line
  line `(o) "Secretary" means the Additional Chief Secretary or Principal Secretary or Secretary, as`
  line `the case may be, who is Head of the concerned Department of the Government of National`
  line `Capital Territory of Delhi.]`
obj_root_law_sections_45_b:
  sectionId (76556)
  sectionNo 45B
  orderNo 47
  title `Public Service Commissions for National Capital Territory of Delhi.`
  content obj_root_law_sections_45_b_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76556&sectionno=45B&orderno=47&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_b_content:
  string
  line `^1[45B. Public Service Commissions for National Capital Territory of Delhi.--(1) The Union Public`
  line `Service Commission shall be the Public Service Commission for Group 'A' and Group 'B' gazetted posts`
  line `in the National Capital Territory of Delhi.`
  line
  line `(2) The Delhi Subordinate Services Selection Board shall be the recruitment agency for appointment`
  line `to the Group 'B' non-gazetted posts and Group 'C' posts in the National Capital Territory of Delhi.]`
obj_root_law_sections_45_c:
  sectionId (76557)
  sectionNo 45C
  orderNo 48
  title `Power of Central Government to make rules under this Part.`
  content obj_root_law_sections_45_c_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76557&sectionno=45C&orderno=48&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_c_content:
  string
  line `^1[45C. Power of Central Government to make rules under this Part.-- The Central Government`
  line `may make rules to provide for any one or more of the following matters, in connection with the affairs of`
  line `the Government of National Capital Territory of Delhi under this Part, namely:--`
  line
  line `(a) the tenure of office, salaries and allowances, provident funds, pensions, gratuities, leave of`
  line `absence and other conditions of service of officers and other employees appointed or posted;`
  line
  line `(b) the powers, duties and functions of officers and other employees appointed or posted;`
  line
  line `(c) the qualifications of candidates for appointment to the posts and the manner of selection for`
  line `the appointments;`
  line
  line `(d) transfer or posting of the officers and other employees posted;`
  line
  line `(e) the procedure to be followed in imposing any penalty, suspension pending departmental`
  line `inquiries before the imposition of such penalty and the authority by whom such suspension or penalty`
  line `may be ordered; and the officer or authority to whom an appeal or revision shall lie;`
  line
  line `(f) any other matter which is incidental to or necessary for the purpose of regulating the`
  line `appointment and conditions of service of persons appointed to services and posts; and`
  line
  line `(g) any other matter for which, in the opinion of the Central Government, provisions are to be`
  line `made by rules.]`
obj_root_law_sections_45_d:
  sectionId (76558)
  sectionNo 45D
  orderNo 49
  title `Power to appoint authorities, boards, commissions or statutory bodies.`
  content obj_root_law_sections_45_d_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76558&sectionno=45D&orderno=49&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_d_content:
  string
  line `^1[45D. Power to appoint authorities, boards, commissions or statutory bodies.--Notwithstanding`
  line `anything contained in any other law for the time being in force, any authority, board, commission or any`
  line `statutory body, by whatever name it may be called, or any office bearer or member thereof, constituted or`
  line `appointed by or under--`
  line
  line `(a) any law made by the Parliament for the time being in force, applicable to the National Capital`
  line `Territory of Delhi, shall be constituted or appointed or nominated by the President; and`
  line
  line `(b) any law made by the Legislative Assembly of National Capital Territory of Delhi for the time`
  line `being in force, the Authority shall recommend a panel of suitable persons for constitution or`
  line `appointment or nomination by the Lieutenant Governor, in accordance with the provisions of section`
  line 45H.]
obj_root_law_sections_45_e:
  sectionId (76559)
  sectionNo 45E
  orderNo 50
  title `Constitution of National Capital Civil Service Authority.`
  content obj_root_law_sections_45_e_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76559&sectionno=45E&orderno=50&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_e_content:
  string
  line `^1i[45E. Constitution of National Capital Civil Service Authority.--(1) There shall be an Authority to`
  line `be known as the National Capital Civil Service Authority to exercise the powers conferred on, and`
  line `discharge the functions assigned to it under this Part.`
  line
  line `(2) The Authority, referred to in sub-section (1), shall consist of the following Members, namely:--`
  line
  line `(a) the Chief Minister of Government of National Capital Territory of Delhi, who shall be the`
  line `Chairperson of the Authority, ex officio;`
  line
  line `(b) the Chief Secretary of Government of National Capital Territory of Delhi, Member, ex officio;`
  line and
  line
  line `(c) the Principal Home Secretary, Government of National Capital Territory of Delhi, who shall`
  line `be the Member-Secretary to the Authority, ex officio.`
  line
  line `(3) All matters required to be decided by the Authority shall be decided by majority of votes of the`
  line `Members present and voting.`
  line
  line `(4) All recommendations of the Authority shall be authenticated by the Member-Secretary.`
  line
  line `(5) The head office of the Authority shall be at Delhi.]`
obj_root_law_sections_45_f:
  sectionId (76560)
  sectionNo 45F
  orderNo 51
  title `Meetings of Authority.`
  content obj_root_law_sections_45_f_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76560&sectionno=45F&orderno=51&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_f_content:
  string
  line `^1[45F. Meetings of Authority. -- (1) The Authority shall meet at such time and place as the MemberSecretary may decide with approval of the Chairperson of the Authority, as and when so required.`
  line
  line `(2) The Chairperson of the Authority shall preside over the meetings of the Authority.`
  line
  line `(3) The quorum for the meeting of the Authority shall be of two Members.]`
obj_root_law_sections_45_g:
  sectionId (76561)
  sectionNo 45G
  orderNo 52
  title `Appointment of officers and other staff of Authority.`
  content obj_root_law_sections_45_g_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76561&sectionno=45G&orderno=52&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_g_content:
  string
  line `^1[45G. Appointment of officers and other staff of Authority.--(1) The Central Government, in`
  line `consultation with the Authority, shall determine the nature and the categories of officers and other`
  line `employees required to assist the Authority in the discharge of its functions and provide the Authority with`
  line `such officers and employees, as it may deem fit.`
  line
  line `(2) The officers and other employees of the Authority shall discharge their duties and functions under`
  line `the general superintendence and control of the Authority.`
  line
  line `(3) The salaries, allowances and conditions of service of the officers and other employees appointed`
  line `under sub-section (1) shall be by rules made by the Central Government.]`
obj_root_law_sections_45_h:
  sectionId (76562)
  sectionNo 45H
  orderNo 53
  title `Powers and functions of Authority.`
  content obj_root_law_sections_45_h_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76562&sectionno=45H&orderno=53&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_h_content:
  string
  line `^1[45H. Powers and functions of Authority.-- (1) Notwithstanding anything contained in any other`
  line `law for the time being in force, the Authority shall have the responsibility to recommend the transfers and`
  line `postings of all Group ‘A’ officers and officers of DANICS serving in the affairs of the Government of`
  line `National Capital Territory of Delhi but not officers serving in connection with any subject matter, either`
  line `fully or in part, connected with Entries 1, 2 and 18 of List II of the Seventh Schedule to the Constitution;`
  line `and Entries 64, 65 and 66 of List II of the Seventh Schedule to the Constitution insofar as they relate to`
  line `Entries 1, 2 and 18 or any other subject matter which is connected therewith or incidental thereto, to the`
  line `Lieutenant Governor:`
  line
  line `Provided that Authority may, if it deems appropriate, by way of a recommendation, delegate the`
  line `responsibility to any other authority of the Government of National Capital Territory of Delhi.`
  line
  line `(2) The Authority shall have the responsibility to recommend for all matters connected with and`
  line `falling under the subject of vigilance and non-vigilance matters for the purpose of initiation of`
  line `disciplinary proceedings and recommend for grant of prosecution sanctions to the Competent Authorities`
  line `under the relevant Constitutional or statutory provisions against all the Group ‘A’ officers, including the`
  line `officers of the All India Services and DANICS, serving in the affairs of the Government of National`
  line `Capital Territory of Delhi but not officers serving in connection with any subject matter, either fully or in`
  line `part, connected with Entries 1, 2 and 18 of List II of the Seventh Schedule to the Constitution, and Entries`
  line `64, 65 and 66 of List II of the Seventh Schedule to the Constitution insofar as they relate to Entries 1, 2`
  line `and 18 or any other subject matter which is connected therewith or incidental thereto, to the Lieutenant`
  line `Governor:`
  line
  line `Provided that the Authority may, if it deems appropriate, by way of a recommendation, delegate the`
  line `responsibility in respect to such officers serving in the affairs of the Government of National Capital`
  line `Territory of Delhi to an officer of All India Services.`
  line
  line `(3) The Lieutenant Governor, after the receipt of such recommendation under sub-section (1) or`
  line `sub-section (2) of this section, may pass appropriate orders giving effect to the recommendation made:`
  line
  line `Provided that the Lieutenant Governor, before passing appropriate orders on such recommendation,`
  line `may ask for any relevant material regarding the Group ‘A’ officers, including the officers of the All India`
  line `Services and DANICS, serving in the affairs of the Government of National Capital Territory of Delhi:`
  line
  line `Provided further that in case the Lieutenant Governor differs with the recommendation made, whether`
  line `based upon the material so called for or otherwise, the Lieutenant Governor may, for reasons to be`
  line `recorded in writing, return the recommendation to the Authority for reconsideration by the Authority:`
  line
  line `Provided also that in case of difference of opinion, the decision of the Lieutenant Governor shall be`
  line final.
  line
  line `(4) Without prejudice to the generality of the provisions contained in sub-section (1), the Authority`
  line shall--
  line
  line `(a) make recommendations to the Lieutenant Governor for framing policies on--`
  line
  line `(i) stability of tenure of posting of officers and other employees;`
  line
  line `(ii) rotational transfers and postings from sensitive to non-sensitive posts and vice-versa;`
  line
  line `(iii) determining suitability of officer for posting as Head of the Department;`
  line
  line `(iv) transfers and postings of all officers and other employees serving in the affairs of the`
  line `Government of National Capital Territory of Delhi;`
  line
  line `(b) make policy insofar as it relates to--`
  line
  line `(i) the capacity building of the officers and other employees serving in the affairs of the`
  line `Government of National Capital Territory of Delhi;`
  line
  line `(ii) ensuring effectiveness in public services delivery in the Government of National Capital`
  line `Territory of Delhi;`
  line
  line `(iii) ensuring good governance and e-governance in public administration in the Government`
  line `of National Capital Territory of Delhi;`
  line
  line `(iv) ensuring greater transparency in the administration of the Government of National`
  line `Capital Territory of Delhi;`
  line
  line `(v) ensuring the presence of a citizen centric administration in the Government of National`
  line `Capital Territory of Delhi; and`
  line
  line `(vi) any other matter connected therewith or incidental thereto.]`
obj_root_law_sections_45_i:
  sectionId (76563)
  sectionNo 45I
  orderNo 54
  title `Disposal of matters by Minister.`
  content obj_root_law_sections_45_i_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76563&sectionno=45I&orderno=54&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_i_content:
  string
  line `^1[45-I. Disposal of matters by Minister. -- (1) The Minister in-charge may, by means of standing`
  line `orders, give such directions as he deems fit for the disposal of proposals or matters in his Department:`
  line
  line `Provided that no such standing order shall be issued in contravention of the provisions of the`
  line `Constitution or any other law for the time being in force including the provisions of this Act or the rules`
  line `made thereunder or the statutory powers conferred under any law upon the officials, and financial powers`
  line `delegated under the Delegation of the Financial Powers Rules, 1978.`
  line
  line `(2) The Minister, in consultation with the Secretary concerned, may issue standing orders, concerning`
  line `the matters or classes of matters which are to be brought to the personal notice of the Minister:`
  line
  line `Provided that no such standing order shall be issued in contravention of the provisions of the`
  line `Constitution or any other law for the time being in force including the provision of this Act or the rules`
  line `made thereunder or the statutory powers conferred under any law upon the officials, and financial powers`
  line `delegated under the Delegation of the Financial Powers Rules, 1978.`
  line
  line `(3) The copies of directions and standing orders shall be forwarded to the Lieutenant Governor and`
  line `the Chief Minister.`
  line
  line `(4) Notwithstanding anything contained in sub-sections (1) and (2), in addition to the proposals or`
  line `matters required to be placed before the Lieutenant Governor under any law for the time being in force,`
  line `the following proposals or matters shall be submitted to the Lieutenant Governor for his opinion through`
  line `the Chief Minister and the Chief Secretary, before issuing any orders thereon, namely:--`
  line
  line `(i) matters which affect or are likely to affect the peace and tranquility of the National Capital`
  line `Territory of Delhi;`
  line
  line `(ii) matters which affect or are likely to affect the interest of any particular community, the`
  line `Scheduled Castes, the Scheduled Tribes and the socially and educationally backward classes or any`
  line `other class of persons;`
  line
  line `(iii) matters which affect the relations of the Government of National Capital Territory of Delhi`
  line `with the Central Government, or any State Government, the Supreme Court of India or the High`
  line `Court of Delhi and such other authorities as may be determined;`
  line
  line `(iv) matters pertaining to the Secretariat of the Lieutenant Governor and personnel establishment`
  line `and other matters relating to his office;`
  line
  line `(v) matters on which the Lieutenant Governor is required to make an order under any law or`
  line `instrument in force in his sole discretion;`
  line
  line `(vi) matters specified under general or special order issued by the Lieutenant Governor under`
  line `proviso to sub-section (2) of section 44;`
  line
  line `(vii) petitions for mercy from persons under sentence for death and other important cases in`
  line `which it is proposed to recommend any revision of a judicial sentence;`
  line
  line `(viii) matters relating to summoning, prorogation and dissolution of the Legislative Assembly,`
  line `removal of disqualification of voters at elections to the Legislative Assembly, Local Self Government`
  line `Institutions and other matters connected therewith; and`
  line
  line `(ix) any other matter of administrative importance which the Chief Minister may consider`
  line necessary.]
obj_root_law_sections_45_j:
  sectionId (76564)
  sectionNo 45J
  orderNo 55
  title `Duties of Secretaries.`
  content obj_root_law_sections_45_j_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76564&sectionno=45J&orderno=55&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_j_content:
  string
  line `^1[45J. Duties of Secretaries.-- (1) The Secretary of the Department concerned shall be responsible for`
  line `preparing and authenticating every memorandum including the Cabinet Notes, for consideration of the`
  line `Council of Ministers and for obtaining approval of the Minister in-charge and the Chief Minister.`
  line
  line `(2) In case of proposals involving more than one Department, the views of all concerned Secretaries`
  line `and the Ministers of all Departments consulted on the proposal shall be clearly and separately reflected in`
  line `writing and signed by the Minister and the Secretary in the memorandum so as to ensure that in case of`
  line `disagreement, the Council of Ministers shall take a decision.`
  line
  line `(3) In case the Secretary to the Council of Ministers is of the opinion that the proposal considered and`
  line `decided by the Council of Ministers is not in accordance with the provisions of any law for the time being`
  line `in force or any rules of procedure made under section 44, it shall be the duty of the Secretary to the`
  line `Council of Ministers to bring it to the notice of the Lieutenant Governor for taking a decision thereon.`
  line
  line `(4) Any matter which is likely to bring the Government of National Capital Territory of Delhi into`
  line `controversy with the Central Government or with any State Government, the Supreme Court of India or`
  line `the High Court of Delhi and such other authorities as may be determined, the Secretary to the Department`
  line `concerned shall, as soon as possible, bring it to the notice of the Lieutenant Governor, the Chief Minister`
  line `and the Chief Secretary in writing.`
  line
  line `(5) The Chief Secretary and the Secretary to the Department concerned shall be responsible for`
  line `compliance with the provisions of this Act and the rules made under section 44, and when either of them`
  line `considers that there has been any material departure from the same, instead of giving effect to such`
  line `departure, he shall personally bring it to the notice of the Minister in-charge, the Chief Minister and the`
  line `Lieutenant Governor immediately in writing.`
obj_root_law_sections_45_k:
  sectionId (76565)
  sectionNo 45K
  orderNo 56
  title `Power to make rules.`
  content obj_root_law_sections_45_k_content
  footnotes `1. Ins. by Act 19 of 2023, s. 4 (w.e.f. 19-5-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=76565&sectionno=45K&orderno=56&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_45_k_content:
  string
  line `^1[45K. Power to make rules.--(1) The Central Government may, by notification published in the`
  line `Official Gazette, make rules for carrying out the provisions of this Part.`
  line
  line `(2) Every rule made by the Central Government under this Part shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament while it is in session for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rules or both Houses agree that the rules should not be made, the rules`
  line `shall thereafter have effect only in such modified form or be of no effect, as the case may be; so, however,`
  line `that any such modification or annulment shall be without prejudice to the validity of anything previously`
  line `done under that rule.]`
obj_root_law_sections_46:
  sectionId (8256)
  sectionNo (46)
  orderNo 57
  title `Consolidated Fund of the Capital.`
  content obj_root_law_sections_46_content
  footnotes `1. Subs. by Act 38 of 2001, s. 7, for "all loans" advanced to the Capital from the Consolidated Fund of India (w.e.f. 10-5-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8256&sectionno=46&orderno=57&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_46_content:
  string
  line `(1) As from such date as the Central Government may, by`
  line `notification in the Official Gazette, appoint in this behalf, all revenues received in the Capital by the`
  line `Government of India or the Lieutenant Governor in relation to any matter with respect to which the`
  line `Legislative Assembly has power to make laws, and all grants made and ^1`
  line `[all loans advanced to the Capital`
  line `from the Consolidated Fund of India and all loans raised by the Government of India or by the`
  line `Lieutenant Governor upon the security of the Consolidated Fund of the Capital] and all moneys received`
  line `by the Capital in repayment of loans shall form one Consolidated Fund to be entitled "the Consolidated`
  line `Fund of the National Capital Territory of Delhi" (referred to in this Act as the Consolidated Fund of the`
  line `Capital).`
  line
  line `(2) No moneys out of the Consolidated Fund of the Capital shall be appropriated except in`
  line `accordance with and for the purposes and in the manner provided in this Act.`
  line
  line `(3) The custody of the Consolidated Fund of the Capital, the payment of moneys into such Fund, the`
  line `withdrawal of moneys therefrom and all other matters connected with or ancillary to those matters shall`
  line `be regulated by rules made by the Lieutenant Governor with the approval of the President.`
obj_root_law_sections_46_a:
  sectionId (8257)
  sectionNo 46A
  orderNo 58
  title `Public Account of the Capital and moneys credited to it.`
  content obj_root_law_sections_46_a_content
  footnotes `1. Ins. by Act 38 of 2001, s. 8 (w.e.f. 10-5-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8257&sectionno=46A&orderno=58&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_46_a_content:
  string
  line ^1
  line `[46A. Public Account of the Capital and moneys credited to it.—(1) As from such date as the`
  line `Central Government may, by notification in the Official Gazette, appoint in this behalf, all other public`
  line `moneys received by or on behalf of the Lieutenant Governor shall be credited to a public account entitled`
  line `“the Public Account of the Capital”.`
  line `(2) The custody of public moneys, other than those credited to the Consolidated Fund of the Capital`
  line `or the Contingency Fund of the National Capital Territory of Delhi, received by or on behalf of the`
  line `Lieutenant Governor, their payment into the Public Account of the Capital and the withdrawal of moneys`
  line `from such account and all other matters connected with or ancillary to matters aforesaid shall be regulated`
  line `by rules made by the Lieutenant Governor with the approval of the President.]`
obj_root_law_sections_47:
  sectionId (8258)
  sectionNo (47)
  orderNo 59
  title `Contingency Fund of the Capital.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8258&sectionno=47&orderno=59&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_47_content:
  string
  line `(1) There shall be established a Contingency Fund in the`
  line `nature of an imprest to be entitled the Contingency Fund of the National Capital Territory of Delhi into`
  line `which shall be paid from and out of the Consolidated Fund of the Capital such sums as may, from time to`
  line `time, be determined by law made by the Legislative Assembly; and the said Fund shall be held by the`
  line `Lieutenant Governor to enable advances to be made by him out of such Fund.`
  line
  line `(2) No advances shall be made out of the Contingency Fund referred to in sub-section (1) except for`
  line `the purposes of meeting unforeseen expenditure pending authorisation of such expenditure by the`
  line `Legislative Assembly under appropriations made by law.`
  line
  line `(3) The Lieutenant Governor may make rules regulating all matters connected with or ancillary to the`
  line `custody of, the payment of moneys into, and the withdrawal of moneys from, the aforesaid Contingency`
  line Fund.
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_47_a:
  sectionId (8259)
  sectionNo 47A
  orderNo 60
  title `Borrowing upon the security of the Consolidated Fund of the Capital.`
  content obj_root_law_sections_47_a_content
  footnotes `7. Ins. by s. 9, ibid. (w.e.f. 10-5-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8259&sectionno=47A&orderno=60&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_47_a_content:
  string
  line ^1
  line `[47A. Borrowing upon the security of the Consolidated Fund of the Capital.—(1) The executive`
  line `power of the Union extends to borrowing upon the security of the Consolidated Fund of the Capital,`
  line `within such limits, if any, as may from time to time be fixed by Parliament by law and to the giving of`
  line `guarantee within such limits, if any, as may be so fixed:`
  line
  line `Provided that the powers exercisable by the Government of India under this sub-section shall also be`
  line `exercisable by the Lieutenant Governor subject to such conditions, if any, as the Government of India`
  line `may think fit to impose.`
  line
  line `(2) Any sums required for the purpose of invoking a guarantee shall be charged on the Consolidated`
  line `Fund of the Capital.`
obj_root_law_sections_47_b:
  sectionId (8260)
  sectionNo 47B
  orderNo 61
  title `Form of accounts of the Capital.`
  content obj_root_law_sections_47_b_content
  footnotes obj_root_law_sections_47_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8260&sectionno=47B&orderno=61&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_47_b_content:
  string
  line `The accounts of the Capital shall be kept in such form as`
  line `the Lieutenant Governor may, after obtaining advice of the Comptroller and Auditor-General of India and`
  line `with the approval of the President, prescribe by rules.]`
obj_root_law_sections_47_b_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (8261)
  sectionNo (48)
  orderNo 62
  title `Audit reports.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8261&sectionno=48&orderno=62&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_48_content:
  string
  line `The reports of the Comptroller and Auditor-General of India relating to the`
  line `accounts of the Capital for any period subsequent to the date referred to in sub-section (1) of section 46`
  line `shall be submitted to the Lieutenant Governor who shall cause them to be laid before the Legislative`
  line Assembly.
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (8262)
  sectionNo (49)
  orderNo 63
  title `Relation of Lieutenant Governor and his Ministers to President.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8262&sectionno=49&orderno=63&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_49_content:
  string
  line `Notwithstanding anything`
  line `in this Act, the Lieutenant Governor and his Council of Ministers shall be under the general control of,`
  line `and comply with such particular directions, if any, as may from time to time be given by, the President.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (8263)
  sectionNo (50)
  orderNo 64
  title `Period of order made under article 239AB and approval thereof by Parliament.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8263&sectionno=50&orderno=64&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_50_content:
  string
  line `(1) Every`
  line `order made by the President under article 239AB shall expire at the end of one year from the date of issue of the order and the provisions of clauses (2) and (3) of article 356 shall, so far as may be, apply to such`
  line `order as they apply to a Proclamation issued under clause (1) of article 356.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the President may extend the duration of`
  line `the aforesaid order for a further period not exceeding two years from the date of expiry of the order under`
  line `sub-section (1) subject to the condition that every extension of the said order for any period beyond the`
  line `expiration of one year shall be approved by resolutions of both Houses of Parliament.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (8264)
  sectionNo (51)
  orderNo 65
  title `Authorisation of expenditure by President.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8264&sectionno=51&orderno=65&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_51_content:
  string
  line `Where the Legislative Assembly is dissolved or`
  line `its functioning as such Assembly remains suspended, on account of an order made by the President under`
  line `article 239AB, it shall be competent for the President to authorise when the House of the People is not in`
  line `session expenditure from the Consolidated Fund of the Capital pending the sanction of such expenditure`
  line `by Parliament.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (8265)
  sectionNo (52)
  orderNo 66
  title `Contracts and suits.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8265&sectionno=52&orderno=66&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_52_content:
  string
  line `For the removal of doubts it is hereby declared that—`
  line
  line `(a) all contracts in connection with the administration of the Capital are contracts made in the`
  line `exercise of the executive power of the Union; and`
  line
  line `(b) all suits and proceedings in connection with the administration of the Capital shall be`
  line `instituted by or against the Government of India.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (8266)
  sectionNo (53)
  orderNo 67
  title `Power of President to remove difficulties.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8266&sectionno=53&orderno=67&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_53_content:
  string
  line `(1) If any difficulty arises in relation to the`
  line `transition from the provisions of any law repealed by this Act or in giving effect to the provisions of this`
  line `Act and in particular in relation to the constitution of the Legislative Assembly, the President may by`
  line `order do anything not inconsistent with the provisions of the Constitution or of this Act which appear to`
  line `him to be necessary or expedient for the purpose of removing the difficulty:`
  line
  line `Provided that no order under this sub-section shall be made after the expiry of the three years from`
  line `the date of constitution of the first Legislative Assembly.`
  line
  line `(2) Every order made under sub-section (1) shall be laid before each House of Parliament.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (8267)
  sectionNo (54)
  orderNo 68
  title `Laying of rules before Legislative Assembly.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8267&sectionno=54&orderno=68&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_54_content:
  string
  line `Every rule made by the Lieutenant Governor`
  line `under this Act shall be laid, as soon as it is made, before the Legislative Assembly.`
obj_root_law_sections_54_footnotes:
  string
  line
obj_root_law_sections_55:
  sectionId (8269)
  sectionNo (55)
  orderNo 69
  title Repealed.
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8269&sectionno=55&orderno=69&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_55_content:
  string
  line `[Amendment of section 27A of Act 43 of 1950.]—Rep. by the Repealing and Amending Act,`
  line `2001 (30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_55_footnotes:
  string
  line
obj_root_law_sections_56:
  sectionId (8270)
  sectionNo (56)
  orderNo 70
  title `Repeal of Act 19 of 1966`
  content `The Delhi Administration Act, 1966 is hereby repealed.`
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00014_199201_1517807323250&sectionId=8270&sectionno=56&orderno=70&orgactid=AC_CEN_5_24_00014_199201_1517807323250
obj_root_law_sections_56_footnotes:
  string
  line
