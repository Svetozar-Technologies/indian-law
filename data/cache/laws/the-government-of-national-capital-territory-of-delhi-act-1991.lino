obj_root_law_translations_hi:
  title `दिल्ली राष्ट्रीिय राजधानी राज्यतक्षेत्र शासन अधिनियम,1991`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1923/2/hH1992-01.pdf`
