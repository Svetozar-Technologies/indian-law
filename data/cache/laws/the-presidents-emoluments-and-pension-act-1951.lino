obj_root_law_sections_1:
  sectionId (6746)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes `1 Subs. by s. 3, ibid., for "Pension" (w.e.f. 16-12-1985).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6746&sectionno=1&orderno=1&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_1_content:
  string
  line `This Act may be called the President's`
  line ^1
  line `[Emoluments and Pension] Act, 1951.`
obj_root_law_sections_1_a:
  sectionId (6747)
  sectionNo 1A
  orderNo 2
  title `Emoluments of the President.`
  content obj_root_law_sections_1_a_content
  footnotes obj_root_law_sections_1_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6747&sectionno=1A&orderno=2&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_1_a_content:
  string
  line `^1[1A. Emoluments of the President.— There shall be paid to the President by way of`
  line emoluments
  line ^2
  line
  line [^3
  line `[five lakh rupees]] per mensem.`
obj_root_law_sections_1_a_footnotes:
  string
  line `1 Ins. by s. 4, ibid. (w.e.f. 16-12-1985).`
  line
  line `2 Subs. by Act 28 of 2008, s. 2, for "fifty thousand rupees" (w.e.f. 30-12-2008).`
  line
  line `3 Subs. by Act 13 of 2018, s. 137, for "one lakh fifty thousand rupees" (w.e.f. 1-1-2016)`
obj_root_law_sections_2:
  sectionId (6748)
  sectionNo (2)
  orderNo 3
  title `Pension to retiring Presidents.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6748&sectionno=2&orderno=3&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_2_content:
  string
  line `^1[(1)] There shall be paid to every person who ceases to hold`
  line `office as President, either by the expiration of his term of office or by resignation of his office, a pension`
  line `of ^2[at the rate of fifty per cent. of the emoluments of the President per month] for the remainder of his`
  line `life:`
  line
  line `^3* * * * *`
  line
  line `^4[Provided that if any person before assuming the office of President, has held the office of the`
  line `Vice-President, such person shall not be entitled to any pension and other benefits under the provisions of`
  line `the Vice-President's Pension Act, 1997 (30 of 1997).]`
  line
  line `^5 [(2) Subject to any rules that may be made in this behalf, every such person shall, for the remainder`
  line `of his life, be entitled--`
  line
  line `^6 [ ^7 [(a) to the use of a furnished residence (including its maintenance), without payment of rent,`
  line `two telephones (one for internet and broadband connectivity), one mobile phone with national`
  line `roaming facility and a motor-car, free of charge or to such car allowance as may be specified in the`
  line rules;
  line
  line `(b) to secretarial staff consisting of a Private Secretary, one Additional Private Secretary, one`
  line `Personal Assistant, two Peons and office expenses up to ^8 [one lakh rupees] per annum;]`
  line
  line `(c) to medical attendance and treatment free of charge;`
  line
  line `^9[(d) to travel anywhere in India, accompanied by one person, by the highest class by air, rail or`
  line steamer.]
  line
  line `Explanation.--For the purposes of this sub-section, "residence" shall have the meaning assigned to it`
  line `in the Salaries and Allowances of Ministers Act, 1952 (58 of 1952).]`
  line
  line `^10 [(2A) Subject to any rules that may be made in this behalf, the spouse of every such person shall, for`
  line `the remainder of life, be entitled to medical attendance and treatment, free of charge.]`
  line
  line `^11 [(3) Where any such person is re-elected to the office of President, such person or the spouse of`
  line `such person shall not be entitled to any benefit under this section for the period during which such person`
  line `again holds that office.]]`
obj_root_law_sections_2_footnotes:
  string
  line `1 Section 2 re-numbered as sub-section (1) thereof by Act 24 of 1962, s. 2 (w.e.f. 28-6-1962).`
  line
  line `2 Subs. by Act 28 of 2008 s. 3, for "of three lakh rupees per annum" (w.e.f. 1-1-2006).`
  line
  line `3. The proviso omitted by Act 24 of 1962, s. 2 (w.e.f. 28-6-1962).`
  line
  line `4 Ins. by Act 25 of 1998, s. 2 (w.e.f. 20-8-1998).`
  line
  line `5 Ins. by Act 24 of 1962, s. 2 (w.e.f. 28-6-1962).`
  line
  line `6 Subs. by Act 16 of 1990, s. 2, for clauses (a) and (b) (w.e.f. 29-6-1990).`
  line
  line `7 Subs. by Act 28 of 2008, s. 3, for clauses (a) and (b) (w.e.f. 30-12-2008).`
  line
  line `8 Subs. by Act 13 of 2018, s. 138, for "sixty thousand rupees" (w.e.f. 1-4-2018).`
  line
  line `9 Ins. by Act 71 of 1993, s. 2 (w.e.f. 26-12-1993).`
  line
  line `10 Ins. by Act 79 of 1976, s. 2 (w.e.f. 25-8-1976).`
  line
  line `11 Subs. by s. 2, ibid., for sub-section (3) (w.e.f. 25-8-1976).`
obj_root_law_sections_2_a:
  sectionId (6749)
  sectionNo 2A
  orderNo 4
  title `Family pension to spouse of President.`
  content obj_root_law_sections_2_a_content
  footnotes `1 Ins. by Act 14 of 2000, s. 2 (w.e.f. 11-8-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6749&sectionno=2A&orderno=4&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_2_a_content:
  string
  line `^1 [2A. Family pension to spouse of President.— The spouse of a person who dies—`
  line
  line `(a) while holding the office of President, or`
  line
  line `(b) after ceasing to hold office as President either by the expiration of his term of office or by`
  line `resignation of his office, shall be paid a family pension at the rate of fifty per cent. of pension as is`
  line `admissible to a retiring President, for the remainder of her life.]`
obj_root_law_sections_3:
  sectionId (6750)
  sectionNo (3)
  orderNo 5
  title `Free medical attendance and treatment to spouse of President dying in office.`
  content obj_root_law_sections_3_content
  footnotes `1 Subs. by Act 79 of 1976, s. 3, for section 3 (w.e.f. 24-5-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6750&sectionno=3&orderno=5&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_3_content:
  string
  line `^1 [3. Free medical attendance and treatment to spouse of President dying in office.— Subject to`
  line `any rules that may be made in this behalf, the spouse of a person who dies while holding the office of`
  line `President shall, for the remainder of life, be entitled to medical attendance and treatment, free of charge.]`
obj_root_law_sections_3_a:
  sectionId (6751)
  sectionNo 3A
  orderNo 6
  title `Free Accommodation to spouse of President.`
  content obj_root_law_sections_3_a_content
  footnotes obj_root_law_sections_3_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6751&sectionno=3A&orderno=6&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_3_a_content:
  string
  line `^1[3A. Free Accommodation to spouse of President.— Subject to any rules that may be made in this`
  line `behalf, the spouse of a person who dies—`
  line
  line `(a) while holding the office of President, or`
  line
  line ^2
  line `[(b) after ceasing to hold office as President, either on the expiration of his term of office or by`
  line `resignation of his office, shall be entitled,—`
  line
  line `(i) to the use of furnished residence (including its maintenance) without payment of licence fee;`
  line
  line `(ii) to secretarial staff consisting of a Private Secretary and a Peon and office expenses as per`
  line `actuals, the total expenditure on which shall not exceed ^3`
  line `[twenty thousand rupees] per annum;`
  line
  line `(iii) to a telephone and a motor-car, free of charge or such car allowance for the remainder of his`
  line `life, as may be specified in the rules;`
  line
  line `(iv) to travel anywhere in India, in a calendar year to twelve single journeys, by the highest`
  line `class, by air, rail or steamer, accompanied by a companion or a relative].]`
obj_root_law_sections_3_a_footnotes:
  string
  line `1 Ins. by Act 14 of 2000, s. 3 (w.e.f. 11-8-2000).`
  line
  line `2 Subs. by Act 28 of 2008, s. 4, for clause (b) (w.e.f. 30-12-2008)`
  line
  line `3 Subs. by Act 13 of 2018, s. 139, for "twelve thousand rupees" (w.e.f. 1-4-2018).`
obj_root_law_sections_4:
  sectionId (6752)
  sectionNo (4)
  orderNo 7
  title `Sums to be charged on the Consolidated Fund of India.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 24 of 1962, s. 3, for "pension" (w.e.f. 28-6-1962).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6752&sectionno=4&orderno=7&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_4_content:
  string
  line `Any ^1[sum] payable under this Act`
  line `shall be charged on the Consolidated Fund of India.`
obj_root_law_sections_5:
  sectionId (6753)
  sectionNo (5)
  orderNo 8
  title `Power to make rules.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6753&sectionno=5&orderno=8&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_5_content:
  string
  line `^1[5. Power to make rules.--`
  line `^2[(1)] The Central Government may, by notification in the Official`
  line `Gazette, make rules for carrying out the purposes of this Act.]`
  line
  line `^3[(2) Every rule made by the Central Government under this Act shall be laid, as soon as may be after`
  line `after it is made, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. Ins. by s. 4, ibid. (w.e.f. 28-6-1962).`
  line
  line `2 Section 5 re-numbered as sub-section (1) thereof by Act 79 of 1976, s. 4 (w.e.f. 25-8-1976).`
  line
  line `3 Ins. by s. 4, ibid. (w.e.f. 25-8-1976).`
obj_root_law_sections_6:
  sectionId (6754)
  sectionNo (6)
  orderNo 9
  title `Power to remove difficulties.`
  content obj_root_law_sections_6_content
  footnotes `1 Ins. by Act 28 of 2008, s. 5 (w.e.f. 30-12-2008).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_40_00009_195130_1517807327831&sectionId=6754&sectionno=6&orderno=9&orgactid=AC_CEN_5_40_00009_195130_1517807327831
obj_root_law_sections_6_content:
  string
  line `^1 [6. Power to remove difficulties.— (1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, as amended by the President's Emoluments and Pension (Amendment) Act, 2008 (28 of 2008),`
  line `the Central Government may, by order, do anything not inconsistent with such provisions for the purpose`
  line `of removing the difficulty:`
  line
  line `Provided that no such order shall be made after the expiration of two years from the date on which`
  line `this Act comes into force.`
  line
  line `(2) Every order made under sub-section (1) shall be laid before each House of Parliament.]`
