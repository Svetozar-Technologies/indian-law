obj_root_law_translations_hi_sections_11:
  kind page
  sectionId pdf-page-11
  sectionNo (11)
  orderNo 11
  title `Page 11`
  content obj_root_law_translations_hi_sections_11_content
  footnotes obj_root_law_translations_hi_sections_11_footnotes
  sourcePage 11
obj_root_law_translations_hi_sections_11_content:
  string
  line 11
  line `18. अनिनिर्म कय अन् र् अनिनि र् नमनतर्ों पर अध् र्य रो ही होिय — उस तयरीि से, निससे ियरय 6 के िण्ड (क) के अिीि कोई`
  line `वस्तु अ निसूनचत की ियती है, इस अनिनिर्म के उपबन्ि र् य उसके अिीि की गई कोई बयत र् य कयरावयई, इस अनिनिर्म से नभन् ि कक सी`
  line `अनिनिर्नमनत र् य ककसी अन् र् निि त में, िो इस अनिनिर्म से नभन्ि ककसी अनिनिर्नमनत के आियर पर प्र भयवी है, अन्त र् वाष्ट ककन्हीं`
  line `ऐसे उपबन्िों के होते हु ए भी (िो ऐसी वस्तु के निर्यात - पूवा क् वय निटी निर्ंत्रण और निरीक्षण से सम्ब नन्ि त है) उस वस्तु के सम्ब न् ि में प्र`
  line `भयवी होगी।`
  line ______
