  string
  line
obj_root_law_sections_2:
  sectionId (80036)
  sectionNo (2)
  orderNo 2
  title `Repeal of certain enactments.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202337_1703224004767&sectionId=80036&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00079_202337_1703224004767
obj_root_law_sections_2_content:
  string
  line `The enactments specified in the First Schedule and the Second`
  line `Schedule are hereby repealed.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (80037)
  sectionNo (3)
  orderNo 3
  title `Amendment of enactments.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202337_1703224004767&sectionId=80037&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00079_202337_1703224004767
obj_root_law_sections_3_content:
  string
  line `The enactment specified in the Third Schedule is hereby amended`
  line `to the extent and in the manner specified in the fourth column thereof.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (80038)
  sectionNo (4)
  orderNo 4
  title Savings.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202337_1703224004767&sectionId=80038&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00079_202337_1703224004767
obj_root_law_sections_4_content:
  string
  line `The repeal by this Act of any enactment shall not affect any other enactment in which`
  line `the repealed enactment has been applied, incorporated or referred to;`
  line
  line `and this Act shall not affect the validity, invalidity, effect or consequences of anything already done or`
  line `suffered, or any right, title, obligation or liability already acquired, accruedor incurred, or any remedy or`
  line `proceeding in respect thereof, or any release or discharge of or from any debt, penalty, obligation,`
  line `liability, claim or demand, or any indemnity already granted, or the proof of any past act or thing;`
  line
  line `nor shall this Act affect any principle or rule of law, or established jurisdiction, form or course of`
  line `pleading, practice or procedure, or existing usage, custom, privilege, restriction, exemption, office or`
  line `appointment, notwithstanding that the same respectively may have been in any manner affirmed or`
  line `recognised or derived by, in or from any enactment hereby repealed;`
  line
  line `nor shall the repeal by this Act of any enactment revive or restore any jurisdiction, office, custom,`
  line `liability, right, title, privilege, restriction, exemption, usage, practice, procedure or other matter or thing`
  line `not now existing or in force.`
obj_root_law_sections_4_footnotes:
  string
  line
