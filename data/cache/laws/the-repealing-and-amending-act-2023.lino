obj_root_law_sections_1:
  sectionId (80035)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Repealing and Amending Act, 2023.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202337_1703224004767&sectionId=80035&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00079_202337_1703224004767
