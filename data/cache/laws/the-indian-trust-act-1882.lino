  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00041_188202_1523272124725&sectionId=44319&sectionno=94&orderno=95&orgactid=AC_CEN_3_20_00041_188202_1523272124725
obj_root_law_sections_94_content:
  string
  line `[Constructive trusts in cases not expressly provided for].-- Rep. by the Benami`
  line `Transactions (Prohibition) Act, 1988 (45 of 1988), s. 7 (w.e.f. 19-5-1988).`
obj_root_law_sections_94_footnotes:
  string
  line
obj_root_law_sections_95:
  sectionId (44320)
  sectionNo (95)
  orderNo 96
  title `Obligor’s duties, liabilities and disabilities.`
  content obj_root_law_sections_95_content
  footnotes obj_root_law_sections_95_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00041_188202_1523272124725&sectionId=44320&sectionno=95&orderno=96&orgactid=AC_CEN_3_20_00041_188202_1523272124725
obj_root_law_sections_95_content:
  string
  line `The person holding property in accordance`
  line `with any of the preceding sections of this Chapter must, so far as may be, perform the same duties,`
  line `and is subject, so far as may be, to the same liabilities and disabilities, as if he were a trustee of the`
  line `property for the person for whose benefit he holds it:`
  line
  line `Provided that (a) where he rightfully cultivates the property or employs it in trade or business, he is`
  line `entitled to reasonable remuneration for his trouble, skill and loss of time in such cultivation or`
  line `employment; and (b) where he holds the property by virtue of a contract with the person for whose`
  line `benefit he holds it, or with any one through whom such person claims, he may, without the permission of`
  line `the Court, buy or become lessee or mortgagee of the property or any part thereof.`
obj_root_law_sections_95_footnotes:
  string
  line
obj_root_law_sections_96:
  sectionId (44321)
  sectionNo (96)
  orderNo 97
  title `Saving of rights of bona fide purchasers.`
  content obj_root_law_sections_96_content
  footnotes obj_root_law_sections_96_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00041_188202_1523272124725&sectionId=44321&sectionno=96&orderno=97&orgactid=AC_CEN_3_20_00041_188202_1523272124725
obj_root_law_sections_96_content:
  string
  line `Nothing contained in this Chapter shall impair the`
  line `rights of transferees in good faith for consideration, or create an obligation in evasion of any law for the`
  line `time being in force.`
obj_root_law_sections_96_footnotes:
  string
  line
