  (str slug) (str the-indian-maritime-university-act-2008)
  (str handle) (str 2093)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Indian Maritime University Act, 2008`)
  (str actNumber) (str 22)
  (str enactmentDate) (str 2008-11-11)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2093`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `भारतीय सामुद्रिक विश्‍वविद्यालय अधिनियम, 2008`)
  (str actYear) (str 2008)
  (str ministry) (str `Ministry of Shipping`)
  (str longTitle) (str `An Act to establish and incorporate a teaching and affiliating University at the national level to facilitate and promote maritime studies and research and to achieve excellence in areas of marine science and technology, marine environment and other related fields, and to provide for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 14-11-2008)
  (str notification) (str `14th November, 2008, vide Notification No. S.O. 2660(E), dated 14th November, 2008, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T00:07:45.241Z`)
