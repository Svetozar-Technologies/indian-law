obj_root_law_translations_hi:
  title `अरुणाचल प्रदेश राज्य अधिनियम, 1986`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1878/3/H1986-69.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T09:52:22.201Z`
