obj_root_law_sections_1:
  sectionId (39804)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the State of Arunachal Pradesh Act, 1986.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39804&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39805)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39805&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Administrator" means the Administrator appointed by the President under article 239;`
  line
  line `(b) "appointed day^1" means the day which the Central Government may, by notification in the`
  line `Official Gazette, appoint;`
  line
  line `(c) "article" means an article of the Constitution;`
  line
  line `(d) "Election Commission" means the Election Commission appointed by the President under`
  line `article 324;`
  line
  line `(e) "existing Union territory of Arunachal Pradesh" means the Union territory of Arunachal`
  line `Pradesh as existing immediately before the appointed day;`
  line
  line `(f) "law" includes any enactment, ordinance, regulation, order, bye-law, rule, scheme, notification`
  line `or other instrument having, immediately before the appointed day, the force of law in the whole or`
  line `any part of the existing Union territory of Arunachal Pradesh;`
  line
  line `(g) "sitting member", in relation to either House of Parliament or of the Legislative Assembly of`
  line `the existing Union territory of Arunachal Pradesh, means a person who, immediately before the`
  line `appointed day, is a member of that House or that Assembly;`
  line
  line `(h) "treasury" includes a sub-treasury.`
obj_root_law_sections_2_footnotes:
  string
  line `1. 20th February, 1987, vide notification No. S.O. 74(E), dated 11th February, 1987, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_3:
  sectionId (39806)
  sectionNo (3)
  orderNo 3
  title `Establishment of the State of Arunachal Pradesh.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39806&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_3_content:
  string
  line `On and from the appointed day, there shall`
  line `be established a new State, to be known as the State of Arunachal Pradesh comprising the territories`
  line `which immediately before that day were comprised in the existing Union territory of Arunachal Pradesh.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39807)
  sectionNo (4)
  orderNo 4
  title [Repealed].
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39807&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_4_content:
  string
  line `[Amendment of First Schedule to the Constitution.]—`
  line `Rep. by the Repealing and Amending Act, 2001 (30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39808)
  sectionNo (5)
  orderNo 5
  title [Repealed].
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39808&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_5_content:
  string
  line `[Amendment of Fourth Schedule to the Constitution.]—Rep. by the Repealing and Amending Act,`
  line `2001 (30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001).`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39809)
  sectionNo (6)
  orderNo 6
  title `Allocation of sitting member.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39809&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_6_content:
  string
  line `(1) On and from the appointed day, the sitting member of the`
  line `Council of States representing the existing Union territory of Arunachal Pradesh shall be deemed to have been duly elected under clause (4) of article 80 to fill the seat allotted to the State of Arunachal Pradesh in`
  line `that Council.`
  line
  line `(2) The term of office of such sitting member shall remain unaltered.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (39810)
  sectionNo (7)
  orderNo 7
  title [Repealed].
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39810&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_7_content:
  string
  line `[Amendment of section 27A of Act 43 of 1950.]—Rep. by the Repealing and Amending Act, 2001`
  line `(30 of 2001), s. 2 and the First Schedule (w.e.f. 3-9-2001)`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (39811)
  sectionNo (8)
  orderNo 8
  title `Allocation of seats in the existing House of the People.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39811&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_8_content:
  string
  line `(1) On and from the appointed day, the`
  line `allocation of seats to the State of Arunachal Pradesh in the House of the People shall be two; and the First`
  line `Schedule to the Representation of the People Act, 1950 (43 of 1950), shall be deemed to be amended`
  line accordingly.
  line
  line `(2) On and from the appointed day, the two parliamentary constituencies of the existing Union`
  line `territory of Arunachal Pradesh shall be deemed to be the parliamentary constituencies of the State of`
  line `Arunachal Pradesh and the Delimitation of Parliamentary and Assembly Constituencies Order, 1976, shall`
  line `be construed accordingly.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (39812)
  sectionNo (9)
  orderNo 9
  title `Provision as to sitting members.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39812&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_9_content:
  string
  line `The sitting members of the House of the People representing`
  line `the constituencies which, on the appointed day, by virtue of the provisions of section 8 become the`
  line `constituencies of the State of Arunachal Pradesh shall be deemed to have been elected under`
  line `sub-clause (a) of clause (1) of article 81 to the House of the People by those constituencies.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (39813)
  sectionNo (10)
  orderNo 10
  title `Provision as to Legislative Assembly.`
  content obj_root_law_sections_10_content
  footnotes `1. Subs. by Act 52 of 1988, s. 2, for section 10 (w.e.f. 27-9-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39813&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_10_content:
  string
  line `^1[10. Provision as to Legislative Assembly.—The total number of seats in the Legislative Assembly`
  line `of the State of Arunachal Pradesh, to be filled by persons chosen by direct election from assembly`
  line `constituencies shall be sixty, out of which fifty-nine seats shall be reserved for the Scheduled Tribes; and`
  line `the provisions of the Representation of the People Act, 1950 (43 of 1950) shall be deemed to be amended`
  line accordingly.]
obj_root_law_sections_11:
  sectionId (39814)
  sectionNo (11)
  orderNo 11
  title `Provisional Legislative Assembly.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39814&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_11_content:
  string
  line `(1) Notwithstanding anything contained in this Act`
  line `(including provisions relating to the strength of the Legislative Assembly of the State of Arunachal`
  line `Pradesh), on and from the appointed day and until the Legislative Assembly of that State has been duly`
  line `constituted and summoned to meet for the first session, there shall be a provisional Legislative Assembly`
  line `^1[which shall consist of—`
  line
  line `(a) members elected by the territorial constituencies of; and`
  line
  line `(b) members nominated to,`
  line
  line `the Legislative Assembly of the existing Union territory of Arunachal Pradesh.]`
  line
  line `(2) The period of five years referred to in clause (1) of article 172 shall, in the case of the provisional`
  line `Legislative Assembly referred to in sub-section (1), be deemed to have commenced on the day on which`
  line `the duration of the existing Legislative Assembly of the Union territory of Arunachal Pradesh commenced`
  line `under section 5 of the Government of Union Territories Act, 1963 (20 of 1963).`
  line
  line `^2[(3) For so long as the provisional Legislative Assembly constituted under this section is in`
  line existence,—
  line
  line `(a) it shall be deemed to be the Legislative Assembly of the State of Arunachal Pradesh duly`
  line `constituted under the Constitution and shall be competent to discharge all the functions of a`
  line `Legislative Assembly of a State under the Constitution; and`
  line
  line `(b) the members thereof, referred to in clause (a) of sub-section (1), shall be deemed to be the`
  line `members of the Legislative Assembly of the State of Arunachal Pradesh duly elected under the`
  line Constitution.]
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by Act 19 of 1987, s. 2, for certain words (w.e.f. 20-2-1987).`
  line
  line `2. Subs. by s. 2, ibid., for sub-section (3) (w.e.f. 20-2-1987).`
obj_root_law_sections_12:
  sectionId (39815)
  sectionNo (12)
  orderNo 12
  title `Speaker and Deputy Speaker.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39815&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_12_content:
  string
  line `The persons who immediately before the appointed day are the`
  line `Speaker and the Deputy Speaker of the Legislative Assembly of the Union territory of Arunachal Pradesh,`
  line `shall be the Speaker and the Deputy Speaker, respectively, of the provisional Legislative Assembly of the`
  line `State of Arunachal Pradesh on and from that day.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (39816)
  sectionNo (13)
  orderNo 13
  title `Rules of procedure.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39816&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_13_content:
  string
  line `The rules of procedure and conduct of business of the Legislative`
  line `Assembly of the existing Union territory of Arunachal Pradesh as in force immediately before the`
  line `appointed day shall, until rules are made under clause (1) of article 208, be the rules of procedure and`
  line `conduct of business of the provisional Legislative Assembly of the State of Arunachal Pradesh, subject to`
  line `such modifications and adaptations as may be made therein by the Speaker thereof.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (39817)
  sectionNo (14)
  orderNo 14
  title `Delimitation of constituencies.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39817&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_14_content:
  string
  line `(1) The Election Commission shall, in the manner herein`
  line `provided, distribute, whether before or after the appointed day, the seats assigned to the Legislative`
  line `Assembly of the State of Arunachal Pradesh under section 10 to single-member territorial constituencies`
  line `and delimit them having regard to the provisions of the Constitution and to the following provisions,`
  line `namely:—`
  line
  line `(a) all constituencies shall, as far as practicable, be geographically compact areas, and in`
  line `delimiting them regard shall be had to physical features, existing boundaries of administrative units,`
  line `facilities of communication and public convenience; and`
  line
  line `(b) constituencies in which seats are reserved for the Scheduled Tribes shall, as far as practicable,`
  line `be located in areas where the proportion of their population to the total population is the largest.`
  line
  line `(2) For the purpose of assisting it in the performance of its functions under sub-section (1), the`
  line `Election Commission shall associate with itself as associate members,—`
  line
  line `(a) the sitting members of the House of the People referred to in section 9; and`
  line
  line `(b) such six of the members of the Legislative Assembly of the existing Union territory of`
  line `Arunachal Pradesh or, as the case may be, the provisional Legislative Assembly referred to in`
  line `section 11 as the Speaker thereof may nominate:`
  line
  line `Provided that none of the associate members shall have a right to vote or to sign any decision of the`
  line `Election Commission.`
  line
  line `(3) If, owing to death or resignation, the office of an associate member falls vacant, it shall be filled,`
  line `if practicable, in accordance with the provisions of sub-section (2).`
  line
  line `(4) The Election Commission shall—`
  line
  line `(a) publish its proposals for the delimitation of constituencies together with the dissenting`
  line `proposals, if any, of any associate member who desires publication thereof, in the Official Gazette`
  line `and in such other manner as the Commission may consider fit, together with a notice inviting`
  line `objections and suggestions in relation to the proposals and specifying a date on or after which the`
  line `proposals will be further considered by it;`
  line
  line `(b) consider all objections and suggestions which may have been received by it before the date so`
  line specified;
  line
  line `(c) after considering all objections and suggestions which may have been received by it before the`
  line `date so specified, determine by one or more orders the delimitation of constituencies and cause such`
  line `order or orders to be published in the Official Gazette; and upon such publication, the order or orders`
  line `shall have the full force of law and shall not be called in question in any court.`
  line
  line `(5) As soon as may be after such publication, every such order relating to assembly constituencies`
  line `shall be laid before the Legislative Assembly of the existing Union territory of Arunachal Pradesh or, as`
  line `the case may be, the provisional Legislative Assembly referred to in section 11.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (39818)
  sectionNo (15)
  orderNo 15
  title `Power of Election Commission to maintain delimitation orders up-to-date.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00055_198669_1517807327057&sectionId=39818&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00055_198669_1517807327057
obj_root_law_sections_15_content:
  string
  line `(1) The Election`
  line `Commission may, from time to time, by notification in the Official Gazette,—`
  line
  line `(a) correct any printing mistake in any order made under section 14 or any error arising therein`
  line `from inadvertent slip or omission;`
  line
  line `(b) where the boundaries or name of any territorial division mentioned in any such order are or is`
  line `altered, make such amendments as appear to it to be necessary or expedient for bringing such order`
  line up-to-date.
  line
  line `(2) Every notification under this section relating to an assembly constituency shall be laid, as soon as`
  line `may be after it is issued, before the Legislative Assembly of the existing Union territory of Arunachal`
  line `Pradesh, the provisional Legislative Assembly referred to in section 11 or the Legislative Assembly of the`
  line `State of Arunachal Pradesh, as the case may be.`
obj_root_law_sections_15_footnotes:
  string
  line
