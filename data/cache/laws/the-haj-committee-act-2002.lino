obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `हज समिमि अमिमियि, 2002`
  line _________
  line `िाराओं का क्र ि`
  line _________
  line `िा राएं`
  line `अध्याय 1 प्र`
  line ारंमिक
  line `1. संमिप् ि िाि और प्र ारंि।`
  line `2. पररिाषाएं।`
  line `अध्याय 2`
  line `िारि की हज समिमि`
  line `3. िारि की हज समिमि का गठि और मिगिि।`
  line `4. समिमि की संरचिा।`
  line `5. सदस्यों की अमिसूचिा।`
  line `6. पदावमि।`
  line `7. अध्यि और उपाध्यि।`
  line `8. समिमि का पुिगगठि।`
  line `9. समिमि के किगव्य।`
  line `10. समिमि के अमिवेशि।`
  line `11. स् थायी समिमियों और उपसमिमियों की मियुमि।`
  line `12. समिमि के सदस्य के रू प िें िािमिदेमशि ककए जािे या बिे रहिे के मिए मिरहगिा।`
  line `13. अध्यि, उपाध्यि और सदस्यों का त् यागपत्र।`
  line `14. अध्यि, उपाध्यि और सदस्यों का हटाया जािा।`
  line `15. आकमस्िक ररमि का िरा जािा।`
  line `16. िुख्य कायगपािक अमिकारी और अन्य किगचारी।`
  line `अध्याय 3`
  line `राज्य हज समिमियां`
  line `17. राज्य हज समिमियों की स् थापिा और मिगिि।`
  line `18. राज्य समिमि की संरचिा।`
  line `19. सदस्यों की अमिसूचिा।`
  line `20. पदावमि।`
  line `21. अध्यि।`
  line `22. राज्य समिमि का पुिगगठि।`
  line `23. समिमि के सदस्य के रू प िें िािमिदेमशि ककए जािे या बिे रहिे के मिए मिरहगिा।`
  line `24. अध्यि और सदस्यों के त् यागपत्र।`
  line `25. अध्यि और सदस्यों को हटाया जािा।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line िाराएं
  line `26. आकमस्िक ररमि का िरा जािा।`
  line `27. राज्य समिमि के किगव्य।`
  line `28. राज्य समिमि के अमिवेशि।`
  line `29. राज्य समिमि का कायगपािक अमिकारी और अन्य किगचारी।`
  line `अध्याय 4`
  line `मवत्त, िेखा और संपरीिा`
  line `30. केन्रीय हज मिमि।`
  line `31. केन्रीय हज मिमि का उपयोजि।`
  line `32. राज्य हज मिमि।`
  line `33. राज्य हज मिमि का उपयोजि।`
  line `34. िेखा और संपरीिा।`
  line `अध्याय 5 प्र`
  line कीर्ग
  line `35. समिमि की िीथगयात्री पासों को जारी करिे और फीसों को उद्गृहीि करिे की शमि यां।`
  line `36. समिमि का अमिक्रिर्।`
  line `37. समिमि या राज्य समिमि की सदस्यिा का िाि का पद ि होिा।`
  line `38. समिमि की कायगवामहयों का रर मि यों, आकद के कारर् अमवमििान्य ि होिा।`
  line `39. समिमि के अमिकाररयों और किगचाररयों का िोक सेवक होिा।`
  line `40. संरिर्।`
  line `41. अिुसूची का संशोिि करिे की शमि।`
  line `42. मशकायिों को दूर करिा।`
  line `43. संपमत्तयों और अन्य अमिकारों, आकद का समिमियों िें मिमहि होिा।`
  line `44. मियि बिािे की शमि।`
  line `45. उपमवमि बिािे की शमि।`
  line `46. प्रत् यायोजि की शमि यां।`
  line `47. मियि बिािे की राज्य सरकार की शमि।`
  line `48. इस अमिमियि के प्र ारंि से पूवग मवद्यिाि समिमि के किगचाररयों के मिए उपबंि।`
  line `49. सद्भावपूवगक की गई कारगवाई के मिए संरिर्।`
  line `50. करठ िाइयों को दूर करिे की शमि।`
  line `51. मिदेश देिे की शमि।`
  line `52. [ मिरसि ]।`
  line अिुसूची।
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line `हज समिमि अमिमियि, 2002`
  line `( 2002 का अमिमियि संख्यांक 35 )`
  line `[11 जूि, 2002 ]`
  line `हज के मिए िुसििाि िीथगयामत्रयों के मिए व्य वस्था करिे और`
  line `उससे संबंमिि मवषयों के मिए एक िारि की हज समिमि`
  line `औ र राज्य हज समिमियां स् थामपि`
  line `करिे के मिए`
  line अमिमियि
  line `िारि गर्राज्य के मिरपिवें वषग िें संसद् द्व ारा मिम्ि मिमखि रू प िें यह अमिमियमि ि हो: —`
  line `अध्याय 1 प्र`
  line ारंमिक
  line `1. संमि प् ि िाि और प्र ारंि — ( 1 ) इस अमिमियि का संमि प् ि िाि हज समिमि अमिमियि, 2002 है।`
  line `( 2 ) यह उस िा रीख या िारीखों को प्र वृत्त होगा, जो केन्रीय सरकार, अमिसूचिा द्व ारा मियि करे और इस अमिमियि के`
  line `मि न् ि - मि न् ि उपबंिों के मिए और मि न् ि - मि न् ि राज्यों के मिए मि न् ि - मि न् ि िारीखें मियि की जा सकेंगी।`
  line `2. पररिाषाएं — इस अमिमियि िें जब िक कक संदिग से अन्यथा अपे मिि ि हों, —`
  line `(क) “ उपमवमियों ” से िारा 45 के अिीि बिाई गई उपमवमियां अमिप्रेि हैं;`
  line `(ख) “ िुख्य कायगपािक अमिकारी या कायगपािक अमिकारी ” से, यथामस्थमि, िारा 16 की उपिारा ( 1 ) या`
  line `िारा 29 की उपिारा ( 1 ) के अिीि मियु ि समिमि का िुख्य कायगपािक अमिकारी या राज्य समिमि का कायगपािक`
  line `अमिकारी अमिप्रेि है;`
  line `(ग) “ समिमि ” से िारा 3 के अिीि गरठि िारि की हज समिमि अमिप्रेि है;`
  line `(घ) “ सदस्य ” से, यथामस्थमि, िारा 4 के अिीि िािमिदेमशि िारि की हज समिमि का कोई सदस्य या िारा 18 के`
  line `अिीि िािमिदेमशि ककसी राज्य हज समिमि का को ई सदस्य अमिप्रेि है और इसके अंिगगि अध्यि िथा कोई उपाध्यि िी है;`
  line `( ङ ) “ अमिसूचिा ” से, यथामस्थमि, िारि के राजपत्र या ककसी राज्य के राजपत्र िें प्र कामशि कोई अमिसूचिा`
  line `अमिप्रेि है;`
  line `(च) “ िीथग यात्री ” से, हज के मिए जािे वािा या वहां से िौटिे वािा कोई िुसििा ि अमिप्रेि है;`
  line `(छ) “ मवमहि ” से, यथामस्थमि, िारा 44 के अिीि केन्रीय सरकार द्व ारा या िारा 47 के अिीि राज्य सरकार द्व ारा`
  line `बिाए गए मियिों द्व ारा मवमहि अमिप्रेि है;`
  line `(ज) “ राज्य समिमि ” से िारा 18 के अिीि गरठि कोई राज्य हज समिमि अमिप्रेि है और इसके अंिगगि संयु ि`
  line `राज्य समिमि िी है;`
  line `(झ) ककसी संघ राज्यिेत्र के संबंि िें, “ राज्य सरकार ” से संमविाि के अिुच्छेद 239 के अिीि रा ष्‍ट र पमि द्व ारा`
  line `मियु ि उस संघ राज्यिेत्र का प्र शासक अमिप्रेि है।`
  line `अध्याय 2`
  line `िारि की हज समिमि`
  line `3. िारि की हज समिमि का गठि और मिगिि — ( 1 ) उस िारीख से, जो केंरीय सरकार इस मिमित्त, राजपत्र िें अमिसूचिा द्व`
  line `ारा मियि करे, एक समिमि गरठि की जाएगी मजसे िारि की हज समिमि कहा जाएगा।`
  line `( 2 ) समिमि पूवो ि िाि की एक मिगमिि मिकाय होगी मजसका शा श् व ि उत्तरामिकार और सािान्य िुरा और मजसे इस`
  line `अमिमियि के उपबंिों के अिीि रहिे हु ए जंगि और स् थावर दोिों ही प्र कार की संपमत्त का अजगि, िारर् और व्य यि करिे, ककसी पूिग न्`
  line `यास या मवन्यास का सृजि करिे और संमवदा करिे की श मि होगी िथा उ ि िाि से वह वाद िाएगी और उस पर वाद`
  line `िाया जाएगा।`
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
  orderNo 4
  title `Page 4`
  content obj_root_law_translations_hi_sections_4_content
  footnotes obj_root_law_translations_hi_sections_4_footnotes
  sourcePage 4
obj_root_law_translations_hi_sections_4_content:
  string
  line 2
  line `( 3 ) समिमि का िुख्यािय िुं बई िें होगा और जब किी समिमि कायगकरर् की दृमि से आवश्यक सिझे, केंरीय सरकार के`
  line `परािशग से अमिरर ि प्र ादेमशक कायागिय खोिे जा सकेंगे।`
  line `4. समिमि की संरचिा — समिमि मिम्ि मिमखि सदस्यों से मििकर बिेगी, अथागि्: —`
  line `( i ) संसद् के िीि सदस्यों मजििें से दो िोक सिा के अध्यि द्व ारा उसके िुसििाि सदस्यों िें से और एक रा ज् य`
  line `सिा के सिापमि द्व ारा उसके िुसििाि सदस्यों िें से िािमिदेमशि ककए जाएंगे:`
  line `परंिु संसद् का कोई सदस्य उस सदि का सदस्य िहीं रहिे पर समिमि का सदस्य िहीं रह जाएगा और केंरीय`
  line `सरकार के अिुरोि पर, यथामस्थ मि, िोक सिा के अध्यि या राज्य सिा के सिापमि द्व ारा िया िािमिदेश ि ककया जाएगा;`
  line `( ii ) समिमि के िौ िुसििाि सदस्य, ऐसी रीमि िें जो मवमहि की जाए, मिवागमचि ककए जाएंगे मजििें से िीि उ ि`
  line `राज्यों से होंगे मजन्होंिे मपछिे िीि वषग के दौराि सवागमिक संख्या िें िीथग यात्री िेजे हैं और एक - एक सदस्य अिु सू ची िें`
  line `मवमिर्दग ष्‍ट ट अंचिों से होगा:`
  line `परंिु एक से अमिक सदस्य अिुसूची िें यथामवमिर्दग ष्‍ट ट अंचि िें आिे वािे राज्य से मिवागमचि िहीं ककया जाएगा;`
  line `( iii ) मवदेश, गृह, मवत्त और िागर मविािि िंत्राियों का प्र मिमिमित्व करिे के मिए उस सरकार द्व ारा िािमि देमश ि`
  line `िारि सरकार के संयु ि समचव से अन्यूि की पं मि के चार व्य मि, पदेि सदस्य होंगे;`
  line `( iv ) केंरीय सरकार द्व ारा मिम्ि मिमखि व्य मि यों के प्र वगों िें से साि िुसििाि सदस्य िािमिर्दग ष्‍ट ट ककए`
  line `जाएंगे, अथागि्: —`
  line `(क) िोक प्र शासि, मवत्त, मशिा, संस्कृमि या सािामजक कायग िें मवशेषज्ञिा रखिे वािे दो सदस्य, मजििें`
  line `से एक मशया िुसििाि होगा;`
  line `(ख) दो िमहिा सदस्य, मजििें से एक मशया िुसििाि होगी;`
  line `(ग) िीि सदस्य ऐसे होंगे जो िुमस्िि ििग मवद्या और मवमि का मवशेष ज्ञ ाि रखिे हों, मजििें से एक`
  line `मशया िुसििाि होगा।`
  line `5. सदस्यों की अमिसूचिा — िारा 4 के अिीि समिमि के सदस्यों के िािमिदेशि के यथाशीघ्र प श् चा ि्, केंरीय सरकार सिी`
  line `ऐसे सदस्यों के िाि राजपत्र िें प्र कामशि करेगी।`
  line `6. पदावमि — ( 1 ) समिमि के सदस्यों की पदावमि (पदेि सदस्यों और आकमस्िक रर मि यों को िरिे वािे सदस्यों से मि न् ि )`
  line `िारा 5 के अिीि सदस्यों की सूची के प्र काशि के अगिे कदि से प्र ारंि होकर िीि वषग की होगी:`
  line `परंिु समिमि के सदस्यों की पदावमि केंरीय सरकार द्व ारा राजपत्र िें अमिसूचिा द्व ारा एक सिय िें छह िास से अ िमिक की`
  line `अवमि के मिए बढाई जा सकेगी ककंिु ककसी िी दशा िें कुि एक वषग से अमिक के मिए िहीं बढाई जाएगी।`
  line `( 2 ) अध्यि, उपाध्यि और सदस्यों को संदेय ित्ते और अन्य मिबंिि और शिें ऐसी होंगी जो मवमहि की जाएं।`
  line `7. अध्यि और उपाध्यि — ( 1 ) िारा 5 के अिीि समिमि के सदस्यों के िािों के प्र काशि के प श् चा ि् केंरीय सरकार, समिमि`
  line `का पहिा अमिवेशि ऐसे प्र काशि के पैंिािीस कदि के िीिर संयोमजि करेगी मजसिें समिमि इसके सदस्यों िें से एक अध्यि और दो`
  line `उपाध्यि मिवागमचि करेगी:`
  line `परंिु कोई िंत्री समिमि का अध्यि िहीं होगा और पदेि सदस्य अध्यि या उपाध्य ि के मिवागचि िें िाग िहीं िें गे।`
  line `( 2 ) यकद समिमि अध्यि या उपाध्यि का मिवागचि करिे िें असफि रहिी है िो, केंरीय सरकार, समिमि के ककसी सद स् य को`
  line `उसका, यथामस्थमि, अध्यि या उपाध्यि मियु ि कर सकेगी।`
  line `( 3 ) अध्यि ऐसी श मि यों का प्र योग करेगा और ऐसे किगव्यों का मिवगहि करेगा, जो मवमहि ककए जाएं।`
  line `( 4 ) उपाध्यि ऐसी श मि यों का प्र योग करेंगे और ऐसे किगव्यों का मिवगहि करेंगे जो समिमि द्व ारा इस मिमि त्त बिाई ग ई`
  line `उपमवमियों द्व ारा अविाररि ककए जाएं:`
  line `परंिु ऐसी उपमवमियों के बिाए जािे िक, उपाध्यि ऐसी श मि यों का प्र योग करेंगे, और ऐसे किगव्यों का मिवगहि करेंगे जो`
  line `इस संबंि िें अध्यि द्व ारा, ककसी आदेश द्व ारा, अविा ररि ककए जाएं।`
  line `( 5 ) केंरीय सरकार द्व ारा अध्यि और उपाध्यिों का मिवागचि राजपत्र िें अमिसूमचि ककया जाएगा।`
  line `( 6 ) यथामस्थमि, अध्यि और उपाध्य िों की पदावमि समिमि की कायागवमि की सहमवस्िारी होगी और कोई िी व्य मि,`
  line `यथामस्थमि, अध्यि या उपाध्यि का पद िगािार दो पदावमियों से अमिक के मिए िाररि िहीं करेगा।`
  line `( 7 ) अध्यि या उपाध्यि के पद की कोई आकमस्िक रर मि, यथामस्थमि, उपिारा ( 1 ) या उपिारा ( 2 ) के अिुसार शे ष अवमि`
  line `के मिए िरी जाएगी।`
obj_root_law_translations_hi_sections_4_footnotes:
  string
  line
obj_root_law_translations_hi_sections_5:
  kind page
  sectionId pdf-page-5
  sectionNo (5)
  orderNo 5
  title `Page 5`
  content obj_root_law_translations_hi_sections_5_content
  footnotes obj_root_law_translations_hi_sections_5_footnotes
  sourcePage 5
obj_root_law_translations_hi_sections_5_content:
  string
  line 3
  line `8. समिमि का पुिगगठि — ( 1 ) केंरीय सरकार, यथामस्थमि, समिमि की अवमि या बढाई गई अवमि की सिा मप्ि से कि से कि`
  line `चार िास पूवग िई समिमि के पुिगगठि के मिए सिी आवश्यक कारगवाइयां करेगी या करवाएगी।`
  line `( 2 ) कोई पदावरोही सदस्य समि मि िें दो पदावमियों से अिमिक के मिए पुिः िािमिदेशि के मिए पात्र होगा:`
  line `परंिु सदस्यों िें से पचास प्र मिशि से अिमिक दूसरी पदावमि के मिए ऐसी रीमि िें पुिःिािमिदेमशि ककए जा सकेंगे, जो`
  line `मवमहि की जाए।`
  line `9. समिमि के किगव्य — ( 1 ) समिमि के मिम्ि मिमखि किगव्य होंगे —`
  line `( i ) िीथगयामत्रयों के मिए उपयोगी जािकारी संग्रह करिा िथा प्र सार करिा और िीथगयामत्रयों के मिए अमिमव न् यास`
  line `और प्र मशिर् कायगक्रिों का आयोजि करिा;`
  line `( ii ) िीथगयात्रा के मिए जािे सिय या उससे िौटिे सिय िारि िें पत्ति केंरों पर ठहरिे के दौराि उिको स िी`
  line `िाििों िें मजिके अंिगगि टीका िगािा, इिोकुिेशि, मचककत्सीय जांच िथा िीथगयात्री पास जारी करिे िथा मवदेशी िु रा से`
  line `संबंमिि िाििे िी हैं, सिाह और सहायिा देिा और ऐसे िाििों िें संबंमिि स् थािीय प्र ामिकाररयों से संपकग करिा;`
  line `( iii ) संकटग्रस्ि िीथगयामत्रयों को राहि पहुं चािा;`
  line `( iv ) केंरीय सरकार के अिुिोदि से, वार्षगक हज योजिा को अंमिि रू प देिा और योजिा को, मजसके अंिगगि`
  line `वायुिागग या ककसी अन्य सािि से यात्रा के मिए व्य वस्थाएं िी हैं, मिष्‍टपाकदि करिा और वास सुमविा से संबंमिि मव षयों िें`
  line `सिाह देिा;`
  line `( v ) समिमि के बजट प्र ा क ििों का अिुिोदि करिा और उसे केन्रीय सरकार को मवत्तीय वषग आरम्ि होिे से कि`
  line `से कि िीि िास पूवग उसकी सहिमि के मिए प्रस् िुि करिा;`
  line `( vi ) िीथगयामत्रयों के मिए यात्रा सुमविाएं सुमि मश्च ि करिे के प्र योजि के मिए केन्रीय सरकार, रे ि सेवा प्र दािा,`
  line `वायु सेवा प्र दा िा और यात्रा अमिकरर्ों के साथ सिन्वय स् थामपि करिा;`
  line `( vii ) सािारर्िया िीथगयामत्रयों के कल्यार् की देखिाि करिा;`
  line `( viii ) समिमि की ऐसी कायगवामहयों और िीथगयामत्रयों के महिों से संबंमिि ऐसे मवषयों को जो समिमि द्व ा रा इस`
  line `मिमित्त बिाई गई उपमवमियों द्व ारा अविाररि ककए जाएं, प्र कामश ि करिा;`
  line `( ix ) हज के संबंि िें ऐसे अन्य कृत्यों का मिवगहि करिा जो केन्रीय सरकार द्व ारा मवमहि ककए जाएं।`
  line `( 2 ) केन्रीय सरकार समिमि को उपिारा ( 1 ) िें मवमिर्दग ष्‍ट ट किगव्यों का मिवगहि करिे के मिए सिी यु मि यु ि सहायिा प्र`
  line `दाि करेगी।`
  line `10. समिमि के अमिवेशि — ( 1 ) समिमि हज की अवमि के प्र ारंि से पूवग एक वषग िें कि से कि िीि बार हज के मिए योजिा`
  line `बिािे और व्य वस्था करिे के मिए और उसके प श् चा ि् एक बार समिमि द्व ारा की गई सिी व्य वस्थाओं का पुिर्वगिोकि करिे के मि ए`
  line `अमिवेशि करेगी।`
  line `( 2 ) उपिारा ( 1 ) िें मव मिर्दग ष्‍ट ट अमिवेशिों के अमिरर ि समिमि जब किी इसके कि से कि एक मिहाई सदस्यों द्व ारा,`
  line `अध्यपेिा की जाए या अध्यि द्व ारा आवश्यक सिझा जाए, अमिवेशि कर सकेगी।`
  line `( 3 ) समिमि की ककसी अमिवेशि िें गर्पूर्िग उसके सदस्यों की संख्या का एक मिहाई होगा।`
  line `( 4 ) सिी मवषयों का मवमि श् च य उपमस्थि सदस्यों के बहुिि द्व ारा ककया जाएगा और ििों के सिाि होिे की दशा िें, अध्यि`
  line `या अध्यििा करिे वािे अन्य व्य मि का िि मिर्ागयक होगा।`
  line `( 5 ) समिमि अपिे अमिवेशिों िें कारबार के संव्यवहार के संबंि िें प्र कक्रया के ऐसे मियिों का पािि करेगी, जो उपमवमियों द्व`
  line `ारा अविाररि ककए जाएं।`
  line `11. स् थायी समिमियों और उपसमिमियों की मियु मि — ( 1 ) समिमि मवत्त और हज व्य वस्थाओं से संबंमिि मवषयों पर कारगवाई`
  line `करिे के मिए अपिे सदस्यों िें से दो स् थायी समिमियों की, मजििें से प्रत् येक की अध्यििा एक उपाध्यि द्व ा रा की जाएगी, मि यु मि`
  line `करेगी उििें ऐसी संख्या िें सदस्य होंगे और उिकी ऐसी श मि यां िथा ऐसे कृत्य होंगे जो समिमि द्व ारा इस मिमित्त बिा ई गई`
  line `उपमवमियों द्व ारा अविाररि ककए जाएं:`
  line `परन्िु यकद अध्यि बैठक िें उपमस्थि होिा है िो वह स् थायी समिमि की अध्यििा करे गा।`
  line `( 2 ) समिमि ऐसे प्र योजिों के मिए जो वह उपयु ि सिझे उपसमिमियां िी मियु ि कर सकेगी और ऐसी कोई उपसमिमि`
  line `उििी संख्या िें सदस्यों और अन्य व्य मि यों से मििकर बिेगी जो समिमि द्व ारा इस मिमित्त अविाररि ककए जाएं।`
obj_root_law_translations_hi_sections_5_footnotes:
  string
  line
obj_root_law_translations_hi_sections_6:
  kind page
  sectionId pdf-page-6
  sectionNo (6)
  orderNo 6
  title `Page 6`
  content obj_root_law_translations_hi_sections_6_content
  footnotes obj_root_law_translations_hi_sections_6_footnotes
  sourcePage 6
obj_root_law_translations_hi_sections_6_content:
  string
  line 4
  line `12. समिमि के सदस्य के रू प िें िाि मिदेमशि ककए जािे या बिे रहिे के मिए मिरहगिा — कोई व्य मि, समिमि के सदस्य के रू`
  line `प िें िािमिर्दग ष्‍ट ट ककए जािे या सदस्य के रू प िें बिे रहिे के मिए िब मिरर्हगि होगा, यकद —`
  line `( i ) वह िारि का िागररक िहीं है;`
  line `( ii ) वह िारा 4 के खंड ( iii ) िें यथामवमहि पदेि सदस्यों के मसवा य िुसििाि िहीं है;`
  line `( iii ) वह प च् ची स वषग से कि आयु का है;`
  line `( iv ) वह मवकृि मचत्त है और उसे सिि न् यायािय द्व ारा इस प्र कार घोमषि ककया गया है;`
  line `( v ) वह अिुन्िोमचि कदवामिया है;`
  line `( vi ) वह ककसी ऐसे अपराि के मिए दोषमसद्ध ककया गया है मजसिें, केन्रीय सरकार की रा य िें, िैमिक अिििा`
  line `अंिवगमिि है;`
  line `( vii ) उसे ककसी पूवग अवसर पर, —`
  line `(क) सदस्य के रू प िें अपिे पद से हटाया गया है; या`
  line `(ख) उसे सिि प्र ामिकारी के ककसी आदेश द्व ारा या िो िीथगयामत्रयों के महि िें कायग िहीं करिे के कारर्`
  line `या भ्र ष्‍ट टा चार के कारर् हटाया गया है।`
  line `13. अध्यि, उपाध्यि और सदस्यों का त् यागपत्र — अध्यि, उपाध्यि या कोई अन्य सदस्य अपिे हस्िािर समहि िेख द्व ारा`
  line `केन्रीय सरकार को संबोमिि करके अपिे पद से त् यागपत्र दे सकेगा और वह ऐसे त् यागपत्र की िारीख से प्र िावी होगा।`
  line `14. अध्यि, उपाध्यि और सदस्यों का हटाया जािा — ( 1 ) केन्रीय सरकार, राजपत्र िें अमिसूचिा द्व ारा, समिमि के अध्यि,`
  line `ककसी उपाध्यि या उसके ककसी सदस्य को हटा सकेगी, यकद वह —`
  line `( i ) िारा 1 2 िें वर्र्गि मिरहगिाओं िें से ककसी के अिीि है या हो जािा है; या`
  line `( ii ) कायग करिे से ििा करिा है या कायग करिे िें असिथग हो जािा है या ऐसी रीमि िें कायग करिा है मज से केन्री य`
  line `सरकार ककसी स् प ष्‍ट टी करर् की, जो वह पेश करे, सुिवाई करिे के प श् चा ि्, समिमि के महिों या िीथगयामत्रयों के महिों के प्र`
  line `मिकूि सिझिी है;`
  line `( iii ) समिमि की राय िें समिमि के िीि िगािार अमिवेशिों िें पयाग प् ि प्र मिहेिु के मबिा उपमस्थि होिे िें असफि`
  line `रहिा है।`
  line `( 2 ) जहां समिमि के अध्यि या ककसी उपाध्यि को उपिारा ( 1 ) के अिीि हटाया जािा है, वहां वह समिमि का सदस्य िी`
  line `िहीं रह जाएगा।`
  line `15. आकमस्िक रर मि का िरा जािा — ( 1 ) जब ककसी सदस्य का स् थाि उसके हटाए जािे, त् यागपत्र देिे, िृत्यु या अन्यथा के`
  line `कारर् रर ि होिा है, िब उसके स् थाि पर एक िए सदस्य को, यथामस्थमि, िािमिर्दग ष्‍ट ट या मिवागमचि ककया जाएगा और ऐसा स दस्य`
  line `िब िक पद िारर् करेगा जब िक वह स् दस्य, मजसका पद वह िरिा है, पद िारर् करिे का हकदार रहिा, यकद ऐसी रर मि िहीं हु`
  line `ई होिी।`
  line `( 2 ) उपिारा ( 1 ) के अिीि कोई आकमस्िक रर मि उसी प्र वगग के सदस्य द्व ारा िरी जाएगी मजसका पूवगविी सदस्य था।`
  line `16. िुख्य कायगपािक अमिकारी और अन्य किगचारी — ( 1 ) केंरीय सरकार, केंरीय सरकार और राज्य सरकारों के िुसििाि`
  line `अमिकारर यों के पैिि िें से एक व्य मि को, जो िारि सरकार के उपसमचव से िीचे की पं मि का ि हो, समिमि का िुख्य का यगपािक`
  line `अमिकारी, ऐसे मिबंिि और शिों पर, जो मवमहि की जाए, मियु ि करेगी।`
  line `( 2 ) िुख्य कायगपािक अमिकारी समिमि का पदेि समचव होगा।`
  line `( 3 ) िुख्य कायगपािक अमिकारी िीि वषग की अवमि के मिए मियु ि ककया जाएगा जो केन्रीय सरकार द्व ारा अमिकिि एक`
  line `वषग की अवमि के मिए बढाई जा सकेगी।`
  line `( 4 ) िुख्य कायगपािक अमिकारी समिमि के मवमि श् च यों का मिष्‍टपादि करेगा और ऐसे अन्य कृत्यों का, पािि करेगा, जो मवमहि`
  line `ककए जाएं:`
  line `परंिु िुख्य कायगपािक अमिकारी और समिमि की राय िें कोई अंिर होिे की दशा िें, वह उस िाििे को केंरीय सरकार के ध्`
  line `याि िें िाएगा मजस पर उसका मवमि श् च य अंमिि होगा।`
  line `( 5 ) समिमि, केंरीय सरकार की पूवग िंजूरी से, ऐसे अन्य अमिकाररयों और अन्य किगचाररयों को मजन्हें वह इ स अमिमियि के प्र`
  line `योजिों के कायागन्वयि के मिए आवश्यक सिझे, ऐसे मिबंिि और शिों पर, जो मवमहि की जाएं, मियोमजि कर सकेगी।`
obj_root_law_translations_hi_sections_6_footnotes:
  string
  line
obj_root_law_translations_hi_sections_7:
  kind page
  sectionId pdf-page-7
  sectionNo (7)
  orderNo 7
  title `Page 7`
  content obj_root_law_translations_hi_sections_7_content
  footnotes obj_root_law_translations_hi_sections_7_footnotes
  sourcePage 7
obj_root_law_translations_hi_sections_7_content:
  string
  line 5
  line `अध्याय 3`
  line `राज्य हज समिमियां`
  line `17. राज्य हज समिमियों की स् थापिा और मिगिि — ( 1 ) कोई राज्य सरकार उस िारीख से जो केंरीय सरकार इस मिमित्त`
  line `राजप त्र िें अमिसूचिा द्व ारा मियि करे....................... (राज्य का िाि) हज समिमि के िाि से ज्ञ ाि एक समिमि का ग ठि करेगी:`
  line `परंिु, यकद केंरीय सरकार को ककसी कारर् से ऐसा प्र िीि होिा है कक ककसी राज्य या संघ राज्यिेत्र के मिए ककसी हज`
  line `समिमि को स् थामपि करिा आव श् यक िहीं है िो वह ककसी संि ग् ि राज्य की राज्य हज समिमि को उि िीथगयामत्रयों के संबंि िें कारगवा ई`
  line `करिे के मिए और उि राज्यों और संघ राज्यिेत्रों के सिुमचि प्र मिमिमित्व का सुझाव देिे के मिए, प्र ामिकृि कर सकेगी।`
  line `( 2 ) राज्य समिमि पूवो ि िाि का एक मिगमि ि मिकाय होगा मजसका शा श् व ि उत्तरामिकार और सािान्य िुरा होगी और`
  line `इस अमिमियि के उपबंिों के अिीि रहिे हु ए जंगि और स् थावर दोिों ही प्र कार की संपमत्त का अजगि, िारर् और व्य यि करिे, कक सी`
  line `पूिग न् यास या मवन्यास का सृजि करिे िथा संमवदा करिे की श मि होगी और वह उ ि िाि से वाद िा सकेगा िथा उसके मव रुद्ध वाद`
  line `िाया जा सकेगा।`
  line `( 3 ) इस अमिमियि िें ककसी बाि के होिे हु ए िी मिम्ि मिमखि द्व ा रा कोई करार ककया जा सकेगा —`
  line `(क) संि ग् ि राज्यों की दो या अमिक सरकारों द्व ारा; या`
  line `(ख) केंरीय सरकार (एक या अमिक संघ राज्यिेत्रों के संबंि िें) और ऐसे संघ राज्यिेत्रों या संघ राज्यिेत्रों से`
  line `संि ग् ि एक या अमिक राज्य सरकारों द्व ारा,`
  line `जो ऐसी अवमि के मिए प्र वृत्त होगा िथा ऐसी और अवमि के मिए, यकद कोई है, िवीकरर् के अिीि होगा, जो संयु ि राज्य समिमि के`
  line `गठि का उपबंि करिे के मिए मिम्ि मिमख ि के मिए करार िें मवमिर्दग ष्‍ट ट ककया जाए, —`
  line `( i ) खंड (क) िें मिर्दग ष्‍ट ट ककसी िाििे िें, सिी िाग िेिे वािे राज्यों के मिए, और`
  line `( ii ) खंड (घ) िें मिर्दग ष्‍ट ट ककसी िाििे िें, िाग िेिे वािे संघ राज्यिेत्र या संघ राज्यिेत्रों और राज्य िथा राज्यों`
  line `के मिए।`
  line `( 4 ) इस अमिमियि के अिीि कोई करार उपिारा ( 2 ) के खंड (क) िें मिर्दग ष्‍ट ट ककसी िाििे िें िागीदार राज्यों के रा जपत्र िें`
  line `और उस उपिारा के खंड (ख) िें मिर्दग ष्‍ट ट ककसी िाििे िें िागीदार संघ राज्यिेत्रों और िागीदार राज्य या राज्यों के रा जपत्र िें प्र`
  line `कामशि ककया जाएगा।`
  line `( 5 ) इस अमिमियि िें राज्य समिमि के प्र मि कोई मिदेश, जब िक संदिग से अन्यथा अपेमिि ि हो, ककसी संयु ि राज्य समि मि`
  line `को समम्िमिि करिे हु ए सिझा जाएगा।`
  line `18. राज्य समिमि की संर चिा — ( 1 ) राज्य समिमि सोिह सदस्यों से मििकर बिेगी जो राज्य सरकार द्व ारा िािमिदे मशि`
  line `ककए जाएंगे, अथागि्: —`
  line `( i ) (क) संसद् िें राज्य का प्र मिमिमित्व करिे वािे;`
  line `(ख) राज्य मविाि सिा के; और`
  line `(ग) मविाि पररषद् के, जहां यह मवद्यिाि है;`
  line `िुसििाि सदस्यों िें से िीि सदस्य;`
  line `( ii ) राज्य िें स् थािीय मिकायों का प्र मिमिमित्व करिे वािे िुसििाि सदस्यों िें से िीि सदस्य;`
  line `( iii ) िुमस्िि ििग मवद्या और मवमि िें मवशेषज्ञिा रखिे वािे िीि सदस्य मजििें एक मशया िुसििाि होगा।`
  line `( iv ) िोक प्र शासि, मवत्त, मशिा, संस्कृमि या सािामजक कायग के िेत्रों िें कायगरि िुसििाि स् वैमच्छक संग ठिों का प्र`
  line `मिमिमित्व करिे वािे पां च सदस्य;`
  line `( v ) राज्य व़ बोडग का अध्यि; और`
  line `( vi ) राज्य समिमि का कायगपािक अमिकारी जो राज्य समिमि का पदेि सदस्य होगा:`
  line `परंिु ककसी संघ राज्यिेत्र की समिमि या संयु ि राज्य समिमि उििी संख्या िें सदस्यों से मििकर बिेगी, जो मव महि`
  line `की जाए।`
  line `( 2 ) उस द शा िें जहां उपिारा ( 1 ) के उपखंड ( i ) और उपखंड ( ii ) िें वर्र्गि ककन्हीं प्र वगों िें कोई िुसििाि सदस्य िहीं है, या`
  line `जहां ककसी राज्य िें कोई मविाि पररषद् िहीं है, वहां िािमिदेशि ऐसी रीमि िें ककया जाएगा, जो मवमहि की जाए।`
obj_root_law_translations_hi_sections_7_footnotes:
  string
  line
obj_root_law_translations_hi_sections_8:
  kind page
  sectionId pdf-page-8
  sectionNo (8)
  orderNo 8
  title `Page 8`
  content obj_root_law_translations_hi_sections_8_content
  footnotes obj_root_law_translations_hi_sections_8_footnotes
  sourcePage 8
obj_root_law_translations_hi_sections_8_content:
  string
  line 6
  line `19. सदस्यों की अमिसूचिा — िारा 18 की उ पिारा ( 1 ) के अिीि ककसी राज्य समिमि के सदस्यों के िािमिदेशि के यथाशीघ्र`
  line `प श् चा ि्, राज्य सरका र उस राज्य के राजपत्र िें ऐसे सिी सदस्यों के िाि प्र कामशि करेगी।`
  line `20. पदावमि — ( 1 ) राज्य समिमि के सदस्यों की पदावमि (पदेि सदस्यों और आकमस्िक रर मि यों को िरिे वािे सदस्यों`
  line `से मि न् ि ) िारा 19 के अिीि सदस्यों की सूची के प्र काशि के अगिे कदि से प्र ारंि होकर िीि वषग की होगी।`
  line `( 2 ) अध्यि और सदस्यों को संदेय ित्ते और अन्य मिबंिि और शिें वे होंगी, जो मवमहि की जाएं।`
  line `21. अध्यि — ( 1 ) िारा 19 के अिीि राज्य समिमि के सदस्यों के िािों के प्र काशि के प श् चा ि्, पैंिािीस कदि के िीिर राज्य`
  line `सरकार राज्य समिमि की पहिी बैठक संयोमजि करेगी मजसिें राज्य समिमि अपिे सदस्यों िें से एक अध्यि मिवागमचि करेगी:`
  line `परंिु पदेि सदस्य अध्यि के मिवागचि िें िाग िहीं िेगा।`
  line `( 2 ) यकद राज्य समिमि अ ध् यि का मिवागचि करिे िें असफि रहिी है िो राज्य सरकार, राज्य समिमि के ककसी सदस्य को`
  line `उसका अध्यि मियु ि कर सकेगी।`
  line `( 3 ) अध्यि का मिवागचि राज्य सरकार द्व ारा राज्य के राजपत्र िें अमिसूमचि ककया जाएगा।`
  line `( 4 ) अध्यि की पदावमि िीि वषग की होगी और कोई िी व्य मि अध्यि का पद दो िगािार पदावमियों से अमिक के मि ए`
  line `िारर् िहीं करेगा।`
  line `( 5 ) अध्यि के पद की कोई आकमस्िक रर मि, यथामस्थमि, उपिारा ( 1 ) या उपिारा ( 2 ) के अिुसार िरी जाएगी।`
  line `22. राज्य समिमि का पुिगगठि — ( 1 ) राज्य सरकार, राज्य समिमि की अवमि के सिा प् ि होिे से कि से कि चार िास पूवग िई`
  line `राज्य समिमि के पुिगगठि के मिए सिी आवश्यक कारगवाईयां करेगी या कराएगी।`
  line `( 2 ) कोई पदावरोही सदस्य राज्य समिमि िें पुिः िािमिदेशि के मिए, दो पदावमियों से अिमिक के मिए, पात्र होगा:`
  line `परंिु िािमिदेमशमियों िें से पचास प्र मिशि दूसरी पदावमि के मिए ऐसी रीमि िें पुिः िािमिदेमशि ककए जा सकें गे, जो`
  line `मवमहि की जाएं।`
  line `23. समिमि के सदस्य के रू प िें िािमिदेमशि ककए जािे या बिे रहिे के मिए मिरहगिा — कोई व्य मि समिमि िें िािमिर्दग ष्‍ट ट`
  line `ककए जािे या सदस्य बिे रहिे के मिए मिरर्हगि होगा यकद वह —`
  line `( i ) िारि का िागररक िहीं है;`
  line `( ii ) उस राज्य का मिवासी िहीं है;`
  line `( iii ) िारा 18 की उपिारा ( 1 ) के खंड ( vi ) िें यथा उपबंमिि कायगपािक अमिकारी के मसवाय, िुसििाि िहीं है;`
  line `( iv ) प च् ची स वषग से कि आयु का है;`
  line `( v ) मवकृिमचि है और उसे ककसी स ि ि न् यायािय द्व ारा ऐसा घोमष ि कर कदया गया है;`
  line `( vi ) अिुन्िोमचि कदवामिया है;`
  line `( vii ) ककसी ऐसे अपराि के मिए दोषमसद्ध ककया गया है मजसिें राज्य सरकार की राय िें िैमिक अिििा`
  line `अंिवगमिि है;`
  line `( viii ) उसे ककसी पूवग अवसर पर, —`
  line `( क ) सदस्य के रू प िें अपिे पद से हटाया गया है; या`
  line `( ख ) उसे सिि प्र ा मिकारी के ककसी आदेश द्व ारा या िो िीथगयामत्रयों के महि िें कायग िहीं करिे के कारर्`
  line `या भ्र ष्‍ट टा चार के कारर् हटाया गया है।`
  line `24. अध्यि और सदस्यों के त् यागपत्र — अध्यि या कोई अन्य सदस्य अपिे हस्िािर समहि िेख द्व ारा राज्य सरकार को`
  line `संबोमिि करके अपिे पद से त् यागपत्र दे सकेगा और वह ऐसे त् यागपत्र की िारीख से प्र िावी होगा।`
  line `25. अध्यि और सदस्यों को हटाया जािा — ( 1 ) राज्य सरकार, राजपत्र िें अमिसूचिा द्व ारा, राज्य समिमि के अध्यि या`
  line `ककसी सदस्य को हटा सकेगी, यकद वह —`
  line `( i ) िारा 23 िें मवमिर्दग ष्‍ट ट ककसी मिरहगिा के अिीि है या हो जािा है; या`
obj_root_law_translations_hi_sections_8_footnotes:
  string
  line
obj_root_law_translations_hi_sections_9:
  kind page
  sectionId pdf-page-9
  sectionNo (9)
  orderNo 9
  title `Page 9`
  content obj_root_law_translations_hi_sections_9_content
  footnotes obj_root_law_translations_hi_sections_9_footnotes
  sourcePage 9
obj_root_law_translations_hi_sections_9_content:
  string
  line 7
  line `( ii ) कायग करिे से ििा करिा है या कायग करिे िें असिथग हो जािा है या ऐसी रीमि िें कायग करिा है मजसे राज्य`
  line `सरकार ककसी स् प ष्‍ट टी करर् की, जो वह पेश करे, सुिवाई करिे के प श् चा ि्, समिमि के महिों या िीथग यामत्रयों के महिों के प्र`
  line `मिकूि सिझिी है; या`
  line `( iii ) राज्य समिमि की राय िें राज्य समिमि के िीि िगािार अमिवेशिों िें ककसी पयाग प् ि प्र मिहेिु के मबिा`
  line `उपमस्थि होिे िें असफि रहिा है।`
  line `( 2 ) जहां राज्य समिमि के अध्यि को उपिारा ( 1 ) के अिीि हटाया जािा है वहां वह राज्य समिमि का सदस्य िी िहीं`
  line `रह जाएगा।`
  line `26. आकमस्िक रर मि का िरा जािा — ( 1 ) जब ककसी सदस्य का स् थाि उसके हटाए जािे, त् यागपत्र देिे, िृत्यु या अन्यथा के`
  line `कारर् रर ि होिा है, िब उसके स् थाि पर एक िए सदस्य को िािमिर्दग ष्‍ट ट ककया जाएगा और ऐसा सदस्य िब िक पद िारर् करेगा`
  line `जब िक वह सदस्य, मजसका पद वह िरिा है, पद िारर् करिे का हकदार रहिा यकद ऐसी रर मि िहीं हु ई होिी।`
  line `( 2 ) उपिारा ( 1 ) के अिीि ककसी आकमस्िक रर मि को उसी प्र वगग के सदस्य द्व ारा िरा जाएगा मजसका पूवगविी स दस्य था।`
  line `27. राज्य समिमि के किगव्य — ( 1 ) राज्य समिमि का य ह किगव्य होगा कक वह हज िीथग यामत्रयों के महि िें समिमि की िीमि`
  line `और मिदेशों को कायागमन्वि करे।`
  line `( 2 ) राज्य समिमि हज िीथगयामत्रयों को सहायिा उपिब्ि कराएगी मजसके अंिगगि उिके गृह राज्यों और िारि से मिका स के स्`
  line `थाि के बीच उिके पररवहि के मवषय और िारि से मिकास स् थािों पर उिके अमिवहि, आवास की व्य वस्था िी है।`
  line `( 3 ) राज्य समिमि हज के संबंि िें ऐसे अन्य किगव्यों का मिवगहि करेगी, जो केन्रीय सरकार के परािशग से संब द्ध राज्य सरकार द्व`
  line `ारा मवमहि ककए जाएं।`
  line `28. राज्य समिमि के अमिवेशि — ( 1 ) राज्य समिमि हज कदि के पूवग एक वषग िें कि से कि दो बार और हज की सिा मप्ि के`
  line `प श् चा ि् एक बार अमिवेशि करेगी।`
  line `( 2 ) राज्य समिमि के ककसी अमिवेशि िें गर्पूर्िग करिे के मिए अपेमिि सदस्यों की संख्या इसके सदस्यों की एक`
  line `मिहाई होगी।`
  line `( 3 ) उपिारा ( 1 ) िें मवमिर्दग ष्‍ट ट अमिवेशिों की संख्या के अमिरर ि राज्य समिमि जब किी इसके कि से कि एक मि हाई`
  line `सदस्यों द्व ारा अध्यपेिा की जाए या अध्यि द्व ारा आवश्यक सिझा जाए अमिवेशि कर सकेगी।`
  line `( 4 ) सिी मवषयों का मवमि श् च य उपमस्थि सदस्यों के बहुिि द्व ारा ककया जाएगा और ििों के बराबर होिे की दशा िें अ ध् यि`
  line `या अ ध् यििा करिे वािे अन्य व्य मि का िि मिर्ागयक होगा।`
  line `29. राज्य समिमि का कायगपािक अमिकारी और अन्य किगचारी — ( 1 ) राज्य सरकार अपिे ऐसे अमिकाररयों िें से जो उप`
  line `समचव से िीचे की पं मि के ि हों, एक व्य मि को राज्य समिमि का कायगपािक अमिकारी मियु ि करेगी:`
  line `परंिु इस प्र कार मियु ि ककया गया व्य मि अमििाििः िुसिाि होगा।`
  line `( 2 ) राज्य समिमि का कायगपािक अमिकारी इसके समचव के रू प िें कायग करेगा।`
  line `( 3 ) कायगपािक अमिकारी राज्य समिमि के मवमि श् च यों का मिष्‍टपादि करेगा और ऐसे अन्य कृत्यों का पािि करेगा जो मव महि`
  line `ककए जाएं:`
  line `परन्िु कायगपािक अमिकारी और समिमि की राय िें अंिर होिे की दशा िें, वह उस िाििे को राज्य सरकार के ध् याि िें`
  line `िाएगा मजस पर उसका मवमि श् च य अंमिि होगा।`
  line `( 4 ) राज्य समिमि राज्य सरकार की पूवग िंजूरी से ऐसे अमिकारी और अन्य किगचारी मियु ि करेगी जो वह इस अमिमि यि के प्र`
  line `योजिों के कायागन्वयि के मिए आवश्यक सिझे।`
  line `( 5 ) अमिकाररयों और अन्य किगचाररयों की पदावमि और सेवा की शिें ऐसी होगी जो मवमहि की जाएं।`
  line `अध्याय 4`
  line `मवत्त, िेखा और संपरीिा`
  line `30. केन्रीय हज मिमि — समिमि की अपिी मिमि होगी जो केन्रीय हज मिमि कहिाएगी और उसके खािे िें मिम्ि मिमखि`
  line `रामशयां जिा की जाएंगी, अथागि्: —`
  line `(क) ककन्हीं फीसों और सेवा प्र िारों से वसूि की गई रामशयां जो समिमि द्व ारा मिम्ि मिमखि के मिए उद्गृही ि की`
  line `जा सकेंगी —`
obj_root_law_translations_hi_sections_9_footnotes:
  string
  line
obj_root_law_translations_hi_sections_10:
  kind page
  sectionId pdf-page-10
  sectionNo (10)
  orderNo 10
  title `Page 10`
  content obj_root_law_translations_hi_sections_10_content
  footnotes obj_root_law_translations_hi_sections_10_footnotes
  sourcePage 10
obj_root_law_translations_hi_sections_10_content:
  string
  line 8
  line `( i ) हज के आवेदिों के रमजस्रीकरर् के मिए; और`
  line `( ii ) हज िीथगयात्री यात्रा पास जा री करिे के मिए;`
  line `(ख) हज करिे के मिए िीथगयामत्रयों से संगृहीि िि;`
  line `(ग) समिमि की मिमि के सिी मििेपों और मवमििाि से आय;`
  line `(घ) िृि िीथगयामत्रयों की चीज - बस्ि के मवक्र य से वसूि की गई रामशयां और उिके द्व ारा छोडी गई ििरामशयां,`
  line `मजिके मिए कोई दावा िहीं ककया गया है और केन्रीय सरकार को व्य पगि हो गई हैं;`
  line `( ङ ) केन्रीय या ककसी राज्य सरकार द्व ारा या सरकार द्व ारा अिुिोकदि ककसी अन्य स्र ोि से उिार िी गई को ई`
  line ििरामश;
  line `(च) ककसी अन्य स्र ोि से कोई अन्य रकि, जो समिमि को मवमिक रू प से देय हो; और`
  line `(छ) इस अमिमियि के प्र ारम्ि प र हज समिमि अमिमियि, 1959 ( 1959 का 51 ) के अिीि स् थामपि हज मिमि या`
  line `मििगि िीथगयात्री मिमि िें जिा रकि।`
  line `31. केन्रीय हज मिमि का उपयोजि — केन्रीय हज मिमि इस अमिमियि के उपबंिों के अिीि और उिके अन्िगगि बिाए गए`
  line `मियिों के अध्य िीि समिमि के मियंत्रर् और प्र बंि के अिीि होगी और उसका उपयोजि मिम्ि मिमखि प्र योजिों के मिए ककया`
  line `जाएगा, अथागि्: —`
  line `(क) समिमि के िुख्य कायगपािक अमिकारी और अन्य किगचाररयों के वेिि और ित्ते;`
  line `(ख) िारा 9 िें मवमिर्दग ष्‍ट ट उद्देश्यों के आिुषंमगक प्र िारों और व्य यों का संदाय; और`
  line `(ग) कोई अ न् य व्य य जो केन्रीय सरकार द्व ारा अिुिोकदि रू प िें समिमि या राज्य समिमि द्व ारा ककया जािा`
  line `अपेमिि हो।`
  line `32. राज्य हज मिमि — राज्य समिमि की अपिी मिमि होगी जो राज्य हज मिमि कहिाएगी और उसके खािे िें मिम्ि मिमखि`
  line `रामशयां जिा की जाएंगी, अथागि्: —`
  line `( i ) इसे संदत्त सिी ििरामशयां या इस अमिमियि के प्र योजिों के मिए समिमि को कदया गया कोई अिुदाि;`
  line `( ii ) राज्य सरकार द्व ारा या अन्य ककसी स्र ोि से इस अमिमियि के अिीि राज्य सरकार के अिुिोदि से राज्य`
  line `समिमि को कदया गया कोई अिुदाि या ऋर्;`
  line `( iii ) ककसी स्र ोि से राज्य समिमि को मवमिक रू प से देय कोई रकि; और`
  line `( iv ) इस अमिमियि के प्र ारम्ि होिे पर राज्य हज समिमि के खािे िें जिा कोई िि, यकद कोई हो।`
  line `33. राज्य हज मिमि का उपयोजि — राज्य हज मिमि, इस अमिमियि के अिीि बिाए गए मियिों के अध्यिीि, राज्य`
  line `समिमि के मियंत्रर् और प्र बंि के अिीि होगी और उसका उ पयोजि मिम्ि मिमखि प्र योजिों के मिए ककया जाएगा, अथागि्: —`
  line `( i ) राज्य समिमि के किगचाररयों के वेिि और ित्ते मजििें कायगपािक अमिकारी के वेिि और ित्ते िहीं हैं, जो राज्य`
  line `सरकार द्व ारा वहि ककए जाएंगे;`
  line `( ii ) िारा 27 िें मवमिर्दग ष्‍ट ट उद्देश्यों के मिए राज्य समिमि द्व ारा उसके किगव्यों के सम्यक् अिुपा िि के आिुषं मगक प्र`
  line `िारों और व्य यों का संदाय;`
  line `( iii ) अन्य व्य य जो राज्य समिमि द्व ारा राज्य सरकार के अिुिोदि से ककए जािे अपेमिि हों।`
  line `34. िेखा और संपरीिा — ( 1 ) समिमि और प्रत् येक राज्य समिमि, ऐसे प्ररू प िें जो, यथामस्थमि, केन्रीय सरकार या राज्य`
  line `सरकार द्व ारा मवमहि ककया जाए, उमचि िेखे और अन्य सुसंगि अमििेख रखेंगी और िेखे का वार्षगक मववरर् िैयार करेंगी।`
  line `( 2 ) िेखाओं की परीिा और संपरीिा वार्षगक रू प से, यथामस्थमि, केन्रीय सरकार या राज्य सरकार द्व ारा अिुिोकदि िेखा`
  line `परीिकों से कराई जाएगी।`
  line `( 3 ) िेखापरीिक द्व ारा यथा सत्यामपि समिमि या राज्य समिमि के िेखे उि पर संपरीिा ररपोटग के साथ, उ ि समिमि द्व ारा,`
  line `यथामस्थमि, केन्रीय सरकार या राज्य सरकार को वार्षगक रू प से अग्रेमषि ककए जाएंगे।`
  line `( 4 ) केन्रीय सरकार, उपिारा ( 3 ) के अ िीि संपरीिा ररपोटग प्र ा प् ि होिे के प श् चा ि् यथाशीघ्र उसे संसद् के प्रत् येक सदि के`
  line `सिि रखवाएगी।`
  line `( 5 ) राज्य सरकार, उपिारा ( 3 ) के अिीि संपरीिा ररपोटग प्र ा प् ि होिे के प श् चा ि् यथाशीघ्र उसे राज्य मविाि - िंडि के`
  line `सिि रखवाएगी।`
obj_root_law_translations_hi_sections_10_footnotes:
  string
  line
obj_root_law_translations_hi_sections_11:
  kind page
  sectionId pdf-page-11
  sectionNo (11)
  orderNo 11
  title `Page 11`
  content obj_root_law_translations_hi_sections_11_content
  footnotes obj_root_law_translations_hi_sections_11_footnotes
  sourcePage 11
obj_root_law_translations_hi_sections_11_content:
  string
  line 9
  line `अध्याय 5 प्र`
  line कीर्ग
  line `3 5. समिमि की िीथगयात्री पासों को जारी करिे और फीसों को उद्गृहीि करिे की श मि यां — ( 1 ) समिमि को ककसी हज`
  line `िीथगयात्री को िारि से सउदी अरब जािे के मिए सद्भावी िीथगयात्री के रू प िें उसके प्रस् थाि के मिए यात्रा दस्िावेज, जो`
  line `“ िीथगयात्री पास ” कहिाएगा, जारी करिे की श मि होगी और उ ि िीथगयात्री को पासपोटग अमिमियि, 1967 ( 1967 का 15 ) की`
  line `िारा 3 के उपबंिों से छूट दी गई सिझी जाएगी।`
  line `( 2 ) पासपोटग अमिमियि, 1967 ( 1967 का 15 ) िें ककसी बाि के होिे हु ए िी, केन्रीय सरकार, समिमि से परािशग करके, हज`
  line `िीथगयात्री रमज स् रीकरर् के मिए, समिमि द्व ारा िीथगयात्री पास जारी करिे और अन्य संबंमिि िाििों के मिए, ऐसी फीसें, जो ऐसी`
  line `सेवाएं कदए जािे के संबंि िें मवमहि की जाएं, उद्गृहीि कर सकेगी।`
  line `36. समिमि का अमिक्रिर् — ( 1 ) यकद केन्रीय सरकार की राय िें, समिमि इस अमिमियि के अिीि या इसके द्व ारा`
  line `अमिरोमपि किगव्यों का पािि करिे िें असिथग है या िगािार अिुपािि िें व्य मिक्रि करिी है या अपिी श मि यों से अमिक प्र योग`
  line `करिी है या उिका दुरुपयोग करिी है, िो केन्रीय सरकार, उसके मिए कारर्ों के कथि के साथ ऐसी अवमि के मिए, जो आदेश िें`
  line `मवमिर्दग ष्‍ट ट की जाए, राजपत्र िें प्र कामशि करके अमिक्रांि करिे का आदेश कर सकेगी:`
  line `परंिु यथापूवो ि अमिक्रिर् का आदेश करिे से पूवग केन्रीय सरकार, समिमि को कारर् बिािे का यु मि यु ि अवसर देगी कक`
  line `यों ि उसे अमिक्रांि कर कदया जाए।`
  line `( 2 ) जब उपिारा ( 1 ) के अिीि ककसी आदेश द्व ारा समिमि को अमिक्रांि कर कदया गया है, िब —`
  line `(क) सिी सदस्य उस िारीख को, जो आदेश िें मवमिर्दग ष्‍ट ट की जाए, खंड (घ) के अिीि िािमिदेशि के मिए उि की`
  line `पात्रिा पर प्र मिकूि प्र िाव डािे मबिा ऐसे सदस्यों के रू प िें अपिे पदों को रर ि कर देंगे;`
  line `(ख) समिमि की अमिक्रांि अवमि के दौराि, इस अमिमियि के द्व ारा या उसके अिीि समिमि को प्र दत्त सिी`
  line `अमिकारों और अमिरोमपि किगव्यों को, ऐसे अमिकारी या प्र ामिकारी द्व ारा प्र योग और मिष्‍टपाकदि ककया जाएगा मजसे के न् री य`
  line `सरकार इस मिमित्त मियु ि करे;`
  line `(ग) समिमि िें मिमहि सिी संपमत्त यां, जब िक कक वह पुिगगरठि ि हो जाएं, केन्रीय सरकार िें मिमहि हों गी;`
  line `(घ) अमिक्रिर् की अवमि के सिा प् ि होिे से पूवग समिमि के पुिगगठि के प्र योजिों के मिए केन्रीय सरका र द्व ारा`
  line `िािमिदेशि ककए जाएंगे।`
  line `( 3 ) इस िारा के अिीि ककए गए अमिक्रिर् के आदेश के साथ उ सके कारर्ों के कथि को, इसको ककए जािे के प श् चा ि्`
  line `यथाशीघ्र संसद् के प्रत् येक सदि के सिि रखा जाएगा।`
  line `( 4 ) कोई राज्य सरकार, राज्य समिमि की बाबि उन्हीं श मि यों का प्र योग और उन्हीं किगव्यों का मिवगहि, मजिका उल्िेख इस`
  line `िारा की उपिारा ( 1 ), उपिारा ( 2 ) और उपिारा ( 3 ) िें ककया गया है, उििें उमल्िमखि शिों और इस संबंि िें केंरीय सरका र द्व ा रा`
  line `जारी ककए गए ककन्हीं मिदेशों के अिीि रहिे हु ए, कर सकेगी।`
  line `37. समिमि या राज्य समिमि की सदस्यिा का िाि का पद ि होिा — ित्सिय प्र वृत्त अन्य ककसी मवमि िें ककसी बाि के होिे हु`
  line `ए िी, समिमि या राज्य समिमि के ककसी सदस्य के पद को िाि का पद िहीं सिझा जाएगा।`
  line `38. समिमि की कायगवामहयों का रर मि यों, आकद के कारर् अमवमििान्य ि होिा — यथामस्थमि, ककसी समिमि या राज्य`
  line `समिमि या संयु ि राज्य समिमि का कोई कायग या कायगवाही केवि इस आिार पर अमवमििा न् य िहीं होगी कक उसके सदस्यों िें कोई`
  line `रर मि है या उसके गठि िें कोई किी है।`
  line `39. समिमि के अमिकाररयों और किगचाररयों का िोक सेवक होिा — समिमियों के अमिकारी और किगचारी या अन्य व्य मि`
  line `जो इस अमिमियि या उसके अिीि बिाए गए मियिों या उपमवमियों के अिीि ककसी किग व्य का मिवगहि करिे के मिए मियु ि ककए`
  line `गए हैं, िारिीय दंड संमहिा ( 1860 का 45 ) की िारा 21 के अथग के अंिगगि िोक सेवक सिझे जाएंगे।`
  line `40. संरिर् — इस अमिमियि के अिीि सद्भावपूवगक की गई या ककए जािे के मिए िात्पर्यगि ककसी बाि के मिए कोई वाद,`
  line `अमियोजि या अन्य मव मिक कायगवाही समिमि या राज्य समिमि के अध्यि, उपाध्यि या ककसी सदस्य के मवरुद्ध, यथामस्थमि, कें री य`
  line `सरकार या राज्य सरकार की पूवग अिुिमि के मसवाय िहीं की जाएगी।`
  line `41. अिुसूची का संशोिि करिे की श मि — ( 1 ) यकद केंरीय सरकार का यह सिािाि हो जािा है कक ऐसा करिा आवश्यक`
  line `या सिीचीि है, िो वह राजपत्र िें प्र कामशि अमिसूचिा द्व ारा, अिुसूची को संशोमिि कर सकेगी और उसके प श् चा ि् अिुसूची ि द् िुसार`
  line `संशोमिि की गई सिझी जाएगी।`
  line `( 2 ) उपिारा ( 1 ) के अिीि मिकािी गई प्रत् येक अमिसूचिा की एक प्र मि, इसके मिकािे जािे के प श् चा ि् य थाशीघ्र संसद् के प्रत्`
  line `येक सदि के सिि रखी जाएगी।`
obj_root_law_translations_hi_sections_11_footnotes:
  string
  line
obj_root_law_translations_hi_sections_12:
  kind page
  sectionId pdf-page-12
  sectionNo (12)
  orderNo 12
  title `Page 12`
  content obj_root_law_translations_hi_sections_12_content
  footnotes obj_root_law_translations_hi_sections_12_footnotes
  sourcePage 12
obj_root_law_translations_hi_sections_12_content:
  string
  line 10
  line `42. मशकायिों को दूर करिा — कोई िी ऐसा हज िीथगयात्री, जो हज समिमि या राज्य हज समिमि द्व ारा ककए गए किगव्यों िें`
  line `से ककसी के मिवगहि से व्य मथि है, अपिी मशकायिों को दूर करिे के मिए, यथामस्थमि, हज समिमि या राज्य हज समिमि को अभ्या वेदि`
  line `करेगा और यह, यकद आवश्यक हो, व्य मथि व्य मि की सुिवाई के प श् चा ि्, उ ि समिमि द्व ारा मिपटाया जाएगा।`
  line `43. संपमत्तयों और अन्य अमिकारों, आकद का समिमियों िें मिमहि होिा — ( 1 ) इस अमिमियि के प्र ारंि से ही, सिी आमस्ियां,`
  line `अमिकार, पट्टािृमियां, श मि यां, प्र ामिकार और मवशेषामिकार िथा सिी जंगि और स् थावर संपमत्तयां, मजिके अंिगगि िूमि, िवि,`
  line `िंडार, िकद अमिशेष, हाथ की रोक ड, आरमिि मिमियां, मवमििाि और ऐसी संपमत्तयों िें या उिसे उत्प न् ि होिे वािे सिी अ न् य`
  line `अमिकार और महि हैं, जो ऐसे प्र ारंि के ठीक पूवग, हज समिमि अमिमियि, 1959 ( 1959 का 51 ) के अिीि गरठि हज समिमि, िुंबई के स्`
  line `वामित्व, श मि या मियंत्रर् िें थे, और सिी िेखा बमहयां, रमजस्टर और उिसे संबंमिि अन्य सिी दस्िावेज, चाहे वे कक सी िी प्र कृमत्त`
  line `के हों, समिमि िें पूर्गिया मिमहि हो जाएंगे और उसके हो जाएंगे।`
  line `( 2 ) इस अमिमियि के प्र ारंि से ही, सिी आमस्ियां, अमिकार, पट्टािृमियां, श मि यां, प्र ामिकार और मवशेषामिकार िथा सिी`
  line `जंगि और स् थावर संपमत्तयां, मजिके अंिगगि िूमि, िवि, िंडार, िकद अमिशेष, हाथ की रोकड, आरमिि मिमियां, मवमििाि और ऐ सी`
  line `संपमत्तयों िें या उिसे उत्प न् ि होिे वािे सिी अन्य अमिकार और महि हैं, जो ऐसे प्र ारंि के ठीक पूवग, ककसी राज्य की हज समिमि के स्`
  line `वामित्व, श मि या मियंत्रर् िें थे, और सिी िेखा बमहयां, रमजस्टर और उिसे संबंमिि अन्य सिी दस्िावेज, चाहे वे कक सी िी प्र कृमत्त`
  line `के हों, राज्य की हज समिमि िें पूर्गिया मिमहि हो जाएंगे और उसके हो जाएंगे।`
  line `( 3 ) ऐसे प्र ारंि के ठीक पूवग, समिमि या राज्य समिमि के प्र योजिों के मिए या उिके संबंि िें समिमि या राज्य समिमि द्व ारा,`
  line `उसके साथ या उसके मिए उपगि सिी ऋर्, बाध्यिाएं और दामयत्व, की गई सिी संमवदाएं और ककए जािे के मिए वचिबद्ध सिी`
  line `िाििे िथा बािें, यथामस्थमि, समिमि या राज्य समिमि के द्व ारा, उसके साथ या उसके मिए उपगि की गई या ककए जािे के मिए`
  line `वचिबद्ध सिझी जाएंगी।`
  line `( 4 ) ऐसे प्र ारंि के ठीक पूवग, समिमि या राज्य समिमि को देय सिी ििरामशयां, यथामस्थमि, समिमि या राज्य समिमि को देय`
  line `सिझी जाएंगी।`
  line `( 5 ) हज समिमि, िुंबई या राज्य की हज समिमि के साथ की गई सिी संमवदाएं और उिकी ओर से मिष्‍टपाकदि सिी मिखिें,`
  line `यथामस्थमि, समिमि या राज्य समिमि की ओर से की गई या मिष्‍टपाकदि की गई सिझी जाएंगी और िद्िुसार उिका अिुपािि`
  line `ककया जाएगा।`
  line `( 6 ) इस अमिमियि के प्र ारंि पर िंमबि सिी वाद और मवमिक कायगवामहयां मजििें हज समिमि, िुंबई या राज्य की हज`
  line `समिमि, पिकार थी, यथामस्थमि, समिमि या राज्य समिमि उसके स् थाि पर प्र मिस्थामपि की गई सिझी जाएंगी।`
  line `44. मियि बिािे की श मि — ( 1 ) केंरीय सरकार इस अमिमिय ि के प्र योजिों को कक्रयामन्वि करिे के मिए, अमिसूचिा द्व ारा,`
  line `मियि बिा सकेगी।`
  line `( 2 ) मवमश ष्‍ट ट िया और पूवगगािी श मि यों की व्य ापकिा पर प्र मिकूि प्र िाव डािे मबिा, ऐसे मियि मिम्ि मिमखि मवषयों या`
  line `उििें से ककसी के मिए उपबंि कर सकेंगे, अथागि्: —`
  line `( i ) िारा 4 के खं ड ( ii ) के अिीि समिमि के सदस्यों के मिवागचि की रीमि;`
  line `( ii ) िारा 6 की उपिारा ( 2 ) के अिीि अध्यि और सदस्यों की पदावमियां और शिें;`
  line `( iii ) िारा 7 की उपिारा ( 3 ) के अिीि अध्यि की श मि यां और किगव्य;`
  line `( iv ) वह रीमि मजसिें िारा 8 की उपिारा ( 2 ) के परंिुक के अिीि सदस्यों का पुिःिािमिदेशि ककया जा सकेगा;`
  line `( v ) िारा 9 की उपिारा ( 1 ) के खंड ( ix ) के अिीि हज से संबंमिि किगव्य;`
  line `( vi ) िारा 16 के अिीि िुख्य कायगपािक अमिकारी के कृत्य और समिमि के िुख्य कायगपािक अमिकारी और अन्य`
  line `किगचाररयों की सेवा के मिबंिि और शिें;`
  line `( vii ) िारा 18 की उपिारा ( 1 ) के खंड ( vi ) के परंिुक के अिीि संयु ि राज्य समिमि या संघ राज्यिेत्र की समिमि`
  line `के सदस्यों की संख्या:`
  line `( viii ) वह रीमि मजसिें िारा 34 के अिीि समिमि और राज्य समिमियों द्व ारा िेखे रखे जाएंगे और ऐसे िेखाओं की`
  line `संपरीिा की जाएगी;`
  line `( ix ) िारा 35 की उपिारा ( 1 ) के अिीि हज िीथगयात्री पास का जारी ककया जािा;`
  line `( x ) िारा 41 के अिीि संि ग् ि राज्यों या संघ राज्यिेत्र से मििकर बििे वािे अंचिों से संबंमिि अिुसूची`
  line `का संशोिि;`
  line `( xi ) कोई अन्य मवषय जो मवमहि ककया जाए।`
obj_root_law_translations_hi_sections_12_footnotes:
  string
  line
obj_root_law_translations_hi_sections_13:
  kind page
  sectionId pdf-page-13
  sectionNo (13)
  orderNo 13
  title `Page 13`
  content obj_root_law_translations_hi_sections_13_content
  footnotes obj_root_law_translations_hi_sections_13_footnotes
  sourcePage 13
obj_root_law_translations_hi_sections_13_content:
  string
  line 11
  line `( 3 ) इस िारा के अिी ि बिाया गया प्रत् येक मियि बिाए जािे के प श् चा ि् यथाशीघ्र संसद् के प्रत् येक सदि के सिि, जब वह`
  line `सत्र िें हो, कुि िीस कदि की अवमि के मिए रखा जाएगा। यह अवमि एक सत्र िें अथवा दो या अमिक आिुक्रमिक सत्रों िें पूरी हो`
  line `सकेगी और यकद उस सत्र के या पूवो ि आिुक्र मिक सत्रों के ठीक बाद के सत्र के अवसाि के पूवग दोिों सदि उस मियि िें कोई परर विगि`
  line `करिे िें सहिि हो जािे हैं िो ित्प श् चा ि् वह ऐसे पररवर्िगि रू प िें ही प्र िावी होगा। यकद उ ि अवसाि के पूवग दो िों सदि सह िि हो`
  line `जाएं कक वह मियि िहीं बिाया जािा चामहए िो ित्प श् चा ि् वह मिष्‍टप्रिाव हो जाएगा। ककंिु मियिों के ऐसे पररवर्िगि या मि ष्‍टप्र िाव`
  line `होिे से उस मियि के अिीि पहिे की गई ककसी बाि की मवमििान्यिा पर कोई प्र मिकूि प्र िाव िहीं पडेगा।`
  line `45. उपमवमि बिािे की श मि — ( 1 ) समिमि, अमिसूचिा द्व ारा, इस अमिमियि के उपबंिों और उिके अिीि बिाए गए`
  line `मियिों के संगि उपमवमियां मिम्ि मिमखि मवषयों के संबंि िें बिा सकेगी, अथागि्: —`
  line `( i ) िारा 7 की उपिारा ( 4 ) के अिीि उपाध्यि की श मि यां और किगव्य;`
  line `( ii ) िारा 9 की उपिारा ( 1 ) के खंड ( viii ) के अिीि समिमि की कायगवामहयां और यामत्रयों के महिों के ककसी मवषय`
  line `के प्र काशि के मिए उपबंि करिा;`
  line `( iii ) िारा 10 की उपिारा ( 5 ) के अिीि समिमि के अमिवेशि िें कारबार के संव्यवहार के मिए प्र कक्रया के मियि`
  line `अमिकमथि करिा;`
  line `( iv ) िारा 11 के अिीि स् थायी समिमि की श मि यां और कृत्य िथा उपसमिमियों िें सदस्यों और अन्य व्य मि यों`
  line `की संख्या का अविारर्;`
  line `( v ) इस अमिमियि के उपबंिों को प्र िावी करिे के मिए समिमि द्व ारा आवश्यक सिझे जािे वािे ककसी अन्य मवषय`
  line `का उपबंि करिा।`
  line `( 2 ) इस िारा के अिीि समिमि द्व ारा बिाई गई उपमवमियां केंरीय सरकार को प्रस् िुि की जाएंगी और जब िक केंरीय सरकार द्व`
  line `ारा उिकी पुमि िहीं कर दी गई हो, िब िक वे िागू िहीं होंगी।`
  line `( 3 ) केंरीय सरकार द्व ारा पु ष्‍ट ट की गई उपमवमियां राजपत्र िें प्र कामशि की जाएंगी।`
  line `46. प्रत् यायोजि की श मि यां — इस अमिमियि के उपबंिों और इसके अिीि बिाए गए मियिों के अिीि समिमि केन्रीय`
  line `सरकार के पूवग अिुिोदि से मिमखि रू प िें; सािारर् या मवशेष आदेश द्व ारा और ऐसी शिों और पररसीिाओं के अिीि जो आदेश िें`
  line `मवमिर्दग ष्‍ट ट की जाएं, इस अमिमियि के (िारा 45 के अिीि उपमवमि बिािे की श मि यों के मसवाय) अिीि ऐसी श मि यों को, मजन्हें`
  line `वह आवश्यक सिझिी है, समिमि के ककसी सदस्य या िुख्य कायगपािक अमिकारी को प्रत् यायोमजि कर सकेगी।`
  line `47. मियि बिािे की राज्य सरकार की श मि — ( 1 ) राज्य सरकारें, केन्रीय सरकार के परािशग से अमिसूचिा द्व ारा, इस`
  line `अमिमियि के प्र योजिों को कायागमन्वि करिे के मिए राज्य समिमियों के बारे िें मियि बिा सकेंगी।`
  line `( 2 ) मवमश ष्‍ट ट िया और पूवगगािी श मि यों की व्य ापकिा पर प्र मिकूि प्र िाव डािे मबिा ऐसे मियि, मिम्ि मिमखि मवषयों या`
  line `उििें से ककसी के मिए उपबंि कर सकेंगे, अथागि्: —`
  line `( i ) िारा 20 की उपिारा ( 2 ) के अिीि राज्य समिमि के अध्यि और सदस्यों के मिबंिि और शिें;`
  line `( ii ) वह रीमि, मजसिें िारा 22 की उपिारा ( 2 ) के परंिुक के अिीि सदस्यों का पुिःिािमिदेशि ककया जा सकेगा;`
  line `( iii ) िारा 27 की उपिारा ( 3 ) के अिीि राज्य समिमि के किगव्य;`
  line `( iv ) िारा 29 के अिीि कायगपािक अमिकारी के कृत्य और अमिकाररयों िथा अन्य किगचाररयों की सेवा के मिबंिि`
  line `और शिें;`
  line `( v ) अन्य कोई मवषय, जो मवमहि ककया जािा अपेमिि हो या जो मवमहि ककया जाए।`
  line `( 3 ) इस िारा के अिीि बिाया गया प्रत् येक मियि, उसके बिाए जािे के प श् चा ि् यथाशीघ्र, राज्य मविाि - िंडि के सिि`
  line `रखा जाएगा।`
  line `48. इस अमिमियि के प्र ारंि से पूवग मवद्यिाि समिमि के किगचाररयों के मिए उपबंि — यथामस्थमि, ककसी मवद्यिाि समिमि`
  line `या राज्य समिमि के प्रत् येक अमिकारी और अन्य किगचारी इस अमिमियि के प्र ारंि की िारीख से ही, यथामस्थमि, समिमि या राज्य`
  line `समिमि के अमिकारी या अन्य किगचारी, ऐसे पदिाि के साथ, जो समि मि अविाररि करे, उसिें पद उसी अवमि के मिए, सिाि`
  line `पाररश्रमिक पर, सेवा के उन्हीं मिबंििों और शिों पर, मजि पर वह हज समिमि अमिमियि, 1959 ( 1959 का 51 ) के अिीि गरठि ह ज`
  line `समिमि के अिीि थे, ऐसे अमिकारी या अन्य किगचारी के रू प िें स् थािान्िररि होंगे और ऐसे सिय िक का यग करिे रहेंगे जब ि क कक`
  line `ऐसी समिमि द्व ारा मिबंिि और शिें सम्यक् रू प से पररवर्िगि िहीं कर दी जािी:`
obj_root_law_translations_hi_sections_13_footnotes:
  string
  line
obj_root_law_translations_hi_sections_14:
  kind page
  sectionId pdf-page-14
  sectionNo (14)
  orderNo 14
  title `Page 14`
  content obj_root_law_translations_hi_sections_14_content
  footnotes obj_root_law_translations_hi_sections_14_footnotes
  sourcePage 14
obj_root_law_translations_hi_sections_14_content:
  string
  line 12
  line `परन्िु, यथामस्थमि, समिमि या राज्य समिमि के ऐसे अमिकारी और अन्य किगचारी की सेवा की अवमि, पाररश्रमिक और`
  line `मिबंिि और शिें, उसे अिािकारी रू प िें, यथामस्थमि, के न् रीय सरकार या राज्य सरकार की पूवग िंजूरी के मबिा, पररवर्िग ि िहीं`
  line `की जाएंगी:`
  line `परन्िु यह और कक इस अमिमियि के प्र ारंि से पूवग ऐसे ककसी अमिकारी या अन्य किगचारी द्व ारा की गई ककसी सेवा को,`
  line `यथामस्थमि, समिमि या राज्य समिमि के अिीि की गई सेवा िािा जाए गा।`
  line `49. सद्भावपूवगक की गई कारगवाई के मिए संरिर् — इस अमिमियि के अिीि सद्भावपूवगक की गई या ककए जािे के मिए`
  line `आशमयि ककसी बाि के मिए कोई वाद या अमियोजि या अन्य मवमिक कायगवामहयां सरकार या सरकार के ककसी अमिकारी या`
  line `किगचारी या इस अमिमियि के अिीि गरठि समिमि के मवरुद्ध िहीं की जाएंगी।`
  line `50. करठिाइयों को दूर करिे की श मि — ( 1 ) यकद इस अमिमियि के उपबंिों को प्र िावी करिे िें कोई करठिाई उत्प न् ि होिी`
  line `है िो केन्रीय सरकार ऐसे आदेश द्व ारा, जो इस अमिमियि के उपबंिों से असंगि ि हों, उस करठिाई को दूर कर सकेगी:`
  line `परन्िु ऐसा कोई आदेश इस अमिमियि के प्र ारंि से दो वषग की अवमि की सिा मप्ि के प श् चा ि् िहीं ककया जाएगा।`
  line `( 2 ) इस िारा के अिीि ककया गया कोई आदेश उसके ककए जािे के प श् चा ि् यथाशीघ्र संसद् के प्रत् येक सदि के सिि`
  line `रखा जाएगा।`
  line `51. मिदेश देिे की श मि — केन्रीय सर कार, इस अमिमियि के अिीि अपिी श मि यों का प्र योग और कृत्यों का मिवगहि करिे हु`
  line `ए, समिमि या राज्य सरकार या राज्य समिमि को मिमखि रू प िें मिदेश जारी कर सकेगी और, यथामस्थमि, ऐसी समिमि या राज्य`
  line `सरकार या राज्य समिमि ऐसे मिदेशों का पािि करिे के मिए बाध्य होंगी।`
  line `52. मिरसि — ( 1 ) हज समिमि अमिमियि, 1959 ( 1959 का 51 ) इसके द्व ारा मिरमसि ककया जािा है।`
  line `( 2 ) ऐसे मिरसि के होिे हु ए िी, उ ि अमिमियि के अिीि गरठि हज समिमि, इस अमिमियि के अिीि समिमि की स् थापिा`
  line `के सिय िक ऐसे कायग करिी रहेगी िािो यह अमिमियि पाररि ि हु आ हो और िारा 5 के अिीि ऐसी अमिसूचिा पर समिमि की स्`
  line `थापिा होिे पर पूवग समिमि मवघरटि हो जाएगी।`
  line `( 3 ) ऐसे मिरसि के होिे हु ए िी, हज समिमि अमिमियि, 1959 ( 1959 का 51 ) के अिीि की गई कोई बाि या कोई कारगवाई`
  line `इस अमिमियि के ित्स्थािी उपबंिों के अिीि की गई सिझी जाएगी।`
obj_root_law_translations_hi_sections_14_footnotes:
  string
  line
