obj_root_law_sections_1:
  sectionId (50770)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50770&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Rashtriya Raksha University`
  line `Act, 2020.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st October, 2020, vide notification No. S.O. 3422(E), dated 30th September, 2020, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3 (ii).`
obj_root_law_sections_2:
  sectionId (50771)
  sectionNo (2)
  orderNo 2
  title `Declaration of Rashtriya Raksha University as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50771&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_2_content:
  string
  line `Whereas the objects of the Rashtriya Raksha University are such as to make it an`
  line `institution of national importance, it is hereby declared that the Rashtriya Raksha University is an`
  line `institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (50772)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50772&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the University referred to in section 17;`
  line
  line `(b) "affiliated college" means an institution recognised as such by the Executive Council in`
  line `accordance with the provisions of this Act and the Statutes made thereunder;`
  line
  line `(c) "college" means an institution maintained by or admitted to the privileges of the University`
  line `and includes an affiliated college;`
  line
  line `(d) "Dean" means the Dean of the University appointed under section 25;`
  line
  line `(e) "department" means an academic department of the University;`
  line
  line `(f) "distance education system" means the system of imparting education through any means of`
  line `communication, such as, broadcasting, telecasting, internet, correspondence courses, seminars,`
  line `contact programmes or the combination of any two or more such modes;`
  line
  line `(g) "employee" means any person appointed by the University and includes teachers, other`
  line `academic and non-academic staff of the University;`
  line
  line `(h) "Executive Council" means the Executive Council of the University constituted under`
  line `section 16;`
  line
  line `(i) "Finance Committee" means the Finance Committee of the University constituted under`
  line `section 19;`
  line
  line `(j) "Fund" means the Fund of University referred to in section 31;`
  line
  line `(k) "Governing Body" means the Governing Body of the University constituted under section 13;`
  line
  line `(l) "notification" means a notification published in the Official Gazette;`
  line
  line `(m) "Pro Vice-Chancellor" means the Pro Vice-Chancellor of the University appointed under`
  line `section 23;`
  line
  line `(n) "Registrar" means the Registrar of the University appointed under section 24;`
  line
  line `(o) "School" means a school of study of the University;`
  line
  line `(p) "Statutes" and "Ordinances" mean, respectively, the Statutes and Ordinances of the University`
  line `made under this Act;`
  line
  line `(q) "student" means a student of the University and includes any person who has enrolled for`
  line `pursuing any course of study in the University;`
  line
  line `(r) "teachers" means professors, associate professors and assistant professors appointed or`
  line `recognised as such by Statutes for the purposes of imparting instruction in the University or for giving`
  line `guidance for research or rendering assistance to students for pursuing any course of study in the`
  line University;
  line
  line `(s) "University" means the Rashtriya Raksha University established under section 4;`
  line
  line `(t) "Vice-Chancellor" means the Vice-Chancellor of the University appointed under section 22.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (50773)
  sectionNo (4)
  orderNo 4
  title `Establishment and incorporation of University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50773&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_4_content:
  string
  line `(1) The Raksha Shakti University in the State`
  line `of Gujarat, established under the Raksha Shakti University Act, 2009 (Gujarat Act 14 of 2009), shall be`
  line `established as a body corporate under this Act by the name of Rashtriya Raksha University.`
  line
  line `(2) The Rashtriya Raksha University shall be a body corporate having perpetual succession and a`
  line `common seal with power, subject to the provisions of this Act, to acquire, hold and dispose of property`
  line `and to contract, and shall, by the said name, sue or be sued.`
  line
  line `(3) The Headquarters of the University shall be at Gandhinagar in the State of Gujarat.`
  line
  line `(4) The University may establish and maintain centres and campuses at such other places in India and`
  line `abroad as it may deem fit.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (50774)
  sectionNo (5)
  orderNo 5
  title `Effect of incorporation of University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50774&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_5_content:
  string
  line `On and from the date of commencement of this Act,--`
  line
  line `(a) any reference to the Raksha Shakti University in any contract or other instrument shall be`
  line `deemed as a reference to the University;`
  line
  line `(b) all property, movable and immovable, of or belonging to the Raksha Shakti University shall`
  line `vest in the University;`
  line
  line `(c) all rights and liabilities of the Raksha Shakti University shall be transferred to, and be the`
  line `rights and liabilities of, the University;`
  line
  line `(d) every person employed by the Raksha Shakti University immediately before the`
  line `commencement of this Act shall hold his office or service in the University by the same tenure, at the`
  line `same remuneration and upon the same terms and conditions and with the same rights and privileges`
  line `as to pension, leave, gratuity, provident fund and other matters as he would have held the same if this`
  line `Act had not been enacted, and shall continue to do so unless and until his employment is terminated`
  line `or until such tenure, remuneration and terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the University in accordance with the term of the contract with the employee or, if`
  line `no provision is made therein in this behalf, on payment to him by the University of compensation`
  line `equivalent to three months' remuneration in case of permanent employees and one month's`
  line `remuneration in the case of other employees:`
  line
  line `Provided further that every person employed before the commencement of this Act, pending the`
  line `execution of a contract, shall be deemed to have been appointed in accordance with the provisions of`
  line `a contract consistent with the provisions of this Act and the Statutes:`
  line
  line `Provided also that any reference, by whatever form of words, to the Vice-Chancellor of the`
  line `Raksha Shakti University in any law for the time being in force, or in any instrument or other`
  line `document, shall be construed as a reference to the Vice-Chancellor of the University;`
  line
  line `(e) every person pursuing any academic or research course in every existing institute or`
  line `department under Raksha Shakti University, immediately before commencement of this Act, shall be`
  line `deemed to have migrated and registered with the corresponding institute or department, on such`
  line `commencement at the same level of course in the University from which such person migrated and`
  line `shall continue to pursue such academic or research course in the University;`
  line
  line `(f) all suits and other legal proceedings instituted by or against Raksha Shakti University,`
  line `immediately before the commencement of this Act, shall be continued or instituted by or against the`
  line University;
  line
  line `(g) all colleges, institutions, faculties and departments affiliated to, or admitted to the privileges`
  line `of, or maintained by, the Raksha Shakti University shall stand affiliated to, or admitted to the`
  line `privilege of, or maintained by, the University.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (50775)
  sectionNo (6)
  orderNo 6
  title `Objects of University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50775&sectionno=6&orderno=6&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_6_content:
  string
  line `The objects of the University shall be to promote global standards and to`
  line provide--
  line
  line `(a) dynamic and high standards of learning and research;`
  line
  line `(b) working environment dedicated to the advancement and dissemination of education, research,`
  line `training and scholarship of the highest quality in the domain of policing including coastal policing,`
  line `security, law enforcement, criminal justice, cyber security, cyber crime, artificial intelligence and`
  line `related areas of internal security; and`
  line
  line `(c) public safety with a view to build human capital having the highest ideals of citizenship and`
  line `citizen centric services with special reference to women, weaker sections and minorities, who are`
  line `endowed with the necessary intellectual acumen, moral commitment and professional competence to`
  line `meet hands-on, the challenges of crime, justice and public safety in a free society.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (50776)
  sectionNo (7)
  orderNo 7
  title `Powers and functions of University.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50776&sectionno=7&orderno=7&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_7_content:
  string
  line `(1) Subject to the provisions of this Act, the University`
  line `shall exercise the following powers and perform the following functions, namely:--`
  line
  line `(a) to provide instructions and research in such branches of police sciences including coastal`
  line `policing, security, cyber security, artificial intelligence, cyber crime, risk management, social sciences`
  line `including studies related to gender sensitisation, minorities and weaker sections, juvenile justice and`
  line `such other subjects relevant for the Government as well as private sector, as the University may think`
  line `fit, and for the advancement of learning, research and dissemination of knowledge in such branches;`
  line
  line `(b) to plan and prescribe courses of study such as degrees, diplomas and certificates including`
  line `in-service courses of short and long duration;`
  line
  line `(c) to endeavour to design and conduct through its affiliated colleges, integrated courses including`
  line `post-matriculation in policing related or allied subjects;`
  line
  line `(d) to hold examinations and grant degrees, diplomas, certificates and other academic`
  line distinctions;
  line
  line `(e) to confer honorary degrees or other distinctions;`
  line
  line `(f) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, of evaluation or any other method of testing, and to withdraw any such diplomas, certificates,`
  line `degrees or other academic distinctions for good and sufficient cause;`
  line
  line `(g) to provide facilities through distance education system to such persons as it may determine;`
  line
  line `(h) to introduce semester system, continuous evaluation and choice-based credit system and enter`
  line `into agreements with other Universities and academic institutions for credit transfer and joint degree`
  line programmes;
  line
  line `(i) to obtain accreditation from the National Assessment and Accreditation Council or any other`
  line `accrediting agency at the national level;`
  line
  line `(j) to introduce e-governance with an effective management information system;`
  line
  line `(k) to fix, demand and receive fees and other charges;`
  line
  line `(l) to establish, maintain and manage colleges, institutions and halls in other States and Union`
  line `territories and hostels for the residence of students;`
  line
  line `(m) to establish such centres and specialised laboratories or other units for research and`
  line `instructions as are, in the opinion of the University, necessary for the furtherance of its objects;`
  line
  line `(n) to supervise and control the residence and regulate the discipline of students of the University`
  line `and to make arrangements for promoting their health, general welfare, cultural and corporate life;`
  line
  line `(o) to institute academic and other posts and to make appointments thereto (except in the case of`
  line `the Vice-Chancellor) as may be necessary for imparting instructions and managing all affairs of the`
  line University;
  line
  line `(p) to appoint persons working in any other University or academic institution, including those`
  line `located outside the country as teachers of the University for a specified period;`
  line
  line `(q) to co-operate, collaborate or partner or associate with educational or other institutions and`
  line `organisations, public and private, including those located outside the country having objects wholly or`
  line `partly similar to those of the University by exchange of teachers and scholars and generally in such`
  line `manner as may be conducive to their common objects;`
  line
  line `(r) to institute and award fellowships, scholarships, exhibitions, prizes and medals;`
  line
  line `(s) to provide for the preparation of instructional material, including related software and other`
  line `audio-visual aids;`
  line
  line `(t) to make provisions for research and development in areas of core competence of the`
  line University;br
  line
  line `(u) to enter into, carry out, vary or cancel contracts;`
  line
  line `(v) to provide, control and maintain discipline among the students and all categories of employees`
  line `and to lay down the conditions of service of such employees including their code of conduct;`
  line
  line `(w) to establish and maintain such infrastructure as may be necessary;`
  line
  line `(x) to set up campuses across the country and off-shore campuses as per requirement;`
  line
  line `(y) to admit foreign students, Overseas Citizen of India card holder, Person of Indian Origin,`
  line `non-resident Indian, children of Indian workers in Gulf and South East Asian Countries, in such`
  line `manner and as may be laid down in the Statutes;`
  line
  line `(z) to do all such things as may be necessary, incidental or conducive to the attainment of all or`
  line `any of the objects of the University.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the University shall not dispose of in any`
  line `manner any immovable property without the prior approval of the Central Government.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (50777)
  sectionNo (8)
  orderNo 8
  title `Jurisdiction of University.`
  content `The jurisdiction of the University shall extend to the whole of India.`
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50777&sectionno=8&orderno=8&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (50778)
  sectionNo (9)
  orderNo 9
  title `University to be open to all races, creeds and classes.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50778&sectionno=9&orderno=9&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_9_content:
  string
  line `(1) The University shall be open to all`
  line `persons irrespective of gender, race, caste, creed, disability, domicile, ethnicity, social or economic`
  line background.
  line
  line `(2) No bequest, donation or transfer of any property shall be accepted by the University which in the`
  line `opinion of the Executive Council involves conditions or obligations opposed to the spirit and object of`
  line `this section.`
  line
  line `(3) Admissions to every academic programme of study in the University shall be based on merit`
  line `assessed through transparent and reasonable criteria disclosed prior to the commencement of the process`
  line `of admission by the University:`
  line
  line `Provided that the University shall be a Central Educational Institution for the purposes of the Central`
  line `Educational Institutions (Reservation in Admission) Act, 2006 (5 of 2007).`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (50779)
  sectionNo (10)
  orderNo 10
  title `Admission of students.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50779&sectionno=10&orderno=10&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_10_content:
  string
  line `(1) It shall be the endeavour of the University to take necessary`
  line `measures to maintain an all-India character, high standard of teaching and research.`
  line
  line `(2) Admission of students for courses in the University shall be made on an all-India basis in such`
  line `manner as may be specified in the Ordinances.`
  line
  line `(3) Admission of students on international basis may be made in such manner as may be laid down in`
  line `the Statutes and the directions or instructions or guidelines issued by the Central Government in this`
  line behalf.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (50780)
  sectionNo (11)
  orderNo 11
  title `Teaching at University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50780&sectionno=11&orderno=11&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_11_content:
  string
  line `All teaching at the University shall be in accordance with the Statutes`
  line `and Ordinances made in this behalf.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (50781)
  sectionNo (12)
  orderNo 12
  title `Authorities of University.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50781&sectionno=12&orderno=12&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_12_content:
  string
  line `The following shall be the authorities of the University, namely:--`
  line
  line `(a) Governing Body;`
  line
  line `(b) Executive Council;`
  line
  line `(c) Academic Council;`
  line
  line `(d) Finance Committee; and`
  line
  line `(e) such other authorities as may be laid down in the Statutes to be the authorities of the`
  line University.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (50782)
  sectionNo (13)
  orderNo 13
  title `Governing Body.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50782&sectionno=13&orderno=13&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_13_content:
  string
  line `(1) The Central Government may, by the notification in the Official Gazette,`
  line `constitute a Governing Body of the University from such date as it may specify therein.`
  line
  line `(2) The Governing Body shall consist of not more than fifteen members including the Chairperson,`
  line `with majority of members from academia, industry and relevant professional fields, to be nominated by`
  line `the Central Government including the following, namely:--`
  line
  line `(a) Chairperson;`
  line
  line `(b) Vice-Chancellor of the University, ex officio;`
  line
  line `(c) one representative of the Ministry of Home Affairs not below the rank of Joint Secretary,`
  line `ex officio;`
  line
  line `(d) an officer of Indian Legal Service, not below the rank of Joint Secretary, to be nominated by`
  line `the Central Government, ex officio;`
  line
  line `(e) two representatives of the Government of Gujarat being officers not below the rank of`
  line `Secretary in that Government;`
  line
  line `(f) one representative of State Police Universities by rotation;`
  line
  line `(g) one person of eminence from the academia or field of education;`
  line
  line `(h) one person of eminence or expertise from the industry or corporate sector;`
  line
  line `(i) one person to be an expert of global eminence from a field having relevance to the objects of`
  line `the University;`
  line
  line `(j) not more than three persons having expertise in defence, policing, internal security and allied`
  line fields.
  line
  line `(3) The Central Government may, in consultation with such State Governments as it deems fit,`
  line `appoint the Chairperson of the Governing Body, who shall be an eminent person from the field of`
  line `academia, defence, security, law enforcement or internal security.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (50783)
  sectionNo (14)
  orderNo 14
  title `Term of office, vacancies among, and allowances payable to, members of Governing Body.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50783&sectionno=14&orderno=14&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_14_content:
  string
  line `(1) Save as otherwise provided in this section, the term of office of a member of the Governing`
  line `Body, other than an ex officio member, shall be for a period of three years from the date of nomination.`
  line
  line `(2) The term of office of an ex officio member shall continue so long as he holds the office by virtue`
  line `of which he is a member.`
  line
  line `(3) The term of office of a member nominated to fill a casual vacancy shall continue for the`
  line `remainder of the term of the member in whose place he has been nominated.`
  line
  line `(4) Notwithstanding anything contained in this section, an outgoing member shall, unless the`
  line `Governing Body otherwise directs, continue in office until another person is nominated as a member in`
  line `his place.`
  line
  line `(5) The members of the Governing Body shall be entitled to such travelling and other allowances as`
  line `may be laid down in the Statutes, but no member shall be entitled to any salary by reason of this`
  line sub-section.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (50784)
  sectionNo (15)
  orderNo 15
  title `Powers and functions of Governing Body.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50784&sectionno=15&orderno=15&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_15_content:
  string
  line `(1) Subject to the provisions of this Act, the`
  line `Governing Body of the University shall be responsible for the general policy making, superintendence,`
  line `direction and control of the affairs of the University and shall exercise all the powers of the University not`
  line `otherwise provided for by this Act, the Statutes and the Ordinances, and shall have the power to review`
  line `the acts of the Academic Council.`
  line
  line `(2) It shall be the general duty of the Governing Body to co-ordinate the activities of the University.`
  line
  line `(3) Without prejudice to the provisions of sub-section (2), the Governing Body shall perform the`
  line `following functions, namely:--`
  line
  line `(a) to formulate and review the broad policies and programmes of the University and suggest`
  line `measures for the development of the University;`
  line
  line `(b) to advise on matters relating to the duration of the courses, degrees and other academic`
  line `distinctions to be conferred by the University, admission standards and other academic matters;`
  line
  line `(c) to lay down policy regarding cadres, methods of recruitment and conditions of service of`
  line `employees, institution of scholarships and fellowships, levying of fees and other matters of common`
  line interest;
  line
  line `(d) to examine the development plans of the University and to approve such of them as are`
  line `considered necessary and also to indicate broadly the financial implications of such approved plans;`
  line
  line `(e) to examine the annual budget estimates of the University and to recommend to the Central`
  line `Government the allocation of funds for that purpose;`
  line
  line `(f) to lay down the policy and take decisions on questions of policy relating to the administration`
  line `and working of the University;`
  line
  line `(g) to institute courses of study;`
  line
  line `(h) to make Statutes;`
  line
  line `(i) to institute and appoint persons to academic as well as other posts;`
  line
  line `(j) to make necessary recommendation in matters for the furtherance of the objective of the`
  line University;
  line
  line `(k) to consider and direct the Executive Council to amend or repeal Ordinances;`
  line
  line `(l) to consider and pass resolutions on the annual report, annual accounts and the budget estimates`
  line `of the University for the next financial year, together with a statement of its development plans,`
  line `submitted by the Executive Council and Academic Council, as it thinks fit;`
  line
  line `(m) to delegate any of its powers to the Executive Council, Vice-Chancellor, Pro Vice-Chancellors, Deans, Registrar or any authority of the University or to a committee or to any other`
  line `officer or employee, of the University;`
  line
  line `(n) to exercise such other powers and perform such other duties as may be conferred or imposed`
  line `upon it by this Act or the Statutes.`
  line
  line `(4) The Governing Body shall have the power to appoint such committees as it considers necessary`
  line `for the exercise of its powers and the performance of its duties under this Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (50785)
  sectionNo (16)
  orderNo 16
  title `Executive Council.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50785&sectionno=16&orderno=16&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_16_content:
  string
  line `(1) The Executive Council shall be the principal executive body of the`
  line University.
  line
  line `(2) The Vice-Chancellor shall be the ex officio Chairperson of the Executive Council.`
  line
  line `(3) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be such as may be laid down in the Statutes:`
  line
  line `Provided that such number of members as may be laid down in the Statutes shall be from among the`
  line `members of the Governing Body.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (50786)
  sectionNo (17)
  orderNo 17
  title `Academic Council.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50786&sectionno=17&orderno=17&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_17_content:
  string
  line `The Academic Council of the University shall consist of the following`
  line `persons, namely:--`
  line
  line `(a) the Vice-Chancellor shall be the ex officio`
  line `Chairperson of the Academic Council;`
  line
  line `(b) the professors appointed or recognised as such by the University for the purpose of imparting`
  line instruction;
  line
  line `(c) three persons to be appointed by the Governing Body from among persons of national or`
  line `international eminence in the industry or academia having relevance to the objects of the University;`
  line
  line `(d) two persons, not being employees of the University, to be nominated by the Vice-Chancellor,`
  line `from amongst educationists of repute;`
  line
  line `(e) one person with wide experience in policing and internal security on rotation from States and`
  line `Union territories to be nominated by the Central Government; and`
  line
  line `(f) two persons from international universities to be nominated by the Governing Body.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (50787)
  sectionNo (18)
  orderNo 18
  title `Functions of Academic Council.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50787&sectionno=18&orderno=18&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_18_content:
  string
  line `The Academic Council shall be the principal academic body`
  line `of the University and shall, subject to the provisions of this Act, the Statutes and Ordinances made thereunder, co-ordinate and exercise control and general supervision over the academic policies of the`
  line `University and shall be responsible for the maintenance of standards of learning, education, instruction,`
  line `evaluation and examinations within the University and shall exercise such other powers and perform such`
  line `other functions as may be conferred or imposed upon it by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (50788)
  sectionNo (19)
  orderNo 19
  title `Finance Committee.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50788&sectionno=19&orderno=19&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_19_content:
  string
  line `The constitution, powers and functions of the Finance Committee shall be`
  line `such as may be laid down in the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (50789)
  sectionNo (20)
  orderNo 20
  title `Board for Affiliation and Recognition.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50789&sectionno=20&orderno=20&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_20_content:
  string
  line `(1) The Board for Affiliation and Recognition shall be`
  line `responsible for admitting colleges and institutions to the privileges of the University.`
  line
  line `(2) The constitution of the Board for Affiliation and Recognition, the term of office of its members`
  line `and its powers and duties shall be such as may be laid down in the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (50790)
  sectionNo (21)
  orderNo 21
  title `Officers of University.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50790&sectionno=21&orderno=21&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_21_content:
  string
  line `The following shall be the officers of the University, namely:--`
  line
  line `(a) Vice-Chancellor;`
  line
  line `(b) Pro Vice-Chancellor;`
  line
  line `(c) Registrar;`
  line
  line `(d) Dean;`
  line
  line `(e) Finance Officer; and`
  line
  line `(f) such other officers as may be laid down in the Statutes to be officers of the University.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (50791)
  sectionNo (22)
  orderNo 22
  title Vice-Chancellor.
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50791&sectionno=22&orderno=22&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_22_content:
  string
  line `(1) The Central Government may, in consultation with such State`
  line `Governments as it deems fit, appoint the Vice-Chancellor of the University, who shall be a person`
  line `possessing the highest level of competence, integrity, moral and institutional commitment, with extensive`
  line `knowledge in policing or research or administration or social sciences, preferably having wide experience`
  line `in police training and internal security or a distinguished academician with a minimum of ten years`
  line `administrative experience in a reputed research or academic organisation.`
  line
  line `(2) The Vice-Chancellor shall be principal academic and chief executive officer of the University and`
  line `shall be responsible for the proper administration of the University and for the imparting of instruction`
  line `and maintenance of discipline therein.`
  line
  line `(3) The Vice-Chancellor shall submit annual reports and accounts to the Governing Body.`
  line `(4) It shall be the duty of the Vice-Chancellor to ensure that decisions taken by the Governing Body`
  line `are implemented.`
  line
  line `(5) The Vice-Chancellor shall ordinarily preside over the meetings of the Academic Council and`
  line `convocations of the University.`
  line
  line `(6) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `assigned to him by this Act or laid down in the Statutes or Ordinances.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (50792)
  sectionNo (23)
  orderNo 23
  title `Pro Vice-Chancellor.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50792&sectionno=23&orderno=23&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_23_content:
  string
  line `The Pro Vice-Chancellor of the University shall be appointed in such`
  line `manner, on such emoluments and other conditions of service and shall exercise such powers and perform`
  line `such duties, as may be laid down in the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (50793)
  sectionNo (24)
  orderNo 24
  title Registrar.
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50793&sectionno=24&orderno=24&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_24_content:
  string
  line `(1) The Registrar of the University shall be appointed in such manner and on such`
  line `terms and conditions as may be laid down in the Statutes.`
  line
  line `(2) The Registrar shall be the custodian of records, common seal, funds of the University and such`
  line `other property of the University as the Governing Body shall commit to his charge.`
  line
  line `(3) The Registrar shall act as the Secretary of the Governing Body, the Executive Council, the`
  line `Academic Council and such other committees as may be laid down in the Statutes.`
  line
  line `(4) The Registrar shall be responsible to the Vice-Chancellor for the proper discharge of his`
  line functions.
  line
  line `(5) The Registrar shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by this Act or the Statutes or by the Vice-Chancellor.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (50794)
  sectionNo (25)
  orderNo 25
  title Dean.
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50794&sectionno=25&orderno=25&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_25_content:
  string
  line `The Dean of the University shall be appointed in such manner, on such emoluments and`
  line `other conditions of service and shall exercise such powers and perform such duties, as may be laid down`
  line `in the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (50795)
  sectionNo (26)
  orderNo 26
  title `Finance Officer.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50795&sectionno=26&orderno=26&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_26_content:
  string
  line `The Finance Officer shall be appointed in such manner, on such emoluments`
  line `and other conditions of service and shall exercise such powers and perform such duties, as may be laid`
  line `down in the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (50796)
  sectionNo (27)
  orderNo 27
  title `Other authorities and officers.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50796&sectionno=27&orderno=27&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_27_content:
  string
  line `The powers and duties of other authorities and officers, other`
  line `than those hereinbefore mentioned, of the University including their terms and conditions of service shall`
  line `be such as may be laid down in the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (50797)
  sectionNo (28)
  orderNo 28
  title `Grants by Central Government.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50797&sectionno=28&orderno=28&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_28_content:
  string
  line `For the purpose of enabling the University to discharge its`
  line `functions efficiently under this Act, the Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the University in each financial year such sums of money in such`
  line `manner as it may think fit.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (50798)
  sectionNo (29)
  orderNo 29
  title `Grants by State Governments.`
  content `The University may receive such sums of money as grants-inaid annually or as one-time grant from any State Government.`
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50798&sectionno=29&orderno=29&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (50799)
  sectionNo (30)
  orderNo 30
  title `Corpus of University.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50799&sectionno=30&orderno=30&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_30_content:
  string
  line `The University may receive funds from the Central Government or State`
  line `Governments or other sources or use its funds to maintain and operate a corpus of the University.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (50800)
  sectionNo (31)
  orderNo 31
  title Fund.
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50800&sectionno=31&orderno=31&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_31_content:
  string
  line `(1) The University shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government;`
  line
  line `(b) all moneys received from State Governments;`
  line
  line `(c) all fees and other charges received by the University;`
  line
  line `(d) all moneys received by the University by way of grants, gifts, donations, benefactions,`
  line `bequests or transfers; and`
  line
  line `(e) all moneys received by the University in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund of the University shall be deposited in such banks or invested in`
  line `such manner as the University may, with the approval of the Central Government, decide.`
  line
  line `(3) The Fund of the University shall be applied towards meeting its expenses including expenditure`
  line `incurred in the exercise of its powers and discharge of its duties under this Act.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (50801)
  sectionNo (32)
  orderNo 32
  title `Accounts and audit.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50801&sectionno=32&orderno=32&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_32_content:
  string
  line `(1) The University shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts including the balance-sheet in such form and`
  line `accounting standard as may be specified, by notification, by the Central Government in consultation with`
  line `the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the University shall be audited by the Comptroller and Auditor-General of India`
  line `and any expenditure incurred by it in connection with such audit shall be payable by it to the Comptroller`
  line `and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the University shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts, and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line University.
  line
  line `(4) The accounts of the University as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (50802)
  sectionNo (33)
  orderNo 33
  title `Pension and provident fund.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50802&sectionno=33&orderno=33&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_33_content:
  string
  line `(1) The University may constitute for the benefit of its employees`
  line `such provident or pension fund or provide such insurance scheme as it may deem fit in such manner and`
  line `subject to such conditions as may be laid down in the Statutes.`
  line
  line `(2) Where any provident fund has been constituted under sub-section (1), the Central Government`
  line `may declare that the provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to such fund as`
  line `if it were a Government provident fund.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (50803)
  sectionNo (34)
  orderNo 34
  title `Annual report of University.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50803&sectionno=34&orderno=34&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_34_content:
  string
  line `(1) The annual report of the University shall be prepared by the`
  line `Executive Council, which shall include, among other matters, the steps taken by the University towards`
  line `the fulfilment of its objects and an outcome based assessment of the research being undertaken by it, and`
  line `be submitted to the Governing Body on or before such date as may be specified and the Governing Body`
  line `shall consider the report in its annual meeting.`
  line
  line `(2) The annual report as approved by the Governing Body shall be published and placed on the`
  line `website of the University.`
  line
  line `(3) The Executive Council shall prepare and release for every year a report, in English and in Hindi,`
  line `the working of the University in the previous year on or before the expiry of nine months from the close`
  line `of financial year, and a copy of the same, together with an audited statement of accounts showing the income and expenditure for the previous year shall be submitted to the Central Government within that`
  line `stipulated time, and the same may be caused to be laid before each House of Parliament.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (50804)
  sectionNo (35)
  orderNo 35
  title Appointments.
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50804&sectionno=35&orderno=35&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_35_content:
  string
  line `All appointments of the employees of the University, except that of the`
  line `Vice-Chancellor, shall be made in accordance with the procedure laid down in the Statutes, by--`
  line
  line `(a) the Governing Body, if the appointment is made on the academic staff in the post of Assistant`
  line `Professor or above, or if the appointment is made on the non-academic staff, in any post equivalent to`
  line `Group 'A' and above;`
  line
  line `(b) by the Vice-Chancellor, in any other case.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (50805)
  sectionNo (36)
  orderNo 36
  title Statutes.
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50805&sectionno=36&orderno=36&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_36_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:--`
  line
  line `(a) the manner of recognition of an institution by the Executive Council as affiliated college;`
  line
  line `(b) the constitution, powers and functions of, authorities and other bodies including disciplinary`
  line `committee and examination committee, of the University as may be constituted from time to time;`
  line
  line `(c) the appointment and continuance in office of the members of the said authorities and bodies,`
  line `the filling up of vacancies of members, and all other matters relating to those authorities and other`
  line `bodies for which it may be necessary or desirable to provide;`
  line
  line `(d) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(e) the appointment of teachers, academic staff and other employees of the University, their`
  line `emoluments and conditions of service;`
  line
  line `(f) the appointment of teachers and academic staff working in any other University or`
  line `organisation for a specific period for undertaking a joint project;`
  line
  line `(g) the conditions of service of employees including provisions for pension, insurance, provident`
  line `fund, the manner of termination of service and disciplinary action;`
  line
  line `(h) the principles governing the seniority of service of the employees of the University;`
  line
  line `(i) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(j) the procedure for appeal to the Governing Body by any employee or student against the action`
  line `of any officer or authority of the University;`
  line
  line `(k) the conferment of autonomous status on a college or an institution or a department;`
  line
  line `(l) the establishment and abolition of Schools, departments, centres, halls, colleges and`
  line institutions;
  line
  line `(m) the manner of co-operation and collaboration with other Universities, institutions and other`
  line `agencies including learned bodies, associations and the private sector;`
  line
  line `(n) the conferment of honorary degrees;`
  line
  line `(o) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(p) the management of colleges and institutions established by the University;`
  line
  line `(q) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(r) the maintenance of discipline among the employees and students; and`
  line
  line `(s) any other matter which by this Act is to be, or may be, laid down in the Statutes.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (50806)
  sectionNo (37)
  orderNo 37
  title `Statutes how made.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50806&sectionno=37&orderno=37&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_37_content:
  string
  line `(1) The first Statute of the University shall be made by the Governing`
  line `Body with the prior approval of the Central Government and a copy of the same shall be laid, as soon as`
  line `may be it is made, before each House of Parliament.`
  line
  line `(2) The Governing Body may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Governing Body shall not make, amend or repeal any Statute affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Governing Body.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (50807)
  sectionNo (38)
  orderNo 38
  title Ordinances.
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50807&sectionno=38&orderno=38&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_38_content:
  string
  line `Subject to the provisions of this Act and the Statutes, the Ordinances may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to`
  line `examinations, degrees and diplomas to the University;`
  line
  line `(f) the conditions and institution for award of fellowships, scholarships, studentships, medals and`
  line prizes;
  line
  line `(g) the conduct of examination including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence and teaching of women`
  line `students and the specifying of special courses of studies for them;`
  line
  line `(j) the establishment of centres of studies, boards of studies, specialised laboratories and other`
  line committees;
  line
  line `(k) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(l) the setting up of machinery for redressal of grievances of employees and students; and`
  line
  line `(m) any other matter which by this Act or Statutes, is to be, or may be, specified in the`
  line Ordinances.
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (50808)
  sectionNo (39)
  orderNo 39
  title `Ordinances how made.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50808&sectionno=39&orderno=39&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_39_content:
  string
  line `(1) Save as otherwise provided in this section, Ordinances shall be`
  line `made by the Executive Council.`
  line
  line `(2) All Ordinances made by the Executive Council shall have effect from such date as it may direct,`
  line `but every Ordinance so made shall be submitted, as soon as may be, to the Governing Body and shall be`
  line `considered by the Governing Body at its next succeeding meeting.`
  line
  line `(3) The Governing Body shall have power by resolution to approve, modify or cancel any such`
  line `Ordinance and such Ordinance shall from the date of such resolution stand modified accordingly or`
  line `cancelled, as the case may be.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (50809)
  sectionNo (40)
  orderNo 40
  title `Tribunal of Arbitration for employees.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50809&sectionno=40&orderno=40&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_40_content:
  string
  line `(1) Every employee of the University shall be`
  line `appointed under a written contract, which shall be retained by the University and a copy of the same shall`
  line `be given to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Executive Council, one member nominated by the employee concerned and chaired by an umpire`
  line `appointed by the Governing Body.`
  line
  line `(3) The decision of the Tribunal of Arbitration shall be final and no suit shall lie in any civil court in`
  line `respect of the matters decided by the said Tribunal: Provided that nothing in this sub-section shall`
  line `preclude the employee from availing of the judicial remedies available under articles 32 and 226 of the`
  line Constitution.
  line
  line `(4) Every request made by the employee under sub-section (2) shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation`
  line `Act, 1996 (26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be laid down in the Statutes.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (50810)
  sectionNo (41)
  orderNo 41
  title `Redressal for debarment from examination and disciplinary action against students.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50810&sectionno=41&orderno=41&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_41_content:
  string
  line `(1) Any student or candidate for an examination whose name has been removed from the rolls`
  line `of the University by an order of the Vice-Chancellor on the recommendation of the disciplinary`
  line `committee or examination committee, as the case may be, and who has been debarred from appearing at`
  line `the examinations of the University for more than one year, may, within ten days of the date of receipt of`
  line `such order by him, appeal to the Governing Body and the Governing Body may confirm, modify or`
  line `reverse the decision of the Vice-Chancellor.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-sections`
  line `(2), (3), (4) and (5) of section 40 shall apply to a reference made under this sub-section.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (50811)
  sectionNo (42)
  orderNo 42
  title `Disputes as to constitution of authorities and bodies.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50811&sectionno=42&orderno=42&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_42_content:
  string
  line `If any question arises as to whether any`
  line `person has been duly elected or appointed as, or is entitled to be, a member of any authority or other body`
  line `of the University, the matter shall be referred to the Central Government, and the decision of that`
  line `Government thereon shall be final.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (50812)
  sectionNo (43)
  orderNo 43
  title `Power of Central Government to make rules in respect of matters relating to Governing Body.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50812&sectionno=43&orderno=43&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_43_content:
  string
  line `(1) The Central Government may, after previous publication, make rules to carry out the`
  line `purposes relating to Governing Body.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:---`
  line
  line `(a) the manner of filling vacancies among the members of the Governing Body;`
  line
  line `(b) the disqualifications for being chosen as, and for being a member of the Governing Body;`
  line
  line `(c) the circumstances in which, and the authority by which, members may be removed;`
  line
  line `(d) the meetings of the Governing Body and the procedure for conduct of business;`
  line
  line `(e) the travelling and other allowances payable to members of the Governing Body; and`
  line
  line `(f) the manner in which functions of the Governing Body may be exercised.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (50813)
  sectionNo (44)
  orderNo 44
  title `Acts and proceeding not to be invalidated by vacancies, etc.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50813&sectionno=44&orderno=44&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_44_content:
  string
  line `No act of the Governing Body`
  line `or any other body set up under this Act or the Statutes, shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or defect in the constitution thereof; or`
  line
  line `(b) any defect in the election, nomination or appointment of a person acting as a member`
  line `thereof; or`
  line
  line `(c) any irregularity in its procedure not affecting the merits of the case.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (50814)
  sectionNo (45)
  orderNo 45
  title `University to be public authority under Right to Information Act.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50814&sectionno=45&orderno=45&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_45_content:
  string
  line `The provisions of the`
  line `Right to Information Act, 2005 (22 of 2005) shall apply to the University, as if it were a public authority`
  line `defined in clause (h) of section 2 of that Act.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (50815)
  sectionNo (46)
  orderNo 46
  title `Power of Central Government to review work and progress made and to hold enquiries.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50815&sectionno=46&orderno=46&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_46_content:
  string
  line `(1) The Central Government may, from time to time, appoint one or more persons to review the work and progress of the University, including colleges and institutions administered by it, and hold`
  line `enquiries thereof and to submit a report thereon in such manner as the Central Government may direct.`
  line
  line `(2) Upon receipt of any such report, the Central Government may, after obtaining the views of the`
  line `Governing Body thereon through the Vice-Chancellor, take such action and issue such directions as it`
  line `considers necessary in respect of any of the matters dealt with in the report and the University shall be`
  line `bound to comply with such directions.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (50816)
  sectionNo (47)
  orderNo 47
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50816&sectionno=47&orderno=47&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_47_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or other employee of the University for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act, the Statutes or the Ordinances made thereunder.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (50817)
  sectionNo (48)
  orderNo 48
  title `Residuary provisions.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50817&sectionno=48&orderno=48&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_48_content:
  string
  line `(1) The Governing Body shall have the authority to deal with any`
  line `matter pertaining to the University and not specifically dealt with in this Act.`
  line
  line `(2) The decision of the Governing Body on all such matters shall, subject to revision by the Central`
  line `Government, be final.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (50818)
  sectionNo (49)
  orderNo 49
  title `Power of Central Government to issue directions.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50818&sectionno=49&orderno=49&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_49_content:
  string
  line `The University shall carry out such`
  line `directions as may be issued to it from time to time by the Central Government for the efficient`
  line `administration of this Act.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (50819)
  sectionNo (50)
  orderNo 50
  title `Power to remove difficulties.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50819&sectionno=50&orderno=50&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_50_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `or give such directions not inconsistent with the provisions of this Act, as appears to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of the period of two`
  line `years from the date of commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (50820)
  sectionNo (51)
  orderNo 51
  title `Laying of rules, Statutes, Ordinances and notifications.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50820&sectionno=51&orderno=51&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_51_content:
  string
  line `(1) Every rule, Statute or Ordinance`
  line `made and every notification issued under this Act shall be published in the Official Gazette.`
  line
  line `(2) Every rule, Statute or Ordinance made and every notification issued under this Act, shall be laid,`
  line `as soon as may be after it is made, before each House of Parliament, while it is in session, for a total`
  line `period of thirty days which may be comprised in one session or in two or more successive sessions, and`
  line `if, before the expiry of the session immediately following the session or the successive sessions aforesaid,`
  line `both Houses agree in making any modification in the rule, Statute, Ordinance or notification or both`
  line `Houses agree that the rule, Statute, Ordinance or notification should not be made, the rule, Statute,`
  line `Ordinance or notification shall thereafter have effect only in such modified form or be of no effect, as the`
  line `case may be; so, however, that any such modification or annulment shall be without prejudice to the`
  line `validity of anything previously done under that rule, Statute, Ordinance or notification.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (50821)
  sectionNo (52)
  orderNo 52
  title `Transitional provisions.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50821&sectionno=52&orderno=52&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_52_content:
  string
  line `(1) The existing Board of Governors, Finance Committee and other`
  line `committees functioning in the Raksha Shakti University, Gujarat shall continue to function till such time`
  line `the University constitutes the authorities or committees under the provisions of this Act.`
  line
  line `(2) The existing officers of the Raksha Shakti University, Gujarat such as, Vice-Chancellor, Registrar`
  line `or Finance Officer, shall continue to function till such time the officers are appointed under the provisions`
  line `of this Act.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (50822)
  sectionNo (53)
  orderNo 53
  title `Repeal of Gujarat Act 14 of 2009.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00048_202031_1602487878914&sectionId=50822&sectionno=53&orderno=53&orgactid=AC_CEN_5_23_00048_202031_1602487878914
obj_root_law_sections_53_content:
  string
  line `(1) The Raksha Shakti University Act, 2009 is hereby`
  line repealed.
  line
  line `(2) Notwithstanding such repeal,--`
  line
  line `(a) all appointments made, orders issued, degrees and other academic distinctions conferred,`
  line `diplomas and certificates awarded, privileges granted, or other things done under the Raksha Shakti`
  line `University Act, 2009, shall be deemed to have been respectively made, issued, conferred, awarded,`
  line `granted or done under the corresponding provisions of this Act and, except as otherwise provided by`
  line `or under this Act or the Statutes, continue in force unless and until they are superseded by any order`
  line `made under this Act or the Statutes; and`
  line
  line `(b) all the proceedings of selection committee or any other authority, if any, for the appointment`
  line `or promotion of teachers and other employees that took place before the commencement of this Act`
  line `and all actions of the concerned authorities in respect of the recommendations of such selection`
  line `committee or authority, if any, where no orders of appointment on the basis thereof were passed`
  line `before the commencement of this Act shall, notwithstanding that the procedure for selection has been`
  line `modified by this Act, be deemed to have been valid but further proceedings in connection with such`
  line `pending selections shall be taken in accordance with the provisions of this Act and be continued from`
  line `the stage where they stood immediately before such commencement, except if the concerned`
  line `authorities take a decision to the contrary.`
obj_root_law_sections_53_footnotes:
  string
  line
