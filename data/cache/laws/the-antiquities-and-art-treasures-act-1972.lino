obj_root_law:
  slug the-antiquities-and-art-treasures-act-1972
  handle (1693)
  collectionHandle 123456789/1362
  title `The Antiquities and Art Treasures Act, 1972`
  actNumber (52)
  enactmentDate 1972-09-09
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1693`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `पुरावशेष तथा बहुमूल्य कलाकृति अधिनियम, 1972`
  actYear (1972)
  ministry `Ministry of Culture`
  department undefined
  longTitle `An Act to regulate the export trade in antiquities and art treasures, to provide for the prevention of smuggling of, and fraudulent dealings in, antiquities, to provide for the compulsory acquisition of antiquities and art treasures for preservation in public places and to provide for certain other matters connected therewith or incidental or ancillary thereto.`
  enforcementDate 05-04-1976
  notification undefined
  fetchedAt `2026-05-09T10:12:02.926Z`
  translations obj_root_law_translations
