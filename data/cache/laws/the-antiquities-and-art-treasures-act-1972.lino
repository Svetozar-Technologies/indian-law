obj_root_law:
  object
  (str slug) (str the-antiquities-and-art-treasures-act-1972)
  (str handle) (str 1693)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Antiquities and Art Treasures Act, 1972`)
  (str actNumber) (str 52)
  (str enactmentDate) (str 1972-09-09)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1693`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `पुरावशेष तथा बहुमूल्य कलाकृति अधिनियम, 1972`)
  (str actYear) (str 1972)
  (str ministry) (str `Ministry of Culture`)
  (str department) (undefined)
  (str longTitle) (str `An Act to regulate the export trade in antiquities and art treasures, to provide for the prevention of smuggling of, and fraudulent dealings in, antiquities, to provide for the compulsory acquisition of antiquities and art treasures for preservation in public places and to provide for certain other matters connected therewith or incidental or ancillary thereto.`)
  (str enforcementDate) (str 05-04-1976)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T10:12:02.926Z`)
  (str translations) obj_root_law_translations
