obj_root_law_sections_1:
  sectionId (11699)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11699&sectionno=1&orderno=1&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Highways`
  line `Authority of India Act, 1988.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 15th June, 1989, vide notification No. S.O. 451(E), dated 15th June, 1989, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (11700)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11700&sectionno=2&orderno=2&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Authority" means the National Highways Authority of India constituted under section 3;`
  line
  line `(b) "Chairman" means the Chairman of the Authority;`
  line
  line `(c) "employee" means a person in the full-time service of the Authority;`
  line
  line `(d) "member" means a member of the Authority appointed under section 3 and includes the`
  line Chairman;
  line
  line `(e) "national highway" means any highway for the time being declared as a national highway`
  line `under section 2 of the National Highways Act, 1956 (48 of 1956);`
  line
  line `(f) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(g) "regulations" means regulations made by the Authority under this Act;`
  line
  line `(h) words and expressions used herein and not defined but defined in the National Highways`
  line `Act, 1956 (48 of 1956) shall have the meanings assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (11701)
  sectionNo (3)
  orderNo 3
  title `Constitution of the Authority.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 19 of 2013, s. 2, for sub-section 3 (w.e.f. 10-9-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11701&sectionno=3&orderno=3&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_3_content:
  string
  line `(1) With effect from such date as the Central Government may,`
  line `by notification in the Official Gazette, appoint in this behalf, there shall be constituted for the purposes of`
  line `this Act an Authority to be called the National Highways Authority of India.`
  line
  line `(2) The Authority shall be a body corporate by the name aforesaid having perpetual succession and a`
  line `common seal, with power, subject to the provisions of this Act, to acquire, hold and dispose of property,`
  line `both movable and immovable, and to contract and shall by the said name sue and be sued.`
  line
  line ^1
  line `[(3) The Authority shall consist of--`
  line
  line `(a) a Chairman;`
  line
  line `(b) not more than six full-time members; and`
  line
  line `(c) not more than six part-time members,`
  line
  line `to be appointed by the Central Government by notification in the Official Gazette:`
  line
  line `Provided that the Central Government shall, while appointing the part-time members, ensure that at`
  line `least two of them are non-Government professionals having knowledge or experience in financial`
  line `management, transportation planning or any other relevant discipline.]`
obj_root_law_sections_4:
  sectionId (11702)
  sectionNo (4)
  orderNo 4
  title `Term of office and conditions of service of members.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11702&sectionno=4&orderno=4&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_4_content:
  string
  line `The term of office and other conditions`
  line `of service of the members shall be such as may be prescribed.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (11703)
  sectionNo (5)
  orderNo 5
  title `Disqualifications for appointment as member.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11703&sectionno=5&orderno=5&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_5_content:
  string
  line `A person shall be disqualified for being`
  line `appointed as a member if he--`
  line
  line `(a) has been convicted and sentenced to imprisonment for an offence which, in the opinion of the`
  line `Central Government, involves moral turpitude; or`
  line
  line `(b) is an undischarged insolvent; or`
  line
  line `(c) is of unsound mind and stands so declared by a competent Court; or`
  line
  line `(d) has been removed or dismissed from the service of the Government or a Corporation owned`
  line `or controlled by the Government; or`
  line
  line `(e) has, in the opinion of the Central Government, such financial or other interest in the Authority`
  line `as is likely to affect prejudicially the discharge by him of his functions as a member.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (11704)
  sectionNo (6)
  orderNo 6
  title `Eligibility of member for reappointment.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11704&sectionno=6&orderno=6&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_6_content:
  string
  line `Subject to the other terms and conditions of service`
  line `as may be prescribed, any person ceasing to be a member shall be eligible for reappointment as such`
  line member.
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (11705)
  sectionNo (7)
  orderNo 7
  title Meetings.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11705&sectionno=7&orderno=7&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_7_content:
  string
  line `(1) The Authority shall meet at such times and places and shall observe such rules of`
  line `procedure in regard to the transaction of business at its meetings, including the quorum thereat, as may be`
  line `provided by regulations.`
  line
  line `(2) If for any reason the Chairman is unable to attend any meeting of the Authority any other member`
  line `chosen by the members present at the meeting shall preside at the meeting.`
  line
  line `(3) All questions which come up before any meeting of the Authority shall be decided by a majority`
  line `of votes of the members present and voting, and in the event of an equality of votes, the Chairman, or in`
  line `his absence the person presiding, shall have and exercise a second or casting vote.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (11706)
  sectionNo (8)
  orderNo 8
  title `Vacancy in the Authority not to invalidate proceedings.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11706&sectionno=8&orderno=8&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_8_content:
  string
  line `No act or proceeding of the Authority`
  line `shall be invalidated merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Authority; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Authority; or`
  line
  line `(c) any irregularity in the procedure adopted by the Authority not affecting the merits of the case.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (11707)
  sectionNo (9)
  orderNo 9
  title `Appointment of officers, consultants and other employees of the Authority.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11707&sectionno=9&orderno=9&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_9_content:
  string
  line `(1) For the`
  line `purpose of discharging its functions, the Authority shall appoint such number of officers and other`
  line `employees as it may consider necessary on such terms and conditions as may be laid down by the`
  line regulations.
  line
  line `(2) The Authority may appoint, from time to time, any person as adviser or consultant as it may`
  line `consider necessary, on such terms and conditions as may be laid down by the regulations.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (11708)
  sectionNo (10)
  orderNo 10
  title `Authority to act on business principles.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11708&sectionno=10&orderno=10&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_10_content:
  string
  line `In the discharge of its functions under this Act, the`
  line `Authority shall act, so far as may be, on business principles.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (11709)
  sectionNo (11)
  orderNo 11
  title `Power of the Central Government to vest or entrust any national highway in the Authority.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11709&sectionno=11&orderno=11&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_11_content:
  string
  line `The Central Government may, from time to time, by notification in the Official Gazette,`
  line `vest in, or entrust to, the Authority, such national highway or any stretch thereof as may be specified in`
  line `such notification.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (11710)
  sectionNo (12)
  orderNo 12
  title `Transfer of assets and liabilities of the Central Government to the Authority.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11710&sectionno=12&orderno=12&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_12_content:
  string
  line `(1) On and`
  line `from the date of publication of the notification under section 11,--`
  line
  line `(a) all debts, obligations and liabilities incurred, all contracts entered into and all matters and`
  line `things engaged to be done by, with, or for, the Central Government, immediately before such date for`
  line `or in connection with the purposes of any national highway or any stretch thereof vested in, or`
  line `entrusted to, the Authority under that section, shall be deemed to have been incurred, entered into and`
  line `engaged to be done by, with, or for, the Authority;`
  line
  line `(b) all non-recurring expenditure incurred by or for the Central Government for or in connection`
  line `with the purposes of any national highway or any stretch thereof, so vested in, or entrusted to, the`
  line `Authority, up to such date and declared to be capital expenditure by the Central Government shall,`
  line `subject to such terms and conditions as may be prescribed, be treated as capital provided by the`
  line `Central Government to the Authority;`
  line
  line `(c) all sums of money due to the Central Government in relation to any national highway or any`
  line `stretch thereof, so vested in, or entrusted to, the Authority immediately before such date shall be`
  line `deemed to be due to the Authority;`
  line
  line `(d) all suits and other legal proceedings instituted or which could have been instituted by or`
  line `against the Central Government immediately before such date for any matter in relation to such`
  line `national highway or any stretch thereof may be continued or instituted by or against the Authority.`
  line
  line `(2) If any dispute arises as to which of the assets, rights or liabilities of the Central Government have`
  line `been transferred to the Authority, such dispute shall be decided by the Central Government.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (11711)
  sectionNo (13)
  orderNo 13
  title `Compulsory acquisition of land for the Authority.`
  content obj_root_law_sections_13_content
  footnotes `1. Subs. by Act 16 of 1997, s. 6, for section 13 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11711&sectionno=13&orderno=13&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_13_content:
  string
  line `^1[13. Compulsory acquisition of land for the Authority.-- Any land required by the Authority for`
  line `discharging its functions under this Act shall be deemed to be land needed for a public purpose and such`
  line `land may be acquired for the Authority under the provisions of the National Highways Act, 1956`
  line `(48 of 1956).]`
obj_root_law_sections_14:
  sectionId (11712)
  sectionNo (14)
  orderNo 14
  title `Contracts by the Authority.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11712&sectionno=14&orderno=14&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_14_content:
  string
  line `Subject to the provisions of section 15, the Authority shall be`
  line `competent to enter into and perform any contract necessary for the discharge of its functions under this`
  line Act.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (11713)
  sectionNo (15)
  orderNo 15
  title `Mode of executing contracts on behalf of the Authority.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11713&sectionno=15&orderno=15&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_15_content:
  string
  line `(1) Every contract shall, on behalf of`
  line `the Authority, be made by the Chairman or such other member or such officer of the Authority as may be`
  line `generally or specially empowered in this behalf by the Authority and such contracts or classes of contracts`
  line `as may be specified in the regulations shall be sealed with the common seal of the Authority:`
  line
  line `Provided that no contract exceeding such value or amount as the Central Government may prescribe`
  line `in this behalf shall be made unless it has been previously approved by that Government:`
  line
  line `Provided further that no contract for the acquisition or sale of immovable property or for the lease of`
  line `any such property for a term exceeding thirty years and no other contract exceeding such value or amount`
  line `as the Central Government may prescribe in this behalf shall be made unless it has been previously`
  line `approved by that Government.`
  line
  line `(2) Subject to the provisions of sub-section (1), the form and manner in which any contract shall be`
  line `made under this Act shall be such as may be provided by regulations.`
  line
  line `(3) No contract which is not in accordance with the provisions of this Act and the regulations shall be`
  line `binding on the Authority.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (11714)
  sectionNo (16)
  orderNo 16
  title `Functions of the Authority.`
  content obj_root_law_sections_16_content
  footnotes `1. Subs. by Act 16 of 1997, s. 7, for clause (h) (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11714&sectionno=16&orderno=16&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_16_content:
  string
  line `(1) Subject to the rules made by the Central Government in this`
  line `behalf, it shall be the function of the Authority to develop, maintain and manage the national highways`
  line `and any other highways vested in, or entrusted to, it by the Government.`
  line
  line `(2) Without prejudice to the generality of the provisions contained in sub-section (1), the Authority`
  line `may, for the discharge of its functions--`
  line
  line `(a) survey, develop, maintain and manage highways vested in, or entrusted to, it;`
  line
  line `(b) construct offices or workshops and establish and maintain hotels, motels, restaurants and`
  line `rest-rooms at or near the highways vested in, or entrusted to, it;`
  line
  line `(c) construct residential buildings and townships for its employees;`
  line
  line `(d) regulate and control the plying of vehicles on the highways vested in, or entrusted to, it for the`
  line `proper management thereof;`
  line
  line `(e) develop and provide consultancy and construction services in India and abroad and carry on`
  line `research activities in relation to the development, maintenance and management of highways or any`
  line `facilities thereat;`
  line
  line `(f) provide such facilities and amenities for the users of the highways vested in, or entrusted to, it`
  line `as are, in the opinion of the Authority, necessary for the smooth flow of traffic on such highways;`
  line
  line `(g) form one or more companies under the Companies Act, 1956 (1 of 1956) to further the`
  line `efficient discharge of the functions imposed on it by this Act;`
  line
  line ^1
  line `[(h) engage, or entrust any of its functions to, any person on such terms and conditions as may be`
  line prescribed;]
  line
  line `(i) advise the Central Government on matters relating to highways;`
  line
  line `(j) assist, on such terms and conditions as may be mutually agreed upon, any State Government in`
  line `the formulation and implementation of schemes for highway development;`
  line
  line `(k) collect fees on behalf of the Central Government for services or benefits rendered under`
  line `section 7 of the National Highways Act, 1956 (48 of 1956), as amended from time to time, and such`
  line `other fees on behalf of the State Governments on such terms and conditions as may be specified by`
  line `such State Governments; and`
  line
  line `(l) take all such steps as may be necessary or convenient for, or may be incidental to, the exercise`
  line `of any power or the discharge of any function conferred or imposed on it by this Act.`
  line
  line `(3) Nothing contained in this section shall be construed as--`
  line
  line `(a) authorising the disregard by the Authority of any law for the time being in force; or`
  line
  line `(b) authorising any person to institute any proceeding in respect of a duty or liability to which the`
  line `Authority or its officers or other employees would not otherwise be subject under this Act.`
obj_root_law_sections_17:
  sectionId (11715)
  sectionNo (17)
  orderNo 17
  title `Additional capital and Grants to the Authority by the Central Government.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by s. 8, ibid., for section 17 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11715&sectionno=17&orderno=17&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_17_content:
  string
  line ^1
  line `[17. Additional capital and grants to the Authority by the Central Government.--The Central`
  line `Government may, after due appropriation made by Parliament, by law in this behalf,--`
  line
  line `(a) provide any capital that may be required by the Authority for the discharge of its functions`
  line `under this Act or for any purpose connected therewith on such terms and conditions as that`
  line `Government may determine;`
  line
  line `(b) pay to the Authority, on such terms and conditions as the Central Government may determine,`
  line `by way of loans or grants such sums of money as that Government may consider necessary for the`
  line `efficient discharge by the Authority of its functions under this Act.]`
obj_root_law_sections_18:
  sectionId (11716)
  sectionNo (18)
  orderNo 18
  title `Fund of the Authority.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11716&sectionno=18&orderno=18&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_18_content:
  string
  line `(1) There shall be constituted a Fund to be called the National`
  line `Highways Authority of India Fund and there shall be credited thereto--`
  line
  line `(a) any grant or aid received by the Authority;`
  line
  line `(b) any loan taken by the Authority or any borrowings made by it;`
  line
  line `(c) any other sums received by the Authority.`
  line
  line `(2) The Fund shall be utilised for meeting--`
  line
  line `(a) expenses of the Authority in the discharge of its functions having regard to the purposes for`
  line `which such grants, loans or borrowings are received and for matters connected therewith or incidental`
  line thereto;
  line
  line `(b) salary, allowances, other remuneration and facilities provided to the members, officers and`
  line `other employees of the Authority;`
  line
  line `(c) expenses on objects and for purposes authorised by this Act.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (11717)
  sectionNo (19)
  orderNo 19
  title Budget.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11717&sectionno=19&orderno=19&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_19_content:
  string
  line `The Authority shall prepare, in such form and at such time in each financial year as`
  line `may be prescribed, its budget for the next financial year, showing the estimated receipts and expenditure`
  line `of the Authority and forward the same to the Central Government.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (11718)
  sectionNo (20)
  orderNo 20
  title `Investment of funds.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11718&sectionno=20&orderno=20&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_20_content:
  string
  line `The Authority may invest its funds (including any reserve fund) in the`
  line `securities of the Central Government or in such other manner as may be prescribed.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (11719)
  sectionNo (21)
  orderNo 21
  title `Borrowing powers of the Authority.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11719&sectionno=21&orderno=21&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_21_content:
  string
  line `(1) The Authority may, with the consent of the Central`
  line `Government or in accordance with the terms of any general or special authority given to it by the Central`
  line `Government, borrow money from any source by the issue of bonds, debentures or such other instruments`
  line `as it may deem fit for discharging all or any of its functions under this Act.`
  line
  line `(2) Subject to such limits as the Central Government may, from time to time, lay down, the Authority`
  line `may borrow temporarily by way of overdraft or otherwise, such amounts as it may require for discharging`
  line `its functions under this Act.`
  line
  line `(3) The Central Government may guarantee in such manner as it thinks fit the repayment of the`
  line `principal and the payment of interest thereon with respect to the borrowings made by the Authority under`
  line `sub-section (1).`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (11720)
  sectionNo (22)
  orderNo 22
  title `Annual report.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11720&sectionno=22&orderno=22&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_22_content:
  string
  line `The Authority shall prepare, in such form and at such time in each financial`
  line `year as may be prescribed, its annual report, giving a full account of its activities during the previous`
  line `financial year, and submit a copy thereof to the Central Government.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (11721)
  sectionNo (23)
  orderNo 23
  title `Accounts and audit.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11721&sectionno=23&orderno=23&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_23_content:
  string
  line `The accounts of the Authority shall be maintained and audited in such`
  line `manner as may, in consultation with the Comptroller and Auditor-General of India, be prescribed and the`
  line `Authority shall furnish, to the Central Government before such date as may be prescribed, its audited`
  line `copy of accounts together with the auditors report thereon.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (11722)
  sectionNo (24)
  orderNo 24
  title `Annual report and auditor’s report to be laid before Parliament.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11722&sectionno=24&orderno=24&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_24_content:
  string
  line `The Central Government`
  line `shall cause the annual report and auditor's report to be laid, as soon as may be, after they are received,`
  line `before each House of Parliament.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (11723)
  sectionNo (25)
  orderNo 25
  title `Delegation of powers.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11723&sectionno=25&orderno=25&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_25_content:
  string
  line `The Authority may, by general or special order in writing, delegate to`
  line `the Chairman or any other member or to any officer of the Authority, subject to such conditions and`
  line `limitations, if any, as may be specified in the order, such of its powers and functions under this Act`
  line `(except its powers under section 35) as it may deem necessary.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (11724)
  sectionNo (26)
  orderNo 26
  title `Authentication of orders and other instruments of the Authority.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11724&sectionno=26&orderno=26&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_26_content:
  string
  line `All orders, decisions and`
  line `other instruments of the Authority shall be authenticated by the signature of the Chairman or any other`
  line `member or any officer of the Authority authorised by it in this behalf.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (11725)
  sectionNo (27)
  orderNo 27
  title `Employees of the Authority to be public servants.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11725&sectionno=27&orderno=27&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_27_content:
  string
  line `All members, officers and employees of`
  line `the Authority shall, when acting or purporting to act in pursuance of the provisions of this Act or of any`
  line `rule or regulation made thereunder, be deemed to be public servants within the meaning of section 21 of`
  line `the Indian Penal Code (45 of 1860).`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (11726)
  sectionNo (28)
  orderNo 28
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11726&sectionno=28&orderno=28&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_28_content:
  string
  line `(1) No suit, prosecution or other legal proceeding`
  line `shall lie against the Authority or any member or officer or employee of the Authority for anything which`
  line `is in good faith done or intended to be done under this Act or the rules or regulations made thereunder.`
  line
  line `(2) No suit, prosecution or other legal proceeding shall lie against the Authority or any member or`
  line `officer or employee of the Authority for any damage caused or likely to be caused by anything which is in`
  line `good faith done or intended to be done under this Act or the rules or regulations made thereunder.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (11727)
  sectionNo (29)
  orderNo 29
  title `Power of the Authority to undertake certain works.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11727&sectionno=29&orderno=29&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_29_content:
  string
  line `The Authority may undertake to carry`
  line `out on behalf of the Government or any local authority any works or services or any class of works or`
  line `services on such terms and conditions as may be agreed upon between the Authority and the Government`
  line `or local authority concerned.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (11728)
  sectionNo (30)
  orderNo 30
  title `Power to enter.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11728&sectionno=30&orderno=30&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_30_content:
  string
  line `Subject to any regulations made in this behalf any person, generally or`
  line `specially authorised by the Authority in this behalf, may, whenever it is necessary so to do for any of the`
  line `purposes of this Act, at all reasonable times, enter upon any land or premises, and--`
  line
  line `(a) make any inspection, survey, measurement, valuation or enquiry;`
  line
  line `(b) take levels;`
  line
  line `(c) dig or bore into sub-soil;`
  line
  line `(d) set out boundaries and intended lines of work;`
  line
  line `(e) mark such levels, boundaries and lines by placing marks and cutting trenches; or`
  line
  line `(f) do such other acts or things as may be prescribed:`
  line
  line `Provided that no such person shall enter any boundary or any enclosed court or garden attached to a`
  line `dwelling-house (except with the consent of the occupier thereof) without previously giving such occupier`
  line `at least twenty-four hours' notice in writing of his intention to do so.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (11729)
  sectionNo (31)
  orderNo 31
  title `Power of the Central Government to temporarily divest the Authority of the management of any national highway.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11729&sectionno=31&orderno=31&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_31_content:
  string
  line `(1) If, at any time, the Central Government is of opinion that in the public`
  line `interest it is necessary or expedient so to do, it may, by order, direct the Authority to entrust the`
  line `development, maintenance or management of any national highway or a part thereof with effect from`
  line `such date and for such period and to such person as may be specified in the order and the Authority shall`
  line `be bound to comply with such direction.`
  line
  line `(2) Where development, maintenance or management of any national highway or part thereof is`
  line `entrusted to any person specified under sub-section (1) (hereafter in this section referred to as the`
  line `authorised person), the Authority shall cease to exercise and discharge all its powers and functions under`
  line `this Act in relation to such national highway or part thereof and such powers and functions shall be`
  line `exercised and discharged by the authorised person in accordance with the instructions, if any, which the`
  line `Central Government may give to the authorised person from time to time:`
  line
  line `Provided that no such power or function as may be specified by the Central Government by a general`
  line `or special order shall be exercised or discharged by the authorised person except with the previous`
  line `sanction of the Central Government.`
  line
  line `(3) The Central Government may reduce or extend the period mentioned in sub-section (1) as it`
  line `considers necessary.`
  line
  line `(4) During the operation of an order made under sub-section (1), it shall be competent for the Central`
  line `Government to issue, from time to time, such directions to the Authority as are necessary to enable the`
  line `authorised person to exercise the powers and discharge the functions of the Authority under this Act in`
  line `relation to the national highway or part thereof, the management of which has been entrusted to him and`
  line `in particular, to transfer any sum of money from the Fund of the Authority to the authorised person for the`
  line `management of the national highway or part thereof and every such direction shall be complied with by`
  line `the Authority.`
  line
  line `(5) On the cesser of operation of any order made under sub-section (1) in relation to any national`
  line `highway or part thereof, the authorised person shall cease to exercise and perform the powers andfunctions of the Authority under this Act in relation to such national highway or part thereof and the`
  line `Authority shall continue to exercise and perform such powers and functions in accordance with the`
  line `provisions of this Act.`
  line
  line `(6) On the cesser of operation of any order made under sub-section (1) in relation to any national`
  line `highway or part thereof, the authorised person shall hand over to the Authority any property (including`
  line `any sum of money or other asset) remaining with him in connection with the management of such`
  line `national highway or part thereof.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (11730)
  sectionNo (32)
  orderNo 32
  title `Power of the Central Government to supersede the Authority.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11730&sectionno=32&orderno=32&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_32_content:
  string
  line `(1) If, at any time, the Central`
  line `Government is of opinion--`
  line
  line `(a) that on account of a grave emergency the Authority is unable to discharge the functions and`
  line `duties imposed on it by or under the provisions of this Act; or`
  line
  line `(b) that the Authority has persistently made default in complying with any direction issued by the`
  line `Central Government under this Act or in the discharge of the functions and duties imposed on it by or`
  line `under the provisions of this Act; or`
  line
  line `(c) that circumstances exist which render it necessary in the public interest so to do,`
  line
  line `the Central Government may, by notification in the Official Gazette, supersede the Authority for such`
  line `period, not exceeding one year, as may be specified in the notification:`
  line
  line `Provided that before issuing a notification under this sub-section for the reasons mentioned in`
  line `clause (b), the Central Government shall give a reasonable opportunity to the Authority to show cause`
  line `why it should not be superseded and shall consider the explanations and objections, if any, of the`
  line Authority.
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the Authority,--`
  line
  line `(a) all the members shall, as from the date of supersession, vacate their offices as such;`
  line
  line `(b) all the powers, functions and duties which may, or under the provisions of this Act, be`
  line `exercised or discharged by or on behalf of the Authority, shall, until the Authority is reconstituted`
  line `under sub-section (3), be exercised and discharged by such person or persons as the Central`
  line `Government may direct;`
  line
  line `(c) all property owned or controlled by the Authority shall, until the Authority is reconstituted`
  line `under sub-section (3), vest in the Central Government.`
  line
  line `(3) On the expiration of the period of supersession specified in the notification issued under`
  line `sub-section (1), the Central Government may--`
  line
  line `(a) extend the period of supersession for such further term, not exceeding one year, as it may`
  line `consider necessary; or`
  line
  line `(b) reconstitute the Authority by fresh appointment and in such a case, any person who vacated`
  line `office under clause (a) of sub-section (2) shall not be deemed disqualified for appointment:`
  line
  line `Provided that the Central Government may, at any time before the expiration of the period of`
  line `supersession whether as originally specified under sub-section (1) or as extended under this sub-section,`
  line `take action under clause (b) of this sub-section.`
  line
  line `(4) The Central Government shall cause a notification issued under sub-section (1) or`
  line `sub-section (3) and a full report of any action taken under this section and the circumstances leading to`
  line `such action to be laid before both Houses of Parliament as soon as may be.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (11731)
  sectionNo (33)
  orderNo 33
  title `Power of the Central Government to issue directions.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11731&sectionno=33&orderno=33&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_33_content:
  string
  line `(1) Without prejudice to the other`
  line `provisions of this Act, the Authority shall, in the discharge of its functions and duties under this Act, be`
  line `bound by such directions on questions of policy as the Central Government may give to it in writing from`
  line `time to time.`
  line
  line `(2) The decision of the Central Government whether a question is one of policy or not shall be final.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (11732)
  sectionNo (34)
  orderNo 34
  title `Power of the Central Government to made rules.`
  content obj_root_law_sections_34_content
  footnotes `1. Ins. by Act 16 of 1997, s. 9 (w.e.f. 24-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11732&sectionno=34&orderno=34&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_34_content:
  string
  line `(1) The Central Government may, by`
  line `notification in the Official Gazette, make rules for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for--`
  line
  line `(a) the term of office and other conditions of service of the members;`
  line
  line `(b) the powers and duties of the Chairman and of the members;`
  line
  line `(c) the terms and conditions subject to which the non-recurring expenditure incurred by or for the`
  line `Central Government for or in connection with the purposes of any national highway shall be treated`
  line `as capital provided by the Central Government to the Authority under clause (b) of sub-section (1) of`
  line `section 12;`
  line
  line `(d) the value or amount required to be prescribed under sub-section (1) of section 15;`
  line
  line ^1
  line `[(dd) the terms and conditions subject to which the functions of the Authority may be entrusted`
  line `to any person under clause (h) of sub-section (2) of section 16;]`
  line
  line `(e) the form in which and the time within which the Authority shall prepare its budget under`
  line `section 19 and its annual report under section 22;`
  line
  line `(f) the manner in which the Authority may invest its funds under section 20;`
  line
  line `(g) the manner in which the accounts of the Authority shall be maintained and audited and the`
  line `date before which the audited copy of the accounts together with the auditor's report thereon shall be`
  line `furnished to the Central Government under section 23;`
  line
  line `(h) the conditions and restrictions with respect to the exercise of the power to enter under`
  line `section 30 and the matters referred to in clause (f) of that section; and`
  line
  line `(i) any other matter which is required to be, or may be, prescribed.`
obj_root_law_sections_35:
  sectionId (11733)
  sectionNo (35)
  orderNo 35
  title `Power of the Authority to make regulations.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11733&sectionno=35&orderno=35&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_35_content:
  string
  line `(1) The Authority may, by notification in the`
  line `Official Gazette, make regulations not inconsistent with this Act and the rules made thereunder to carry`
  line `out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the times and places of the meetings of the Authority and the procedure to be followed for the`
  line `transaction of business at such meetings;`
  line
  line `(b) the terms and conditions of service, method of recruitment and the remuneration of officers`
  line `and other employees appointed by the Authority;`
  line
  line `(c) the form and manner in which a contract or class of contracts may be made by the Authority`
  line `and the contracts or classes of contracts which are to be sealed with the common seal of the`
  line Authority;
  line
  line `(d) the manner of preventing obstructions on the national highways for their normal functioning;`
  line
  line `(e) the manner of prohibiting the parking or waiting of any vehicle or carriage on the national`
  line `highway except at places specified by the Authority;`
  line
  line `(f) the manner of prohibiting or restricting access to any part of the national highway;`
  line
  line `(g) the manner of regulating or restricting advertisements on and around national highways; and`
  line
  line `(h) generally for the efficient and proper maintenance and management of the national highways.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (11734)
  sectionNo (36)
  orderNo 36
  title `Power to remove difficulties.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11734&sectionno=36&orderno=36&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_36_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by notification in the Official Gazette, make order not inconsistent`
  line `with the provisions of this Act as may appear to it to be necessary or expedient for the removal of the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made after the expiration of two years from the commencement`
  line `of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (11735)
  sectionNo (37)
  orderNo 37
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_30_42_00007_198868_1517807326113&sectionId=11735&sectionno=37&orderno=37&orgactid=AC_CEN_30_42_00007_198868_1517807326113
obj_root_law_sections_37_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `भारतीय राष्‍ट्रीय राजमार्ग प्राधिकरण अधिनियम, 1988`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1803/2/h198868.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T09:40:34.556Z`
  pageCount 8
  sections obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
  obj_root_law_translations_hi_sections_3
  obj_root_law_translations_hi_sections_4
  obj_root_law_translations_hi_sections_5
  obj_root_law_translations_hi_sections_6
  obj_root_law_translations_hi_sections_7
  obj_root_law_translations_hi_sections_8
obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `भारतीय राष्‍टरी य राजमार्ग प्र ाधिकरण अधिधियम, 1988`
  line `(1988 का अधिधियम संखयां क 68 )`
  line `[19 दिसंबर, 1988]`
  line `राष्‍टरी य राजमार्ों के धिकास, अिुरक्षण और प्र बंि के`
  line `धिए एक प्र ाधिकरण का र् ठि करिे तथा`
  line `उससे संब द्ध या उसके आिुषंधर्क`
  line `धिषयों के धिए उपबंि`
  line `करिे के धिए`
  line `अधि धियम`
  line `भारत र् णराज्य के उितािीसिें िषग में संसि् द्व ारा धिम्ि धिधित रू प में यह अधिधियधमत हो: ––`
  line `अध्या य 1 प्र`
  line ारंधभक
  line `1. संधक्षप्त िाम, धिस्ता र और प्र ारंभ –– (1) इस अधिधियम का संधक्षप्त िाम भारतीय राष्‍टरी य राजमार्ग प्र ाधिकरण`
  line `अधिधियम, 1988 है।`
  line `(2) इ सका धिस्ता र संपूणग भारत पर है।`
  line `(3) यह उस तारीि को प्र िृत्त हो र् ा जो केंद्रीय सरकार, राजपत्र में अधिसूचिा द्व ारा, धियत करे।`
  line `2. पररभाषाएं –– इस अधिधियम में, जब तक दक संिभग से अन्य था अपेधक्षत ि हो, ––`
  line `( क ) “ प्र ाधिकरण ” से िारा 3 के अिीि र् रठत भारतीय राष्‍टरी य राजमार्ग प्र ाधिकरण अधभप्रेत है;`
  line `( ि ) “ अध्य क्ष ” से प्र ाधिकरण का अध्य क्ष अधभप्रेत है;`
  line `( र् ) “ कमगचारी ” से प्र ाधिकरण में पूणगकाधिक सेिारत व् य धत अधभप्रेत है;`
  line `( घ ) “ सिस्य ” से प्र ाधिकरण का िारा 3 के अिीि धियुत सिस्य अधभप्रेत है और इसमें अध्य क्ष भी है;`
  line `( ङ ) “ राष्‍टरी य राजमार्ग ” से राष्‍टरी य राजमार्ग अधिधियम, 1956 (1956 का 48) की िारा 2 के अिीि तत्स मय`
  line `राष्‍टरी य राजमार्ग के रू प में घोधषत कोई राजमा र् ग अधभप्रेत है;`
  line `( च ) “ धिधहत ” से इस अधिधियम के अिीि बिाए र् ए धियमों द्व ारा धिधहत अधभप्रेत है;`
  line `( छ ) “ धिधियम ” से प्र ाधिकरण द्व ारा इस अधिधियम के अिीि बिाए र् ए धिधियम अधभप्रेत हैं;`
  line `( ज ) उि शब्िों और पिों के जो इसमें प्र युत हैं और पररभाधषत िहीं हैं ककंतु राष्‍टरी य राजमार्ग अधिधियम, 1956`
  line `(1956 का 48) में पररभाधषत हैं, िही अथग होंर्े जो उिके उ स अधिधियम में हैं।`
  line `अध्या य 2`
  line `भारतीय राष्‍टरी य राजमार्ग प्र ाधिकरण`
  line `3. प्र ाधिकरण का र् ठि –– (1) इस अधिधियम के प्र योजिों के धिए ऐसी तारीि से जो केंद्रीय सरकार, राजपत्र में अधिसूचिा द्व`
  line `ारा, इस धिधमत्त धियत करे, एक प्र ाधिकरण का र् ठि दकया जाएर्ा धजसका िाम भारतीय रा ष्‍ट री य राजमार्ग प्र ाधिकरण होर्ा।`
  line `(2) यह प्र ाधिकरण पूिोत िाम का, शाश्ि त उत्तराधिकार और सामान्य मुद्रा िािा, एक धिर् धमत धिकाय होर्ा धजसे इस`
  line `अधिधियम के उपबंिों के अिीि रहते हु ए, जंर्म और स् था िर, िोिों प्र कार की संपधत्त का अजगि, िारण तथा व् य यि करिे की और`
  line `संधििा करिे की शधत होर्ी और उ त िाम से यह िाि िा सकेर्ा और इस पर िाि िाया जा सकेर्ा।`
  line `1 [(3) प्र ाधिकरण में धिम्ि धिधित होंर्े, धजन्हें केन् द्री य सरकार, राजपत्र में अधिसूचिा द्व ारा, धियुत करेर्ी: ––`
  line `(i) अध्य क्ष;`
  line `(ii) पूणगकाधिक सिस्य, जो छह से अधिक िहीं होंर्े; और`
  line `(iii) अशंकाधिक सिस्य, जो छह से अधिक िहीं होंर्े:`
  line `1 2013 के अधिधियम सं ० 19 की िारा 2 द्व ारा प्र धतस्था धपत।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line 2
  line `परंतु केन् द्री य सरकार, अंशकाधिक सिस्यों को धियुत करते समय यह सुधिधश्च त करेर्ी दक उिमें से कम से कम िो सिस्य`
  line `ऐसे र्ै र सरकारी िृधत्तक हों, धजन्हें धित्तीय प्र बंि, पररिहि योजिा या दकसी अन्य सुसंर्त धिद्या शािा में ज्ञ ाि या अिुभि हो। ]`
  line `4. सिस्यों की पिािधि और सेिा की शतें –– सिस्यों की पिािधि और सेिा की अन्य शतें ऐसी होंर्ी जो धिधहत की जाएं।`
  line `5. सिस्य के रू प में धियुधत के धिए धिरहगताएं –– कोई व् य धत सिस्य के रू प में धि युधत के धिए धिरर्हग त होर्ा यदि िह, ––`
  line `( क ) ऐेसे दकसी अपरा ि के धिए धसद्धिोष ठहराया र् या है और कारािास से िंडादिष्‍ट ट दकया र् या है धजसमें, केंद्रीय`
  line `सरकार की राय में, िैधतक अिमता अंतर्ग्गस्त है; या`
  line `( ि ) अििुमोधचत दििा धिया है; या`
  line `( र् ) धिकृत धचत्त का है और सक्ष म न् या यािय द्व ारा ऐसा घोधषत कर दिया र् या है; या`
  line `( घ ) सरकार की या सरकार के स् िा धमत्िा िीि या धियंत्रणा िीि दकसी धिर्म की सेिा से हटा दिया र् या है या`
  line `पिच्यु त कर दिया है; या`
  line `( ङ ) केंद्रीय सरकार की राय में, प्र ाधिकरण में ऐसा धित्तीय या अन्य धहत रिता है धज सका उसके सिस्य के रू प में`
  line `उसके द्व ारा कृत्यों के धििगहि पर प्र धतकूि प्र भाि पड़ सक ता है।`
  line `6. पुिर्िगयुधत के धिए सिस्य की पात्रता –– सेिा के ऐसे अन्य धिबंििों और शतों के अिीि रहते हु ए जैसी धिधहत की जाए`
  line `कोई व् य धत, जो सिस्य िहीं रह र् या है, ऐसे सिस्य के रू प में पुिर्िगयुधत का पात्र होर्ा।`
  line `7. अधििेशि –– (1) प्र ाधिकरण के अधि िेशि ऐसे समय और स् था ि पर होंर्े और उि अधििेशिों में दकए जािे िािे कायग के`
  line `बारे में, धजसके अंतर्गत ऐसे अधििेशिों में र् णपूर्तग भी है, प्र दिया के ऐसे धियमों का पािि दकया जाए र् ा, जो धिधियमों द्व ारा उपबंधित`
  line `दकए जाएं।`
  line `(2) यदि दकसी कारण से अध्य क्ष प्र ाधिकरण के दकसी अधििेशि में उपधस्थ त होिे में असमथग है तो, उस अधििेशि में उपधस्थ त`
  line `सिस्यों द्व ारा चुिा र् या कोई अन्य सिस्य अधििेशि का सभापधतत्ि करेर्ा।`
  line `(3) ऐसे सभी प्रश् ि जो प्र ाधिकरण के दकसी अधििेशि के समक्ष आएं उपधस्थ त और म तिाि करिे िािे सिस्यों के बहुम त से`
  line `धिधिधश्च त दकए जाएंर्े, और मतों के बराबर होिे की िशा में अध्य क्ष का, अथिा उसकी अिुपधस्थ धत में पीठासीि व् य धत का, िूसरा या`
  line `धिणागयक मत होर्ा और िह उसका प्र योर् करेर्ा।`
  line `8. प्र ाधिकरण में ररधत से कायगिाधहयों का अधिधिमान्य ि होिा –– प्र ाधिकरण का कोई कायग या कायग िाही, केिि इस कारण`
  line `अधिधिमान्य िहीं होर्ी, दक ––`
  line `( क ) प्र ाधिकरण में कोई ररधत है या उसके र् ठि में कोई त्रु रट है; या`
  line `( ि ) प्र ाधिकरण के सिस्य के रू प में कायग करिे िािे दकसी व् य धत की धियुधत में कोई त्रु रट है; या`
  line `( र् ) प्र ाधिकरण द्व ारा अपिाई जािे िािी प्र दिया में कोई ऐसी अधियधमतता है, जो मामिे के र्ु णा र्ु ण को प्र भाधित`
  line `िहीं करती है।`
  line `9. प्र ाधिकरण के अधिकाररयों, परामशगिाताओं और अन्य कमगचाररयों की धि युधत –– (1) प्र ाधिकरण अपिे कतगव्यों का धििगहि`
  line `करिे के प्र योजिाथग, उतिे अधिकारी और अन्य कमगचारी जो िह आिश्य क समझता है, और ऐसे धिबंििों और शतों पर, जो धिधियमों द्व`
  line `ारा अधिकधथत दकए जाएं, धियुत कर सकेर्ा।`
  line `(2) प्र ा धिकरण, समय - समय पर, दकसी व् य धत को सिाहकार या परामशगिाता के रू प में, जैसा िह आिश्य क समझे, ऐसे`
  line `धिबंििों और शतों पर जो धिधियमों द्व ारा अधिकधथत दकए जाएं, धियुत कर सकेर्ा।`
  line `10. प्र ाधिकरण का कारबार के धसद्धांतों पर चििा –– इस अधिधियम के अिीि अपिे कृत् यों के धििगहि में प्र ाधिकरण, जहां`
  line `तक हो सके, कारबार के धसद्धांतों पर चिेर्ा।`
  line `अध्या य 3`
  line `संपधत्त और संधििा`
  line `11. प्र ाधिकरण में कोई भी राष्‍टरी य राजमार्ग धिधहत करिे या उसे सौंपिे की केंद्रीय सरकार की शधत –– केंद्रीय सरकार,`
  line `समय - स मय पर, राजपत्र में अधिसूचिा द्व ारा, ऐसे राष्‍टरी य राजमार्ग या उ सके दकसी भार् को, जो उस अधिसूचिा में धिधिर्िगष्‍टट दकया`
  line `जाए, प्र ाधिकरण में धिधहत कर सकेर्ी या उसे सौंप सकेर्ी।`
  line `12. केंद्रीय सरकार की आधस्त यों और िाधयत्िों का प्र ाधिकरण को अंतरण –– (1) िारा 11 के अिीि अधिसूचिा के प्र`
  line `काशि से ही ––`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line 3
  line `( क ) ऐसे दिि से ठीक पहिे, उस िारा के अिीि प्र ाधिकरण में धिधहत या उसे सौंपे र् ए दकसी राष्‍टरी य राजमार्ग या`
  line `उसके दकसी भार् के प्र योजिों के धिए या उसके संबंि में केंद्रीय सरकार द्व ारा, उसके साथ या उसके धिए उपर्त सभी ऋ ण,`
  line `बाध्य ताएं और िाधयत्ि, की र् ई सभी संधििाएं और दकए जािे के धि ए िचिबद्ध सभी मामिे और बातें उस प्र ाधिकरण के द्व`
  line `ारा, उसके साथ या उसके धिए उपर्त की र् ई या दकए जािे के धिए िचिबद्ध समझी जाएर्ी।`
  line `( ि ) प्र ाधिकरण में इस प्र कार धिधहत या उसे सौंपे र् ए दकसी राष्‍टरी य राजमार्ग या उसके दकसी भार् के प्र योजिों के`
  line `धिए या उिके संबंि में केंद्रीय सरकार द्व ारा या उसके धिए उस तारीि तक उपर्त और पूंजीर्त व् य य के रू प में घोधषत सभी`
  line `अिािती व् य य ऐसे धिबंििों और शतों के अिीि रहते हु ए जो केंद्रीय सरकार द्व ारा धि धहत की जाएं, केंद्रीय सरकार द्व ा रा प्र`
  line `ाधिकरण को उपिब् ि कराई र् ई पूंजी समझी जाएर्ी;`
  line `( र् ) प्र ाधिकरण में इस प्र कार धिधहत या उसे सौंपे र् ए दकसी राष्‍टरी य राजमार्ग या उसके भार् के संबंि में उस`
  line `तारीि से ठीक पहिे केंद्रीय सरकार को िेय सभी राधशयां प्र ाधिकरण को िेय समझी जाएंर्ी;`
  line `( घ ) ऐसे सभी िाि और अन्य धिधिक कायगिाधहयां जो ऐसे राष्‍टरी य राजमार्ग या उसके दकसी भार् के संबंि में दकसी`
  line `मामिे की बाबत उस तारीि से ठीक पहिे केंद्रीय सरकार के द्व ारा या उसके धिरुद्ध संधस्थ त की र् ई हो या संधस्थ त की जा`
  line `सकती थीं, प्र ाधिकरण द्व ारा या उसके धिरुद्ध चािू रिी या संधस्थ त की जा सकेर्ी।`
  line `(2) यदि कोई ऐसा धििाि उत्प न् ि होता है दक केंद्रीय सरकार की आधस्त यों, अधिकारों या िाधयत्िों में से कौि से प्र ाधिकरण`
  line `को अंतररत कर दिए र् ए हैं, तो ऐसे धििाि का धिधिश्च य केंद्रीय सरकार द्व ारा दक या जाएर्ा।`
  line `1 [ 13. प्र ाधिकरण के धिए भूधम का अधििायग अजगि –– इस अधिधियम के अिीि प्र ाधिकरण द्व ा रा अपिे कृत्यों का धििगहि करिे`
  line `के धिए अपेधक्षत कोई भूधम, िोक प्र योजि के धिए आिश्य क भूधम समझी जाएर्ी और प्र ाधिकरण के धिए ऐसी भूधम का अजगि राष्‍टरी य`
  line `राजमार्ग अधिधियम, 1956 (1956 का 48) के उपबंिों के अिीि दकया जा सकेर्ा। ]`
  line `14. प्र ाधिकरण द्व ारा संधििाएं – – िारा 15 के उपबंिों के अिीि रहते हु ए, प्र ाधिकरण इस अधिधियम के अिीि अपिे कृत् यों के`
  line `धििगहि के धिए आिश्य क कोई संधििा करिे और उसे संपादित क रिे के धिए समक्ष होर्ा।`
  line `15. प्र ाधिकरण की ओर से संधििाएं धिष्‍टपा दित करिे का ढंर् –– (1) प्र ाधिकरण की ओर से प्रत् ये क सं धििा प्र ाधिकरण के अध्य क्ष द्व`
  line `ारा या उसके ऐसे अन्य सिस्य द्व ारा या ऐसे अधिकारी द्व ारा की जाएर्ी धजसे प्र ाधिकरण इस धिधमत्त सा िारणतया या धिधशष्‍टट तया`
  line `सशत करे और ऐसी संधििाएं या ऐसे िर्ग को संधििाएं जैसी धिधियमों में धिधिर्िगष्‍टट की जाएं, प्र ाधिकरण की सामा न् य मुद्रा से`
  line `मुद्रांदकत की जाएंर्ी:`
  line `परंतु इतिे मूल्य या रकम से, धजतिी केंद्रीय सरकार इस धिधमत्त धिधहत करे, अधिक की कोई संधििा तब तक िहीं की जाएर्ी`
  line `जब तक उस सरकार द्व ारा उसका पूिागिु मोिि ि कर दिया र् या हो:`
  line `परंतु यह और दक स् था िर संपधत्त के अजगि या धिि य के धिए या ऐसी दकसी संपधत्त के तीस िषग से अधिक की अिधि के पट्टे के`
  line `धिए, कोई संधििा तथा इतिे मूल्य या रकम से, धजतिी केंद्रीय सरकार इस धिधमत्त धिधहत करे, अधिक की कोई अन्य संधििा तब तक`
  line `िहीं की जाएर्ी जब तक केंद्रीय सरकार द्व ारा उसका पूिागिुमोिि ि कर दिया र् या हो।`
  line `(2) उपिारा (1) के उपबं िों के अिीि रहते हु ए, इस अधिधियम के अिीि की जािे िािी दकसी संधििा का प्ररू प और रीधत`
  line `ऐसी होर्ी जैसी धिधियमों द्व ारा धिधहत की जाए।`
  line `(3) कोई भी संधििा जो इस अधिधियम के उपबंिों और धिधियमों के अिुसार िहीं है, प्र ाधिकरण पर आबद्ध कर िहीं होर्ी।`
  line `अध्या य 4 प्र`
  line `ाधिकरण के कृत्य`
  line `16. प्र ाधिकरण के कृत् य –– (1) इस धिधमत्त केंद्रीय सरकार द्व ारा बिाए र् ए धियमों के अिीि रहते हु ए प्र ाधिकरण का कृत् य यह`
  line `होर्ा दक िह राष्‍टरी य राजमार्ों तथा सरकार द्व ारा उ समें धिधहत दकए र् ए या उसे सौं पे र् ए अन्य दक सी राजमार्ग का सधन्ि मागण,`
  line `अिुरक्षण और प्र बंि करे।`
  line `(2) उपिारा (1) में अंतर्िगष्‍टट उपबंिों की व् या पकता पर प्र धतकूि प्र भाि डािे धबिा, प्र ाधिकरण अपिे कृत् यों के धििगहि`
  line `के धिए, ––`
  line `( क ) उसमें धिधहत या उसे सौंपे र् ए राजमार्ों का सिेक्षण, धिकास, अ िुरक्षण और प्र बंि कर सकेर्ा;`
  line `( ि ) उसमें धिधहत या उसे सौं पे र् ए राजमार्ों पर या उिके धि कट कायागिय या कमगशािाएं सधन्ि र् मगत कर सकेर्ा`
  line `और होटि, मोटि, उपाहारर्ृह और धिश्रामकक्ष स् था धपत कर सकेर्ा और उ िका अिुरक्षण कर सकेर्ा;`
  line `( र् ) अपिे कमगचाररयों के धिए धििास भि िों और िर्ररयों का स धन्ि मागण कर सकेर्ा;`
  line `1 1997 के अधिधियम सं ० 16 की िारा 6 द्व ारा प्र धतस्था धपत।`
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
  orderNo 4
  title `Page 4`
  content obj_root_law_translations_hi_sections_4_content
  footnotes obj_root_law_translations_hi_sections_4_footnotes
  sourcePage 4
obj_root_law_translations_hi_sections_4_content:
  string
  line 4
  line `( घ ) राजमार्ों के उधचत प्र बंि के धिए, उसमें धिधहत या उसे सौंपे र् ए राजमार्ों पर यािों के चिाए जािे को`
  line `धिधियधमत और धियंधत्रत कर सकेर्ा;`
  line `( ङ ) भारत और धििेश में परामशगिात्री और धिमागण सेिाओं का धिकास और व् य िस्था कर सकेर्ा और राजमार्ों के`
  line `धिकास, अिुरक्षण और प्र बंि के संबंि में या उि पर दकन्हीं सुधििाओं के संबंि में अिुसंिाि दियाकिाप चिा सकेर्ा;`
  line `( च ) उसमें धिधहत या उसे सौं पे र् ए राजमार्ों के उपयोर्कतागओं के धिए ऐसी सुधििाओं और प्र सुधििाओं की व्`
  line `य िस्था कर सकेर्ा, जो प्र ाधिकरण की राय में ऐसे राजमार्ों पर यातायात के धि बागि आिार्मि के धिए आिश्य क हों;`
  line `( छ ) इस अधिधियम द्व ारा उस पर अधिरोधपत कृत् यों का अधिक िक्षतापूणग धििगहि करिे के धिए कंपिी अधिधियम,`
  line `1956 (1956 का 1) के अिीि एक या अधिक कंपधियां बिा सकेर्ा;`
  line `1 [( ज ) दकसी व् य धत को अपिे कृत् यों में से दकसी कृत् य में ऐसे धिबंििों और शतों पर, जो धिधहत की जाएं, िर्ा`
  line `सकेर्ा या उसे सौंप सकेर्ा; ]`
  line `( झ ) राजमार्ों से संबंधित धिषयों के बारे में केंद्रीय सरकार को सिाह िे सकेर्ा;`
  line `( ञ ) राजमार्ग के धिकास की स् की म बिािे और उ से कायागधन्ि त करिे में दकसी राज्य सरकार की ऐसे धिबंििों और`
  line `शतों पर सहायता कर सकेर्ा, धजि पर पारस्प ररक रू प में सहमधत हो जाए;`
  line `( ट ) समय - समय पर यथासंशोधित राष्‍टरी य राजमार्ग अधिधियम, 1956 (1956 का 48) की िारा 7 के अिीि की र् ई`
  line `सेिाओं या प्र ित्त फायिों के धिए केंद्रीय सरकार की ओर से फीस तथा राज्य सरकारों की ओर से ऐसे धिबं ििों और शतों पर`
  line `जैसी उस राज्य सरकार द्व ारा धिधिर्िग ष्‍ट ट की जाएं, ऐसी अन्य फीस एकधत्रत कर सकेर्ा;`
  line `( ठ ) ऐसे सभी कायग कर सकेर्ा जो इस अधिधियम द्व ा रा प्र ाधिकरण की प्र ित्त दकसी श धत के प्र योर् या उस पर`
  line `अधिरोधपत दकसी कृत्य के धििगहि के धिए आिश्य क या सुधििाजिक हो या उिके आिुषंधर्क हों।`
  line `(3) इस िारा में अंतर्िगष्‍टट दकसी बात का यह अथग िहीं िर्ाया जाएर्ा दक िह, ––`
  line `( क ) प्र ाधिकरण द्व ारा, तत्स मय प्र िृत्त दकसी धिधि की अिहेििा को प्र ाधिकृत करती है; या`
  line `( ि ) दकसी व् य धत को दकसी ऐसे कतगव्य या िाधयत्ि की बाबत, धजसके अिीि प्र ाधिकरण या उसके अधिकारी या`
  line `अन्य कमगचारी, इस अधिधियम के अिीि अन्य था ि हों, कोई कायगिाही संधस्थ त करिे के धिए प्र ा धिकृत करती है।`
  line `अध्या य 5`
  line `धित्त, िेिा और िेिापरी क्ष ा`
  line `2 [ 17. केन् द्री य सरकार द्व ारा प्र ाधिकरण को अधतररत पूंजी और अिुिाि –– केन् द्री य सरकार, संसि् की धिधि द्व ारा इस धिधमत्त,`
  line `दकए र् ए सम्य क् धिधियोर् के पश्चा त्, ––`
  line `( क ) दकसी पूंजी का, जो प्र ाधिकरण द्व ारा इस अधिधियम के अिीि अपिे कृत् यों का धििगहि करिे के धिए या उससे`
  line `संबंधित दकसी प्र योजि के धिए अपेधक्षत हो, ऐसे धिबंििों और शतों पर, जो िह सरकार अििाररत करे, प्र बंि कर सके र् ी;`
  line `( ि ) प्र ाधिकरण को, ऐसे धिबंििों और शतों पर जो केन् द्री य सरकार अििाररत करे, उिार या अिुिािों के रू प में`
  line `ऐसी ििराधश का संिाय कर सकेर्ी जो िह सरकार इस अधिधियम के अिीि प्र ाधिकरण द्व ारा अपिे कृत् यों के िक्षतापूणग`
  line `धििगहि के धिए आिश्य क समझे। ]`
  line `18. प्र ाधिकरण की धिधि –– (1) भारतीय राष्‍टरी य राजमार्ग प्र ाधिकरण धिधि िामक एक धिधि का र् ठि दकया जाएर्ा और`
  line `उसमें धिम्ि धिधित राधश जमा की जाएंर्ी, अथागत्: ––`
  line `( क ) प्र ाधिकरण द्व ारा प्र ाप्त कोई अिुिाि या सहायता;`
  line `( ि ) प्र ाधिकरण द्व ारा धिया र् या कोई ऋण या उसके द्व ारा धिया र् या कोई उिार;`
  line `( र् ) प्र ाधिकरण द्व ारा प्र ाप्त कोई अन्य राधश।`
  line `(2) उ त धिधि का उपयोर् धिम्ि धिधित को पूरा करिे के धिए दकया जाएर्ा, अथाग त्: ––`
  line `( क ) ऐसे अिुिािों, उिारों या ऋणों के प्र योजिों को, धजिके धिए िे प्र ाप्त हु ए हैं, ध् या ि में रिते हु ए, प्र ाधिकरण के`
  line `कृत्यों के धििगह ि और उिसे संबंधित या उिके आिुषंधर्क धिषयों के धिए प्र ाधिकरण के धिए व् य य;`
  line `1 1997 के अधिधियम सं ० 16 की िारा 7 द्व ारा प्र धतस्था धपत।`
  line `2 1997 के अधिधियम सं ० 16 की िारा 8 द्व ारा प्र धतस्था धपत।`
obj_root_law_translations_hi_sections_4_footnotes:
  string
