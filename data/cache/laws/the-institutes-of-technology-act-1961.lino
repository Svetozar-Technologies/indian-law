obj_root_law_sections_1:
  sectionId (24026)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 1st April, 1962, vide notification No. S.O. 929, dated 23rd March, 1962, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24026&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Institutes of Technology`
  line `Act, 1961.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint, and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_2:
  sectionId (24027)
  sectionNo (2)
  orderNo 2
  title `Declaration of certain institutions as institutions of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24027&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_2_content:
  string
  line `Whereas the objects`
  line `of the institutions known as the Indian Institute of Technology, Bombay, ^1[the College of Engineering and`
  line `Technology, Delhi,] ^2[the Indian Institute of Technology, Guwahati, Assam] the Indian Institute of`
  line `Technology, ^3[Kanpur, the Indian Institute of Technology, Madras ^4[the Indian Institute of Technology,`
  line `Roorkee]], the Indian Institute of Technology, Bhubaneswar, the Indian Institute of Technology, Gandhi`
  line `Nagar, the Indian Institute of Technology, Hyderabad, the Indian Institute of Technology, Indore, the`
  line `Indian Institute of Technology, Jodhpur, the Indian Institute of Technology, Mandi, the Indian Institute of`
  line `Technology, Patna, the Indian Institute of Technology, Ropar ^5[and the Indian Institute of Technology`
  line `(Banaras Hindu University), Varanasi] are such as to make them institutions of national importance, it is`
  line `hereby declared that each such institution is an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Ins. by Act 29 of 1963, s. 2 (w.e.f. 13-9-1963).`
  line
  line `2. Ins. by Act 35 of 1994, s. 2 (w.e.f. 1-9-1994).`
  line
  line `3. Subs. by Act 16 of 2002, s. 2, for`
  line `"Kanpur and the Indian Institute of Technology, Madras" (w.e.f. 21-9-2001).`
  line
  line `4. Subs. by Act 34 of 2012, s. 2, for "and the Indian Institute of Technology, Roorkee" (w.e.f. 29-6-2012).`
  line
  line `5. The words in brackets shall stand substituted (date to be notified) by Act 41 of 2016, s. 2 to read as under:--`
  line
  line `"the Indian Institute of Technology (Banaras Hindu University), Varanasi, the Indian Institute of Technology, Tirupati, the`
  line `Indian Institute of Technology, Palakkad, the Indian Institute of Technology, Goa, the Indian Institute of Technology,`
  line `Dharwad, the Indian Institute of Technology, Bhilai, the Indian Institute of Technology, Jammu and the Indian Institute of`
  line `Technology (Indian School of Mines), Dhanbad".`
obj_root_law_sections_3:
  sectionId (24028)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24028&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Board", in relation to any Institute, means the Board of Governors thereof;`
  line
  line `(b) "Chairman" means the Chairman of the Board;`
  line
  line `(c) "corresponding Institute" means,--`
  line
  line `(i) in relation to the society known as the Indian Institute of Technology, Bombay, the Indian`
  line `Institute of Technology, Bombay;`
  line
  line `^1[(ia) in relation to the society known as the College of Engineering and Technology, Delhi,`
  line `the Indian Institute of Technology, Delhi;]`
  line
  line `^2[(ib) in relation to the society known as the Indian Institute of Technology, Guwahati,`
  line `Assam, the Indian Institute of Technology, Guwahati.]`
  line
  line `(ii) in relation to the society known as the Indian Institute of Technology (Kanpur) Society,`
  line `the Indian Institute of Technology, Kanpur, ^3***`
  line
  line `(iii) in relation to the society known as the Indian Institute of Technology, Madras, the Indian`
  line `Institute of Technology Madras;`
  line
  line `^4[(iv) in relation to the University of Roorkee, Roorkee, the Indian Institute of Technology,`
  line Roorkee;]
  line
  line `^5[(v) in relation to the society known as the Indian Institute of Technology, Bhubaneswar, the`
  line `Indian Institute of Technology, Bhubaneswar;`
  line
  line `(vi) in relation to the society known as the Indian Institute of Technology, Gandhinagar, the`
  line `Indian Institute of Technology, Gandhinagar;`
  line
  line `(vii) in relation to the society known as the Indian Institute of Technology, Hyderabad, the`
  line `Indian Institute of Technology, Hyderabad;`
  line
  line `(viii) in relation to the society known as the Indian Institute of Technology, Indore, the Indian`
  line `Institute of Technology, Indore;`
  line
  line `(ix) in relation to the society known as the Indian Institute of Technology, Rajasthan, the`
  line `Indian Institute of Technology, Jodhpur;`
  line
  line `(x) in relation to the society known as the Indian Institute of Technology, Mandi, the Indian`
  line `Institute of Technology, Mandi;`
  line
  line `(xi) in relation to the society known as the Indian Institute of Technology, Patna, the Indian`
  line `Institute of Technology, Patna;`
  line
  line `(xii) in relation to the society known as the Indian Institute of Technology, Punjab, the Indian`
  line `Institute of Technology, Ropar;`
  line
  line `(xiii) in relation to the Institute of Technology, Banaras Hindu University, referred to in`
  line `Statute 25(A)(1) of the Statutes set out in the Schedule to the Banaras Hindu University`
  line `Act, 1915 (16 of 1915), the Indian Institute of Technology (Banaras Hindu University),`
  line Varanasi;]
  line
  line `^6[(xiv) in relation to the society known as the Indian Institute of Technology, Tirupati, the`
  line `Indian Institute of Technology, Tirupati;`
  line
  line `(xv) in relation to the society known as the Indian Institute of Technology, Palakkad, the`
  line `Indian Institute of Technology, Palakkad;`
  line
  line `(xvi) in relation to the society known as the Indian Institute of Technology, Goa, the Indian`
  line `Institute of Technology, Goa;`
  line
  line `(xvii) in relation to the society known as the Indian Institute of Technology, Dharwar, the`
  line `Indian Institute of Technology, Dharwad;`
  line
  line `(xviii) in relation to the society known as the Indian Institute of Technology, Bhilai, the`
  line `Indian Institute of Technology, Bhilai;`
  line
  line `(xix) in relation to the society known as the Indian Institute of Technology, Jammu, the Indian`
  line `Institute of Technology, Jammu;`
  line
  line `(xx) in relation to the society known as the Indian School of Mines, Dhanbad, the Indian`
  line `Institute of Technology (Indian School of Mines), Dhanbad.]`
  line
  line `(d) "Council" means the Council established under sub-section (1) of section 31;`
  line
  line `(e) "Deputy Director", in relation to any Institute, means the Deputy Director thereof;`
  line
  line `(f) "Director", in relation to any Institute, means the Director thereof;`
  line
  line `(g) "Institute" means any of the Institutions mentioned in section 2 and includes the Indian`
  line `Institute of Technology, Kharagpur, incorporated under the Indian Institute of Technology`
  line `(Kharagpur) Act, 1956 (5 of 1956);`
  line
  line `^7[(ga) "Institute of Technology, Banaras Hindu University" means the Institute of Technology`
  line
  line `Banaras Hindu University, referred to in Statute 25(A)(1) of the Statutes set out in the Schedule to the`
  line `Banaras Hindu University Act, 1915 (16 of 1915);]`
  line
  line `^8[(gb) "Indian School of Mines, Dhanbad" means the society known as the Indian School of`
  line `Mines, Dhanbad;]`
  line
  line `(h) "Registrar", in relation to any Institute, means the Registrar thereof;`
  line
  line `(i) "Senate", in relation to any Institute, means the Senate thereof;`
  line
  line `(j) "society" means any of the following societies registered under the Societies Registration`
  line `Act, 1860, (21 of 1860) namely:--`
  line
  line `(i) the Indian Institute of Technology, Bombay;`
  line
  line `^9[(ia) the College of Engineering and Technology, Delhi;]`
  line
  line `^10[(ib) the Indian Institute of Technology, Guwahati, Assam,]`
  line
  line `(ii) the Indian Institute of Technology (Kanpur) Society;`
  line
  line `(iii) the Indian Institute of Technology, Madras;`
  line
  line `^7[(iv) the Indian Institute of Technology, Bhubaneswar;`
  line
  line `(v) the Indian Institute of Technology, Gandhinagar;`
  line
  line `(vi) the Indian Institute of Technology, Hyderabad;`
  line
  line `(vii) the Indian Institute of Technology, Indore;`
  line
  line `(viii) the Indian Institute of Technology, Rajasthan;`
  line
  line `(ix) the Indian Institute of Technology, Mandi;`
  line
  line `(x) the Indian Institute of Technology, Patna;`
  line
  line `(xi) the Indian Institute of Technology, Punjab;]`
  line
  line `^8[(xii) the Indian Institute of Technology, Tirupati;`
  line
  line `(xiii) the Indian Institute of Technology, Palakkad;`
  line
  line `(xiv) the Indian Institute of Technology, Goa;`
  line
  line `(xv) the Indian Institute of Technology, Dharwad;`
  line
  line `(xvi) the Indian Institute of Technology, Bhilai;`
  line
  line `(xvii) the Indian Institute of Technology, Jammu;`
  line
  line `(xviii) the Indian School of Mines, Dhanbad;]`
  line
  line `(k) "Statutes" and "Ordinances", in relation to any Institute, mean the Statutes and Ordinances of`
  line `the Institute made under this Act.`
  line
  line `^11[(l) "University of Roorkee" means the University of Roorkee established under the Roorkee`
  line `University Act, 1947 (U.P. Act IX of 1948);]`
  line
  line `^12[(m) "zone", in relation to an Institute, means such group of States and Union territories as the`
  line `Central Government may, by notification in the Official Gazette, specify.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Ins. by Act 29 of 1963, s. 3 (w.e.f. 13-9-1963).`
  line
  line `2. Ins. by Act 35 of 1994, s. 3 (w.e.f. 1-9-1994).`
  line
  line `3. The word "and" omitted by Act 16 of 2002, s. 3 (w.e.f. 21-9-2001).`
  line
  line `4. Ins. by s. 3, ibid. (w.e.f. 21-9-2001).`
  line
  line `5. Ins. by Act 34 of 2012, s. 3 (w.e.f. 29-6-2012).`
  line
  line `6. The words in brackets shall stand inserted (date to be notified) by Act 41 of 2016, s. 3.`
  line
  line `7. Ins. by Act 34 of 2012, s. 3 (w.e.f. 29-6-2012).`
  line
  line `8. The words in brackets shall stand inserted (date to be notified) by Act 41 of 2016, s. 3.`
  line
  line `9. Ins. by Act 29 of 1963, s. 3 (w.e.f. 13-9-1963).`
  line
  line `10. Ins. by Act 35 of 1994, s. 3 (w.e.f. 1-9-1994).`
  line
  line `11. Ins. by Act 16 of 2002, s. 3 (w.e.f. 21-9-2001).`
  line
  line `12. Ins. by Act 34 of 2012, s. 3 (w.e.f. 29-6-2012).`
obj_root_law_sections_4:
  sectionId (24029)
  sectionNo (4)
  orderNo 4
  title `Incorporation of institutes.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24029&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_4_content:
  string
  line `(1) Each of the Institutes mentioned in section 2 shall be a body`
  line `corporate having perpetual succession and a common seal and shall, by its name, sue and be sued.`
  line
  line `^1[(1A) The College of Engineering and Technology, Delhi shall, on such incorporation, be called the`
  line `Indian Institute of Technology, Delhi`
  line
  line `^2[(1B) The Indian Institute of Technology, Guwahati Assam shall, on such incorporation, be called`
  line `the Indian Institute of Technology, Guwahati.]`
  line
  line `^3[(1C) The University of Roorkee, Roorkee shall, on such incorporation, be called the Indian Institute`
  line `of Technology, Roorkee.]`
  line
  line `^4[(1D) The Institute of Technology, Banaras Hindu University shall, on such incorporation, be called`
  line `the Indian Institute of Technology (Banaras Hindu University), Varanasi.]`
  line
  line `^5[(IE) The Indian School of Mines, Dhanbad shall, on such incorporation, be called the Indian`
  line `Institute of Technology (Indian School of Mines), Dhanbad.]`
  line
  line `(2) The body corporate constituting each of the said Institutes shall consist of a Chairman, a Director`
  line `and other members of the Board for the time being of the Institute.`
obj_root_law_sections_4_footnotes:
  string
  line `1. Ins. by Act 29 of 1963, s. 4 (w.e.f. 13-9-1963).`
  line `2. Ins. by Act 35 of 1994, s. 4 (w.e.f. 1-9-1994).`
  line `3. Ins. by Act 16 of 2002, s. 4 (w.e.f. 21-9-2001).`
  line `4. Ins. by Act 34 of 2012, s. 4 (w.e.f. 29-6-2012).`
  line `5. The words in brackets shall stand inserted (date to be notified) by Act 41 of 2016, s. 4.`
obj_root_law_sections_5:
  sectionId (24030)
  sectionNo (5)
  orderNo 5
  title `Effect of incorporation of institutes.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24030&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_5_content:
  string
  line `On and from the commencement of this Act,--`
  line
  line `(a) any reference to a society in any law (other than this Act) or in any contract or other`
  line `instrument shall be deemed as a reference to the corresponding Institute;`
  line
  line `(b) all property, movable and immovable, of or belonging to a society shall vest in the`
  line `corresponding Institute;`
  line
  line `(c) all the rights and liabilities of a society shall be transferred to, and be the rights and liabilities`
  line `of, the corresponding Institute; and`
  line
  line `(d) every person employed by a society immediately before such commencement shall hold his`
  line `office or service in the corresponding Institute by the same tenure, at the same remuneration and upon`
  line `the same terms and conditions and with the same rights and privileges as to pension, leave, gratuity,`
  line `provident fund and other matters as he would have held the same if this Act had not been passed, and`
  line `shall continue to do so unless and until his employment is terminated or until such tenure,`
  line `remuneration and terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alternation so made is not acceptable to such employee, his employment may`
  line `be terminated by the Institute in accordance with the terms of the contract with the employee or, if no`
  line `provision is made therein in this behalf, on payment to him by the Institute of compensation`
  line `equivalent to three months' remuneration in the case of permanent employees and one month's`
  line `remuneration in the case of other employees.`
  line
  line `^1[^2[Explanation 1.]--The reference in the section to the commencement of this Act shall be`
  line `construed in relation to the Indian Institute of Technology, Guwahati as the reference to the date on`
  line `which the provisions of the Institutes of Technology (Amendment) Act, 1994) come into force.]`
  line
  line `^3[Explanation 2.The reference in this section to the commencement of this Act shall be`
  line `construed in relation to the Indian Institute of Technology, Bhubaneswar, the Indian Institute of`
  line `Technology, Gandhinagar, the Indian Institute of Technology, Hyderabad, the Indian Institute of`
  line `Technology, Indore, the Indian Institute of Technology, Jodhpur, the Indian Institute of Technology,`
  line `Mandi, the Indian Institute of Technology, Patna and the Indian Institute of Technology, Ropar, as the`
  line `reference to the date on which the provisions of the Institutes of Technology (Amendment) Act, 2012`
  line `come into force.]`
  line
  line `^4[Explanation 3.--The reference in this section to the commencement of this Act shall be`
  line `construed in relation to the Indian Institute of Technology, Tirupati, the Indian Institute of`
  line `Technology, Palakkad, the Indian Institute of Technology, Goa, the Indian Institute of Technology,`
  line `Dharwad, the Indian Institute of Technology, Bhilai, the Indian Institute of Technology, Jammu, and`
  line `the Indian Institute of Technology (Indian School of Mines) Dhanbad, as the reference to the date on`
  line `which the provisions of the Institutes of Technology (Amendment) Act, 2016 come into force.]`
obj_root_law_sections_5_footnotes:
  string
  line `1. The Explanation inserted by Act 35 of 1994, s. 5 (w.e.f. 1-9-1994).`
  line
  line `2. Explanation numbered as Explanation 1 thereof by Act 34 of 2012, s. 5 (w.e.f. 29-6-2012).`
  line
  line `3. Ins. by Act 34 of 2012, s. 5 (w.e.f. 29-6-2012).`
  line
  line `4. The words in brackets shall stand inserted (date to be notified) by Act 41 of 2016, s. 5.`
obj_root_law_sections_5_a:
  sectionId (24031)
  sectionNo 5A
  orderNo 6
  title `Effect of incorporation of Institute of Technology, Roorkee.`
  content obj_root_law_sections_5_a_content
  footnotes `1. Ins. by Act 16 of 2002, s. 5 (w.e.f. 21-9-2001).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24031&sectionno=5A&orderno=6&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_5_a_content:
  string
  line `^1[5A. Effect of incorporation of Institute of Technology, Roorkee.--On and from the`
  line `commencement of the Institutes of Technology (Amendment) Act, 2002 (16 of 2002),--`
  line
  line `(a) any reference to the University of Roorkee in any law (other than this Act) or in any contract`
  line `or other instrument shall be deemed as a reference to the Indian Institute of Technology, Roorkee;`
  line
  line `(b) all property, movable and immovable, of or belonging to the University of Roorkee, shall vest`
  line `in the Indian Institute of Technology, Roorkee;`
  line
  line `(c) all rights and liabilities of the University of Roorkee shall be transferred to, and be the rights`
  line `and liabilities of, the Indian Institute of Technology, Roorkee;`
  line
  line `(d) every person employed by the University of Roorkee immediately before such`
  line `commencement shall hold his office or service in the Indian Institute of Technology, Roorkee by the`
  line `same tenure, at the same remuneration and upon the same terms and conditions and with the same`
  line `rights and privileges as to pension, leave, gratuity, provident fund and other matters as he would have`
  line `held the same if this Act had not been passed, and shall continue to do so unless and until his`
  line `employment is terminated or until such tenure, remuneration and terms and conditions are duly`
  line `altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the Indian Institute of Technology, Roorkee in accordance with the terms of the`
  line `contract with the employee or, if no provision is made therein in this behalf, on payment to him by the`
  line `Indian Institute of Technology, Roorkee of compensation equivalent to three months remuneration in`
  line `the case of permanent employees and one months remuneration in the case of other employees:`
  line
  line `Provided further that any reference, by whatever form of words, to the Vice-Chancellor and`
  line `Pro-Vice-Chancellor of the University of Roorkee in any law for the time being in force, or in any`
  line `instrument or other document, shall be construed as a reference to the Director and the Deputy`
  line `Director, respectively, of the Indian Institute of Technology, Roorkee; and`
  line
  line `(e) on the commencement of the Institutes of Technology (Amendment) Act, 2002 (16 of 2002),`
  line `the Vice-Chancellor of the University of Roorkee, appointed under the provisions of the Roorkee`
  line `University Act, 1947 (U.P. Act IX of 1948) shall be deemed to have been appointed as Director under`
  line `the Act, and shall hold office for a period of three months or till such time the Director is appointed,`
  line `whichever is earlier.`
  line
  line `Explanation.--The reference in this section to the commencement of this Act shall be construed in`
  line `relation to the Indian Institute of Technology, Roorkee as the reference to the date on which the`
  line `provisions of the Institutes of Technology (Amendment) Act, 2002 (16 of 2002) come into force.]`
obj_root_law_sections_5_b:
  sectionId (24032)
  sectionNo 5B
  orderNo 7
  title `Effect of incorporation of Indian Institute of Technology (Banaras Hindu University), Varanasi.`
  content obj_root_law_sections_5_b_content
  footnotes `1. Ins. by Act 34 of 2012, s. 6 (w.e.f. 29-6-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24032&sectionno=5B&orderno=7&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_5_b_content:
  string
  line `^1[5B. Effect of incorporation of Indian Institute of Technology (Banaras Hindu`
  line `University), Varanasi.--On and from the commencement of the Institutes of Technology (Amendment)`
  line `Act, 2012 (34 of 2012),--`
  line
  line `(a) any reference to the Institute of Technology, Banaras Hindu University in any law for the time`
  line `being in force (other than this Act) or in any contract or other instrument shall be deemed as a`
  line `reference to the Indian Institute of Technology (Banaras Hindu University), Varanasi;`
  line
  line `(b) all property, movable and immovable, of or belonging to the Institute of Technology, Banaras`
  line `Hindu University, shall vest in the Indian Institute of Technology (Banaras Hindu University),`
  line Varanasi;
  line
  line `(c) all rights and liabilities of the Institute of Technology, Banaras Hindu University shall be`
  line `transferred to, and be the rights and liabilities of, the Indian Institute of Technology (Banaras Hindu`
  line `University), Varanasi;`
  line
  line `(d) every person employed in the Institute of Technology, Banaras Hindu University immediately`
  line `before such commencement shall hold his office or service in the Indian Institute of Technology`
  line `(Banaras Hindu University), Varanasi by the same tenure, at the same remuneration and upon the`
  line `same terms and conditions and with the same rights and privileges as to pension, leave, gratuity,`
  line `provident fund and other matters as he would have held the same if this Act had not been passed and`
  line `shall continue to do so unless and until his employment is terminated or until such tenure,`
  line `remuneration and terms and conditions are duly altered by the Statutes:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the Indian Institute of Technology (Banaras Hindu University), Varanasi in`
  line `accordance with the terms of the contract with the employee or, if no provision is made therein in this`
  line `behalf, on payment to him by the Indian Institute of Technology (Banaras Hindu University),`
  line `Varanasi of compensation equivalent to three months remuneration in the case of permanent`
  line `employees and one month's remuneration in the case of other employees:`
  line
  line `Provided further that any reference, by whatever form of words, to the Director of the Institute of`
  line `Technology, Banaras Hindu University in any law for the time being in force, or in any instrument or`
  line `other document, shall be construed as a reference to the Director of the Indian Institute of Technology`
  line `(Banaras Hindu University), Varanasi; and`
  line
  line `(e) on the commencement of the Institutes of Technology (Amendment)`
  line `Act, 2012 (34 of 2012)--`
  line
  line `(i) the Vice-Chancellor of the Banaras Hindu University, appointed under the provisions of`
  line `the Banaras Hindu University Act, 1915 (16 of 1915) shall be deemed to have been appointed as`
  line `ex officio Chairman of the Board of Governors of the Indian Institute of Technology (Banaras`
  line `Hindu University), Varanasi under this Act, and shall hold office for a period of three years with`
  line `effect from such commencement;`
  line
  line `(ii) the Director of the Institute of Technology, Banaras Hindu University, appointed under`
  line `the provisions of the Banaras Hindu University Act, 1915 (16 of 1915) shall be deemed to have`
  line `been appointed as Director of the Indian Institute of Technology (Banaras Hindu University),`
  line `Varanasi under this Act, and shall hold his office till Director is appointed under this Act.`
  line
  line `Explanation.--The reference in this section to the commencement of this Act shall be construed in`
  line `relation to the Indian Institute of Technology (Banaras Hindu University), Varanasi as the reference to the`
  line `date on which the provisions of the Institutes of Technology (Amendment) Act, 2012 (34 of 2012) come`
  line `into force.]`
obj_root_law_sections_6:
  sectionId (24033)
  sectionNo (6)
  orderNo 8
  title `Powers of Institutes.`
  content obj_root_law_sections_6_content
  footnotes `1. Ins. by Act 34 of 2012, s. 7 (w.e.f. 29-6-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24033&sectionno=6&orderno=8&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_6_content:
  string
  line `(1) Subject to the provisions of this Act, every Institute shall exercise the`
  line `following powers and perform the following duties, namely:--`
  line
  line `(a) to provide for instruction and research in such branches of engineering and technology,`
  line `sciences and arts, as the Institute may think fit, and for the advancement of learning and`
  line `dissemination of knowledge in such branches;`
  line
  line `(b) to hold examinations and grant degrees, diplomas and other academic distinctions or titles;`
  line
  line `(c) to confer honorary degrees or other distinctions;`
  line
  line `(d) to fix, demand and receive fees and other charges;`
  line
  line `(e) to establish, maintain and manage halls and hostels for the residence of students;`
  line
  line `(f) to supervise and control the residence and regulate the discipline of students of the Institute`
  line `and to make arrangements for promoting their health, general welfare and cultural and corporate life;`
  line
  line `(g) to provide for the maintenance of units of the National Cadet Corps for the students of the`
  line Institute;
  line
  line `(h) to institute academic and other posts and to make appointments thereto (except in the case of`
  line `the Director) ;`
  line
  line `(i) to frame Statutes and Ordinances and to alter, modify or rescind the same;`
  line
  line `(j) to deal with any property belonging to or vested in the Institute in such manner as the Institute`
  line `may deem fit for advancing the objects of the Institute;`
  line
  line `(k) to receive gifts, grants, donations or benefactions from the Government and to receive`
  line `bequests, donations and transfers of movable or immovable properties from testators, donors or`
  line `transferors, as the case may be;`
  line
  line `(l) to co-operate with educational or other institutions in any part of the world having objects`
  line `wholly or partly similar to those of the Institute by exchange of teachers and scholars and generally in`
  line `such manner as may be conducive to their common objects;`
  line
  line `(m) to institute and award fellowships, scholarships, exhibitions, prizes and medals; and`
  line
  line `(n) to do all such things as may be necessary, incidental or conducive to the attainment of all or`
  line `any of the objects of the Institute.`
  line
  line `^1[(1A) subject to the provisions of this Act, every Institute may strive to meet the technological needs`
  line `of the States and the Union territories included in its zone by--`
  line
  line `(a) supporting and collaborating with technical education institutions located in the zone with a`
  line `view to enhance their quality and capability;`
  line
  line `(b) advising the State Governments and the Union territories included in its zone in the matter of`
  line `technical education and any technological issue referred by them to the Institute for advice.]`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), an Institute shall not dispose of in any`
  line `manner any immovable property without the prior approval of the Visitor.`
obj_root_law_sections_7:
  sectionId (24034)
  sectionNo (7)
  orderNo 9
  title `Institutes to be open to all races, creeds and classes.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24034&sectionno=7&orderno=9&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_7_content:
  string
  line `(1) Every Institute shall be open to`
  line `persons of either sex an of whatever race, creed, caste or class, and no test or condition shall be imposed`
  line `as to religious belief or profession in admitting or appointing members, students, teachers or workers or in`
  line `any other connection whatsoever.`
  line
  line `(2) No bequest, donation or transfer of any property shall be accepted by any Institute which in the`
  line `opinion of the Council involves conditions or obligations opposed to the spirit and object of this section.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (24035)
  sectionNo (8)
  orderNo 10
  title `Teaching at Institute.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24035&sectionno=8&orderno=10&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_8_content:
  string
  line `All teaching at each of the Institutes shall be conducted by or in the name`
  line `of the Institute in accordance with the Statutes and Ordinances made in this behalf.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (24036)
  sectionNo (9)
  orderNo 11
  title Visitor.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24036&sectionno=9&orderno=11&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_9_content:
  string
  line `(1) The President of India shall be the Visitor of every Institute.`
  line
  line `(2) The Visitor may appoint one or more persons to review the work and progress of any Institute and`
  line `to hold inquiries into the affairs thereof and to report thereon in such manner as the Visitor may direct.`
  line
  line `(3) Upon receipt of any such report, the Visitor may take such action and issue such directions as he`
  line `considers necessary in respect of any of the matters dealt with in the report and the Institute shall be`
  line `bound to comply with such directions.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (24037)
  sectionNo (10)
  orderNo 12
  title `Authorities of Institutes.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24037&sectionno=10&orderno=12&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_10_content:
  string
  line `The following shall be the authorities of an Institute, namely:--`
  line
  line `(a) a Board of Governors;`
  line
  line `(b) a Senate; and`
  line
  line `(c) such other authorities as may be declared by the Statutes to be the authorities of the Institute.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (24038)
  sectionNo (11)
  orderNo 13
  title `Board of Governors.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24038&sectionno=11&orderno=13&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_11_content:
  string
  line `The Board of an Institute shall consist of the following persons,`
  line `namely:--`
  line
  line `(a) the Chairman, to be nominated by the Visitor;`
  line
  line `(b) the Director, ex officio;`
  line
  line `(c) one person to be nominated by the Government of each of the States comprising the zone in`
  line `which the Institute is situated, from among persons who, in the opinion of that Government, are`
  line `technologists or industrialists of repute;`
  line
  line `(d) four persons having special knowledge or practical experience in respect of education,`
  line `engineering or science, to be nominated by the Council; and`
  line
  line `(e) two professors of the Institute, to be nominated by the Senate:`
  line
  line `^1[Provided that in the case of the Indian Institute of Technology (Banaras Hindu University),`
  line Varanasi,--
  line
  line `(a) the Board of such Institute shall consist of Vice-Chairman to be nominated, after a`
  line `period of three years from the commencement of the Institutes of Technology (Amendment)`
  line `Act, 2012 (34 of 2012), by the Executive Council referred to in clause (d) of section 2 of the`
  line `Banaras Hindu University Act, 1915 (16 of 1915), from amongst its members including its`
  line `Vice-Chancellor;"`
  line
  line `(b) four persons to be nominated under clause (d), out of which two persons to be nominated by`
  line `the Executive Council referred to in clause (d) of section 2 of the Banaras Hindu University`
  line `Act, 1915 (16 of 1915), from amongst its members including its Vice-Chancellor.]`
  line
  line `^2* * * * *`
obj_root_law_sections_11_footnotes:
  string
  line `1. Ins. by Act 34 of 2012, s. 8 (w.e.f. 29-6-2012).`
  line
  line `2. The Explanation omitted by Act 34 of 2012, s. 8 (w.e.f. 29-6-2012).`
obj_root_law_sections_12:
  sectionId (24039)
  sectionNo (12)
  orderNo 14
  title `Term of office of, vacancies among, and allowances payable to, members of Board.`
  content obj_root_law_sections_12_content
  footnotes `1. Subs. by Act 29 of 1963, s. 5, for "clause (c)" (w.e.f. 13-9-1963).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24039&sectionno=12&orderno=14&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_12_content:
  string
  line `(1) Save as otherwise provided in this section, the term of office of the Chairman or any other`
  line `member of the Board shall be three years from the date of his nomination.`
  line
  line `(2) The term of office of an ex officio member shall continue so long as he holds the office by virtue`
  line `of which he is a member.`
  line
  line `(3) The term of office of a member nominated under ^1[clause (e)] of section 11 shall be two years`
  line `from the 1st day of January of the year in which he is nominated.`
  line
  line `(4) The term of office of a member nominated to fill a casual vacancy shall continue for the`
  line `remainder of the term of the member in whose place he has been nominated.`
  line
  line `(5) Notwithstanding anything contained in this section, an outgoing member shall, unless the Council`
  line `otherwise directs, continue in office until another person is nominated as a member in his place.`
  line
  line `(6) The members of the Board shall be entitled to such allowances, if any, from the Institute as may`
  line `be provided for in the Statutes but no member other than the persons referred to in clauses (b) and (e) of`
  line `section 11 shall be entitled to any salary by reason of this sub-section.`
obj_root_law_sections_13:
  sectionId (24040)
  sectionNo (13)
  orderNo 15
  title `Functions of Board.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24040&sectionno=13&orderno=15&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_13_content:
  string
  line `(1) Subject to the provisions of this Act, the Board of any Institute shall be`
  line `responsible for the general superintendence, direction and control of the affairs of the Institute and shall`
  line `exercise all the powers of the Institute not otherwise provided for by this Act, the Statutes and the`
  line `Ordinances, and shall have the power to review the acts of the Senate.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Board of any Institute shall--`
  line
  line `(a) take decisions on questions of policy relating to the administration and working of the`
  line Institute;
  line
  line `(b) institute courses of study at the Institute;`
  line
  line `(c) make Statutes;`
  line
  line `(d) institute and appoint persons to academic as well as other posts in the Institute;`
  line
  line `(e) consider and modify or cancel Ordinances;`
  line
  line `(f) consider an pass resolutions on the annual report, the annual accounts and the budget estimates`
  line `of the Institute for the next financial year as it thinks fit and submit them to the Council together with`
  line `a statement of its development plans;`
  line
  line `(g) exercise such other powers and perform such other duties as may be conferred or imposed`
  line `upon it by this Act or the Statutes.`
  line
  line `(3) The Board shall have the power to appoint such committees as it considers necessary for the`
  line `exercise of its powers and the performance of its duties under this Act.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (24041)
  sectionNo (14)
  orderNo 16
  title Senate.
  content obj_root_law_sections_14_content
  footnotes `1. The proviso ins. by Act 34 of 2012, s. 9 (w.e.f. 29-6-2012).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24041&sectionno=14&orderno=16&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_14_content:
  string
  line `The Senate of each Institute shall consist of the following persons, namely:--`
  line
  line `(a) the Director, ex officio, who shall be the Chairman of the Senate;`
  line
  line `(b) the Deputy Director, ex officio;`
  line
  line `(c) the professors appointed or recognised as such by the Institute for the purpose of imparting`
  line `instruction in the Institute;`
  line
  line `(d) three persons, not being employees of the Institute, to be nominated by the Chairman in`
  line `consultation with the Director, from among educationists of repute, one each from the fields of`
  line `science, engineering and humanities; and`
  line
  line `(e) such other members of the staff as may be laid down in the Statutes.`
  line
  line `^1[Provided that in case of the Indian Institute of Technology (Banaras Hindu University), Varanasi,`
  line `three members shall be nominated by the Executive Council referred to in clause (d) of section 2 of the`
  line `Banaras Hindu University Act, 1915 (16 of 1915).]`
obj_root_law_sections_15:
  sectionId (24042)
  sectionNo (15)
  orderNo 17
  title `Functions of Senate.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24042&sectionno=15&orderno=17&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_15_content:
  string
  line `Subject to the provisions of this Act, the Statutes and the Ordinances, the`
  line `Senate of an Institute shall have the control and general regulation, and be responsible for the`
  line `maintenance, of standards of instruction, education and examination in the Institute and shall exercise`
  line `such other powers an perform such other duties as may be conferred or imposed upon it by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (24043)
  sectionNo (16)
  orderNo 18
  title `Chairman of Board.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24043&sectionno=16&orderno=18&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_16_content:
  string
  line `(1) The Chairman shall ordinarily preside at the meetings of the Board`
  line `and at the Convocations of the Institute.`
  line
  line `(2) It shall be the duty of the Chairman to ensure that the decisions taken by the Board are`
  line implemented.
  line
  line `(3) The Chairman shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by this Act or the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (24044)
  sectionNo (17)
  orderNo 19
  title Director.
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24044&sectionno=17&orderno=19&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_17_content:
  string
  line `(1) The Director of each Institute shall be appointed by the Council with the prior`
  line `approval of the Visitor.`
  line
  line `(2) The Director shall be the principal academic and executive officer of the Institute and shall be`
  line `responsible for the proper administration of the Institute and for the imparting of instruction and`
  line `maintenance of discipline therein.`
  line
  line `(3) The Director shall submit annual reports and accounts to the Board.`
  line
  line `(4) The Director shall exercise such other powers and perform such other duties as may be assigned to`
  line `him by this Act or the Statutes or Ordinances.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (24045)
  sectionNo (18)
  orderNo 20
  title `Deputy Director.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24045&sectionno=18&orderno=20&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_18_content:
  string
  line `The Deputy Director of each Institute shall be appointed on such terms and`
  line `conditions as my be laid down by the Statutes and shall exercise such powers and perform such duties as`
  line `may be assigned to him by this Act or the Statutes or by the Director.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (24046)
  sectionNo (19)
  orderNo 21
  title Registrar.
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24046&sectionno=19&orderno=21&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_19_content:
  string
  line `(1) The Registrar of each Institute shall be appointed on such terms and conditions as`
  line `may be laid down by the Statutes and shall be the custodian of records, the common seal, the funds of the`
  line `Institute and such other property of the Institute as the Board shall commit to his charge.`
  line
  line `(2) The Registrar shall act as the Secretary of the Board, the Senate, and such committees as may be`
  line `prescribed by the Statutes.`
  line
  line `(3) The Registrar shall be responsible to the Director for the proper discharge of his functions.`
  line
  line `(4) The Registrar shall exercise such other powers and perform such other duties as may be assigned`
  line `to him by this Act or the Statutes or by the Director.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (24047)
  sectionNo (20)
  orderNo 22
  title `Other authorities and officers.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24047&sectionno=20&orderno=22&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_20_content:
  string
  line `The powers and duties of authorities and officers other than`
  line `those hereinbefore mentioned shall be determined by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (24048)
  sectionNo (21)
  orderNo 23
  title `Grants by Central Government.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24048&sectionno=21&orderno=23&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_21_content:
  string
  line `For the purpose of enabling the Institutes to discharge their`
  line `functions efficiently under this Act, the Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to each Institute in each financial year such sums of money and in`
  line `such manner as it may think fit.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (24049)
  sectionNo (22)
  orderNo 24
  title `Fund of the Institute.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24049&sectionno=22&orderno=24&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_22_content:
  string
  line `(1) Every Institute shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provide by the Central Government;`
  line
  line `(b) all fees and other charges received by the Institute;`
  line
  line `(c) all moneys received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all moneys received by the Institute in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund of any Institute shall be deposited in such Banks or invested in`
  line `such manner as the Institute may, with the approval of the Central Government, decide.`
  line
  line `(3) The Fund of any Institute shall be applied towards meeting the expenses of the Institute including`
  line `expenses incurred in the exercise of its powers and discharge of its duties under this Act.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (24050)
  sectionNo (23)
  orderNo 25
  title `Accounts and audit.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24050&sectionno=23&orderno=25&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_23_content:
  string
  line `(1) Every Institute shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts, including the balance-sheet, in such form as may be`
  line `prescribed by the Central Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of every Institute shall be audited by the Comptroller and Auditor-General of India`
  line `and any expenditure incurred by him in connection with such audit shall be payable by the Institute to the`
  line `comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of any Institute shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts, and, in particular, shall have the right to demand the production of books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line Institute.
  line
  line `(4) The accounts of every Institute as certified by the Comptroller and Auditor-General of India or`
  line `any other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (24051)
  sectionNo (24)
  orderNo 26
  title `Pension and provident fund.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24051&sectionno=24&orderno=26&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_24_content:
  string
  line `(1) Every Institute shall constitute for the benefit of its`
  line `employees, including the Director, in such manner and subject to such conditions as may be prescribed by`
  line `the Statutes, such pension, insurance and provident funds as it may deem fit.`
  line
  line `(2) Where any such provident fund has been so constituted, the Central Government may declare that`
  line `the provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to such fund as if it were a`
  line `Government Provident Fund.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (24052)
  sectionNo (25)
  orderNo 27
  title Appointments.
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24052&sectionno=25&orderno=27&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_25_content:
  string
  line `All appointments on the staff of any Institute, except that of the Director, shall`
  line `be made in accordance with the procedure laid down in the Statutes, by--`
  line
  line `(a) the Board, if the appointment is made on the academic staff in the post of Lecturer or above or`
  line `if the appointment is made on the non-academic staff in any cadre the maximum of the pay-scale for`
  line `which exceeds six hundred rupees per month;`
  line
  line `(b) by the Director, in any other case.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (24053)
  sectionNo (26)
  orderNo 28
  title Statutes.
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24053&sectionno=26&orderno=28&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_26_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:--`
  line
  line `(a) the conferment of honorary degrees;`
  line
  line `(b) the formation of departments of teaching;`
  line
  line `(c) the fees to be charged for courses of study in the Institute and for admission to the`
  line `examinations of degree and diplomas of the Institute;`
  line
  line `(d) the institution of fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(e) the term of office and the method of appointment of officers of the Institute;`
  line
  line `(f) the qualifications of teachers of the Institute;`
  line
  line `(g) the classification, the method of appointment and the determination of the terms and`
  line `conditions of service of, teachers and other staff of the Institute;`
  line
  line `(h) the constitution of pension, insurance and provident funds for the benefit of the officers,`
  line `teachers and other staff of the Institute;`
  line
  line `(i) the constitution, powers and duties of the authorities of the Institute;`
  line
  line `(j) the establishment and maintenance of halls and hostels;`
  line
  line `(k) the conditions of residence of students of the Institute and the levying of fees for residence in`
  line `the halls and hostels and of other charges;`
  line
  line `(l) the manner of filling vacancies among members of the Board;`
  line
  line `(m) the allowances to be paid to the Chairman and members of the Board;`
  line
  line `(n) the authentication of the orders and decisions of the Board;`
  line
  line `(o) the meetings of the Board, the Senate, or any Committee, the quorum at such meetings and the`
  line `procedure to be followed in the conduct of their business;`
  line
  line `(p) any other matter which by this Act is to be or may be prescribed by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (24054)
  sectionNo (27)
  orderNo 29
  title `Statutes how made.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24054&sectionno=27&orderno=29&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_27_content:
  string
  line `(1) The first Statutes of each Institute shall be framed by the Council with`
  line `the previous approval of the Visitor and a copy of the same shall be laid as soon as may be before each`
  line `House of Parliament.`
  line
  line `(2) The Board may, from time to time, make new or additional Statutes or may amend or repeal the`
  line `Statutes in the manner hereafter in this section provided.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require`
  line `the previous approval of the Visitor who may assent thereto or withhold assent or remit it to the Board or`
  line consideration.
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (24055)
  sectionNo (28)
  orderNo 30
  title Ordinances.
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24055&sectionno=28&orderno=30&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_28_content:
  string
  line `Subject to the provisions of this Act and the Statutes, the Ordinances of each`
  line `Institute may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of the students to the Institute;`
  line
  line `(b) the courses of study to be laid down for all degrees and diplomas of the Institute;`
  line
  line `(c) the conditions under which students shall be admitted to the degree or diploma courses and to`
  line `the examinations of the Institute, and shall be eligible for degrees and diplomas;`
  line
  line `(d) the conditions of award of the fellowships, scholarships, exhibitions, medals and prizes;`
  line
  line `(e) the conditions and mode of appointment and duties of examining bodies, examiners and`
  line moderators;
  line
  line `(f) the conduct of examinations;`
  line
  line `(g) the maintenance of discipline among the students of the Institute; and`
  line
  line `(h) any other matter which by this Act or the Statutes is to be or may be provided for by the`
  line Ordinances.
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (24056)
  sectionNo (29)
  orderNo 31
  title `Ordinances how made.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24056&sectionno=29&orderno=31&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_29_content:
  string
  line `(1) Save as otherwise provided in this section, Ordinances shall be`
  line `made by the Senate.`
  line
  line `(2) All Ordinances made by the Senate shall have effect from such date as it may direct, but every`
  line `Ordinance so made shall be submitted, as soon as may be, to the Board and shall be considered by the`
  line `Board at its next succeeding meeting.`
  line
  line `(3) The Board shall have power by resolution to modify or cancel any such Ordinance and such`
  line `Ordinance shall from the date of such resolution stand modified accordingly or cancelled, as the case may`
  line be.
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (24057)
  sectionNo (30)
  orderNo 32
  title `Tribunal of Arbitration.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24057&sectionno=30&orderno=32&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_30_content:
  string
  line `(1) Any dispute arising out of a contract between an Institute and any`
  line `of its employees shall, at the request of the employee concerned or at the instance of the Institute, be`
  line `referred to a Tribunal of Arbitration consisting of one member appointed by the Institute, one member`
  line `nominated by the employee, and an umpire appointed by the Visitor.`
  line
  line `(2) The decision of the Tribunal shall be final and shall not be questioned in any court.`
  line
  line `(3) No suit or proceeding shall lie in any court in respect of any matter which is required by`
  line `sub-section (1) to be referred to the Tribunal of Arbitration.`
  line
  line `(4) The Tribunal of Arbitration shall have power to regulate its own procedure.`
  line
  line `(5) Nothing in any law for the time being in force relating to arbitration shall apply to arbitrations`
  line `under this section.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (24058)
  sectionNo (31)
  orderNo 33
  title `Establishment of Council.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24058&sectionno=31&orderno=33&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_31_content:
  string
  line `(1) With effect from such date as the Central Government may, by`
  line `notification in the Official Gazette, specify in this behalf, there shall be established a central body to be`
  line `called the Council.`
  line
  line `(2) The Council shall consist of the following members, namely:--`
  line
  line `(a) the Minister in charge of technical education in the Central Government, ex officio, as`
  line Chairman;
  line
  line `(b) the Chairman of each Institute, ex officio;`
  line
  line `(c) the Director of each Institute, ex officio;`
  line
  line `(d) the Chairman, University Grants Commission, ex officio;`
  line
  line `(e) the Director-General, Council of Scientific and Industrial Research, ex officio;`
  line
  line `(f) the Chairman of the Council of the Indian Institute of Science, Bangalore, ex officio;`
  line
  line `(g) the Director of the Indian Institute of Science, Bangalore, ex officio;`
  line
  line `(h) three persons to be nominated by the Central Government, one to represent the Ministry`
  line `concerned with technical education, another to represent the Ministry of Finance and the third to`
  line `represent any other Ministry;`
  line
  line `(i) one person to be nominated by the All-India Council for Technical Education;`
  line
  line `(j) not less than three, but not more than five, persons to be nominated by the Visitor, who shall`
  line `be persons having special knowledge or practical experience in respect of education, industry, science`
  line `or technology;`
  line
  line `(k) three Members of Parliament, of whom two shall be elected by the House of the People from`
  line `among its members and one by the Council of States from among its members.`
  line
  line `(3) An officer of the Ministry of the Central Government concerned with technical education shall be`
  line `nominated by that Government to act as the Secretary of the Council.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (24059)
  sectionNo (32)
  orderNo 34
  title `Term of office of, vacancies among, and allowances payable to, members of Council.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24059&sectionno=32&orderno=34&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_32_content:
  string
  line `(1) Save as otherwise provided in this section, the term of office of a member of the Council`
  line `shall be three years from the date of his nomination or election, as the case may be.`
  line
  line `(2) The term of office of an ex officio member shall continue so long as he holds the office by virtue`
  line `of which he is a member.`
  line
  line `(3) A member of the Council referred to in clause (h) of sub-section (2) of section 31 shall hold office`
  line `during the pleasure of the Central Government.`
  line
  line `(4) The term of office of a member elected under clause (k) of sub-section (2) of section 31 shall`
  line `expire as soon as he ceases to be a member of the House which elected him.`
  line
  line `(5) The term of office of a member nominated or elected to fill a casual vacancy shall continue for the`
  line `remainder of the term of the member in whose place he has been nominated or elected.`
  line
  line `(6) Notwithstanding anything contained in this section an outgoing member shall, unless the Central`
  line `Government otherwise directs, continue in office until another person is nominated or elected as a`
  line `member in his place.`
  line
  line `(7) The members of the Council shall be paid such travelling and other allowances by the Central`
  line `Government as may be determined by that Government, but no member shall be entitled to any salary by`
  line `reason of this sub-section.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (24060)
  sectionNo (33)
  orderNo 35
  title `Functions of Council.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24060&sectionno=33&orderno=35&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_33_content:
  string
  line `(1) It shall be the general duty of the Council to co-ordinate the activities`
  line `of all the Institutes.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Council shall perform the following`
  line `functions, namely:--`
  line
  line `(a) to advise on matters relating to the duration of the courses, the degrees and other academic`
  line `distinctions to be conferred by the Institutes, admission standards and other academic matters;`
  line
  line `(b) to lay down policy regarding cadres, methods of recruitment and conditions of service of`
  line `employees, institution of scholarships and freeships, levying of fees and other matters of common`
  line interest;
  line
  line `(c) to examine the development plans of each Institute and to approve such of them as are`
  line `considered necessary and also to indicate broadly the financial implications of such approved plans;`
  line
  line `(d) to examine the annual budget estimates of each Institute and to recommend to the Central`
  line `Government the allocation of funds for the purpose;`
  line
  line `(e) to advise the Visitor, if so required, in respect of any function to be performed by him under`
  line `this Act; and`
  line
  line `(f) to perform such other functions as are assigned to it by or under this Act.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (24061)
  sectionNo (34)
  orderNo 36
  title `Chairman of Council.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24061&sectionno=34&orderno=36&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_34_content:
  string
  line `(1) The Chairman of the Council shall ordinarily preside at the meetings`
  line `of the Council.`
  line
  line `(2) It shall be the duty of the Chairman of the Council to ensure that the decisions taken by the`
  line `Council are implemented.`
  line
  line `(3) The Chairman shall exercise such other powers and perform such other duties as are assigned to`
  line `him by this Act.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (24062)
  sectionNo (35)
  orderNo 37
  title `Power to make rules in respect of matters in this Chapter.`
  content obj_root_law_sections_35_content
  footnotes `1. Ins. by Act 4 of 1986, s. 2 and the Schedule (w.e.f. 15-5-1986).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24062&sectionno=35&orderno=37&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_35_content:
  string
  line `(1) The Central Government may`
  line `^1[, by notification n the Official Gazette,] make rules to carry out the purposes of this Chapter.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of filling vacancies among the members of the Council;`
  line
  line `(b) the disqualifications for being chosen as, and for being a member of the Council;`
  line
  line `(c) the circumstances in which, and the authority by which, members may be removed;`
  line
  line `(d) the meetings of the Council and the procedure of conducting business thereat;`
  line
  line `(e) the travelling and other allowances payable to members of the Council; and`
  line
  line `(f) the functions of the Council and the manner in which such functions may be exercised.`
  line
  line `^1[(3) Every rule made by the Central Government under this Chapter shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the rule or both Houses agree that the rule should not be made, the rule shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that`
  line `any such modification or annulment shall be without prejudice to the validity of anything previously done`
  line `under that rule.]`
obj_root_law_sections_36:
  sectionId (24063)
  sectionNo (36)
  orderNo 38
  title `Acts and proceedings not to be invalidated by vacancies.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24063&sectionno=36&orderno=38&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_36_content:
  string
  line `No act of the Council, or any`
  line `Institute or Board or Senate or any other body set up under this Act or the Statutes, shall be invalid merely`
  line `by reason of--`
  line
  line `(a) any vacancy in, or defect in the constitution thereof, or`
  line
  line `(b) any defect in the election, nomination or appointment of a person acting as a member`
  line `thereof, or`
  line
  line `(c) any irregularity in its procedure not affecting the merits of the case.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (24064)
  sectionNo (37)
  orderNo 39
  title `Power to remove difficulties.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24064&sectionno=37&orderno=39&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_37_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order published in the Official Gazette, make such provision or`
  line `give such direction not inconsistent with the purposes of this Act, as appears to it to be necessary or`
  line `expedient for removing the difficulty.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (24065)
  sectionNo (38)
  orderNo 40
  title `Transitional provisions.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24065&sectionno=38&orderno=40&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_38_content:
  string
  line `Notwithstanding anything contained in this Act,--`
  line
  line `(a) the Board of Governors of an Institute functioning as such immediately before the`
  line `commencement of this Act shall continue to so function until a new Board is constituted for that`
  line `Institute under this Act, but on the constitution of a new Board under this Act, the members of the`
  line `Board holding office before such constitution shall cease to hold office;`
  line
  line `(b)`
  line `^1[the Staff Committee constituted in relation to the College of Engineering and Technology,`
  line `Delhi and any Academic Council constituted in relation to any other Institute] before the`
  line `commencement of this Act shall be deemed to be the Senate constituted under this Act until a Senate`
  line `is constituted under this Act for that Institute;`
  line
  line `(c) until the first Statutes and the Ordinances are made under this Act, the Statutes and`
  line `Ordinances of the Indian Institute of Technology, kharagpur as in force immediately before the`
  line `commencement of this Act shall continue to apply to that Institute and shall, with the necessary`
  line `modifications and adaptations, also apply to any other Institute, in so far as they are not inconsistent`
  line `with the provisions of this Act;`
  line
  line `^2[(d) until the first Statutes and the Ordinances in relation to the Indian Institute of Technology,`
  line `Guwahati are made under this Act, the Statutes and Ordinances of the Indian Institute of Technology,`
  line `Kharagpur as in force immediately before the commencement of the Institutes of Technology`
  line `(Amendment) Act, 1994 (35 of 1994) shall apply to the Indian Institute of Technology, Guwahati`
  line `with the necessary modification and adaptations in so far as they are not inconsistent with the`
  line `provisions of this Act.`
  line
  line `^3[(e) the Syndicate of the University of Roorkee functioning as such immediately before the`
  line `commencement of this Act shall continue to so function until a new Board is constituted for the`
  line `Indian Institute of Technology, Roorkee under this Act, but on the constitution of a new Board under`
  line `this Act, the members of the Syndicate holding office before such constitution shall cease to hold`
  line office;
  line
  line `(f) the Academic Council of the University of Roorkee functioning as such immediately before`
  line `the commencement of this Act shall continue to so function until a new Senate is constituted for the`
  line `Indian Institute of Technology, Roorkee under this Act, but on the constitution of a new Senate under`
  line `this Act, the members of the Academic Council holding office before such constitution shall cease to`
  line `hold office;`
  line
  line `(g) until the first Statutes and the Ordinances in relation to the Indian Institute of Technology,`
  line `Roorkee are made under this Act, the Statutes and Ordinances of the Indian Institute of Technology,`
  line `Bombay as in force immediately before the commencement of the Institutes of Technology`
  line `(Amendment) Act, 2002 shall apply to the Indian Institute of Technology, Roorkee with the necessary`
  line `modifications and adaptations in so far as they are not inconsistent with the provisions of this Act;`
  line
  line `(h) notwithstanding anything contained in the Institutes of Technology (Amendment)`
  line `Act, 2002 (16 of 2002), any student who joined classes of the University of Roorkee on or after the`
  line `commencement of 1994-95 academic session shall, for the purpose of clause (b) of sub-section (1) of`
  line `section 6, be deemed to have pursued a course of study in the Indian Institute of Technology, Roorkee`
  line `provided that such student has not already been awarded degree or diploma for the same course of`
  line study;
  line
  line `(i) if any difficulty arises in giving effect to the provisions of the Institutes of Technology`
  line `(Amendment) Act, 2002 (16 of 2002), the Central Government may, by order published in the`
  line `Official Gazette, make such provisions not inconsistent with the provisions of this Act as may appear`
  line `to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this clause after the expiry of two years from the`
  line `commencement of the Institutes of Technology (Amendment) Act, 2002 (16 of 2002):`
  line
  line `Provided further that every order made under this clause shall be laid, as soon as may be after it is`
  line `made, before each House of Parliament.]`
  line
  line `^4[(j) until the first Statutes and Ordinances in relation to the Indian Institute of Technology,`
  line `Bhubaneswar, the Indian Institute of Technology, Gandhinagar, the Indian Institute of Technology,`
  line `Hyderabad, the Indian Institute of Technology, Indore, the Indian Institute of Technology, Jodhpur,`
  line `the Indian Institute of Technology, Mandi, the Indian Institute of Technology, Patna and the Indian`
  line `Institute of Technology, Ropar are made under this Act, the Statutes and Ordinances of such Institute,`
  line `as in force immediately before the commencement of the Institutes of Technology (Amendment)`
  line `Act, 2012 (34 of 2012), shall apply to those Institutes with necessary modifications and adaptations in`
  line `so far as they are not inconsistent with the provisions of this Act;`
  line
  line `(k) the Executive Council, referred to in clause (d) of section 2 of the Banaras Hindu University`
  line `Act, 1915 (16 of 1915), functioning as such immediately before the commencement of the Institutes`
  line `of Technology (Amendment) Act, 2012 (34 of 2012), shall continue to so function until a new Board`
  line `is constituted for the Indian Institute of Technology (Banaras Hindu University), Varanasi under this`
  line `Act, but on the constitution of a new Board under this Act, the Executive Council of the Banaras`
  line `Hindu University shall cease to function so far as the Indian Institute of Technology (Banaras Hindu`
  line `University), Varanasi is concerned;`
  line
  line `(l) the Academic Council, referred to in clause (a) of section 2 of the Banaras Hindu University`
  line `Act, 1915 (16 of 1915), functioning as such immediately before the commencement of the Institutes`
  line `of Technology (Amendment) Act, 2012 (34 of 2012) shall continue to so function until a new Senate`
  line `is constituted for the Indian Institute of Technology (Banaras Hindu University), Varanasi under this`
  line `Act, but on the constitution of a new Senate under this Act, the Academic Council of the Banaras`
  line `Hindu University shall cease to function so far as the Indian Institute of Technology (Banaras Hindu`
  line `University), Varanasi;`
  line
  line `(m) until the first Statutes and the Ordinances in relation to the Indian Institute of Technology`
  line `(Banaras Hindu University), Varanasi are made under this Act, the Statutes and Ordinances as are`
  line `applicable to the Indian Institute of Technology, Kanpur immediately before the commencement of`
  line `the Institutes of Technology (Amendment) Act, 2012, shall apply to the Indian Institute of`
  line `Technology (Banaras Hindu University), Varanasi with the necessary modifications and adaptations`
  line `in so far as they are not inconsistent with the provisions of this Act;`
  line
  line `(n) notwithstanding anything contained in the Institutes of Technology (Amendment)`
  line `Act, 2012 (34 of 2012), any student who joined classes of the Institute of Technology, Banaras Hindu`
  line `University on or after the commencement of 2006-2007 academic session or completed the courses`
  line `on or after 2009-2010 academic session shall for the purpose of clause (b) of sub-section (1) of`
  line `section 6, be deemed to have pursued a course of study in the Indian Institute of Technology (Banaras`
  line `Hindu University), Varanasi provided that such student has not already been awarded degree or`
  line `diploma for the same course of study;`
  line
  line `(o) if any difficulty arises in giving effect to the provisions of the Institutes of Technology`
  line `(Amendment) Act, 2012 (34 of 2012), the Central Government may, by order published in the`
  line `Official Gazette, make such provisions not inconsistent with the provisions of this Act, as may appear`
  line `to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this clause after the expiry of two years from the`
  line `commencement of the Institutes of Technology (Amendment) Act, 2012:`
  line
  line `Provided further that every order made under this clause shall be laid, as soon as may be after it is`
  line `made, before each House of Parliament.]`
  line
  line `^5[(p) until the first Statutes and Ordinances in relation to the Indian Institute of Technology,`
  line `Tirupati, the Indian Institute of Technology, Palakkad, the Indian Institute of Technology, Goa, the`
  line `Indian Institute of Technology, Dharward, the Indian Institute of Technology, Bhilai, the Indian`
  line `Institute of Technology, Jammu, are made under this Act, the Statutes and Ordinances of such`
  line `Institutes, as in force immediately before the commencement of the Institutes of Technology`
  line `(Amendment) Act, 2016 (41 of 2016), shall apply to those Institutes with necessary modifications and`
  line `adaptations in so far as they are not inconsistent with the provisions of this Act;`
  line
  line `(q) the Executive Board, referred to in Rule 7 of the Rules and Regulations of the Indian School`
  line `of Mines, Dhanbad, functioning as such immediately before the commencement of the Institutes of`
  line `Technology (Amendment) Act, 2016 (41 of 2016), shall continue to so function until a new Board is`
  line `constituted for the Indian Institute of Technology (Indian School of Mines), Dhanbad, under this Act,`
  line `but on the constitution of a new Board under this Act, the Executive Board of the Indian School of`
  line `Mines, Dhanbad shall cease to function so far as the Indian Institute of Technology (Indian School of`
  line `Mines), Dhanbad is concerned;`
  line
  line `(r) the Academic Council, referred to in Rule 9 of the Rules and Regulations of the Indian School`
  line `of Mines, Dhanbad, functioning as such immediately before the commencement of the Institutes of`
  line `Technology (Amendment) Act, 2016 (41 of 2016) shall continue to so function until a new Senate is`
  line `constituted for the Indian Institute of Technology (Indian School of Mines), Dhanbad under this Act,`
  line `but on the constitution of a new Senate under this Act, the Academic Council of the Indian School of`
  line `Mines, Dhanbad shall cease to function so far as the Indian Institute of Technology (Indian School of`
  line `Mines), Dhanbad;`
  line
  line `(s) until the first Statutes and the Ordinances in relation to the Indian Institute of Technology`
  line `(Indian School of Mines), Dhanbad are made under this Act, the Statutes and Ordinances as are`
  line `applicable to the Indian Institute of Technology, Roorkee immediately before the commencement of`
  line `the Institutes of Technology (Amendment) Act, 2016 (41 of 2016), shall apply to the Indian Institute`
  line `of Technology (Indian School of Mines), Dhanbad, with the necessary modifications and adaptations`
  line `in so far as they are not inconsistent with the provisions of this Act;`
  line
  line `(t) notwithstanding anything contained in the Institutes of Technology (Amendment) Act, 2016,`
  line `any student who joined classes of the Indian School of Mines, Dhanbad on or after the`
  line `commencement of 2015-2016 academic session or completed the courses on or after 2015-2016`
  line `academic session shall for the purpose of clause (b) of sub-section (1) of section 6, be deemed to have`
  line `pursued a course of study in the Indian Institute of Technology (Indian School of Mines), Dhanbad`
  line `provided that such student has not already been awarded degree or diploma for the same course of`
  line study;
  line
  line `(u) if any difficulty arises in giving effect to the provisions of the Institutes of Technology`
  line `(Amendment) Act, 2016 (41 of 2016), the Central Government may, by order published in the`
  line `Official Gazette, make such provisions not inconsistent with the provisions of this Act, as may appear`
  line `to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this clause after the expiry of two years from the`
  line `commencement of the Institutes of Technology (Amendment) Act, 2016 (41 of 2016):`
  line
  line `Provided further that every order made under this clause shall be laid, as soon as may be after it is`
  line `made, before each House of Parliament.]`
  line
  line `^6[Explanation. 1]--The reference in clause (a) of this section to the commencement of this Act`
  line `shall be construted in relation to the Indian Institute of Technology, Guwahati as the reference to the`
  line `date on which the provisions of the institutes of Technology (Amendment) Act, 1994 (35 of 1994)`
  line `come into force.]`
  line
  line `^7[Explanation 2.--The reference in clauses (e) and (f) of this section to the commencement of this`
  line `Act shall be construed in relation to the Indian Institute of Technology, Roorkee as the reference to`
  line `the date on which the provisions of the Institutes of Technology (Amendment) Act, 2002 come into`
  line force.]
  line
  line `^8[Explanation 3.--The reference in clauses (k), (l) and (m) of this section to the commencement`
  line `of this Act shall be construed in relation to the Indian Institute of Technology (Banaras Hindu`
  line `University), Varanasi, as the reference to the date on which the provisions of the Institutes of`
  line `Technology (Amendment) Act, 2012 (34 of 2012) come into force.]`
  line
  line `^9[Explanation 4.--The reference in clauses (q), (r) and (s) of this section to the commencement of`
  line `this Act shall be construed in relation to the Indian Institute of Technology (Indian School of Mines),`
  line `Dhanbad, as the reference to the date on which the provisions of the Institutes of Technology`
  line `(Amendment) Act, 2016 come into force.]`
obj_root_law_sections_38_footnotes:
  string
  line `1. Subs. by Act 29 of 1963, s. 6, for "any Academic Council constituted in relation to any Institute" (w.e.f. 13-9-1963).`
  line
  line `2. Added by Act 35 of 1994, s. 6 (w.e.f. 1-9-1994).`
  line
  line `3. Ins. by s. 6, ibid. (w.e.f. 21-9-2001).`
  line
  line `4. Ins. by Act 34 of 2012, s. 10 (w.e.f. 29-6-2012).`
  line
  line `5. The words in brackets shall stand inserted (date to be notified) by Act 41 of 2016, s. 6.`
  line
  line `6. Explanation numbered as Explanation 1 thereof by Act 16 of 2002, s. 6 (w.e.f. 21-9-2001).`
  line
  line `7. Explanation 2 ins. by s. 6, ibid. (w.e.f. 21-9-2001).`
  line
  line `8. Explanation 3 ins. by Act 34 of 2012, s. 10 (w.e.f. 29-6-2012).`
  line
  line `9. The words in brackets shall stand inserted (date to be notified) by Act 41 of 2016, s. 6.`
obj_root_law_sections_39:
  sectionId (24066)
  sectionNo (39)
  orderNo 41
  title `Repeal and savings.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00018_196159_1517807324881&sectionId=24066&sectionno=39&orderno=41&orgactid=AC_CEN_9_30_00018_196159_1517807324881
obj_root_law_sections_39_content:
  string
  line `(1) The Indian Institute of Technology (Kharagpur) Act, 1956 (5 of 1956)`
  line `is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, the provisions of the said Act set out in the Schedule shall continue`
  line `to have effect:`
  line
  line `Provided that in the said provisions, the expression "this Act" means the said provisions.`
obj_root_law_sections_39_footnotes:
  string
  line
