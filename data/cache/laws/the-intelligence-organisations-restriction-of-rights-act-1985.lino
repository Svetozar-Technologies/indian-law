  (str slug) (str the-intelligence-organisations-restriction-of-rights-act-1985)
  (str handle) (str 1811)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Intelligence Organisations (Restriction of Rights) Act, 1985`)
  (str actNumber) (str 58)
  (str enactmentDate) (str 1985-09-06)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1811`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str actYear) (str 1985)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of Internal Security`)
  (str longTitle) (str `An Act to provide for the restriction of certain rights conferred by Part III of the Constitution in their application to the members of certain organisations established by the Central Government for purposes of intelligence or counter-intelligence so as to ensure the proper discharge of their duties and the maintenance of discipline among them.`)
  (str enforcementDate) (str 09-11-1985)
  (str notification) (str `9th December, 1985, vide notification No. S.O. 885(E), dated 9th December, 1985, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
