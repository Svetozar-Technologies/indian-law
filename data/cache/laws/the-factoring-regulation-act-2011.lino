obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `फेक्ट रविवियमिअविवियम, 2011`
  line _________
  line िाराओंकाक्रम
  line _________
  line िाराएं
  line `अध्या य 1 प्र`
  line `ा र वि क`
  line `1. संविप्त िाम,विस्ता रऔरप्रारंि।`
  line `2. पररिाषाएं।`
  line `अध्या य 2`
  line `फेक्ट रोंकारविस्री करण`
  line `3. फेक्ट रोंकारविस्री करण।`
  line `4. गैर - बैंककारीवित्तीयकंपवियोंके उपबंिोंकाफेक्ट रकोलागूहोिा।`
  line `5. ककसीफेक्ट रकेरूपमेंरविस्री करणकीअपेिाकाबैंकयाकािूिीविगमयासरकारीकंपिीको लागूिहोिा।`
  line `6. ररििवबैंककीफेक्ट रोंकोविदेशदेिेऔरसूचिासंगृहीतकरिेकीशवक्त यां।`
  line `अध्या य 3 प्र`
  line `ाप्त व् यों कासमिुदे शि`
  line `7. प्र ाप्त व् यों कासमिुदेशि।`
  line `8. देिदारकोसूचिाऔरऐसेदेिदारकीबाध्य ताकाउन्मो चि।`
  line `9. समिुदेवशतीकोसंदायकरकदएिािेपरदेिदारकेदावयत्ि काउन्मो चि।`
  line `10. देिदारद्वारासमिुदेशककोककएगएसंदायकवतपयमामलोंमेंसमिुदेवशतीकेफायदेकेवलएन्या सकेरूपमेंिाररत`
  line ककयािािा।
  line `अध्या य 4 प्र`
  line `ाप्त व् यों केसमिुदेशिकेवलएसंविदाकेपिकारोंकेअविकारऔरबाध्य ताएं`
  line `11. प्र ाप्त व् यों केसमिुदेशिकेवलएसंविदाकेपिकारोंकेअविकारऔरबाध्य ताएं।`
  line `12. देिदारकादावयत्ि।`
  line `13. समिुदेशककासमिुदेवशती कान्या सीहोिा।`
  line `14. ऐसेसमिुदेशककीदशामें,िोसूक्ष्म यालघुउद्यमहै,देिदारकादावयत्ि।`
  line `15. देिदारसंरिणकावसद्ांत।`
  line `16. बचािऔरदेिदारकामुिरासंबंिीअविकार।`
  line `17. मूलसंविदाकाउपांतरण।`
  line `18. संविदाकािंग।`
  line `अध्या य 5`
  line `समिुदेशिोंकारविस्री करण`
  line `19. प्र ाप्त व् य संव्य िहारोंकेकवतपयसमिुदेशिोंकारविस्री करण।`
  line `20. लोकविरीिण।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
