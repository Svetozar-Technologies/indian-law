obj_root_law_sections_1:
  sectionId (39434)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39434&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Manipur (Hill Areas) District Councils`
  line `Act, 1971.`
  line
  line `(2) It extends to the whole of the Union territory of Manipur.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39435)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39435&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "Administrator" means the administrator of the Union territory of Manipur appointed under`
  line `article 239 of the Constitution;`
  line
  line `(b) "autonomous district" means an autonomous district referred to in sub-section (1) of section 3;`
  line
  line `(c) "building" includes a house, out-house, stable, latrine, urinal, shed, hut, wall (other than`
  line `boundary wall) and any other structure (whether of masonry, bricks, wood, mud or other material) but`
  line `does not include any portable or temporary shelter;`
  line
  line `(d) "constituency" means a District Council constituency provided by order made under section 5`
  line `for the purpose of elections to the District Council;`
  line
  line `(e) "Deputy Commissioner", in relation to any District Council, means the officer appointed as`
  line `such by the Administrator, by notification in the Official Gazette, to perform the functions of the`
  line `Deputy Commissioner under this Act in the autonomous district for which such District Council has`
  line `been constituted;`
  line
  line `(f) "Hill Areas" means the Hill Areas determined by the President by any notification issued`
  line `under sub-section (2) of section 52 of the Government of Union Territories Act, 1963 (20 of 1963)`
  line `and in force immediately before the commencement of this Act;`
  line
  line `(g) "Hill Areas Committee" means the Standing Committee referred to in section 52 of the`
  line `Government of Union Territories Act, 1963 (20 of 1963);`
  line
  line `(h) "market" includes any place where persons assemble for the sale of, or for the purpose of`
  line `exposing for sale of, meat, fish, fruit, vegetables, animals intended for human food or any other`
  line `articles of human food whatsoever with or without the consent of the owner of such place`
  line `notwithstanding that there may be no common regulation for the concourse of buyers and sellers and`
  line `whether or not any control is exercised over the business of, or the persons frequenting, the market by`
  line `the owner of the place or by any other persons;`
  line
  line `(i) "member" means a member of a District Council constituted under this Act;`
  line
  line `(j) "Official Gazette" means the Gazette of the Union territory of Manipur;`
  line
  line `(k) "person" does not include a body of persons;`
  line
  line `(l) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(m) "Scheduled Tribes" has the same meaning assigned to it in clause (25) of article 366 of the`
  line Constitution;
  line
  line `(n) "vehicle" includes a carriage, cart, hand-cart, bicycle, tricycle and every wheeled conveyance`
  line `which is used or is capable of being used on a street but does not include a mechanically propelled`
  line vehicle.
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39436)
  sectionNo (3)
  orderNo 3
  title `Division of Hill Areas into autonomous districts.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39436&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_3_content:
  string
  line `(1) As soon as may be after the`
  line `commencement of this Act, the Administrator shall cause all the Hill Areas to be divided into not more`
  line `than six autonomous districts.`
  line
  line `(2) The Administrator may, by order notified in the Official Gazette,—`
  line
  line `(a) declare that any area in any autonomous district which is, or is intended to be, included within`
  line `the limits of any municipality, cantonment or town committee shall cease to be a part of such`
  line `autonomous district;`
  line
  line `(b) increase the area of any autonomous district;`
  line
  line `(c) diminish the area of any autonomous district;`
  line
  line `(d) unite two or more autonomous districts or parts thereof so as to form one autonomous district;`
  line
  line `(e) define the boundaries of any autonomous district;`
  line
  line `(f) alter the name of any autonomous district.`
  line
  line `(3) No order under sub-section (2) shall be made by the Administrator except after consultation with`
  line `the Hill Areas Committee.`
  line
  line `(4) Any order made by the Administrator under sub-section (2) may contain such incidental and`
  line `consequential provisions as appear to the Administrator to be necessary for giving effect to the provisions`
  line `of the order.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39437)
  sectionNo (4)
  orderNo 4
  title `Constitution of District Councils and their composition.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39437&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_4_content:
  string
  line `(1) For each autonomous district there`
  line `shall be a District Council as from such date as the Administrator may, by notification in the Official`
  line `Gazette, appoint in this behalf.`
  line
  line `(2) The total number of seats in the District Council to be filled by persons chosen by direct election`
  line `on the basis of adult suffrage from territorial constituencies shall be not more than eighteen.`
  line
  line `(3) The Administrator may nominate not more than two persons, not being persons in the service of`
  line `Government, to be members of any District Council.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39438)
  sectionNo (5)
  orderNo 5
  title `Delimitation of constituencies.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39438&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_5_content:
  string
  line `The Administrator shall, by order, determine—`
  line
  line `(a) the constituencies (which shall be single member constituencies) into which an autonomous`
  line `district shall be divided for the purpose of election of members to the District Council of that district;`
  line and
  line
  line `(b) the extent of each constituency.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39439)
  sectionNo (6)
  orderNo 6
  title `Power to alter or amend delimitation orders.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39439&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_6_content:
  string
  line `The Administrator may, from time to time, by`
  line `order, alter or amend any order made under section 5.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (39440)
  sectionNo (7)
  orderNo 7
  title `Qualifications for membership.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39440&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_7_content:
  string
  line `A person shall not be qualified to be chosen as a member of a`
  line `District Council of any autonomous district unless he is an elector for any District Council constituency in`
  line `that autonomous district.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (39441)
  sectionNo (8)
  orderNo 8
  title `Disqualifications for membership.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39441&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_8_content:
  string
  line `(1) A person shall be disqualified for being chosen as a`
  line `member of a District Council if he is for the time being disqualified for being chosen as a member of`
  line `either House of Parliament or holds any office of profit under any District Council.`
  line
  line `(2) For the purposes of this section, a person shall not be deemed to hold an office of profit under a`
  line `District Council by reason only that he is a member thereof.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (39442)
  sectionNo (9)
  orderNo 9
  title `Electors on electoral rolls.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39442&sectionno=9&orderno=9&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_9_content:
  string
  line `(1) The persons entitled to vote at elections of members of a District`
  line `Council shall be the persons entitled, by virtue of the provisions of the Constitution and the`
  line `Representation of the People Act, 1950 (43 of 1950), to be registered as voters at elections to the House`
  line `of the People.`
  line
  line `(2) So much of the electoral roll for any parliamentary constituency for the time being in force as`
  line `relates to the areas comprised within a constituency formed under section 5 shall be deemed to be the`
  line `electoral roll for that constituency for the purposes of this Act.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (39443)
  sectionNo (10)
  orderNo 10
  title `Right to vote.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39443&sectionno=10&orderno=10&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_10_content:
  string
  line `(1) Every person whose name is, for the time being, entered in the electoral roll`
  line `of a constituency shall be entitled to vote at the election of a member of the District Council from that`
  line constituency.
  line
  line `(2) Every person shall give one vote and no more to any one candidate at an election.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (39444)
  sectionNo (11)
  orderNo 11
  title `Election of members.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39444&sectionno=11&orderno=11&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_11_content:
  string
  line `Election of members of a District Council shall be held in accordance`
  line `with the rules made under section 21 on such date or dates as the Administrator may, by notification in`
  line `the Official Gazette, direct:`
  line
  line `Provided that a casual vacancy shall be filled as soon as may be after the occurrence of the vacancy:`
  line
  line `Provided further that no election shall be held to fill up a casual vacancy occurring within four`
  line `months prior to the holding of a general election under this section.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (39445)
  sectionNo (12)
  orderNo 12
  title `Notification of results of elections.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39445&sectionno=12&orderno=12&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_12_content:
  string
  line `The names of all persons elected or nominated to be`
  line `members of a District Council shall be published by the Administrator in the Official Gazette.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (39446)
  sectionNo (13)
  orderNo 13
  title `Term of office of members.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39446&sectionno=13&orderno=13&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_13_content:
  string
  line `(1) Save as otherwise provided in this section, the term of office of`
  line `a member shall be five years and shall commence from the date of the notification of his election or`
  line `nomination under section 12 or from the date on which the vacancy in which he is elected or nominated`
  line `has occurred, whichever date is later:`
  line
  line `Provided that the Adminstrator may, when satisfied that it is necessary in order to avoid`
  line `administrative difficulty, extend the term of office of all the members by such period not exceeding one`
  line `year as he thinks fit.`
  line
  line `(2) The term of office of a member elected to fill a casual vacancy shall commence from the date of`
  line `the notification of his election and shall continue so long only as the member in whose place he is elected`
  line `would have been entitled to hold office if the vacancy had not occurred.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (39447)
  sectionNo (14)
  orderNo 14
  title `Disputes as to elections.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39447&sectionno=14&orderno=14&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_14_content:
  string
  line `(1) No election of a member shall be called in question except by an`
  line `election petition presented to the court of the District Judge having jurisdiction in the area in which the`
  line `constituency concerned is situated, within thirty days from the date of the notification of the result of the`
  line `election under section 12.`
  line
  line `(2) An election petition calling in question any such election may be presented on one or more of the`
  line `grounds specified in section 16 by any candidate at such election or by any elector of the constituency.`
  line
  line `(3) A petitioner shall join as respondents to his petition all the candidates at the election.`
  line
  line `(4) An election petition—`
  line
  line `(a) shall contain a concise statement of the material facts on which the petitioner relies;`
  line
  line `(b) shall, with sufficient particulars, set forth the ground or grounds on which the election is`
  line `called in question; and`
  line
  line `(c) shall be signed by the petitioner and verified in the manner laid down in the Code of Civil`
  line `Procedure, 1908 (5 of 1908), for the verification of pleadings.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (39448)
  sectionNo (15)
  orderNo 15
  title `Relief that may be claimed by petitioner.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39448&sectionno=15&orderno=15&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_15_content:
  string
  line `A petitioner may, in addition to claiming a`
  line `declaration that the election of all or any of the returned candidates is void, claim a further declaration`
  line `that he himself or any other candidate has been duly elected.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (39449)
  sectionNo (16)
  orderNo 16
  title `Grounds on which an election may be called in question.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39449&sectionno=16&orderno=16&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_16_content:
  string
  line `The election of a returned candidate`
  line `may be called in question on any one or more of the following grounds, namely:—`
  line
  line `(a) that on the date of his election the returned candidate was not qualified to be elected, or he`
  line `was disqualified for being elected, as a member under this Act; or`
  line
  line `(b) that the nomination paper of any candidate at the election has been improperly rejected; or`
  line
  line `(c) that the result of the election has been materially affected by the improper acceptance of a`
  line `nomination paper or by the improper acceptance or refusal of a vote or by any other cause.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (39450)
  sectionNo (17)
  orderNo 17
  title `Procedure to be followed by the District Judge.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39450&sectionno=17&orderno=17&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_17_content:
  string
  line `The procedure provided in the Code of Civil`
  line `Procedure, 1908 (5 of 1908) in regard to suits shall be followed by the court of the District Judge, as far`
  line `as it can be made applicable, in the trial and disposal of an election petition under this Act.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (39451)
  sectionNo (18)
  orderNo 18
  title `Decision of the District Judge.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39451&sectionno=18&orderno=18&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_18_content:
  string
  line `(1) At the conclusion of the trial of an election petition, the`
  line `court of the District Judge shall make an order—`
  line
  line `(a) dismissing the election petition; or`
  line
  line `(b) declaring the election of all or any of the returned candidates to be void; or`
  line
  line `(c) declaring the election of all or any of the returned candidates to be void and the petitioner or`
  line `any other candidate to have been duly elected.`
  line
  line `(2) If any person who has filed an election petition has, in addition to calling in question the election`
  line `of the returned candidate, claimed a declaration that he himself or any other candidate has been duly`
  line `elected and the court of the District Judge is of opinion—`
  line
  line `(a) that in fact the petitioner or such other candidate received a majority of the valid votes; or`
  line
  line `(b) that but for the votes obtained by the returned candidate, the petitioner or such other candidate`
  line `would have obtained a majority of the valid votes,`
  line
  line `the court of the District Judge shall, after declaring the election of the returned candidate to be void,`
  line `declare the petitioner or such other candidate, as the case may be, to have been duly elected.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (39452)
  sectionNo (19)
  orderNo 19
  title `Procedure in case of equality of votes.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39452&sectionno=19&orderno=19&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_19_content:
  string
  line `(1) If during the trial of an election petition it appears`
  line `that there is equality of votes between any candidates at the election and that the addition of a vote would`
  line `entitle any of those candidates to be declared elected, then, the court of the District Judge shall decide`
  line `between them by lot and proceed as if the one on whom the lot falls had received an additional vote.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (39453)
  sectionNo (20)
  orderNo 20
  title `Finality of decisions.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39453&sectionno=20&orderno=20&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_20_content:
  string
  line `(1) An order of the court of the District Judge on an election petition shall`
  line `be final and conclusive.`
  line
  line `(2) An election of a member not called in question in accordance with the foregoing provisions shall`
  line `be deemed to be a good and valid election.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (39454)
  sectionNo (21)
  orderNo 21
  title `Power to make rules regulating the election of members.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39454&sectionno=21&orderno=21&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_21_content:
  string
  line `The Administrator may make rules`
  line `to regulate all or any of the following matters for the purpose of the holding of elections of members`
  line `under this Act, namely:—`
  line
  line `(a) the manner of the splitting up of electoral rolls for parliamentary constituencies into parts for`
  line `the purpose of constituting one or more of such parts into electoral roll for a constituency; and the`
  line `officer or authority by whom such splitting up is to be carried out;`
  line
  line `(b) the drawing up of the programme of election;`
  line
  line `(c) the appointment of returning officers, presiding and polling officers for election;`
  line
  line `(d) the nomination of candidates and the scrutiny of such nomination;`
  line
  line `(e) the deposits to be made by candidates and the time and manner of making such deposits;`
  line
  line `(f) the withdrawal of candidatures;`
  line
  line `(g) the appointment of agents of candidates;`
  line
  line `(h) the time and manner of holding elections;`
  line
  line `(i) the general procedure at the elections including the time, place and hours of poll and the`
  line `method by which votes shall be cast;`
  line
  line `(j) the fee to be paid on an election petition;`
  line
  line `(k) any other matter relating to elections or election disputes in respect of which the`
  line `Administrator deems it necessary to make rules under this section or in respect of which this Act`
  line `makes no provision or makes insufficient provision and provision is, in the opinion of the`
  line `Administrator, necessary.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (39455)
  sectionNo (22)
  orderNo 22
  title `Incorporation of District Councils.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39455&sectionno=22&orderno=22&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_22_content:
  string
  line `Each District Council shall be a body corporate by the`
  line `name respectively of "the District Council of (name of autonomous district)" and shall have perpetual`
  line `succession and a common seal with power to acquire, hold and dispose of property and to contract and`
  line `may by the said name sue and be sued.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (39456)
  sectionNo (23)
  orderNo 23
  title `Chairman and Vice-Chairman.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39456&sectionno=23&orderno=23&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_23_content:
  string
  line `(1) A District Council shall, as soon as may be, choose two`
  line `members to be respectively Chairman and Vice-Chairman thereof and so often as the office of Chairman`
  line `or Vice-Chairman becomes vacant, the Council shall choose another member to be Chairman or`
  line `Vice-Chairman, as the case may be:`
  line
  line `Provided that the Administrator may nominate the first Chairman who shall hold office for a period`
  line `not exceeding one year.`
  line
  line `(2) If a resolution for the removal of an elected Chairman is passed by not less than two-thirds of the`
  line `total membership of the Council at a meeting convened in accordance with the provisions of`
  line `sub-section (3), such resolution shall have the effect of removing the Chairman from his office as from`
  line `the date on which the resolution is so passed and if such resolution is passed by less than two-thirds but`
  line `not less than one-half of the total membership of the Council, the Administrator may, by order in writing,`
  line `remove, for reasons to be recorded, the Chairman from his office as from such date as may be specified in`
  line `the order:`
  line
  line `Provided that no such resolution shall be brought within one year from the date of election of the`
  line `Chairman:`
  line
  line `Provided further that if the resolution is not passed by not less than two-thirds of the total`
  line `membership of the Council, no other resolution for the removal of the Chairman shall be allowed to be`
  line `considered within one year from the date on which such resolution was considered.`
  line
  line `(3) A notice in writing of the intention to move a resolution referred to in sub-section (2) signed by`
  line `not less than one-third of the total membership of the Council together with a copy of the proposed`
  line `resolution shall be delivered to the Deputy Commissioner in accordance with the rules made by the`
  line `Deputy Commissioner in this behalf and the Deputy Commissioner shall, after giving not less than fifteen`
  line `days' notice thereon, convene for consideration of the resolution a meeting of the Council to be held in the`
  line `office of the Council on a date not later than thirty days from the date on which the notice was delivered`
  line `to him and he shall preside over the meeting.`
  line
  line `(4) The Chairman of the Council shall be a whole-time functionary and shall be entitled to such salary`
  line `or allowances as may be fixed by the Administrator.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (39457)
  sectionNo (24)
  orderNo 24
  title `Oath or affirmation by members.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39457&sectionno=24&orderno=24&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_24_content:
  string
  line `Every member shall, before taking his seat, make and`
  line `subscribe at a meeting of the District Council, an oath or affirmation in the prescribed form.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (39458)
  sectionNo (25)
  orderNo 25
  title `Vacation of seats.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39458&sectionno=25&orderno=25&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_25_content:
  string
  line `(1) No person shall be a member both of the Legislative Assembly of the`
  line `Union territory of Manipur and of a District Council and if a person is chosen a member both of the`
  line `Legislative Assembly and of a District Council, then, at the expiration of fourteen days from the date of`
  line `publication in the Official Gazette that he has been so chosen, that person's seat in the District Council`
  line `shall become vacant unless he has previously resigned his seat in the Legislative Assembly.`
  line
  line `(2) If a member—`
  line
  line `(a) becomes subject to any of the disqualifications mentioned in section 8; or`
  line
  line `(b) resigns his seat by writing under his hand addressed to the Chairman of the District Council,`
  line
  line `his seat shall thereupon become vacant.`
  line
  line `(3) If during the six successive months a member is, without the permission of the District Council,`
  line `absent from all meetings thereof, the Council may declare his seat vacant.`
  line
  line `(4) If any question arises as to whether a member has become subject to any of the disqualifications`
  line `mentioned in section 8, it shall be referred to the District Judge having jurisdiction in the area in which`
  line `the constituency concerned is situated and his decision shall be final.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (39459)
  sectionNo (26)
  orderNo 26
  title `Allowances of members.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39459&sectionno=26&orderno=26&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_26_content:
  string
  line `Subject to the provisions of sub-section (4) of section 23, every`
  line `member shall be entitled to receive such allowances as may be determined by the Administrator.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (39460)
  sectionNo (27)
  orderNo 27
  title `Liability of members.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39460&sectionno=27&orderno=27&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_27_content:
  string
  line `Every person shall be liable for the loss, waste or misappropriation of`
  line `any money or other property belonging to a District Council, if such loss, waste or misappropriation is a`
  line `direct consequence of his neglect or misconduct while a member of the District Council and a suit for`
  line `compensation may be instituted against him by the Council with the previous sanction of the Deputy`
  line `Commissioner or by the Deputy Commissioner with the previous sanction of the Administrator.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (39461)
  sectionNo (28)
  orderNo 28
  title `Members to be deemed to be public servants.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39461&sectionno=28&orderno=28&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_28_content:
  string
  line `Every member shall be deemed to be a public`
  line `servant within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (39462)
  sectionNo (29)
  orderNo 29
  title `Functions of District Councils.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39462&sectionno=29&orderno=29&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_29_content:
  string
  line `(1) Subject to such exceptions and conditions as the`
  line `Administrator may make and impose, the following matters shall be under the control and administration`
  line `of a District Council, namely:—`
  line
  line `(i) the maintenance and management of such property, movable and immovable, and institutions`
  line `as may be transferred to that Council by the Administrator;`
  line
  line `(ii) the construction, repair and maintenance of such of the roads, bridges, channels and buildings`
  line `as may be transferred to that Council by the Administrator;`
  line
  line `(iii) the establishment, maintenance and management of primary schools and the construction and`
  line `repair of all buildings connected with these institutions and institution of scholarships;`
  line
  line `(iv) the establishment, maintenance and management of dispensaries;`
  line
  line `(v) the establishment and maintenance of cattle pounds including such functions under the`
  line `Cattle-trespass Act, 1871 (1 of 1871) as may be transferred to that Council by the Administrator;`
  line
  line `(vi) the establishment, maintenance and management of markets and fairs and the construction,`
  line `repair and maintenance of all buildings connected therewith;`
  line
  line `(vii) the supply, storage and prevention from pollution of water for drinking, cooking and bathing`
  line purposes;
  line
  line `(viii) the construction, repair and maintenance of embankments and the supply, storage and`
  line `control of water for agricultural purposes;`
  line
  line `(ix) the preservation and reclamation of soil;`
  line
  line `(x) the preservation, protection and improvement of live-stock and prevention of animal diseases;`
  line
  line `(xi) public health and sanitation;`
  line
  line `(xii) the management of such ferries as may be entrusted to the charge of that Council by the`
  line Administrator;
  line
  line `(xiii) the initiation, inspection and control of relief works;`
  line
  line `(xiv) the allotment, occupation or use, or the setting apart of land, other than land acquired for any`
  line `public purpose or land which is a reserved forest, for the purpose of agriculture or grazing or for`
  line `residential or other non-agricultural purposes or for any other purposes likely to promote the interests`
  line `of the inhabitants of any village or town situated within the autonomous district for which that council`
  line `is constituted;`
  line
  line `(xv) the management of any forest not being a reserved forest;`
  line
  line `(xvi) the regulation of the practice of Jhum or other form of shifting cultivation; and`
  line
  line `(xvii) any other matter which the Administrator may, in consultation with the Hill Areas`
  line `Committee, entrust to the District Council in the field of agriculture, animal husbandry, community`
  line `development, social and tribal welfare, village planning or any other matter referred to in section 52`
  line `of the Government of Union Territories Act, 1963 (20 of 1963).`
  line
  line `(2) It shall be competent for a District Council to recommend to the Government of the Union`
  line `territory of Manipur legislation relating to the following matters in so far as they concern members of the`
  line `Scheduled Tribes, namely:—`
  line
  line `(a) appointment or succession of Chiefs;`
  line
  line `(b) inheritance of property;`
  line
  line `(c) marriage and divorce; and`
  line
  line `(d) social customs.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (39463)
  sectionNo (30)
  orderNo 30
  title `Conduct of business.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39463&sectionno=30&orderno=30&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_30_content:
  string
  line `A District Council shall conduct its business in such manner and in`
  line `accordance with such procedure as may be prescribed.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (39464)
  sectionNo (31)
  orderNo 31
  title Committees.
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39464&sectionno=31&orderno=31&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_31_content:
  string
  line `A District Council may, from time to time, appoint out of its own body such and`
  line `so many committees for the efficient discharge of its duties as may be necessary.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (39465)
  sectionNo (32)
  orderNo 32
  title `Officers and staff.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39465&sectionno=32&orderno=32&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_32_content:
  string
  line `(1) For every District Council there shall be a Chief Executive Officer, who`
  line `shall be appointed by the Administrator.`
  line
  line `(2) If a resolution for removal of the Chief Executive Officer is passed at a meeting of the District`
  line `Council by a majority of not less than two-thirds of the total membership of the Council, the`
  line `Administrator shall remove him forthwith.`
  line
  line `(3) The District Council shall appoint such officers and staff as may be necessary for the proper and`
  line `efficient execution of its duties and make regulations for their conditions of service.`
  line
  line `(4) The power of appointing officers and staff (whether temporary or permanent) shall be exercised in`
  line `accordance with the rules framed for the purpose by the Administrator.`
  line
  line `(5) The conditions of service applicable to a person immediately before his appointment to a post`
  line `under a District Council shall not be varied to his disadvantage except with the previous approval of the`
  line Administrator.
  line
  line `(6) Every officer or member of staff of a District Council shall be deemed to be a public servant`
  line `within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (39466)
  sectionNo (33)
  orderNo 33
  title `Powers of taxation.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39466&sectionno=33&orderno=33&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_33_content:
  string
  line `Notwithstanding anything to the contrary contained in any other law for the`
  line `time being in force, a District Council shall have the power to levy all or any of the following taxes within`
  line `the autonomous district for which the Council is constituted, that is to say—`
  line
  line `(a) taxes on professions, trades, callings and employments;`
  line
  line `(b) taxes on animals, vehicles (other than mechanically propelled vehicles) and boats;`
  line
  line `(c) taxes on entry of goods into a market for sale there in and tolls on passengers and goods`
  line `carried in ferries;`
  line
  line `(d) taxes for the maintenance of schools, dispensaries or roads; and`
  line
  line `(e) any other tax falling under List II of the Seventh Schedule to the Constitution which the`
  line `Legislature of the Union territory of Manipur may, by law, empower the District Council to levy.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (39467)
  sectionNo (34)
  orderNo 34
  title `Levy of fees.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39467&sectionno=34&orderno=34&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_34_content:
  string
  line `A District Council may fix and levy—`
  line
  line `(a) school fees; and`
  line
  line `(b) fees for the use of, or benefits derived from, any of the works done or services rendered under`
  line `section 29.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (39468)
  sectionNo (35)
  orderNo 35
  title `Procedure for imposing taxes.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39468&sectionno=35&orderno=35&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_35_content:
  string
  line `(1) A District Council may resolve at a meeting specially`
  line `convened for the purpose to propose the imposition of any of the taxes mentioned in section 33.`
  line
  line `(2) When a resolution has been passed, the Council shall publish a notice in the Official Gazette and`
  line `also in the prescribed manner, defining the class of persons or description of property proposed to be`
  line `taxed, the amount or rate of tax to be imposed and the system of assessment to be adopted.`
  line
  line `(3) Any person, directly or indirectly affected by the proposed tax and objecting to it, may, within`
  line `thirty days from the publication of the notice, send his objections in writing to the Council and the`
  line `Council shall, at a specially convened meeting, take all such objections into consideration.`
  line
  line `(4) If no objection is sent within the said period of thirty days or if the objections received are deemed`
  line `insufficient, the Council may submit its proposals to the Administrator with the objections, if any, and its`
  line `decision thereon.`
  line
  line `(5) The Administrator may then sanction the proposals or refuse to sanction them or return them to`
  line `the Council for further consideration.`
  line
  line `(6) When the proposal in respect of a tax has been sanctioned, the Administrator shall notify its`
  line `imposition in the Official Gazette and specify a date not later than three months from the date of`
  line `notification on which the tax shall come into force.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (39469)
  sectionNo (36)
  orderNo 36
  title `Abolition or reduction of taxes.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39469&sectionno=36&orderno=36&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_36_content:
  string
  line `The Administrator may, by notification in the Official Gazette,`
  line `and a District Council may with the previous approval of the Administrator by a resolution passed at a`
  line `meeting specially convened for the purpose, abolish or reduce any tax imposed under section 33.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (39470)
  sectionNo (37)
  orderNo 37
  title `Recovery of taxes and fees.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39470&sectionno=37&orderno=37&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_37_content:
  string
  line `All arrears of taxes and fees levied under this Act may be`
  line `recovered under the law for the time being in force for the recovery of public dues as if such arrears were`
  line `public dues.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (39471)
  sectionNo (38)
  orderNo 38
  title `Assessment and collection of taxes and fees.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39471&sectionno=38&orderno=38&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_38_content:
  string
  line `A District council may, by notification in the`
  line `Official Gazette, determine the person by whom any tax or fee shall be assessed and collected and make`
  line `rules for the assessment and collection of such tax or fee and direct in what manner persons employed in`
  line `the assessment or collection shall be remunerated.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (39472)
  sectionNo (39)
  orderNo 39
  title Appeals.
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39472&sectionno=39&orderno=39&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_39_content:
  string
  line `(1) In matters connected with the assessment and collection of any tax or fee levied`
  line `under this Act, an appeal shall lie from the order of any person authorised to make assessment or`
  line `collections to such person as the Administrator may appoint or designate for the purpose.`
  line
  line `(2) An appeal under sub-section (1) shall be presented within thirty days from the date of the order.`
  line
  line `(3) The order passed on the appeal shall be final.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (39473)
  sectionNo (40)
  orderNo 40
  title `Instalments of taxes and fees.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39473&sectionno=40&orderno=40&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_40_content:
  string
  line `A District Council may, by notification in the Official Gazette`
  line `and with the previous approval of the Deputy Commissioner, prescribe by what instalments and at what`
  line `times any tax or fee shall be payable.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (39474)
  sectionNo (41)
  orderNo 41
  title `Power to exempt from taxation.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39474&sectionno=41&orderno=41&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_41_content:
  string
  line `A District Council may, with the previous approval of the`
  line `Administrator, by notification in the Official Gazette, remit or reduce any tax or fee or exempt any`
  line `persons or class of persons or any description of property, wholly or in part, from liability to any tax or`
  line `fee and cancel any such remission, reduction or exemption.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (39475)
  sectionNo (42)
  orderNo 42
  title `Recoveries of moneys claimable by the Council.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39475&sectionno=42&orderno=42&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_42_content:
  string
  line `(1) Save as provided by section 37, all`
  line `moneys claimable by a District Council may be recovered on an application to a Magistrate having`
  line `jurisdiction in the area where the person from whom the money is claimable may, for the time being, be`
  line `resident, by the distress and sale of any movable property or by the attachment and sale of any immovable`
  line `property, within the limits of his jurisdiction belonging to such person and the cost of such proceedings`
  line `shall be recoverable in the same manner as the said moneys.`
  line
  line `(2) An application for recovery of money shall be in writing and shall be signed by an officer`
  line `authorised in this behalf by order of the Chairman of the Council.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (39476)
  sectionNo (43)
  orderNo 43
  title `Council Fund.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39476&sectionno=43&orderno=43&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_43_content:
  string
  line `(1) All moneys received by or on behalf of a District Council under the`
  line `provisions of this Act or any other law for the time being in force shall be credited to a fund which shall`
  line `be called the "Council Fund" and it shall be held by the District Council in trust for the purposes of this`
  line Act.
  line
  line `(2) All expenditure of the Council shall be defrayed out of the Council Fund.`
  line
  line `(3) The Administrator may make rules for the management of the Council Fund and for the procedure`
  line `to be followed in respect of payment of money into the said Fund, the withdrawal of moneys therefrom,`
  line `the custody of moneys therein and any other matter connected with or ancillary to the matters aforesaid.`
  line
  line `(4) The accounts of a District Council shall be kept in such form as may be prescribed.`
  line
  line `(5) The accounts of a District Council shall be audited in such manner as may be prescribed.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (39477)
  sectionNo (44)
  orderNo 44
  title `Property vested in District Council.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39477&sectionno=44&orderno=44&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_44_content:
  string
  line `Subject to any order of the Administrator, all property of`
  line `the nature specified below and situated in the autonomous district shall vest in and belong to the District`
  line `Council for which it is constituted and shall, with all other property which may become vested in the`
  line `Council, be under its direction, management and control and shall be held and applied for the purposes of`
  line `this Act—`
  line
  line `(a) all public buildings, constructed or maintained out of the Council Fund;`
  line
  line `(b) all public roads which have been constructed or are maintained out of the Council Fund and`
  line `the stones and other materials thereof and also all trees, erections, materials, implements and things`
  line `provided for such roads;`
  line
  line `(c) all land or other property transferred to the District Council by the Administrator or by gift,`
  line `sale or otherwise for public purposes.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (39478)
  sectionNo (45)
  orderNo 45
  title Budget.
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39478&sectionno=45&orderno=45&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_45_content:
  string
  line `(1) A District Council shall, on or before a prescribed day in each year submit to the`
  line `Administrator an estimate of the income and expenditure of the Council for the next financial year in such`
  line `form as may be prescribed.`
  line
  line `(2) The Administrator may, on or before a prescribed day, return the estimate of the Council with or`
  line `without modifications.`
  line
  line `(3) When a budget is returned with modifications under sub-section (2), the Council shall consider the`
  line `proposed modifications, take a decision thereon and report the same to the Administrator.`
  line
  line `(4) The budget estimate finally adopted by the Council shall be the budget of the District Council.`
  line
  line `(5) Any subsequent alteration in the budget or reappropriation or transfer of provision within the`
  line `estimate shall be made with the approval of the Administrator.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (39479)
  sectionNo (46)
  orderNo 46
  title Control.
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39479&sectionno=46&orderno=46&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_46_content:
  string
  line `(1) It shall be the duty of the Chairman of a District Council to furnish to the Deputy`
  line `Commissioner a copy of the proceedings of the meetings of the Council and such other information as the`
  line `Deputy Commissioner may require.`
  line
  line `(2) The Deputy Commissioner shall have the power to give to any District Council all such directions`
  line `as he may consider necessary in respect of subjects, curricula, text books and standards of teaching in`
  line `schools vested wholly or partly in the Council and in schools wholly or partly maintained by grants`
  line `payable from the Council Fund and the Council shall comply with such directions.`
  line
  line `(3) The Deputy Commissioner may, by order, and for reasons to be recorded, suspend the execution`
  line `of any resolution or order of any District Council or prohibit the doing of any act which is about to be`
  line `done, or is being done, in pursuance of or under cover of any provision of the law relating to the`
  line `constitution or functions of the District Council, if, in his opinion, the resolution, order or act is in excess`
  line `of the powers conferred by law or the execution of the resolution or order or the doing of the act is likely`
  line `to lead to a breach of the peace, or to cause annoyance or injury to the public or to any class or body of`
  line `persons:`
  line
  line `Provided that the Council may, within fifteen days of the date of the order of the Deputy`
  line `Commissioner offer such explanation as it deems fit in relation to the execution of the resolution or order`
  line `which has been suspended or the doing of the act has been prohibited.`
  line
  line `(4) When the Deputy Commissioner makes any order as aforesaid, he shall forthwith send a copy of it`
  line `to the Administrator with a statement of the reasons for making it and forward in due course to the`
  line `Administrator the explanation, if any, offered by the Council and the Administrator may, thereupon,`
  line `confirm, modify or rescind the order of the Deputy Commissioner.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (39480)
  sectionNo (47)
  orderNo 47
  title `Supersession of District Council.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39480&sectionno=47&orderno=47&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_47_content:
  string
  line `(1) If, on receipt of a report from the Deputy Commissioner`
  line `or otherwise, the Administrator is of opinion that—`
  line
  line `(a) any District Council is not competent to perform, or persistently makes default in the`
  line `performance of, the duties imposed on it by or under this Act or any other law; or`
  line
  line `(b) any District Council exceeds or abuses its powers; or`
  line
  line `(c) the financial position and credit position of any District Council is seriously threatened; or`
  line
  line `(d) a situation has arisen in which the administration of any District Council cannot be carried on`
  line `in accordance with the provisions of this Act,`
  line
  line `the Administrator may, by an order published, together with a statement of reasons therefor, in the`
  line `Official Gazette, supersede such Council for such period, not exceeding one year, as may be specified in`
  line `the order:`
  line
  line `Provided that before making an order of supersession as aforesaid under clause (a) or clause (b) or`
  line `clause (c), reasonable opportunity shall be given to such Council to show cause why such order of`
  line `supersession should not be made:`
  line
  line `Provided further that the period of supersession may be extended for any further period or periods not`
  line `exceeding six months at a time in consultation with the Hill Areas Committee.`
  line
  line `(2) When any District Council is superseded by an order under sub-section (1),—`
  line
  line `(a) all the members of the Council (including the Chairman and Vice-Chairman thereof) shall, on`
  line `such date as may be specified in the order, vacate their offices as such members without prejudice to`
  line `their eligibility for election or nomination under clause (d);`
  line
  line `(b) during the period of supersession of the Council, all powers and duties conferred and imposed`
  line `upon the Council by or under this Act or any other law shall be exercised and performed by such`
  line `officer or authority as the Administrator may appoint in this behalf;`
  line
  line `(c) all property vested in the Council shall, until it is reconstituted, vest in the Central`
  line Government;
  line
  line `(d) before the expiry of the period of supersession, election or nomination, as the case may be, of`
  line `members to the Council shall be held or made for the purpose of reconstituting the Council.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (39481)
  sectionNo (48)
  orderNo 48
  title `Effect of certain provisions during the period when the Hill Areas Committee is not functioning.`
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39481&sectionno=48&orderno=48&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_48_content:
  string
  line `Where at any time, consequent on the dissolution of the Legislative Assembly of the`
  line `Union territory of Manipur, the Hill Areas Committee is not functioning, then, during the period when`
  line `such Committee is not functioning,—`
  line
  line `(i) section 3 shall have effect as if sub-section (3) thereof had been omitted;`
  line
  line `(ii) clause (xvii) of section 29 and the second proviso to sub-section (1) of section 47 have effect`
  line `as if the words "in consultation with the Hill Areas Committee" had been omitted therefrom.`
obj_root_law_sections_48_footnotes:
  string
  line
obj_root_law_sections_49:
  sectionId (39482)
  sectionNo (49)
  orderNo 49
  title `Penalty for obstruction.`
  content obj_root_law_sections_49_content
  footnotes obj_root_law_sections_49_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39482&sectionno=49&orderno=49&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_49_content:
  string
  line `If any person wilfully obstructs a District Council or any officer or`
  line `servant of a District Council or any person authorised by the District Council in the exercise of its powers,`
  line `he shall be punishable with fine which may extend to fifty rupees.`
obj_root_law_sections_49_footnotes:
  string
  line
obj_root_law_sections_50:
  sectionId (39483)
  sectionNo (50)
  orderNo 50
  title `Penalty for entering into any contract with the Council.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39483&sectionno=50&orderno=50&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_50_content:
  string
  line `If any member, officer or other`
  line `employee of a District Council enters into any contract with the Council, he shall be deemed to have`
  line `committed an offence under section 168 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_50_footnotes:
  string
  line
obj_root_law_sections_51:
  sectionId (39484)
  sectionNo (51)
  orderNo 51
  title `Power of Administrator to make rules.`
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39484&sectionno=51&orderno=51&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_51_content:
  string
  line `(1) Without prejudice to the power to make rules`
  line `under any other provision of this Act, the Administrator may, after previous publication, make, by`
  line `notification in the Official Gazette, rules for the purpose of carrying out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may—`
  line
  line `(i) regulate the conduct of business of a District Council;`
  line
  line `(ii) prescribe the forms in which the budget estimate is to be prepared and the dates for the`
  line `various stages of its completion;`
  line
  line `(iii) determine the language in which the business of a District Council will be transacted;`
  line
  line `(iv) regulate the powers of a District Council to transfer property;`
  line
  line `(v) regulate the powers of a District Council to contract and do other things necessary for the`
  line `purposes of its constitution and the mode of executing contracts;`
  line
  line `(vi) regulate the employment, payment, suspension and removal of officers and staff of a District`
  line Council;
  line
  line `(vii) protect the terms and conditions of service of Government servants transferred to a District`
  line Council;
  line
  line `(viii) prescribe the forms for statements, registers, estimates and accounts of a District Council`
  line `and regulate the keeping, checking and publication of such accounts;`
  line
  line `(ix) prescribe the authority by whom and the manner in which the accounts of a District Council`
  line `shall be audited; and`
  line
  line `(x) provide for any other matter for which rules have to be made under this Act.`
obj_root_law_sections_51_footnotes:
  string
  line
obj_root_law_sections_52:
  sectionId (39485)
  sectionNo (52)
  orderNo 52
  title `Power to make bye-laws.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39485&sectionno=52&orderno=52&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_52_content:
  string
  line `(1) Subject to the provisions of this Act and of the rules made`
  line `thereunder, a District Council may make bye-laws to provide for all or any of the following matters in the`
  line `autonomous district for which it is constituted or in any part thereof, namely:—`
  line
  line `(a) the maintenance and management of schools and grants of stipends and scholarships;`
  line
  line `(b) control and administration of dispensaries, their construction and repairs, the supply of`
  line `medicines and the measures to be taken during the prevalence of diseases;`
  line
  line `(c) the protection from pollution of such tanks, springs, wells or parts of rivers, streams, channels`
  line `or water courses as are set apart for drinking or culinary purposes;`
  line
  line `(d) any other matter which is necessary for carrying out all or any of the provisions of this Act`
  line `and the rules made thereunder.`
  line
  line `(2) A bye-law made under sub-section (1) shall not have effect until it has been confirmed by the`
  line `Administrator and published in such manner as he may direct.`
  line
  line `(3) The Administrator, in confirming a bye-law, may make any change therein which appears to him`
  line `to be necessary.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (39486)
  sectionNo (53)
  orderNo 53
  title `Penalty for infringement of rules or bye-laws.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00020_197176_1517807320542&sectionId=39486&sectionno=53&orderno=53&orgactid=AC_CEN_5_5_00020_197176_1517807320542
obj_root_law_sections_53_content:
  string
  line `(1) In making any rule, the Administrator, and`
  line `in making any bye-law, a District Council, may direct that the breach of the same shall be punishable with`
  line `fine which may extend to one hundred rupees and in the case of a continuing breach with a further fine`
  line `which may extend to ten rupees of every day during which the breach is continued after the offender has`
  line `been convicted of such breach.`
  line
  line `(2) In default of payment of any fine, the defaulter shall be punishable with imprisonment for a term`
  line `which may extend to fifteen days.`
obj_root_law_sections_53_footnotes:
  string
  line
