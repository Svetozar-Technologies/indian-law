  (str slug) (str the-reserve-and-auxiliary-air-forces-act-1952)
  (str handle) (str 2161)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Reserve and Auxiliary Air Forces Act, 1952`)
  (str actNumber) (str 62)
  (str enactmentDate) (str 1952-08-22)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2161`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `रिजर्व और सहायक वायु सेना अधिनियम, 1952`)
  (str actYear) (str 1952)
  (str ministry) (str `Ministry of Defence`)
  (str department) (str `Department of Military Affairs`)
  (str longTitle) (str `An Act to provide for the constitution and regulation of certain Air Force Reserve and also an Auxiliary Air Force and for matters connected therewith.`)
  (str enforcementDate) (str 15-08-1955)
  (str notification) (str `Chapters II and III and provisions of Chapters V and VI except so far as they relate to the Auxiliary Air Force came into force on the 15th August, 1955, vide S.R.O. 332, dated the 20th August, 1955, Gazette of India, Part II, sec. 4. Chapter IV and provisions of Chapters V and VI relating to the Auxiliary Air Force came into force on the 15th October, 1955, vide S.R.O. 395, dated the 15th October, 1955, Gazette of India, Part II, sec. 4.`)
