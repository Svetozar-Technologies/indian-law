obj_root_law_sections_1:
  object
  (str sectionId) (str 33505)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and extent.`)
  (str content) (str `(1) This Act may be called the Hindu Disposition of Property Act, 1916.

^1[(2) It extends to the whole of India ^2***.]^3`)
  (str footnotes) (str `1. Subs. by Act 48 of 1959, s. 3 and Sch. I, for sub-section (2) (w.e.f. 1-2-1960).

2. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule
(w.e.f. 31-10- 2019).

3. The Act has been extended to Dadra and Nagar Haveli by Reg. 6 of 1963, s. 2 and Sch.

In its application to Pondicherry, in section 1, after sub-section (2), the following shall be inserted "Provided
that nothing contained in this Act, shall apply to the Renoncants of the Union territory of Pondicherry. "--(Vide
Act 26 of 1968).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33505&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00055_191615_1523342501478)
obj_root_law_sections_2:
  object
  (str sectionId) (str 33506)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Dispositions for the benefit of persons not in existence.`)
  (str content) (str `Subject to the limitations and
provisions specified in this Act, no disposition of property by a Hindu, whether by transfer inter vivos or
by will, shall be invalid by reason only that any person for whose benefit it may have been made was not
in existence at the date of such disposition.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33506&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00055_191615_1523342501478)
obj_root_law_sections_3:
  object
  (str sectionId) (str 33507)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Limitations and conditions.`)
  (str content) (str `The limitations and provisions referred to in section 2 shall be the
following, namely:--

(a) in respect of dispositions by transfer inter vivos, those contained in ^1[Chapter II] of the
Transfer of Property Act, 1882 (4 of 1882), and

(b) in respect of dispositions by will, those contained in ^2[sections 113, 114, 115 and 116 of the
Indian Succession Act, 1925 (33 of 1925)].`)
  (str footnotes) (str `1. Subs. by Act 21 of 1929, s. 12, for "sections 13, 14 and 20".

2. Subs. by s. 12, ibid., for "sections 100 and 101 of the Indian Succession Act, 1865".`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33507&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00055_191615_1523342501478)
obj_root_law_sections_4:
  object
  (str sectionId) (str 33508)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str [Repealed.].)
  (str content) (str `[Failure of prior disposition.] Rep. by the Transfer of Property (Amendment) Supplementary Act, 1929 (21 of1929), s. 12.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33508&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00055_191615_1523342501478)
obj_root_law_sections_5:
  object
  (str sectionId) (str 33509)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Application of this Act to the Khoja community.`)
  (str content) (str `Where the ^1[State Government] is of
opinion that the Khoja community in ^2[the State] or any part thereof desire that the provisions of this
Act should be extended to such community ^3[it] may by notification in the Official Gazette, declare
that the provisions of this Act, with the substitution of the word "Khojas" or "Khoja", as the case
may be, for the word "Hindus" or "Hindu" wherever those words occur, shall apply to that
community in such area as may be specified in the notification, and this Act shall thereupon have
effect accordingly.`)
  (str footnotes) (str `1. Subs. by the A.O. 1937, for "G.G. in C"..

2. Subs., ibid., for "British India".

3. Subs., ibid., for "he".`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33509&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00055_191615_1523342501478)
