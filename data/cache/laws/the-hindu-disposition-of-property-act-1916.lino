obj_root_law_sections_1:
  sectionId (33505)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33505&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00055_191615_1523342501478
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Hindu Disposition of Property Act, 1916.`
  line
  line `^1[(2) It extends to the whole of India ^2***.]^3`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 48 of 1959, s. 3 and Sch. I, for sub-section (2) (w.e.f. 1-2-1960).`
  line
  line `2. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule`
  line `(w.e.f. 31-10- 2019).`
  line
  line `3. The Act has been extended to Dadra and Nagar Haveli by Reg. 6 of 1963, s. 2 and Sch.`
  line
  line `In its application to Pondicherry, in section 1, after sub-section (2), the following shall be inserted "Provided`
  line `that nothing contained in this Act, shall apply to the Renoncants of the Union territory of Pondicherry. "--(Vide`
  line `Act 26 of 1968).`
obj_root_law_sections_2:
  sectionId (33506)
  sectionNo (2)
  orderNo 2
  title `Dispositions for the benefit of persons not in existence.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33506&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00055_191615_1523342501478
obj_root_law_sections_2_content:
  string
  line `Subject to the limitations and`
  line `provisions specified in this Act, no disposition of property by a Hindu, whether by transfer inter vivos or`
  line `by will, shall be invalid by reason only that any person for whose benefit it may have been made was not`
  line `in existence at the date of such disposition.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (33507)
  sectionNo (3)
  orderNo 3
  title `Limitations and conditions.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33507&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00055_191615_1523342501478
obj_root_law_sections_3_content:
  string
  line `The limitations and provisions referred to in section 2 shall be the`
  line `following, namely:--`
  line
  line `(a) in respect of dispositions by transfer inter vivos, those contained in ^1[Chapter II] of the`
  line `Transfer of Property Act, 1882 (4 of 1882), and`
  line
  line `(b) in respect of dispositions by will, those contained in ^2[sections 113, 114, 115 and 116 of the`
  line `Indian Succession Act, 1925 (33 of 1925)].`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 21 of 1929, s. 12, for "sections 13, 14 and 20".`
  line
  line `2. Subs. by s. 12, ibid., for "sections 100 and 101 of the Indian Succession Act, 1865".`
obj_root_law_sections_4:
  sectionId (33508)
  sectionNo (4)
  orderNo 4
  title [Repealed.].
  content `[Failure of prior disposition.] Rep. by the Transfer of Property (Amendment) Supplementary Act, 1929 (21 of1929), s. 12.`
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33508&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00055_191615_1523342501478
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (33509)
  sectionNo (5)
  orderNo 5
  title `Application of this Act to the Khoja community.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00055_191615_1523342501478&sectionId=33509&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00055_191615_1523342501478
obj_root_law_sections_5_content:
  string
  line `Where the ^1[State Government] is of`
  line `opinion that the Khoja community in ^2[the State] or any part thereof desire that the provisions of this`
  line `Act should be extended to such community ^3[it] may by notification in the Official Gazette, declare`
  line `that the provisions of this Act, with the substitution of the word "Khojas" or "Khoja", as the case`
  line `may be, for the word "Hindus" or "Hindu" wherever those words occur, shall apply to that`
  line `community in such area as may be specified in the notification, and this Act shall thereupon have`
  line `effect accordingly.`
obj_root_law_sections_5_footnotes:
  string
  line `1. Subs. by the A.O. 1937, for "G.G. in C"..`
  line
  line `2. Subs., ibid., for "British India".`
  line
  line `3. Subs., ibid., for "he".`
