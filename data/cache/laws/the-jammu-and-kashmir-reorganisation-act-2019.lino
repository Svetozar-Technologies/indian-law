obj_root_law_sections_2:
  sectionId (49599)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00071_201934_1568889824041&sectionId=49599&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00071_201934_1568889824041
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,---`
  line
  line `(a) "appointed day" means the day^1 which the Central Government may, by notification in the`
  line `Official Gazette, appoint;`
  line
  line `(b) "article" means an article of the Constitution;`
  line
  line `(c) "assembly constituency" and "parliamentary constituency" have the same meanings as in the`
  line `Representation of the People Act, 1950 (43 of 1950);`
  line
  line `(d) "Election Commission" means the Election Commission appointed by the President under`
  line `article 324;`
  line
  line `(e) "existing State of Jammu and Kashmir" means the State of Jammu and Kashmir as existing`
  line `immediately before the appointed day, comprising the territory which immediately before the`
  line `commencement of the Constitution of India in the Indian State of Jammu and Kashmir;`
  line
  line `(f) "law" includes any enactment, ordinance, regulation, order, bye-law, rule, scheme, notification or`
  line `other instrument having, immediately before the appointed day, the force of law in the whole or in any`
  line `part of the existing State of Jammu and Kashmir;`
  line
  line `(g) "Legislative Assembly" means Legislative Assembly of Union territory of Jammu and`
  line Kashmir;
  line
  line `(h) "Lieutenant Governor" means the Administrator of the Union territory appointed by the`
  line `President under article 239;`
  line
  line `(i) "notified order" means an order published in the Official Gazette;`
  line
  line `(j) "population ratio", in relation to the Union territory of Jammu and Kashmir, and Union`
  line `territory of Ladakh means the ratio as per 2011 Census;`
  line
  line `(k) "Scheduled Castes" in relation to the Union territory means such castes, races or tribes or`
  line `parts of groups within such castes, races or tribes as are deemed under article 341 to be Scheduled`
  line `Castes in relation to that Union territory;`
  line
  line `(l) "Scheduled Tribes" in relation to the Union territory means such tribes or tribal communities`
  line `or parts of or groups within such tribes or tribal communities as are deemed under article 342 to be`
  line `Scheduled Tribes in relation to that Union territory;`
  line
  line `(m) "sitting member", in relation to either House of Parliament or of the Legislature of the`
  line `existing State of Jammu and Kashmir, means a person who immediately before the appointed day,`
  line `is a member of that House;`
  line
  line `(n) "Union territory", in relation to the existing State of Jammu and Kashmir, means the Union`
  line `territory of Jammu and Kashmir or Union territory of Ladakh, as the case may be;`
  line
  line `(o) "transferred territory" means the territory which on the appointed day is transferred from the`
  line `existing State of Jammu and Kashmir to Union territories formed under sections 3 and 4 of this`
  line `Act; and`
  line
  line `(p) any reference to a district, tehsil or other territorial division of the existing State of Jammu`
  line `and Kashmir shall be construed as a reference to the area comprised within that territorial division`
  line `on the appointed day.`
obj_root_law_sections_2_footnotes:
  string
  line `1. 31st October, 2019 ---clause (a) of Section 2,`
  line `vide notification No. S.O. 2889 (E), dated 09th August, 2019 see Gazette of`
  line `India Extraordinary, Part II, s. 3 (ii).`
obj_root_law_sections_3:
  sectionId (49600)
  sectionNo (3)
  orderNo 3
  title `Formation of Union territory of Ladakh without Legislature.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
