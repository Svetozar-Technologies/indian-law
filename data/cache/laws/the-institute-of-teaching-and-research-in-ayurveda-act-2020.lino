obj_root_law_sections_1:
  sectionId (51428)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51428&sectionno=1&orderno=1&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Institute of Teaching and`
  line `Research in Ayurveda Act, 2020.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint and different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 15th October, 2020, vide notification No. S.O. 3608(E), dated 14th October, 2020, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (51460)
  sectionNo (2)
  orderNo 2
  title `Declaration of institute of Teaching and Research in Ayurveda as an institution of national importance.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51460&sectionno=2&orderno=2&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_2_content:
  string
  line `It is hereby declared that the Institute of Teaching and Research in Ayurveda`
  line `incorporated under this Act shall be an institution of national importance.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (51430)
  sectionNo (3)
  orderNo 3
  title Definitions.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51430&sectionno=3&orderno=3&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_3_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Anteceding Institutions" means the Institute of Post Graduate Teaching and Research in`
  line `Ayurveda, Jamnagar, Shree Gulabkunverba Ayurved Mahavidyalaya, Jamnagar and the Indian`
  line `Institute of Ayurvedic Pharmaceutical Sciences, Jamnagar;`
  line
  line `(b) "Department of Swasthvritta" means the Maharishi Patanjali Institute for Yoga Naturopathy`
  line `Education and Research, Jamnagar, a constituent institute of the Gujarat Ayurveda University, to be`
  line `established as a Department of the Institute;`
  line
  line `(c) "Director" means the Director of the Institute appointed under sub-section (1) of section 11;`
  line
  line `(d) "Fund" means the Fund of the Institute maintained under section 15;`
  line
  line `(e) "Governing Body" means the body constituted under sub-section (1) of section 10;`
  line
  line `(f) "Gujarat Ayurved University" means the University established and incorporated under the`
  line `Gujarat Ayurved University Act, 1965 (40 of 1965);`
  line
  line `(g) "Indian Institute of Ayurvedic Pharmaceutical Sciences, Jamnagar" means an institution`
  line `established by the Gujarat Ayurveda University for conducting Pharmacy courses in Ayurveda and`
  line `includes the Pharmacy Unit established for preparation of Ayurvedic drugs for use in hospital of the`
  line Institute;
  line
  line `(h) "Institute" means the Institute of Teaching and Research in Ayurveda established by`
  line `conglomerating Anteceding Institutions and incorporated under section 4;`
  line
  line `(i) "Institute of Post Graduate Teaching and Research in Ayurveda, Jamnagar" means a national`
  line `institute for postgraduate courses in Ayurveda established and funded by the Government of India,`
  line `but maintained by the Gujarat Ayurveda University under a lease agreement entered between the`
  line `Government of India and that University;`
  line
  line `(j) "member" means a member of the Institute;`
  line
  line `(k) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(l) "regulation" means a regulation made by the Institute.`
  line
  line `(m) "Shree Gulabkunverba Ayurved Mahavidyalaya, Jamnagar" means a constituent institute of`
  line `the Gujarat Ayurveda University for conducting undergraduate courses in Ayurveda.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (51461)
  sectionNo (4)
  orderNo 4
  title `Establishment and incorporation of Anteceding Institutions as Institute of Teaching and Research in Ayurveda.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51461&sectionno=4&orderno=4&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_4_content:
  string
  line `(1) The Anteceding Institutions, namely, the Institute of Post Graduate`
  line `Teaching and Research in Ayurveda, Jamnagar, Shree Gulabkunverba Ayurved Mahavidyalaya,`
  line `Jamnagar and the Indian Institute of Ayurvedic Pharmaceutical Sciences, Jamnagar are hereby`
  line `conglomerated and established as a body corporate under this Act and on such incorporation be called the`
  line `Institute of Teaching and Research in Ayurveda.`
  line
  line `(2) The Institute shall have perpetual succession and a common seal, with power to acquire, hold and`
  line `dispose of property, both movable and immovable, and to contract, and may by that name sue or be sued.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (51459)
  sectionNo (5)
  orderNo 5
  title `Effect of incorporation of Anteceding Institutions as Institute of Teaching and Research in Ayurveda.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51459&sectionno=5&orderno=5&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_5_content:
  string
  line `On and from the commencement of this Act,--`
  line
  line `(a) any reference in any law, other than this Act, or in any contract or other instrument to`
  line `Anteceding Institutions shall be deemed as a reference to the Institute;`
  line
  line `(b) all property, movable and immovable, of or belonging to Anteceding Institutions shall vest in`
  line `the Institute;`
  line
  line `(c) all the rights and liabilities of Anteceding Institutions shall be transferred to, and be the rights`
  line `and liabilities of, the Institute;`
  line
  line `(d) every person who is employed in the Anteceding Institutions immediately before such`
  line `commencement shall, subject to the provisions of this Act, become the employee of the Institute and`
  line `hold his office or service therein by the same tenure, at the same remuneration and upon the same`
  line `terms and conditions and with the same rights and privileges as to pension, leave, gratuity, provident`
  line `fund, and other matters as he would have held the same if this Act had not been passed, and shall`
  line `continue to do so unless and until his employment is terminated or until such tenure, remuneration`
  line `and terms and conditions are duly altered by regulations:`
  line
  line `Provided that if the alteration so made is not acceptable to such employee, his employment may`
  line `be terminated by the Institute in accordance with the terms of the contract with the employee or, if no`
  line `provision is made therein in this behalf, on payment to him by the Institute of compensation`
  line `equivalent to not less than three months' remuneration in the case of permanent employees and not`
  line `less than one month's remuneration in the case of other employees;`
  line
  line `(e) the Director of the Institute of Post Graduate Teaching and Research in Ayurveda, Jamnagar`
  line `shall be deemed to have been appointed as the Director of the Institute under this Act and shall hold`
  line `office for a period of five years with effect from such commencement or until he attains the age of`
  line `sixty-five years, whichever is earlier;`
  line
  line `(f) the Directors of Shree Gulabkunverba Ayurved Mahavidyalaya, Jamnagar and the Indian`
  line `Institute of Ayurvedic Pharmaceutical Sciences, Jamnagar shall be deemed to have been appointed as`
  line `Deputy Director (Undergraduate) and Deputy Director (Pharmacy), respectively, under this Act and`
  line `shall hold office for a period of five years with effect from such commencement or until they attain`
  line `the age of sixty-five years, whichever is earlier;`
  line
  line `(g) every person pursuing any academic or research course in Anteceding Institutions before such`
  line `commencement, shall be deemed to have migrated and registered with the Institute at the same level`
  line `of course in the Institute;`
  line
  line `(h) all suits and other legal proceedings instituted or which could have been instituted by or`
  line `against Anteceding Institutions, immediately before such commencement, shall be continued or`
  line `instituted by or against the Institute.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (51433)
  sectionNo (6)
  orderNo 6
  title `Composition of Institute.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51433&sectionno=6&orderno=6&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_6_content:
  string
  line `(1) The Institute shall consist of the following members, namely:--`
  line
  line `(a) the Minister in charge of the Ministry of AYUSH, ex officio;`
  line
  line `(b) the Secretary to the Government of India in the Ministry of AYUSH, ex officio;`
  line
  line `(c) the Secretary, Department of Health, Government of Gujarat, ex officio;`
  line
  line `(d) the Director of the Institute, ex officio;`
  line
  line `(e) the technical head of Ayurveda, not below the level of Advisor (Ayurveda), Ministry of`
  line `AYUSH, ex officio;`
  line
  line `(f) the Secretary to the Government of India or his nominee (not below the rank of Joint`
  line `Secretary) Ministry of Finance, Department of Expenditure, ex officio;`
  line
  line `(g) the Vice-Chancellor of Gujarat Ayurved University, Jamnagar, ex officio;`
  line
  line `(h) the Director-General, Central Council for Research in Ayurveda, ex officio;`
  line
  line `(i) the Secretary to the Government of India or his nominee (not below the rank of Joint`
  line `Secretary) in the Department of Higher Education, Ministry of Human Resource Development, ex`
  line officio;
  line
  line `(j) three experts in Ayurveda, having special knowledge and experience in the field of education,`
  line `industry and research, to be nominated by the Central Government;`
  line
  line `(k) three Members of Parliament, of whom two shall be elected from among themselves by the`
  line `members of the House of the People and one from among themselves by members of the Council of`
  line States.
  line
  line `(2) It is hereby declared that the office of member of the Institute shall not disqualify its holder for`
  line `being chosen as, or for being, a member of either House of Parliament.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (51434)
  sectionNo (7)
  orderNo 7
  title `Terms of office of, and vacancies among, members.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51434&sectionno=7&orderno=7&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_7_content:
  string
  line `(1) Save as otherwise provided in this`
  line `section, the term of office of a member including nominated or elected member of the Institute shall be`
  line `five years from the date of his nomination or election.`
  line
  line `(2) The term of office of a member elected under clause (k) of sub-section (1) of section 6 shall come`
  line `to an end as soon as he becomes a Minister or Minister of State or Deputy Minister or the Speaker or the`
  line `Deputy Speaker of the House of the People or the Deputy Chairman of the Council of States or ceases to`
  line `be a member of the House from which he was elected.`
  line
  line `(3) The term of office of an ex officio member shall continue so long as he holds the office by virtue`
  line `of which he is a member.`
  line
  line `(4) The term of office of a member nominated or elected to fill a causal vacancy shall continue for the`
  line `remainder of the term of the member in whose place he has been nominated or elected.`
  line
  line `(5) An outgoing member shall, unless the Central Government otherwise directs, continue in office`
  line `until another person is nominated or elected as a member in his place.`
  line
  line `(6) A member may resign his office by writing under his hand addressed to the Central Government`
  line `but he shall continue in office till his resignation is accepted by that Government.`
  line
  line `(7) The manner of filling vacancies among members shall be such as may be prescribed.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (51435)
  sectionNo (8)
  orderNo 8
  title `President of Institute.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51435&sectionno=8&orderno=8&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_8_content:
  string
  line `(1) There shall be a President of the Institute who shall be nominated by`
  line `the Central Government from among the members other than the Director of the Institute.`
  line
  line `(2) The President shall exercise such powers and discharge such functions as are laid down in this Act`
  line `or as may be prescribed.`
  line
  line `(3) The President and other members shall receive such allowances from the Institute as may be`
  line prescribed.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (51436)
  sectionNo (9)
  orderNo 9
  title `Meetings of Institute.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51436&sectionno=9&orderno=9&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_9_content:
  string
  line `The Institute shall hold its first meeting at such time and place as may be`
  line `appointed by the Central Government and shall observe such rules of procedure in regard to the`
  line `transaction of business at the first meeting as may be laid down by that Government, and thereafter, the`
  line `Institute shall meet at such times and places and observe such rules of procedure in regard to the`
  line `transaction of business at its meetings (including quoram) as may be specified by regulations.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (51437)
  sectionNo (10)
  orderNo 10
  title `Governing Body and other committees of Institute.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51437&sectionno=10&orderno=10&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_10_content:
  string
  line `(1) There shall be a Governing Body of`
  line `the Institute which shall be constituted by the Institute in such manner as may be specified by regulations.`
  line
  line `(2) The Governing Body shall be the executive committee of the Institute and shall exercise such`
  line `powers and discharge such functions as the Institute may, by regulations made in this behalf, confer or`
  line `impose upon it.`
  line
  line `(3) The President of the Institute shall be the Chairperson of the Governing Body and as Chairperson`
  line `thereof shall exercise such powers and discharge such functions as may be specified by regulations.`
  line
  line `(4) The procedure to be followed in the exercise of its powers and discharge of its functions by the`
  line `Governing Body, and the term of office of, and the manner of filling vacancies among, the members of`
  line `the Governing Body shall be such as may be specified by regulations.`
  line
  line `(5) Subject to such control and restrictions as may be prescribed, the Institute may constitute as many`
  line `standing committees and ad hoc committees as it thinks fit for exercising any power or discharging any`
  line `function of the Institute or for inquiring into, or reporting or advising upon, any matter which the Institute`
  line `may refer to them, in such manner as may be specified by regulations.`
  line
  line `(6) The Chairperson and members of the Governing Body and the Chairperson and the members of a`
  line `standing committee or an ad hoc committee shall receive such allowances, as may be specified by`
  line regulations.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (51438)
  sectionNo (11)
  orderNo 11
  title `Staff of Institute.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51438&sectionno=11&orderno=11&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_11_content:
  string
  line `(1) There shall be a chief executive officer of the Institute who shall be`
  line `designated as the Director of the Institute and shall, subject to such rules as may be made by the Central`
  line `Government in this behalf, be appointed by the Institute:`
  line
  line `Provided that the Director of the Institute of Post Graduate Teaching and Research in Ayurveda,`
  line `Jamnagar shall be deemed to have been appointed as the first Director of the Institute.`
  line
  line `(2) The Director shall hold office for a term of five years from the date on which he enters upon his`
  line `office or until he attains the age of sixty-five years, whichever is earlier.`
  line
  line `(3) The Director shall exercise such powers and discharge such functions as may be specified by`
  line `regulations or as may be delegated to him by the Institute or the President of the Institute or the`
  line `Governing Body or the Chairperson of the Governing Body.`
  line
  line `(4) Subject to such rules as may be made by the Central Government in this behalf, the Institute may`
  line `appoint Deputy Director (Undergraduate), Deputy Director (Postgraduate) and Deputy Director (Pharmacy) and such number of other officers and employees as may be necessary for the exercise of its`
  line `powers and discharge of its functions and the designations and grades of other officers and employees`
  line `shall be such as may be specified by regulations:`
  line
  line `Provided that the Director of Shree Gulabkunverba Ayurved Mahavidyalaya, Jamnagar shall be`
  line `deemed to have been appointed as the first Deputy Director (Undergraduate) of the Institute:`
  line
  line `Provided further that the Director of the Indian Institute of Ayurvedic Pharmaceutical Sciences,`
  line `Jamnagar shall be deemed to have been appointed as the first Deputy Director (Pharmacy) under this Act.`
  line
  line `(5) The Director, Deputy Director (Undergraduate), Deputy Director (Postgraduate) and Deputy`
  line `Director (Pharmacy) and other officers and employees of the Institute shall be entitled to such salary and`
  line `allowances and shall be governed by such conditions of service in respect of leave, pension, provident`
  line `fund and other matters as may be specified by regulations.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (51439)
  sectionNo (12)
  orderNo 12
  title `Objects of Institute.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51439&sectionno=12&orderno=12&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_12_content:
  string
  line `The objects of the Institute shall be--`
  line
  line `(a) to develop patterns of teaching in undergraduate and postgraduate medical education in`
  line `Ayurveda and Pharmacy so as to demonstrate a high standard of such medical education to all`
  line `medical colleges and other allied institutions of Ayurveda in India;`
  line
  line `(b) to bring together in one place educational facilities of the highest order for the training of`
  line `personnel in all important branches of Ayurveda including Pharmacy;`
  line
  line `(c) to attain self-sufficiency in postgraduate education to meet the country's needs for specialists`
  line `and medical teachers in Ayurveda;`
  line
  line `(d) to make an in-depth study and research in the field of Ayurveda.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (51440)
  sectionNo (13)
  orderNo 13
  title `Functions of Institute.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51440&sectionno=13&orderno=13&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_13_content:
  string
  line `With a view to the promotion of the objects specified in section 12, the`
  line `Institute may---`
  line
  line `(a) provide for undergraduate and postgraduate teaching in Ayurveda, including Pharmacy;`
  line
  line `(b) provide facilities for research in the various branches of Ayurveda including Pharmacy;`
  line
  line `(c) prescribe courses and curricula for both undergraduate and postgraduate studies in Ayurveda`
  line `including Pharmacy;`
  line
  line `(d) notwithstanding anything contained in any other law for the time being in force, establish and`
  line maintain---
  line
  line `(i) one or more Ayurveda medical colleges with different Departments including department`
  line `of Swasthvritta and such other departments as may deemed to be necessary for scientific`
  line `validation of Ayurveda, implementing Ayurveda principles and theories in public health and`
  line `further expansion of Ashtanga Ayurveda with the help of modern scientific advances sufficiently`
  line `staffed and equipped to undertake undergraduate and postgraduate Ayurveda education including`
  line Pharmacy;
  line
  line `(ii) one or more well-equipped hospitals;`
  line
  line `(iii) colleges for Ayurveda supporting staffs such as nurses, Pharmacists, Panchakarma`
  line `technicians or therapists and such other allied disciplines of Ayurveda sufficiently staffed and`
  line `equipped for training such students;`
  line
  line `(iv) rural and urban health organisations which will form centres for the field training in`
  line `Ayurveda and for research into community health problems; and`
  line
  line `(v) other institutions for the training of different types of health workers, such as`
  line `physiotherapists, occupational therapists and Ayurvedic medical technicians of various kinds;`
  line
  line `(e) train teachers for the different Ayurveda colleges in India;`
  line
  line `(f) hold examinations (including for admissions) and grant degrees, diplomas and other academic`
  line `distinctions and titles in undergraduate and postgraduate education in Ayurveda and Pharmacy as may`
  line `be laid down in the regulations;`
  line
  line `(g) institute, and appoint persons to professorships, readerships, lectureships and posts of any`
  line `description in accordance with regulations;`
  line
  line `(h) receive grants from the Government and gifts, donations, benefactions, bequests and transfers`
  line `of properties, both movable and immovable, from donors, benefactors, testators or transferors, as the`
  line `case may be;`
  line
  line `(i) deal with any property belonging to, or vested in, the Institute in any manner which is`
  line `considered necessary for promoting the objects specified in section 12;`
  line
  line `(j) demand and receive such fees and other charges as may be specified by regulations;`
  line
  line `(k) construct quarters for its staff and allot such quarters to the staff in accordance with such`
  line `regulations as may be made in this behalf;`
  line
  line `(l) establish, maintain and manage halls and hostels for the residence of students;`
  line
  line `(m) supervise and control the residence and regulate the discipline of students of the Institute and`
  line `to make arrangements for promoting their health, general welfare and cultural and corporate life;`
  line
  line `(n) institute and award fellowships, scholarships, exhibitions, prizes and medals;`
  line
  line `(o) borrow money, with the prior approval of the Central Government, on the security of the`
  line `property of the Institute;`
  line
  line `(p) to perform all such things as may be necessary, incidental or conducive to the attainment of all`
  line `or any of the objects of the Institute.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (51441)
  sectionNo (14)
  orderNo 14
  title `Payment to Institute.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51441&sectionno=14&orderno=14&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_14_content:
  string
  line `The Central Government may, after due appropriation made by`
  line `Parliament by law in this behalf, pay to the Institute in each financial year such sums of money and in`
  line `such manner as may be considered necessary for the exercise of its powers and discharge of its functions`
  line `under this Act.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (51442)
  sectionNo (15)
  orderNo 15
  title `Fund of Institute.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51442&sectionno=15&orderno=15&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_15_content:
  string
  line `(1) The Institute shall maintain a Fund to which shall be credited--`
  line
  line `(a) all moneys provided by the Central Government;`
  line
  line `(b) all fees and other charges received by the Institute;`
  line
  line `(c) all moneys received by the Institute by way of grants, gifts, donations, benefactions, bequests`
  line `or transfers; and`
  line
  line `(d) all moneys received by the Institute in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund shall be deposited in such banks or invested in such manner as`
  line `the Institute may, with the approval of the Central Government, decide.`
  line
  line `(3) The Fund shall be utilised towards meeting the expenses of the Institute including expenses`
  line `incurred in the exercise of its powers and discharge of its duties under section 13.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (51443)
  sectionNo (16)
  orderNo 16
  title `Budget of Institute.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51443&sectionno=16&orderno=16&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_16_content:
  string
  line `The Institute shall prepare in such form and at such time every year a`
  line `budget in respect of the financial year next ensuing showing the estimated receipts and expenditure of the`
  line `Institute and shall forward to the Central Government such number of copies thereof as may be`
  line prescribed.
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (51444)
  sectionNo (17)
  orderNo 17
  title `Accounts and audit.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51444&sectionno=17&orderno=17&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_17_content:
  string
  line `(1) The Institute shall maintain proper accounts and other relevant records`
  line `and prepare an annual statement of accounts including the balance-sheet, in such form as the Central`
  line `Government may prescribe by rules, and in accordance with such general directions as may be issued by`
  line `that Government, in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Institute shall be audited by the Comptroller and Auditor-General of India and`
  line `any expenditure incurred by him in connection with such audit shall be payable by the Institute to the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any person appointed by him in connection`
  line `with the audit of the accounts of the Institute shall have the same rights, privileges and authority in`
  line `connection with such audit as the Comptroller and Auditor-General of India has in connection with the`
  line `audit of the Government accounts, and, in particular, shall have the right to demand the production of`
  line `books, accounts, connected vouchers and other documents and papers and to inspect the offices of the`
  line Institute.
  line
  line `(4) The accounts of the Institute as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before both the`
  line `Houses of Parliament.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (51445)
  sectionNo (18)
  orderNo 18
  title `Annual report.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51445&sectionno=18&orderno=18&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_18_content:
  string
  line `The Institute shall prepare for every year a report of its activities during that`
  line `year and submit the report to the Central Government in such form and on or before such date as may be`
  line `prescribed and a copy of this report shall be laid before both Houses of Parliament within one month of its`
  line receipt.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (51446)
  sectionNo (19)
  orderNo 19
  title `Pension and provident funds.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51446&sectionno=19&orderno=19&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_19_content:
  string
  line `(1) The Institute shall constitute for the benefit of its officers,`
  line `teachers and other employees, in such manner and subject to such conditions as may be specified by`
  line `regulations, such pension and provident funds as it may deem fit:`
  line
  line `Provided that the pension and provident fund constituted by the Anteceding Institutions before the`
  line `commencement of this Act shall be deemed to be the pension and provident fund under this section.`
  line
  line `(2) Where any such provident fund has been constituted, the Central Government may declare that the`
  line `provisions of the Provident Funds Act, 1925 (19 of 1925) shall apply to such fund as if it were a`
  line `Government Provident Fund.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (51447)
  sectionNo (20)
  orderNo 20
  title `Authentication of orders and instruments of Institute.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51447&sectionno=20&orderno=20&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_20_content:
  string
  line `All orders and decisions of the`
  line `Institute shall be authenticated by the Director or any other member authorised by the Institute in this`
  line `behalf and all other instruments shall be authenticated by the signature of the Director or such other`
  line `officers as may be authorised by the Institute.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (51448)
  sectionNo (21)
  orderNo 21
  title `Acts and proceedings not to be invalidated by vacancies, etc.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51448&sectionno=21&orderno=21&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_21_content:
  string
  line `No act done or proceeding`
  line `taken by the Institute, Governing Body or any standing or ad hoc committee under this Act shall be`
  line `questioned on the ground merely of the existence of any vacancy in, or defect in the constitution of the`
  line `Institute, Governing Body or such standing or ad hoc committee.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (51449)
  sectionNo (22)
  orderNo 22
  title `Grant of degrees, diplomas, etc., by Institute.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51449&sectionno=22&orderno=22&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_22_content:
  string
  line `Notwithstanding anything contained in any`
  line `other law for the time being in force, the Institute shall have power to grant medical degrees, diplomas`
  line `and other academic distinctions and titles under this Act.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (51450)
  sectionNo (23)
  orderNo 23
  title `Recognition of medical qualifications granted by Institute.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51450&sectionno=23&orderno=23&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_23_content:
  string
  line `Notwithstanding anything`
  line `contained in the Indian Medicine Central Council Act, 1970 (49 of 1970) and the University Grants`
  line `Commission Act, 1956 (3 of 1956), the medical degrees or diplomas granted by the Institute under this`
  line `Act shall be recognised medical qualifications for the purposes of the Acts aforesaid and shall be deemed`
  line `to be included in the Schedule to the respective Acts.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (51451)
  sectionNo (24)
  orderNo 24
  title `Control by Central Govern.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51451&sectionno=24&orderno=24&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_24_content:
  string
  line `The Institute shall carry out such directions as may be issued`
  line `to it from time to time by the Central Government for the efficient administration of this Act.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (51452)
  sectionNo (25)
  orderNo 25
  title `Resolution of differences.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51452&sectionno=25&orderno=25&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_25_content:
  string
  line `If in, or in connection with, the exercise of its powers and discharge`
  line `of its functions by the Institute under this Act, any dispute or difference arises between the Institute and`
  line `the Central Government, the decision of the Central Government thereon shall be final.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (51453)
  sectionNo (26)
  orderNo 26
  title `Returns and information.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51453&sectionno=26&orderno=26&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_26_content:
  string
  line `The Institute shall furnish to the Central Government such reports,`
  line `returns and other information as that Government may require from time to time.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (51454)
  sectionNo (27)
  orderNo 27
  title `Power to make rules.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51454&sectionno=27&orderno=27&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_27_content:
  string
  line `(1) The Central Government may make rules to carry out the purposes of`
  line `this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner of filling vacancies among members of the Institute under sub-section (7) of`
  line `section 7;`
  line
  line `(b) the powers and functions to be exercised and discharged by the President of the Institute under`
  line `sub-section (2) of section 8;`
  line
  line `(c) the allowances, if any, to be paid to the President and members of the Institute under subsection (3) of section 8;`
  line
  line `(d) the control and restrictions in relation to the constitution of standing committees and ad hoc`
  line `committees under sub-section (5) of section 10;`
  line
  line `(e) the form in which and the time at which the budget showing the estimated receipts and`
  line `expenditure of the Institute shall be prepared by the Institute and the numbers of copies thereof to be`
  line `forwarded to the Central Government under section 16;`
  line
  line `(f) the form in which annual report shall be prepared and the date before which such report shall`
  line `be submitted to the Central Government under section 18;`
  line
  line `(g) any other matter which has to be or may be prescribed.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (51455)
  sectionNo (28)
  orderNo 28
  title `Power to make regulations.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51455&sectionno=28&orderno=28&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_28_content:
  string
  line `(1) The Institute, with the previous approval of the Central`
  line `Government may, by notification in the Official Gazette, make regulations consistent with this Act and`
  line `the rules made thereunder to carry out the purposes of this Act, and without prejudice to the generality of`
  line `this power, such regulations may provide for:--`
  line
  line `(a) the summoning and holding of meetings other than the first meeting of the Institute, the time`
  line `and place where such meetings are to be held, the conduct of business at such meetings and the`
  line `number of members necessary to form a quorum under section 9;`
  line
  line `(b) the manner of constituting the Governing Body under sub-section (1) of section 10;`
  line
  line `(c) the powers and functions to be exercised and discharged by the Governing Body under`
  line `sub-section (2) of section 10;`
  line
  line `(d) the powers and functions to be exercised and discharged by the President of the Institute under`
  line `sub-section (3) of section 10;`
  line
  line `(e) the procedure to be followed by the Governing Body, the term of office of, and the manner of`
  line `filling vacancies among, the members of the Governing Body under sub-section (4) of section 10;`
  line
  line `(f) the manner of constituting standing committees and ad hoc committees under sub-section (5)`
  line `of section 10;`
  line
  line `(g) the allowances, if any, to be paid to the Chairperson and the members of the Governing Body`
  line `and of standing committee and ad hoc committee under sub-section (6) of section 10;`
  line
  line `(h) the powers and functions to be exercised and discharged by the Director of the Institute under`
  line `sub-section (3) of section 11;`
  line
  line `(i) the designations and grades of other officers and employees under sub-section (4) of section`
  line 11;
  line
  line `(j) the salaries and allowances and other conditions of services of the Director, Deputy Director`
  line `(Undergraduate), Deputy Director (Postgraduate) and Deputy Director (Pharmacy) and other officers`
  line `and employees of the Institute under sub-section (5) of section 11;`
  line
  line `(k) the examinations which may be held and the degrees, diplomas and other academic`
  line `distinctions and titles which may be granted by the Institute under clause (f) of section 13;`
  line
  line `(l) the professorships, readerships, lectureships and other posts which may be instituted and`
  line `persons who may be appointed to such professorships, readerships, lectureships and other posts under`
  line `clause (g) of section 13;`
  line
  line `(m) the fees and other charges which may be demanded and received by the Institute under`
  line `clause (j) of section 13;`
  line
  line `(n) the construction of quarters for the staff and allotment of such quarters under clause (k) of`
  line `section 13;`
  line
  line `(o) the manner in which, and the conditions subject to which, pension and provident funds may be`
  line `constituted for the benefit of officers, teachers and other employees of the Institute under`
  line `sub-section (1) of section 19;`
  line
  line `(p) any other matter for which provisions under this Act may be made by regulations.`
  line
  line `(2) Until the Institute is established under this Act, any regulation which may be made under`
  line `sub-section (1) may be made by the Central Government; and any regulation so made may be altered or`
  line `rescinded by the Institute in exercise of its powers under sub-section (1).`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (51456)
  sectionNo (29)
  orderNo 29
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51456&sectionno=29&orderno=29&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_29_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days, which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (51457)
  sectionNo (30)
  orderNo 30
  title `Power to remove difficulties.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51457&sectionno=30&orderno=30&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_30_content:
  string
  line `(1) If any difficulty arises is giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the purposes of this Act, as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made after the expiry of two years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (51458)
  sectionNo (31)
  orderNo 31
  title `Transitional provisions.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_51_0_00005_202016_1603175098070&sectionId=51458&sectionno=31&orderno=31&orgactid=AC_CEN_51_0_00005_202016_1603175098070
obj_root_law_sections_31_content:
  string
  line `Notwithstanding anything contained in this Act,--`
  line
  line `(a) the Board of Governors or any other governing system of the Anteceding Institutions`
  line `functioning as such immediately before the commencement of this Act shall continue to so function`
  line `until a Governing Body is constituted for the Institute under this Act, but on the constitution of a new`
  line `Governing Body under this Act, the members of the Board holding office before such constitution`
  line `shall, unless otherwise provided in this Act, cease to hold office;`
  line
  line `(b) the committees constituted in relation to the Anteceding Institutions before the`
  line `commencement of this Act shall be deemed to be constituted under this Act until new committees are`
  line `constituted for the Institute.`
obj_root_law_sections_31_footnotes:
  string
  line
