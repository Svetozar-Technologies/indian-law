obj_root_law_sections_1:
  sectionId (49419)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49419&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Muslim Women`
  line `(Protection of Rights on Marriage) Act, 2019.`
  line
  line `(2) It shall extend to the whole of India except the State of Jammu and Kashmir*.`
  line
  line `(3) It shall be deemed to have come into force on the 19th day of September, 2018.`
obj_root_law_sections_1_footnotes:
  string
  line `*. Vide Notification No. S.O. 3912 (E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (49420)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49420&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "electronic form" shall have the same meaning as assigned to it in clause (r) of sub-section (1)`
  line `of section 2 of the Information Technology Act, 2000 (21 of 2000);`
  line
  line `(b) "Magistrate" means a Judicial Magistrate of the first class exercising jurisdiction under the`
  line `Code of Criminal Procedure, 1973 (2 of 1974), in the area where the married Muslim woman resides;`
  line and
  line
  line `(c) "talaq" means talaq-e-biddat or any other similar form of talaq having the effect of`
  line `instantaneous and irrevocable divorce pronounced by a Muslim husband.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (49421)
  sectionNo (3)
  orderNo 3
  title `Talaq to be void and illegal.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49421&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_3_content:
  string
  line `Any pronouncement of talaq by a Muslim husband upon his wife, by words,`
  line `either spoken or written or in electronic form or in any other manner whatsoever, shall be void and illegal.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (49422)
  sectionNo (4)
  orderNo 4
  title `Punishment for pronouncing talaq.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49422&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_4_content:
  string
  line `Any Muslim husband who pronounces talaq referred to in`
  line `section 3 upon his wife shall be punished with imprisonment for a term which may extend to three years,`
  line `and shall also be liable to fine.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (49423)
  sectionNo (5)
  orderNo 5
  title `Subsistence allowance.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49423&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_5_content:
  string
  line `Without prejudice to the generality of the provisions contained in any`
  line `other law for the time being in force, a married Muslim woman upon whom talaq is pronounced shall be`
  line `entitled to receive from her husband such amount of subsistence allowance, for her and dependent`
  line `children, as may be determined by the Magistrate.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (49424)
  sectionNo (6)
  orderNo 6
  title `Custody of minor children.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49424&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_6_content:
  string
  line `Notwithstanding anything contained in any other law for the time`
  line `being in force, a married Muslim woman shall be entitled to custody of her minor children in the event of`
  line `pronouncement of talaq by her husband, in such manner as may be determined by the Magistrate.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (49425)
  sectionNo (7)
  orderNo 7
  title `Offence to be cognizable, compoundable, etc.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49425&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_7_content:
  string
  line `Notwithstanding anything contained in the Code`
  line `of Criminal Procedure, 1973 (2 of 1974),--`
  line
  line `(a) an offence punishable under this Act shall be cognizable, if information relating to the`
  line `commission of the offence is given to an officer in charge of a police station by the married Muslim`
  line `woman upon whom talaq is pronounced or any person related to her by blood or marriage;`
  line
  line `(b) an offence punishable under this Act shall be compoundable, at the instance of the married`
  line `Muslim woman upon whom talaq is pronounced or any person related to her by blood or marriage; is pronounced with the permission of the Magistrate, on such terms and conditions as he may determine;`
  line
  line `(c) no person accused of an offence punishable under this Act shall be released on bail unless the`
  line `Magistrate, on an application filed by the accused and after hearing the married Muslim woman upon`
  line `whom talaq is pronounced or any person related to her by blood or marriage; is pronounced, is satisfied that there are reasonable grounds for granting bail to such`
  line person.
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (49426)
  sectionNo (8)
  orderNo 8
  title `Repeal and savings.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00069_201920_1565334896444&sectionId=49426&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00069_201920_1565334896444
obj_root_law_sections_8_content:
  string
  line `(1) The Muslim Women (Protection of Rights on Marriage) Second`
  line `Ordinance, 2019 (Ord. 4 of 2019) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the Muslim Women`
  line `(Protection of Rights on Marriage) Second Ordinance, 2019 (Ord. 4 of 2019), shall be deemed to have`
  line `been done or taken under the provisions of this Act.`
obj_root_law_sections_8_footnotes:
  string
  line
