  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00007_195523_1517807318520&sectionId=35238&sectionno=54&orderno=66&orgactid=AC_CEN_2_11_00007_195523_1517807318520
obj_root_law_sections_55:
  sectionId (35239)
  sectionNo (55)
  orderNo 67
  title `No proceeding to lie in India against Imperial Bank after appointed day.`
  content obj_root_law_sections_55_content
  footnotes `1. Ins. by s. 6, ibid. (w.e.f. 1-4-1957).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00007_195523_1517807318520&sectionId=35239&sectionno=55&orderno=67&orgactid=AC_CEN_2_11_00007_195523_1517807318520
obj_root_law_sections_55_content:
  string
  line `^1[55. No proceeding to lie in India against Imperial Bank after appointed day.-- On and from the`
  line `appointed day, no person shall make any claim or demand or take any proceeding in India against the`
  line `Imperial Bank or a director, officer or other employee thereof in his capacity as such director, officer or`
  line `employee except in so far as may be necessary for enforcing the provisions of this Act or except in so far`
  line `as it relates to any offence committed by any such director, officer or employee.]`
obj_root_law_sections_56:
  sectionId (35229)
  sectionNo (56)
  orderNo 68
  title `References to the Imperial Bank, the Bank of Bengal, etc., in other laws.`
  content obj_root_law_sections_56_content
  footnotes `1. Ins. by s. 6, ibid. (w.e.f. 1-4-1957).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00007_195523_1517807318520&sectionId=35229&sectionno=56&orderno=68&orgactid=AC_CEN_2_11_00007_195523_1517807318520
obj_root_law_sections_56_content:
  string
  line `^1[56. References to the Imperial Bank, the Bank of Bengal, etc., in other laws.-- On and from the`
  line `appointed day, any reference to the Imperial Bank or to the Bank of Bengal, the Bank of Madras or the`
  line `Bank of Bombay in any law (other than this Act or the Imperial Bank of India Act, 1920 (47 of 1920) or`
  line `in any contract or other instrument shall, except as otherwise provided in any general or special order`
  line `made by the Central Government, be deemed to be a reference to the State Bank.]`
obj_root_law_sections_57:
  sectionId (35230)
  sectionNo (57)
  orderNo 69
  title `Dissolution of Imperial Bank, etc.`
  content obj_root_law_sections_57_content
  footnotes `1. Ins. by s. 6, ibid. (w.e.f. 1-4-1957).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00007_195523_1517807318520&sectionId=35230&sectionno=57&orderno=69&orgactid=AC_CEN_2_11_00007_195523_1517807318520
obj_root_law_sections_57_content:
  string
  line `^1[57. Dissolution of Imperial Bank, etc.-- (1) On such day as the Central Government may, by`
  line `notification in the Official Gazette, specify in this behalf the Imperial Bank shall stand dissolved, and the`
  line `Imperial Bank of India Act, 1920 (47 of 1920), shall stand repealed.`
  line
  line `(2) On the day specified in the notification under sub-section (1), the State Bank shall pay to the`
  line `Reserve Bank a sum of ten lakhs of rupees.`
  line
  line `(3) If, on the day specified in the notification under sub-section (1), the Imperial Bank has in its`
  line `possession or custody any assets created on or after the appointed day, such assets shall be disposed of in`
  line `accordance with directions issued by the Central Government in this behalf.]`
