obj_root_law_sections_1:
  sectionId (23007)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23007&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Babasaheb Bhimrao Ambedkar`
  line `University Act, 1994.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint`
obj_root_law_sections_1_footnotes:
  string
  line `1. 10th January 1996, vide notification No. S.O. 18(E), dated 5th January, 1996, see Gazette of India, Extraordinary, Part II, sec.`
  line `3(ii).`
obj_root_law_sections_2:
  sectionId (23008)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23008&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "Board of Management" means the Board of Management of the University;`
  line
  line `(d) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(e) "Chancellor", "Vice-Chancellor" and "Pro-Vice-Chancellor" mean, respectively, the`
  line `Chancellor, Vice-Chancellor and Pro-Vice-Chancellor of the University;`
  line
  line `(f) "College" means a College maintained by the University;`
  line
  line `(g) "Department" means a Department of Studies; and includes a Centre of Studies;`
  line
  line `(h) "distance education system" means the system of imparting education through any means of`
  line `communication, such as broadcasting, telecasting, correspondence courses, seminars, contact`
  line
  line `(i) "employee" means any person appointed by the University; and includes teachers and other`
  line `staff of the University;`
  line
  line `(j) "Finance Committee" means the Finance Committee of the University;`
  line
  line `(k) "Hall" means a unit of residence or of corporate life for the students of the University, or of a`
  line `College or of an Institution, maintained by the University;`
  line
  line `(l) "Institution" means an academic institution, not being a College, maintained by the University;`
  line
  line `(m) "Planning Board" means the Planning Board of the University;`
  line
  line `(n) "Principal" means the Head of a College or an Institution maintained by the University, and`
  line `includes, where there is no Principal, the person for the time being duly appointed to act as Principal,`
  line `and, in the absence of the Principal or the acting Principal, a Vice-Principal duly appointed as such;`
  line
  line `(o) "recognised institution" means an institution of higher learning recognised by the University;`
  line
  line `(p) "recognised teachers" means such persons as may be recognised by the University for the`
  line `purpose of imparting instructions in a College or an Institution maintained by the University;`
  line
  line `(q) "Regulations" means the Regulations made by any authority of the University under this Act`
  line `for the time being in force;`
  line
  line `(r) "School" means a School of Studies of the University;`
  line
  line `(s) "Statutes" and "Ordinances" mean, respectively, the Statutes and Ordinances of the University`
  line `for the time being in force;`
  line
  line `(t) "teachers of the University" means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instruction or conducting research in the University or in any College`
  line `or Institution maintained by the University and are designated as teachers by the Ordinances;`
  line
  line `(u) "University" means the Babasaheb Bhimrao Ambedkar University established under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (23009)
  sectionNo (3)
  orderNo 3
  title `The University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23009&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established a University by the name of "Babasaheb Bhimrao`
  line `Ambedkar University".`
  line
  line `(2) The headquarters of the University shall be at Lucknow and it may also establish campuses at`
  line `such other places within its jurisdiction as it may deem fit.`
  line
  line `(3) The first Vice-Chancellor and the first members of the Board of Management, or the Academic`
  line `Council or the Planning Board and all persons who may hereafter become such officers or members, so`
  line `long as they continue to hold such office or membership, are hereby constituted a body corporate by the`
  line `name of "Babasaheb Bhimrao Ambedkar University".`
  line
  line `(4) The University shall have perpetual succession and a common seal and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (23010)
  sectionNo (4)
  orderNo 4
  title `Objects of the University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23010&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_4_content:
  string
  line `The objects of the University shall be to promote advanced`
  line `knowledge by providing instructional and research facilities in such branches of learning as it may deem`
  line `fit, to make provisions for integrated courses in Science and key and frontier areas of Technology and`
  line `other allied disciplines in the educational programmes of the University; to offer appropriate courses`
  line `relevant for the development of socially and economically depressed sections of the people, including`
  line `agricultural technology and rural crafts; to promote the study of the principles for which Babasaheb`
  line `Bhimrao Ambedkar worked during his life time, namely, national integration, social justice and`
  line `democratic way of life, and also study of the Constitutions of the world to take appropriate measures for`
  line `promoting innovations in teaching-learning processes in inter-disciplinary studies and research and pay`
  line `special attention to the promotion of educational and economic interests and welfare of the people in`
  line `general and of members belonging to the Scheduled Castes and the Scheduled Tribes in particular by`
  line `providing adequate percentage of seats for the Scheduled Castes and the Scheduled Tribes and the`
  line `University shall, in organising its activities, have due regard to the objects specified in the First Schedule.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (23011)
  sectionNo (5)
  orderNo 5
  title `Powers of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23011&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_5_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provision for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing on, persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(iii) to organise and to undertake extra-mural studies, training and extension services;`
  line
  line `(iv) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(v) to provide facilities through the distance education system to such persons as it may`
  line determine;
  line
  line `(vi) to institute Principalships, Professorships, Readerships, Lecturerships and other teaching or`
  line `academic positions, required by the University and to appoint persons to such Principalships,`
  line `Professorships, Readerships, Lecturerships or other teaching on academic positions;`
  line
  line `(vii) to recognise an institution of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(viii) to recognise persons for imparting instructions in any College or Institution maintained by`
  line `the University;`
  line
  line `(ix) to appoint persons working in any other University or organisation as teacher of the`
  line `University for a specified period;`
  line
  line `(x) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(xi) to co-operate or collaborate or associate with any other University or authority or institution`
  line `of higher learning in such manner and for such purposes as the University may determine;`
  line
  line `(xii) to establish such campuses, special centres, specialised laboratories or other units for`
  line `research and instruction as are, in the opinion of the University, necessary for the furtherance of its`
  line objects;
  line
  line `(xiii) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xiv) to establish and maintain Colleges, Institutions and Halls;`
  line
  line `(xv) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions, industrial or other organisations, as the University may deem`
  line necessary;
  line
  line `(xvi) to organise and conduct refresher courses, orientation courses, workshops, seminars and`
  line `other programmes for teachers, evaluators and other academic staff;`
  line
  line `(xvii) to make special arrangements in respect of the residence discipline and teaching of women`
  line `students as the University may consider desirable;`
  line
  line `(xviii) to appoint on contract or otherwise visiting Professors, Emeritus Professors, Consultants,`
  line `Scholars and such other persons who may contribute to the advancement of the objects of the`
  line University;
  line
  line `(xix) to confer autonomous status on a College or an Institution or a Department, as the case may`
  line `be, in accordance with the Statutes;`
  line
  line `(xx) to determine standards of admission to the University which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xxi) to fix quota for students belonging to the Scheduled Castes and the Scheduled Tribes for`
  line `admission purposes;`
  line
  line `(xxii) to demand and receive payment of fees and other charges;`
  line
  line `(xxiii) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xxiv) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xxv) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxvi) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(xxvii) to receive benefactions, donations and gifts and to acquire, hold, mange and dispose of any`
  line `property, movable or immovable including trust and endowment properties for the purposes of the`
  line University;
  line
  line `(xxviii) to borrow, with the prior approval of the Central Government, on the security of the`
  line `property of the University, money for the purposes of the University;`
  line
  line `(xxix) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (23012)
  sectionNo (6)
  orderNo 6
  title Jurisdiction.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23012&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_6_content:
  string
  line `The jurisdiction of the University shall extend to the whole of the State of Uttar`
  line Pradesh.
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (23013)
  sectionNo (7)
  orderNo 7
  title `University open to all classes, castes and creed.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23013&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_7_content:
  string
  line `The University shall be open to all persons of`
  line `either sex and of whatever caste, creed, race, class, place of domicile and it shall not be lawful for the`
  line `University to adopt or impose on any person, any test whatsoever of religious belief or profession in order`
  line `to entitle him to be appointed as a teacher of the University or to hold any other office therein or be`
  line `admitted as a student in the University or to graduate thereat or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for the employment or promotion of educational interests of women, physically handicapped`
  line `or of persons belonging to the weaker sections of the society and, in particular, of the Scheduled Castes`
  line `and the Scheduled Tribes.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (23014)
  sectionNo (8)
  orderNo 8
  title `Residence of students.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23014&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_8_content:
  string
  line `Every student of the University (other than a student who pursues a`
  line `course of study by distance education system) shall normally reside in a Hall or hostel or under such`
  line `conditions as may be prescribed by the Ordinances.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (23015)
  sectionNo (9)
  orderNo 9
  title `The Visitor.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23015&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_9_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University, including Colleges and Institutions managed by it, and to submit a report thereon; and`
  line `upon receipt of that report, the Visitor may, after obtaining the views of the Board of Management`
  line `thereon through the Vice-Chancellor, take such action and issue such directions as he considers necessary`
  line `in respect of any of the matters dealt with in the report and the University shall be bound to comply with`
  line `such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection to be made by such person or persons as he`
  line `may direct of the University, its buildings, laboratories and equipment, and of any College or Institution`
  line `maintained by the University and also of the examinations, teaching and other work conducted or done by`
  line `the University and to cause an inquiry to be made in like manner in respect of any matter connected with`
  line `the administration or finances of the University, Colleges or Institutions.`
  line
  line `(4) The Visitor shall, in every matter referred to in sub-section (2), give notice of his intention to`
  line `cause an inspection or inquiry to be made to the University and the University shall have the right to`
  line `make such representations to the Visitor, as it may consider necessary.`
  line
  line `(5) After considering the representations, if any, made by the University, the Visitor may cause to be`
  line `made such inspection or inquiry as is referred to in sub-section (3).`
  line
  line `(6) Where any inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative, who shall have the right to be present and be heard at such`
  line `inspection or inquiry.`
  line
  line `(7) The Visitor may, if the inspection or inquiry is made in respect of the University or any College or`
  line `Institution maintained by it, address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry together with such views and advice with regard to the action to be taken thereon, as the Visitor`
  line `may be pleased to offer, and on receipt of address made by the Visitor, the Vice-Chancellor shall`
  line `communicate to the Board of Management the views of the Visitor with such advice as the Visitor may`
  line `offer upon the action to be taken thereon.`
  line
  line `(8) The Board of Management shall communicate, through the Vice-Chancellor, to the Visitor such`
  line `action, if any, as it proposes to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(9) Where, the Board of Management does not, within a reasonable time, take action to the`
  line `satisfaction of the Visitor, the Visitor may, after considering any explanation furnished or representation`
  line `made by the Board of Management, issue such directions as he may think fit and the Board of`
  line `Management shall comply with such directions.`
  line
  line `(10) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annul any proceeding of the University which is not in conformity with the Act, the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the Registrar to show cause why such`
  line `an order should not be made, and, if any cause is shown within a reasonable time, he shall consider the`
  line same.
  line
  line `(11) The Visitor shall have such other powers as may be prescribed by the Statues.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (23016)
  sectionNo (10)
  orderNo 10
  title `Officers of the University.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23016&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_10_content:
  string
  line `The following shall be the officers of the University:--`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Pro-Vice-Chancellors;`
  line
  line `(4) the Deans of Schools;`
  line
  line `(5) the Registrar;`
  line
  line `(6) the Finance Officer; and`
  line
  line `(7) such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (23017)
  sectionNo (11)
  orderNo 11
  title `The Chancellor.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23017&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_11_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the head of the University.`
  line
  line `(3) The Chancellor shall, if present, preside at the convocation of the University held for conferring`
  line `degrees, and may be delegated such powers as may be necessary.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (23018)
  sectionNo (12)
  orderNo 12
  title `The Vice-Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23018&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_12_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic head of the University and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been taken, it`
  line `may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to appeal against such action to the`
  line `Board of Management within three months from the date on which decision on such action is`
  line `communicated to him and thereupon the Board of Management may confirm, modify or reverse the action`
  line `taken by the Vice-Chancellor.`
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the University is`
  line `beyond the powers of the authority conferred by the provisions of this Act, the Statutes or the Ordinances`
  line `or that any decision taken is not in the interest of the University, may ask the authority concerned to`
  line `review its decision within sixty days of such decision and if the authority refuses to review the decision`
  line `either in whole or in part or no decision is taken by it within the said period of sixty days, the matter shall`
  line `be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (23019)
  sectionNo (13)
  orderNo 13
  title `The Pro-Vice-Chancellors.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23019&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_13_content:
  string
  line `One or more Pro-Vice-Chancellors shall be appointed in such`
  line `manner and shall exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (23020)
  sectionNo (14)
  orderNo 14
  title `Deans of Schools.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23020&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_14_content:
  string
  line `Every Dean of a School shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (23021)
  sectionNo (15)
  orderNo 15
  title `The Registrar.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23021&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_15_content:
  string
  line `(1) The Registrar shall be appointed in such manner as may be prescribed by the`
  line Statutes.
  line
  line `(2) The Registrar shall have the power to enter into agreement, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such powers and perform such duties as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (23022)
  sectionNo (16)
  orderNo 16
  title `The Finance Officer.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23022&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_16_content:
  string
  line `The Finance Officer shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (23023)
  sectionNo (17)
  orderNo 17
  title `Other officers.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23023&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_17_content:
  string
  line `The manner of appointment and powers and duties of the other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (23024)
  sectionNo (18)
  orderNo 18
  title `Authorities of the University.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23024&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_18_content:
  string
  line `The following shall be the authorities of the University,`
  line `namely:--`
  line
  line `(1) the Board of Management;`
  line
  line `(2) the Academic Council;`
  line
  line `(3) the Planning Board;`
  line
  line `(4) the Boards of Studies;`
  line
  line `(5) the Finance Committee; and`
  line
  line `(6) such other authorities as may be declared by the Statutes to be the authorities of the`
  line University.
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (23025)
  sectionNo (19)
  orderNo 19
  title `The Board of Management.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23025&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_19_content:
  string
  line `(1) The Board of Management shall be the principal executive`
  line `body of the University.`
  line
  line `(2) The constitution of the Board of Management, the term of office of its members and its powers`
  line `and functions shall be prescribed by the Statutes:`
  line
  line `Provided that the Board of Management shall also have representatives of the House of the People`
  line `and the Council of States, the Government of India, the University Grants Commission and the teaching`
  line community.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (23026)
  sectionNo (20)
  orderNo 20
  title `The Academic Council.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23026&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_20_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and the Ordinances, co-ordinate`
  line `and exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes:`
  line
  line `Provided that representation shall be given to students also.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (23027)
  sectionNo (21)
  orderNo 21
  title `The Planning Board.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23027&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_21_content:
  string
  line `(1) The Planning Board shall be the principal planning body of the`
  line University.
  line
  line `(2) The constitution of the Planning Board, term of office of its members and its powers and functions`
  line `shall be prescribed by the Statutes:`
  line
  line `Provided that representation shall be given to non-teaching staff.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (23028)
  sectionNo (22)
  orderNo 22
  title `The Boards of Schools.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23028&sectionno=22&orderno=22&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_22_content:
  string
  line `The constitution, powers and functions of the Boards of Schools shall`
  line `be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (23029)
  sectionNo (23)
  orderNo 23
  title `The Finance Committee.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23029&sectionno=23&orderno=23&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_23_content:
  string
  line `The constitution, powers and functions of the Finance Committee`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (23030)
  sectionNo (24)
  orderNo 24
  title `Other authorities of the University.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23030&sectionno=24&orderno=24&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_24_content:
  string
  line `The constitution, powers and functions of other`
  line `authorities, as may be declared by the Statutes to be the authorities of the University, shall be prescribed`
  line `by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (23031)
  sectionNo (25)
  orderNo 25
  title `Power to make Statutes.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23031&sectionno=25&orderno=25&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_25_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all`
  line `or any of the following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of the authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the election and continuance in office of the members of the said authorities and bodies, the`
  line `filling up of vacancies of members, and all other matters relating to those authorities and other bodies`
  line `for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers, academic staff and other employees of the University, their`
  line `emoluments and other conditions of service;`
  line
  line `(e) the appointment of teachers, academic staff working in any other University or organisation`
  line `for a specific period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provision for pension, insurance and`
  line `provident fund, the manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing the seniority of service of the employees or students and the`
  line University;
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Board of Management by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(j) the conferment of autonomous status on a College or an Institution or a Department;`
  line
  line `(k) the establishment and abolition of Schools, Departments, Centres, Halls, Colleges and`
  line Institutions;
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(n) the institution of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(o) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(p) the maintenance of the discipline among the employees and students;`
  line
  line `(q) all other matters which by this Act are to be or may be provided for by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (23032)
  sectionNo (26)
  orderNo 26
  title `Statutes how to be made.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23032&sectionno=26&orderno=26&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_26_content:
  string
  line `(1) The first Statutes are those set out in the Second Schedule.`
  line
  line `(2) The Board of Management may, from time to time, make new or additional Statutes or may`
  line `amend or repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Board of Management shall not make, amend or repeal any Statutes affecting the`
  line `status, powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Board of Management.`
  line
  line `(3) Every new Statutes or addition to the Statutes or any amendment or repeal of a Statute shall`
  line `require the assent of the Visitor who may assent thereto or withhold assent or remit to the Board of`
  line `Management for reconsideration.`
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor, in exceptional`
  line `circumstances, may direct the University to make provisions in the Statutes in respect of any matter`
  line `specified by him and if the Board of Management is unable to implement such direction within sixty days`
  line `of its receipt, the Visitor may, after considering the reasons, if any, communicated by the Board of`
  line `Management for its inability to comply with such direction, make or amend the Statutes suitably.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (23033)
  sectionNo (27)
  orderNo 27
  title `Power to make Ordinances.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23033&sectionno=27&orderno=27&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_27_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(f) the conditions for award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(g) the conduct of examinations, including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing of special courses of studies for them;`
  line
  line `(j) the appointments and emoluments of employees other than those for whom provision has been`
  line `made in the Statutes;`
  line
  line `(k) the establishment of Centres of Studies, Boards of Studies, Special Centres, Specialised`
  line `Laboratories and other Committees;`
  line
  line `(l) the manner of co-operation and collaboration with other Universities and authorities including`
  line `learned bodies or associations;`
  line
  line `(m) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(n) such other terms and conditions of service of teachers and other academic staff as are not`
  line `prescribed by the Statutes;`
  line
  line `(o) the management of Colleges and Institutions established by the University;`
  line
  line `(p) the setting up of a machinery for redressal of grievances of employees; and`
  line
  line `(q) all other matters which by this Act or the Statutes may be provided for by the Ordinances.`
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Central Government and the Ordinances so made may be amended, repealed or added to at any time by`
  line `the Board of Management in the manner prescribed by the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (23034)
  sectionNo (28)
  orderNo 28
  title Regulations.
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23034&sectionno=28&orderno=28&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_28_content:
  string
  line `The authorities of the University may make Regulations, consistent with this Act,`
  line `the Statutes and the Ordinances for the conduct of their own business and that of the Committees, if any,`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances, in the manner`
  line `prescribed by the Statutes.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (23035)
  sectionNo (29)
  orderNo 29
  title `Annual report.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23035&sectionno=29&orderno=29&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_29_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Board of Management, which shall include, among other matters, the steps taken by the University`
  line `towards the fulfilment of its objects.`
  line
  line `(2) The annual report so prepared shall be submitted to the Visitor on or before such date as may be`
  line `prescribed by the Statutes.`
  line
  line `(3) A copy of the annual report as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (23036)
  sectionNo (30)
  orderNo 30
  title `Annual accounts.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23036&sectionno=30&orderno=30&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_30_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be`
  line `prepared under the directions of the Board of Management and shall, once at least every year and at`
  line `intervals of not more than fifteen months, be audited by the Comptroller and Auditor-General of India or`
  line `by such persons as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts together with the audit report thereon shall be submitted to the`
  line Visitor.
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Board of Management and the observations of the Board of Management, if any, shall be submitted to the`
  line Visitor.
  line
  line `(4) A copy of the annual accounts together with the audit report as submitted to the Visitor, shall also`
  line `be submitted to the Central Government, which shall, as soon as may be, cause the same to be laid before`
  line `both Houses of Parliament.`
  line
  line `(5) The audited annual accounts after having been laid before both Houses of Parliament shall be`
  line `published in the Gazette of India.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (23037)
  sectionNo (31)
  orderNo 31
  title `Conditions of service of employees.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23037&sectionno=31&orderno=31&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_31_content:
  string
  line `(1) Every employee of the University shall be appointed`
  line `under a written contract, which shall be lodged with the University and a copy of which shall be furnished`
  line `to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Board of Management, one member nominated by the employee concerned and an umpire appointed`
  line `by the Visitor.`
  line
  line `(3) The decision of the Tribunal in such matters shall be final.`
  line
  line `(4) Every request made by the employee under sub-section (2), shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration Act, 1940 (2 of 1940).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be prescribed by the Statutes.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (23038)
  sectionNo (32)
  orderNo 32
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23038&sectionno=32&orderno=32&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_32_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the case`
  line `may be, and who has been debarred from appearing at the examinations of the University for more than`
  line `one year, may, within ten days of the date of receipt of such orders or copy of such resolution by him,`
  line `appeal to the Board of Management and the Board of Management may confirm, modify or reverse the`
  line `decision of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-sections`
  line `(2), (3), (4) and (5) of section 31 shall, as far as may be, apply to a reference made under this sub-section.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (23039)
  sectionNo (33)
  orderNo 33
  title `Right to appeal.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23039&sectionno=33&orderno=33&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_33_content:
  string
  line `Every employee or student of the University or of a College or Institution`
  line `maintained by the University shall, notwithstanding anything contained in this Act, have a right to appeal`
  line `within such time as may be prescribed by the Statutes, to the Board of Management against the decision`
  line `of any officer or authority of the University or of the Principal of any College or Institution, as the case`
  line `may be, and thereupon the Board of Management may confirm, modify or reverse the decision appealed`
  line against.
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (23040)
  sectionNo (34)
  orderNo 34
  title `Provident and pension funds.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23040&sectionno=34&orderno=34&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_34_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such provident or pension fund or provide such insurance schemes as it may deem fit in such`
  line `manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or pension fund has been so constituted, the Central Government may`
  line `declare that the provision of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund, as if it`
  line `were a Government provident fund.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (23041)
  sectionNo (35)
  orderNo 35
  title `Disputes as to constitution of University authorities and bodies.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23041&sectionno=35&orderno=35&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_35_content:
  string
  line `If any question arises as to`
  line `whether any person has been duly elected or appointed as, or is entitled to be, a member of any authority`
  line `or other body of the University, the matter shall be referred to the Visitor whose decision thereon shall be`
  line final.
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (23042)
  sectionNo (36)
  orderNo 36
  title `Constitution of Committees.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23042&sectionno=36&orderno=36&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_36_content:
  string
  line `Where any authority of the University is given power by this Act`
  line `or the Statutes to appoint Committees, such Committees shall, save as otherwise provided, consist of the`
  line `members of the authority concerned and of such other person, if any, as the authority in each case may`
  line `think fit.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (23043)
  sectionNo (37)
  orderNo 37
  title `Filling of casual vacancies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23043&sectionno=37&orderno=37&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_37_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `members) of any authority or other body of the University shall be filled, as soon as may be, by the`
  line `person or body who appointed, elected or co-opted the member whose place has become vacant and the`
  line `person appointed, elected or co-opted to a casual vacancy shall be a member of such authority or body for`
  line `the residue of the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (23044)
  sectionNo (38)
  orderNo 38
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23044&sectionno=38&orderno=38&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_38_content:
  string
  line `No act or`
  line `proceedings of any authority or other body of the University shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (23045)
  sectionNo (39)
  orderNo 39
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23045&sectionno=39&orderno=39&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_39_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or other employee of the University for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (23046)
  sectionNo (40)
  orderNo 40
  title `Mode of proof of University record.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23046&sectionno=40&orderno=40&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_40_content:
  string
  line `A copy of any receipt application, notice, order,`
  line `proceeding, resolution of any authority or Committee of the University, or other documents in possession`
  line `of the University, or any entry in any register duly maintained by the University, if certified by the`
  line `Registrar, shall be received as prima facie evidence of such receipt, application, notice, order, proceeding,`
  line `resolution or documents or the existence of entry in the register and shall be admitted as evidence of the`
  line `matters and transactions therein where the original thereof would, if produced, have been admissible in`
  line `evidence, notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872), or in any`
  line `other law for the time being in force.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (23047)
  sectionNo (41)
  orderNo 41
  title `Power to remove difficulties.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23047&sectionno=41&orderno=41&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_41_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appear to it to be necessary of expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (23048)
  sectionNo (42)
  orderNo 42
  title `Transitional provisions.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23048&sectionno=42&orderno=42&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_42_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes,--`
  line
  line `(a) the first Vice-Chancellor shall be appointed by the Visitor and the said officer shall hold`
  line `office for a term of five years;`
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Visitor and each of`
  line `the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Board of Management shall consist of not more than eleven members who shall be`
  line `nominated by the Visitor and they shall hold office for a term of three years;`
  line
  line `(d) the first Academic Council and the first Planning Board shall be nominated by the Visitor for`
  line `a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment or nomination, as the case may be, by the Visitor, and the persons so appointed or`
  line `nominated shall hold office for so long as the officer or member in whose place he is appointed or`
  line `nominated would have held that office, if such vacancy had not occurred.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (23049)
  sectionNo (43)
  orderNo 43
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_000010_199458_1517807323674&sectionId=23049&sectionno=43&orderno=43&orgactid=AC_CEN_9_30_000010_199458_1517807323674
obj_root_law_sections_43_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.`
  line
  line `(3) The power to make Statutes, Ordinances or Regulations shall include the power to give`
  line `retrospective effect from a date not earlier than the date of commencement of this Act, to the Statutes,`
  line `Ordinances or Regulations or any of them but no retrospective effect shall be given to any Statute,`
  line `Ordinance or Regulation so as to prejudicially affect the interests of any person to whom such Statute,`
  line `Ordinance or Regulation may be applicable.`
obj_root_law_sections_43_footnotes:
  string
  line
