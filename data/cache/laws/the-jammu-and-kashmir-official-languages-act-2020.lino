obj_root_law_sections_1:
  sectionId (50402)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_34_00004_202023_1601447366243&sectionId=50402&sectionno=1&orderno=1&orgactid=AC_CEN_5_34_00004_202023_1601447366243
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Jammu and`
  line `Kashmir Official Languages Act, 2020.`
  line
  line `(2) It extends to the Union territory of Jammu and Kashmir.`
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by`
  line `notification in the Official Gazette, appoint:`
  line
  line `Provided that the Administrator may appoint different dates for different areas in the`
  line `Union territory.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 29th September, 2020, vide notification No. S.O. 3394(E), dated 29th September, 2020 see Gazette of India,`
  line `Extraordinary, Part II, sec. 3 (ii).`
obj_root_law_sections_2:
  sectionId (50403)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_34_00004_202023_1601447366243&sectionId=50403&sectionno=2&orderno=2&orgactid=AC_CEN_5_34_00004_202023_1601447366243
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Administrator" means the Lieutenant Governor of the Union territory of Jammu`
  line `and Kashmir appointed by the President under article 239 of the Constitution;`
  line
  line `(b) "Union territory" means the Union territory of Jammu and Kashmir.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (50404)
  sectionNo (3)
  orderNo 3
  title `Official languages of Union territory.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_34_00004_202023_1601447366243&sectionId=50404&sectionno=3&orderno=3&orgactid=AC_CEN_5_34_00004_202023_1601447366243
obj_root_law_sections_3_content:
  string
  line `With effect from such date as the`
  line `Administrator may, by notification in the Official Gazette, appoint in this behalf, the`
  line `Kashmiri, Dogri, Urdu, Hindi and English languages shall be the official languages to be`
  line `used for all or any of the official purposes of the Union territory:`
  line
  line `Provided that the English language may continue to be used, for those administrative and`
  line `legislative purposes, in the Union territory for which it was being used before the`
  line `commencement of this Act:`
  line
  line `Provided further that the business in the Legislative Assembly of the Union territory shall`
  line `be transacted in the official language or languages of the Union territory.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (50405)
  sectionNo (4)
  orderNo 4
  title `Promotion and development of regional languages.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_34_00004_202023_1601447366243&sectionId=50405&sectionno=4&orderno=4&orgactid=AC_CEN_5_34_00004_202023_1601447366243
obj_root_law_sections_4_content:
  string
  line `(1) The Administrator may, for`
  line `the promotion and development of regional languages of the Union territory, take necessary`
  line `steps to strengthen the existing institutional mechanisms such as the Academy of Art, Culture`
  line `and languages in the Union territory.`
  line
  line `(2) The institutional mechanisms referred to in sub-section (1) shall make special efforts`
  line `for the promotion and development of Gojri, Pahari and Punjabi languages.`
obj_root_law_sections_4_footnotes:
  string
  line
