obj_root_law_sections_14:
  sectionId (20889)
  sectionNo (14)
  orderNo 14
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_7_7_00006_200269_1517807324733&sectionId=20889&sectionno=14&orderno=14&orgactid=AC_CEN_7_7_00006_200269_1517807324733
obj_root_law_sections_14_content:
  string
  line `(1) No suit, prosecution or other legal proceeding`
  line `shall lie against any person for anything which is in good faith done or intended to be done in pursuance`
  line `of the provisions of this Act.`
  line
  line `(2) No suit or other legal proceeding shall lie against the Central Government for any damage caused`
  line `or likely to be caused for anything which is in good faith done or intended to be done in pursuance of the`
  line `provisions of this Act.`
obj_root_law_sections_14_footnotes:
  string
  line
