obj_root_law:
  object
  (str slug) (str the-immigration-and-foreigners-act-2025)
  (str handle) (str 21918)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Immigration and Foreigners Act, 2025`)
  (str actNumber) (str 13)
  (str enactmentDate) (str 2025-04-04)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/21918`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (undefined)
  (str actYear) (str 2025)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of Home`)
  (str longTitle) (str `An Act to confer upon the Central Government certain powers to provide for requirement of passports or other travel documents in respect of persons entering into and exiting from India and for regulating matters related to foreigners including requirement of visa and registration and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-09-2025)
  (str notification) (undefined)
