obj_root_law:
  slug the-immigration-and-foreigners-act-2025
  handle (21918)
  collectionHandle 123456789/1362
  title `The Immigration and Foreigners Act, 2025`
  actNumber (13)
  enactmentDate 2025-04-04
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/21918`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle undefined
  actYear (2025)
  ministry `Ministry of Home Affairs`
  department `Department of Home`
  longTitle `An Act to confer upon the Central Government certain powers to provide for requirement of passports or other travel documents in respect of persons entering into and exiting from India and for regulating matters related to foreigners including requirement of visa and registration and for matters connected therewith or incidental thereto.`
  enforcementDate 01-09-2025
  notification undefined
