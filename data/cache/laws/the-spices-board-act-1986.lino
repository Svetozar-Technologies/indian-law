obj_root_law_sections_1:
  sectionId (2486)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2486&sectionno=1&orderno=1&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Spices Board Act, 1986.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date ^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1 . 26th February, 1987, vide Notification No. S.O. 122(E), dated 26th February, 1987, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (2487)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2487&sectionno=2&orderno=2&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Board" means the Spices Board constituted under sub-section (1) of section 3;`
  line
  line `(b) "cardamom" means the fruit of cardamom plant and includes green cardamom, bleached`
  line `cardamom, bleachable white cardamom, sun-dried cardamom, cardamom seeds, powdered cardamom`
  line `and oil extracted from cardamom;`
  line
  line `(c) "cardamom plant" means ELETTARIA CARDAMOMUM MATON, AMMOMUM`
  line `SUBULATUM ROXB and any other plant which the Board may, by notification in the Official`
  line `Gazette, declare to be a cardamom plant for the purposes of this Act;`
  line
  line `(d) "certificate" means a certificate granted under section 12;`
  line
  line `(e) "dealer" means a dealer in spices;`
  line
  line `(f) "estate" means the area administered as one unit which contains land planted with cardamom`
  line plants;
  line
  line `(g) 'export" and "import" mean, respectively, taking out of or bringing into India by land, sea and`
  line air;
  line
  line `(h) "manufacturer" means a manufacturer of spices;`
  line
  line `(i) "member" means a member of the Board appointed under sub-section (3) of section 3;`
  line
  line `(j) "owner", in relation to any land planted with cardamom plants, includes--`
  line
  line `(i) any agent of the owner; and`
  line
  line `(ii) a mortgagee, lessee or other person in actual possession of the land;`
  line
  line `(k) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(l) "registered estate" means an estate in respect of which an owner is registered under`
  line `sub-section (1) of section 8 and includes any estate in respect of which an owner is required to be`
  line `registered under the provisions of that sub-section;`
  line
  line `(m) "registered owner" means an owner of a registered estate which has been or is registered or is`
  line `required to be registered under sub-section (1) of section 8; and`
  line
  line `(n) "spices" means the spices specified in the Schedule:`
  line
  line `Provided that the Central Government may, if satisfied that it is necessary or expedient in the`
  line `public interest so to do, by notification in the Official Gazette, add any other spice to the Schedule or`
  line `omit any spice therefrom.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (2488)
  sectionNo (3)
  orderNo 3
  title `Constitution and incorporation of the Board.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2488&sectionno=3&orderno=3&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_3_content:
  string
  line `(1) The Central Government shall, by`
  line `notification in the Official Gazette, constitute, for the purposes of this Act, a Board, to be called the`
  line `Spices Board.`
  line
  line `(2) The Board shall be a body corporate by the name aforesaid having perpetual succession and a`
  line `common seal with power, subject to the provisions of this Act, to contract and shall, by the said name, sue`
  line `and be sued.`
  line
  line `(3) The Board shall consist of such number of members, not exceeding thirty-two, as may be`
  line `prescribed, and unless the rules made in this behalf otherwise provide, the Board shall consist of the`
  line `following members, namely:--`
  line
  line `(a) a Chairman;`
  line
  line `(b) three Members of Parliament, of whom two shall be elected by the House of the People and`
  line `one by the Council of States;`
  line
  line `(c) three members to represent respectively the Ministries of the Central Government dealing`
  line with--
  line
  line `(i) Commerce;`
  line
  line `(ii) Agriculture; and`
  line
  line `(iii) Finance;`
  line
  line `(d) six members to represent the growers of spices;`
  line
  line `(e) eleven members to represent the exporters of spices;`
  line
  line `(f) three members to represent major spice producing States;`
  line
  line `(g) five members, one each to represent--`
  line
  line `(i) the Directorate of Cocoa, Arecanut and Spices Development, Calicut;`
  line
  line `(ii) the Indian Institute of Packaging, Bombay;`
  line
  line `(iii) the Central Food Technological and Research Institute, Mysore;`
  line
  line `(iv) the Regional Research Laboratory, Trivandrum; and`
  line
  line `(v) the Central Plantation Crops Research Institute, Kasargode.`
  line
  line `(4) The office of member of the Board shall not disqualify its holder for being chosen as, or for being,`
  line `a member of either House of Parliament.`
  line
  line `(5) The term of office of the members and other conditions of service of the members shall be such as`
  line `may be prescribed.`
  line
  line `(6) The Chairman shall, in addition to presiding over the meetings of the Board, exercise and`
  line `discharge such powers and duties of the Board as may be delegated to him by the Board and such other`
  line `powers and duties as may be prescribed.`
  line
  line `(7) The Board shall elect from among its members a Vice-Chairman who shall exercise such of the`
  line `powers and perform such of the functions of the Chairman as may be prescribed or as may be delegated to`
  line `him by the Chairman.`
  line
  line `(8) No act or proceeding of the Board shall be invalidated merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Board;`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Board;`
  line
  line `(c) any irregularity in the procedure of the Board not affecting the merits of the case.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (2489)
  sectionNo (4)
  orderNo 4
  title `Secretary and other officers.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2489&sectionno=4&orderno=4&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_4_content:
  string
  line `(1) The Board may appoint the Secretary and such other officers`
  line `and employees as it considers necessary for the efficient discharge of its functions under this Act.`
  line
  line `(2) The terms and conditions of service of the Secretary and other officers and employees of the`
  line `Board shall be such as may be determined by regulations.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (2490)
  sectionNo (5)
  orderNo 5
  title `Advisory Committees.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2490&sectionno=5&orderno=5&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_5_content:
  string
  line `(1) Subject to any rules made in this behalf, the Board may, from time to`
  line `time, constitute such committees as may be necessary for the efficient discharge of its functions.`
  line
  line `(2) Every committee constituted under sub-section (1) shall consist of such number of persons as the`
  line `Board may deem fit.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (2491)
  sectionNo (6)
  orderNo 6
  title `Transfer of assets and liabilities of the Cardamom Board and the Spices Export Promotion Council to the Board.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2491&sectionno=6&orderno=6&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_6_content:
  string
  line `(1) On and from the commencement of this Act,--`
  line
  line `(a) all properties and other assets vested in the Cardamom Board and the Spices Export`
  line `Promotion Council immediately before such commencement shall vest in the Board;`
  line
  line `(b) all debts, obligations and liabilities incurred, all contracts entered into and all matters and`
  line `things engaged to be done by, with, or for the Cardamom Board or the Spices Export Promotion`
  line `Council immediately before such commencement for or in connection with the purposes of the`
  line `Cardamom Board or the Spices Export Promotion Council shall be deemed to have been incurred,`
  line `entered into and engaged to be done by, with, or for the Board;`
  line
  line `(c) all sums of money due to the Cardamom Board or the Spices Export Promotion Council`
  line `immediately before such commencement shall be deemed to be due to the Board;`
  line
  line `(d) all suits and other legal proceedings instituted or which could have been instituted by or`
  line `against the Cardamom Board or the Spices Export Promotion Council immediately before such`
  line `commencement may be continued or instituted by or against the Board; and`
  line
  line `(e) every employee holding any office under the Cardamom Board or the Spices Export`
  line `Promotion Council immediately before such commencement shall on such commencement hold his`
  line `office or service under the Board with the same rights and privileges as to pension, gratuity and other`
  line `matters as would have been admissible to him if there had been no such vesting; and shall continue to`
  line `do so unless and until his employment under the Board is duly terminated or until his remuneration`
  line `and other conditions of service are duly altered by the Board.`
  line
  line `(2) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947) or in any`
  line `other law for the time being in force, the absorption of any employee by the Board in its regular service`
  line `under this section shall not entitle such employee to any compensation under that Act or other law and no`
  line `such claim shall be entertained by any court, tribunal or other authority.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (2492)
  sectionNo (7)
  orderNo 7
  title `Functions of the Board.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2492&sectionno=7&orderno=7&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_7_content:
  string
  line `(1) The Board may--`
  line
  line `(i) develop, promote and regulate export of spices;`
  line
  line `(ii) grant certificate for export of spices and register brokers therefor;`
  line
  line `(iii) undertake programmes and projects for promotion of export of spices;`
  line
  line `(iv) assist and encourage studies and research for improvement of processing, quality, techniques`
  line `of grading and packaging of spices;`
  line
  line `(v) strive towards stabilisation of prices of spices for export;`
  line
  line `(vi) evolve suitable quality standards and introduce certification of quality through "Quality`
  line `Marking" for spaces for export;`
  line
  line `(vii) control quality of spices for export;`
  line
  line `(viii) give licences, subject to such terms and conditions as may be prescribed, to the`
  line `manufacturers of spices for export;`
  line
  line `(ix) market any spice, if it considers necessary, in the interest of promotion of export;`
  line
  line `(x) provide warehousing facilities abroad for spices;`
  line
  line `(xi) collect statistics with regard to spices for compilation and publication;`
  line
  line `(xii) import, with the previous approval of the Central Government, any spice for sale; and`
  line
  line `(xiii) advise the Central Government on matters relating to import and export of spices.`
  line
  line `(2) The Board may also--`
  line
  line `(i) promote co-operative efforts among growers of cardamom;`
  line
  line `(ii) ensure remunerative returns to growers of cardamom;`
  line
  line `(iii) provide financial or other assistance for improved methods of cultivation and processing of`
  line `cardamom, for replanting cardamom and for extension of cardamom growing areas;`
  line
  line `(iv) regulate the sale of cardamom and stabilisation of prices of cardamom;`
  line
  line `(v) provide training in cardamom testing and fixing grade standards of cardamom;`
  line
  line `(vi) increase the consumption of cardamom and carry on propaganda for that purpose;`
  line
  line `(vii) register and licence brokers (including auctioneers) of cardamom and persons engaged in the`
  line `business of cardamom;`
  line
  line `(viii) improve the marketing of cardamom;`
  line
  line `(ix) collect statistics from growers, dealers and such other persons as may be prescribed on any`
  line `matter relating to the cardamom industry; publish statistics so collected or portions thereof or extracts`
  line therefrom;
  line
  line `(x) secure better working conditions and the provision and improvement of amenities and`
  line `incentives for workers; and`
  line
  line `(xi) undertake, assist or encourage scientific, technological and economic research.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (2493)
  sectionNo (8)
  orderNo 8
  title `Registration of owners of cardamom estates.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2493&sectionno=8&orderno=8&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_8_content:
  string
  line `(1) Every owner of land planted with cardamom`
  line `plants, whether such land is comprised in one estate or more than one estate, shall, before the expiration`
  line `of one month from the date on which he first became owner of such estate or estates, apply to the`
  line `registering officer appointed in this behalf by the State Government to be registered as an owner in`
  line `respect of each estate owned by him:`
  line
  line `Provided that the State Government may, for sufficient reasons, extend the time-limit for registration`
  line `by such period as it thinks fit.`
  line
  line `(2) Registration once made shall continue to be in force until it is cancelled by the registering officer.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (2494)
  sectionNo (9)
  orderNo 9
  title `Power of State Government to make rules.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2494&sectionno=9&orderno=9&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_9_content:
  string
  line `(1) The State Government may, by notification in`
  line `the Official Gazette, make rules to carry into effect the provisions of section 8.`
  line
  line `(2) Without prejudice to the generality of the foregoing power, such rules may prescribe the form of`
  line `the application for registration and for cancellation of registration, the fee payable on such applications,`
  line `the particulars to be included in such application, the procedure to be followed in granting and cancelling`
  line `registration, the registers to be kept by registering officers and the supply by registering officers of`
  line `information to the Board.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (2495)
  sectionNo (10)
  orderNo 10
  title `Returns to be made by registered owners.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2495&sectionno=10&orderno=10&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_10_content:
  string
  line `(1) A registered owner shall furnish returns to the`
  line `Board in such form, at such times and in such manner as may be prescribed.`
  line
  line `(2) The Board may authorise an officer to visit any estate at any time to verify the accuracy of any`
  line `return made under this section or to ascertain the productive capacity of the estate.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (2496)
  sectionNo (11)
  orderNo 11
  title `No person to export spices without certificate.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2496&sectionno=11&orderno=11&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_11_content:
  string
  line `Save as otherwise provided in this Act, no`
  line `person shall, after the commencement of this Act, commence or carry on the business of export of any`
  line `spice except under and in accordance with a certificate:`
  line
  line `Provided that a person carrying on the business of export of spices immediately before the`
  line `commencement of this Act, may continue to do so for a period of three months from such`
  line `commencement; and if he has made an application for such certificate within the said period of three`
  line `months till the disposal of such application.`
  line
  line `Explanation.--The reference in this section to the commencement of this Act shall be construed in`
  line `relation to any spice added to the Schedule by notification under the proviso to clause (n) of section 2 as`
  line `reference to the date with effect from which such spice is added to the Schedule.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (2497)
  sectionNo (12)
  orderNo 12
  title `Grant of certificate.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2497&sectionno=12&orderno=12&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_12_content:
  string
  line `(1) An application for grant of certificate shall be made to the Board in`
  line `such form and shall contain such particulars as may be prescribed and shall be accompanied by a receipt`
  line `evidencing the payment of the prescribed fee.`
  line
  line `(2) On receipt of such application, the Board shall--`
  line
  line `(a) if the application is not in the prescribed form or does not contain any of the prescribed`
  line `particulars, return the application to the applicant; or`
  line
  line `(b) if the application is in the prescribed form and contains the prescribed particulars, grant the`
  line `certificate subject to such terms and conditions as may be determined by regulations.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (2498)
  sectionNo (13)
  orderNo 13
  title `Cancellation, suspension, etc., of certificate.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2498&sectionno=13&orderno=13&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_13_content:
  string
  line `(1) The Board may cancel any certificate on any`
  line `one or more of the following grounds, namely:--`
  line
  line `(a) that the holder of the certificate has violated any of the terms and conditions of the certificate;`
  line and
  line
  line `(b) that in the opinion of the Central Government it is necessary in the interests of general public`
  line `to cancel the certificate.`
  line
  line `(2) Where the Board, for reasons to be recorded in writing, is satisfied that pending consideration of`
  line `the question of cancelling the certificate on any grounds mentioned in sub-section (1), it is necessary so to`
  line `do, the Board may, by order in writing, suspend the operation of the certificate for such period not`
  line `exceeding forty-five days as may be specified in the order and require the holder of the certificate to show`
  line `cause, within fifteen days from the date of receipt of such order, as to why the suspension of the`
  line `certificate should not be extended till the determination of the question as to whether the registration`
  line `should be cancelled.`
  line
  line `(3) No order of cancellation of registration under this section shall be made unless the person`
  line `concerned has been given a reasonable opportunity of being heard in respect of the grounds for such`
  line cancellation.
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (2499)
  sectionNo (14)
  orderNo 14
  title Appeal.
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2499&sectionno=14&orderno=14&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_14_content:
  string
  line `(1) Any person aggrieved by an order made under section 13 may prefer an appeal to`
  line `the Central Government within such period as may be prescribed.`
  line
  line `(2) No appeal shall be admitted if it is preferred after the expiry of the period prescribed therefor:`
  line
  line `Provided that an appeal may be admitted after the expiry of the period prescribed therefor if the`
  line `appellant satisfies the Central Government that he had sufficient cause for not preferring the appeal within`
  line `the prescribed period.`
  line
  line `(3) Every appeal made under this section shall be made in such form and shall be accompanied by a`
  line `copy of order appealed against and by such fees as may be prescribed.`
  line
  line `(4) The procedure for disposing of an appeal shall be such as may be prescribed:`
  line
  line `Provided that before disposing of an appeal, the appellant shall be given a reasonable opportunity of`
  line `being heard.`
  line
  line `(5) The Central Government may confirm, modify or reverse the order appealed against.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (2500)
  sectionNo (15)
  orderNo 15
  title `Power to permit export without certificate.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2500&sectionno=15&orderno=15&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_15_content:
  string
  line `The Central Government may, if satisfied that it`
  line `is necessary or expedient, so to do, in public interest, by notification in the Official Gazette and subject to`
  line `such conditions, if any, as may be specified therein, permit any body or other agency to commence or`
  line `carry on the business of export of spices without a certificate.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (2501)
  sectionNo (16)
  orderNo 16
  title `Power to control price and distribution of cardamom.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2501&sectionno=16&orderno=16&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_16_content:
  string
  line `(1) The Central Government may, by`
  line `order notified in the Official Gazette, fix in respect of cardamom of any description specified therein--`
  line
  line `(a) the maximum price or the minimum price, or the maximum and minimum prices, which may`
  line `be charged by a grower of cardamom or cardamom dealer, wholesale or retail, whether for the Indian`
  line `market or for export; and`
  line
  line `(b) the maximum quantity which may in one transaction be sold to any person.`
  line
  line `(2) Without prejudice to the generality of the powers conferred by sub-section (1), any order made`
  line `thereunder may provide--`
  line
  line `(a) for requiring persons engaged in the production, supply or distribution of, or trade and`
  line `commerce in, cardamom to maintain and produce for inspection such books, accounts and records`
  line `relating to their business and to furnish such information relating thereto as may be specified in the`
  line `order; and`
  line
  line `(b) for such other matters, including in particular the entering and search of premises, vehicles,`
  line `vessels and aircraft, and the seizure by a person authorised to make such search, of cardamom in`
  line `respect of which such person has reason to believe that a contravention of the order has been, is being`
  line `or is about to be, committed.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (2502)
  sectionNo (17)
  orderNo 17
  title `Power to prohibit or control import of cardamom.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2502&sectionno=17&orderno=17&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_17_content:
  string
  line `The Central Government may, by order`
  line `published in the Official Gazette, make provision for prohibiting, restricting or otherwise controlling the`
  line `import of cardamom, either generally or in specified classes of cases.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (2503)
  sectionNo (18)
  orderNo 18
  title `Power of the Central Government to issue directions.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2503&sectionno=18&orderno=18&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_18_content:
  string
  line `(1) Without prejudice to the foregoing`
  line `provisions of this Act, the Board shall, in the discharge of its functions and duties under this Act, be`
  line `bound by such directions on questions of policy as the Central Government may give in writing to it from`
  line `time to time:`
  line
  line `Provided that the Board shall, as far as practicable, be given an opportunity to express its views`
  line `before any direction is given under this sub-section.`
  line
  line `(2) The decision of the Central Government whether a question is one of policy or not shall be final.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (2504)
  sectionNo (19)
  orderNo 19
  title `Power of the Central Government to supersede the Board.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2504&sectionno=19&orderno=19&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_19_content:
  string
  line `(1) If at any time the Central`
  line `Government is of opinion--`
  line
  line `(a) that on account of grave emergency, the Board is unable to discharge the functions and duties`
  line `imposed on it by or under the provisions of this Act; or`
  line
  line `(b) that the Board has persistently made default in complying with any direction issued by the`
  line `Central Government under this Act or in the discharge of the functions and duties imposed on it by or`
  line `under the provisions of this Act and as a result of such default the financial position of the Board or`
  line `the administration of the Board has deteriorated; or`
  line
  line `(c) that circumstances exist which render it necessary in the public interest so to do,`
  line `the Central Government may, by notification in the Official Gazette, supersede the Board for such`
  line `period, not exceeding six months, as may be specified in the notification.`
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the Board,--`
  line
  line `(a) all the members shall, as from the date of supersession, vacate their offices as such;`
  line
  line `(b) all the powers, functions and duties which may, by or under the provisions of this Act, be`
  line `exercised or discharged by or on behalf of the Board, shall until the Board is reconstituted under`
  line `sub-section (3), be exercised and discharged by such person or persons as the Central Government`
  line `may direct; and`
  line
  line `(c) all property owned or controlled by the Board shall, until the Board is reconstituted under`
  line `sub-section (3), vest in the Central Government.`
  line
  line `(3) On the expiration of the period of supersession specified in the notification issued under`
  line `sub-section (1), the Central Government may reconstitute the Board by a fresh appointment and in such`
  line `case any person or persons who vacated their offices under clause (a) of sub-section (2), shall not be`
  line `deemed disqualified for appointment:`
  line
  line `Provided that the Central Government may, at any time, before the expiration of the period of`
  line `supersession, take action under this sub-section.`
  line
  line `(4) The Central Government shall cause a notification issued under sub-section (1) and a full report of`
  line `any action taken under this section and the circumstances leading to such action to be laid before each`
  line `House of Parliament at the earliest.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (2505)
  sectionNo (20)
  orderNo 20
  title `Grants and loans by the Central Government.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2505&sectionno=20&orderno=20&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_20_content:
  string
  line `The Central Government may, after due`
  line `appropriation made by Parliament by law, in this behalf, make to the Board grants and loans of such sums`
  line `of money as that Government may consider necessary.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (2506)
  sectionNo (21)
  orderNo 21
  title `Board Fund.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2506&sectionno=21&orderno=21&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_21_content:
  string
  line `(1) There shall be constituted a fund to be called the Spices Board Fund and there`
  line `shall be credited thereto--`
  line
  line `(a) any grants and loans made to the Board by the Central Government under section 20;`
  line
  line `(b) all fees levied and collected in respect of certificates granted under this Act; and`
  line
  line `(c) all sums received by the Board from such other sources as may be decided upon by the`
  line `Central Government.`
  line
  line `(2) The Fund shall be applied for meeting--`
  line
  line `(a) salary, allowances and other remuneration of the members, officers and other employees of`
  line `the Board;`
  line
  line `(b) expenses of the Board in the discharge of its functions under section 7; and`
  line
  line `(c) expenses on objects and for purposes authorised by this Act.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (2507)
  sectionNo (22)
  orderNo 22
  title Budget.
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2507&sectionno=22&orderno=22&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_22_content:
  string
  line `The Board shall prepare in such form and at such time each financial year, as may be`
  line `prescribed, its budget for the next financial year, showing the estimated receipts and expenditure of the`
  line `Board and forward the same to the Central Government.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (2508)
  sectionNo (23)
  orderNo 23
  title `Annual report.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2508&sectionno=23&orderno=23&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_23_content:
  string
  line `The Board shall prepare, in such form and at such time each financial year, as`
  line `may be prescribed, its annual report, giving a full account of its activities during the previous financial`
  line `year, and submit a copy thereof to the Central Government.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (2509)
  sectionNo (24)
  orderNo 24
  title `Accounts and audit.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2509&sectionno=24&orderno=24&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_24_content:
  string
  line `The accounts of the Board shall be maintained and audited in such manner`
  line `as may, in consultation with the Comptroller and Auditor-General of India, be prescribed and the Board`
  line `shall furnish to the Central Government before such date, as may be prescribed, its audited copy of`
  line `accounts together with the auditors report thereon.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (2510)
  sectionNo (25)
  orderNo 25
  title `Annual report and auditor’s report to be laid before Parliament.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2510&sectionno=25&orderno=25&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_25_content:
  string
  line `The Central Government`
  line `shall cause the annual report and auditor's report to be laid, as soon as may be after they are received,`
  line `before each House of Parliament.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (2511)
  sectionNo (26)
  orderNo 26
  title `Penalty for making false returns.`
  content obj_root_law_sections_26_content
  footnotes `1. Subs. by Act 18 of 2023, s. 2 and Schedule for certain words (w.e.f. 09-08-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2511&sectionno=26&orderno=26&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_26_content:
  string
  line `Any person who being required by or under this Act to`
  line `furnish any return fails to furnish such return or furnishes a return containing any particular which is false`
  line `and which he knows to be false or does not believe to be true shall be ^1[liable to penalty which may extend to fifty thousand rupees and for subsequent failure, penalty which may extend to one lakh rupees].`
obj_root_law_sections_27:
  sectionId (2512)
  sectionNo (27)
  orderNo 27
  title `Penalties for obstructing an officer or member of the Board in the discharge of his duties and for failure to produce books and records.`
  content obj_root_law_sections_27_content
  footnotes `1. Subs. by Act 18 of 2023, s. 2 and Schedule, for certain words (w.e.f. 09-08-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2512&sectionno=27&orderno=27&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_27_content:
  string
  line `Any person who--`
  line
  line `(a) obstructs any member authorised by the Chairman in writing or any officer or other employee`
  line `of the Board authorised by it in this behalf or any person authorised in this behalf by the Central`
  line `Government or by the Board, in the exercise of any power conferred, or in the discharge of any duty`
  line `imposed, on him by or under this Act; or`
  line
  line `(b) having control over or custody of any account book or other record, fails to produce such`
  line `book or record when required to do so by or under this Act,`
  line
  line `shall be ^1[liable to penalty which may extend to fifty thousand rupees and for subsequent contravention penalty which may extend to one lakh rupees].`
obj_root_law_sections_28:
  sectionId (2513)
  sectionNo (28)
  orderNo 28
  title Omitted.
  content `28. [Penalty for contravention of order relating to control of price, etc.]--Omitted by the Jan Vishwas (Amendment of Provisions) Act, 2023 (18 of 2023), s. 2 and Schedule (w.e.f. 9-8-2024).`
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2513&sectionno=28&orderno=28&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (2514)
  sectionNo (29)
  orderNo 29
  title `Penalties for contravention of section 11 or any order made under section 17.`
  content obj_root_law_sections_29_content
  footnotes `1. Subs. by Act 18 of 2023, s. 2 and Schedule for certain words (w.e.f. 09-08-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2514&sectionno=29&orderno=29&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_29_content:
  string
  line `If any person`
  line `contravenes the provisions of section 11 or any order made under section 17 he shall, without prejudice to`
  line `any confiscation or penalty to which he may be liable under the provisions of the Customs`
  line `Act, 1962 (52 of 1962), be ^1[liable to penalty which may extend to fifty thousand rupees and forsubsequent contravention penalty which may extend to one lakh rupees]`
  line .
obj_root_law_sections_30:
  sectionId (2515)
  sectionNo (30)
  orderNo 30
  title `Other penalties.`
  content obj_root_law_sections_30_content
  footnotes `1. Subs. by Act 18 of 2023, s. 2 and Schedule for certain words (w.e.f. 09-08-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2515&sectionno=30&orderno=30&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_30_content:
  string
  line `Whoever contravenes or attempts to contravene or abets the contravention of`
  line `the provisions of this Act or of any rules or regulations made thereunder other than the provisions, punishment for the contravention whereof has been provided for in sections 26, 27, 28 and 29, shall be`
  line `^1[liable to penalty which may extend to fifty thousand rupees and for subsequent contravention penalty which may extend to one lakh rupees].`
obj_root_law_sections_30_a:
  sectionId (92416)
  sectionNo 30A
  orderNo 31
  title `Adjudication of penalties.`
  content obj_root_law_sections_30_a_content
  footnotes `1. Ins. by Act 18 of 2023, s. 2 and Schedule, (w.e.f. 09-08-2024).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=92416&sectionno=30A&orderno=31&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_30_a_content:
  string
  line `^1[30A. Adjudication of penalties.--(1) For the purposes of adjudging the penalties under sections 26, 27, 29 and 30, the Secretary to the Board shall appoint an officer not below the rank of Director in the Board or any other officer authorised by the Central Government, as the case may be, to be an adjudicating officer for holding an inquiry and imposing penalty in the manner as may be prescribed, after`
  line `giving any person concerned a reasonable opportunity of being heard.`
  line
  line `(2) Whoever is aggrieved by any order of the adjudicating officer may prefer an appeal to the Secretary to the Board, within a period of sixty days from the date of receipt of such order in such form and manner as may be prescribed.`
  line
  line `(3) An appeal may be admitted after the expiry of the period of sixty days if the appellant satisfies the`
  line `Secretary to the Board that he had sufficient cause for not preferring the appeal within that period.`
  line
  line `(4) No appeal shall be disposed of unless the appellant has been given a reasonable opportunity of`
  line `being heard.`
  line
  line `(5) An appeal under sub-section (2) shall be disposed of within sixty days from the date of filing`
  line
  line `(6) The amount of penalty imposed under sub-section (1), if not paid, shall be recovered as an arrear`
  line `of land revenue.]`
obj_root_law_sections_31:
  sectionId (2516)
  sectionNo (31)
  orderNo 32
  title `Offences by companies.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2516&sectionno=31&orderno=32&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_31_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person who at the time the offence was committed was in charge of, and was responsible`
  line `to, the company for the conduct of the business of the company, as well as the company, shall be deemed`
  line `to be guilty of the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment provided in this Act, if he proves that the offence was committed without his knowledge or`
  line `that he had exercised all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be`
  line `guilty of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (2517)
  sectionNo (32)
  orderNo 33
  title `Provisions of Act 52 of 1962 to apply to export of spices and import of cardamom.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2517&sectionno=32&orderno=33&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_32_content:
  string
  line `(a) All`
  line `spices to which section 11 of this Act applies, and`
  line
  line `(b) the cardamom to which any order under section 17 of this Act applies,`
  line
  line `shall be deemed to be goods of which the import or export has been prohibited or restricted under`
  line `section 11 of the Customs Act, 1962 (52 of 1962), and all the provisions of that Act shall have effect`
  line accordingly.
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (2518)
  sectionNo (33)
  orderNo 34
  title `Previous sanction of the Central Government.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2518&sectionno=33&orderno=34&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_33_content:
  string
  line `No prosecution for any offence punishable`
  line `under this Act shall be instituted except with the previous sanction of the Central Government.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (2519)
  sectionNo (34)
  orderNo 35
  title Delegation.
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2519&sectionno=34&orderno=35&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_34_content:
  string
  line `The Board may, by general or special order in writing, delegate to the Chairman or`
  line `any other member or to any officer of the Board, subject to such conditions and limitations, if any, as may`
  line `be specified in the order, such of its powers and functions under this Act (except the power under section`
  line `39) as it may deem necessary.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (2520)
  sectionNo (35)
  orderNo 36
  title `Members, officers and employees of the Board to be public servants.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2520&sectionno=35&orderno=36&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_35_content:
  string
  line `All members, officers`
  line `and other employees of the Board shall be deemed, when acting or purporting to act in pursuance of any`
  line `of the provisions of this Act, to be public servants within the meaning of section 21 of the Indian Penal`
  line `Code (45 of 1860).`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (2521)
  sectionNo (36)
  orderNo 37
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2521&sectionno=36&orderno=37&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_36_content:
  string
  line `No prosecution or other legal proceeding shall lie`
  line `against the Government, or the Board or any committee appointed by it, or any member of the Board or`
  line `such committee, or any officer or employee of the Government or the Board or any other person`
  line `authorised by the Government or the Board, for anything which is in good faith done or intended to be`
  line `done under this Act or the rules or regulations made thereunder.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (2522)
  sectionNo (37)
  orderNo 38
  title `Power to enter.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2522&sectionno=37&orderno=38&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_37_content:
  string
  line `Subject to any rule made in this behalf, any person, generally or specially`
  line `authorised by the Board in this behalf, may, whenever it is necessary so to do, for any of the purposes of`
  line `this Act, at all reasonable times, enter upon any land or premises and make any inspection or inquiry or`
  line `do such other act or thing as may be prescribed:`
  line
  line `Provided that no such person shall enter any building or any enclosed courtyard or garden attached to`
  line `a dwelling-house (unless with the consent of the occupier thereof) without previously giving such`
  line `occupier at least twenty-four hours notice in writing of his intention to do so.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (2523)
  sectionNo (38)
  orderNo 39
  title `Power to make rules.`
  content obj_root_law_sections_38_content
  footnotes `1. Ins. by Act 18 of 2023, s. 2 and Schedule (w.e.f. 09-08-2024)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2523&sectionno=38&orderno=39&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_38_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the purposes of this Act.`
  line
  line `(2) Without prejudice to the generality of the foregoing power such rules may provide for all or any`
  line `of the following matters, namely:--`
  line
  line `(a) the number of members of the Board under sub-section (3) of section 3;`
  line
  line `(b) the term of office and other conditions of service of the members of the Board under`
  line `sub-section (5) of section 3;`
  line
  line `(c) the powers and duties of the Chairman under sub-section (6) of section 3;`
  line
  line `(d) the powers and functions of the Vice-Chairman under sub-section (7) of section 3;`
  line
  line `(e) the constitution of committees under section 5;`
  line
  line `(f) the terms and conditions for giving licences to manufacturers of spices for export under`
  line `clause (viii) of sub-section (1) of section 7;`
  line
  line `(g) the form and manner in which and the time at which the registered owner may furnish returns`
  line `to the Board under section 10;`
  line
  line `(h) the form of the application and the fees under sub-section (1) of section 12;`
  line
  line `(i) the period of limitation for appeal under sub-section (1) of section 14;`
  line
  line `(j) the form of appeal and the fees payable under sub-section (3) of section 14;`
  line
  line `(k) the procedure for disposal of appeal under sub-section (4) of section 14;`
  line
  line `(l) the form in which, and the time at which, the Board shall prepare its budget under section 22`
  line `and its annual report under section 23;`
  line
  line `(m) the manner in which the accounts of the Board shall be maintained and audited and the date`
  line `before which the audited copy of the accounts may be furnished to the Central Government under`
  line `section 24;`
  line
  line `^1[(ma) the manner of holding inquiry and imposing penalty under sub-section (1) of section 30A;`
  line
  line `(mb) the form and manner of preferring appeal under sub-section (2) of section 30A;]`
  line
  line `(n) the conditions and the restrictions with respect to the exercise of the power to enter under`
  line `section 37;`
  line
  line `(o) any other matter which is to be, or may be, prescribed or in respect of which provision is to`
  line `be, or may be, made by rules.`
obj_root_law_sections_39:
  sectionId (2524)
  sectionNo (39)
  orderNo 40
  title `Power to make regulations.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2524&sectionno=39&orderno=40&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_39_content:
  string
  line `(1) The Board may, with the previous approval of the Central`
  line `Government, by notification in the Official Gazette, make regulations consistent with this Act and the`
  line `rules generally to carry out the purposes of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the terms and conditions of service of the Secretary and other officers and employees of the`
  line `Board under sub-section (2) of section 4; and`
  line
  line `(b) the terms and conditions under which the certificate may be granted under sub-section (2) of`
  line `section 12.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (2525)
  sectionNo (40)
  orderNo 41
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2525&sectionno=40&orderno=41&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_40_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (2526)
  sectionNo (41)
  orderNo 42
  title `Power to remove difficulties.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2526&sectionno=41&orderno=42&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_41_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (2527)
  sectionNo (42)
  orderNo 43
  title `Repeal and savings.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00009_198610_1517807327250&sectionId=2527&sectionno=42&orderno=43&orgactid=AC_CEN_11_12_00009_198610_1517807327250
obj_root_law_sections_42_content:
  string
  line `(1) Sections 3 to 33 of the Cardamom Act, 1965 (42 of 1965) are hereby`
  line repealed.
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the provisions of the said`
  line `Act shall, in so far as such thing or action is not inconsistent with the provisions of this Act, be deemed to`
  line `have been done or taken under the provisions of this Act as if the said provisions were in force when such`
  line `thing was done or such action was taken and shall continue in force accordingly until superseded by`
  line `anything done or any action taken under this Act.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `मसाला बोर्ड अधिनियम, 1986`
