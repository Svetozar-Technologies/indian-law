obj_root_law_sections_1:
  sectionId (9621)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the High Courts (Seals) Act, 1950.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00004_195007_1517807318859&sectionId=9621&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00004_195007_1517807318859
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (9622)
  sectionNo (2)
  orderNo 2
  title `Seals of High Courts.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00004_195007_1517807318859&sectionId=9622&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00004_195007_1517807318859
obj_root_law_sections_2_content:
  string
  line `(1) Every High Court in a ^1`
  line `[State] shall have and use, as occasion may`
  line `arise, a seal bearing a device and impression of the Asoka capital within an exergue or label surrounding`
  line `the same, with the following inscriptions at convenient places, namely, “THE SEAL OF THE HIGH`
  line `COURT AT (or OF) ..............”, followed by the name of the seal of the High Court or the name of the`
  line `State, as the case may be, and “Satyameva Jayate” in Devanagari script.`
  line
  line `(2) Every Court of the Judicial Commissioner for a ^2`
  line `[Union territory] shall have and use, as occasion`
  line `may arise, a seal similar to the seal of a High Court in a ^3`
  line `* * * State, but with the first inscription reading`
  line `“THE SEAL OF THE JUDICIAL COMMISSIONER'S COURT FOR .......................” followed by the`
  line ^4
  line `[name of the Union territory].`
  line
  line `(3) The provisions of this shall supersede any provision contrary thereto or inconsistent therewith`
  line `contained in any Letters Patent, Order, direction or other law relating to the use of seals by High Courts.`
obj_root_law_sections_2_footnotes:
  string
  line `1. Subs. by the Adaptation of Laws (No. 3) Order, 1956, for "Part A State or Part B State".`
  line
  line `2. Subs., ibid., for "Part C State".`
  line
  line `3. The word and letter "Part A" omitted, ibid.`
  line
  line `4. Subs., ibid., for "name of the State".`
