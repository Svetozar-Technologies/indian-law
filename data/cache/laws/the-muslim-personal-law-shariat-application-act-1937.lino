  sectionId (29998)
  sectionNo (6)
  orderNo 6
  title Repeals.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00062_193726_1523351646990&sectionId=29998&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00062_193726_1523351646990
obj_root_law_sections_6_content:
  string
  line `^1[The undermentioned provisions] of the Acts and Regulations mentioned below shall`
  line `be repealed in so far as they are inconsistent with the provisions of this Act, namely:--`
  line
  line `(1) Section 26 of the Bombay Regulation IV of 1827;`
  line
  line `(2) Section 16 of the Madras Civil Courts Act, 1873 (3 of 1873);`
  line
  line `^2** * * *`
  line
  line `(4) Section 3 of the Oudh Laws Act, 1876 (18 of 1876);`
  line
  line `(5) Section 5 of the Punjab Laws Act, 1872 (4 of 1872);`
  line
  line `(6) Section 5 of the Central Provinces Laws Act, 1875 (20 of 1875); and`
  line
  line `(7) Section 4 of the Ajmere Laws Regulation, 1877 (3 of 1877).`
obj_root_law_sections_6_footnotes:
  string
  line `1. Subs. by Act 16 of 1943, s. 3, for "Provisions" (w.e.f. 7-4-1943).`
  line
  line `2. Entry (3) omitted by s. 3, ibid. (w.e.f. 7-4-1943).`
