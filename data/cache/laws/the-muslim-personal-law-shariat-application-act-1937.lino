obj_root_law_translations_hi:
  object
  (str title) (str `मुस्लिम स्वीय विधि (शरीयत) अधिनियम, 1937`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/2303/3/H1937-26.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T13:09:27.812Z`)
