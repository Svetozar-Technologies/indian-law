obj_root_law:
  object
  (str slug) (str the-lady-hardinge-medical-college-and-hospital-acquisition-and-miscellaneous-provisions-act-1977)
  (str handle) (str 1623)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Lady Hardinge Medical College and Hospital (Acquisition and Miscellaneous Provisions) Act, 1977`)
  (str actNumber) (str 34)
  (str enactmentDate) (str 1977-12-03)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1623`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `लेडी हार्डिंग आयुर्विज्ञान महाविद्यालय और अस्पताल (अर्जन) और प्रकीर्ण उपबंध अधिनियम,1977`)
  (str actYear) (str 1977)
  (str ministry) (str `Ministry of Health and Family Welfare`)
  (str department) (str `Department of Health and Family Welfare`)
  (str longTitle) (str `An Act to provide for the acquisition of the Lady Hardinge Medical College and Hospital and for the management of the Kalavati Saran Hospital, with a view to ensuring better facilities for higher medical education for women and medical facilities for women and children in the Union territory of Delhi and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-02-1978)
  (str notification) (str `1st February, 1978, vide notification No. S. O. 188(E), dated 12th January, 1978, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
