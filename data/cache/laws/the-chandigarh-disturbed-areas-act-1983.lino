obj_root_law_sections_1:
  sectionId (39302)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39302&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00048_198333_1517807325584
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Chandigarh Disturbed`
  line `Areas Act, 1983.`
  line
  line `(2) It extends to the whole of the Union territory of Chandigarh.`
  line
  line `(3) It shall be deemed to have come into force on the 7th day of October, 1983.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (39303)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39303&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00048_198333_1517807325584
obj_root_law_sections_2_content:
  string
  line `In this Act,—`
  line
  line `(a) "Administrator" means the Administrator of the Union territory of Chandigarh appointed`
  line `under article 239 of the Constitution;`
  line
  line `(b) "disturbed area" means the area which is for the time being declared by notification under`
  line `section 3 to be a disturbed area.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39304)
  sectionNo (3)
  orderNo 3
  title `Powers to declare areas to be disturbed areas.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39304&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00048_198333_1517807325584
obj_root_law_sections_3_content:
  string
  line `The Administrator may, by notification in the`
  line `Official Gazette, declare that the whole or any part of the Union territory of Chandigarh as may be`
  line `specified in the notification, is a disturbed area.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39305)
  sectionNo (4)
  orderNo 4
  title `Power to fire upon persons contravening certain orders.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39305&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00048_198333_1517807325584
obj_root_law_sections_4_content:
  string
  line `Any Magistrate or Police Officer not`
  line `below the rank of Sub-Inspector or Havildar in case of the Armed Branch of the Police may, if he is of`
  line `opinion that it is necessary so to do for the maintenance of public order, after giving such due warning, as`
  line `he may consider necessary, fire upon, or otherwise use force, even to the causing of death, against any`
  line `person who is acting in contravention of any law or order for the time being in force in the disturbed area,`
  line `prohibiting the assembly of five or more persons or the carrying of weapons or of things capable of being`
  line `used as weapons or of fire-arms, ammunition or explosive substances.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (39306)
  sectionNo (5)
  orderNo 5
  title `Powers to destroy arms dump, fortified positions, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39306&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00048_198333_1517807325584
obj_root_law_sections_5_content:
  string
  line `Any Magistrate or Police Officer not`
  line `below the rank of a Sub-Inspector may, if he is of opinion that it is necessary so to do, destroy any arms`
  line `dump, prepared or fortified position or shelter from which armed attacks are made or are likely to be`
  line `made or are attempted to be made or any structure used as training camp for armed volunteers or utilised`
  line `as a hide-out by armed gangs or absconders wanted for any offence.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (39307)
  sectionNo (6)
  orderNo 6
  title `Protection of persons acting under sections 4 and 5.`
  content obj_root_law_sections_6_content
  footnotes `1 Subs. by Act 15 of 1989, s. 2,for "the Administrator" (w.e.f. 18-5-1989).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39307&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00048_198333_1517807325584
obj_root_law_sections_6_content:
  string
  line `No suit, prosecution or other legal`
  line `proceedings shall be instituted except with the previous sanction of ^1`
  line `[the Central Government]against any`
  line `person in respect of anything done or purporting to be done in exercise of the powers conferred by`
  line `sections 4 and 5.`
obj_root_law_sections_7:
  sectionId (39308)
  sectionNo (7)
  orderNo 7
  title `Repeal and saving.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39308&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00048_198333_1517807325584
obj_root_law_sections_7_content:
  string
  line `(1) The Chandigarh Disturbed Areas Ordinance, 1983 (6 of 1983), is hereby`
  line repealed.
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_7_footnotes:
  string
  line
