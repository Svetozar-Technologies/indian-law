obj_root_law_sections_1:
  object
  (str sectionId) (str 39302)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title, extent and commencement.`)
  (str content) (str `(1) This Act may be called the Chandigarh Disturbed
Areas Act, 1983.

(2) It extends to the whole of the Union territory of Chandigarh.

(3) It shall be deemed to have come into force on the 7th day of October, 1983.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39302&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00048_198333_1517807325584)
obj_root_law_sections_2:
  object
  (str sectionId) (str 39303)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str Definitions.)
  (str content) (str `In this Act,—

(a) "Administrator" means the Administrator of the Union territory of Chandigarh appointed
under article 239 of the Constitution;

(b) "disturbed area" means the area which is for the time being declared by notification under
section 3 to be a disturbed area.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39303&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00048_198333_1517807325584)
obj_root_law_sections_3:
  object
  (str sectionId) (str 39304)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Powers to declare areas to be disturbed areas.`)
  (str content) (str `The Administrator may, by notification in the
Official Gazette, declare that the whole or any part of the Union territory of Chandigarh as may be
specified in the notification, is a disturbed area.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39304&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00048_198333_1517807325584)
obj_root_law_sections_4:
  object
  (str sectionId) (str 39305)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Power to fire upon persons contravening certain orders.`)
  (str content) (str `Any Magistrate or Police Officer not
below the rank of Sub-Inspector or Havildar in case of the Armed Branch of the Police may, if he is of
opinion that it is necessary so to do for the maintenance of public order, after giving such due warning, as
he may consider necessary, fire upon, or otherwise use force, even to the causing of death, against any
person who is acting in contravention of any law or order for the time being in force in the disturbed area,
prohibiting the assembly of five or more persons or the carrying of weapons or of things capable of being
used as weapons or of fire-arms, ammunition or explosive substances.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39305&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00048_198333_1517807325584)
obj_root_law_sections_5:
  object
  (str sectionId) (str 39306)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Powers to destroy arms dump, fortified positions, etc.`)
  (str content) (str `Any Magistrate or Police Officer not
below the rank of a Sub-Inspector may, if he is of opinion that it is necessary so to do, destroy any arms
dump, prepared or fortified position or shelter from which armed attacks are made or are likely to be
made or are attempted to be made or any structure used as training camp for armed volunteers or utilised
as a hide-out by armed gangs or absconders wanted for any offence.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39306&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00048_198333_1517807325584)
obj_root_law_sections_6:
  object
  (str sectionId) (str 39307)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Protection of persons acting under sections 4 and 5.`)
  (str content) (str `No suit, prosecution or other legal
proceedings shall be instituted except with the previous sanction of ^1
[the Central Government]against any
person in respect of anything done or purporting to be done in exercise of the powers conferred by
sections 4 and 5.`)
  (str footnotes) (str `1 Subs. by Act 15 of 1989, s. 2,for "the Administrator" (w.e.f. 18-5-1989).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39307&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00048_198333_1517807325584)
obj_root_law_sections_7:
  object
  (str sectionId) (str 39308)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Repeal and saving.`)
  (str content) (str `(1) The Chandigarh Disturbed Areas Ordinance, 1983 (6 of 1983), is hereby
repealed.

(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be
deemed to have been done or taken under the corresponding provisions of this Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00048_198333_1517807325584&sectionId=39308&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_00048_198333_1517807325584)
