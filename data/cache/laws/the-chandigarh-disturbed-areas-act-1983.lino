  object
  (str title) (str `चंडीगढ़ विक्षुब्ध क्षेत्र अधिनियम, 1983`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1823/3/H1983-33.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:42:21.215Z`)
