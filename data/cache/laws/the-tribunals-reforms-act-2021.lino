  sectionNo (21)
  orderNo 21
  title `Amendment of Act 47 of 1999.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_202133_1629961891898&sectionId=57375&sectionno=21&orderno=21&orgactid=AC_CEN_2_2_00040_202133_1629961891898
obj_root_law_sections_21_content:
  string
  line `In the Trade Marks Act, 1999,---`
  line
  line `(a) in section 2, in sub-section (1),---`
  line
  line `(i) clauses (a), (d), (f), (k), (n), (ze) and (zf) shall be omitted;`
  line
  line `(ii) for clause (s), the following clause shall be substituted, namely:---`
  line
  line `'(s) "prescribed means",---`
  line
  line `(i) in relation to proceedings before a High Court, prescribed by rules made by the`
  line `High Court; and`
  line
  line `(ii) in other cases, prescribed by rules made under this Act;';`
  line
  line `(b) in section 10, for the word "tribunal", the words "Registrar or the High Court, as the case may`
  line `be", shall be substituted;`
  line
  line `(c) in section 26, for the word "tribunal", the words "Registrar or the High Court, as the case may`
  line `be", shall be substituted;`
  line
  line `(d) in section 46, in sub-section (3), for the word "tribunal", the words "Registrar or the High`
  line `Court, as the case may be", shall be substituted;`
  line
  line `(e) in section 47,---`
  line
  line `(i) for the words "Appellate Board", at both the places where they occur, the words "High`
  line `Court" shall be substituted;`
  line
  line `(ii) for the word "tribunal", wherever it occurs, the words "Registrar or the High Court, as the`
  line `case may be", shall be substituted;`
  line
  line `(f) in section 55, in sub-section (1), for the word "tribunal", the words "Registrar or the High`
  line `Court, as the case may be", shall be substituted;`
  line
  line `(g) in section 57,---`
  line
  line `(i) for the words "Appellate Board", wherever they occur, the words "High Court" shall be`
  line substituted;
  line
  line `(ii) for the word "tribunal", wherever it occurs, the words "Registrar or the High Court, as the`
  line `case may be", shall be substituted;`
  line
  line `(h) in section 71, in sub-section (3), for the word "tribunal", the words "Registrar or the High`
  line `Court, as the case may be", shall be substituted;`
  line
  line `(i) in Chapter XI, for the Chapter heading, the Chapter heading "APPEALS" shall be substituted;`
  line
  line `(j) sections 83, 84, 85, 86, 87, 88, 89, 89A and 90 shall be omitted;`
  line
  line `(k) in section 91, for the words "Appellate Board", wherever they occur, the words "High Court"`
  line `shall be substituted;`
  line
  line `(l) sections 92 and 93 shall be omitted;`
  line
  line `(m) for section 94, the following section shall be substituted, namely:---`
  line
  line `"94. Bar to appear before Registrar.--- On ceasing to hold the office, the erstwhile Chairperson, Vice-Chairperson or other`
  line `Members shall not appear before the Registrar.";`
  line
  line `(n) sections 95 and 96 shall be omitted;`
  line
  line `(o) in section 97, for the words "Appellate Board", wherever they occur, the words "High Court"`
  line `shall be substituted;`
  line
  line `(p) in section 98, for the words "Appellate Board" or "Board", wherever they occur, the words`
  line `"High Court" shall be substituted;`
  line
  line `(q) sections 99 and 100 shall be omitted;`
  line
  line `(r) in section 113,---`
  line
  line `(i) for the words "Appellate Board", at both the places where they occur, the words "High`
  line `Court" shall be substituted;`
  line
  line `(ii) for the word "tribunal", the words "Registrar or the High Court, as the case may be", shall`
  line `be substituted;`
  line
  line `(s) in section 123, the words "and every Member of the Appellate Board" shall be omitted;`
  line
  line `(t) in sections 124 and 125, for the words "Appellate Board", wherever they occur, the words`
  line `"High Court" shall be substituted;`
  line
  line `(u) in section 130, the words "the Appellate Board or" shall be omitted;`
  line
  line `(v) in section 141, for the words "Appellate Board", at both the places where they occur, the`
  line `words "High Court" shall be substituted;`
  line
  line `(w) in section 144, for the word "tribunal", the words "Registrar or the High Court, as the case`
  line `may be", shall be substituted;`
  line
  line `(x) in section 157, in sub-section (2),---`
  line
  line `(i) clauses (xxxi) and (xxxii) shall be omitted;`
  line
  line `(ii) in clause (xxxiii), for the words "Appellate Board", the words "High Court" shall be`
  line substituted.
obj_root_law_sections_21_footnotes:
  string
  line
