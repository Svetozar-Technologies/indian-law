  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_202133_1629961891898&sectionId=57367&sectionno=13&orderno=13&orgactid=AC_CEN_2_2_00040_202133_1629961891898
obj_root_law_sections_13_content:
  string
  line `In the Patents Act, 1970,--`
  line
  line `(a) in section 2, in sub-section (1),--`
  line
  line `(i) clause (a) shall be omitted;`
  line
  line `(ii) in clause (u), sub-clause (B) shall be omitted;`
  line
  line `(b) in section 52, the words “Appellate Board or”, wherever they occur, shall be omitted;`
  line
  line `(c) in section 58,--`
  line
  line `(i) the words “the Appellate Board or”, wherever they occur, shall be omitted;`
  line
  line `(ii) the words “as the case may be” shall be omitted;`
  line
  line `(d) in section 59, the words “the Appellate Board or” shall be omitted;`
  line
  line `(e) in section 64, in sub-section (1), the words “by the Appellate Board” shall be omitted;`
  line
  line `(f) in section 71, for the words “Appellate Board” and “Board”, wherever they occur, the words`
  line `“High Court” shall be substituted;`
  line
  line `(g) in section 76, the words “or Appellate Board” shall be omitted;`
  line
  line `(h) in section 113,--`
  line
  line `(i) in sub-section (1),--`
  line
  line `(A) the words “the Appellate Board or”, wherever they occur, shall be omitted;`
  line
  line `(B) the words “as the case may be” shall be omitted;`
  line
  line `(ii) in sub-section (3), the words “or the Appellate Board” shall be omitted;`
  line
  line `(i) in Chapter XIX, for the Chapter heading, the Chapter heading “APPEALS” shall be`
  line substituted;
  line
  line `(j) sections 116 and 117 shall be omitted;`
  line
  line `(k) in section 117A, for the words “Appellate Board”, wherever they occur, the words “High`
  line `Court” shall be substituted;`
  line
  line `(l) sections 117B, 117C and 117D shall be omitted;`
  line
  line `(m) in section 117E, for the words “Appellate Board”, wherever they occur, the words “High`
  line `Court” shall be substituted;`
  line
  line `(n) sections 117F, 117G and 117H shall be omitted;`
  line
  line `(o) in section 151,--`
  line
  line `(i) in sub-section (1), the words “or the Appellate Board”, at both the places where they`
  line `occur, shall be omitted;`
  line
  line `(ii) in sub-section (3), for the words “the Appellate Board or the courts, as the case may be”,`
  line `the words “the courts” shall be substituted;`
  line
  line `(p) in section 159, in sub-section (2), clauses (xiia), (xiib) and (xiic) shall be omitted.`
obj_root_law_sections_13_footnotes:
  string
  line
