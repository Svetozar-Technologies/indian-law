  title `Amendment of Act 52 of 1962.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_202133_1629961891898&sectionId=57366&sectionno=12&orderno=12&orgactid=AC_CEN_2_2_00040_202133_1629961891898
obj_root_law_sections_12_content:
  string
  line `In the Customs Act, 1962,--`
  line
  line `(a) in section 28E, clauses (ba), (f) and (g) shall be omitted;`
  line
  line `(b) in section 28EA, the proviso shall be omitted;`
  line
  line `(c) in section 28F, sub-section (1) shall be omitted;`
  line
  line `(d) in section 28KA,--`
  line
  line `(i) in sub-section (1), for the words “Appellate Authority”, at both the places where they`
  line `occur, the words “High Court” shall be substituted;`
  line
  line `(ii) sub-section (2) shall be omitted;`
  line
  line `(e) in section 28L, the words “or Appellate Authority”, wherever they occur, shall be omitted;`
  line
  line `(f) in section 28M,--`
  line
  line `(i) in the marginal heading, the words “and Appellate Authority” shall be omitted;`
  line
  line `(ii) sub-section (2) shall be omitted;`
  line
  line `(g) in section 129, in sub-section (7), for the words and figures “Part XIV of Chapter VI of the`
  line `Finance Act, 2017 (7 of 2017), shall be governed by the provisions of the section 184 of that Act”, the`
  line `words and figures “the Tribunal Reforms Act, 2021, shall be governed by the provisions of Chapter II`
  line `of the said Act” shall be substituted.`
obj_root_law_sections_12_footnotes:
  string
  line
