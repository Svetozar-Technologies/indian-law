obj_root_law_sections_1:
  sectionId (46596)
  sectionNo (1)
  orderNo 1
  title `Title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_23_62_00006_187101_1523268567263&sectionId=46596&sectionno=1&orderno=1&orgactid=AC_CEN_23_62_00006_187101_1523268567263
obj_root_law_sections_1_content:
  string
  line `^1 [1. Title and extent.--(1) This Act may be called the Cattle-trespass Act, 1871; and`
  line
  line `(2) It extends to the whole of India except ^2[the territories which, immediately before the 1st`
  line `November, 1956, were comprised in Part B States], and the presidency-towns and such local areas as the`
  line `State Government, by notification in the Official Gazette, may from time to time exclude from its`
  line operation.
  line
  line `^3[* * * * *]`
  line
  line `STATE AMENDMENT`
  line
  line Maharashtra.--
  line
  line `Amendment of section 1 of Act 1 of 1871.--In section 1 of the Cattle-trespass Act, 1871, in its`
  line `application to the State I of Bombay (hereinafter referred to as the "principal Act"), to sub-section (2) the`
  line `1871, following proviso shall be added, namely:--`
  line
  line `"provided that on the commencement of the Cattle-trespass (Bombay Extension and Amendment)`
  line `Act, 1959 (Bom. XIII of 1959), it shall extend to those areas in which the Hyderabad, Cattle Trespass`
  line `Act, or as the case may be the Cattle-trespass Act, 1871 (Hyd. Act V of 1837, 1 of 1871), as modified and`
  line `applied to the Saurashtra area of the State of Bombay was in force immediately before such`
  line `commencement."`
  line
  line `[Vide Bombay Act XIII of 1959, s. 3]`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 1 of 1891, s. 1, for section 1.`
  line
  line `2. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part B States".`
  line
  line `3. Sub-section (3) rep. by Act 10 of 1914, s. 3 and the Second Schedule.`
obj_root_law_sections_2:
  sectionId (46597)
  sectionNo (2)
  orderNo 2
  title [Repealed.].
  content `[Repeal of Acts. References to repealed Acts.] Rep. by the Repealing Act, 1938 (1 of 1938).`
  footnotes obj_root_law_sections_2_footnotes
