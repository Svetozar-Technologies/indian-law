obj_root_law:
  slug the-central-industrial-security-force-act-1968
  handle (1599)
  collectionHandle 123456789/1362
  title `The Central Industrial Security Force Act, 1968`
  actNumber (50)
  enactmentDate 1968-12-02
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1599`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `केन्‍द्रीय औद्योगिक सुरक्षा बल अधिनियम, 1968`
  actYear (1968)
  ministry `Ministry of Home Affairs`
  department `Department of Internal Security`
  longTitle `An Act to provide for the constitution and regulation of an armed force of the Union for the better protection and security of industrial undertakings owned by the Central Government, certain other industrial undertakings, employees of all such undertakings and to provide technical consultancy services to industrial establishments in the private sector and for matters connected therewith.`
  enforcementDate 10-03-1969
  notification `10th March, 1969, vide notification No. S.O. 924, dated 3rd March, 1969, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T15:30:07.578Z`
  translations obj_root_law_translations
