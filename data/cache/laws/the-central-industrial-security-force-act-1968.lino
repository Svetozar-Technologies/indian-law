  (str slug) (str the-central-industrial-security-force-act-1968)
  (str handle) (str 1599)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Central Industrial Security Force Act, 1968`)
  (str actNumber) (str 50)
  (str enactmentDate) (str 1968-12-02)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1599`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `केन्‍द्रीय औद्योगिक सुरक्षा बल अधिनियम, 1968`)
  (str actYear) (str 1968)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of Internal Security`)
  (str longTitle) (str `An Act to provide for the constitution and regulation of an armed force of the Union for the better protection and security of industrial undertakings owned by the Central Government, certain other industrial undertakings, employees of all such undertakings and to provide technical consultancy services to industrial establishments in the private sector and for matters connected therewith.`)
  (str enforcementDate) (str 10-03-1969)
  (str notification) (str `10th March, 1969, vide notification No. S.O. 924, dated 3rd March, 1969, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-09T15:30:07.578Z`)
  (str translations) obj_root_law_translations
