  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00005_196336_1517807319297&sectionId=29987&sectionno=32&orderno=32&orgactid=AC_CEN_3_20_00005_196336_1517807319297
obj_root_law_sections_32_content:
  string
  line `[Repeal.]--Rep. by Repealing and Amending Act, 1974 (56 of 1974), s. 2 and the First Schedule`
  line `(w.e.f. 20-12-1974).`
