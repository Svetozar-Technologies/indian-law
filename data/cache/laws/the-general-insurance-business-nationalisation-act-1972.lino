obj_root_law:
  object
  (str slug) (str the-general-insurance-business-nationalisation-act-1972)
  (str handle) (str 1710)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The General Insurance Business (Nationalisation) Act, 1972`)
  (str actNumber) (str 57)
  (str enactmentDate) (str 1972-09-20)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1710`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `साधारण बीमा कारबार (राष्ट्री यकरण) अधिनियम,1972`)
  (str actYear) (str 1972)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Financial Services`)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of shares of Indian insurance companies and undertakings of other existing insurers in order to serve better the needs of the economy by securing the development of general insurance business in the best interests of the community and to ensure that the operation of the economic system does not result in the concentration of wealth to the common detriment, for the regulation and control of such business and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 20-09-1972)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T12:30:26.060Z`)
  (str translations) obj_root_law_translations
