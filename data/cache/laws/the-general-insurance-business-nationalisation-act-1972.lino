obj_root_law:
  slug the-general-insurance-business-nationalisation-act-1972
  handle (1710)
  collectionHandle 123456789/1362
  title `The General Insurance Business (Nationalisation) Act, 1972`
  actNumber (57)
  enactmentDate 1972-09-20
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1710`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `साधारण बीमा कारबार (राष्ट्री यकरण) अधिनियम,1972`
  actYear (1972)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to provide for the acquisition and transfer of shares of Indian insurance companies and undertakings of other existing insurers in order to serve better the needs of the economy by securing the development of general insurance business in the best interests of the community and to ensure that the operation of the economic system does not result in the concentration of wealth to the common detriment, for the regulation and control of such business and for matters connected therewith or incidental thereto.`
  enforcementDate 20-09-1972
  notification undefined
  fetchedAt `2026-05-10T12:30:26.060Z`
  translations obj_root_law_translations
