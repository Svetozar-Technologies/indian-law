  object
  (str title) (str `कराधान विधियां (वसूली की कार्यवाहियों का चालू रखा जाना और विधिमान्‍यकरण) अधिनियम, 1964`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1427/4/H1964-11.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:20:27.896Z`)
  (str pageCount) (int 3)
  (str sections) obj_root_law_translations_hi_sections
obj_root_law_translations_hi_sections:
