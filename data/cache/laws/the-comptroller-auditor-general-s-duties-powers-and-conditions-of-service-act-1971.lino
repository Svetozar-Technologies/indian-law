obj_root_law_sections_1:
  sectionId (18875)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=18875&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Comptroller and Auditor-General's (Duties, Powers and`
  line `Conditions of Service) Act, 1971.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (18876)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=18876&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "accounts", in relation to commercial undertakings of a Government, includes trading,`
  line `manufacturing and profit and loss accounts and balance-sheets and other subsidiary accounts;`
  line
  line `(b) "appropriation accounts" means accounts which relate the expenditure brought to account`
  line `during a financial year, to the several items specified in the law made in accordance with the`
  line `provisions of the Constitution or of the Government of Union Territories Act, 1963 (20 of 1963), for`
  line `the appropriation of moneys out of the Consolidated Fund of India or of a State, or of a Union`
  line `territory having a Legislative Assembly, as the case may be;`
  line
  line `(c) "Comptroller and Auditor-General" means the Comptroller and Auditor-General of India`
  line `appointed under article 148 of the Constitution;`
  line
  line `(d) "State" means a State specified in the First Schedule to the Constitution;`
  line
  line `(e) "Union" includes a Union territory, whether having a Legislative Assembly or not.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (18877)
  sectionNo (3)
  orderNo 3
  title Salary.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=18877&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_3_content:
  string
  line `There shall be paid to the Comptroller and Auditor-General a salary which is equal to the`
  line `salary of the Judge of the Supreme Court:`
  line
  line `Provided that if a person who, immediately before the date of assuming office as the Comptroller and`
  line `Auditor-General, was in receipt of, or, being eligible so to do, had elected to draw, a pension (other than a`
  line `disability or wound pension) in respect of any previous service under the Government of the Union or any`
  line `of its predecessor Governments, or under the Government of a State or any of its predecessor`
  line `Governments, his salary in respect of service as Comptroller and Auditor-General shall be reduced--`
  line
  line `(a) by the amount of that pension; and`
  line
  line `(b) if he had, before assuming office, received, in lieu of a portion of the pension due to him in`
  line `respect of such previous service, the commuted value thereof, by the amount of that portion of the`
  line pension;
  line ^1***
  line
  line `^2* * * * *`
obj_root_law_sections_3_footnotes:
  string
  line `1. The word "and" omitted by Act 51 of 1994, s. 2 (w.e.f. 27-3-1990).`
  line
  line `2. Clause (c) omitted by s. 2, ibid. (w.e.f. 27-3-1990).`
obj_root_law_sections_4:
  sectionId (18878)
  sectionNo (4)
  orderNo 4
  title `Term of office.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=18878&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_4_content:
  string
  line `The Comptroller and Auditor-General shall hold office for a term of six years`
  line `from the date on which he assumes such office:`
  line
  line `Provided that where he attains the age of sixty-five years before the expiry of the said term of six`
  line `years, he shall vacate such office on the date on which he attains the said age:/`
  line
  line `Provided further that he may, at any time, by writing under his hand addressed to the President, resign`
  line `his office.`
  line
  line `Explanation.--For the purpose of this section, the term of six years in respect of the Comptroller and`
  line `Auditor-General holding office immediately before the commencement of this Act, shall be computed`
  line `from the date on which he had assumed office.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (18879)
  sectionNo (5)
  orderNo 5
  title Leave.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=18879&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_5_content:
  string
  line `(1) A person who, immediately before the date of assuming office as the Comptroller and`
  line `Auditor-General, was in the service of Government may be granted during his tenure of office but not`
  line `thereafter, leave in accordance with the rules for the time being applicable to the Service to which he`
  line `belonged before such date and he shall be entitled to carry forward the amount of leave standing at his`
  line `credit on such date, notwithstanding anything contained in section 6.`
  line
  line `(2) Any other person who is appointed as the Comptroller and Auditor-General may be granted leave`
  line `in accordance with such rules as are for the time being applicable to a member of the Indian`
  line `Administrative Service.`
  line
  line `(3) The power to grant or refuse leave to the Comptroller and Auditor-General and to revoke or`
  line `curtail leave granted to him, shall vest in the President.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (18880)
  sectionNo (6)
  orderNo 6
  title Pension.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=18880&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_6_content:
  string
  line `(1) A person who, immediately before the date of assuming office as the Comptroller`
  line `and Auditor-General, was in the service of Government shall be deemed to have retired from service on`
  line `the date on which he enters upon office as the Comptroller and Auditor-General but his service as the`
  line `Comptroller and Auditor-General shall be reckoned as continuing approved service counting for pension`
  line `in the Service to which he belonged.`
  line
  line `(2) Every person who enters upon office as the Comptroller and Auditor-General shall, on demitting`
  line `the said office, be eligible to a pension of a sum of fifteen thousand rupees per annum which sum shall`
  line `include the aggregate of all pensions payable to him and the commuted portion, if any, of his pension, and`
  line `the pension equivalent of the retirement gratuity, if any, which may have been admissible to him under`
  line `the rules for the time being applicable to the Service to which he belonged:`
  line
  line `Provided that if such a person is or becomes eligible, at any time, under the rules for the time being`
  line `governing the Service to which he belonged, to a pension higher than the said sum of fifteen thousand`
  line `rupees, he shall be eligible to draw, as pension, the said higher amount.`
  line
  line `(3) A person who, immediately before the date of assuming office as the Comptroller and`
  line `Auditor-General, was in receipt of, or, had become eligible for receiving, a pension in respect of any`
  line `previous service under Government, shall, on demitting office as the Comptroller and Auditor-General,`
  line `be eligible to a pension of fifteen thousand rupees per annum which sum shall include the aggregate of all`
  line `pensions payable to him and the commuted portion, if any, of his pension, and the pension equivalent of`
  line `the retirement gratuity, if any, which may have been admissible to him under the rules for the time being`
  line `applicable to the Service to which he belonged:`
  line
  line `Provided that if such a person is or becomes eligible, at any time, under the rules for the time being`
  line `governing the Service to which he belonged, to a pension higher than the said sum of fifteen thousand`
  line `rupees, he shall be eligible to draw, as pension, the said higher amount.`
  line
  line `(4) Any other person who is appointed as the Comptroller and Auditor-General shall, on demitting the`
  line `said office, be eligible to a pension of fifteen thousand rupees per annum.`
  line
  line `(5) The person holding office immediately before the commencement of this Act as the Comptroller`
  line `and Auditor-General shall be eligible to draw, at his option, pension at the rate at which it would be`
  line `admissible to him if this Act had not come into force or at the rate specified in this section.`
  line
  line `(6) A person who demits office as the Comptroller and Auditor-General by resignation shall, on such`
  line `demission, be eligible to a pension at the rate of two thousand rupees per annum for each completed year`
  line `of his service as the Comptroller and Auditor-General:`
  line
  line `Provided that in the case of a person referred to in sub-section (1) or sub-section (3), the aggregate`
  line `amount of pension admissible under this sub-section together with the amount of pension including`
  line `the commuted portion, if any, of his pension, and the pension equivalent of the retirement gratuity, if`
  line `any, which may have been admissible to him under the rules for the time being applicable to the Service`
  line `to which he belonged immediately before he assumed office as the Comptroller and Auditor-General,`
  line `shall not exceed fifteen thousand rupees per annum or the higher pension referred to in proviso to`
  line `sub-section (2) or sub-section (3), as the case may be.`
  line
  line `^1[(6A) Notwithstanding anything contained in the foregoing provisions of this section, a person`
  line `referred to in sub-section (1) who demits office [whether in any manner specified in sub-section (8) or by`
  line `resignation] as the Comptroller and Auditor-General after the commencement of the Comptroller and`
  line `Auditor-General's (Duties, Powers and Conditions of Service) Amendment Act, 1984 (2 of 1984), shall,`
  line `on such demission, be entitled to--`
  line
  line `(a) the pension to which he would have been entitled under the rules of the Service to which he`
  line `belonged by reckoning his service as the Comptroller and Auditor-General as continuing approved`
  line `service counting for pension in such Service; and`
  line
  line `(b) a special pension of seven hundred rupees per annum in respect of each completed year of`
  line `service as the Comptroller and Auditor-General:`
  line
  line `^4* * * * *`
  line
  line `(6B) Notwithstanding anything contained in the foregoing provisions of this section, a person referred`
  line `to in sub-section (3) who demits office [whether in any manner specified in sub-section (8) or by`
  line `resignation] as the Comptroller and Auditor-General after the commencement of the Comptroller and`
  line `Auditor-General's (Duties, Powers and Conditions of Service) Amendment Act, 1984 (2 of 1984), shall,`
  line `on such demission, be entitled to--`
  line
  line `(a) the pension payable to him in respect of any previous service under Government; and`
  line
  line `(b) a special pension of seven hundred rupees per annum in respect of each completed year of`
  line `service as the Comptroller and Auditor-General:`
  line
  line `^2* * * * *]`
  line
  line `^3[(6C) Notwithstanding anything contained in the foregoing provisions of this section, a person who`
  line `demits office [whether in any manner specified in sub-section (8) or by resignation] as the Comptroller`
  line `and Auditor-General after the commencement of the Comptroller and Auditor-General's (Duties, Powers`
  line `and Conditions of Service) Amendment Act, 1987 (50 of 1987), shall, on such demission, be entitled to--`
  line
  line `(a) a pension which is equal to the pension payable to a Judge of the Supreme Court,`
  line
  line `(i) if such person is a person referred to in sub-section (1) or sub-section (3), in accordance`
  line `with the provisions of Part III of the Schedule to the Supreme Court Judges (Conditions of`
  line `Service) Act, 1958 (41 of 1958) (hereafter in this Act referred to as the Supreme Court Judges`
  line `Act), as amended from time to time; and`
  line
  line `(ii) if such person is a person referred to in sub-section (4), in accordance with the provisions`
  line `of Part I of the Schedule to the Supreme Court Judges Act, as amended from time to time;`
  line
  line `(b) such pension (including commutation of pension), family pension and gratuity as are`
  line `admissible to a Judge of Supreme Court under the Supreme Court Judges Act and the rules made`
  line `thereunder, as amended from time to time.]`
  line
  line `^4[(6D) Notwithstanding anything contained in the forgoing provisions of this section, a person who`
  line `demitted office [whether in any manner specified in sub-section (8) or by resignation] as the Comptroller`
  line `and Auditor-General, at any time before the 16th day of December, 1987, shall be entitled to the pension`
  line `specified in sub-section (6C) on and from that date.]`
  line
  line `(7) If a person who demits office as the Comptroller and Auditor-General is not eligible to`
  line `any pension under this section but is eligible to a pension under the rules for the time being applicable to`
  line `the Service to which he belonged immediately before be assumed office as the Comptroller and AuditorGeneral,`
  line `he shall, notwithstanding anything contained in this section, be eligible to draw such pension as`
  line `is admissible to him under the said rules.`
  line
  line `(8) Except where he demits office by resignation, a person holding office of the Comptroller and`
  line `Auditor-General shall be deemed, for the purposes of this Act, to have demitted such office as such if, and`
  line `only if,--`
  line
  line `(a) he has completed the term of office specified in section 4, or`
  line
  line `(b) he has attained the age of sixty-five years, or`
  line
  line `(c) his demission of office is medically certified to be necessitated by ill health.`
obj_root_law_sections_6_footnotes:
  string
  line `1. Ins. by Act 2 of 1984, s. 2 (w.e.f. 16-3-1984).`
  line
  line `2. The proviso omitted by Act 50 of 1987, s. 2 (w.e.f. 1-1-1986).`
  line
  line `3. Ins. by s. 2, ibid. (w.e.f. 16-12-1987).`
  line
  line `4. Ins. by Act 51 of 1994, s. 3 (w.e.f. 16-12-1987).`
obj_root_law_sections_7:
  sectionId (18881)
  sectionNo (7)
  orderNo 7
  title Omitted.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=18881&sectionno=7&orderno=7&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_7_content:
  string
  line `[Commutation, of pension.] Omitted by the Comptroller and Auditor-General's (Duties, Powers`
  line `and Conditions of service Amendment) Act, 1987 (50 of 1987), s. 3 (w.e.f. 16-12-1987).`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (29209)
  sectionNo (8)
  orderNo 8
  title `Right to subscribe to General Provident Fund.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29209&sectionno=8&orderno=8&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_8_content:
  string
  line `Every person holding office as the Comptroller`
  line `and Auditor-General shall be entitled to subscribe to the General Provident Fund (Central Services).`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (29210)
  sectionNo (9)
  orderNo 9
  title `Other conditions of service.`
  content obj_root_law_sections_9_content
  footnotes `1. Subs. by s. 4, ibid., for certain words (w.e.f. 16-12-1987).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29210&sectionno=9&orderno=9&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_9_content:
  string
  line `^1[Save as otherwise provided in this Act, the conditions of`
  line `service relating to travelling allowance, provision of rent-free residence and exemption from payment of`
  line `income- tax on the value of such rent-free residence, conveyance facilities, sumptuary allowance, medical`
  line `facilities and such other conditions of service as are for the time being applicable to a Judge of the`
  line `Supreme Court under Chapter IV of the Supreme Court Judges Act, and the rules made thereunder, shall,`
  line `so far as may be, apply to a serving or retired Comptroller and Auditor-General as the case may be:]`
  line
  line `Provided that nothing in this section shall have effect so as to give a person, who immediately before`
  line `the date of assuming office as the Comptroller and Auditor-General, was in the service of Government,`
  line `less favourable terms in respect of any of the matters aforesaid than those to which he would be entitled`
  line `as a member of the Service to which he belonged, his service as Comptroller and Auditor-General being`
  line `treated for the purpose of this proviso as continuing service in the Service to which he belonged.`
obj_root_law_sections_10:
  sectionId (29211)
  sectionNo (10)
  orderNo 10
  title `Comptroller and Auditor-General to compile accounts of Union and States`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29211&sectionno=10&orderno=10&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_10_content:
  string
  line `(1) The`
  line `Comptroller and Auditor-General shall be responsible--`
  line
  line `(a) for compiling the accounts of the Union and of each State from the initial and subsidiary`
  line `accounts rendered to the audit and accounts offices under his control by treasuries, offices or`
  line `departments responsible for the keeping of such accounts; and`
  line
  line `(b) for keeping such accounts in relation to any of the matters specified in clause (a) as may be`
  line `necessary:`
  line
  line `^1[Provided that the President may, after consultation with the Comptroller and Auditor-General, by`
  line `order, relieve him from the responsibility for compiling--`
  line
  line `(i) the said accounts of the Union (either at once or gradually by the issue of several orders); or`
  line
  line `(ii) the accounts of any particular services or departments of the Union:`
  line
  line `Provided further that the Governor of a State may, with the previous approval of the President and`
  line `after consultation with the Comptroller and Auditor-General, by order, relieve him from the responsibility`
  line `for compiling--`
  line
  line `(i) the said accounts of the State (either at once or gradually by the issue of several orders); or`
  line
  line `(ii) the accounts of any particular services or departments of the State:]`
  line
  line `^2[Provided also] that the President may, after consultation with the Comptroller and Auditor-General,`
  line `by order, relieve him from the responsibility for keeping the accounts of any particular class or character.`
  line
  line `(2) Where, under any arrangement, a person other than the Comptroller and Auditor-General has,`
  line `before the commencement of this Act, been responsible--`
  line
  line `(i) for compiling the accounts of any particular service or department of the Union or of a State,`
  line or
  line
  line `(ii) for keeping the accounts of any particular class or character,`
  line
  line `such arrangement shall, notwithstanding anything contained in sub-section (1), continue to be in force`
  line `unless, after consultation with the Comptroller and Auditor-General, it is revoked in the case referred to`
  line `in clause (i), by an order of the President or the Governor of the State, as the case may be, and in the case`
  line `referred to in clause (ii), by an order of the President.`
obj_root_law_sections_10_footnotes:
  string
  line `1. Subs. by Act 58 of 1976, s. 2, for the first proviso (w.e.f. 1-3-1976).`
  line
  line `2. Subs. by Act 58 of 1976, s. 2, for "Provided further" (w.e.f. 1-3-1976).`
obj_root_law_sections_11:
  sectionId (29212)
  sectionNo (11)
  orderNo 11
  title `Comptroller and Auditor-General to prepare and submit accounts to the President, Governors of States and Administrators of Union territories having Legislative Assemblies.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29212&sectionno=11&orderno=11&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_11_content:
  string
  line The
  line `Comptroller and Auditor-General shall, from the accounts compiled by him or ^1[by the Government or`
  line `any other person responsible in that behalf], prepare in each year accounts (including, in the case of`
  line `accounts compiled by him, appropriation accounts) showing under the respective heads the annual`
  line `receipts and disbursements for the purpose of the Union, of each State and of each Union territory having`
  line `a Legislative Assembly, and shall submit those accounts to the President or the Governor of a State or`
  line `Administrator of the Union territory having a Legislative Assembly, as the case may be, on or before such`
  line `dates as he may, with the concurrence of the Government concerned, determine:`
  line
  line `^2[Provided that the President may, after consultation with the Comptroller and Auditor-General, by`
  line `order, relieve him from the responsibility for the preparation and submission of the accounts relating to`
  line `annual receipts and disbursements for the purpose of the Union or of a Union territory having a`
  line `Legislative Assembly:`
  line
  line `Provided further that the Governor of a State may, with the previous approval of the President and`
  line `after consultation with the Comptroller and Auditor-General, by order, relieve him from the responsibility`
  line `for the preparation and submission of the accounts relating to annual receipts and disbursements for the`
  line `purpose of the State.]`
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for "by any other person responsible in that behalf" (w.e.f. 1-3-1976).`
  line
  line `2. The provisos ins. by s. 3, ibid. (w.e.f. 1-3-1976).`
obj_root_law_sections_12:
  sectionId (29213)
  sectionNo (12)
  orderNo 12
  title `Comptroller and Auditor-General to give information and render assistance to the Union and States.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29213&sectionno=12&orderno=12&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_12_content:
  string
  line `The Comptroller and Auditor-General shall, in so far as the accounts, for the compilation`
  line `or keeping of which he is responsible, enable him so to do, give to the Union Government, to the State`
  line `Governments or to the Governments of Union territories having Legislative Assemblies, as the case may`
  line `be, such information as they may, from time to time, require, and render such assistance in the preparation`
  line `of their annual financial statements as they may reasonably ask for.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (29214)
  sectionNo (13)
  orderNo 13
  title `General provisions relating to audit.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29214&sectionno=13&orderno=13&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_13_content:
  string
  line `It shall be the duty of the Comptroller and`
  line Auditor-General--
  line
  line `(a) to audit all expenditure from the Consolidated Fund of India and of each State and of each`
  line `Union territory having a Legislative Assembly and to ascertain whether the moneys shown in the`
  line `accounts as having been disbursed were legally available for and applicable to the service or purpose`
  line `to which they have been applied or charged and whether the expenditure conforms to the authority`
  line `which governs it;`
  line
  line `(b) to audit all transactions of the Union and of the States relating to Contingency Funds and`
  line `Public Accounts;`
  line
  line `(c) to audit all trading, manufacturing, profit and loss accounts and balance-sheets and other`
  line `subsidiary accounts kept in any department of the Union or of a State;`
  line
  line `and in each case to report on the expenditure, transactions or accounts so audited by him.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (29215)
  sectionNo (14)
  orderNo 14
  title `Audit of receipts and expenditure of bodies or authorities substantially financed from Union or State Revenues.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29215&sectionno=14&orderno=14&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_14_content:
  string
  line `^1[(1)] Where any body or authority is substantially financed by grants or`
  line `loans from the Consolidated Fund of India or of any State or of any Union territory having a Legislative`
  line `Assembly, the Comptroller and Auditor-General shall, subject to the provisions of any law for the time`
  line `being in force applicable to the body or authority, as the case may be, audit all receipts and expenditure of`
  line `that body or authority and to report on the receipts and expenditure audited by him.`
  line
  line `Explanation.--Where the grant or loan to a body or authority from the Consolidated Fund of India or`
  line `of any State or of any Union territory having a Legislative Assembly in a financial year is not less than`
  line `^2[rupees twenty-five lakhs] and the amount of such grant or loan is not less than seventy-five per cent of`
  line `the total expenditure of that body or authority, such body or authority shall be deemed, for the purposes of`
  line `^3[this sub-section] to be substantially financed by such grants or loans, as the case may be.`
  line
  line `^4[(2) Notwithstanding anything contained in sub-section (1) the Comptroller and Auditor-General`
  line `may, with the previous approval of the President or the Governor of a State or the Administrator of a`
  line `Union territory having a Legislative Assembly, as the case may be, audit all receipts and expenditure of`
  line `any body or authority where the grant or loan to such body or authority from the Consolidated Fund of`
  line `India or of any State, or of any Union territory having a Legislative Assembly, as the case may be, in a`
  line `financial year is not less than rupees one crore.`
  line
  line `(3) Where the receipts and expenditure of any body or authority are, by virtue of the fulfilment`
  line `of the conditions specified in sub-section (1) or sub-section (2), audited by the Comptroller and`
  line `Auditor-General in a financial year, he shall continue to audit the receipts and expenditure of that body or`
  line `authority for a further period of two years notwithstanding that the conditions specified in sub-section (1)`
  line `or sub-section (2) are not fulfilled during any of the two subsequent years.]`
obj_root_law_sections_14_footnotes:
  string
  line `1. Section 14 renumbered as sub-section (1) thereof by Act 2 of 1984, s. 3 (w.e.f. 16-3-1984).`
  line
  line `2. Subs. by s. 3, ibid., for "rupees five lakhs" (w.e.f. 16-3-1984).`
  line
  line `3. Subs. by s. 3, ibid., for "this section" (w.e.f. 16-3-1984).`
  line
  line `4. Ins. by s. 3, ibid. (w.e.f. 16-3-1984).`
obj_root_law_sections_15:
  sectionId (29216)
  sectionNo (15)
  orderNo 15
  title `Functions of Comptroller and Auditor-General in the case of grants or loans given to other authorities or bodies.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29216&sectionno=15&orderno=15&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_15_content:
  string
  line `(1) Where any grant or loan is given for any specific purpose from the`
  line `Consolidated Fund of India or of any State or of any Union territory having a Legislative Assembly to`
  line `any authority or body, not being a foreign State or international organisation, the Comptroller and`
  line `Auditor-General shall scrutinise the procedures by which the sanctioning authority satisfies itself as to the`
  line `fulfilment of the conditions subject to which such grants or loans were given and shall for this purpose`
  line `have right of access, after giving reasonable previous notice, to the books and accounts of that authority`
  line `or body:`
  line
  line `Provided that the President, the Governor of a State or the Administrator of a Union territory having a`
  line `Legislative Assembly, as the case may be, may, where he is of opinion that it is necessary so to do in the`
  line `public interest, by order, relieve the Comptroller and Auditor-General, after consultation with him, from`
  line `making any such scrutiny in respect of any body or authority receiving such grant or loan.`
  line
  line `(2) Except where he is authorised so to do by the President, the Governor of a State or`
  line `the Administrator of a Union territory having a Legislative Assembly, as the case may be, the`
  line `Comptroller and Auditor-General shall not have, while exercising the powers conferred on him by`
  line `sub-section (1), right of access to the books and accounts of any corporation to which any such grant or`
  line `loan as is referred to in sub-section (1) is given if the law by or under which such corporation has been`
  line `established provides for the audit of the accounts of such corporation by an agency other than the`
  line `Comptroller and Auditor-General:`
  line
  line `Provided that no such authorisation shall be made except after consultation with the Comptroller and`
  line `Auditor-General and except after giving the concerned corporation a reasonable opportunity of making`
  line `representations with regard to the proposal to give to the Comptroller and Auditor-General right of access`
  line `to its books and accounts.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (29217)
  sectionNo (16)
  orderNo 16
  title `Audit of receipts of Union or of States.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29217&sectionno=16&orderno=16&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_16_content:
  string
  line `It shall be the duty of the Comptroller and`
  line `Auditor-General to audit all receipts which are payable into the Consolidated Fund of India and of each`
  line `State and of each Union territory having a Legislative Assembly and to satisfy himself that the rules and`
  line `procedures in that behalf are designed to secure an effective check on the assessment, collection and`
  line `proper allocation of revenue and are being duly observed and to make for this purpose such examination`
  line `of the accounts as he thinks fit and report thereon.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (29218)
  sectionNo (17)
  orderNo 17
  title `Audit of accounts of stores and stock.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29218&sectionno=17&orderno=17&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_17_content:
  string
  line `The Comptroller and Auditor-General shall have`
  line `authority to audit and report on the accounts of stores and stock kept in any office or department of the`
  line `Union or of a State.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (29219)
  sectionNo (18)
  orderNo 18
  title `Powers of Comptroller and Auditor-General in connection with audit of accounts.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29219&sectionno=18&orderno=18&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_18_content:
  string
  line `(1) The`
  line `Comptroller and Auditor-General shall in connection with the performance of his duties under this Act,`
  line `have authority--`
  line
  line `(a) to inspect any office of accounts under the control of the Union or of a State, including`
  line `treasuries and such offices responsible for the keeping of initial or subsidiary accounts, as submit`
  line `accounts to him;`
  line
  line `(b) to require that, any accounts, books, papers and other documents which deal with or from the`
  line `basis of or are otherwise relevant to the transactions to which his duties in respect of audit extend,`
  line `shall be sent to such place as he may appoint for his inspection;`
  line
  line `(c) to put such questions or make such observations as he may consider necessary, to the person`
  line `in charge of the office and to call for such information as he may require for the preparation of any`
  line `account or report which it is his duty to prepare.`
  line
  line `(2) The person in charge of any office or department, the accounts of which have to be inspected and`
  line `audited by the Comptroller and Auditor-General, shall afford all facilities for such inspection and comply`
  line `with requests for information in as complete a form as possible and with all reasonable expedition.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (29220)
  sectionNo (19)
  orderNo 19
  title `Audit of Government companies and corporations.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29220&sectionno=19&orderno=19&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_19_content:
  string
  line `(1) The duties and powers`
  line `of the Comptroller and Auditor-General in relation to the audit of the accounts of Government companies`
  line `shall be performed and exercised by him in accordance with the provisions of the Companies`
  line `Act, 1956 (1 of 1956).`
  line
  line `(2) The duties and powers of the Comptroller and Auditor-General in relation to the audit of the`
  line `accounts of corporations (not being companies) established by or under law made by Parliament shall be`
  line `performed and exercised by him in accordance with the provisions of the respective legislations.`
  line
  line `(3) The Governor of a State or the Administrator of a Union territory having a Legislative Assembly`
  line `may, where he is of opinion that it is necessary in the public interest so to do, request the Comptroller and`
  line `Auditor-General to audit the accounts of a corporation established by law made by the Legislature of the`
  line `State or of the Union territory, as the case may be, and where such request has been made, the`
  line `Comptroller and Auditor-General shall audit the accounts of such corporation and shall have, for the`
  line `purposes of such audit, right of access to the books and accounts of such corporation:`
  line
  line `provided that no such request shall be made except after consultation with the Comptroller and`
  line `Auditor-General and except after giving reasonable opportunity to the corporation to make`
  line `representations with regard to the proposal for such audit.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_19_a:
  sectionId (29221)
  sectionNo 19A
  orderNo 20
  title `Laying of reports in relation to accounts of Government companies and corporations.`
  content obj_root_law_sections_19_a_content
  footnotes `1. Ins. by Act 2 of 1984, s. 4 (w.e.f. 16-3-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29221&sectionno=19A&orderno=20&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_19_a_content:
  string
  line `^1[19A. Laying of reports in relation to accounts of Government companies and corporations.--(1) The reports of the Comptroller and Auditor-General, in relation to the accounts of a Government company or a corporation referred to in section 19, shall be submitted to the Government or Governments`
  line concerned.
  line
  line `(2) The Central Government shall cause every report received by it under sub-section (1) to be laid, as`
  line `soon as may be after it is received, before each House of Parliament.`
  line
  line `(3) The State Government shall cause every report received by it under sub-section (1) to be laid as,`
  line `soon as may be after it is received, before the Legislature of the State.`
  line
  line `Explanation.--For the purposes of this section, "Government" or "State Government", in relation to a`
  line `Union territory having a Legislative Assembly, means the Administrator of the Union territory.]`
obj_root_law_sections_20:
  sectionId (29222)
  sectionNo (20)
  orderNo 21
  title `Audit of accounts of certain authorities or bodies.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29222&sectionno=20&orderno=21&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_20_content:
  string
  line `(1) Save as otherwise provided in`
  line `section 19, where the audit of the accounts of any body or authority has not been entrusted to the`
  line `Comptroller and Auditor-General by or under any law made by Parliament, he shall, if requested so to do`
  line `by the President or the Governor of a State or the Administrator of a Union territory having a Legislative`
  line `Assembly, as the case may be, undertake the audit of the accounts of such body or authority on such`
  line `terms and conditions as may be agreed upon between him and the concerned Government and shall have,`
  line `for the purposes of such audit, right of access to the books and accounts of that body or authority:`
  line
  line `Provided that no such request shall be made except after consultation with the Comptroller and`
  line Auditor-General.
  line
  line `(2) The Comptroller and Auditor-General may propose to the President or the Governor of a State or`
  line `the Administrator of a Union territory having a Legislative Assembly, as the case may be, that he may be`
  line `authorised to undertake the audit of the accounts of any body or authority, the audit of the accounts of`
  line `which has not been entrusted to him by law, if he is of opinion that such audit is necessary because a`
  line `substantial amount has been invested in, or advanced to, such body or authority by the Central or State`
  line `Government or by the Government of a Union territory having a Legislative Assembly, and on such`
  line `request being made, the President or the Governor or the Administrator, as the case may be, may`
  line `empower the Comptroller and Auditor-General to undertake the audit of the accounts of such body or`
  line authority.
  line
  line `(3) The audit referred to in sub-section (1) or sub-section (2) shall not be entrusted to the Comptroller`
  line `and Auditor-General except where the President or the Governor of a State or the Administrator of a`
  line `Union territory having a Legislative Assembly, as the case may be, is satisfied that it is expedient so to do`
  line `in the public interest and except after giving a reasonable opportunity to the concerned body or authority`
  line `to make representations with regard to the proposal for such audit.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (29223)
  sectionNo (21)
  orderNo 22
  title `Delegation of power of Comptroller and Auditor-General.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29223&sectionno=21&orderno=22&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_21_content:
  string
  line `Any power exercisable by the`
  line `Comptroller and Auditor-General under the provisions of this Act, or any other law may be exercised by`
  line `such officer of his department as may be authorised by him in this behalf by general or special order:`
  line
  line `Provided that except during the absence of the Comptroller and Auditor-General on leave or`
  line `otherwise, no officer shall be authorised to submit on behalf of the Comptroller and Auditor-General any`
  line `report which the Comptroller and Auditor-General is required by the Constitution or the Government of`
  line `Union Territories Act, 1963 (20 of 1963) to submit to the President or the Governor of a State or the`
  line `Administrator of a Union territory having a Legislative Assembly, as the case may be.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (29224)
  sectionNo (22)
  orderNo 23
  title `Power to make rules.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29224&sectionno=22&orderno=23&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_22_content:
  string
  line `(1) The Central Government may, after consultation with the`
  line `Comptroller and Auditor-General, by notification in the Official Gazette, make rules for carrying out the`
  line `provisions of this Act in so far as they relate to the maintenance of accounts.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner in which initial and subsidiary accounts shall be kept by the treasuries, offices and`
  line `departments rendering accounts to audit and accounts offices;`
  line
  line `(b) the manner in which the accounts of ^1[the Union or of a State or of] any particular service or`
  line `department or of any particular class or character, in respect of which the Comptroller and`
  line `Auditor-General has been relieved from the responsibility of compiling or keeping the accounts, shall`
  line `be compiled or kept;`
  line
  line `(c) the manner in which the accounts of stores and stock shall be kept in any office or department`
  line `of the Union or of a State, as the case may be;`
  line
  line `(d) any other matter which is required to be, or may be, prescribed by rules.`
  line
  line `(3) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or ^2[in two or more successive sessions], and if, before the expiry of ^3[the session`
  line `immediately following the session or the successive sessions aforesaid] both Houses agree in making any`
  line `modification in the rule or both Houses agree that the rule should not be made, the rule shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule.`
obj_root_law_sections_22_footnotes:
  string
  line `1. Ins. by Act 58 of 1976, s. 4 (w.e.f. 1-3-1976).`
  line
  line `2. Subs. by Act 58 of 1976, s. 4, for "in two successive sessions" (w.e.f. 1-3-1976).`
  line
  line `3. Subs. by s. 4, ibid., for "the session in which it is so laid or the session immediately following" (w.e.f. 1-3-1976).`
obj_root_law_sections_23:
  sectionId (29225)
  sectionNo (23)
  orderNo 24
  title `Power to make regulations.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29225&sectionno=23&orderno=24&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_23_content:
  string
  line `The Comptroller and Auditor-General is hereby authorised to`
  line `make regulations for carrying into effect the provisions of this Act in so far as they relate to the scope and`
  line `extent of audit, including laying down for the guidance of the Government Departments the general`
  line `principles of Government accounting and the broad principles in regard to audit of receipts and`
  line expenditure.
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (29226)
  sectionNo (24)
  orderNo 25
  title `Power to dispense with detailed audit.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29226&sectionno=24&orderno=25&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_24_content:
  string
  line `The Comptroller and Auditor-General is hereby`
  line `authorised to dispense with, when circumstances so warrant, any part of detailed audit of any accounts or`
  line `class of transactions and to apply such limited check in relation to such accounts or transactions as he`
  line `may determine.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (29227)
  sectionNo (25)
  orderNo 26
  title Repeal.
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29227&sectionno=25&orderno=26&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_25_content:
  string
  line `The Comptroller and Auditor-General (Conditions of Service) Act, 1953 (21 of 1953),`
  line `is hereby repealed.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (29228)
  sectionNo (26)
  orderNo 27
  title `Removal of doubts.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00004_197156_1517807318130&sectionId=29228&sectionno=26&orderno=27&orgactid=AC_CEN_2_11_00004_197156_1517807318130
obj_root_law_sections_26_content:
  string
  line `For the removal of doubts, it is hereby declared that on the commencement`
  line `of this Act the Government of India (Audit and Accounts) Order, 1936, as adapted by the India`
  line `(Provisional Constitution) Order, 1947, shall cease to be in force except as respects anything done or any`
  line `action taken thereunder.`
obj_root_law_sections_26_footnotes:
  string
  line
