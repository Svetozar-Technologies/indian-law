obj_root_law_sections_1:
  sectionId (184)
  sectionNo (1)
  orderNo 1
  title `Short title, extent, commencement and application.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00008_201318_1517807327856&sectionId=184&sectionno=1&orderno=1&orgactid=AC_CEN_22_29_00008_201318_1517807327856
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Companies Act, 2013.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) This section shall come into force at once and the remaining provisions of this Act shall come into force on such date^1 as the Central Government may, by notification in the Official Gazette, appoint and ^*different dates may be appointed for different provisions of this Act and any reference in any provision to the commencement of this Act shall be construed as a reference to the coming into force of that provision.`
  line
  line `(4) The provisions of this Act shall apply to--`
  line
  line `(a) companies incorporated under this Act or under any previous company law;`
  line
  line `(b) insurance companies, except in so far as the said provisions are inconsistent with the`
  line `provisions of the Insurance Act, 1938 (4 of 1938) or the Insurance Regulatory and Development Authority Act, 1999 (41 of 1999);`
  line
  line `(c) banking companies, except in so far as the said provisions are inconsistent with the provisions of the Banking Regulation Act, 1949 (10 of 1949);`
  line
  line `(d) companies engaged in the generation or supply of electricity, except in so far as the said`
  line `provisions are inconsistent with the provisions of the Electricity Act, 2003 (36 of 2003);`
  line
  line `(e) any other company governed by any special Act for the time being in force, except in so far as the said provisions are inconsistent with the provisions of such special Act; and`
  line
  line `(f) such body corporate, incorporated by any Act for the time being in force, as the Central Government may, by notification, specify in this behalf, subject to such exceptions,`
  line
  line `modifications or adaptation, as may be specified in the notification.`
  line `To be deleted`
