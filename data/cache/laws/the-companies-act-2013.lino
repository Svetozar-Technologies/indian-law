obj_root_law_sections_324:
  sectionId (1515)
  sectionNo (324)
  orderNo 328
  title `Debts of all descriptions to be admitted to proof`
  content obj_root_law_sections_324_content
  footnotes obj_root_law_sections_324_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_22_29_00008_201318_1517807327856&sectionId=1515&sectionno=324&orderno=328&orgactid=AC_CEN_22_29_00008_201318_1517807327856
obj_root_law_sections_324_content:
  string
  line `In every winding up (subject, in the case`
  line `of insolvent companies, to the application in accordance with the provisions of this Act or of the law of`
  line `insolvency), all debts payable on a contingency, and all claims against the company, present or future,`
  line `certain or contingent, ascertained or sounding only in damages, shall be admissible to proof against the`
  line `company, a just estimate being made, so far as possible, of the value of such debts or claims as may be`
  line `subject to any contingency, or may sound only in damages, or for some other reason may not bear a`
  line `certain value.`
obj_root_law_sections_324_footnotes:
  string
  line
