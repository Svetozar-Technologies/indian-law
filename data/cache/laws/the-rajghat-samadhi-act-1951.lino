obj_root_law_sections_1:
  sectionId (8616)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes `1. 7th June, 1952, vide notification No. S.R.O. 1018, dated 7th June, 1952, see Gazette of India, Extraordinary, Part II, s. 3.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8616&sectionno=1&orderno=1&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Rajghat Samadhi Act, 1951.`
  line
  line `(2) It shall come into force on such date ^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_2:
  sectionId (8617)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8617&sectionno=2&orderno=2&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_2_content:
  string
  line `In this Act,--`
  line
  line `(a) "Committee" means the Rajghat Samadhi Committee constituted under this Act;`
  line
  line `(b) "Samadhi" means the structure built in token of reverence for Mahatama Gandhi at Rajghat`
  line `on the Western bank of the Jamuna in Delhi, and includes the premises described in the Schedule`
  line `with all buildings contained therein, together with all additions thereto or alterations thereof which`
  line `may be made after the commencement of this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (8618)
  sectionNo (3)
  orderNo 3
  title `The Rajghat Samadhi Committee.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8618&sectionno=3&orderno=3&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_3_content:
  string
  line `(1) The administration and control of the Samadhi shall be`
  line `vested in a Committee constituted in the manner hereinafter provided.`
  line
  line `(2) The Committee shall by the name of "The Rajghat Samadhi Committee", be a body corporate and`
  line `shall have perpetual succession and a common seal and shall by the said name sue and be sued through its`
  line Chairman.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (8619)
  sectionNo (4)
  orderNo 4
  title `Composition of the Committee.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8619&sectionno=4&orderno=4&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_4_content:
  string
  line `(1) The Committee shall consist of the following members,`
  line `namely:--`
  line
  line `^1[(a) the Mayor of the Municipal Corporation of Delhi, ex officio;]`
  line
  line `(b) three officials nominated by the Central Government;`
  line
  line `^2[(c) four non-officials nominated by the Central Government;`
  line
  line `(d) three members of Parliament of whom shall be elected from among themselves by members`
  line `of the House of the People and one from among themselves by members of the Council of States.]`
  line
  line `(2) The Central Government may appoint any person referred to in sub-section (1) or any other`
  line `person to be the Chairman of the Committee, and if any other person is so appointed, he shall be deemed`
  line `to be a member of the Committee within the meaning of sub-section (1).`
  line
  line `(3) All persons nominated by the Central Government to be members of the Committee shall hold`
  line `office during the pleasure of the Central Government.`
  line
  line `^3[(4) The term of office of a member elected under clause (d) of sub-section (1) shall come to an end`
  line `as soon as he ceases to be a member of the House from which he was elected.]`
  line
  line `^4[(5) It is hereby declared that the office of member of the Committee shall not disqualify its holder`
  line `for being chosen as, or for being, a member of either House of Parliament.]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 37 of 1958, s. 2, for clause (a) (w.e.f. 9-3-1959.)`
  line
  line `2. Subs. by s. 2, ibid., for clauses (c) and (d) (w.e.f. 9-3-1959).`
  line
  line `3. Ins. by s. 2, ibid. (w.e.f. 9-3-1959).`
  line
  line `4. Ins. by Act 30 of 1988, s. 2 (w.e.f. 18-5-1988).`
obj_root_law_sections_5:
  sectionId (8620)
  sectionNo (5)
  orderNo 5
  title `Powers and duties of the Committee.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8620&sectionno=5&orderno=5&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_5_content:
  string
  line `Subject to such rules as may be made under this Act, the`
  line `powers and duties of the Committee shall be--`
  line
  line `(a) to administer the affairs of the Samadhi and to keep the Samadhi in proper order and in a state`
  line `of good repair;`
  line
  line `(b) to organise and regulate periodical functions at the Samadhi;`
  line
  line `(c) to do such other things as may be incidental or conducive to the efficient administration of the`
  line `affairs of the Samadhi.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (8621)
  sectionNo (6)
  orderNo 6
  title `Power of Central Government to make rules.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8621&sectionno=6&orderno=6&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_6_content:
  string
  line `The Central Government may, by notification in`
  line `the Official Gazette, make rules to carry out the objects of this Act, and to regulate access to the Samadhi`
  line `or to any portion thereof.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (8622)
  sectionNo (7)
  orderNo 7
  title `Power of Committee to make bye-laws.`
  content obj_root_law_sections_7_content
  footnotes `1. Ins. by Act 30 of 1988, s. 3 (w.e.f 18-5-1988)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8622&sectionno=7&orderno=7&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_7_content:
  string
  line `(1) The Committee may ^1[by notification in the`
  line `Official Gazette] make bye-laws consistent with this Act and the rules made thereunder for all or any of`
  line `the following purposes, namely:--`
  line
  line `(a) the manner in which meetings of the Committee shall be convened, the quorum for the`
  line `transaction of any business thereat and the procedure at such meetings;`
  line
  line `(b) the appointment of such persons as may be necessary to assist the Committee in the efficient`
  line `performance of its duties and the terms and conditions of service of such employees;`
  line
  line `(c) the duties and powers of the employees of the Committee;`
  line
  line `(d) the submission of accounts, returns and reports to the Committee by any of its employees.`
  line
  line `(2) All bye-laws made under this section shall be subject to the condition of previous publication and`
  line `shall not have effect until they are approved by the Central Government.`
obj_root_law_sections_7_a:
  sectionId (8623)
  sectionNo 7A
  orderNo 8
  title `Rules and bye-laws to be laid before Parliament.`
  content obj_root_law_sections_7_a_content
  footnotes `1. Ins. by s. 4, ibid. (w.e.f. 18-5-1988).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8623&sectionno=7A&orderno=8&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_7_a_content:
  string
  line `^1[7A. Rules and bye-laws to be laid before Parliament.--Every rule and every bye-law made under`
  line `this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it is in`
  line `session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or bye-law or`
  line `both Houses agree that the rule or bye-law should not be made, the rule or bye-law shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or bye-law.]`
obj_root_law_sections_8:
  sectionId (8624)
  sectionNo (8)
  orderNo 9
  title `Validity of acts of Committee not to be questioned by reason of vacancy, etc.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_19_00034_195141_1517807328535&sectionId=8624&sectionno=8&orderno=9&orgactid=AC_CEN_17_19_00034_195141_1517807328535
obj_root_law_sections_8_content:
  string
  line `No act or`
  line `proceeding of the Committee shall be deemed to be invalid merely by reason of any vacancy in, or any`
  line `defect in the constitution of, the Committee.`
obj_root_law_sections_8_footnotes:
  string
  line
