obj_root_law_sections_1:
  sectionId (30216)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30216&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Specific Relief Act,`
  line 1963.
  line
  line `(2) It extends to the whole of India ^1***.`
  line
  line `(3) It shall come into force on such date^2as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words except the State of Jammu and Kashmir omitted by Act 34 of 2019, s. 95 and 96 and the Fifth Schedule`
  line `(w.e.f. 31-10-2019).`
  line
  line `2. 1st March, 1964, vide notification No. S.O. 189, dated 13th January, 1964, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (30217)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30217&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "obligation" includes every duty enforceable by law;`
  line
  line `(b) "settlement" means an instrument (other than a will or codicil as defined by the Indian`
  line `Succession Act, 1925 (39 of 1925), whereby the destination or devolution of successive interests in`
  line `movable or immovable property is disposed of or is agreed to be disposed of;`
  line
  line `(c) "trust" has the same meaning as in section 3 of the Indian Trusts Act, 1882 (2 of 1882), and`
  line `includes an obligation in the nature of a trust within the meaning of Chapter IX of that Act;`
  line
  line `(d) "trustee" includes every person holding property in trust;`
  line
  line `(e) all other words and expressions used herein but not defined, and defined in the Indian`
  line `Contract Act, 1872 (9 of 1872), have the meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (30218)
  sectionNo (3)
  orderNo 3
  title Savings.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30218&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_3_content:
  string
  line `Except as otherwise provided herein, nothing in this Act shall be deemed--`
  line
  line `(a) to deprive any person of any right to relief, other than specific performance, which he may`
  line `have under any contract; or`
  line
  line `(b) to affect the operation of the Indian Registration Act, 1908 (16 of 1908), on documents.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (30219)
  sectionNo (4)
  orderNo 4
  title `Specific relief to be granted only for enforcing individual civil rights and not for enforcing penal laws.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30219&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_4_content:
  string
  line `Specific relief can be granted only for the purpose of enforcing individual civil rights and`
  line `not for the mere purpose of enforcing a penal law.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (30220)
  sectionNo (5)
  orderNo 5
  title `Recovery of specific immovable property.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30220&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_5_content:
  string
  line `A person entitled to the possession of specific`
  line `immovable property may recover it in the manner provided by the Code of Civil Procedure, 1908`
  line `(5 of 1908).`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (30221)
  sectionNo (6)
  orderNo 6
  title `Suit by person dispossessed of immovable property.`
  content obj_root_law_sections_6_content
  footnotes `1. Ins. by Act 18 of 2018, s. 2 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30221&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_6_content:
  string
  line `(1) If any person is dispossessed without`
  line `his consent of immovable property otherwise than in due course of law, he or any person ^1[through whom he has been in possession or any person] claiming through him may, by suit, recover possession thereof,`
  line `notwithstanding any other title that may be set up in such suit.`
  line
  line `(2) No suit under this section shall be brought--`
  line
  line `(a) after the expiry of six months from the date of dispossession; or`
  line
  line `(b) against the Government.`
  line
  line `(3) No appeal shall lie from any order or decree passed in any suit instituted under this section, nor`
  line `shall any review of any such order or decree be allowed.`
  line
  line `(4) Nothing in this section shall bar any person from suing to establish his title to such property and to`
  line `recover possession thereof.`
obj_root_law_sections_7:
  sectionId (30222)
  sectionNo (7)
  orderNo 7
  title `Recovery of specific movable property.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30222&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_7_content:
  string
  line `A person entitled to the possession of specific movable`
  line `property may recover it in the manner provided by the Code of Civil Procedure, 1908 (5 of 1908).`
  line
  line `Explanation 1.--A trustee may sue under this section for the possession of movable property to the`
  line `beneficial interest in which the person for whom he is trustee is entitled.`
  line
  line `Explanation 2.--A special or temporary right to the present possession of movable property is`
  line `sufficient to support a suit under this section.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (30223)
  sectionNo (8)
  orderNo 8
  title `Liability of person in possession, not as owner, to deliver to persons entitled to immediate possession.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30223&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_8_content:
  string
  line `Any person having the possession or control of a particular article of movable property, of`
  line `which he is not the owner, may be compelled specifically to deliver it to the person entitled to its`
  line `immediate possession, in any of the following cases:--`
  line
  line `(a) when the thing claimed is held by the defendant as the agent or trustee of the plaintiff;`
  line `(b) when compensation in money would not afford the plaintiff adequate relief for the loss of the`
  line `thing claimed;`
  line
  line `(c) when it would be extremely difficult to ascertain the actual damage caused by its loss;`
  line
  line `(d) when the possession of the thing claimed has been wrongfully transferred from the plaintiff.`
  line
  line `Explanation.--Unless and until the contrary is proved, the court shall, in respect of any article of`
  line `movable property claimed under clause (b) or clause (c) of this section, presume--`
  line
  line `(a) that compensation in money would not afford the plaintiff adequate relief for the loss of the`
  line `thing claimed, or, as the case may be;`
  line
  line `(b) that it would be extremely difficult to ascertain the actual damage caused by its loss`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (30224)
  sectionNo (9)
  orderNo 9
  title `Defences respecting suits for relief based on contract.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30224&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_9_content:
  string
  line `Except as otherwise provided herein`
  line `where any relief is claimed under this Chapter in respect of a contract, the person against whom the relief`
  line `is claimed may plead by way of defence any ground which is available to him under any law relating to`
  line contracts.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (30225)
  sectionNo (10)
  orderNo 10
  title `Cases in which specific performance of contract enforceable.`
  content obj_root_law_sections_10_content
  footnotes `1. Subs. by Act 18 of 2018, s 3, for section 10 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30225&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_10_content:
  string
  line `^1[The specific performance of a contract shall`
  line `be enforced by the court subject to the provisions contained in sub-section (2) of section 11, section 14`
  line `and section 16.]`
obj_root_law_sections_11:
  sectionId (30226)
  sectionNo (11)
  orderNo 11
  title `Cases in which specific performance of contracts connected with trusts enforceable.`
  content obj_root_law_sections_11_content
  footnotes `1. Subs. by Act 18 of 2018, s. 4, for contract may, in the discretion of the court (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30226&sectionno=11&orderno=11&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_11_content:
  string
  line `(1) Except as otherwise provided in this Act, specific performance of a ^1[contract shall], be enforced when`
  line `the act agreed to be done is in the performance wholly or partly of a trust.`
  line
  line `(2) A contract made by a trustee in excess of his powers or in breach of trust cannot be specifically`
  line enforced.
obj_root_law_sections_12:
  sectionId (30227)
  sectionNo (12)
  orderNo 12
  title `Specific performance of part of contract.`
  content obj_root_law_sections_12_content
  footnotes `1. Ins. by Act 52 of 1964, s. 3 and the Second Schedule (w.e.f. 29-12-1964).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30227&sectionno=12&orderno=12&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_12_content:
  string
  line `(1) Except as otherwise hereinafter provided in this`
  line `section, the court shall not direct the specific performance of a part of a contract.`
  line
  line `(2) Where a party to a contract is unable to perform the whole of his part of it, but the part which must`
  line `be left unperformed be a only a small proportion to the whole in value and admits of compensation in`
  line `money, the court may, at the suit of either party, direct the specific performance of so much of the`
  line `contract as can be performed, and award compensation in money for the deficiency.`
  line
  line `(3) Where a party to a contract is unable to perform the whole of his part of it, and the part which`
  line `must be left unperformed either--`
  line
  line `(a) forms a considerable part of the whole, though admitting of compensation in money; or`
  line
  line `(b) does not admit of compensation in money;`
  line
  line `he is not entitled to obtain a decree for specific performance; but the court may, at the suit of the other`
  line `party, direct the party in default to perform specifically so much of his part of the contract as he can`
  line `perform, if the other party--`
  line
  line `(i) in a case falling under clause (a), [pays or has paid] the agreed consideration for the whole of`
  line `the contract reduced by the consideration for the part which must be left unperformed and in a case`
  line `falling under clause (b) ^1pays or has paid the consideration for the whole of the contract without any`
  line `abatement; and`
  line
  line `(ii) in either case, relinquishes all claims to the performance of the remaining part of the contract`
  line `and all right to compensation, either for the deficiency or for the loss or damage sustained by him`
  line `through the default of the defendant.`
  line
  line `(4) When a part of a contract which, taken by itself, can and ought to be specifically performed,`
  line `stands on a separate and independent footing from another part of the same contract which cannot or`
  line `ought not to be specifically performed the court may direct specific performance of the former part.`
  line
  line `Explanation.--For the purposes of this section, a party to a contract shall be deemed to be unable to`
  line `perform the whole of his part of it if a portion of its subject-matter existing at the date of the contract has`
  line `ceased to exist at the time of its performance.`
obj_root_law_sections_13:
  sectionId (30228)
  sectionNo (13)
  orderNo 13
  title `Rights of purchaser or lessee against person with no title or imperfect title.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30228&sectionno=13&orderno=13&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_13_content:
  string
  line `(1) Where a person`
  line `contracts to sell or let certain immovable property having no title or only an imperfect title, the purchaser`
  line `or lessee (subject to the other provisions of this Chapter), has the following rights, namely:--`
  line
  line `(a) if the vendor or lessor has subsequently to the contract acquired any interest in the property,`
  line `the purchaser or lessee may compel him to make good the contract out of such interest;`
  line
  line `(b) where the concurrence of other person is necessary for validating the title, and they are bound`
  line `to concur at the request of the vendor or lessor, the purchaser or lessee may compel him to procure`
  line `such concurrence, and when a conveyance by other persons is necessary to validate the title and they`
  line `are bound to convey at the request of the vendor or lessor, the purchaser or lessee may compel him to`
  line `procure such conveyance;`
  line
  line `(c) where the vendor professes to sell unencumbered property, but the property is mortgaged for`
  line `an amount not exceeding the purchase money and the vendor has in fact only a right to redeem it, the purchaser may compel him to redeem the mortgage and to obtain a valid discharge, and, where`
  line `necessary, also a conveyance from the mortgagee;`
  line
  line `(d) where the vendor or lessor sues for specific performance of the contract and the suit is`
  line `dismissed on the ground of his want of title or imperfect title, the defendant has a right to a return of`
  line `his deposit, if any, with interest thereon, to his costs of the suit, and to a lien for such deposit, interest`
  line `and costs on the interest, if any, of the vendor or lesser in the property which is the subject-matter of`
  line `the contract.`
  line
  line `(2) The provisions of sub-section (1) shall also apply, as far as may be, to contracts for the sale or hire`
  line `of movable property.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (30229)
  sectionNo (14)
  orderNo 14
  title `Contracts not specifically enforceable.`
  content obj_root_law_sections_14_content
  footnotes `1. Subs. by Act 18 of 2018, s. 5, for section 14 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30229&sectionno=14&orderno=14&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_14_content:
  string
  line `^1The following contracts cannot be specifically`
  line `enforced, namely:--`
  line
  line `(a) where a party to the contract has obtained substituted performance of contract in accordance`
  line `with the provisions of section 20;`
  line
  line `(b) a contract, the performance of which involves the performance of a continuous duty which the`
  line `court cannot supervise;`
  line
  line `(c) a contract which is so dependent on the personal qualifications of the parties that the court`
  line `cannot enforce specific performance of its material terms; and`
  line
  line `(d) a contract which is in its nature determinable.]`
obj_root_law_sections_14_a:
  sectionId (42822)
  sectionNo 14A
  orderNo 15
  title `Power of court to engage experts.`
  content obj_root_law_sections_14_a_content
  footnotes `1. Subs. by Act 18 of 2018, s. 5, for section 14 (w.e.f. 1-10-2018)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=42822&sectionno=14A&orderno=15&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_14_a_content:
  string
  line `^1[14A. Power of court to engage experts.-- (1) Without prejudice to the generality of the provisions`
  line `contained in the Code of Civil Procedure, 1908 (5 of 1908), in any suit under this Act, where the court`
  line `considers it necessary to get expert opinion to assist it on any specific issue involved in the suit, it may`
  line `engage one or more experts and direct to report to it on such issue and may secure attendance of the`
  line `expert for providing evidence, including production of documents on the issue.`
  line
  line `(2) The court may require or direct any person to give relevant information to the expert or to`
  line `produce, or to provide access to, any relevant documents, goods or other property for his inspection.`
  line
  line `(3) The opinion or report given by the expert shall form part of the record of the suit; and the court, or`
  line `with the permission of the court any of the parties to the suit, may examine the expert personally in open`
  line `court on any of the matters referred to him or mentioned in his opinion or report, or as to his opinion or`
  line `report, or as to the manner in which he has made the inspection.`
  line
  line `(4) The expert shall be entitled to such fee, cost or expense as the court may fix, which shall be`
  line `payable by the parties in such proportion, and at such time, as the court may direct.]`
obj_root_law_sections_15:
  sectionId (30230)
  sectionNo (15)
  orderNo 16
  title `Who may obtain specific performance.`
  content obj_root_law_sections_15_content
  footnotes `1. Ins. by Act 18 of 2018, s. 6 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30230&sectionno=15&orderno=16&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_15_content:
  string
  line `Except as otherwise provided by this Chapter, the`
  line `specific performance of a contract may be obtained by--`
  line
  line `(a) any party thereto;`
  line
  line `(b) the representative in interest or the principal, of any party thereto:`
  line
  line `Provided that where the learning, skill, solvency or any personal quality of such party is a`
  line `material ingredient in the contract, or where the contract provides that his interest shall not be`
  line `assigned, his representative in interest or his principal shall not be entitled to specific performance of`
  line `the contract, unless such party has already performed his part of the contract, or the performance`
  line `thereof by his representative in interest, or his principal, has been accepted by the other party;`
  line
  line `(c) where the contract is a settlement on marriage, or a compromise of doubtful rights between`
  line `members of the same family, any person beneficially entitled thereunder;`
  line
  line `(d) where the contract has been entered into by a tenant for life in due exercise of a power, the`
  line remainderman;
  line
  line `(e) a reversioner in possession, where the agreement is a covenant entered into with his`
  line `predecessor in title and the reversioner is entitled to the benefit of such covenant;`
  line
  line `(f) a reversioner in remainder, where the agreement is such a covenant, and the reversioner is`
  line `entitled to the benefit thereof and will sustain material injury by reason of its breach;`
  line
  line `^1[(fa) when a limited liability partnership has entered into a contract and subsequently becomes`
  line `amalgamated with another limited liability partnership, the new limited liability partnership which`
  line `arises out of the amalgamation./]br`
  line
  line `(g) when a company has entered into a contract and subsequently becomes amalgamated with`
  line `another company, the new company which arises out of the amalgamation;`
  line
  line `(h) when the promoters of a company have, before its incorporation, entered into a contract for`
  line `the purposes of the company, and such contract is warranted by the terms of the incorporation, the`
  line `company:`
  line
  line `Provided that the company has accepted the contract and has communicated such acceptance to`
  line `the other party to the contract.`
obj_root_law_sections_16:
  sectionId (30231)
  sectionNo (16)
  orderNo 17
  title `Personal bars to relief.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30231&sectionno=16&orderno=17&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_16_content:
  string
  line `Specific performance of a contract cannot be enforced in favour of a`
  line person--
  line
  line `^1[(a) who has obtained substituted performance of contract under section 20; or]`
  line
  line `(b) who has become incapable of performing, or violates any essential term of, the contract that`
  line `on his part remains to be performed, or acts in fraud of the contract, or wilfully acts at variance with,`
  line `or in subversion of, the relation intended to be established by the contract; or`
  line
  line `(c) ^2[who fails to prove] that he has performed or has always been ready and willing to perform`
  line `the essential terms of the contract which are to be performed by him, other than terms of the`
  line `performance of which has been prevented or waived by the defendant.`
  line
  line `Explanation.--For the purposes of clause (c),--`
  line
  line `(i) where a contract involves the payment of money, it is not essential for the plaintiff to`
  line `actually tender to the defendant or to deposit in court any money except when so directed by the`
  line court;
  line
  line `(ii) the plaintiff ^3[must prove] performance of, or readiness and willingness to perform, the`
  line `contract according to its true construction.`
obj_root_law_sections_16_footnotes:
  string
  line `1. Subs. by s. 7, ibid., for clause (a) (w.e.f. 1-10-2018).`
  line
  line `2.Subs. by s. 7, ibid., for who fails to aver and prove (w.e.f. 1-10-2018).`
  line
  line `3. Subs by s. 7, ibid., for must aver (w.e.f. 1-10-2018).`
obj_root_law_sections_17:
  sectionId (30232)
  sectionNo (17)
  orderNo 18
  title `Contract to sell or let property by one who has no title, not specifically enforceable.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30232&sectionno=17&orderno=18&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_17_content:
  string
  line `(1) A`
  line `contract to sell or let any immovable property cannot be specifically enforced in favour of a vendor or`
  line lessor--
  line
  line `(a) who, knowing himself not to have any title to the property, has contracted to sell or let the`
  line property;
  line
  line `(b) who, though he entered into the contract believing that he had a good title to the property,`
  line `cannot at the time fixed by the parties or by the court for the completion of the sale or letting, give the`
  line `purchaser or lessee a title free from reasonable doubt.`
  line
  line `(2) The provisions of sub-section (1) shall also apply, as far as may be, to contracts for the sale or hire`
  line `of movable property.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (30233)
  sectionNo (18)
  orderNo 19
  title `Non-enforcement except with variation.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30233&sectionno=18&orderno=19&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_18_content:
  string
  line `Where a plaintiff seeks specific performance of a`
  line `contract in writing, to which the defendant sets up a variation, the plaintiff cannot obtain the performance`
  line `sought, except with the variation so set up, in the following cases, namely:--`
  line
  line `(a) where by fraud, mistake of fact or mis-representation, the written contract of which`
  line `performance is sought is in its terms or effect different from what the parties agreed to, or does not`
  line `contain all the terms agreed to between the parties on the basis of which the defendant entered into`
  line `the contact;`
  line
  line `(b) where the object of the parties was to produce a certain legal result which the contract as`
  line `framed is not calculated to produce;`
  line
  line `(c) where the parties have, subsequently to the execution of the contract, varied its terms.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (30234)
  sectionNo (19)
  orderNo 20
  title `Relief against parties and persons claiming under them by subsequent title.`
  content obj_root_law_sections_19_content
  footnotes `1. Ins. by Act 18 of 2018, s. 8 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30234&sectionno=19&orderno=20&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_19_content:
  string
  line `Except as`
  line `otherwise provided by this Chapter, specific performance of a contract may be enforced against--`
  line
  line `(a) either party thereto;`
  line
  line `(b) any other person claiming under him by a title arising subsequently to the contract, except a`
  line `transferee for value who has paid his money in good faith and without notice of the original contract;`
  line
  line `(c) any person claiming under a title which, though prior to the contract and known to the`
  line `plaintiff, might have been displaced by the defendant;`
  line
  line `^1[(ca) when a limited liability partnership has entered into a contract and subsequently becomes amalgamated with another limited liability partnership, the new limited liability partnership which`
  line `arises out of the amalgamation.]`
  line
  line `(d) when a company has entered into a contract and subsequently becomes amalgamated with`
  line `another company, the new company which arises out of the amalgamation;`
  line
  line `(e) when the promoters of a company have, before its incorporation, entered into a contract for`
  line `the purpose of the company and such contract is warranted by the terms of the incorporation, the`
  line `company:`
  line
  line `Provided that the company has accepted the contract and communicated such acceptance to the other`
  line `party to the contract.`
obj_root_law_sections_20:
  sectionId (30235)
  sectionNo (20)
  orderNo 21
  title `Substituted performance of contract`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30235&sectionno=20&orderno=21&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_20_content:
  string
  line `^1, ^2[20. Substituted performance of contract.-- (1) Without prejudice to the generality of the`
  line `provisions contained in the Indian Contract Act, 1872 (9 of 1872), and, except as otherwise agreed upon`
  line `by the parties, where the contract is broken due to non-performance of promise by any party, the party`
  line `who suffers by such breach shall have the option of substituted performance through a third party or by`
  line `his own agency, and, recover the expenses and other costs actually incurred, spent or suffered by him,`
  line `from the party committing such breach.`
  line
  line `(2) No substituted performance of contract under sub-section (1) shall be undertaken unless the party`
  line `who suffers such breach has given a notice in writing, of not less than thirty days, to the party in breach`
  line `calling upon him to perform the contract within such time as specified in the notice, and on his refusal or`
  line `failure to do so, he may get the same performed by a third party or by his own agency:`
  line
  line `Provided that the party who suffers such breach shall not be entitled to recover the expenses and costs`
  line `under sub-section (1) unless he has got the contract performed through a third party or by his own agency.`
  line
  line `(3) Where the party suffering breach of contract has got the contract performed through a third party`
  line `or by his own agency after giving notice under sub-section (1), he shall not be entitled to claim relief of`
  line `specific performance against the party in breach.`
  line
  line `(4) Nothing in this section shall prevent the party who has suffered breach of contract from claiming`
  line `compensation from the party in breach.]`
obj_root_law_sections_20_footnotes:
  string
  line `1. Subs. by s. 9, ibid., for "Discretion and powers of Court"(w.e.f. 1-10-2018).`
  line
  line `2. Subs. by s. 10, ibid., for section 20 (w.e.f. 1-10-2018).`
obj_root_law_sections_20_a:
  sectionId (42823)
  sectionNo 20A
  orderNo 22
  title `Special provisions for contract relating to infrastructure project.`
  content obj_root_law_sections_20_a_content
  footnotes `1. Subs. by s. 10, ibid., for section 20 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=42823&sectionno=20A&orderno=22&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_20_a_content:
  string
  line `^1[20A. Special provisions for contract relating to infrastructure project-- (1) No injunction shall`
  line `be granted by a court in a suit under this Act involving a contract relating to an infrastructure project`
  line `specified in the Schedule, where granting injunction would cause impediment or delay in the progress or`
  line `completion of such infrastructure project.`
  line
  line `Explanation.--For the purposes of this section, section 20B and clause (ha) of section 41, the`
  line `expression "infrastructure project" means the category of projects and infrastructure Sub-Sectors`
  line `specified in the Schedule.`
  line
  line `(2) The Central Government may, depending upon the requirement for development of infrastructure`
  line `projects, and if it considers necessary or expedient to do so, by notification in the Official Gazette, amend`
  line `the Schedule relating to any Category of projects or Infrastructure Sub-Sectors.`
  line
  line `(3) Every notification issued under this Act by the Central Government shall be laid, as soon as may`
  line `be after it is issued, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the notification or both Houses agree that the notification should not be made,`
  line `the notification shall thereafter have effect only in such modified form or be of no effect, as the case may`
  line `be; so, however, that any such modification or annulment shall be without prejudice to the validity of`
  line `anything previously done under that notification].`
obj_root_law_sections_20_b:
  sectionId (42824)
  sectionNo 20B
  orderNo 23
  title `Special Courts.`
  content obj_root_law_sections_20_b_content
  footnotes `1. Subs. by s. 10, ibid., for section 20 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=42824&sectionno=20B&orderno=23&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_20_b_content:
  string
  line `^1[20B. Special Courts.-- The State Government, in consultation with the Chief Justice of the High`
  line `Court, shall designate, by notification published in the Official Gazette, one or more Civil Courts as`
  line `Special Courts, within the local limits of the area to exercise jurisdiction and to try a suit under this Act in`
  line `respect of contracts relating to infrastructure projects.]`
obj_root_law_sections_20_c:
  sectionId (42825)
  sectionNo 20C
  orderNo 24
  title `Expeditious disposal of suits.`
  content obj_root_law_sections_20_c_content
  footnotes `1. Subs. by s. 10, ibid., for section 20 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=42825&sectionno=20C&orderno=24&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_20_c_content:
  string
  line `^1[20C. Expeditious disposal of suits.-- Notwithstanding anything contained in the Code of Civil`
  line `Procedure, 1908 (5 of 1908), a suit filed under the provisions of this Act shall be disposed of by the court`
  line `within a period of twelve months from the date of service of summons to the defendant:`
  line
  line `Provided that the said period may be extended for a further period not exceeding six months in`
  line `aggregate after recording reasons in writing for such extension by the court.]`
obj_root_law_sections_21:
  sectionId (30236)
  sectionNo (21)
  orderNo 25
  title `Power to award compensation in certain cases.`
  content obj_root_law_sections_21_content
  footnotes `1. Subs. by Act 18 of 2018, s. 11, for , either in addition to, or in substitution of, (w.e.f. 1-10-2018)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30236&sectionno=21&orderno=25&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_21_content:
  string
  line `(1) In a suit for specific performance of a`
  line `contract, the plaintiff may also claim compensation for its breach ^1[in addition to] such performance.`
  line
  line `(2) If, in any such suit, the court decides that specific performance ought not to be granted, but that`
  line `there is a contract between the parties which has been broken by the defendant, and that the plaintiff is`
  line `entitled to compensation for that breach, it shall award him such compensation accordingly.`
  line
  line `(3) If, in any such suit, the court decides that specific performance ought to be granted, but that it is`
  line `not sufficient to satisfy the justice of the case, and that some compensation for breach of the contract`
  line `should also be made to the plaintiff, it shall award him such compensation accordingly.`
  line
  line `(4) In determining the amount of any compensation awarded under this section, the court shall be`
  line `guided by the principles specified in section 73 of the Indian Contract Act, 1872 (9 of 1872).`
  line
  line `(5) No compensation shall be awarded under this section unless the plaintiff has claimed such`
  line `compensation in his plaint:`
  line
  line `Provided that where the plaintiff has not claimed any such compensation in the plaint, the court shall,`
  line `at any stage of the proceeding, allow him to amend the plaint on such terms as may be just, for including`
  line `a claim for such compensation.`
  line
  line `Explanation.The circumstances that the contract has become incapable of specific performance`
  line `does not preclude the court from exercising the jurisdiction conferred by this section.`
obj_root_law_sections_22:
  sectionId (30237)
  sectionNo (22)
  orderNo 26
  title `Power to grant relief for possession, partition, refund of earnest money, etc.`
  content obj_root_law_sections_22_content
  footnotes `1. Subs. by Act 52 of 1964, s. 3, and the Second Schedule, for made to (w.e.f. 29-12-1964).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30237&sectionno=22&orderno=26&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_22_content:
  string
  line `(1)`
  line `Notwithstanding anything to the contrary contained in the Code of Civil Procedure,1908 (5 of 1908), any`
  line `person suing for the specific performance of a contract for the transfer of immovable property may, in an`
  line `appropriate case, ask for--`
  line
  line `(a) possession, or partition and separate possession, of the property in addition to such`
  line `performance; or`
  line
  line `(b) any other relief to which he may be entitled, including the refund of any earnest money or`
  line `deposit paid or ^1[made by] him, in case his claim for specific performance is refused.`
  line
  line `(2) No relief under clause (a) or clause (b) of sub-section (1) shall be granted by the court unless it`
  line `has been specifically claimed:`
  line
  line `Provident that where the plaintiff has not claimed any such relief in the plaint, the court shall, at any`
  line `stage of the proceeding, allow him to amend the plaint on such terms as may be just for including a claim`
  line `for such relief.`
  line
  line `(3) The power of the court to grant relief under clause (b) of sub-section (1) shall be without prejudice`
  line `to its powers to award compensation under section 21.`
obj_root_law_sections_23:
  sectionId (30238)
  sectionNo (23)
  orderNo 27
  title `Liquidation of damages not a bar to specific performance.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30238&sectionno=23&orderno=27&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_23_content:
  string
  line `(1) A contract, otherwise proper`
  line `to be specifically enforced, may be so enforced, though a sum be named in itas the amount to be paid in`
  line `case of its breach and the party in default is willing to pay the same, if the court, having regard to the`
  line `terms of the contract and other attending circumstances, is satisfied that the sum was named only for the`
  line `purpose of securing performance of the contract and not for the purpose of giving to the party in default`
  line `an option of paying money in lieu of specific performance.`
  line
  line `(2) When enforcing specific performance under this section, the court shall not also decree payment`
  line `of the sum so named in the contract.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (30239)
  sectionNo (24)
  orderNo 28
  title `Bar of suit for compensation for breach after dismissal of suit for specific performance.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30239&sectionno=24&orderno=28&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_24_content:
  string
  line `The dismissal of a suit for specific performance of a contract or part thereof shall bar the plaintiff's right`
  line `to sue for compensation for the breach of such contract or part, as the case may be, but shall not bar his`
  line `right to sue for any other relief to which he may be entitled, by reason of such breach.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (30240)
  sectionNo (25)
  orderNo 29
  title `Application of preceding sections to certain awards and testamentary directions to execute settlements.`
  content obj_root_law_sections_25_content
  footnotes `1. Subs. by Act 18 of 2018, s. 12, for "the Arbitration Act", 1940 (10 of 1940) (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30240&sectionno=25&orderno=29&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_25_content:
  string
  line `The provisions of this Chapter as to contracts shall apply to awards to which ^1[the`
  line `Arbitration and Conciliation Act, 1996 (26 of 1996)], does not apply and to directions in a will or codicil`
  line `to execute a particular settlement.`
obj_root_law_sections_26:
  sectionId (30241)
  sectionNo (26)
  orderNo 30
  title `When instrument may be rectified.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30241&sectionno=26&orderno=30&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_26_content:
  string
  line `(1) When, through fraud or a mutual mistake of the parties`
  line `a contract or other instrument in writing [not being the articles of association of a company to which the`
  line `Companies Act, 1956 (1 of 1956), applies] does not express their real intention, then--`
  line
  line `(a) either party or his representative in interest may institute a suit to have the instrument`
  line `rectified; or`
  line
  line `(b) the plaintiff may, in any suit in which any right arising under the instrument is in issue, claim`
  line `in his pleading that the instrument be rectified; or`
  line
  line `(c) a defendant in any such suit as is referred to in clause (b), may, in addition to any other`
  line `defence open to him, ask for rectification of the instrument.`
  line
  line `(2) If, in any suit in which a contract or other instrument is sought to be rectified under`
  line `sub-section (1), the court finds that the instrument, through fraud or mistake, does not express the real`
  line `intention of the parties, the court may in its discretion, direct rectification of the instrument so as to`
  line `express that intention, so far as this can be done without prejudice to rights acquired by third persons in`
  line `good faith and for value.`
  line
  line `(3) A contract in writing may first be rectified, and then if the party claiming rectification has so`
  line `prayed in his pleading and the court thinks fit, may be specifically enforced.`
  line
  line `(4) No relief for the rectification of an instrument shall be granted to any party under this section`
  line `unless it has been specifically claimed:`
  line
  line `Provided that where a party has not claimed any such relief in his pleading, the court shall, at any`
  line `stage of the proceeding, allow him to amend the pleading on such terms as may be just for including such`
  line claim.
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (30242)
  sectionNo (27)
  orderNo 31
  title `When rescission may be adjudged or refused.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30242&sectionno=27&orderno=31&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_27_content:
  string
  line `(1) Any person interested in a contract may sue`
  line `to have it rescinded, and such rescission may be adjudged by the court in any of the following cases,`
  line `namely:--`
  line
  line `(a) where the contract is voidable or terminable by the plaintiff;`
  line
  line `(b) where the contract is unlawful for causes not apparent on its face and the defendant is more to`
  line `blame than the plaintiff.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), the court may refuse to rescind the`
  line contract--
  line
  line `(a) where the plaintiff has expressly or impliedly ratified the contract; or`
  line
  line `(b) where, owing to the change of circumstances which has taken place since the making of the`
  line `contract (not being due to any act of the defendant himself), the parties cannot be substantially`
  line `restored to the position in which they stood when the contract was made; or`
  line
  line `(c) where third parties have, during the subsistence of the contract, acquired rights in good faith`
  line `without notice and for value; or`
  line
  line `(d) where only a part of the contract is sought to be rescinded and such part is not severable from`
  line `the rest of the contract.`
  line
  line `Explanation.--In this section "contract" in relation to the territories to which the Transfer of Property`
  line `Act, 1882 (4 of 1882), does not extend, means a contract in writing.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (30243)
  sectionNo (28)
  orderNo 32
  title `Rescission in certain circumstances of contracts for the sale or lease of immovable property, the specific performance of which has been decreed.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30243&sectionno=28&orderno=32&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_28_content:
  string
  line `(1) Where in any suit a decree for specific`
  line `performance of a contract for the sale or lease of immovable property has been made and the purchaser or`
  line `lessee does not, within the period allowed by the decree or such further period as the court may allow, pay`
  line `the purchase money or other sum which the court has ordered him to pay, the vendor or lessor may apply`
  line `in the same suit in which the decree is made, to have the contract rescinded and on such application the`
  line `court may, by order, rescind the contract either so far as regards the party in default or altogether, as the`
  line `justice of the case may require.`
  line
  line `(2) Where a contract is rescinded under sub-section (1), the court--`
  line
  line `(a) shall direct the purchaser or the lessee, if he has obtained possession of the property under the`
  line `contract, to restore such possession to the vendor or lessor; and`
  line
  line `(b) may direct payment to the vendor or lessor of all the rents and profits which have accrued in`
  line `respect of the property from the date on which possession was so obtained by the purchaser or lessee`
  line `until restoration of possession to the vendor or lessor, and, if the justice of the case so requires, the refund of any sum paid by the vendee or the lessee as earnest money or deposit in connection with the`
  line contract.
  line
  line `(3) If the purchase or lessee pays the purchase money or other sum which he is ordered to pay under`
  line `the decree within the period referred to in sub-section (1), the court may, on application made in the same`
  line `suit, award the purchaser or lessee such further relief as he may be entitled to, including in appropriate`
  line `cases all or any of the following reliefs, namely:--`
  line
  line `(a) the execution of a proper conveyance or lease by the vendor or lessor;`
  line
  line `(b) the delivery of possession, or partition and separate possession, of the property on the`
  line `execution of such conveyance or lease.`
  line
  line `(4) No separate suit in respect of any relief which may be claimed under this section shall lie at the`
  line `instance of a vendor, purchaser, lessor or lessee, as the case may be.`
  line
  line `(5) The costs of any proceedings under this section shall be in the discretion of the court.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (30244)
  sectionNo (29)
  orderNo 33
  title `Alternative prayer for rescission in suit for specific performance.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30244&sectionno=29&orderno=33&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_29_content:
  string
  line `A plaintiff instituting a`
  line `suit for the specific performance of a contract in writing may pray in the alternative that, if the contract`
  line `cannot be specifically enforced, it may be rescinded and delivered up to be cancelled; and the court, if it`
  line `refuses to enforce the contract specifically, may direct it to be rescinded and delivered up accordingly.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (30245)
  sectionNo (30)
  orderNo 34
  title `Court may require parties rescinding to do equity.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30245&sectionno=30&orderno=34&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_30_content:
  string
  line `On adjudging the rescission of a contract,`
  line `the court may require the party to whom such relief is granted to restore, so far as may be, any benefit`
  line `which he may have received from the other party and to make any compensation to him which justice`
  line `may require.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (30246)
  sectionNo (31)
  orderNo 35
  title `When cancellation may be ordered.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30246&sectionno=31&orderno=35&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_31_content:
  string
  line `(1) Any person against whom a written instrument is void`
  line `or voidable, and who has reasonable apprehension that such instrument, if left outstanding may cause him`
  line `serious injury, may sue to have it adjudged void or voidable; and the court may, in its discretion, so`
  line `adjudge it and order it to be delivered up and cancelled.`
  line
  line `(2) If the instrument has been registered under the Indian Registration Act, 1908 (16 of 1908), the`
  line `court shall also send a copy of its decree to the officer in whose office the instrument has been so`
  line `registered; and such officer shall note on the copy of the instrument contained in his books the fact of its`
  line cancellation.
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (30247)
  sectionNo (32)
  orderNo 36
  title `What instruments may be partially cancelled.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30247&sectionno=32&orderno=36&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_32_content:
  string
  line `Where an instrument is evidence of different`
  line `rights or different obligations, the court may, in a proper case, cancel it in part and allow it to stand for the`
  line residue.
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (30248)
  sectionNo (33)
  orderNo 37
  title `Power to require benefit to be restored or compensation to be made when instrument is cancelled or is successfully resisted as being void or voidable.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30248&sectionno=33&orderno=37&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_33_content:
  string
  line `(1) On adjudging the cancellation of`
  line `an instrument, the court may require the party to whom such relief is granted, to restore, so far as may be`
  line `any benefit which he may have received from the other party and to make any compensation to him which`
  line `justice may require.`
  line
  line `(2) Where a defendant successfully resists any suit on the ground--`
  line
  line `(a) that the instrument sought to be enforced against him in the suit is voidable, the court may if`
  line `the defendant has received any benefit under the instrument from the other party, require him to`
  line `restore, so far as may be, such benefit to that party or to make compensation for it;`
  line
  line `(b) that the agreement sought to be enforced against him in the suit is void by reason of his not`
  line `having been competent to contract under section 11 of the Indian Contract Act, 1872 (9 of 1872), the`
  line `court may, if the defendant has received any benefit under the agreement from the other party, require`
  line `him to restore, so far as may be, such benefit to that party, to the extent to which he or his estate has`
  line `benefited thereby.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (30249)
  sectionNo (34)
  orderNo 38
  title `Discretion of court as to declaration of status or right.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30249&sectionno=34&orderno=38&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_34_content:
  string
  line `Any person entitled to any legal`
  line `character, or to any right as to any property, may institute a suit against any person denying, or interested`
  line `to deny, his title to such character or right, and the court may in its discretion make therein a declaration`
  line `that he is so entitled, and the plaintiff need not in such suit ask for any further relief:`
  line
  line `Provided that no court shall make any such declaration where the plaintiff, being able to seek further`
  line `relief than a mere declaration of title, omits to do so.`
  line
  line `Explanation.--A trustee of property is a "person interested to deny" a title adverse to the title of some`
  line `one who is not inexistence, and for whom, if in existence, he would be a trustee.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (30250)
  sectionNo (35)
  orderNo 39
  title `Effect of declaration.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30250&sectionno=35&orderno=39&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_35_content:
  string
  line `A declaration made under this Chapter is binding only on the parties to`
  line `the suit, persons claiming through them respectively, and, where any of the parties are trustees, on the`
  line `persons for whom, if in existence at the date of the declaration, such parties would be trustees.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (30251)
  sectionNo (36)
  orderNo 40
  title `Preventive relief how granted.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30251&sectionno=36&orderno=40&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_36_content:
  string
  line `Preventive relief is granted at the discretion of the court by`
  line `injunction, temporary or perpetual.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (30252)
  sectionNo (37)
  orderNo 41
  title `Temporary and perpetual injunctions.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30252&sectionno=37&orderno=41&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_37_content:
  string
  line `(1) Temporary injunctions are such as are to continue`
  line `until a specific time, or until the further order of the court, and they maybe granted at any stage of a suit,`
  line `and are regulated by the Code of Civil Procedure, 1908 (5 of 1908).`
  line
  line `(2) A perpetual injunction can only be granted by the decree made at the hearing and upon the merits`
  line `of the suit; the defendant is thereby perpetually enjoined from the assertion of a right, or from the`
  line `commission of an act, which would be contrary to the rights of the plaintiff.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (30253)
  sectionNo (38)
  orderNo 42
  title `Perpetual injunction when granted.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30253&sectionno=38&orderno=42&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_38_content:
  string
  line `(1) Subject to the other provisions contained in or`
  line `referred to by this Chapter, a perpetual injunction may be granted to the plaintiff to prevent the breach of`
  line `an obligation existing in his favour, whether expressly or by implication.`
  line
  line `(2) When any such obligation arises from contract, the court shall be guided by the rules and`
  line `provisions contained in Chapter II.`
  line
  line `(3) When the defendant invades or threatens to invade the plaintiffs right to, or enjoyment of,`
  line `property, the court may grant a perpetual injunction in the following cases, namely:--`
  line
  line `(a) where the defendant is trustee of the property for the plaintiff;`
  line
  line `(b) where there exists no standard for ascertaining the actual damage caused, or likely to be`
  line `caused, by the invasion;`
  line
  line `(c) where the invasion is such that compensation in money would not afford adequate relief;`
  line
  line `(d) where the injunction is necessary to prevent a multiplicity of judicial proceedings.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (30254)
  sectionNo (39)
  orderNo 43
  title `Mandatory injunctions.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30254&sectionno=39&orderno=43&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_39_content:
  string
  line `When, to prevent the breach of an obligation, it is necessary to compel`
  line `the performance of certain acts which the court is capable of enforcing, the court may in its discretion`
  line `grant an injunction to prevent the breach complained of, and also to compel performance of the requisite`
  line acts.
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (30255)
  sectionNo (40)
  orderNo 44
  title `Damages in lieu of, or in addition to, injunction.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30255&sectionno=40&orderno=44&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_40_content:
  string
  line `(1) The plaintiff in a suit for perpetual`
  line `injunction under section 38, or mandatory injunction under section 39, may claim damages either in`
  line `addition to, or in substitution for, such injunction and the court may, if it thinks fit, award such damages.`
  line
  line `(2) No relief for damages shall be granted under this section unless the plaintiff has claimed such`
  line `relief in his plaint:`
  line
  line `Provided that where no such damages have been claimed in the plaint, the court shall, at any stage of`
  line `the proceedings, allow the plaintiff to amend the plaint on such terms as may be just for including such`
  line claim.
  line
  line `(3) The dismissal of a suit to prevent the breach of an obligation existing in favour of the plaintiff`
  line `shall bar his right to sue for damages for such breach.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (30256)
  sectionNo (41)
  orderNo 45
  title `Injunction when refused.`
  content obj_root_law_sections_41_content
  footnotes `1. Ins. by Act 18 of 2018, s. 13 (w.e.f. 1-10-2018).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30256&sectionno=41&orderno=45&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_41_content:
  string
  line `An injunction cannot be granted--`
  line
  line `(a) to restrain any person from prosecuting a judicial proceeding pending at the institution of the`
  line `suit in which the injunction is sought, unless such restraint is necessary to prevent a multiplicity of`
  line proceedings;
  line
  line `(b) to restrain any person from instituting or prosecuting any proceeding in a court not`
  line `sub-ordinate to that from which the injunction is sought;`
  line
  line `(c) to restrain any person from applying to any legislative body;`
  line
  line `(d) to restrain any person from instituting or prosecuting any proceeding in a criminal matter;`
  line
  line `(e) to prevent the breach of a contract the performance of which would not be specifically`
  line enforced;
  line
  line `(f) to prevent, on the ground of nuisance, an act of which it is not reasonably clear that it will be a`
  line nuisance;
  line
  line `(g) to prevent a continuing breach in which the plaintiff has acquiesced;`
  line
  line `(h) when equally efficacious relief can certainly be obtained by any other usual mode of`
  line `proceeding except in case of breach of trust;`
  line
  line `^1[(ha) if it would impede or delay the progress or completion of any infrastructure project or`
  line `interfere with the continued provision of relevant facility related thereto or services being the subject]matter of such project.`
  line
  line `(i) when the conduct of the plaintiff or his agents has been such as to disentitle him to be the`
  line `assistance of the court;`
  line
  line `(j) when the plaintiff has no personal interest in the matter.`
obj_root_law_sections_42:
  sectionId (30257)
  sectionNo (42)
  orderNo 46
  title `Injunction to perform negative agreement.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30257&sectionno=42&orderno=46&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_42_content:
  string
  line `Notwithstanding anything contained in clause (e)`
  line `of section 41, where a contract comprises an affirmative agreement to do a certain act, coupled with a`
  line `negative agreement, express or implied, not to do a certain act, the circumstance that the court is unable to`
  line `compel specific performance of the affirmative agreement shall not preclude it from granting an`
  line `injunction to perform the negative agreement:`
  line
  line `Provided that the plaintiff has not failed to perform the contract so far as it is binding on him.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (30258)
  sectionNo (43)
  orderNo 47
  title Repealed.
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30258&sectionno=43&orderno=47&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_43_content:
  string
  line `[Amendment of Act 10 of 1940.] Rep. by the Repealing and Amending Act, 1974 (56 of 1974), s. 2`
  line `and the First Schedule (w.e.f. 20-12-1974).`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (30259)
  sectionNo (44)
  orderNo 48
  title Repealed.
  content `[Repeal.] Rep. by s. 2 and the First Schedule, ibid. (w.e.f. 20-12-1974).`
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00009_196347_1517807320084&sectionId=30259&sectionno=44&orderno=48&orgactid=AC_CEN_3_20_00009_196347_1517807320084
obj_root_law_sections_44_footnotes:
  string
  line
