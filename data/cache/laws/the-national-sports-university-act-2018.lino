obj_root_law:
  slug the-national-sports-university-act-2018
  handle (4037)
  collectionHandle 123456789/1362
  title `The National Sports University Act, 2018`
  actNumber (25)
  enactmentDate 2018-08-17
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/4037`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `राष्ट्रीय खेलकूद विश्वआविद्यालय अधिनियम, 2018`
  actYear (2018)
  ministry `Ministry of Youth Affairs and Sports`
  department `Department of Sports`
  longTitle `An Act to establish and incorporate a National Sports University in the State of Manipur, a specialised University first of its kind, to promote sports education in the areas of sports sciences, sports technology, sports management and sports coaching besides functioning as the national training centre for select sports disciplines by adopting best international practices and for matters connected therewith or incidental thereto.`
  enforcementDate 31-05-2018
  fetchedAt `2026-05-08T19:05:45.917Z`
  translations obj_root_law_translations
