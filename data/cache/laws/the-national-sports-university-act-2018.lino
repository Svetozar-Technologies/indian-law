obj_root_law_sections_1:
  sectionId (36027)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36027&sectionno=1&orderno=1&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the National Sports University`
  line `Act, 2018.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall be deemed to have come into force on the 31st day of May, 2018.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (36028)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36028&sectionno=2&orderno=2&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,`
  line `(a) "Academic and Activity Council" means the Academic and Activity Council of the University;`
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the Ordinances;`
  line `(c) "Board of Sports Studies" means the Board of Sports Studies of a Department of the University;`
  line `(d) "Chancellor" means the Chancellor of the University;`
  line `(e) "College" means a college or other academic institution established or maintained by, or admitted to the privileges of, the University;`
  line `(f) "Court" means the Court of the University;`
  line `(g) "Department" means a Department of Studies and includes a Centre of Studies;`
  line `(h) "employee" means any person appointed by the University and includes teachers and other staff of the University;`
  line `(i) "Executive Council" means the Executive Council of the University;`
  line `(j) "Finance Committee" means the Finance Committee of the University;`
  line `(k) "Fund" means the University Fund referred to in section 30;`
  line `(l) "Hall" means a unit of residence or of corporate life for the students of the University, or of an Outlying Campus or of a College or an Institution, maintained by the University;`
  line `(m) "Head of the Department" means the head of any teaching department of the University;`
  line `(n) "Institution" means an academic institution, not being a College, maintained by, or admitted to the privileges of, the University;`
  line `(o) "Outlying Campus" means the campus of the University as may be established by it at any place within or outside India;`
  line `(p) "Principal" means the Head of a College or an Institution maintained by the University and includes, where there is no Principal, the person for the time being duly appointed to act as Principal, and in the absence of the Principal, or the acting Principal, a Vice-Principal duly appointed as such;`
  line `(q) "Regional Centre" means a centre established or maintained by the University for the purpose of coordinating and supervising the work of Study Centres in any region and for performing such other functions as may be conferred on such centre by the Executive Council;`
  line `(r) "Regulations" means the regulations made by any authority of the University under this Act for the time being in force;`
  line `(s) "School" means a School of Studies of the University;`
  line `(t) "section" means the section of this Act;`
  line `(u) "State" includes a Union territory;`
  line `(v) "Statutes" and "Ordinances" mean, respectively, the Statutes and the Ordinances of the University for the time being in force;`
  line `(w) "Study Centre" means a centre established, maintained or recognised by the University for the purpose of advising, counselling, training or for rendering any other assistance required by the students;`
  line `(x) "teachers of the University" means Professors, Associate Professors, Assistant Professors and such other persons as may be appointed for imparting instructions, training or conducting research in the University or in any Outlying Campus, College or Institution or Regional Centres and Study Centres maintained by the University and are designated as teachers by the Ordinances;`
  line `(y) "University" means the National Sports University established and incorporated as a University under this Act;`
  line `(z) "Vice-Chancellor" means the Vice-Chancellor of the University.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (36029)
  sectionNo (3)
  orderNo 3
  title `Establishment of University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36029&sectionno=3&orderno=3&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established a University by the name of`
  line `"National Sports University".`
  line
  line `(2) The headquarters of the University shall be in the State of Manipur and it may establish or`
  line `maintain Outlying Campuses, Colleges, Regional Centres and Study Centres at such other places in`
  line `India as it may deem fit:`
  line
  line `Provided that the University may, with the prior approval of the Central Government, also`
  line `establish Outlying Campuses and Study Centres outside India.`
  line
  line `(3) The first Chancellor, the first Vice-Chancellor and the first members of the Court, the`
  line `Executive Council and the Academic and Activity Council, and all such persons who may hereafter`
  line `become such officers or members, so long as they continue to hold such office or membership, are`
  line `hereby constituted a body corporate by the name of "National Sports University".`
  line
  line `(4) The University shall have perpetual succession and a common seal, and shall sue and be sued`
  line `by the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36030)
  sectionNo (4)
  orderNo 4
  title `Objects of University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36030&sectionno=4&orderno=4&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_4_content:
  string
  line `The objects of the University shall be––`
  line
  line `(i) to evolve as an institute of advanced study in the field of physical education and sports`
  line sciences;
  line
  line `(ii) to provide for research and development and dissemination of knowledge in physical`
  line `education and sports sciences by providing specially designed academic and training programmes`
  line `in various areas of physical education and sports sciences and training in advanced technologies of`
  line sports;
  line
  line `(iii) to strengthen physical education and sports training programmes to promote sports`
  line `including traditional and tribal sports and games;`
  line
  line `(iv) to establish centres and institutions of excellence for imparting state of the art educational`
  line `training and research in the fields of physical education and sports sciences, sports technology and`
  line `high performance training for all sports and games;`
  line
  line `(v) to provide professional and academic leadership to other institutions in the field of physical`
  line `education and sports sciences;`
  line
  line `(vi) to provide vocational guidance and placement services in physical education, sports sciences,`
  line `sports medicine, sports technology and other related fields;`
  line
  line `(vii) to generate capabilities for the development of knowledge, skills and competences at`
  line `various levels in the fields of physical education and sports sciences, sports technology and high`
  line `performance training for all sports and games;`
  line
  line `(viii) to generate capabilities to provide infrastructure of international standard for education,`
  line `training and research in the areas related to physical education and sports sciences, sports`
  line `technology and high performance training for all sports and games;`
  line
  line `(ix) to prepare highly qualified professionals in the fields of physical education and sports`
  line `sciences, sports technology and high performance training for all sports and games;`
  line
  line `(x) to serve as a Centre of Excellence for the elite and other talented sportspersons of all sports and`
  line `games and innovation in physical education and sports sciences and to carry out, endorse and propagate`
  line research;
  line
  line `(xi) to function as a leading resource centre for knowledge and development in the areas of`
  line `physical education and sports sciences, sports technology and high performance training for all`
  line `sports and games;`
  line
  line `(xii) to provide international collaboration in the fields of physical education and sports`
  line `sciences, sports technology and high performance training for all sports and games;`
  line
  line `(xiii) to establish close linkage with sports academies, schools, colleges, sports and recreation`
  line `clubs, sports associations and international federations for the purpose of teaching, training and`
  line `research in physical education and sports sciences, sports technology and high performance`
  line `training for all sports and games;`
  line
  line `(xiv) to train talented athletes so as to help them to evolve into elite athletes of international`
  line level;
  line
  line `(xv) to make India become a sporting power;`
  line
  line `(xvi) such other objects, not inconsistent with the provisions of this Act, which the Central`
  line `Government may, by notification in the Official Gazette, specify in this behalf.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (36031)
  sectionNo (5)
  orderNo 5
  title `Powers and functions of University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36031&sectionno=5&orderno=5&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_5_content:
  string
  line `(1) The University shall have the following powers and`
  line `functions, namely:---`
  line
  line `(i) to plan, design, develop and prescribe courses of study and conduct appropriate academic and`
  line `training programmes in physical education and sports sciences including sports technology and to`
  line `provide for instruction and training in such branches of learning as the University may, from time to`
  line `time, determine and to make provisions for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or`
  line `certificates to, and confer degrees or other academic distinctions on, persons, on the basis of`
  line `examinations, evaluation or any method of testing, and to withdraw any such certificates,`
  line `diplomas, degrees or other academic distinctions for good and sufficient cause;`
  line
  line `(iii) to provide opportunities to the students of the University to participate in the sports`
  line `tournaments and competitions in co-ordination with established International Sports Federations,`
  line `National Sports Federations, Indian Olympic Association and Association of Indian Universities;`
  line
  line `(iv) to have liaison or membership with various international professional organisations or`
  line bodies;
  line
  line `(v) to establish and maintain, with the prior approval of the Central Government, such Outlying`
  line `Campuses, Regional Centres, specialised laboratories or other units for research, instruction and`
  line `training as are, in the opinion of the University, necessary for the furtherance of its objects;`
  line
  line `(vi) to establish, maintain or recognise Study Centres in the manner laid down by the Statutes;`
  line
  line `(vii) to establish and maintain Colleges, Institutions and Halls;`
  line
  line `(viii) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(ix) to institute Principalships, Professorships, Associate Professorships, Assistant`
  line `Professorships and other teaching or academic positions, required by the University and to appoint`
  line `persons to such Principalships, Professorships, Associate Professorships, Assistant Professorships`
  line `or other teaching or academic positions;`
  line
  line `(x) to appoint persons working in any University or academic institution, including those located`
  line `outside the country, as teachers of the University for a specified period;`
  line
  line `(xi) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(xii) to co-operate or collaborate or associate with any other University or authority or`
  line `Institution of higher learning, including those located outside the country, in such manner and for`
  line `such purposes as the University, may determine;`
  line
  line `(xiii) to provide facilities through the distance education system to such persons and in such`
  line `manner as may be prescribed by the Statutes;`
  line
  line `(xiv) to institute and award fellowships, scholarships, studentship, medals and prizes for raising`
  line `academic standards and research;`
  line
  line `(xv) to organise and to undertake extramural studies, training and extension services;`
  line
  line `(xvi) to make provision for research and advisory services and for that purpose, to enter into`
  line `such arrangements with other institutions, industrial or other organisations, as the University may`
  line `deem necessary;`
  line
  line `(xvii) to organise and conduct refresher courses, workshops, seminars and other programmes`
  line `for teachers, evaluators, other academic staff and students;`
  line
  line `(xviii) to appoint on contract or otherwise visiting Professors, Emeritus Professors, Consultants and`
  line `such other persons who may contribute to the advancement of the objects of the University;`
  line
  line `(xix) to determine standards of admission to the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xx) to demand and receive payment of fees and other charges;`
  line
  line `(xxi) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xxii) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xxiii) to regulate and enforce discipline among the students and the employees, and to take`
  line `such disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxiv) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(xxv) to receive benefactions, donations and gifts and to acquire, hold and manage, and to`
  line `dispose of, with the previous approval of the Central Government, any property, movable or`
  line `immovable, including trust and endowment properties, for the purposes of the University;`
  line
  line `(xxvi) to borrow, with the previous approval of the Central Government, on the security of the`
  line `property of the University, money for the purposes of the University;`
  line
  line `(xxvii) to conduct innovative experiments and promote new methods and technologies in the`
  line `fields of physical education, sports sciences, sports medicine, sports technology, sports`
  line `management and other related fields;`
  line
  line `(xxviii) to purchase or to take on lease any land or building or sports complex or sports`
  line `infrastructure and scientific sports research equipment or indoor stadium or works which may be`
  line `necessary or convenient for the purposes of the University, on such terms and conditions as it may`
  line `think fit and proper and to construct, alter and maintain any such building or work;`
  line
  line `(xxix) to start any new allied course or research programme or diploma or training programme`
  line `and discontinue any course or training programme;`
  line
  line `(xxx) to invest the funds of the University in or upon such securities and transpose any`
  line `investment from time to time in such manner as it may deem fit in the interest of the University;`
  line
  line `(xxxi) to execute conveyances regarding transfers, mortgages, leases, licenses, agreements and`
  line `other conveyances in respect of the property, movable or immovable, including Government`
  line `securities, belonging to the University or to be acquired for the purposes of the University, after taking`
  line `prior permission of the Central Government;`
  line
  line `(xxxii) to act as a technical advisory body to Government of India and other National`
  line `Organisations, State Governments and National Sports Federations on all matters related to sports;`
  line
  line `(xxxiii) to provide training, coaching and other back up to high level sports persons for`
  line `achieving success in different national and international sports competitions;`
  line
  line `(xxxiv) to give effect to the procedures and standards provided under the Khelo India Scheme or`
  line `the National Sports Talent Search and Identification Scheme;`
  line
  line `(xxxv) to confer autonomous status on a College or an Institution in the manner laid down by`
  line `the Statutes;`
  line
  line `(xxxvi) to admit to its privileges any College or Institution in or outside India subject to such`
  line `conditions as may be laid down by the Statutes:`
  line
  line `Provided that no College or Institution shall be so admitted except with the prior approval of`
  line `the Central Government;`
  line
  line `(xxxvii) to provide for the preparation of instructional and training materials, including films,`
  line `cassettes, tapes, video cassettes and other software;`
  line
  line `(xxxviii) to recognise persons for imparting instructions in any College or Institution admitted`
  line `to the privileges of the University; and`
  line
  line `(xxxix) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
  line
  line `(2) The University shall in the exercise of its powers have jurisdiction over the whole of India and`
  line `to the Outlying Campuses and Study Centres outside India.`
  line
  line `(3) In exercising its powers referred to in sub-section (1), it shall be the endeavour of the University`
  line `to maintain an all-India character and high standards of teaching, training and research, and the`
  line `University shall, among other measures which may be necessary for the said purpose, take, in particular,`
  line `the following measures, namely:---`
  line
  line `(i) admissions of students and recruitment of faculty shall be made on all-India basis through`
  line `appropriate procedures approved by the Executive Council of the University;`
  line
  line `(ii) foreign students shall be admitted by the University to various courses and programmes as`
  line `per the policy and schemes of the Government of India and the procedure approved by the`
  line `Executive Council of the National Sports University;`
  line
  line `(iii) inter-University mobility of faculty with portable pension scheme benefits, if any, and`
  line `protection of seniority shall be encouraged;`
  line
  line `(iv) semester system, continuous evaluation and choice-based credit system shall be introduced and`
  line `the University shall enter into agreement with other Universities and academic institutions for credit`
  line `transfer and joint degree programmes;`
  line
  line `(v) innovative courses and programmes of studies shall be introduced with a provision for`
  line `periodic review and restructuring;`
  line
  line `(vi) active participation of students shall be ensured in all academic activities of the University,`
  line `including evaluation of teachers;`
  line
  line `(vii) accreditation shall be obtained from the National Assessment and Accreditation Council or`
  line `any other accrediting agency at the national level; and`
  line
  line `(viii) e-governance shall be introduced with effective management information.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36032)
  sectionNo (6)
  orderNo 6
  title `University to be open to all caste, creed, race or class.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36032&sectionno=6&orderno=6&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_6_content:
  string
  line `The University shall be open to`
  line `persons of any sex and of whatever caste, creed, race or class, and it shall not be lawful for the`
  line `University to adopt or impose on any person, any test whatsoever of religious belief or profession in`
  line `order to entitle such person to be appointed as a teacher of the University or to hold any other office`
  line `therein or to be admitted as a student in the University or to graduate thereat or to enjoy or exercise`
  line `any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making`
  line `special provisions for the employment or admission of women, persons with disabilities or of persons`
  line `belonging to the weaker sections of the society and, in particular, of the Scheduled Castes, the`
  line `Scheduled Tribes and the other socially and educationally backward classes of citizens:`
  line
  line `Provided further that no such special provision shall be made on the ground of domicile.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (36033)
  sectionNo (7)
  orderNo 7
  title `Central Government to review work and progress of University.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36033&sectionno=7&orderno=7&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_7_content:
  string
  line `(1) The Central`
  line `Government may, from time to time, appoint one or more persons to review the work and progress of`
  line `the University, including Outlying Campuses, Colleges, Institutions, Regional Centres and Study`
  line `Centres maintained by it, and to submit a report thereon; and upon receipt of that report, the Central`
  line `Government may, after obtaining the views of the Executive Council thereon through the ViceChancellor, take such action and issue such directions, as it considers necessary, in respect of any of`
  line `the matters dealt with in the report and the University shall abide by such action and be bound to`
  line `comply with such directions.`
  line
  line `(2) The Central Government shall have the right to cause an inspection to be made by such person or`
  line `persons, as it may direct, of the University, its buildings, sports complexes, libraries, laboratories and`
  line `equipment, and of any Outlying Campus or College or Institution or Regional Centres or Study Centres`
  line `maintained by the University; and also of the examinations, teaching and other work conducted or done`
  line `by the University and to cause an inquiry to be made in like manner in respect of any matter connected`
  line `with the administration or finances of the University, Colleges or Institutions or Regional Centres or`
  line `Study Centres.`
  line
  line `(3) The Central Government shall, in every matter referred to in sub-section (2), give notice of its`
  line `intention to cause an inspection or inquiry to be made, to the University, and the University shall have`
  line `the right to make such representations to the Central Government, as it may consider necessary.`
  line
  line `(4) After considering the representations, if any, made by the University, the Central Government`
  line `may cause to be made such inspection or inquiry as is referred to in sub-section (3).`
  line
  line `(5) Where any inspection or inquiry has been caused to be made by the Central Government, the`
  line `University shall be entitled to appoint a representative, who shall have the right to be present and be`
  line `heard at such inspection or inquiry.`
  line
  line `(6) The Central Government may, if the inspection or inquiry is made in respect of the University or`
  line `any Outlying Campus or College or Institution or Regional Centre or Study Centre established or`
  line `maintained by it, address the Vice-Chancellor with reference to the result of such inspection or inquiry`
  line `together with such views and advice with regard to the action to be taken thereon, as the Central`
  line `Government may be pleased to offer, and on receipt of address made by the Central Government, the`
  line `Vice-Chancellor shall communicate to the Executive Council the views of the Central Government with`
  line `such advice as the Central Government may offer upon the action to be taken thereon.`
  line
  line `(7) The Executive Council shall communicate through the Vice-Chancellor to the Central`
  line `Government such action, if any, as it proposes to take or has been taken upon the result of such`
  line `inspection or inquiry.`
  line
  line `(8) Where, the Executive Council does not, within a reasonable time, take action to the satisfaction`
  line `of the Central Government, it may, after considering any explanation furnished or representation`
  line `made by the Executive Council, issue such directions, as it may think fit, and the Executive Council`
  line `shall comply with such directions.`
  line
  line `(9) Without prejudice to the foregoing provisions of this section, the Central Government may, by`
  line `order in writing, annul any proceeding of the University which is not in conformity with the`
  line `provisions of this Act or the Statutes or the Ordinances:`
  line
  line `Provided that before making any such order, the Central Government shall call upon the ViceChancellor to show cause why such an order should not be made, and, if any cause is shown within a`
  line `reasonable time, it shall consider the same.`
  line
  line `(10) The Central Government shall have such other powers, in respect of the affairs of the`
  line `University, as may be prescribed by the Statutes.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (36034)
  sectionNo (8)
  orderNo 8
  title `Officers of University.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36034&sectionno=8&orderno=8&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_8_content:
  string
  line `The following shall be the officers of the University, namely:—`
  line
  line `(a) the Chancellor;`
  line
  line `(b) the Vice-Chancellor;`
  line
  line `(c) the Deans of Schools;`
  line
  line `(d) the Registrar;`
  line
  line `(e) the Finance Officer;`
  line
  line `(f) the Controller of Examinations;`
  line
  line `(g) the Librarian; and`
  line
  line `(h) such other officers as may be declared by the Statutes to be the officers of the University.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (36035)
  sectionNo (9)
  orderNo 9
  title Chancellor.
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36035&sectionno=9&orderno=9&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_9_content:
  string
  line `(1) The Chancellor shall be appointed by the Central Government in such manner`
  line `as may be prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the head of the University and shall, if`
  line `present, preside at the Convocations of the University held for conferring degrees and other`
  line `ceremonial functions and also the meetings of the Court.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (36036)
  sectionNo (10)
  orderNo 10
  title Vice-Chancellor.
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36036&sectionno=10&orderno=10&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_10_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Central Government in`
  line `such manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University`
  line `and shall exercise general supervision and control over the affairs of the University and give effect to`
  line `the decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of the opinion that immediate action is necessary on any`
  line `matter, exercise any power conferred on any authority of the University by or under this Act and shall`
  line `apprise such authority at its next meeting the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of the opinion that such action ought not to have been`
  line `taken, it may refer the matter to the Central Government whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action`
  line `taken by the Vice-Chancellor under this sub-section shall have the right to represent against such`
  line `action to the Executive Council within three months from the date on which decision on such action is`
  line `communicated to him and thereupon the Executive Council may confirm, modify or reverse the action`
  line `taken by the Vice-Chancellor.`
  line
  line `(4) Where the Vice-Chancellor is of the opinion that any decision taken by any authority of the University`
  line `is beyond the powers of the authority conferred under the provisions of this Act or the Statutes or the`
  line `Ordinances, or that any decision taken by the authority is not in the interest of the University, he may`
  line `ask the authority concerned to review its decision within sixty days of such decision and if the authority`
  line `refuses to review the decision either in whole or in part or no decision is taken by it within the said`
  line `period of sixty days, the matter shall be referred to the Central Government whose decision thereon shall`
  line `be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (36037)
  sectionNo (11)
  orderNo 11
  title `Deans of Schools.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36037&sectionno=11&orderno=11&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_11_content:
  string
  line `Every Dean of School shall be appointed in such manner, and on such`
  line `terms and conditions of service, and shall exercise such powers and perform such duties, as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (36038)
  sectionNo (12)
  orderNo 12
  title Registrar.
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36038&sectionno=12&orderno=12&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_12_content:
  string
  line `(1) The Registrar shall be appointed in such manner, and on such terms and`
  line `conditions of service, as may be prescribed by the Statutes.`
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University, and shall exercise such powers and perform such duties, as may`
  line `be prescribed by the Statutes.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (36039)
  sectionNo (13)
  orderNo 13
  title `Finance Officer.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36039&sectionno=13&orderno=13&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_13_content:
  string
  line `The Finance Officer shall be appointed in such manner, and shall exercise`
  line `such powers and perform such duties, as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (36040)
  sectionNo (14)
  orderNo 14
  title `Controller of Examinations.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36040&sectionno=14&orderno=14&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_14_content:
  string
  line `Controller of Examinations shall be appointed in such manner`
  line `and shall exercise such powers and perform such duties, as may be prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (36041)
  sectionNo (15)
  orderNo 15
  title Librarian.
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36041&sectionno=15&orderno=15&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_15_content:
  string
  line `The Librarian shall be appointed in such manner and on such terms and conditions`
  line `of service, and shall exercise such powers and perform such duties, as may be prescribed by the`
  line Statutes.
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (36042)
  sectionNo (16)
  orderNo 16
  title `Other officers.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36042&sectionno=16&orderno=16&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_16_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (36043)
  sectionNo (17)
  orderNo 17
  title `Authorities of University.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36043&sectionno=17&orderno=17&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_17_content:
  string
  line `The following shall be the authorities of the University, namely:—`
  line
  line `(a) the Court;`
  line
  line `(b) the Executive Council;`
  line
  line `(c) the Academic and Activity Council;`
  line
  line `(d) the Board of Sports Studies;`
  line
  line `(e) the Finance Committee;`
  line
  line `(f) such other authorities as may be declared by the Statutes to be the authorities of the`
  line University.
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (36044)
  sectionNo (18)
  orderNo 18
  title `The Court.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36044&sectionno=18&orderno=18&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_18_content:
  string
  line `(1) The constitution of the Court and the term of office of its members shall be`
  line `prescribed by the Statutes.`
  line
  line `(2) Subject to the provisions of this Act, the Court shall have the following powers and`
  line `functions, namely:—`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University, and`
  line `to suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the`
  line `University and the audit report on such accounts;`
  line
  line `(c) to advise the Central Government in respect of any matter which may be referred to it for`
  line `advice; and`
  line
  line `(d) to perform such other functions as may be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (36045)
  sectionNo (19)
  orderNo 19
  title `Executive Council.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36045&sectionno=19&orderno=19&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_19_content:
  string
  line `(1) The Executive Council shall be the principal executive body of the`
  line University.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (36046)
  sectionNo (20)
  orderNo 20
  title `Academic and Activity Council.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36046&sectionno=20&orderno=20&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_20_content:
  string
  line `(1) The Academic and Activity Council shall be the principal`
  line `academic body of the University and shall, subject to the provisions of this Act, the Statutes and the`
  line `Ordinances, co-ordinate and exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic and Activity Council, the term of office of its members and`
  line `its powers and functions shall be prescribed by the Statutes:`
  line
  line `Provided that the Academic and Activity Council shall have sports persons who have achieved`
  line `distinction in Olympics or world championships.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (36047)
  sectionNo (21)
  orderNo 21
  title `Board of Sports Studies.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36047&sectionno=21&orderno=21&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_21_content:
  string
  line `The constitution, powers and functions of the Board of Sports`
  line `Studies shall be prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (36048)
  sectionNo (22)
  orderNo 22
  title `Finance Committee.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36048&sectionno=22&orderno=22&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_22_content:
  string
  line `The constitution, powers and functions of the Finance Committee shall`
  line `be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (36049)
  sectionNo (23)
  orderNo 23
  title `Other authorities of University.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36049&sectionno=23&orderno=23&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_23_content:
  string
  line `The constitution, powers and functions of other authorities,`
  line `as may be declared by the Statutes to be the authorities of the University, shall be prescribed by the`
  line Statutes.
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (36050)
  sectionNo (24)
  orderNo 24
  title `Power to make Statutes.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36050&sectionno=24&orderno=24&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_24_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for`
  line `all or any of the following matters, namely:—`
  line
  line `(a) the constitution, powers and functions of authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the appointment and continuance in office of the members of the said authorities and bodies,`
  line `the filling up of vacancies of members, and all other matters relating to those authorities and other`
  line `bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers, academic staff and other employees of the University, the`
  line `emoluments and conditions of service;`
  line
  line `(e) the appointment of teachers and academic staff working in any other University or`
  line `organisation for a specific period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provisions for pension, insurance, provident`
  line `fund, the manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing the seniority of service of the employees of the University;`
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(j) the conferment of autonomous status on a College or an Institution or a Department;`
  line
  line `(k) the establishment and abolition of Schools, Departments, Centres, Halls, Colleges,`
  line `Institutions, Regional Centres and Study Centres;`
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the conferment and withdrawal of degrees, diplomas, certificates and other academic`
  line distinctions;
  line
  line `(n) the management of Colleges, Institutions, Regional Centres and Study Centres established`
  line `and maintained by the University;`
  line
  line `(o) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(p) the maintenance of discipline among the employees and students; and`
  line
  line `(q) all other matters which by this Act are to be, or may be, provided for by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (36051)
  sectionNo (25)
  orderNo 25
  title `Statutes, how to be made.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36051&sectionno=25&orderno=25&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_25_content:
  string
  line `(1) The first Statutes are those set out in the Schedule to this Act.`
  line
  line `(2) The Executive Council may, from time to time, make new or additional Statutes or may amend`
  line `or repeal any Statutes referred to in sub-section (1):`
  line
  line `Provided that the Executive Council shall not make, amend or repeal any Statutes affecting the`
  line `status, powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on proposed changes, and any opinion so expressed`
  line `shall be considered by the Executive Council.`
  line
  line `(3) Every new Statutes or Statutes amending or repealing existing Statutes shall require the approval of`
  line `the Central Government and unless so approved, they shall be invalid.`
  line
  line `(4) Notwithstanding anything contained in the foregoing sub-sections, the Central Government may`
  line `make new or additional Statutes or amend or repeal the Statutes referred to in sub-section (1), during the`
  line `period of three years immediately after the commencement of this Act:`
  line
  line `Provided that the Central Government may, on the expiry of the said period of three years, make,`
  line `within one year from the date of such expiry, such detailed Statutes as it may consider necessary and such`
  line `detailed Statutes shall be laid before both Houses of Parliament.`
  line
  line `(5) Notwithstanding anything contained in this section, the Central Government may direct the`
  line `University to make provisions in the Statutes in respect of any matter specified by it and if the Executive`
  line `Council is unable to implement such direction within sixty days of its receipt, the Central Government`
  line `may, after considering the reasons, if any, communicated by the Executive Council for its inability to`
  line `comply with such direction, make or amend the Statutes suitably.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (36052)
  sectionNo (26)
  orderNo 26
  title `Power to make Ordinances.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36052&sectionno=26&orderno=26&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_26_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters, namely:---`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study and their duration to be laid down for all degrees, diplomas and`
  line `certificates of the University;`
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the`
  line `qualifications for the same and the means to be taken relating to the granting and obtaining of the`
  line same;
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(f) the conditions for award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(g) the conduct of examinations, including the term of office and manner of appointment`
  line `and the duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence and teaching of`
  line `women students and the prescribing of special courses of studies for them;`
  line
  line `(j) the establishment of Centres of Studies, Board of Studies, Specialised Laboratories and`
  line `other Committees;`
  line
  line `(k) the manner of co-operation and collaboration with other Universities, institutions and`
  line `other agencies including learned bodies or associations;`
  line
  line `(l) the creation, composition and functions of any other body which is considered necessary`
  line `for improving the academic life of the University;`
  line
  line `(m) the institution of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(n) the setting up of a machinery for redressal of grievances of employees and students; and`
  line
  line `(o) any other matter which, by this Act or the Statutes, is to be or may be, provided for by`
  line `the Ordinances.`
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with previous approval of the`
  line `Executive Council and the Ordinances so made may also be amended or repealed at any time by the`
  line `Executive Council in the manner prescribed by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (36053)
  sectionNo (27)
  orderNo 27
  title Regulations.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36053&sectionno=27&orderno=27&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_27_content:
  string
  line `The authorities of the University may make Regulations, consistent with this`
  line `Act, the Statutes and the Ordinances, for the conduct of their own business and that of the`
  line `Committees, if any, appointed by them and not provided for by this Act, the Statutes or the`
  line `Ordinances, in the manner prescribed by the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (36054)
  sectionNo (28)
  orderNo 28
  title `Annual report.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36054&sectionno=28&orderno=28&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_28_content:
  string
  line `(1) The annual report of the University shall be prepared under the`
  line `directions of Executive Council, which shall include, among other matters, the steps taken by the`
  line `University towards the fulfilment of its objects and shall be submitted to the Court on or before such`
  line `date as may be prescribed by the Statutes and the Court shall consider the report in its annual`
  line meeting.
  line
  line `(2) The Court shall submit the annual report to the Central Government along with its comments,`
  line `if any.`
  line
  line `(3) The Central Government shall, as soon as may be, cause a copy of the annual report to be laid`
  line `before both the Houses of Parliament.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (36055)
  sectionNo (29)
  orderNo 29
  title `Annual accounts.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36055&sectionno=29&orderno=29&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_29_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be`
  line `prepared under the directions of the Executive Council and shall, once at least every year and at`
  line `intervals of not more than fifteen months, be audited by the Comptroller and Auditor-General of`
  line `India or by such persons as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts together with the audit report thereon shall be submitted to the`
  line `Court and the Central Government along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Central Government on the annual accounts shall be brought to`
  line `the notice of the Court and the observations of the Court, if any, shall, after being considered by the`
  line `Executive Council, be submitted to the Central Government.`
  line
  line `(4) The Central Government shall, as soon as may be, cause the copy of the annual accounts`
  line `together with the audit report to be laid before both the Houses of Parliament.`
  line
  line `(5) The audited annual accounts after having been laid before both the Houses of Parliament shall`
  line `be published in the Official Gazette.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (36056)
  sectionNo (30)
  orderNo 30
  title `Fund of University.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36056&sectionno=30&orderno=30&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_30_content:
  string
  line `(1) There shall be a University Fund which shall include––`
  line
  line `(a) any contribution or grant made by the University Grants Commission or the Central`
  line Government;
  line
  line `(b) any contribution or grant made by the State Government;`
  line
  line `(c) any contribution made by Government, semi-Government or autonomous bodies;`
  line
  line `(d) any loans, gifts, bequests, donations, endowments or other grants, if any;`
  line
  line `(e) income received by the University from fees and charges;`
  line
  line `(f) the moneys received by the University from the collaborating industries in terms of the`
  line `provisions of the Memorandum of Understanding entered between the University and the industry`
  line `for the establishment of sponsored chairs, fellowships or infrastructure facilities of the University;`
  line and
  line
  line `(g) amounts received in any other manner from any other source.`
  line
  line `(2) All funds of the University shall be deposited in such banks or invested in such manner as the`
  line `Board may decide on the recommendation of the Finance Committee.`
  line
  line `(3) The funds of the University shall be applied towards the expenses of the University including`
  line `expenses incurred in the exercise of its powers and discharge of its functions by or under this Act.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (36057)
  sectionNo (31)
  orderNo 31
  title `Returns and information.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36057&sectionno=31&orderno=31&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_31_content:
  string
  line `The University shall furnish to the Central Government such`
  line `returns or other information with respect to its property or activities, within such period, as the Central`
  line `Government may, from time to time, require.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (36058)
  sectionNo (32)
  orderNo 32
  title `Conditions of service of employees, etc.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36058&sectionno=32&orderno=32&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_32_content:
  string
  line `(1) Every employee of the University shall be`
  line `appointed under a written contract, which shall be lodged with the University and a copy of which`
  line `shall be furnished to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed`
  line `by the Executive Council, one member nominated by the employee concerned and an umpire`
  line `appointed by the Central Government.`
  line
  line `(3) The decision of the Tribunal shall be final and no suit shall lie in any civil court in respect of`
  line `the matters decided by the Tribunal:`
  line
  line `Provided that nothing in this sub-section shall preclude the employee from availing of judicial`
  line `remedies available under articles 32 and 226 of the Constitution.`
  line
  line `(4) Every request made by the employee under sub-section (2) shall be deemed to be a submission`
  line `to arbitration upon the terms of this section within the meaning of the Arbitration and Conciliation`
  line `Act, 1996 (26 of 1996).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be prescribed by the Statutes.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (36059)
  sectionNo (33)
  orderNo 33
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36059&sectionno=33&orderno=33&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_33_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the`
  line `case may be, and who has been debarred from appearing at the examinations of the University for more`
  line `than one year, may, within ten days of the date of receipt of such orders or copy of such resolution by`
  line `him, appeal to the Executive Council and the Executive Council may confirm, modify or reverse the`
  line `decision of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-sections`
  line `(2), (3), (4) and (5) of section 32 shall, as far as may be, apply to a reference made under this`
  line sub-section.
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (36060)
  sectionNo (34)
  orderNo 34
  title `Rights to appeals.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36060&sectionno=34&orderno=34&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_34_content:
  string
  line `Every employee or student of the University or of a College or an`
  line `Institution or a Regional Centre or a Study Centre established or maintained by the University shall,`
  line `notwithstanding anything contained in this Act, have a right to appeal to the Executive Council within`
  line `such time, as may be prescribed by the Statutes, against the decision of any officer or authority of the`
  line `University, or of the Principal or the management of any College or Institution or Regional Centre or`
  line `Study Centre, as the case may be, and thereupon, the Executive Council may confirm, modify or reverse`
  line `the decision appealed against.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (36061)
  sectionNo (35)
  orderNo 35
  title `Provident and pension funds.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36061&sectionno=35&orderno=35&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_35_content:
  string
  line `(1) The University shall constitute for benefit of its`
  line `employees such provident fund or any other similar fund or provide such insurance schemes, as it may`
  line `deem fit, in such manner and subject to such conditions, as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or other similar fund has been so constituted, the Central`
  line `Government may declare that the provisions of the Provident Funds Act, 1925 (19 of 1925) shall`
  line `apply to such fund, as if it were a Government provident fund.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (36062)
  sectionNo (36)
  orderNo 36
  title `Disputes as to constitution of authorities and bodies.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36062&sectionno=36&orderno=36&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_36_content:
  string
  line `If any question arises as to whether any`
  line `person has been duly elected or appointed as, or is entitled to be, a member of any authority or other body`
  line `of the University, the matter shall be referred to the Central Government whose decision thereon shall be`
  line final.
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (36063)
  sectionNo (37)
  orderNo 37
  title `Filing of casual vacancies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36063&sectionno=37&orderno=37&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_37_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `members) of any authority or other body of the University shall be filled, as soon as may be, by the`
  line `person or body who appoints, elects or co-opts the member whose place has become vacant and the`
  line `persons appointed, elected or co-opted to a casual vacancy shall be a member of such authority or`
  line `body for the residue of the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (36064)
  sectionNo (38)
  orderNo 38
  title `Proceedings of authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36064&sectionno=38&orderno=38&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_38_content:
  string
  line `No act or proceedings`
  line `of any authority or other body of the University shall be invalid merely by reason of the existence of a`
  line `vacancy or vacancies among its members.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (36065)
  sectionNo (39)
  orderNo 39
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36065&sectionno=39&orderno=39&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_39_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or other employee of the University for anything which is in good faith done or intended`
  line `to be done in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (36066)
  sectionNo (40)
  orderNo 40
  title `Mode of proof of University record.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36066&sectionno=40&orderno=40&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_40_content:
  string
  line `Notwithstanding anything contained in the Indian`
  line `Evidence Act, 1872 (1 of 1872) or in any other law for the time being in force, a copy of any receipt,`
  line `application, notice, order, proceeding or resolution of any authority or other body of the University, or any`
  line `other document in possession of the University, or any entry in any register duly maintained by the`
  line `University, if certified by the Registrar, shall be received as prima facie evidence of such receipt,`
  line `application, notice, order, proceeding, resolution or document or the existence of entry in the register and`
  line `shall be admitted as evidence of the matters and transactions therein where the original thereof would, if`
  line `produced, have been admissible in evidence.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (36067)
  sectionNo (41)
  orderNo 41
  title `Power to remove difficulties.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36067&sectionno=41&orderno=41&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_41_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such`
  line `provisions, not inconsistent with the provisions of this Act, as appears to it to be necessary or`
  line `expedient for removing the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from`
  line `the commencement of this Act.`
  line
  line `(2) Every order made under sub-section (1) shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament, while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the order or both Houses agree that the order should not be made, the order shall thereafter have effect`
  line `only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that order`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (36071)
  sectionNo (42)
  orderNo 42
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36071&sectionno=42&orderno=42&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_42_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be`
  line `published in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act, shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry`
  line `of the session immediately following the session or the successive sessions aforesaid, both Houses agree`
  line `in making any modification in the Statute, Ordinances or Regulations or both Houses agree that the`
  line `Statute, Ordinances or Regulations should not be made, the Statute, Ordinances or Regulations shall`
  line `thereafter have effect only in such modified form or be of no effect, as the case may be; so, however,`
  line `that any such modification or annulment shall be without prejudice to the validity of anything previously`
  line `done under the Statute, Ordinances or Regulations.`
  line
  line `(3) The power to make Statutes, Ordinances or Regulations shall include the power to give`
  line `retrospective effect, from a date not earlier than the date of commencement of this Act, to the Statutes,`
  line `Ordinances or Regulations or any of them but no retrospective effect shall be given to any Statutes,`
  line `Ordinances or Regulations so as to prejudicially affect the interests of any person to whom such Statutes,`
  line `Ordinances or Regulations may be applicable.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (36069)
  sectionNo (43)
  orderNo 43
  title `Transitional provisions.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36069&sectionno=43&orderno=43&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_43_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes,—`
  line
  line `(a) the first Vice-Chancellor shall be appointed by the Central Government in such manner and`
  line `on such conditions as may be deemed fit and the said officer shall hold office for such term, not`
  line `exceeding five years, as may be specified by the Central Government;`
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Central`
  line `Government and each of the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Court and the first Executive Council shall consist of not more than thirty-one`
  line `members and eleven members, respectively, who shall be nominated by the Central Government and`
  line `shall hold office for a term of three years; and`
  line
  line `(d) the first Academic and Activity Council shall consist of not more than twenty-one`
  line `members, who shall be nominated by the Central Government and they shall hold office for a`
  line `term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment or nomination, as the case may be, by the Central Government and the person so`
  line `appointed or nominated shall hold office for so long as the officer or member in whose place he is`
  line `appointed or nominated would have held office, if such vacancy had not occurred.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (36070)
  sectionNo (44)
  orderNo 44
  title `Repeal and savings.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_34_92_00001_A2018-25_1542612433983&sectionId=36070&sectionno=44&orderno=44&orgactid=AC_CEN_34_92_00001_A2018-25_1542612433983
obj_root_law_sections_44_content:
  string
  line `(1) The National Sports University Ordinance, 2018 (Ord. 5 of`
  line `2018) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance`
  line `shall be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_44_footnotes:
  string
  line
