obj_root_law:
  slug the-sports-broadcasting-signals-mandatory-sharing-with-prasarbharati-act-2007
  handle (2076)
  collectionHandle 123456789/1362
  title `The Sports Broadcasting Signals (Mandatory Sharing with PrasarBharati) Act, 2007`
  actNumber (11)
  enactmentDate 2007-03-19
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2076`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `खेल प्रसारण सिगनल (प्रसार भारती के साथ अनिवार्य हिस्सेदारी) अधिनियम, 2007`
  actYear (2007)
  ministry `Ministry of Information and Broadcasting`
  department undefined
  longTitle `An Act to provide access to the largest number of listeners and viewers, on a free to air basis, of sporting events of national importance through mandatory sharing of sports broadcasting signals with Prasar Bharati and for matters connected therewith or incidental thereto.`
  enforcementDate 11-11-2005
  notification undefined
