obj_root_law:
  object
  (str slug) (str the-sports-broadcasting-signals-mandatory-sharing-with-prasarbharati-act-2007)
  (str handle) (str 2076)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Sports Broadcasting Signals (Mandatory Sharing with PrasarBharati) Act, 2007`)
  (str actNumber) (str 11)
  (str enactmentDate) (str 2007-03-19)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2076`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `खेल प्रसारण सिगनल (प्रसार भारती के साथ अनिवार्य हिस्सेदारी) अधिनियम, 2007`)
  (str actYear) (str 2007)
  (str ministry) (str `Ministry of Information and Broadcasting`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide access to the largest number of listeners and viewers, on a free to air basis, of sporting events of national importance through mandatory sharing of sports broadcasting signals with Prasar Bharati and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 11-11-2005)
  (str notification) (undefined)
