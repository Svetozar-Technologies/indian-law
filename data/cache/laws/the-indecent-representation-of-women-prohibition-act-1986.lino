  (str hindiTitle) (str `स्‍त्री अशिष्‍ट रूपण (प्रतिषेध) अधिनियम, 1986`)
  (str actYear) (str 1986)
  (str ministry) (str `Ministry of Women and Child Development`)
  (str longTitle) (str `An Act to prohibit indecent representation of women through advertisements or in publications, writings, paintings, figures or in any other manner and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 02-10-1987)
  (str notification) (str `2nd October, 1987, vide notification No G.S.R. 821(E), dated 25th September, 1987, see Gazette of India, Extraordinary, Part II, sec. 3(i).`)
