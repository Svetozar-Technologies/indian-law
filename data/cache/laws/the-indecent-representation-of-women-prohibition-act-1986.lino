obj_root_law_sections_1:
  sectionId (12686)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=12686&sectionno=1&orderno=1&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Indecent Representation`
  line `of Women (Prohibition) Act, 1986.`
  line
  line `(2) It extends to the whole of India, ^1***.`
  line
  line `(3) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule (w.e.f. 31-10- 2019).`
  line
  line `2. 2nd October, 1987, vide notification No G.S.R. 821(E), dated 25th September, 1987, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (12687)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=12687&sectionno=2&orderno=2&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "advertisement" includes any notice, circular, label, wrapper or other document and also`
  line `includes any visible representation made by means of any light, sound, smoke or gas;`
  line
  line `(b) "distribution" includes distribution by way of samples whether free or otherwise;`
  line
  line `(c) "indecent representation of women" means the depiction in any manner of the figure of a`
  line `woman, her form or body or any part thereof in such a way as to have the effect of being indecent, or`
  line `derogatory to, or denigrating, women, or is likely to deprave, corrupt or injure the public morality or`
  line morals;
  line
  line `(d) "label" means any written, marked, stamped, printed or graphic matter, affixed to, or`
  line `appearing upon, any package;`
  line
  line `(e) "package" includes a box, carton, tin or other container;`
  line
  line `(f) "prescribed" means prescribed by rules made under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (12688)
  sectionNo (3)
  orderNo 3
  title `Prohibition of advertisements containing indecent representation of women.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=12688&sectionno=3&orderno=3&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_3_content:
  string
  line `No person shall`
  line `publish, or cause to be published, or arrange or take part in the publication or exhibition of, any`
  line `advertisement which contains indecent representation of women in any form.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (12689)
  sectionNo (4)
  orderNo 4
  title `Prohibition of publication or sending by post of books, pamphlets, etc., containing indecent representation of women.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=12689&sectionno=4&orderno=4&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_4_content:
  string
  line `No person shall produce or cause to be produced, sell, let to hire, distribute,`
  line `circulate or send by post any book, pamphlet, paper, slide, film, writing, drawing, painting, photograph,`
  line `representation or figure which contains indecent representation of women in any form:`
  line
  line `Provided that nothing in this section shall apply to--`
  line
  line `(a) any book, pamphlet, paper, slide, film, writing, drawing, painting, photograph, representation`
  line `or figure--`
  line
  line `(i) the publication of which is proved to be justified as being for the public good on the`
  line `ground that such book, pamphlet, paper, slide, film, writing, drawing, painting, photograph,`
  line `representation or figure is in the interest of science, literature, art, or learning or other objects of`
  line `general concern; or`
  line
  line `(ii) which is kept or used bona fide for religious purposes;`
  line
  line `(b) any representation sculptured, engraved, painted or otherwise represented on or in--`
  line
  line `(i) any ancient monument within the meaning of the Ancient Monument and Archaeological`
  line `Sites and Remains Act, 1958 (24 of 1958); or`
  line
  line `(ii) any temple, or on any car used for the conveyance of idols, or kept or used for any`
  line `religious purpose;`
  line
  line `(c) any film in respect of which the provisions of Part II of the Cinematograph Act, 1952 (37 of`
  line `1952), will be applicable.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (12690)
  sectionNo (5)
  orderNo 5
  title `Powers to enter and search.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=12690&sectionno=5&orderno=5&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_5_content:
  string
  line `(1) Subject to such rules as may be prescribed, any Gazetted`
  line `Officer authorised by the State Government may, within the local limits of the area for which he is so`
  line authorised,--
  line
  line `(a) enter and search at all reasonable times, with such assistance, if any, as he considers`
  line `necessary, any place in which he has reason to believe that an offence under this Act has been or is`
  line `being committed;`
  line
  line `(b) seize any advertisement or any book, pamphlet, paper, slide film, writing, drawing, painting,`
  line `photograph, representation or figure which he has reason to believe contravenes any of the provisions`
  line `of this Act;`
  line
  line `(c) examine any record, register, document or any other material object found in any place`
  line `mentioned in clause (a) and seize the same if he has reason to believe that it may furnish evidence of`
  line `the commission of an offence punishable under this Act:`
  line
  line `Provided that no entry under this sub-section shall be made into a private dwelling house without a`
  line `warrant:`
  line
  line `Provided further that the power of seizure under this sub-section may be exercised in respect of any`
  line `document, article or thing which contains any such advertisement, including the contents, if any, of such`
  line `document, article or thing, if the advertisement cannot be separated by reason of its being embossed or`
  line `otherwise from such document, article or thing without affecting the integrity, utility or saleable value`
  line thereof.
  line
  line `(2) The provisions of the Code of Criminal Procedure, 1973 (2 of 1974), shall, so far as may be, apply`
  line `to any search or seizure under this Act as they apply to any search or seizure made under the authority of`
  line `a warrant issued under section 94 of the said Code.`
  line
  line `(3) Where any person seizes anything under clause (b) or clause (c) of sub-section (1), he shall, as`
  line `soon as may be, inform the nearest Magistrate and take his orders as to the custody thereof.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (12691)
  sectionNo (6)
  orderNo 6
  title Penalty.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=12691&sectionno=6&orderno=6&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_6_content:
  string
  line `Any person who contravenes the provisions of section 3 or section 4 shall be punishable`
  line `on first conviction with imprisonment of either description for a term which may extend to two years, and`
  line `with fine which may extend two thousand rupees, and in the event of a second or subsequent conviction`
  line `with imprisonment for a term of not less than six months but which may extend to five years and also`
  line `with a fine not less than ten thousand rupees but which may extend to one lakh rupees.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (12692)
  sectionNo (7)
  orderNo 7
  title `Offences by companies`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=12692&sectionno=7&orderno=7&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_7_content:
  string
  line `(1) Where an offence under this Act has been committed by a`
  line `company, every person, who, at the time the offence was committed, was in charge of, and was`
  line `responsible to, the company for the conduct of the business of the company, as well as the company, shall`
  line `be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other officer of the company, such director, manager, secretary or other officer shall be proceeded against and`
  line `punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (22362)
  sectionNo (8)
  orderNo 8
  title `Offences to be cognizable and bailable.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=22362&sectionno=8&orderno=8&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_8_content:
  string
  line `(1) Notwithstanding anything contained in the Code of`
  line `Criminal Procedure, 1973 (2 of 1974), an offence punishable under this Act shall be bailable.`
  line
  line `(2) An offence punishable under this Act shall be cognizable.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (22363)
  sectionNo (9)
  orderNo 9
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=22363&sectionno=9&orderno=9&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_9_content:
  string
  line `No suit, prosecution or other legal proceeding shall lie`
  line `against the Central Government or any State Government or any officer of the Central Government or any`
  line `State Government for anything which is in good faith done or intended to be done under this Act.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (22364)
  sectionNo (10)
  orderNo 10
  title `Power to make rules.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_13_14_00007_198660_1517807324297&sectionId=22364&sectionno=10&orderno=10&orgactid=AC_CEN_13_14_00007_198660_1517807324297
obj_root_law_sections_10_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the provisions of this Act.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner in which the seizure of advertisements or other articles shall be made, and the`
  line `manner in which the seizure list shall be prepared and delivered to the person from whose custody`
  line `any advertisement or other article has been seized;`
  line
  line `(b) any other matter which is required to be, or may be, prescribed.`
  line
  line `(3) Every rule made under this Act, shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session for a total period of thirty days, which may be comprised in`
  line `one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_10_footnotes:
  string
  line
