  (str title) (str `The Indecent Representation of Women (Prohibition) Act, 1986`)
  (str actNumber) (str 60)
  (str enactmentDate) (str 1986-12-23)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1768`)
