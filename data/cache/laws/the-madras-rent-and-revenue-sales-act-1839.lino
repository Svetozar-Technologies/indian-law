obj_root_law_sections_1:
  object
  (str sectionId) (str 76453)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str [Repealed.].)
  (str content) (str `1. [Repeal of Reg. XXVIII of 1802, s. 23] Rep., Act XIV of 1874.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_183907_1691478563347&sectionId=76453&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00114_183907_1691478563347)
obj_root_law_sections_2:
  object
  (str sectionId) (str 76454)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Tahsildars empowered to sell property distrained.`)
  (str content) (str `^1**** All tahsildars within the territories
subject to the Presidency of Fort St. George shall be vested with the powers of Commissioners for the sale
of property distrained for arrears of rent or of revenue, and shall be subject to all rules and provisions to
which by any law or regulation such Commissioners are subject.`)
  (str footnotes) (str `1. The words “And it is hereby enacted that from the said day” were repealed by the Repealing Act, 1873 (XII of 1873).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_183907_1691478563347&sectionId=76454&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00114_183907_1691478563347)
obj_root_law_sections_3:
  object
  (str sectionId) (str 76455)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Control of tahsildars in exercise of such power.`)
  (str content) (str `Provided always that in respect of the exercise
of those powers tahsildars shall be subject to the control and superintendence of the Collector, and shall
not be subject to the authority of the Zila Judge, except in the case of any judicial proceedings.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_183907_1691478563347&sectionId=76455&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00114_183907_1691478563347)
obj_root_law_sections_4:
  object
  (str sectionId) (str 76456)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str Repealed..)
  (str content) (str `4. [Their liabilities in exercise of same power.] Rep. by the Repealing and Amending Act, 1891
(XII of 1891).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_183907_1691478563347&sectionId=76456&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00114_183907_1691478563347)
obj_root_law_sections_5:
  object
  (str sectionId) (str 76457)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Fees for selling property to be credited to Government.`)
  (str content) (str `Provided also that tahsildars shall not
be entitled to any fee or commission for selling such distrained property; but that all fees or commission
which may be now lawfully taken by Commissioners for the sale of such distrained property shall be
taken and carried to the account of Government.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_183907_1691478563347&sectionId=76457&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_00114_183907_1691478563347)
obj_root_law_sections_6:
  object
  (str sectionId) (str 76458)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Delegation of tahsildars powers.`)
  (str content) (str `And it is herby enacted that tahsildars shall have authority, subject to the orders of the Collector, to delegate the powers vested in them by the second section of this Act to any public servants placed under their authority; and that the provisions of ^1[sections 3 and 5] of this Act shall apply to all public servants to whom those powers shall have so delegated in the same manner as they apply to tahsildars.`)
  (str footnotes) (str `1. The words and figures in square brackets have been substituted for the words “the three last proceeding sections” by the
Amending Act, 1801 (XII of 1891). General Acts, Vol. IV.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00114_183907_1691478563347&sectionId=76458&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_00114_183907_1691478563347)
