  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Madras, Bengal and Bombay Children (Supplementary) Act, 1925.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00118_192535_1668063050055&sectionId=71467&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00118_192535_1668063050055)
obj_root_law_sections_2:
  object
  (str sectionId) (str 71468)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Validation of certain provisions of Madras Children Act, 1920, Bengal Children Act 1922, and Bombay Children Act, 1924.`)
  (str content) (str `The Madras Children Act, 1920 (Mad. Act IV of 1920.), the Bengal Children Act, 1922 (Ben.
Act II of 1922.), and the Bombay Children Act, 1924 (Bom. Act XIII of 1924.), shall, so far as regards the appellate
and revisional jurisdiction conferred by the said Acts on the High Courts of Judicature at Madras, at Fort William in
Bengal and at Bombay, respectively, be as valid as if the said Acts had been passed by the Indian Legislature.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00118_192535_1668063050055&sectionId=71468&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00118_192535_1668063050055)
