obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `िबहार पुनग ᭅ ठन अिधिनयम, 2000`
  line _________
  line `धारा Ა का ᮓ म`
  line _________
  line धाराएं
  line `भाग 1`
  line `ᮧ ारंिभक`
  line `1. संि ᭃ᭡ त नाम।`
  line `2. प ᳯ रभाषाएं।`
  line `भाग 2`
  line `िबहार रा ᭔ य का पुनग ᭅ ठन`
  line `3. झारखंड रा ᭔ य का बनाया जाना।`
  line `4. िबहार रा ᭔ य और उसके ᮧ ादेिशक खंड।`
  line `5. संिवधान क ᳱ पहली अनुसूची का संशो धन।`
  line `6. रा ᭔ य सरकार ᲂ क ᳱ ᳞ ावृि ᱫ शि ᭍ त यां।`
  line `भाग 3`
  line `िवधान - मंडल ᲂ म ᱶ ᮧ ितिनिध ᭜ व`
  line `रा ᭔ य सभा`
  line `7. संिवधान क ᳱ चौथी अनुसूची का संशोधन।`
  line `8. आसीन सद ᭭ य ᲂ का आबंटन।`
  line `लोक सभा`
  line `9. लोक सभा म ᱶ ᮧ ितिनिध ᭜ व।`
  line `10. संसदीय और सभा िनवा ᭅ चन - ᭃ े ᮢ ᲂ का प ᳯ रसीमन।`
  line `11. आसीन सद ᭭ य ᲂ के बारे म ᱶ उपबंध।`
  line `िवधान सभा`
  line `12. िवधान सभा Ა के बारे म ᱶ उपबंध।`
  line `13. आसीन सद ᭭ य ᲂ का आबंटन।`
  line `14. िवधान सभा Ა क ᳱ अविध।`
  line `15. अ ᭟ य ᭃ और उपा ᭟ य ᭃ।`
  line `16. ᮧᳰᮓ या के िनयम।`
  line `िबहार क ᳱ िवधान प ᳯ रषद्`
  line `17. िबहार क ᳱ िवधान प ᳯ रषद्।`
  line `18. प ᳯ रषद् िनवा ᭅ चन - ᭃ े ᮢ।`
  line `19. आसीन सद ᭭ य ᲂ के बारे म ᱶ उपबंध।`
  line `20. सभापित और उप-सभापित।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line धाराएं
  line `िनवा ᭅ चन - ᭃ े ᮢ ᲂ का प ᳯ रसीमन`
  line `21. िनवा ᭅ चन - ᭃ े ᮢ ᲂ का प ᳯ रसीमन।`
  line `22. प ᳯ रसीमन आदेश ᲂ को अ ᳒ तन रखने क ᳱ िनवा ᭅ चन आयोग क ᳱ शि ᭍ त।`
  line `अनुसूिचत जाितयां और अनुसूिचत जनजाितयां`
  line `23. अनुसूिचत जाितयां आदेश का संशोधन।`
  line `24. अनुसूिचत जनजाितयां आदेश का संशोधन।`
  line `भाग 4`
  line `उ ᭒ च ᭠ यायालय`
  line `25. झारखंड उ ᭒ च ᭠ यायालय।`
  line `26. उ ᭒ च ᭠ यायालय के ᭠ यायाधीश।`
  line `27. उ ᭒ च ᭠ यायालय क ᳱ अिधका ᳯ रता।`
  line `28. िविध ᭄ प ᳯ रषद् और अिधव ᭍ ता Ა के संबंध म ᱶ िवशेष उपबंध।`
  line `29. उ ᭒ च ᭠ यायालय म ᱶ प ᳍ ित और ᮧᳰᮓ या।`
  line `30. उ ᭒ च ᭠ यायालय क ᳱ मु ᮤ ा क ᳱ अिभर ᭃ ा।`
  line `31. ᳯ रट ᲂ और अ ᭠ य आदेिशका Ა का ᮧᱨ प।`
  line `32. ᭠ यायाधीश ᲂ क ᳱ शि ᭍ त यां।`
  line `33. उ ᭒ च तम ᭠ यायालय को अपील ᲂ के बारे म ᱶ ᮧᳰᮓ या।`
  line `34. पटना उ ᭒ च ᭠ यायालय से झारखंड उ ᭒ च ᭠ यायालय को काय ᭅ वािहय ᲂ का अ ᭠ त रण।`
  line `35. झारखंड उ ᭒ च ᭠ यायालय को अ ᭠ त ᳯ रत काय ᭅ वािहय ᲂ म ᱶ उपसंजात होने या काय ᭅ वाही करने का अिधकार।`
  line `36. िनव ᭅ चन।`
  line `37. ᳞ ावृि ᱫ।`
  line `भाग 5 ᳞`
  line `य का ᮧ ािधकृत ᳰ कया जाना और राज ᭭ व का िवतरण`
  line `38. झारखंड रा ᭔ य के ᳞ य का ᮧ ािधकृत ᳰ कया जाना।`
  line `39. िबहार रा ᭔ य के लेखा Ა से संबंिधत ᳯ रपोट ᱸ।`
  line `40. राज ᭭ व का िवतरण।`
  line `भाग 6`
  line `आि ᭭ तय ᲂ और दािय ᭜ व ᲂ का ᮧ भाजन`
  line `41. भाग का लागू होना।`
  line `42. भूिम और माल।`
  line `43. खजाना और ब ᱹ क अितशेष।`
  line `44. कर ᲂ क ᳱ बकाया।`
  line `45. उधार और अि ᮕ म को वसूल करने का अिधकार।`
  line `46. कितपय िन िधय ᲂ म ᱶ िविनधान और जमा।`
  line `47. रा ᭔ य उप ᮓ म ᲂ क ᳱ आि ᭭ तयां और दािय ᭜ व।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
