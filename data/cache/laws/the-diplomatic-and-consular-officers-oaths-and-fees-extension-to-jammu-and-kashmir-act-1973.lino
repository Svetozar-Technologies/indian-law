obj_root_law_sections_1:
  object
  (str sectionId) (str 31956)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Diplomatic and Consular
Officers (Oaths and Fees) (Extension to Jammu and Kashmir) Act, 1973.

(2) It shall come into force at once.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00002_197302_1517807317977&sectionId=31956&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00002_197302_1517807317977)
obj_root_law_sections_2:
  object
  (str sectionId) (str 31957)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Extension of Act 41 of 1948.`)
  (str content) (str `The Diplomatic and Consular Officers (Oaths and Fees) Act, 1948
(hereinafter referred to as the principal Act) is hereby extended to, and shall come into force in, and in
relation to, the State of Jammu and Kashmir and accordingly,--

(a) the provisions of the principal Act and the rules made thereunder shall apply to and in relation
to the State of Jammu and Kashmir as they apply to and in relation to any other State;

(b) clause (d) of section 2 of the principal Act shall be omitted.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00002_197302_1517807317977&sectionId=31957&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00002_197302_1517807317977)
