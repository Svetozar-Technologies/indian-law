  sectionId (31956)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00002_197302_1517807317977&sectionId=31956&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00002_197302_1517807317977
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Diplomatic and Consular`
  line `Officers (Oaths and Fees) (Extension to Jammu and Kashmir) Act, 1973.`
  line
  line `(2) It shall come into force at once.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (31957)
  sectionNo (2)
  orderNo 2
  title `Extension of Act 41 of 1948.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00002_197302_1517807317977&sectionId=31957&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00002_197302_1517807317977
obj_root_law_sections_2_content:
  string
  line `The Diplomatic and Consular Officers (Oaths and Fees) Act, 1948`
  line `(hereinafter referred to as the principal Act) is hereby extended to, and shall come into force in, and in`
  line `relation to, the State of Jammu and Kashmir and accordingly,--`
  line
  line `(a) the provisions of the principal Act and the rules made thereunder shall apply to and in relation`
  line `to the State of Jammu and Kashmir as they apply to and in relation to any other State;`
  line
  line `(b) clause (d) of section 2 of the principal Act shall be omitted.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (31958)
  sectionNo (3)
  orderNo 3
  title Repealed.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00002_197302_1517807317977&sectionId=31958&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00002_197302_1517807317977
obj_root_law_sections_3_content:
  string
  line `[Amendment of section 8.] Rep. by the Repealing and Amending Act, 1978 (38 of 1978), s. 2 and`
  line `the First Schedule (w.e.f. 26-11-1978).`
obj_root_law_sections_3_footnotes:
  string
  line
