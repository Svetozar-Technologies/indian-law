  slug the-national-company-limited-acquisition-and-transfer-of-undertakings-act-1980
  handle (1801)
  collectionHandle 123456789/1362
  title `The National Company Limited (Acquisition and Transfer of Undertakings) Act, 1980`
  actNumber (42)
  enactmentDate 1980-07-19
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1801`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `नेशनल कम्‍पनी लिमिटेड (उपक्रमों का अर्जन औरअन्‍तरण) अधिनियम, 1980`
  actYear (1980)
  ministry `Ministry of Textiles`
  department undefined
  longTitle `An Act to provide for the acquisition and transfer of the undertakings of Messrs. National Company Limited with a view to securing the proper management of such undertakings so as to subserve the interests of the general public by ensuring the continued manufacture, production and distribution of articles made of jute, which are essential to the needs of the economy of the country and for matters connected therewith or incidental thereto.`
  enforcementDate 27-04-1980
  notification undefined
  fetchedAt `2026-05-10T12:41:44.136Z`
