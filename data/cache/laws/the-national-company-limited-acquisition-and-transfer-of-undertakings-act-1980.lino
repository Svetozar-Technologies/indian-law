obj_root_law:
  object
  (str slug) (str the-national-company-limited-acquisition-and-transfer-of-undertakings-act-1980)
  (str handle) (str 1801)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The National Company Limited (Acquisition and Transfer of Undertakings) Act, 1980`)
  (str actNumber) (str 42)
  (str enactmentDate) (str 1980-07-19)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1801`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `नेशनल कम्‍पनी लिमिटेड (उपक्रमों का अर्जन औरअन्‍तरण) अधिनियम, 1980`)
  (str actYear) (str 1980)
  (str ministry) (str `Ministry of Textiles`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the undertakings of Messrs. National Company Limited with a view to securing the proper management of such undertakings so as to subserve the interests of the general public by ensuring the continued manufacture, production and distribution of articles made of jute, which are essential to the needs of the economy of the country and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 27-04-1980)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-10T12:41:44.136Z`)
  (str translations) obj_root_law_translations
