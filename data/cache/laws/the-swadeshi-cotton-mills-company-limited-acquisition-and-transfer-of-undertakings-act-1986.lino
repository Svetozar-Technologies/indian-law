obj_root_law:
  object
  (str slug) (str the-swadeshi-cotton-mills-company-limited-acquisition-and-transfer-of-undertakings-act-1986)
  (str handle) (str 1871)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Swadeshi Cotton Mills Company Limited (Acquisition and Transfer of Undertakings) Act, 1986`)
  (str actNumber) (str 30)
  (str enactmentDate) (str 1986-05-30)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1871`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `स्‍वदेशी काटन मिल्‍स कंपनी लिमिटेड (उपक्रमों का अर्जन और अन्‍तरण) अधिनियम, 1986`)
  (str actYear) (str 1986)
  (str ministry) (str `Ministry of Textiles`)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of certain textile undertakings of the Swadeshi Cotton Mills Company Limited, with a view to securing the proper management of such undertakings so as to subserve the interests of the general public by ensuring the continued manufacture, production and distribution of different varieties of cloth and yarn and thereby to give effect to the policy of the State towards securing the principles specified in clauses (b) and (c) of article 39 of the Constitution and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 01-04-1985)
  (str notification) (str `Ss. 27 & 28 (30-05-1986)`)
  (str fetchedAt) (str `2026-05-08T23:58:24.342Z`)
  (str translations) obj_root_law_translations
