obj_root_law_sections_1:
  sectionId (44443)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44443&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Religious Societies Act, 1880.`
  line
  line `Local extent--.It ^1*** shall extend to the whole of India except ^2[the territories which, immediately`
  line `before the 1st November, 1956, were comprised in Part B States,]`
  line
  line `but nothing herein contained shall apply to any Hindus, Muhammadans or Buddhists, or to any`
  line `persons whom the State Government may from time to time, by notification in the Official Gazette,`
  line `exclude from the operation of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1 The words "shall come into force at once, and" omitted by Act 10 of 1914, s. 3 and the Second Schedule.`
  line
  line `2. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part B States".`
obj_root_law_sections_2:
  sectionId (44444)
  sectionNo (2)
  orderNo 2
  title `Appointment of new trustee in cases not otherwise provided for.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44444&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_2_content:
  string
  line `When any body of persons`
  line `associated for the purpose of maintaining religious worship has acquired, or hereafter shall acquire, any`
  line property,
  line
  line `and such property has been or hereafter shall be vested in trustees in trust for such body,`
  line
  line `and it becomes necessary to appoint a new trustee in the place of or in addition to any such trustee or`
  line `any trustee appointed in the manner hereinafter prescribed,`
  line
  line `and no manner of appointing such new trustee is prescribed by any instrument by which such`
  line `property was so vested or by which the trusts on which it is held have been declared, or such new trustee`
  line `cannot for any reason be appointed in the manner so prescribed,`
  line
  line `such new trustee may be appointed in such manner as may be agreed upon by such body, or by a`
  line `majority of not less than two-thirds of the members of such body actually present at the meeting at which`
  line `the appointment is made.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (44445)
  sectionNo (3)
  orderNo 3
  title `Appointment under section 2 to be recorded in a memorandum under the hand of the chairman of the meeting.`
  content obj_root_law_sections_3_content
  footnotes `1 See now the Indian Registration Act, 1908 (16 of 1908).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44445&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_3_content:
  string
  line `Every appointment of new trustees under section 2 shall be made to appear`
  line `by some memorandum under the hand of the chairman for the time being of the meeting at which such`
  line `appointment is made.`
  line
  line `Such memorandum shall be in the form set forth in the Schedule hereto annexed, or as near thereto as`
  line `circumstances allow, shall be executed and attested by two or more credible witnesses in the presence of`
  line `such meeting, and shall be deemed to be a document of which the registration is required by the Indian`
  line `Registration Act, 1877^1`
  line `(3 of 1877), section 17.`
obj_root_law_sections_4:
  sectionId (44446)
  sectionNo (4)
  orderNo 4
  title `Property to vest in new trustees without conveyance.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44446&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_4_content:
  string
  line `When any new trustees have been`
  line `appointed, whether in the manner prescribed by any such instrument as aforesaid or in the manner`
  line `hereinbefore provided, the property subject to the trust shall forthwith, notwithstanding anything`
  line `contained in any such instrument, become vested, without any conveyance or other assurance, in such`
  line `new trustees and the old continuing trustees jointly, or, if there are no old continuing trustees, in such new`
  line `trustees wholly, upon the same trusts, and with and subject to the same powers and provisions, as it was`
  line `vested in the old trustees.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (44447)
  sectionNo (5)
  orderNo 5
  title `Saving of existing modes of appointment and conveyance.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44447&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_5_content:
  string
  line `Nothing herein contained shall be`
  line `deemed to invalidate any appointment of new trustees, or any conveyance of any property, which may`
  line `hereafter be made as heretofore was by law required.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (44448)
  sectionNo (6)
  orderNo 6
  title `Provision for dissolution of societies and adjustment of their affairs.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44448&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_6_content:
  string
  line `Any number not less`
  line `than three-fifths of the members of any such body as aforesaid may at a meeting convened for the purpose`
  line `determine that such body shall be dissolved; and thereupon it shall be dissolved forthwith, or at the time`
  line `then agreed upon; and all necessary steps shall be taken for the disposal and settlement of the property of`
  line `such body, its claims and liabilities, according to the rules of such body applicable thereto, if any, and, if`
  line `not, then as such body at such meeting may determine:`
  line
  line `Provided that, in the event of any dispute arising among the members of such body, the adjustment of`
  line `its affairs shall be referred to the principal Court of original civil jurisdiction of the district in which the`
  line `chief building of such body is situate; and the Court shall make such order in the matter as it deems fit.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (44449)
  sectionNo (7)
  orderNo 7
  title `Upon a dissolution no member to receive profit.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44449&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_7_content:
  string
  line `If upon the dissolution of any such body`
  line `there remains, after the satisfaction of all its debts and liabilities, any property whatsoever, the same shall`
  line `not be paid to or distributed among the members of such body or any of them, but shall be given to some`
  line `other body of persons associated for the purpose of maintaining religious worship or some other religious`
  line `or charitable purpose to be determined by the votes of not less than three-fifths of the members present at`
  line `a meeting convened in this behalf, or in default thereof by such court as last aforesaid.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (44450)
  sectionNo (8)
  orderNo 8
  title `Saving of certain provisions of instruments.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44450&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_8_content:
  string
  line `Nothing in sections 6 and 7 shall be deemed to`
  line `affect any provision contained in any instrument for the dissolution of such body, or for the payment or`
  line `distribution of such property.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (44451)
  sectionNo (9)
  orderNo 9
  title `Questions may be submitted to High Court.`
  content obj_root_law_sections_9_content
  footnotes `1 As to effect of a declaratory decree, see the Specific Relief Act 1963, s. 35.`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00039_188001_1523270795707&sectionId=44451&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00039_188001_1523270795707
obj_root_law_sections_9_content:
  string
  line `When any question arises, either in connection`
  line `with the matters hereinbefore referred to, or otherwise, as to whether any person is a member of any such`
  line `body as aforesaid, or as to the validity of any appointment under this Act, any person interested in such`
  line `question may apply by petition to the High Court for its opinion on such question. A copy of such petition`
  line `shall be served upon, and the hearing thereof may be attended by, such other persons interested in the`
  line `question as the Court thinks fit.`
  line
  line `Any opinion given by the Court on an application under this section shall be deemed to have the force`
  line `of a declaratory decree^1.`
  line
  line `The costs of every application under this section shall be in the discretion of the Court.`
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `धार्मिक सोसाइटी अधिनियम,1880`
