obj_root_law_translations_hi_sections:
  obj_root_law_translations_hi_sections_1
  obj_root_law_translations_hi_sections_2
obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `धार्मिक सोसाइटी अधधधियम, 1 88 0`
  line `( 1 88 0 का अधधधियम संखयां क 1 ) 1`
  line `[ 9 जिवरी, 188 0 ]`
  line `धा र् मिक सोसाइटटयों को कधिपय शधि यां प्र`
  line `दाि करिे के धिए`
  line अधधधियम
  line `उद्देधशका  यह समीचीि है कक उस रीधि को स र ि बिाया जाए धजसमें धार्मिक उपासिा जारी रखिे के प्र योजि के धिए`
  line `सहमेधिि व् य धि यों के कधिपय धिकाय ऐसे प्र योजि के धिए अर्जिि सम्प धि धारण कर सकें, िथा ऐसे धिकायों के धवघटि िथा उिके`
  line `कामकाज के समायोजि के धिए िथा ऐसे धिकायों से संबंधधि कधिपय प्रश् िों के धवधिश्च य के धिए उपबंध कक या जाए;`
  line `अि: एिद द्व ारा धिम्ि धिधखि रू प में यह अधधधि यधमि ककया जािा है: `
  line `1. संधिप्ि िाम  इस अधधधियम का संधिप् ि िाम धार्मिक सोसाइटी अधधधियम, 1880 है। स्`
  line `था िीय धवस्िा र  2 *** इसका धवस्िा र 3 [ उि राज्य िेत्रों के धसवाय जो 1 िवम्ब र, 1956 के ठीक पहिे भाग ख राज्यों में`
  line `समाधवष्ट थे ] सम्पू णि भारि पर है,`
  line `ककन्िु इसमें अन्ि र् विष्ट कोई बाि धहन्दु ओं, मुसिमािों या बौद्धों को अथवा ककन्हीं ऐसे व् य धि यों को िागू िहीं होगी धज न् हें`
  line `राज्य सरकार, समय - समय पर राजपत्र में अधधसूचिा द्व ारा, इस अधधधियम के प्र वििि से अपवर्जिि करे।`
  line `2. उि मामिों में िए न् या सी की धियुधि धजिके धिए अन्य था उपबन् ध िहीं ककया गया है  जब धार्मिक उपासिा जारी रखिे`
  line `के प्र योजि के धिए सहमेधिि व् य धि यों के ककसी धिका य िे कोई सम्प धि अर्जिि की है या वह इसके प श् चा ि अर्जिि करिा है,`
  line `िथा ऐसी सम्प धि ऐसे धिकाय के धिए न् या स के रू प में न् या धसयों में धिधहि की गई है या इसके पश्चा ि की जािी है,`
  line `िथा यह आवश्य क हो जािा है कक ककसी ऐसे न् या सी के स् था ि में या उसके अधिटरि या इसके पश्चा ि धवधहि रीधि से`
  line `धियुि ककसी न् या सी के स् था ि में कोई िया न् या सी धियुि ककया जाए,`
  line `िथा ऐसे िए न् या सी को धियुि करिे की कोई रीधि ककसी ऐसी धिखि द्व ारा धवधहि िहीं की गई है धजसके द्व ारा ऐसी`
  line `सम्प धि इस प्र कार धिधहि की गई थी अ थवा धजसके द्व ारा वे न् या स धजि पर वह धाटरि है, घोधिि ककए गए हैं, अथवा ऐसा िया न् या सी`
  line `इस प्र कार धवधहि रीधि से ककसी कारण धियुि िहीं ककया जा सकिा,`
  line `िब ऐसा िया न् या सी ऐसी रीधि से धियुि ककया जा सकेगा धजस पर वह धिकाय अथ वा उस अधधवेशि में धजसमें वह`
  line `धियुधि की जािी है, ऐसे धिकाय के वस्िु ि: उपधस्थ ि सदस्यों का दो धिहाई से अन्यू ि बहुमि सहमि हो।`
  line `3. धारा 2 के अधीि धियुधि का अधधवेश ि के अध्य ि के हस्िा िर से ज्ञ ापि में अधभधिधखि ककया जािा  धारा 2 के अधीि`
  line `िए न् या धसयों की प्रत् ये क धियुधि उस अधधवेशि के धजसमें ऐसी धियुधि की जािी है ित्स मय अध्य ि के हस्िा िर से ककसी ज्ञ ापि द्व ारा प्र`
  line `काधशि कराई जाएगी।`
  line `ऐसा ज्ञ ापि इससे उपाबद्ध अिुसूची में उपवर्णिि प्ररू प में या उि पटरधस्थ धियों में यथासाध्य धिकटिम प्ररू प में होगा िथा दो`
  line `या अधधक धवश्व सिीय साधियों द्व ारा ऐसे अधधवेशि में धिष्पा कदि और अिुप्रमाधणि ककया जाएगा िथा ऐसा दस्िा वेज समझा जाएगा`
  line `धजसका रधजस्री करण भारिीय रधजस्री करण अधधधियम, 1877 4 (1877 का 37) की धारा 17 द्व ारा अपेधिि है।`
  line `4. िए न् या धसयों में सम्प धि का अधभहस्िा न् ि रण के धबिा धिधहि होिा  जब ककन्हीं िए न् या धसयों की धियुधि चाहे`
  line `यथापूवोि ककसी धिखि द्व ारा धवधहि रीधि से या इसमें इसके पूवि उपबंधधि रीधि से की जा चुकी है िब न् या साधीि सम्प धि ऐसी`
  line `ककसी धिखि में ककसी बाि के होिे हु ए भी ककसी अधभहस्िा न् ि रण या अन्य हस्िा न् ि रण पत्र के धबिा ऐसे िए न् या धसयों और पुरािे जारी`
  line `रहे न् या धसयों में संयुि ि: या यकद कोई पुरािे जारी रहे न् या सी िहीं हैं िो पूणिि: ऐसे िए न् या धसयों में उन्हीं न् या सों पर िथा उन्हीं`
  line `शधि यों और उपबन्धों के सधहि और अधीि िुरन्ि धिधहि हो जाएगी जै से वह पुरािे न् या धसयों में धिधहि थी।`
  line `5. धियुधि और अधभहस्िा न् ि रण के वििमाि ढंगों की व् या वृ धि  इसमें अन्ि र् विष्ट कक सी बाि के बारे में यह िहीं समझा`
  line `जाएगा कक वह िए न् या धसयों की ककसी धियुधि या ककसी सम्प धि के ककसी अधभहस्िा न् ि रण को अधवधधमान्य करिी है जो इसके`
  line `पश्चा ि ककया जाए जैसा कक इसके पूवि धवधध द्व ारा अपेधिि था।`
  line `1 इस अधधधियम का 1963 के धवधियम सं ० 6 की धारा 2 और अिुसूची 1 द्व ारा (1 - 7 - 1965 से ) दादरा और िागर हवेिी में और 1968 के अधधधियम सं ० 26 और`
  line `अिुसूची द्व ारा पाधि चेरी संघ राज्य िेत्र पर धवस् िा र और प्र वृि ककया गया।`
  line `2 “ यह िुरन्ि प्र वृि होगा और ” शब्द 1914 के अधधधियम सं ० 10 की धारा 3 और अिुसूची 2 द्व ारा धिरधसि।`
  line `3 धवधध अिुकूिि ( सं ० 2) आदेश, 1956 द्व ारा “ भाग ख राज्यों के धसवाय ” के स् था ि पर प्र धिस्था धपि।`
  line `4 अब भारिीय रधजस्री करण अधधधियम, 1908 (1908 का 16) देधखए।`
