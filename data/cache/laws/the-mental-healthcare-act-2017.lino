  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00024_201710_1517807327874&sectionId=6269&sectionno=63&orderno=63&orgactid=AC_CEN_12_13_00024_201710_1517807327874
obj_root_law_sections_63_content:
  string
  line `(1) The State Authority shall maintain proper`
  line `accounts and other relevant records and prepare an annual statement of accounts in such form as may be`
  line `prescribed by the State Government, in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the State Authority shall be audited by the Comptroller and Auditor-General of`
  line `India at such intervals as may be specified by him and any expenditure incurred in connection with such`
  line `audit shall be payable by the State Authority to the Comptroller and Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any other person appointed by him in`
  line `connection with the audit of the accounts of the State Authority shall have the same rights and privileges`
  line `and authority in connection with such audit as the Comptroller and Auditor-General generally has in`
  line `connection with the audit of the Government accounts and, in particular, shall have the right to demand`
  line `the production of books, accounts, connected vouchers and other documents and papers and to inspect`
  line `any of the office of the State Authority.`
