  (str title) (str `The Regional Centre for Biotechnology Act, 2016.`)
  (str actNumber) (str 36)
  (str enactmentDate) (str 2016-07-29)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2153`)
