obj_root_law_sections_1:
  sectionId (37056)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37056&sectionno=1&orderno=1&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Regional Centre for`
  line `Biotechnology Act, 2016.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st March, 2017, vide notification No. S.O. 642 (E), dated 28th February, 2017, see Gazette of India, Extraordinary,`
  line `Part II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (37057)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37057&sectionno=2&orderno=2&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "academic staff" means Assistant Professors, Associate Professors, Professors, Deans, SubDeans, Executive Director and such other persons, including Visiting Professors, Professors of`
  line `Eminence, Honorary Professors, Adjunct Professors and Emeritus Professors, as may be appointed or`
  line `engaged for imparting education, training or conducting research in the Regional Centre for`
  line Biotechnology;
  line
  line `(b) "Board" means the Board of Governors constituted under section 14;`
  line
  line `(c) "Board of Studies" means the Board of Studies of the Regional Centre referred to in`
  line `section 21;`
  line
  line `(d) "Chairperson" means the Chairperson of the Board;`
  line
  line `(e) "employee" means any person appointed by the Regional Centre and includes officers,`
  line `academic and other staff of the Regional Centre;`
  line
  line `(f) "Executive Committee" means the Executive Committee of the Regional Centre constituted`
  line `under section 18;`
  line
  line `(g) "Executive Director" means the Executive Director of the Regional Centre appointed under`
  line `sub-section (1) of section 23;`
  line
  line `(h) "existing Regional Centre" means the Regional Centre for Biotechnology Training and`
  line `Education at National Capital Region, Faridabad;`
  line
  line `(i) "hall" means a unit of residence, by whatever name called, for the students of the Regional`
  line `Centre, maintained or recognised by it;`
  line
  line `(j) "institution" includes autonomous organisations within or outside India, for imparting`
  line `education, training and conducting research in the areas of Biotechnology and supported by the`
  line `Government of India or industry or universities or other organisations;`
  line
  line `(k) "Ordinances" means the Ordinances framed by the Programme Advisory Committee under`
  line `section 42;`
  line
  line `(l) "Programme Advisory Committee" means the Programme Advisory Committee of the`
  line `Regional Centre constituted under section 17;`
  line
  line `(m) "region" means the region comprising the territories of South Asian Association for Regional`
  line `Co-operation (SAARC) States and generally the Asia region;`
  line
  line `(n) "Regional Centre" means the Regional Centre for Biotechnology established under section 3;`
  line
  line `(o) "Regulations" means the Regulations made by any authority of the Regional Centre under`
  line `section 43;`
  line
  line `(p) "Statutes" means the Statutes framed by the Board under section 41;`
  line
  line `(q) "UNESCO" means the United Nations Educational, Scientific and Cultural Organisation.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (37058)
  sectionNo (3)
  orderNo 3
  title `Establishment and incorporation of Regional Centre for Biotechnology.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37058&sectionno=3&orderno=3&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_3_content:
  string
  line `(1) The Regional`
  line `Centre for Biotechnology Training and Education at National Capital Region, Faridabad, Haryana`
  line `functioning under the Department of Biotechnology, Ministry of Science and Technology is hereby`
  line `established as a body corporate by the name of "Regional Centre for Biotechnology" having perpetual`
  line `succession and a common seal with power, subject to the provisions of this Act, to contract and shall, by`
  line `the said name, sue or be sued.`
  line
  line `(2) The Regional Centre shall consist of a Board of Governors and authorities specified in section 13.`
  line
  line `(3) The headquarters of the Regional Centre shall be at its campus in the National Capital Region,`
  line Faridabad
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (37059)
  sectionNo (4)
  orderNo 4
  title `Declaration of Regional Centre for Biotechnology as an institution of national importance.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37059&sectionno=4&orderno=4&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_4_content:
  string
  line `Whereas the objects of the institution known as the Regional Centre for Biotechnology are`
  line `such as to make the institution one of national importance, it is hereby declared that the institution known`
  line `as the Regional Centre for Biotechnology is an institution of national importance.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (37060)
  sectionNo (5)
  orderNo 5
  title `Effect of establishment of Regional Centre.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37060&sectionno=5&orderno=5&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_5_content:
  string
  line `(1) On and from the date of commencement of this`
  line Act,—
  line
  line `(a) any reference to the existing Regional Centre in any law, other than this Act, or in any`
  line `contract or other instrument, shall be deemed as a reference to the Regional Centre;`
  line
  line `(b) all properties and assets, movable and immovable, of, or belonging to the existing Regional`
  line `Centre shall vest in the Regional Centre;`
  line
  line `(c) all rights and liabilities of the existing Regional Centre shall be transferred to, and be the`
  line `rights and liabilities of, the Regional Centre;`
  line
  line `(d) without prejudice to the provisions of clause (c), all debts, obligations and liabilities incurred,`
  line `all contracts entered into and all matters and things engaged to be done by, with or for, the existing`
  line `Regional Centre immediately before the said date, for or in connection with the purposes of the said`
  line `Regional Centre shall be deemed to have incurred, entered into or engaged to be done by, with or for,`
  line `the Regional Centre;`
  line
  line `(e) all sums of money due to the existing Regional Centre immediately before that date shall be`
  line `deemed to be due to the Regional Centre;`
  line
  line `(f) all suits and other legal proceedings instituted or which could have been instituted by or`
  line `against the existing Regional Centre immediately before that date may be continued or may be`
  line `instituted by or against the Regional Centre;`
  line
  line `(g) every employee (including those appointed for imparting instruction or giving training or`
  line `conducting research in the existing Regional Centre), holding any office under the existing Regional`
  line `Centre or teaching therein immediately before the commencement of this Act shall hold his office in`
  line `the Regional Centre or continue teaching therein by the same tenure and upon the same terms and conditions of service as respects remuneration, leave, provident fund, retirement and other terminal`
  line `benefits as he would have held such office if this Act had not been enacted and shall continue to do so`
  line `as an employee of the Regional Centre or until the expiry of the period of six months from that date if`
  line `such employee opts not to be the employee of the Regional Centre within such period.`
  line
  line `(2) Notwithstanding anything in the Industrial Disputes Act, 1947 (14 of 1947) or in any other law for`
  line `the time being in force, absorption of any employee by the Regional Centre in its regular service under`
  line `this section shall not entitle such employee to any compensation under that Act or any other law and no`
  line `such claim shall be entertained by any court, tribunal or other authority.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (37061)
  sectionNo (6)
  orderNo 6
  title Jurisdiction.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37061&sectionno=6&orderno=6&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_6_content:
  string
  line `The jurisdiction of the Regional Centre shall extend to whole of India and to such`
  line `centres and specialised laboratories or other units for research, development and instruction, established`
  line `by the Regional Centre within or outside India.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (37062)
  sectionNo (7)
  orderNo 7
  title `Objectives of Regional Centre.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37062&sectionno=7&orderno=7&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_7_content:
  string
  line `The objectives of the Regional Centre shall be—`
  line
  line `(a) to disseminate and to advance knowledge by providing instructional and research facilities in`
  line `such branches of biotechnology and related fields as it may deem fit including technology policy`
  line development;
  line
  line `(b) to provide capacity-building through education, training, research and development in`
  line `biotechnology and related academic fields for sustainable development objectives through regional`
  line `and international cooperation;`
  line
  line `(c) to facilitate transfer of knowledge and technology relating to biotechnology at the regional`
  line level;
  line
  line `(d) to create a hub of biotechnology expertise and to address human resources needs in the`
  line `countries in the region;`
  line
  line `(e) to promote and strengthen international co-operation to improve the social and economic`
  line `conditions and welfare of the people;`
  line
  line `(f) to promote and facilitate a network of satellite centres in the region as well as within India.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (37063)
  sectionNo (8)
  orderNo 8
  title `Functions of Regional Centre.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37063&sectionno=8&orderno=8&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_8_content:
  string
  line `The functions of the Regional Centre, shall be—`
  line
  line `(a) to establish infrastructure and technology platforms which are directly relevant to`
  line `biotechnology education, training and research;`
  line
  line `(b) to execute educational and training activities including grant of degrees in education and`
  line `research in biotechnology and related fields;`
  line
  line `(c) to produce human resource tailored to drive innovation in biotechnology, particularly in areas`
  line `of new opportunities and to fill talent gap in deficient areas;`
  line
  line `(d) to undertake research and development and scientific investigations in collaboration with`
  line `relevant research centres in the region;`
  line
  line `(e) to hold scientific symposia and conferences within India or in the region or outside the region`
  line `and to conduct short-term and long-term training courses and workshops in all areas of`
  line biotechnology;
  line
  line `(f) to collect universally available information with a view to setting up data banks for bioinformation;`
  line
  line `(g) to collect and disseminate, through networking, the relevant local knowledge in the field of`
  line `biotechnology, ensuring protection of intellectual property rights of local stakeholder communities;`
  line
  line `(h) to develop and implement a policy for intellectual property rights which is equitable and just`
  line `to the stakeholders involved in research in the Regional Centre;`
  line
  line `(i) to disseminate the outcome of research activities in different countries through the publication`
  line `of books and articles;`
  line
  line `(j) to promote collaborative research and development networking programme in specific areas of`
  line `biotechnology with national, regional and international networks and promote exchange of scientists,`
  line `at the regional level having regard to issues pertaining to intellectual property rights of collaborating`
  line `institutions promoting equitable sharing of benefits with collaborating institutions.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (37064)
  sectionNo (9)
  orderNo 9
  title `Regional Centre to work in collaboration with other institutions of UNESCO.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37064&sectionno=9&orderno=9&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_9_content:
  string
  line `The Regional`
  line `Centre shall pursue its objects and discharge its functions in close collaboration with other national,`
  line `regional and international institutions of the UNESCO.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (37065)
  sectionNo (10)
  orderNo 10
  title `Powers of Regional Centre.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37065&sectionno=10&orderno=10&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_10_content:
  string
  line `(1) The Regional Centre shall have the following powers,`
  line `namely:—`
  line
  line `(a) to provide for masters degree (including integrated programmes leading to masters degree),`
  line `post-graduate diploma and doctoral degrees in biotechnology and related subjects at the interface of`
  line `varied disciplines including physical, chemical, biological, medical, agricultural and engineering and`
  line `other relevant sciences, as may be determined by the Regional Centre, from time to time;`
  line
  line `(b) to provide for short-term and long-term training courses in biotechnology on specific issues`
  line `related to the development, extension, implementation and regulation of biotechnology and related`
  line `areas, as may be specified by Statutes, from time to time;`
  line
  line `(c) to organise and undertake extramural studies, training and extension services in`
  line biotechnology;
  line
  line `(d) to confer honorary degrees or other academic distinctions referred to in clause (a), in the`
  line `manner specified by the Statutes;`
  line
  line `(e) to institute Professorships, Associate Professorships, Assistant Professorships and other`
  line `academic positions required by the Regional Centre and to appoint persons to such Professorships,`
  line `Associate Professorships, Assistant Professorships or other academic positions;`
  line
  line `(f) to recognise an institution of higher learning within India for the purposes of this Act and to`
  line `withdraw such recognition in accordance with the norms laid down in the Statutes;`
  line
  line `(g) to appoint persons working in any other institution, including those located outside the`
  line `country, as academic staff of the Regional Centre for such period as may be specified by the Statutes;`
  line
  line `(h) to create administrative, technical and other posts and to make appointments thereto, as may`
  line `be specified by Statutes;`
  line
  line `(i) to co-operate or collaborate or associate with any institution, including those located outside`
  line `the country, in such manner as may be specified and for such purposes as may be determined or`
  line `agreed upon by the Regional Centre;`
  line
  line `(j) to establish and maintain centres and specialised laboratories or other units for research,`
  line `development and instruction in India or outside India, as may be determined by the Statutes from time`
  line `to time;`
  line
  line `(k) to institute and award fellowships, scholarships, studentships, medals and prizes as may be`
  line `specified by the Statutes;`
  line
  line `(l) to make provision for research and advisory services and for that purpose to enter into such`
  line `agreements with other institutions, industrial or other organisations, including those located outside`
  line `the country as may be specified by the Statutes;`
  line
  line `(m) to organise and conduct refresher courses, workshops, seminars and other programmes for`
  line `teachers, evaluators and other stakeholders;`
  line
  line `(n) to appoint visiting Professors, Professors of Eminence, Honorary Professors, Adjunct`
  line `Professors, Emeritus Professors, Consultants and such other persons who may contribute to the`
  line `advancement and objects of the Regional Centre;`
  line
  line `(o) to determine standards of admission to the Regional Centre, including examination,`
  line `evaluation or any other method of testing;`
  line
  line `(p) to fix, demand and receive payment of fees and other charges;`
  line
  line `(q) to establish, recognise, maintain and manage halls or residences of students of the Regional`
  line `Centre and other accommodation for students and to withdraw any such recognition;`
  line
  line `(r) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(s) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the Regional Centre to be necessary;`
  line
  line `(t) to make arrangements for promoting the health and general welfare of the students and`
  line `employees of the Regional Centre;`
  line
  line `(u) to receive benefactions, donations and gifts and to acquire, hold and manage, and dispose of,`
  line `with the prior approval of the Central Government, any property, movable or immovable, including`
  line `trust and endowment properties, for the purposes or objectives of the Regional Centre;`
  line
  line `(v) to borrow money, with the prior approval of the Central Government on the security of the`
  line `property of the Regional Centre; and`
  line
  line `(w) to do all such other acts and things as may be necessary in furtherance of the objects specified`
  line `in section 7.`
  line
  line `(2) In exercising its powers under sub-section (1), it shall be the endeavour of the Regional Centre to`
  line `maintain high standards of education, training and research and the Regional Centre shall, among other`
  line `measures which may be necessary for the said purpose, take, in particular, the following measures,`
  line `namely:—`
  line
  line `(a) conduct innovative courses and programmes of studies with a provision for periodic review`
  line `and restructuring; and`
  line
  line `(b) promote e-governance with an effective management information system.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (37066)
  sectionNo (11)
  orderNo 11
  title `Regional Centre open to all castes, creed, race or class.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37066&sectionno=11&orderno=11&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_11_content:
  string
  line `The Regional Centre or any`
  line `institution recognised by it shall be open to persons of either sex and whatever caste, creed, race,`
  line `ethnicity, nationality or class, and it shall not be lawful for the Regional Centre or such institution to`
  line `adopt or impose on any person, any test whatsoever of religious belief or profession in order to entitle him`
  line `to be appointed as a member of the academic staff of the Regional Centre or such institution or to hold`
  line `any other office therein or to be admitted as a student in the Regional Centre or such institution or to`
  line `enjoy or exercise any privilege thereof.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (37067)
  sectionNo (12)
  orderNo 12
  title `Privileges and immunities of Regional Centre.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37067&sectionno=12&orderno=12&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_12_content:
  string
  line `The Regional Centre or persons attending the`
  line `meetings of the Regional Centre shall enjoy such privileges and immunities as the Central Government`
  line `may grant, pursuant to agreement entered into between the UNESCO and the Government of India from`
  line `time to time concerning the Regional Centre.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (37068)
  sectionNo (13)
  orderNo 13
  title `Authorities of Regional Centre.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37068&sectionno=13&orderno=13&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_13_content:
  string
  line `The following shall be the authorities of the Regional Centre,`
  line `namely:—`
  line
  line `(i) the Board of Governors;`
  line
  line `(ii) the Programme Advisory Committee;`
  line
  line `(iii) the Executive Committee;`
  line
  line `(iv) the Finance Committee;`
  line
  line `(v) the Board of Studies; and`
  line
  line `(vi) such other authorities as may be declared by the Statutes to be the authorities of the Regional`
  line Centre.
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (37069)
  sectionNo (14)
  orderNo 14
  title `Board of Governors.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37069&sectionno=14&orderno=14&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_14_content:
  string
  line `(1) There shall be a Board of Governors which shall be responsible for`
  line `the governance of the Regional Centre.`
  line
  line `(2) The Board shall be the apex body of the Regional Centre and shall consist of the following`
  line `members, namely:—`
  line
  line `(a) Secretary to the Government of India in the Ministry of Science and Technology, Department`
  line `of Biotechnology—ex officio Chairperson;`
  line
  line `(b) three eminent scientists in the relevant field not below the rank of Joint Secretary to the`
  line `Government of India or equivalent, out of whom at least one shall be a woman, to be nominated by`
  line `the Central Government—ex officio members;`
  line
  line `(c) a representative of the Director-General of UNESCO;`
  line
  line `(d) two representatives from amongst the other member States of UNESCO, who substantially`
  line `contribute resources to the running of the Regional Centre, in such manner as may be specified by the`
  line Statutes—members.
  line
  line `(3) The Chairperson of the Programme Advisory Committee shall be a permanent invitee of the`
  line Board.
  line
  line `(4) The Executive Director of the Regional Centre shall be the Convenor of the meetings of the`
  line Board.
  line
  line `(5) The Chairperson shall ordinarily preside over the meetings of the Board.`
  line
  line `(6) The Board shall meet at least once in a year and at such times as the Chairperson may decide in`
  line `such manner as may be specified by the Statutes.`
  line
  line `(7) The term of office of the members of the Board, other than ex officio members, shall be such as`
  line `may be specified by the Statutes.`
  line
  line `(8) Subject to the provisions of this Act and the Statutes and the Ordinances made thereunder, the`
  line `Board may regulate its own procedure (including quorum) for the conduct of meetings and transacting`
  line business.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (37070)
  sectionNo (15)
  orderNo 15
  title `Powers and functions of Board.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37070&sectionno=15&orderno=15&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_15_content:
  string
  line `Subject to the provisions of this Act, the Board shall have the`
  line `following powers and functions, namely:—`
  line
  line `(a) to approve the annual plan and budget of the Regional Centre;`
  line
  line `(b) to review, from time to time, the broad policies and programmes of the Regional Centre, and`
  line `to suggest measures for the improvement and development of the Regional Centre;`
  line
  line `(c) to consider the annual report and the annual accounts of the Regional Centre and the audit`
  line `report on such accounts;`
  line
  line `(d) to study and approve the internal procedures, including financial procedure and staff`
  line `regulations of the Regional Centre;`
  line
  line `(e) to approve the organisational structure and number of academic staff and other employees at`
  line `the Regional Centre;`
  line
  line `(f) to convene special consultative sessions of its members, to which it may invite representatives`
  line `of other interested countries and international organisations in order to obtain proposals for`
  line `strengthening the scope of services of the Regional Centre;`
  line
  line `(g) to carry out projects and activities relevant to the Regional Centre, and to expand the fundraising strategy and capabilities; and`
  line
  line `(h) to frame the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (37071)
  sectionNo (16)
  orderNo 16
  title `Powers and functions of Chairperson.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37071&sectionno=16&orderno=16&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_16_content:
  string
  line `(1) The Chairperson shall exercise such powers and`
  line `discharge such functions as may be delegated to him by the Board or as may be specified by the Statutes.`
  line
  line `(2) If for any reason, the Chairperson is unable to attend any meeting of the Board, any member of`
  line `the Board nominated by the Chairperson shall preside over the meeting.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (37072)
  sectionNo (17)
  orderNo 17
  title `Programme Advisory Committee.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37072&sectionno=17&orderno=17&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_17_content:
  string
  line `(1) The Programme Advisory Committee shall be the`
  line `principal academic body of the Regional Centre and shall, subject to the provisions of this Act, advice`
  line `planning, execution, review and monitoring of the scientific and academic programmes of the Regional`
  line Centre.
  line
  line `(2) The Programme Advisory Committee shall consist of the following members, namely:—`
  line
  line `(a) a Chairperson of the Programme Advisory Committee to be nominated by the Board;`
  line
  line `(b) two members to be nominated by the UNESCO;`
  line
  line `(c) three members to be nominated by rotation, from amongst the member States of UNESCO`
  line `which provide maximum financial assistance;`
  line
  line `(d) two members having expertise and experience in biotechnology policy and legal matters to be`
  line `nominated by the Central Government;`
  line
  line `(e) six members from amongst the persons being renowned scientist or academician, to be`
  line `nominated by the Board.`
  line
  line `(3) The Executive Director shall be the Member-Secretary, ex officio, to the Programme Advisory`
  line Committee.
  line
  line `(4) The Programme Advisory Committee shall be responsible for—`
  line
  line `(a) making recommendations on matters of planning and coordinating of the education, training`
  line `and research activities;`
  line
  line `(b) recommending modifications or revision of education, training and research programmes of`
  line `the Regional Centre and submitting reports thereon;`
  line
  line `(c) reviewing annually the programmes of the Regional Centre, evaluating its progress and`
  line `submitting the reports thereon;`
  line
  line `(d) publishing reports on any matter concerning scientific and technical issues referred to it by the`
  line `Board or by the Executive Director;`
  line
  line `(e) performing all such duties and to do all such acts as may be necessary for furtherance of`
  line `education, training and research under this Act;`
  line
  line `(f) framing the Ordinances; and`
  line
  line `(g) performing such other functions as may be specified by the Statutes.`
  line
  line `(5) The fees and allowances payable to members of the Programme Advisory Committee and their`
  line `term of office shall be such as may be specified by the Statutes.`
  line
  line `(6) Subject to the provisions of this Act and the Statutes and Ordinances made thereunder, the`
  line `Programme Advisory Committee may regulate its own procedure (including quorum) for the conduct of`
  line `meetings and transacting of its business:`
  line
  line `Provided that the Programme Advisory Committee shall place the minutes of its meetings before the`
  line `Board of Governors.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (37073)
  sectionNo (18)
  orderNo 18
  title `Executive Committee.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37073&sectionno=18&orderno=18&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_18_content:
  string
  line `(1) The Executive Committee shall be responsible for management of`
  line `the Regional Centre and implementation of policies and decisions of the Board relating to management.`
  line
  line `(2) The constitution, powers and functions of the Executive Committee and the term of office of its`
  line `members shall be such as may be specified by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (37074)
  sectionNo (19)
  orderNo 19
  title `Finance Committee.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37074&sectionno=19&orderno=19&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_19_content:
  string
  line `(1) The Finance Committee shall review finances, consider the annual`
  line `budget estimates, the statements of accounts and the audit reports and make recommendations thereon, to`
  line `the Board.`
  line
  line `(2) The constitution, powers and functions of the Finance Committee and the term of office of its`
  line `members shall be such as may be specified by the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (37075)
  sectionNo (20)
  orderNo 20
  title `Other authorities of Regional Centre.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37075&sectionno=20&orderno=20&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_20_content:
  string
  line `The constitution, powers and functions of other`
  line `authorities referred to in clause (vi) of section 13, and the term of office of its members shall be such as`
  line `may be specified by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (37076)
  sectionNo (21)
  orderNo 21
  title `Board of Studies.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37076&sectionno=21&orderno=21&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_21_content:
  string
  line `The constitution, powers and functions of the Board of Studies and the term`
  line `of office of its members shall be such as may be specified by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (37077)
  sectionNo (22)
  orderNo 22
  title `Officers of Regional Centre.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37077&sectionno=22&orderno=22&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_22_content:
  string
  line `The following shall be the officers of the Regional Centre,`
  line `namely:—`
  line
  line `(i) Executive Director;`
  line
  line `(ii) Deans;`
  line
  line `(iii) Sub-Deans;`
  line
  line `(iv) Associate Director (Administration);`
  line
  line `(v) Registrar;`
  line
  line `(vi) Finance Officer; and`
  line
  line `(vii) such other officers as may be declared by the Statutes to be the officers of the Regional`
  line Centre.
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (37078)
  sectionNo (23)
  orderNo 23
  title `Executive Director.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37078&sectionno=23&orderno=23&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_23_content:
  string
  line `(1) The Executive Director shall be appointed on the recommendation of`
  line `the Board in such manner and on such terms and conditions of service, as may be specified by the`
  line Statutes.
  line
  line `(2) The Executive Director shall—`
  line
  line `(a) be the principal executive and academic officer of the Regional Centre;`
  line
  line `(b) direct the work of the Regional Centre in conformity with the programmes and directives`
  line `established by the Board;`
  line
  line `(c) propose the draft work plan and budget to be submitted to the Board;`
  line
  line `(d) prepare the agenda for the sessions of the Board;`
  line
  line `(e) prepare reports on the Regional Centre's activities for submission to the Board; and`
  line
  line `(f) exercise such other powers and perform such other functions as may be specified by the`
  line Statutes.
  line
  line `(3) The financial powers delegated to the Executive Director by the Board shall be such as may be`
  line `specified by the Statutes.`
  line
  line `(4) The Executive Director may, if he is of the opinion that immediate action is necessary on any`
  line `matter, exercise any power conferred on any authority of the Regional Centre by or under this Act and`
  line `shall report to such authority at its next meeting the action taken by him on such matter.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (37079)
  sectionNo (24)
  orderNo 24
  title `Deans and Sub-Deans.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37079&sectionno=24&orderno=24&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_24_content:
  string
  line `The Deans and Sub-Deans shall be appointed in such manner and on`
  line `such terms and conditions of service, and shall exercise such powers and perform such duties, as may be`
  line `specified by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (37080)
  sectionNo (25)
  orderNo 25
  title `Associate Director (Administration).`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37080&sectionno=25&orderno=25&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_25_content:
  string
  line `(1) The Associate Director (Administration) shall be`
  line `appointed in such manner, and on such terms and conditions of service, as may be specified by the`
  line Statutes.
  line
  line `(2) The Associate Director (Administration) shall have the power to enter into agreements, sign`
  line `documents and authenticate records on behalf of the Regional Centre and shall exercise such powers and`
  line `perform such duties, as may be specified by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (37081)
  sectionNo (26)
  orderNo 26
  title Registrar.
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37081&sectionno=26&orderno=26&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_26_content:
  string
  line `The Registrar shall be appointed in such manner and on such terms and conditions of`
  line `service and shall exercise such powers and perform such duties, as may be specified by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (37082)
  sectionNo (27)
  orderNo 27
  title `Finance officer.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37082&sectionno=27&orderno=27&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_27_content:
  string
  line `The Finance officer shall be appointed in such manner and on such terms and`
  line `conditions of service and shall exercise such powers and perform such duties, as may be specified by the`
  line Statutes.
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (37083)
  sectionNo (28)
  orderNo 28
  title `Other officers.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37083&sectionno=28&orderno=28&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_28_content:
  string
  line `The manner of appointment and powers and duties and terms and conditions of`
  line `service of other officers of the Regional Centre, referred to in clause (vii) of section 22, shall be such as`
  line `may be specified by the Statutes.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (37084)
  sectionNo (29)
  orderNo 29
  title `Grants and loans to Regional Centre.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37084&sectionno=29&orderno=29&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_29_content:
  string
  line `The Central Government may, after due appropriation`
  line `made by Parliament by law, in this behalf, make to the Regional Centre grants and loans of such sums of`
  line `money and in such manner as that Government may consider necessary for being utilised for the`
  line `fulfilment of the objects and purposes of this Act.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (37085)
  sectionNo (30)
  orderNo 30
  title `Fund of Regional Centre.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37085&sectionno=30&orderno=30&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_30_content:
  string
  line `(1) The Regional Centre shall maintain a Fund to which shall be`
  line credited—
  line
  line `(a) all moneys provided by the Central Government;`
  line
  line `(b) all fees and other charges received by the Regional Centre;`
  line
  line `(c) all moneys received by the Regional Centre by way of grants, gifts, donations, benefactions,`
  line `bequests or transfers; and`
  line
  line `(d) all moneys received by the Regional Centre in any other manner or from any other source.`
  line
  line `(2) All moneys credited to the Fund shall be deposited in such banks or invested in such manner as`
  line `the Regional Centre may, with the approval of the Central Government, decide.`
  line
  line `(3) The fund shall be applied for meeting—`
  line
  line `(a) the fees and allowances payable to the Chairperson and members of the Board or Chairperson`
  line `of the Programme Advisory Committee and members of the other committees and the salaries,`
  line `allowances and other remunerations payable to the academic staff, officers and other employees of`
  line `the Regional Centre;`
  line
  line `(b) the expenses of the Regional Centre in the discharge of its functions and for the fulfilment of`
  line `its objects and for purposes as envisaged under this Act.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (37086)
  sectionNo (31)
  orderNo 31
  title `Annual report.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37086&sectionno=31&orderno=31&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_31_content:
  string
  line `(1) The annual report of the Regional Centre shall be prepared under the`
  line `directions of the Executive Director, which shall include, among other matters, the steps taken by the`
  line `Regional Centre towards the fulfilment of its objectives and shall be submitted to the Board on or before`
  line `such date as may be specified by the Statutes and the Board shall consider the report in its annual`
  line meeting.
  line
  line `(2) A copy of the annual report, as prepared under sub-section (1), shall be submitted to the Central`
  line `Government, which shall, as soon as may be, cause the same to be laid before both Houses of Parliament.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (37087)
  sectionNo (32)
  orderNo 32
  title `Annual accounts.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37087&sectionno=32&orderno=32&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_32_content:
  string
  line `(1) The annual accounts and the balance sheet of the Regional Centre shall`
  line `be prepared under the directions of the Board and shall, once at least every year, and at intervals of not`
  line `more than fifteen months, be audited by the Comptroller and Auditor-General of India.`
  line
  line `(2) A copy of the accounts together with the audit report shall be submitted to the Central`
  line `Government along with the observations, if any, of the Board.`
  line
  line `(3) A copy of the annual report and annual accounts together with the audit report, shall be submitted`
  line `to the Central Government which shall, as soon as may be, cause the same to be laid before each House of`
  line Parliament.
  line
  line `(4) The audited annual accounts, after having been laid before both Houses of Parliament, shall be`
  line `published in the Official Gazette.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (37088)
  sectionNo (33)
  orderNo 33
  title `Returns and information.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37088&sectionno=33&orderno=33&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_33_content:
  string
  line `The Regional Centre shall furnish to the Central Government such`
  line `returns or other information with respect to its property or activities as the Central Government may, from`
  line `time to time, require, within such period as may be specified by the Central Government.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (37089)
  sectionNo (34)
  orderNo 34
  title `Review of functioning of Regional Centre.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37089&sectionno=34&orderno=34&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_34_content:
  string
  line `(1) There shall be a review of the functioning of`
  line `the Regional Centre once in every four years by persons of eminence to be appointed by the Central`
  line Government.
  line
  line `(2) The Regional Centre shall meet the expenses for conducting the review under sub-section (1) and`
  line `upon receipt of the report of such review, the Board may take appropriate action.`
  line
  line `(3) In addition to the review under sub-section (1), the Board may conduct review of functioning of`
  line `administrative and academic wings of the Regional Centre, in such manner and at such intervals, as may`
  line `be specified by the Statutes.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (37090)
  sectionNo (35)
  orderNo 35
  title `Appointment and conditions of service of employees of Regional Centre.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37090&sectionno=35&orderno=35&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_35_content:
  string
  line `(1) All`
  line `appointments of employees of the Regional Centre shall be made in accordance with the procedure laid`
  line `down in the Statutes, by—`
  line
  line `(a) the Board of Governors for the Executive Director, Deans and Sub-Deans;`
  line
  line `(b) the Executive Director, in any other case.`
  line
  line `(2) The terms and conditions of service of the employees of the Regional Centre, other than the`
  line `officers referred to in clause (vii) of section 22, shall be such as may be specified by the Statutes.`
  line
  line `(3) The terms and conditions of service of the academic staff shall be consistent with such staff`
  line `engaged in higher education and research at Central Universities.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (37091)
  sectionNo (36)
  orderNo 36
  title Meetings.
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37091&sectionno=36&orderno=36&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_36_content:
  string
  line `The meetings of the Board, Programme Advisory Committee, Executive Committee`
  line `or other committees constituted by the Regional Centre may be held using contemporary tools of`
  line `information and communication technologies (including video conferencing) without the members`
  line `necessarily having to be physically present.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (37092)
  sectionNo (37)
  orderNo 37
  title `Filling of casual vacancies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37092&sectionno=37&orderno=37&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_37_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `members) of the authorities under section 13 shall be filled, as soon as may be, by the person or body who`
  line `appoints, elects or co-opts the member whose place has become vacant and the person appointed, elected`
  line `or co-opted to a casual vacancy shall be a member of such authority for the residue of the term for which`
  line `the person whose place he fills would have been a member.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (37093)
  sectionNo (38)
  orderNo 38
  title `Proceedings of authorities not invalidated by vacancies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37093&sectionno=38&orderno=38&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_38_content:
  string
  line `No act or proceedings of any`
  line `authority of the Regional Centre shall be invalid merely by reason of the existence of a vacancy or`
  line `vacancies among its members.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (37094)
  sectionNo (39)
  orderNo 39
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37094&sectionno=39&orderno=39&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_39_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or employee of the Regional Centre for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act or the Statutes, Ordinances or the Regulations made`
  line thereunder.
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (37095)
  sectionNo (40)
  orderNo 40
  title Arbitration.
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37095&sectionno=40&orderno=40&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_40_content:
  string
  line `Any dispute arising between the Regional Centre and any of its employees shall,`
  line `at the first instance, be resolved through such grievance redressal mechanism as may be specified by the`
  line Statutes.
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (37096)
  sectionNo (41)
  orderNo 41
  title `Power to make Statutes.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37096&sectionno=41&orderno=41&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_41_content:
  string
  line `(1) The Statutes of the Regional Centre shall be framed by the Board`
  line `of Governors.`
  line
  line `(2) Without prejudice to the provisions contained in sub-section (1), the Executive Committee may`
  line `make recommendations for framing of Statutes to the Board.`
  line
  line `(3) Subject to the provisions of this Act, the Statutes may provide for all or any of the following`
  line `matters, namely:—`
  line
  line `(a) to provide for short-term and long-term training courses in biotechnology on specific issues`
  line `related to the development, extension, implementation and regulation of biotechnology and related`
  line `areas, from time to time under clause (b) of sub-section (1) of section 10;`
  line
  line `(b) the manner of conferring honorary degrees or other distinctions under clause (d) of`
  line `sub-section (1) of section 10;`
  line
  line `(c) the norms for recognition of an institution of higher learning within India and to withdraw such`
  line `recognition under clause (f) of sub-section (1) of section 10;`
  line
  line `(d) period for appointment of persons working in any other institution, including those located`
  line `outside the country, as academic staff of the Regional Centre under clause (g) of sub-section (1) of`
  line `section 10;`
  line
  line `(e) to create administrative, technical and other posts under clause (h) of sub-section (1) of`
  line `section 10;`
  line
  line `(f) the manner and purposes of co-operation or collaboration or association with any institution,`
  line `including those located outside the country, under clause (i) of sub-section (1) of section 10;`
  line
  line `(g) to establish and maintain centres and specialised laboratories or other units for research,`
  line `development and instruction in India or outside India, clause (j) of sub-section (1) of section 10;`
  line
  line `(h) to institute and award fellowships, scholarships, studentships, medals and prizes, under`
  line `clause (k) of sub-section (1) of section 10;`
  line
  line `(i) the manner of entering into agreements with other institutions, industrial or other organisations,`
  line `including those located outside the country, for research and advisory services under clause (l) of`
  line `sub-section (1) of section 10;`
  line
  line `(j) to declare other authorities to be the authorities of the Regional Centre under clause (vi) of`
  line `section 13;`
  line
  line `(k) the manner of appointment of representatives from amongst the member States of UNESCO,`
  line `under clause (d) of sub-section (2) of section 14;`
  line
  line `(l) the time and manner in which the Board shall meet under sub-section (5) of section 14;`
  line
  line `(m) the term of office of the members of the Board, under sub-section (6) of section 14;`
  line
  line `(n) such other powers and functions of the Chairperson under sub-section (1) of section 16;`
  line
  line `(o) such other functions of the Programme Advisory Committee under clause (g) of sub-section (4)`
  line `of section 17;`
  line
  line `(p) the fees and allowances payable to members of the Programme Advisory Committee and their`
  line `term of office under sub-section (5) of section 17;`
  line
  line `(q) the constitution, powers and functions and the term of office of members of the Executive`
  line `Committee under sub-section (2) of section 18;`
  line
  line `(r) the constitution, powers and functions and term of office of members of the Finance Committee`
  line `under sub-section (2) of section 19;`
  line
  line `(s) the constitution, powers and functions and term of office of members of other authorities under`
  line `section 20;`
  line
  line `(t) the constitution, powers and functions and term of office of members of the Board of Studies`
  line `under section 21;`
  line
  line `(u) the other officers as may be declared to be the officers of the Regional Centre under clause (vii)`
  line `of section 22;`
  line
  line `(v) the manner of appointment and terms and conditions of service of the Executive Director under`
  line `sub-section (1) of section 23;`
  line
  line `(w) the other powers and functions of the Executive Director under clause (f) of sub-section (2) of`
  line `section 23;`
  line
  line `(x) the financial powers to be delegated to the Executive Director by the Board under`
  line `sub-section (3) of section 23;`
  line
  line `(y) the manner of appointment, terms and conditions of service and powers and duties of the Deans`
  line `and Sub-Deans under section 24;`
  line
  line `(z) the manner of appointment and terms and conditions of service of the Associate Director`
  line `(Administration) under sub-section (1) and powers and duties to be performed by him under`
  line `sub-section (2) of section 25;`
  line
  line `(za) the manner of appointment, terms and conditions of service and powers and duties of the`
  line `Registrar under section 26;`
  line
  line `(zb) the manner of appointment, terms and conditions of service and powers and duties of the`
  line `Finance officer under section 27;`
  line
  line `(zc) the manner of appointment, powers and duties and terms and conditions of service of other`
  line `officers of the Regional Centre under section 28;`
  line
  line `(zd) the time for submission of the annual report of the Regional Centre to the Board under`
  line `sub-section (1) of section 31;`
  line
  line `(ze) the manner and frequency of conducting review of the functioning of administrative and`
  line `academic wings of the Regional Centre by the Board under sub-section (3) of section 34;`
  line
  line `(zf) the procedure for appointment of employees of the Regional Centre under sub-section (1) and`
  line `their terms and conditions of service under sub-section (2) of section 35;`
  line
  line `(zg) the grievance redressal mechanism for resolution of disputes arising between the Regional`
  line `Centre and any of its employees under section 40;`
  line
  line `(zh) the manner of making regulations by the authorities of the Regional Centre under section 43;`
  line and
  line
  line `(zi) any other matter which may be required or necessary for the purposes of this Act.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (37097)
  sectionNo (42)
  orderNo 42
  title `Power to make Ordinances.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37097&sectionno=42&orderno=42&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_42_content:
  string
  line `(1) Save as otherwise provided in this Act, the Ordinances of the`
  line `Regional Centre shall be made by the Programme Advisory Committee.`
  line
  line `(2) Subject to the provisions of this Act and the Statutes made thereunder, the Ordinances of the`
  line `Regional Centre may provide for all or any of the following matters, namely:—`
  line
  line `(a) admission of students from within India and from the region to the Regional Centre and their`
  line `enrolment as such;`
  line
  line `(b) the course of study;`
  line
  line `(c) the conditions under which students shall be admitted to the examinations of the Regional`
  line `Centre and shall be eligible for degrees, diplomas and certificates;`
  line
  line `(d) the conditions for award of fellowships, scholarships, medals and prizes;`
  line
  line `(e) the conditions and manner of appointment, term and duties of examining bodies, examiners`
  line `and moderators;`
  line
  line `(f) the conduct of examinations;`
  line
  line `(g) the conditions of residence of students of the Regional Centre;`
  line
  line `(h) the maintenance of discipline among the employees and students;`
  line
  line `(i) the courses of study to be laid down for all degrees, diplomas and certificates of the Regional`
  line `Centre including the medium of instruction and examination;`
  line
  line `(j) the award of degrees and other academic distinctions, and the manner of granting and`
  line `obtaining of the same;`
  line
  line `(k) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(l) the fees to be charged for courses of study and for admission to examinations, degrees and`
  line `diplomas of the Regional Centre;`
  line
  line `(m) the special arrangements, if any, which may be made for the residence and teaching of`
  line `women students and prescribing of special courses of studies for them;`
  line
  line `(n) the establishment, management, recognition and abolition of centres of studies, schools,`
  line `departments, specialised laboratories, halls and institutions; and`
  line
  line `(o) any other matter which by this Act or the Statutes, is to be, or may be, provided for by the`
  line Ordinances.
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (37098)
  sectionNo (43)
  orderNo 43
  title Regulations.
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37098&sectionno=43&orderno=43&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_43_content:
  string
  line `The authorities of the Regional Centre may make Regulations, consistent with the`
  line `provisions of this Act, the Statutes and the Ordinances for the conduct of their own business and that of`
  line `the Committees, if any, appointed by them and not provided for by this Act, the Statutes or the`
  line `Ordinances, in the manner specified by the Statutes.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (37099)
  sectionNo (44)
  orderNo 44
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37099&sectionno=44&orderno=44&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_44_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute or Ordinance or Regulation made under this Act shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament, while it is in session, for a total period of thirty days`
  line `which may be comprised in one session or in two or more successive sessions, and if, before the expiry of`
  line `the session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute or Ordinance or Regulation or both Houses agree that the Statute`
  line `or Ordinance or Regulation should not be made, the Statute or Ordinance or Regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute or Ordinance or Regulation.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (37100)
  sectionNo (45)
  orderNo 45
  title `Power to make Statutes or Ordinances or Regulations retrospectively.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37100&sectionno=45&orderno=45&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_45_content:
  string
  line `The power to make`
  line `Statutes or Ordinances or Regulations under section 41 or section 42 or section 43, as the case may be,`
  line `shall include the power to give retrospective effect, from a date not earlier than the date of`
  line `commencement of this Act, to the Statutes or Ordinances or Regulations or any of them but no`
  line `retrospective effect shall be given to any Statutes or Ordinances or Regulations so as to prejudicially`
  line `affect the interests of any person to whom such Statutes or Ordinances or Regulations may be applicable.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (37101)
  sectionNo (46)
  orderNo 46
  title `Power to remove difficulties.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_31_84_00001_201636_1517807328236&sectionId=37101&sectionno=46&orderno=46&orgactid=AC_CEN_31_84_00001_201636_1517807328236
obj_root_law_sections_46_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appears to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of two years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_46_footnotes:
  string
  line
