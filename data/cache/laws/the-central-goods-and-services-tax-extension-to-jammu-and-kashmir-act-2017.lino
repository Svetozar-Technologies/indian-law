obj_root_law_sections_1:
  object
  (str sectionId) (str 33024)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Central Goods and Services Tax
(Extension to Jammu and Kashmir) Act, 2017.

(2) It shall be deemed to have come into force on the 8th day of July, 2017.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_201726_1517807327964&sectionId=33024&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00040_201726_1517807327964)
obj_root_law_sections_2:
  object
  (str sectionId) (str 33025)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Extension and amendment of Central Goods and Services Tax Act, 2017.`)
  (str content) (str `(1)The Central
Goods and Services Tax Act, 2017 (12 of 2017) (hereinafter referred to as the principal Act) and all
rules, notifications and orders made thereunder by the Central Government are hereby extended to, and
shall be in force in, the State of Jammu and Kashmir*.

(2) With effect from the date of commencement of this Act, in the principal Act,---

(a) in section 1, in sub-section (2), the words "except the State of Jammu and Kashmir*" shall be
omitted;

(b) in section 22, in the Explanation, in clause (ii), after the word "Constitution", the words "except
the State of Jammu and Kashmir*" shall be inserted;

(c) in section 109, in sub-section (6),---

(i) after the words "each State or Union territory", the words "except for the State of Jammu and Kashmir*" shall be inserted;

(ii) in the first proviso, for the words "Provided that", the following shall be substituted, namely:---

"Provided that for the State of Jammu and Kashmir*, the State Bench of the Goods and Services Tax Appellate Tribunal constituted under this Act shall be the State Appellate Tribunal constituted under the Jammu and Kashmir Goods and Services Tax Act, 2017:

Provided further that";

(iii) in the second proviso, for the words "Provided further that", the words "Provided also that" shall be substituted.`)
  (str footnotes) (str `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu
and Kashmir and the Union territory of Ladakh.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_201726_1517807327964&sectionId=33025&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00040_201726_1517807327964)
obj_root_law_sections_3:
  object
  (str sectionId) (str 33026)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Repeal and saving.`)
  (str content) (str `(1) The Central Goods and Services Tax (Extension to Jammu and Kashmir)
Ordinance, 2017 (Ord. 3 of 2017) is hereby repealed.

(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be
deemed to have been done or taken under the corresponding provisions of this Act.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_201726_1517807327964&sectionId=33026&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00040_201726_1517807327964)
