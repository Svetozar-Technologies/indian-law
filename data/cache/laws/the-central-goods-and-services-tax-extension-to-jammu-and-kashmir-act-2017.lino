obj_root_law_sections_1:
  sectionId (33024)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_201726_1517807327964&sectionId=33024&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00040_201726_1517807327964
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Central Goods and Services Tax`
  line `(Extension to Jammu and Kashmir) Act, 2017.`
  line
  line `(2) It shall be deemed to have come into force on the 8th day of July, 2017.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (33025)
  sectionNo (2)
  orderNo 2
  title `Extension and amendment of Central Goods and Services Tax Act, 2017.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_201726_1517807327964&sectionId=33025&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00040_201726_1517807327964
obj_root_law_sections_2_content:
  string
  line `(1)The Central`
  line `Goods and Services Tax Act, 2017 (12 of 2017) (hereinafter referred to as the principal Act) and all`
  line `rules, notifications and orders made thereunder by the Central Government are hereby extended to, and`
  line `shall be in force in, the State of Jammu and Kashmir*.`
  line
  line `(2) With effect from the date of commencement of this Act, in the principal Act,---`
  line
  line `(a) in section 1, in sub-section (2), the words "except the State of Jammu and Kashmir*" shall be`
  line omitted;
  line
  line `(b) in section 22, in the Explanation, in clause (ii), after the word "Constitution", the words "except`
  line `the State of Jammu and Kashmir*" shall be inserted;`
  line
  line `(c) in section 109, in sub-section (6),---`
  line
  line `(i) after the words "each State or Union territory", the words "except for the State of Jammu and Kashmir*" shall be inserted;`
  line
  line `(ii) in the first proviso, for the words "Provided that", the following shall be substituted, namely:---`
  line
  line `"Provided that for the State of Jammu and Kashmir*, the State Bench of the Goods and Services Tax Appellate Tribunal constituted under this Act shall be the State Appellate Tribunal constituted under the Jammu and Kashmir Goods and Services Tax Act, 2017:`
  line
  line `Provided further that";`
  line
  line `(iii) in the second proviso, for the words "Provided further that", the words "Provided also that" shall be substituted.`
obj_root_law_sections_2_footnotes:
  string
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu`
  line `and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_3:
  sectionId (33026)
  sectionNo (3)
  orderNo 3
  title `Repeal and saving.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00040_201726_1517807327964&sectionId=33026&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00040_201726_1517807327964
obj_root_law_sections_3_content:
  string
  line `(1) The Central Goods and Services Tax (Extension to Jammu and Kashmir)`
  line `Ordinance, 2017 (Ord. 3 of 2017) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
