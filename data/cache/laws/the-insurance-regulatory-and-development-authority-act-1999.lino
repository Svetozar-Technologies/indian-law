  (str title) (str `The Insurance Regulatory and Development Authority Act, 1999`)
  (str actNumber) (str 41)
  (str enactmentDate) (str 1999-12-29)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1893`)
