obj_root_law_sections_1:
  sectionId (4835)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4835&sectionno=1&orderno=1&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Insurance Regulatory`
  line `and Development Authority Act, 1999.`
  line
  line `(2) It extends to the whole of India.`
  line
  line `(3) It shall come into force on such date ^1 as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act and any reference`
  line `in any such provision to the commencement of this Act shall be construed as a reference to the coming`
  line `into force of that provision.`
obj_root_law_sections_1_footnotes:
  string
  line `1 19th April, 2000, vide notification No. S.O. 397(E), dated 19th April, 2000, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (4836)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4836&sectionno=2&orderno=2&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_2_content:
  string
  line `(1) In this Act, unless the context otherwise requires,---`
  line
  line `(a) appointed day means the date on which the Authority is established under sub-section (1)`
  line `of section 3;`
  line
  line `(b) "Authority" means the Insurance Regulatory and Development Authority ^1[of India]`
  line `established under sub-section (1) of section 3;`
  line
  line `(c) "Chairperson" means the Chairperson of the Authority;`
  line
  line `(d) "Fund" means the Insurance Regulatory and Development Authority Fund constituted under`
  line `sub-section (1) of section 16;`
  line
  line `(e) "Interim Insurance Regulatory Authority" means the Insurance Regulatory Authority set up by`
  line `the Central Government through Resolution No. 17(2)/94-Ins.-V, dated the 23rd January, 1996;`
  line
  line `^2[(f) "insurance intermediary" shall have the same meaning as assigned to it in clause (10B) of`
  line `section 2 of the Insurance Act, 1938 (4 of 1938);]`
  line
  line `(g) "member" means a whole-time or a part-time member of the Authority and includes the`
  line Chairperson;
  line
  line `(h) "notification" means a notification published in the Official Gazette;`
  line
  line `(i) "prescribed" means prescribed by rules made under this Act;`
  line
  line `(j) "regulations" means the regulations made by the Authority.`
  line
  line `(2) Words and expressions used and not defined in this Act but defined in the Insurance Act, 1938`
  line `(4 of 1938) or the Life Insurance Corporation Act, 1956 (31 of 1956) or the General Insurance Business`
  line `(Nationalisation) Act, 1972 (57 of 1972) shall have the meanings respectively assigned to them in those`
  line Acts.
obj_root_law_sections_2_footnotes:
  string
  line `1 Ins. by Act 5 of 2015, s. 105 (w.e.f. 26-12-2014).`
  line
  line `2 Subs. by Act 40 of 2025, s. 87, for clause (f) (w.e.f. 05-02-2026).`
obj_root_law_sections_3:
  sectionId (4837)
  sectionNo (3)
  orderNo 3
  title `Establishment and incorporation of Authority.`
  content obj_root_law_sections_3_content
  footnotes `1 Ins. by Act 5 of 2015, s. 106 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4837&sectionno=3&orderno=3&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_3_content:
  string
  line `(1) With effect from such date as the Central`
  line `Government may, by notification, appoint, there shall be established, for the purposes of this Act, an`
  line `Authority to be called "the Insurance Regulatory and Development Authority ^1[of India]."`
  line
  line `(2) The Authority shall be a body corporate by the name aforesaid having perpetual succession and a`
  line `common seal with power, subject to the provisions of this Act, to acquire, hold and dispose of property,`
  line `both movable and immovable, and to contract and shall, by the said name, sue or be sued.`
  line
  line `(3) The head office of the Authority shall be at such place as the Central Government may decide`
  line `from time to time.`
  line
  line `(4) The Authority may establish offices at other places in India.`
obj_root_law_sections_4:
  sectionId (4838)
  sectionNo (4)
  orderNo 4
  title `Composition of Authority.`
  content obj_root_law_sections_4_content
  footnotes `1. Ins. by Act 40 of 2025, s. 88 (w.e.f. 05-02-2026)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4838&sectionno=4&orderno=4&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_4_content:
  string
  line `The Authority shall consist of the following members, namely:--`
  line
  line `(a) a Chairperson;`
  line
  line `(b) not more than five whole-time members;`
  line
  line `(c) not more than four part-time members,`
  line
  line `to be appointed by the Central Government from amongst persons of ability, integrity and standing who`
  line `have knowledge or experience in life insurance, general insurance, actuarial science, finance, economics,`
  line `law, accountancy, administration ^1[, information technology] or any other discipline which would, in the`
  line `opinion of the Central Government, be useful to the Authority:`
  line
  line `Provided that the Central Government shall, while appointing the Chairperson and the whole-time`
  line `members, ensure that at least one person each is a person having knowledge or experience in life`
  line `insurance, general insurance or actuarial science, respectively.`
obj_root_law_sections_5:
  sectionId (4839)
  sectionNo (5)
  orderNo 5
  title `Tenure of office of Chairperson and other members.`
  content obj_root_law_sections_5_content
  footnotes `1. Subs. by Act 40 of 2025, s. 89, for sub-section (1) (w.e.f. 05-02-2026)`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4839&sectionno=5&orderno=5&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_5_content:
  string
  line `^1[(1) The term of office of the`
  line `Chairperson and other whole-time members shall be five years from the date on which they enter upon`
  line `their office or till they attain the age of sixty-five years, whichever is earlier, and shall be eligible for`
  line reappointment.]
  line
  line `(2) A part-time member shall hold office for a term not exceeding five years from the date on which`
  line `he enters upon his office.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1) or sub-section (2), a member may--`
  line
  line `(a) relinquish his office by giving in writing to the Central Government notice of not less than`
  line `three months; or`
  line
  line `(b) be removed from his office in accordance with the provisions of section 6.`
obj_root_law_sections_6:
  sectionId (4840)
  sectionNo (6)
  orderNo 6
  title `Removal from office.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4840&sectionno=6&orderno=6&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_6_content:
  string
  line `(1) The Central Government may remove from office any member who--`
  line
  line `(a) is, or at any time has been, adjudged as an insolvent; or`
  line
  line `(b) has become physically or mentally incapable of acting as a member; or`
  line
  line `(c) has been convicted of any offence which, in the opinion of the Central Government, involves`
  line `moral turpitude; or`
  line
  line `(d) has acquired such financial or other interest as is likely to affect prejudicially his functions as`
  line `a member; or`
  line
  line `(e) has so abused his position as to render his continuation in office detrimental to the public`
  line interest.
  line
  line `(2) No such member shall be removed under clause (d) or clause (e) of sub-section (1) unless he has`
  line `been given a reasonable opportunity of being heard in the matter.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (4841)
  sectionNo (7)
  orderNo 7
  title `Salary and allowances of Chairperson and members.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4841&sectionno=7&orderno=7&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_7_content:
  string
  line `(1) The salary and allowances payable`
  line `to, and other terms and conditions of service of, the members other than part-time members shall be such`
  line `as may be prescribed.`
  line
  line `(2) The part-time members shall receive such allowances as may be prescribed.`
  line
  line `(3) The salary, allowances and other conditions of service of a member shall not be varied to his`
  line `disadvantage after appointment.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (4842)
  sectionNo (8)
  orderNo 8
  title `Bar on future employment of members.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4842&sectionno=8&orderno=8&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_8_content:
  string
  line `The Chairperson and the whole-time members shall`
  line `not, for a period of two years from the date on which they cease to hold office as such, except with the`
  line `previous approval of the Central Government, accept--`
  line
  line `(a) any employment either under the Central Government or under any State Government; or`
  line
  line `(b) any appointment in any company in the insurance sector.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (4843)
  sectionNo (9)
  orderNo 9
  title `Administrative powers of Chairperson.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4843&sectionno=9&orderno=9&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_9_content:
  string
  line `The Chairperson shall have the powers of general`
  line `superintendence and direction in respect of all administrative matters of the Authority.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (4844)
  sectionNo (10)
  orderNo 10
  title `Meetings of Authority.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4844&sectionno=10&orderno=10&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_10_content:
  string
  line `(1) The Authority shall meet at such time and places and shall observe`
  line `such rules and procedures in regard to transaction of business at its meetings (including quorum at such`
  line `meetings) as may be determined by the regulations.`
  line
  line `(2) The Chairperson, or if for any reason he is unable to attend a meeting of the Authority, any other`
  line `member chosen by the members present from amongst themselves at the meeting shall preside at the`
  line meeting.
  line
  line `(3) All questions which come up before any meeting of the Authority shall be decided by a majority`
  line `of votes by the members present and voting, and in the event of an equality of votes, the Chairperson, or`
  line `in his absence, the person presiding shall have a second or casting vote.`
  line
  line `(4) The Authority may make regulations for the transaction of business at its meetings.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (4845)
  sectionNo (11)
  orderNo 11
  title `Vacancies, etc., not to invalidate proceedings of Authority.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4845&sectionno=11&orderno=11&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_11_content:
  string
  line `No act or proceeding of the`
  line `Authority shall be invalid merely by reason of--`
  line
  line `(a) any vacancy in, or any defect in the constitution of, the Authority; or`
  line
  line `(b) any defect in the appointment of a person acting as a member of the Authority; or`
  line
  line `(c) any irregularity in the procedure of the Authority not affecting the merits of the case.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (4846)
  sectionNo (12)
  orderNo 12
  title `Officers and employees of Authority.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4846&sectionno=12&orderno=12&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_12_content:
  string
  line `(1) The Authority may appoint officers and such other`
  line `employees as it considers necessary for the efficient discharge of its functions under this Act.`
  line
  line `(2) The terms and other conditions of service of officers and other employees of the Authority`
  line `appointed under sub-section (1) shall be governed by the regulations made under this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (4847)
  sectionNo (13)
  orderNo 13
  title `Transfer of assets, liabilities, etc., of Interim Insurance Regulatory Authority.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4847&sectionno=13&orderno=13&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_13_content:
  string
  line `On the`
  line `appointed day,---`
  line
  line `(a) all the assets and liabilities of the Interim Insurance Regulatory Authority shall stand`
  line `transferred to, and vested in, the Authority.`
  line
  line `Explanation.---The assets of the Interim Insurance Regulatory Authority shall be deemed to`
  line `include all rights and powers, and all properties, whether movable or immovable, including, in`
  line `particular, cash balances, deposits and all other interests and rights in, or arising out of, such`
  line `properties as may be in the possession of the Interim Insurance Regulatory Authority and all books of`
  line `account and other documents relating to the same; and liabilities shall be deemed to include all debts,`
  line `liabilities and obligations of whatever kind;`
  line
  line `(b) without prejudice to the provisions of clause (a), all debts, obligations and liabilities incurred,`
  line `all contracts entered into and all matters and things engaged to be done by, with or for the Interim`
  line `Insurance Regulatory Authority immediately before that day, for or in connection with the purpose of`
  line `the said Regulatory Authority, shall be deemed to have been incurred, entered into or engaged to be`
  line `done by, with or for, the Authority;`
  line
  line `(c) all sums of money due to the Interim Insurance Regulatory Authority immediately before that`
  line `day shall be deemed to be due to the Authority; and`
  line
  line `(d) all suits and other legal proceedings instituted or which could have been instituted by or`
  line `against the Interim Insurance Regulatory Authority immediately before that day may be continued or`
  line `may be instituted by or against the Authority.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (4848)
  sectionNo (14)
  orderNo 14
  title `Duties, powers and functions of Authority.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4848&sectionno=14&orderno=14&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_14_content:
  string
  line `(1) Subject to the provisions of this Act and any`
  line `other law for the time being in force, the Authority shall have the duty to regulate, promote and ensure`
  line `orderly growth of the insurance business and re-insurance business.`
  line
  line `(2) Without prejudice to the generality of the provisions contained in sub-section (1), the powers and`
  line `functions of the Authority shall include,--`
  line
  line `(a) issue to the applicant a certificate of registration, renew, modify, withdraw, suspend or cancel`
  line `such registration;`
  line
  line `(b) protection of the interests of the policy-holders in matters concerning assigning of policy,`
  line `nomination by policy-holders, insurable interest, settlement of insurance claim, surrender value of`
  line `policy and other terms and conditions of contracts of insurance;`
  line
  line `(c) specifying requisite qualifications, code of conduct and practical training for intermediary or`
  line `insurance intermediaries and agents;`
  line
  line `(d) specifying the code of conduct for surveyors and loss assessors;`
  line
  line `(e) promoting efficiency in the conduct of insurance business;`
  line
  line `(f) promoting and regulating professional organisations connected with the insurance and`
  line `re-insurance business;`
  line
  line `(g) levying fees and other charges for carrying out the purposes of this Act;`
  line
  line `(h) calling for information from, undertaking inspection of, conducting enquiries and`
  line `investigations including audit of the insurers, intermediaries, insurance intermediaries and other`
  line `organisations connected with the insurance business;`
  line
  line `(i) control and regulation of the rates, advantages, terms and conditions that may be offered by`
  line `insurers in respect of general insurance business ^1***;`
  line
  line `(j) specifying the form and manner in which books of account shall be maintained and statement`
  line `of accounts shall be rendered by insurers and other insurance intermediaries;`
  line
  line `(k) regulating investment of funds by insurance companies;`
  line
  line `(l) regulating maintenance of margin of solvency;`
  line
  line `(m) adjudication of disputes between insurers and intermediaries or insurance intermediaries;`
  line
  line `^2[(n) imposing such penalty as specified in section 102 of the Insurance Act, 1938 (4 of 1938) and`
  line `for any violation of the provisions of this Act or rules or regulations made thereunder;]`
  line
  line `(o) specifying the percentage of premium income of the insurer to finance schemes for promoting`
  line `and regulating professional organisations referred to in clause (f);`
  line
  line `(p) specifying the percentage of life insurance business and general insurance business to be`
  line `undertaken by the insurer in the rural or social sector; and`
  line
  line `(q) exercising such other powers as may be prescribed.`
obj_root_law_sections_14_footnotes:
  string
  line `1. Certain words omitted by Act 40 of 2025, s. 90 (w.e.f. 05-02-2026).`
  line
  line `2. Subs. by s. 90, ibid. for clause (n) (w.e.f. 05-02-2026).`
obj_root_law_sections_14_a:
  sectionId (105607)
  sectionNo 14A
  orderNo 15
  title `Power of Authority to collect policy information`
  content obj_root_law_sections_14_a_content
  footnotes `1. Ins. by Act 40 of 2025, s. 91, (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=105607&sectionno=14A&orderno=15&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_14_a_content:
  string
  line `^1[14A. Power of Authority to collect policy information.---The Authority may, for the purpose of`
  line `efficient discharge of its functions and to regulate and develop the insurance business---`
  line
  line `(a) collect in such manner as it may think fit, information relating to policies and claims from any`
  line `insurer or other regulated entities; and`
  line
  line `(b) furnish such information to any insurer or other regulated entities in accordance with the`
  line `provisions of section 14C.]`
obj_root_law_sections_14_b:
  sectionId (105608)
  sectionNo 14B
  orderNo 16
  title `Power to call for returns containing policy information`
  content obj_root_law_sections_14_b_content
  footnotes `1. 1. Ins. by Act 40 of 2025, s. 91, (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=105608&sectionno=14B&orderno=16&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_14_b_content:
  string
  line `^1[14B. Power to call for returns containing policy information.---(1) For the purpose of enabling the`
  line `Authority to discharge its functions under this Act and the Insurance Act, 1938 (4 of 1938), it may at any`
  line `time direct any insurer or other regulated entities to submit statements relating to policies and`
  line `policyholder related information in such form and within such time as may be specified by the`
  line regulations.
  line
  line `(2) Notwithstanding anything to the contrary contained in any law for the time being in force or in`
  line `any instrument regulating the constitution thereof or in any agreement executed by it, relating to the`
  line `secrecy of its dealings with its constituents, an insurer or other regulated entities shall comply with any`
  line `direction issued under sub-section (1).]`
obj_root_law_sections_14_c:
  sectionId (105609)
  sectionNo 14C
  orderNo 17
  title `Procedure for furnishing policyholder and policy related information to insurer or other regulated entities.`
  content obj_root_law_sections_14_c_content
  footnotes `1. Ins. by Act 40 of 2025, s. 91, (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=105609&sectionno=14C&orderno=17&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_14_c_content:
  string
  line `^1[14C. Procedure for furnishing policyholder and policy related information to insurer or other`
  line `regulated entities.---(1) The insurer may, in connection with any insurance policy issued or proposed to`
  line `be issued by it, to any person, make an application to the Authority in such form as the Authority may`
  line `specify by the regulations.`
  line
  line `(2) The Authority shall process the application made under sub-section (1) within such period as may`
  line `be specified by the regulations only after the insurer confirms to the Authority that the person has`
  line `consented to provide access of his policy related information in accordance with the existing law and`
  line `regulations framed in this regard including the preservation of evidence of such consent.`
  line
  line `(3) On receipt of an application under sub-section (1), the Authority shall, as soon as may be, furnish`
  line `the applicant with such policy related information as specified in the application, as may be in its`
  line `possession:`
  line
  line `Provided that the information so furnished shall not disclose the names of the insurer or other`
  line `regulated entities that has submitted such information to the Authority.`
  line
  line `(4) The Authority may in respect of each application levy such fees, as it may deem fit for furnishing`
  line `such information.]`
obj_root_law_sections_14_d:
  sectionId (105610)
  sectionNo 14D
  orderNo 18
  title `Disclosure of information prohibited.`
  content obj_root_law_sections_14_d_content
  footnotes `1. Ins. by Act 40 of 2025, s. 91, (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=105610&sectionno=14D&orderno=18&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_14_d_content:
  string
  line `^1[14D. Disclosure of information prohibited.---(1) Any information contained in any statement`
  line `submitted by an insurer or other regulated entities under section 14B or furnished by the Authority to any`
  line `insurer or other regulated entities under section 14C, shall be treated as confidential and shall not, except`
  line `for the specified intended purposes, be published or otherwise disclosed.`
  line
  line `(2) Nothing in this section shall apply to---`
  line
  line `(a) the disclosure by any insurer or other regulated entities, with the previous permission of the`
  line `Authority, of any information furnished to the Authority under section 14B or 14C;`
  line
  line `(b) the publication by the Authority, if it considers necessary in the public interest so to do, of any`
  line `information collected by it under section 14B or 14C, in such consolidated form as it may think fit`
  line `without disclosing the name of any insurer or other regulated entities or the policyholder;`
  line
  line `(c) the disclosure or publication by the Authority or the insurer or other regulated entities of any`
  line `policy related information to any other insurance company, intermediary or regulated entity as`
  line `permitted by the Authority under the regulations to be issued from time to time.`
  line
  line `(3) Notwithstanding anything contained in any law for the time being in force, no court, tribunal or`
  line `other authority shall compel the Authority or any insurer or other regulated entities to produce or to give`
  line `inspection of any statement submitted by that insurer or other regulated entities under section 14B or 14C`
  line `or to disclose any policy related information furnished by the Authority to that insurer or other regulated`
  line `entities under section 14C.]`
obj_root_law_sections_14_e:
  sectionId (105611)
  sectionNo 14E
  orderNo 19
  title `Power to authorize.`
  content obj_root_law_sections_14_e_content
  footnotes `1. Ins. by Act 40 of 2025, s. 91, (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=105611&sectionno=14E&orderno=19&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_14_e_content:
  string
  line `^1[14E. Power to authorise.---The Authority may, for the efficient discharge of its functions under`
  line `sections 14A to 14D, by a general or special order in writing, authorise any entity regulated by it or any`
  line `other statutory body having similar objectives to perform such functions as specified in the said order.]`
obj_root_law_sections_15:
  sectionId (4849)
  sectionNo (15)
  orderNo 20
  title `Grants by Central Government.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4849&sectionno=15&orderno=20&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_15_content:
  string
  line `The Central Government may, after due appropriation made`
  line `by Parliament by law in this behalf, make to the Authority grants of such sums of money as the`
  line `Government may think fit for being utilised for the purposes of this Act.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (4850)
  sectionNo (16)
  orderNo 21
  title `Constitution of Fund.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4850&sectionno=16&orderno=21&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_16_content:
  string
  line `(1) There shall be constituted a fund to be called "the Insurance`
  line `Regulatory and Development Authority Fund" and there shall be credited thereto---`
  line
  line `(a) all Government grants, fees and charges received by the Authority;`
  line
  line `(b) all sums received by the Authority from such other source as may be decided upon by the`
  line `Central Government;`
  line
  line `^1* * * * *`
  line
  line `(2) The Fund shall be applied for meeting---`
  line
  line `(a) the salaries, allowances and other remuneration of the members, officers and other employees`
  line `of the Authority;`
  line
  line `(b) the other expenses of the Authority in connection with the discharge of its functions and for`
  line `the purposes of this Act ^2[and the Insurance Act, 1938 (4 of 1938)];`
  line
  line `^2[(c) the capital expenditure, as per annual capital expenditure plan approved by the Authority.]`
  line
  line `^2[(3) The Authority shall constitute a Reserve Fund and twenty-five per cent. of the annual surplus of`
  line `the Fund in any year shall be credited to such Reserve Fund and such fund shall not exceed the total of`
  line `annual expenditure of preceding three financial years.`
  line
  line `(4) After incurring all the expenses referred to in sub-section (2) and transfer to Reserve Fund as`
  line `specified in sub-section (3), the surplus of the Fund shall be transferred to the Consolidated Fund of India.`
  line
  line `Explanation.---For the purposes of this section, the expression "Reserve Fund" means a fund to`
  line `hold the surplus of the Fund, in the form and manner specified in sub-section (3) of section 16.]`
obj_root_law_sections_16_footnotes:
  string
  line `1. Clause (c) omitted by Act 5 of 2015, s. 107 (w.e.f. 26-12-2014).`
  line
  line `2. Ins. by Act 40 of 2025, s. 92 (w.e.f. 05-02-2026).`
obj_root_law_sections_16_a:
  sectionId (105612)
  sectionNo 16A
  orderNo 22
  title `Constitution of Policyholders’ Education and Protection Fund.`
  content obj_root_law_sections_16_a_content
  footnotes `1. Ins. by Act 40 of 2025, s. 93 (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=105612&sectionno=16A&orderno=22&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_16_a_content:
  string
  line `^1[16A. Constitution of Policyholders' Education and Protection Fund.---(1) The Authority shall`
  line `constitute a fund to be called the Policyholders' Education and Protection Fund.`
  line
  line `(2) There shall be credited to the Policyholders' Education and Protection Fund the following`
  line `amounts, namely:---`
  line
  line `(a) any grants and donations given to the Policyholders' Education and Protection Fund by the`
  line `Central Government, State Governments, the Authority, companies or any other institutions for the`
  line `purposes of the Policyholders' Education and Protection Fund;`
  line
  line `(b) the sums realised by way of penalties by the Authority under this Act or the Insurance Act,`
  line `1938 (4 of 1938) or rules and regulations thereunder; and`
  line
  line `(c) such other sums as may be specified by the regulations.`
  line
  line `(3) The Policyholders' Education and Protection Fund shall be administered and utilised by the`
  line `Authority for education of policyholders and protection of the interests of policyholders in the manner`
  line `and for such other purposes as may be specified by the regulations.]`
obj_root_law_sections_17:
  sectionId (4851)
  sectionNo (17)
  orderNo 23
  title `Accounts and audit.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4851&sectionno=17&orderno=23&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_17_content:
  string
  line `(1) The Authority shall maintain proper accounts and other relevant`
  line `records and prepare an annual statement of accounts in such form as may be prescribed by the Central`
  line `Government in consultation with the Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Authority shall be audited by the Comptroller and Auditor-General of India at`
  line `such intervals as may be specified by him and any expenditure incurred in connection with such audit`
  line `shall be payable by the Authority to the Comptroller and Auditor-General.`
  line
  line `(3) The Comptroller and Auditor-General of India and any other person appointed by him in`
  line `connection with the audit of the accounts of the Authority shall have the same rights, privileges and`
  line `authority in connection with such audit as the Comptroller and Auditor-General generally has in`
  line `connection with the audit of the Government accounts and, in particular, shall have the right to demand`
  line `the production of books of account, connected vouchers and other documents and papers and to inspect`
  line `any of the offices of the Authority.`
  line
  line `(4) The accounts of the Authority as certified by the Comptroller and Auditor-General of India or any`
  line `other person appointed by him in this behalf together with the audit report thereon shall be forwarded`
  line `annually to the Central Government and that Government shall cause the same to be laid before each`
  line `House of Parliament.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (4852)
  sectionNo (18)
  orderNo 24
  title `Power of Central Government to issued directions.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4852&sectionno=18&orderno=24&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_18_content:
  string
  line `(1) Without prejudice to the foregoing`
  line `provisions of this Act, the Authority shall, in exercise of its powers or the performance of its functions`
  line `under this Act, be bound by such directions on questions of policy, other than those relating to technical`
  line `and administrative matters, as the Central Government may give in writing to it from time to time:`
  line
  line `Provided that the Authority shall, as far as practicable, be given an opportunity to express its views`
  line `before any direction is given under this sub-section.`
  line
  line `(2) The decision of the Central Government, whether a question is one of policy or not, shall be final.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (4853)
  sectionNo (19)
  orderNo 25
  title `Power of Central Government to supersede Authority.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4853&sectionno=19&orderno=25&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_19_content:
  string
  line `(1) If, at any time the Central`
  line `Government is of the opinion,---`
  line
  line `(a) that, on account of circumstances beyond the control of the Authority, it is unable to discharge`
  line `the functions or perform the duties imposed on it by or under the provisions of this Act; or`
  line
  line `(b) that the Authority has persistently defaulted in complying with any direction given by the`
  line `Central Government under this Act or in the discharge of the functions or performance of the duties`
  line `imposed on it by or under the provisions of this Act and as a result of such default the financial`
  line `position of the Authority or the administration of the Authority has suffered; or`
  line
  line `(c) that circumstances exist which render it necessary in the public interest so to do,`
  line
  line `the Central Government may, by notification and for reasons to be specified therein, supersede the`
  line `Authority for such period, not exceeding six months, as may be specified in the notification and appoint a`
  line `person to be the Controller of Insurance under section 2B of the Insurance Act, 1938 (4 of 1938), if not`
  line `already done:`
  line
  line `Provided that before issuing any such notification, the Central Government shall give a reasonable`
  line `opportunity to the Authority to make representations against the proposed supersession and shall consider`
  line `the representations, if any, of the Authority.`
  line
  line `(2) Upon the publication of a notification under sub-section (1) superseding the Authority,--`
  line
  line `(a) the Chairperson and other members shall, as from the date of supersession, vacate their offices`
  line `as such;`
  line
  line `(b) all the powers, functions and duties which may, by or under the provisions of this Act, be`
  line `exercised or discharged by or on behalf of the Authority shall, until the Authority is reconstituted`
  line `under sub-section (3), be exercised and discharged by the Controller of Insurance; and`
  line
  line `(c) all properties owned or controlled by the Authority shall, until the Authority is reconstituted`
  line `under sub-section (3), vest in the Central Government.`
  line
  line `(3) On or before the expiration of the period of supersession specified in the notification issued under`
  line `sub-section (1), the Central Government shall reconstitute the Authority by a fresh appointment of its`
  line `Chairperson and other members and in such case any person who had vacated his office under clause (a)`
  line `of sub-section (2) shall not be deemed to be disqualified for reappointment.`
  line
  line `(4) The Central Government shall cause a copy of the notification issued under sub-section (1) and a`
  line `full report of any action taken under this section and the circumstances leading to such action to be laid`
  line `before each House of Parliament at the earliest.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (4854)
  sectionNo (20)
  orderNo 26
  title `Furnishing of returns, etc., to Central Government.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4854&sectionno=20&orderno=26&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_20_content:
  string
  line `(1) The Authority shall furnish to the`
  line `Central Government at such time and in such form and manner as may be prescribed, or as the Central`
  line `Government may direct to furnish such returns, statements and other particulars in regard to any proposed`
  line `or existing programme for the promotion and development of the insurance industry as the Central`
  line `Government may, from time to time, require.`
  line
  line `(2) Without prejudice to the provisions of sub-section (1), the Authority shall, within nine months`
  line `after the close of each financial year, submit to the Central Government a report giving a true and full`
  line `account of its activities including the activities for promotion and development of the insurance business`
  line `during the previous financial year.`
  line
  line `(3) Copies of the reports received under sub-section (2) shall be laid, as soon as may be after they are`
  line `received, before each House of Parliament.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (4855)
  sectionNo (21)
  orderNo 27
  title `Chairperson, members, officers and other employees of Authority to be public servants.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4855&sectionno=21&orderno=27&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_21_content:
  string
  line `The Chairperson, members, officers and other employees of the Authority shall be deemed, when acting`
  line `or purporting to act in pursuance of any of the provisions of this Act, to be public servants within the`
  line `meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (4856)
  sectionNo (22)
  orderNo 28
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4856&sectionno=22&orderno=28&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_22_content:
  string
  line `No suit, prosecution or other legal proceedings shall`
  line `lie against the Central Government or any officer of the Central Government or any member, officer or`
  line `other employee of the Authority for anything which is in good faith done or intended to be done under`
  line `this Act or the rules or regulations made thereunder:`
  line
  line `Provided that nothing in this Act shall exempt any person from any suit or other proceedings which`
  line `might, apart from this Act, be brought against him.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (4857)
  sectionNo (23)
  orderNo 29
  title `Delegation of powers.`
  content obj_root_law_sections_23_content
  footnotes `1. Subs. by Act 40 of 2025, s. 94 (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4857&sectionno=23&orderno=29&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_23_content:
  string
  line `^1[(1) The Authority may, for the efficient discharge of its functions`
  line `under this Act, by a general or special order in writing by notification, delegate to the Chairperson or any`
  line `other member or any officer of the Authority, subject to such conditions or restrictions, if any, as may be`
  line `specified in the order, such of its powers and functions under this Act, except the power to make`
  line `regulations and the power to register an insurer, as it may deem necessary or expedient.]`
  line
  line `(2) The Authority may, by a general or special order in writing, also form committees of the members`
  line `and delegate to them the powers and functions of the Authority as may be specified by the regulations.`
obj_root_law_sections_23_a:
  sectionId (50601)
  sectionNo 23A
  orderNo 30
  title `Powers of Authority not to apply to International Financial Services Centre.`
  content obj_root_law_sections_23_a_content
  footnotes `1. Ins. by Act 50 of 2019, s. 33 and the second Schedule (w.e.f. 1-10-2020).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=50601&sectionno=23A&orderno=30&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_23_a_content:
  string
  line `^1[23A. Powers of Authority not to apply to International Financial Services Centre.---`
  line `Notwithstanding anything contained in any other law for the time being in force, the powers exercisable`
  line `by the Authority under this Act,---`
  line
  line `(a) shall not extend to an International Financial Services Centre set up under sub-section (1) of`
  line `section 18 of the Special Economic Zones Act, 2005 (28 of 2005);`
  line
  line `(b) shall be exercisable by the International Financial Services Centres Authority established`
  line `under sub-section (1) of section 4 of the International Financial Services Centres Authority Act, 2019,`
  line
  line `in so far as regulation of financial products, financial services and financial institutions that are permitted`
  line `in the International Financial Services Centres are concerned.]`
obj_root_law_sections_24:
  sectionId (4858)
  sectionNo (24)
  orderNo 31
  title `Power to make rules.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4858&sectionno=24&orderno=31&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_24_content:
  string
  line `(1) The Central Government may, by notification, make rules for`
  line `carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the salary and allowances payable to, and other terms and conditions of service of, the`
  line `members other than part-time members under sub-section (1) of section 7;`
  line
  line `(b) the allowances to be paid to the part-time members under sub-section (2) of section 7;`
  line
  line `(c) such other powers that may be exercised by the Authority under clause (q) of sub-section (2)`
  line `of section 14;`
  line
  line `(d) the form of annual statement of accounts to be maintained by the Authority under`
  line `sub-section (1) of section 17;`
  line
  line `(e) the form and manner in which and the time within which returns and statements and`
  line `particulars are to be furnished to the Central Government under sub-section (1) of section 20;`
  line
  line `(f) the matters under sub-section (5) of section 25 on which the Insurance Advisory Committee`
  line `shall advise the Authority;`
  line
  line `(g) any other matter which is required to be, or may be, prescribed, or in respect of which`
  line `provision is to be or may be made by rules.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (4859)
  sectionNo (25)
  orderNo 32
  title `Establishment of Insurance Advisory Committee.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4859&sectionno=25&orderno=32&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_25_content:
  string
  line `(1) The Authority may, by notification,`
  line `establish with effect from such date as it may specify in such notification, a Committee to be known as`
  line `the Insurance Advisory Committee.`
  line
  line `(2) The Insurance Advisory Committee shall consist of not more than twenty-five members excluding`
  line `ex officio members to represent the interests of commerce, industry, transport, agriculture, consumer fora,`
  line `surveyors, agents, intermediaries, organisations engaged in safety and loss prevention, research bodies`
  line `and employees' association in the insurance sector.`
  line
  line `(3) The Chairperson and the members of the Authority shall be the ex officio Chairperson and`
  line `ex officio members of the Insurance Advisory Committee.`
  line
  line `(4) The objects of the Insurance Advisory Committee shall be to advise the Authority on matters`
  line `relating to the making of the regulations under section 26.`
  line
  line `(5) Without prejudice to the provisions of sub-section (4), the Insurance Advisory Committee may`
  line `advise the Authority on such other matters as may be prescribed.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (4860)
  sectionNo (26)
  orderNo 33
  title `Power to make regulations.`
  content obj_root_law_sections_26_content
  footnotes `1. Subs. by Act 40 of 2025, s. 95, for sub-section (1) (w.e.f. 05-02-2026).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4860&sectionno=26&orderno=33&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_26_content:
  string
  line `^1[(1) The Authority may, in consultation with the Insurance`
  line `Advisory Committee, by notification make regulations consistent with the provisions of this Act and the`
  line `rules made thereunder, to carry out the purposes of this Act and while making the regulations shall ensure`
  line `transparency by---`
  line
  line `(a) publishing draft regulations along with such other details as may be specified on its website`
  line `and inviting public comments for a specified period prior to issuing such regulations;`
  line
  line `(b) publishing a general statement of its response to the public comments, not later than the date of`
  line `notification of the regulations; and`
  line
  line `(c) periodically reviewing such regulations:`
  line
  line `Provided that if the Authority is of the opinion that certain regulations are required to be made or`
  line `existing regulations to be amended urgently in the public interest or the subject matter of the regulation`
  line `relates solely to the internal functioning of the Authority, it may dispense with the condition of publishing`
  line `draft regulations and record the reason for doing so:`
  line
  line `Provided further that if the Authority decides to approve regulations in a form substantially different`
  line `from the proposed regulations other than changes made in consideration of comments received by it, it`
  line `shall repeat the process mentioned in this sub-section.]`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such regulations may`
  line `provide for all or any of the following matters, namely:---`
  line
  line `(a) the time and places of meetings of the Authority and the procedure to be followed at such`
  line `meetings including the quorum necessary for the transaction of business under sub-section (1) of`
  line `section 10;`
  line
  line `(b) the transaction of business at its meetings under sub-section (4) of section 10;`
  line
  line `(c) the terms and other conditions of service of officers and other employees of the Authority under`
  line `sub-section (2) of section 12;`
  line
  line `(d) the powers and functions which may be delegated to committees of the members under`
  line `sub-section (2) of section 23; and`
  line
  line `(e) any other matter which is required to be, or may be, specified by regulations or in respect of`
  line `which provision is to be or may be made by regulations.`
obj_root_law_sections_27:
  sectionId (4861)
  sectionNo (27)
  orderNo 34
  title `Rules and regulations to be laid before Parliament.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4861&sectionno=27&orderno=34&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_27_content:
  string
  line `Every rule and every regulation made`
  line `under this Act shall be laid, as soon as may be after it is made, before each House of Parliament, while it`
  line `is in session, for a total period of thirty days which may be comprised in one session or in two or more`
  line `successive sessions, and if, before the expiry of the session immediately following the session or the`
  line `successive sessions aforesaid, both Houses agree in making any modification in the rule or regulation or`
  line `both Houses agree that the rule or regulation should not be made, the rule or regulation shall thereafter`
  line `have effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that rule or regulation.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (4862)
  sectionNo (28)
  orderNo 35
  title `Application of other laws not barred.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4862&sectionno=28&orderno=35&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_28_content:
  string
  line `The provisions of this Act shall be in addition to, and`
  line `not in derogation of, the provisions of any other law for the time being in force.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (4863)
  sectionNo (29)
  orderNo 36
  title `Power to remove difficulties.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_45_00001_199941_1517807320115&sectionId=4863&sectionno=29&orderno=36&orgactid=AC_CEN_2_45_00001_199941_1517807320115
obj_root_law_sections_29_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the`
  line `appointed day.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_29_footnotes:
  string
  line
