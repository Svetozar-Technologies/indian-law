  (str title) (str `The Employment of Manual Scavengers and Construction of Dry Latrines (Prohibition) Act, 1993`)
  (str actNumber) (str 46)
  (str enactmentDate) (str 1993-06-05)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1581`)
  (str sources) obj_root_law_sources
