obj_root_law_sections_1:
  sectionId (40807)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40807&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the ^1[Banaras] Hindu University`
  line `Act, 1915.`
  line
  line `(2) It shall come into force on such date^2`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, direct.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 55 of 1951, s. 2, for "Benares" (w.e.f. 3-11-1951).`
  line
  line `2. 1st April, 1916, see Gazette of India, 1916, Pt. I. P. 352.`
obj_root_law_sections_2:
  sectionId (40808)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1. Subs. by Act 52 of 1966, s. 2, for section 2 (w.e.f. 31-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40808&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_2_content:
  string
  line `^1[2. Definitions.--In this Act, unless the context otherwise requires,--`
  line
  line `(a) "Academic Council" means the Academic Council of the University.`
  line
  line `(b) "college" means a college or teaching institution (other than a secondary, primary or infant`
  line `school or pathasala) maintained by, or admitted to the privileges of, the University;`
  line
  line `(c) "Court" means the University Court;`
  line
  line `(d) "Executive Council" means the University Executive Council;`
  line
  line `(e) "Faculty" means a Faculty of the University;`
  line
  line `(f) "Ordinances" means the Ordinances of the University for the time being in force;`
  line
  line `(g) "Regulations" means the Regulations of the University for the time being in force;`
  line
  line `(h) "Statutes" means the Statutes of the University for the time being in force;`
  line
  line `(i) "teacher" means a salaried professor, reader, lecturer or tutor who imparts instruction in a`
  line `Faculty of, or in a college maintained by, the University and includes any other person who is`
  line `declared to be a teacher by the Academic Council;`
  line
  line `(j) "University" means the Banaras Hindu University.]`
obj_root_law_sections_3:
  sectionId (40809)
  sectionNo (3)
  orderNo 3
  title Incorporation.
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40809&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_3_content:
  string
  line `^4[(1) The Chancellor and the Vice-Chancellor and the members of the Court, the`
  line `Executive Council and the Academic Council, for the time being shall be a body corporate by the name of`
  line `the Banaras Hindu University.]`
  line
  line `(2) The University shall have perpetual succession and a common seal, and shall sue, and be sued, by`
  line `the name first aforesaid.`
  line
  line `^5* * * * *`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by s. 3, ibid., for sub-section (1) (w.e.f. 31-12-1966).`
  line
  line `2. Sub-section (3) omitted by s. 3, ibid. (w.e.f. 31-12-1966).`
obj_root_law_sections_4:
  sectionId (40810)
  sectionNo (4)
  orderNo 4
  title `University open to all classes, castes and creeds.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40810&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_4_content:
  string
  line `^1[4. University open to all classes, castes and creeds.--The University shall be open to persons of`
  line `either sex and of whatever race, creed, caste or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person any test whatsoever of religious belief or profession in order to entitle him to be`
  line `admitted therein, as a teacher or student, or to hold any office therein, or to graduate thereat, or to enjoy or`
  line `exercise any privilege thereof, except in respect of any particular benefaction accepted by the University,`
  line `where such test is made a condition thereof by any testamentary, or other instrument creating such`
  line `benefaction:`
  line
  line `Provided that nothing in this section shall be deemed to prevent religious instruction being given in`
  line `the manner prescribed by the Ordinances ^2[to those who, or, in the case of minors, whose parents or`
  line `guardians have given their consent thereto in writing].]`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 55 of 1951, s. 3, for sub-sections (4), (5) and (6) (w.e.f. 3-11-1951).`
  line
  line `2. Subs. by Act 52 of 1966, s. 4, for "to those who have consented to receive it" (w.e.f. 31-12-1966).`
obj_root_law_sections_4_a:
  sectionId (40811)
  sectionNo 4A
  orderNo 5
  title `Powers of the University.`
  content obj_root_law_sections_4_a_content
  footnotes obj_root_law_sections_4_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40811&sectionno=4A&orderno=5&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_4_a_content:
  string
  line `^1[4A. Powers of the University.--The University shall have the following powers, namely:--`
  line
  line `(1) to provide for instruction in such branches of learning as the University may think fit, and to`
  line `make provision for research and for the advancement and dissemination of knowledge;`
  line
  line `^2[(2) to promote the study of religion, literature, history, science and art of`
  line `Vedic, Hindu, Buddhist, Jain, Islamic, Sikh, Christian, Zoroastrian and other civilisations and`
  line cultures;
  line
  line `(3) to hold examinations and to grant diplomas and certificates, and confer degrees`
  line `and other academic distinctions to and on persons--`
  line
  line `(a) who shall have pursued a course of study in the University or in a college and passed the`
  line `examination or who shall have carried on research work in the manner prescribed by`
  line `the Ordinances, or`
  line
  line `(b) who are teachers of the University or any college under conditions laid down in the`
  line `Statutes or the Ordinances and shall have passed the examinations of the University under like`
  line `conditions, or`
  line
  line `(c) who, being women, shall have pursued a course of private study in subjects provided for`
  line `by the Ordinances and shall have passed the examinations of the University in their subjects`
  line `under conditions laid down in the Ordinances;]`
  line
  line `(4) to confer honorary degrees or other distinctions in the manner laid down in the Statutes;`
  line
  line `(5) to grant such diplomas ^3[or certificates] to, and to provide such lectures and instruction for,`
  line `persons not being members of the University as the University may determine;`
  line
  line `^3[(5A) To withdraw degrees, diplomas, certificates and other academic distinctions;]`
  line
  line `(6) to co-operate with other Universities and authorities in such manner and for such purposes as`
  line `the University may determine;`
  line
  line `(7) to institute professorships, readerships, lectureships and other teaching posts required by the`
  line `University and to appoint persons to such professorships, readerships and lectureships and other`
  line posts;
  line
  line `(8) to institute and award fellowships (including travelling fellowships), scholarships,`
  line `studentships, exhibitions and prizes in accordance with the Statutes and the Ordinances;`
  line
  line `(9) to institute and maintain halls and hostels and to recognise places of residence for students of`
  line `the University;`
  line
  line `^4[(9A) to institute, establish, maintain, reconstitute, amalgamate, divide or abolish departments,`
  line `faculties or colleges and carry out inspection thereof and inquiry in relation thereto;]`
  line
  line `(10) to demand and receive such fees and other charges as may be prescribed by the Ordinances;`
  line
  line `(11) to supervise and control the residence and to regulate the discipline of students of the`
  line `University, and to make arrangements for promoting their health ^4[and welfare].`
  line
  line `(12) to make special arrangements in respect of the residence, discipline, and teaching of women`
  line students;
  line
  line `^4[(12A) to regulate and enforce discipline among salaried officers, teachers and other employees`
  line `of the University in accordance with the Statutes and Ordinances;]`
  line
  line `(13) to create administrative, ministerial and other necessary posts and to make appointments`
  line `thereto; ^5***`
  line
  line `^4[(13A) to acquire, hold, manage and dispose of property, movable or immovable, including trust`
  line `or endowed property, for the purposes of the University;`
  line
  line `(13B) with the approval of the Central Government, to borrow on the security of the property of`
  line `the University, money for the purpose of the University;]`
  line
  line `(14) to do all such other acts and things, whether incidental to the powers aforesaid or not, as may`
  line `be requisite in order to further the objects of the University.]`
obj_root_law_sections_4_a_footnotes:
  string
  line `1. Subs. by Act 55 of 1951, s. 3, for sub-sections (4), (5) and (6) (w.e.f. 3-11-1951).`
  line
  line `2. Subs. by s. 5, ibid., for clauses (2) and (3) (w.e.f. 31-12-1966).`
  line
  line `3. Ins. by s. 5, ibid. (w.e.f. 31-12-1966).`
  line
  line `4. Ins. by Act 52 of 1966, s. 5 (w.e.f. 31-12-1966).`
  line
  line `5. The word "and" omitted by s. 5, ibid. (w.e.f. 31-12-1966).`
obj_root_law_sections_5:
  sectionId (40812)
  sectionNo (5)
  orderNo 6
  title Visitor.
  content obj_root_law_sections_5_content
  footnotes `1. Ins. by s. 6, ibid. (w.e.f. 31-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40812&sectionno=5&orderno=6&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_5_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor shall have the right to cause an inspection to be made, by such person or persons as he`
  line `may direct, of the University, its buildings, laboratories and equipment ^1[of any college] and of any`
  line `institution maintained by University, and also of the examinations, teaching and other work conducted or`
  line `done by the University and to cause an inquiry to be made in like manner in respect of any matter`
  line `connected with the University.`
  line
  line `(3) The Visitor shall in every case give notice to the University of his intention to cause an inspection`
  line `or inquiry to be made, and the University shall be entitled to appoint a representative who shall have the`
  line `right to be present and be heard at such inspection or inquiry.`
  line
  line `(4) The Visitor may address the Vice-Chancellor with reference to the result of such inspection and`
  line `inquiry, and the Vice-Chancellor shall communicate to the Executive Council the views of the Visitor`
  line `with such advice as the Visitor may offer upon the action to be taken thereon.`
  line
  line `(5) The Executive Council shall communicate through the Vice-Chancellor to the Visitor such action,`
  line `if any, as it is proposed to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(6) Where the Executive Council does not, within a reasonable time, take action to the satisfaction of`
  line `the Visitor, the Visitor may, after considering any explanation furnished or representation made by the`
  line `Executive Council, issue such directions as he may think fit and the Executive Council shall be bound to`
  line `comply with such directions.`
  line
  line `(7) Without prejudice to the foregoing provisions of this section the Visitor may, by order in writing,`
  line `annul any proceeding of the University which is not in conformity with this Act, the Statutes or the`
  line `Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the University to show cause why`
  line `such an order should not be made and if any cause is shown within a reasonable time, shall consider the`
  line same.]
obj_root_law_sections_6:
  sectionId (40813)
  sectionNo (6)
  orderNo 7
  title `Officers of the University.`
  content obj_root_law_sections_6_content
  footnotes `1. Subs. by Act 52 of 1966, s. 7, for sections 6 and 7 (w.e.f. 31-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40813&sectionno=6&orderno=7&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_6_content:
  string
  line `^1[6. Officers of the University.--The following shall be the officers of the University, namely:--`
  line
  line `(a) the Chancellor,`
  line
  line `(b) the Vice-Chancellor,`
  line
  line `(c) the Rector,`
  line
  line `(d) the Registrar,`
  line
  line `(e) the Finance Officer,`
  line
  line `(f) the Deans of Faculties,`
  line
  line `(g) the Dean of Students,`
  line
  line `(h) the Librarian,`
  line
  line `(i) the Chief Proctor,`
  line
  line `(j) such other persons in the service of the University as may be declared by the Statutes to be the`
  line `officers of the University.]`
obj_root_law_sections_7:
  sectionId (40814)
  sectionNo (7)
  orderNo 8
  title Chancellor.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40814&sectionno=7&orderno=8&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_7_content:
  string
  line `(1) The Chancellor shall be elected by the Court and shall hold office for a term of`
  line `three years:`
  line
  line `Provided that the Chancellor shall, notwithstanding the expiration of his term, continue to hold his`
  line `office until the election of his successor.`
  line
  line `(2) If the office of the Chancellor becomes vacant, the functions of his office shall, until some person`
  line `is elected under sub-section (1) to the vacant office, be performed by the Vice-Chancellor.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_7_a:
  sectionId (40815)
  sectionNo 7A
  orderNo 9
  title `Powers of Chancellor.`
  content obj_root_law_sections_7_a_content
  footnotes obj_root_law_sections_7_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40815&sectionno=7A&orderno=9&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_7_a_content:
  string
  line `(1) The Chancellor shall, by virtue of his office, be the Head of the`
  line University.
  line
  line `(2) The Chancellor shall, if present, preside at convocation of the University for conferring degrees`
  line `and at all meetings of the Court.`
obj_root_law_sections_7_a_footnotes:
  string
  line
obj_root_law_sections_7_b:
  sectionId (40816)
  sectionNo 7B
  orderNo 10
  title Vice-Chancellor.
  content obj_root_law_sections_7_b_content
  footnotes obj_root_law_sections_7_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40816&sectionno=7B&orderno=10&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_7_b_content:
  string
  line `^1[(1) The Vice-Chancellor shall be appointed by the Visitor on the`
  line `recommendation of a Selection Committee constituted by the Visitor for the purpose:`
  line
  line `Provided that, if the Visitor does not approve of such recommendation, he may call for one or more`
  line `fresh recommendations.]`
  line
  line `(3) The Vice-Chancellor shall be a whole-time salaried officer of the University.`
  line
  line `(4) The Vice-Chancellor shall hold office for a term of ^2[three years] from the date on which he enters`
  line `upon his office and shall, on the expiration of his term of office, be ^3[eligible for reappointment to that`
  line `office for a second term]:`
  line
  line `Provided that the Vice-Chancellor shall, notwithstanding the expiration of his term, continue to`
  line `hold his office until his successor is appointed and enters upon his office.`
  line
  line `(5) The emoluments and other terms and conditions of service of the Vice-Chancellor shall be`
  line `prescribed by the Statutes.`
  line
  line `(6) If the office of the Vice-Chancellor becomes vacant, the functions of his office shall, until some`
  line `person is appointed under sub-section (1) to the vacant office, be performed by the Rector:`
  line
  line `Provided that if there is no Rector, the Registrar shall carry on the current duties of the ViceChancellor and call a meeting of the Executive Council forthwith and take its directions for the carrying`
  line `on of the work of the University.`
obj_root_law_sections_7_b_footnotes:
  string
  line `1. Subs. by Act 34 of 1969, s. 2, for sub-sections (1) and (2) (w.e.f. 5-9-1969).`
  line
  line `2. Subs. by s. 2, ibid., for "five years" (w.e.f. 5-9-1969).`
  line
  line `3. Subs. by s. 2, ibid., for "ineligible for reappointment to that office" (w.e.f. 5-9-1969).`
obj_root_law_sections_7_c:
  sectionId (40817)
  sectionNo 7C
  orderNo 11
  title `Powers and duties of Vice-Chancellor.`
  content obj_root_law_sections_7_c_content
  footnotes obj_root_law_sections_7_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40817&sectionno=7C&orderno=11&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_7_c_content:
  string
  line `(1) The Vice-Chancellor who shall be the principal`
  line `executive and academic officer of the University, shall take rank next to the Chancellor and shall exercise`
  line `general supervision and control over the affairs of the University and give effect to the decisions of its`
  line authorities.
  line
  line `(2) The Vice-Chancellor shall be the ex officio Chairman of the Executive Council, the Academic`
  line `Council ^1*** and the Finance Committee and shall, in the absence of the Chancellor, preside at any`
  line `convocation of the University for conferring degrees and also at any meeting of the Court; he shall be`
  line `entitled to be present at and to address any meeting of any authority or board or committee of the`
  line `University but shall not be entitled to vote thereat unless he is a member of such authority or board or`
  line committee.
  line
  line `(3) It shall be the duty of the Vice-Chancellor to see that the provisions of this Act, the Statutes,`
  line `the Ordinances and the Regulations are duly observed.`
  line
  line `(4) The Vice-Chancellor shall have power to convene meetings of the Court, the Executive`
  line `Council, ^2[and the Academic Council] and shall perform all such acts as may be necessary to carry out the`
  line `provisions of this Act, the Statutes and the Ordinances.`
  line
  line `(5) If, in the opinion of the Vice-Chancellor, any emergency has arisen which requires immediate`
  line `action to be taken, the Vice-Chancellor shall take such action as he deems necessary and shall report the`
  line `same for approval at the next meeting to the authority which, in the ordinary course, would have dealt`
  line `with the matter:`
  line
  line `Provided that, if the action taken by the Vice-Chancellor is not approved by the authority concerned,`
  line `he may refer the matter to the Visitor, whose decision thereon shall be final.`
  line
  line `Provided further that, where any such action taken by the Vice-Chancellor affects any person in the`
  line `service of the University, such person, shall be entitled to prefer, within thirty days from the date on`
  line `which he receives notice of such action, an appeal to the Executive Council.`
  line
  line `(6) The Vice-Chancellor shall exercise such other powers as may be prescribed by the Statutes,`
  line `the Ordinances or the Regulations.`
obj_root_law_sections_7_c_footnotes:
  string
  line `1. The words ", the Standing Committee of the Academic Council" omitted by Act 34 of 1969, s. 3 (w.e.f. 5-9-1969).`
  line
  line `2. Subs. by s. 2, ibid., for ", the Academic Council and the Standing Committee of the Academic Council" (w.e.f. 5-9-1969).`
obj_root_law_sections_8:
  sectionId (40818)
  sectionNo (8)
  orderNo 12
  title `Powers and duties of officers, terms of office and filling of casual vacancies.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 52 of 1966, s. 8, for "the officers of the University" (w.e.f. 31-12-1966).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40818&sectionno=8&orderno=12&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_8_content:
  string
  line `Subject to the`
  line `provisions of this Act, the powers and duties of ^1[the other officers of the University] the term for which`
  line `they shall hold office, and the filling up of casual vacancies in such offices, shall be provided for by the`
  line Statutes.
obj_root_law_sections_8_a:
  sectionId (40819)
  sectionNo 8A
  orderNo 13
  title `Authorities of the University.`
  content obj_root_law_sections_8_a_content
  footnotes obj_root_law_sections_8_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40819&sectionno=8A&orderno=13&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_8_a_content:
  string
  line `^1[8A. Authorities of the University.--The following shall be the authorities of the University,`
  line `namely:--`
  line
  line `(a) the Court,`
  line
  line `(b) the Executive Council,`
  line
  line `(c) the Academic Council,`
  line
  line `^2* * * * *`
  line
  line `(e) the Finance Committee,`
  line
  line `(f) the Faculties,`
  line
  line `(g) such other authorities as may be declared by the Statutes to be the authorities of the`
  line University.]
obj_root_law_sections_8_a_footnotes:
  string
  line `1. Ins. by s. 9, ibid. (w.e.f. 31-12-1966).`
  line
  line `2. Clause (d) omitted by Act 34 of 1969, s. 4 (w.e.f. 5-9-1969).`
obj_root_law_sections_9:
  sectionId (40820)
  sectionNo (9)
  orderNo 14
  title `The Court.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40820&sectionno=9&orderno=14&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_9_content:
  string
  line `^1[ ^2[9. The Court.--The Court shall be an advisory body and its functions shall be--`
  line
  line `(a) to advise the Visitor in respect of any matter which may be referred to it for advice;`
  line
  line `(b) to advise any authority of the University in respect of any matter which may be referred to the`
  line `Court by such authority; and`
  line
  line `(c) to perform such other duties and exercise such other powers as may be assigned to it by the`
  line `Visitor or under this Act.`
obj_root_law_sections_9_footnotes:
  string
  line `1. Subs. by s. 5, ibid., for sections 9 and 9A (w.e.f. 5-9-1969).`
  line
  line `2. Subs. by Act 52 of 1966, s. 10, for sections 9 and 10 (w.e.f. 31-12-1966).`
obj_root_law_sections_10:
  sectionId (40821)
  sectionNo (10)
  orderNo 15
  title `Executive Council.`
  content obj_root_law_sections_10_content
  footnotes `1. Subs. by Act 34 of 1969, s. 6, for "Court" (w.e.f. 5-9-1969).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40821&sectionno=10&orderno=15&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_10_content:
  string
  line `(1) The Executive Council shall, subject to the control of the ^1[Visitor] be`
  line `the executive body of the University and shall have charge of the management and administration of the`
  line `revenue and property of the University and the conduct of all administrative affairs of the University not`
  line `otherwise provided for.`
  line
  line `(2) Subject to the provisions of this Act, the Executive Council shall exercise such other powers and`
  line `perform such other duties as may be conferred or imposed on it by the Statutes or the Ordinances.]`
obj_root_law_sections_11:
  sectionId (40822)
  sectionNo (11)
  orderNo 16
  title `The Academic Council.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00037_191516_1523342355197&sectionId=40822&sectionno=11&orderno=16&orgactid=AC_CEN_9_30_00037_191516_1523342355197
obj_root_law_sections_11_content:
  string
  line `(1) The ^1[Academic Council] shall be the academic body of the`
  line `University and, subject to the Act, the Statutes and ^2[Ordinances] shall have ^3*** charge of`
  line `the organization of] ^4[study and research] in the University and the Colleges, the courses of study and`
  line `the examination ^5*** of students and the conferment of ordinary and honorary`
  line `degrees ^6and shall exercise such other powers and perform such other duties as may be conferred or`
  line `imposed on it by the Statutes and Ordinances, and shall have the right to advise the Executive Council on`
  line `all academic matters].`
  line
  line `^7 * * * *`
obj_root_law_sections_11_footnotes:
  string
  line `1. Subs. by Act 55 of 1951, s. 2, for "Senate" (w.e.f. 3-11-1951).`
  line
  line `2. Subs. by s. 2, ibid., for "Regulations" (w.e.f. 3-11-1951).`
  line
  line `3. The word "entire" omitted by s. 7, ibid. (w.e.f. 3-11-1951).`
  line
  line `4. Subs. by Act 52 of 1966, s. 11, for "instruction" (w.e.f. 31-12-1966).`
  line
  line `5. The words "and discipline" omitted by s. 11, ibid. (w.e.f. 31-12-1966).`
  line
  line `6. Ins. by s. 11, ibid. (w.e.f. 31-12-1966).`
  line
  line `7. Sub-section (2) omitted by Act 55 of 1951, s. 7 (w.e.f. 3-11-1951).`
