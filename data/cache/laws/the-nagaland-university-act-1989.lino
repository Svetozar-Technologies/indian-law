  (str actYear) (str 1989)
  (str ministry) (str `Ministry of Education`)
  (str department) (str `Department of Higher Education`)
  (str longTitle) (str `An Act to establish and incorporate a teaching and affiliating University in the State of Nagaland and to provide for matters connected therewith or incidental thereto.`)
