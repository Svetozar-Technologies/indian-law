obj_root_law_sections_1:
  sectionId (41119)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41119&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Nagaland University Act, 1989.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 6th September, 1994, vide notification No. S.O. 644(E), dated 6th September, 1994, see Gazette of India, 1994, Extraordinary,`
  line `Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (41120)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41120&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made thereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(d) "Chancellor", "Vice-Chancellor" and "Pro-Vice-Chancellor" mean, respectively, the`
  line `Chancellor, Vice-Chancellor and Pro-Vice-Chancellor of the University;`
  line
  line `(e) "College" means a College maintained by, or admitted to the privileges of, the University;`
  line
  line `(f) "Court" means the Court of the University;`
  line
  line `(g) "Department" means a Department of Studies; and includes a Centre of Studies;`
  line
  line `(h) "distance education system" means the system of imparting education through any means of`
  line `communication, such as broadcasting, telecasting, correspondence courses, seminars, contact`
  line `programmes or the combination of any two or more such means;`
  line
  line `(i) "employee" means any person appointed by the University, and includes teachers and other`
  line `staff of the University;`
  line
  line `(j) "Executive Council" means the Executive Council of the University;`
  line
  line `(k) "Hall" means a unit of residence or of corporate life for the students of the University, or of a`
  line `College or an Institution, maintained by the University;`
  line
  line `(l) "Institution" means an academic institution, not being a College, maintained by, or admitted to`
  line `the privileges of the University;`
  line
  line `(m) "North-Eastern Hill University" means the University established under section 3 of the`
  line `North-Eastern Hill University Act, 1973 (24 of 1973);`
  line
  line `(n) "Planning Board" means the Planning Board of the University;`
  line
  line `(o) "Principal" means the Head of a College or an Institution maintained by the University and`
  line `includes, where there is no Principal, the person for the time being duly appointed to act as Principal,`
  line `and in the absence of the Principal or the acting Principal, a Vice-Principal duly appointed as such;`
  line
  line `(p) "recognised Institution" means an institution of higher learning recognised by the University;`
  line
  line `(q) "recognised teachers" means such persons as may be recognised by the University for the`
  line `purpose of imparting instructions in a College or an Institution admitted to the privileges of the`
  line University;
  line
  line `(r) "Regulations" means the Regulations made by any authority of the University under this Act`
  line `for the time being in force;`
  line
  line `(s) "School" means a School of Studies of the University;`
  line
  line `(t) "Statutes" and "Ordinances" mean, respectively, the Statues and the Ordinances of the`
  line `University for the time being in force;`
  line
  line `(u) "teachers of the University" means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instruction or conducting research in the University or in any College`
  line `or Institution maintained by the University and are designated as teachers by the Ordinances;`
  line
  line `(v) "University" means the Nagaland University established under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (41121)
  sectionNo (3)
  orderNo 3
  title `The University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41121&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established a University by the name of "Nagaland`
  line `University".`
  line
  line `(2) The headquarters of the University shall be at Lumami and it may also establish campuses at such`
  line `other places within its jurisdiction as it may deem fit.`
  line
  line `(3) The first Chancellor and the first Vice-Chancellor and the first members of the Court, the`
  line `Executive Council, the Academic Council and the Planning Board and all persons who may hereafter`
  line `become such officers or members, so long as they continue to hold such office or membership, are hereby`
  line `constituted a body corporate by the name of "Nagaland University".`
  line
  line `(4) The University shall have perpetual succession and a common seal and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (41122)
  sectionNo (4)
  orderNo 4
  title `Objects of the University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41122&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_4_content:
  string
  line `The objects of the University shall be to disseminate and advance`
  line `knowledge by providing instructional and research facilities in such branches of learning as it may deem`
  line `fit; to make provisions for integrated courses in humanities, natural and physical sciences, social`
  line `sciences, agricultural science and forestry and other allied disciplines in the educational programmes of`
  line `the University; and to take appropriate measures for promoting innovations in teaching-learning`
  line `processes, inter-disciplinary studies and research; to educate and train manpower for the development of`
  line `the State of Nagaland; and to pay special attention to the improvement of the social and economic`
  line `conditions and welfare of the people of that State, their intellectual, academic and cultural development.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (41123)
  sectionNo (5)
  orderNo 5
  title `Transfer of properties of North-Eastern Hill University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41123&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_5_content:
  string
  line `On and from the commencement of`
  line `this Act, all properties of the North-Eastern Hill University in the State of Nagaland shall stand`
  line `transferred to, and vest in, the University and shall be applied to the objects for which the University is`
  line established.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (41124)
  sectionNo (6)
  orderNo 6
  title `Powers of the University.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41124&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_6_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instruction in such branches of learning as the University may, from time to`
  line `time, determine and to make provision for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing, on persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(iii) to organise and to undertake extra-mural studies, training and extension services;`
  line
  line `(iv) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(v) to provide facilities through the distance education system to such persons as it may`
  line determine;
  line
  line `(vi) to institute Principalships, Professorships, Readerships, Lecturerships and other teaching or`
  line `academic positions, required by the University and to appoint persons to such Principalships,`
  line `Professorships, Readerships, Lecturerships or other teaching or academic positions;`
  line
  line `(vii) to recognise an institution of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(viii) to recognise persons for imparting instructions in any College or Institution admitted to the`
  line `privileges of the University;`
  line
  line `(ix) to appoint persons working in any other University or organisation as teachers of the`
  line `University for a specified period;`
  line
  line `(x) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(xi) to co-operate or collaborate or associate with any other University or authority or institution`
  line `of higher learning in such manner and for such purposes as the University may determine;`
  line
  line `(xii) to establish such campuses, special centres, specialised laboratories or other units for`
  line `research and instruction as are, in the opinion of the University, necessary for the furtherance of its`
  line objects;
  line
  line `(xiii) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xiv) to establish and maintain Colleges, Institutions and Halls;`
  line
  line `(xv) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions, industrial or other organisations, as the University may deem`
  line necessary;
  line
  line `(xvi) to organise and conduct refresher courses, workshops, seminars and other programmes for`
  line `teachers, evaluators and other academic staff;`
  line
  line `(xvii) to admit to its privileges colleges and institutions not maintained by the University; to`
  line `withdraw all or any of those privileges in accordance with such conditions as may be prescribed by`
  line `the Statutes; to recognise, guide, supervise, and control Halls not maintained by the University and`
  line `other accommodation for students, and to withdraw any such recognition;`
  line
  line `(xviii) to appoint on contract or otherwise visiting Professors, Emeritus Professors, Consultants,`
  line `Scholars and such other persons who may contribute to the advancement of the objects of the`
  line University;
  line
  line `(xix) to confer autonomous status on a College or an Institution or a Department, as the case may`
  line `be, in accordance with the Statutes;`
  line
  line `(xx) to determine standards of admission to the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xxi) to demand and receive payment of fees and other charges;`
  line
  line `(xxii) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xxiii) to lay down conditions of service of all categories of employees, including their code of`
  line conduct;
  line
  line `(xxiv) to regulate and enforce discipline among the students and the employees, and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxv) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(xxvi) to receive benefactions, donations and gifts and to acquire, hold, manage and dispose of`
  line `any property, movable or immovable, including trust and endowment properties for the purposes of`
  line `the University;`
  line
  line `(xxvii) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University;`
  line
  line `(xxviii) to do all such other acts and things as may be necessary, incidental or conceive to the`
  line `attainment of all or any of its objects.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (41125)
  sectionNo (7)
  orderNo 7
  title Jurisdiction.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41125&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_7_content:
  string
  line `(1) The jurisdiction of the University shall extend to the whole of the State of`
  line Nagaland.
  line
  line `(2) On and from commencement of this Act, all Colleges, Institutions, Schools and Departments`
  line `affiliated to, or admitted to the privileges of, or maintained by, the North-Eastern Hill University shall`
  line `stand affiliated to, or admitted to the privileges of, or maintained by, the University.`
  line
  line `(3) On and from the date of commencement of this Act, the North-Eastern Hill University shall cease`
  line `to exercise its jurisdiction in the State of Nagaland.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (41126)
  sectionNo (8)
  orderNo 8
  title `University open to all classes, castes and creed.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41126&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_8_content:
  string
  line `The University shall be open to persons of`
  line `either sex and of whatever caste, creed, race or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person, any test whatsoever of religious belief or profession in order to entitle him to be`
  line `appointed as a teacher of the University or to hold any other office therein or be admitted as a student in`
  line `the University or to graduate thereat or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for the employment or admission of women, physically handicapped or of persons belonging`
  line `to the weaker sections of the society and, in particular, of the Scheduled Castes and the Scheduled Tribes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (41127)
  sectionNo (9)
  orderNo 9
  title `The Visitor.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41127&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_9_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University, including Colleges and Institutions managed by it, and to submit a report thereon; and`
  line `upon receipt of that report, the Visitor may, after obtaining the views of the Executive Council thereon`
  line `through the Vice-Chancellor, take such action and issue such directions as he considers necessary in`
  line `respect of any of the matters dealt with in the report and the University shall be bound to comply with`
  line `such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection to be made by such person or persons as he`
  line `may direct, of the University, its buildings, laboratories and equipment, and of any College or Institution`
  line `maintained by the University or admitted to its privileges; and also of the examinations, teaching and`
  line `other work conducted or done by the University and to cause an inquiry to be made in like manner in`
  line `respect of any matter connected with the administration or finances of the University, Colleges of`
  line Institutions.
  line
  line `(4) The Visitor shall, in every matter referred to in sub-section (2), give notice of his intention to`
  line `cause an inspection or inquiry to be made,--`
  line
  line `(a) to the University, if such inspection or inquiry is to be made in respect of the University or`
  line `any College or Institution maintained by it, or`
  line
  line `(b) to the management of the College or Institution, if the inspection or inquiry is to be made in`
  line `respect of the College or Institution admitted to the privileges of the University, and the University or the management, as the case may be, shall have the right to make such`
  line `representations to the Visitor, as it may consider necessary.`
  line
  line `(5) After considering the representations, if any, made by the University or the management, as the`
  line `case may be, the Visitor may cause to be made such inspection or inquiry as is referred to in`
  line `sub-section (3).`
  line
  line `(6) Where any inspection or inquiry has been caused to be made by the Visitor, the University or the`
  line `management shall be entitled to appoint a representative, who shall have the right to be present and be`
  line `heard at such inspection or inquiry.`
  line
  line `(7) The Visitor may, if the inspection or inquiry is made in respect of the University or any College or`
  line `Institution maintained by it, address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry together with such views and advice with regard to the action to be taken thereon, as the Visitor`
  line `may be pleased to offer, and on receipt of address made by the Visitor, the Vice-Chancellor shall`
  line `communicate, to the Executive Council, the views of the Visitor with such advice as the Visitor may offer`
  line `upon the action to be taken thereon.`
  line
  line `(8) The Visitor may, if the inspection or inquiry is made in respect of any College or Institution`
  line `admitted to the privileges of the University, address the management concerned through Vice-Chancellor`
  line `with reference to the result of such inspection or inquiry, his views thereon and such advice as he may be`
  line `pleased to offer upon the action to be taken thereon.`
  line
  line `(9) The Executive Council or the management, as the case may be, shall communicate, through the`
  line `Vice-Chancellor to the Visitor such action, if any, as it proposes to take or has been taken upon the result`
  line `of such inspection or inquiry.`
  line
  line `(10) Where, the Executive Council or the management, does not, within a reasonable time, take action`
  line `to the satisfaction of the Visitor, the Visitor may, after considering any explanation furnished or`
  line `representation made by the Executive Council or the management, issue such directions as he may think`
  line `fit and the Executive Council or the management, as the case may be, shall comply with such directions.`
  line
  line `(11) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annul any proceeding of the University which is not in conformity with the Act, the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the Registrar to show cause why such`
  line `an order should not be made, and, if any cause is shown within a reasonable time, he shall consider the`
  line same.
  line
  line `(12) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (41128)
  sectionNo (10)
  orderNo 10
  title `The Chief Rector.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41128&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_10_content:
  string
  line `The Governor of the State of Nagaland shall be the Chief Rector of the`
  line University.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (41129)
  sectionNo (11)
  orderNo 11
  title `Officers of the University.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41129&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_11_content:
  string
  line `The following shall be the officers of the University:--`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Pro-Vice-Chancellor;`
  line
  line `(4) the Deans of Schools;`
  line
  line `(5) the Registrar;`
  line
  line `(6) the Finance Officer; and`
  line
  line `(7) such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (41130)
  sectionNo (12)
  orderNo 12
  title `The Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41130&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_12_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the Head of the University.`
  line
  line `(3) The Chancellor shall, if present, preside at the convocations of the University held for conferring`
  line degrees.
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (41131)
  sectionNo (13)
  orderNo 13
  title `The Vice-Chancellor.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41131&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_13_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor may, if he is of opinion that immediate officer of the University, and shall`
  line `exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been taken, it`
  line `may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to appeal against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated`
  line `to him and thereupon the Executive Council may confirm, modify or reverse the action taken by the`
  line Vice-Chancellor.
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the University is`
  line `beyond the powers of the authority conferred by the provisions of this Act, the Statutes or the Ordinances`
  line `or that any decision taken is not in the interest of the University, may ask the authority concerned to`
  line `review its decision within sixty days of such decision and if the authority refuses to review the decision`
  line `either in whole or in part or no decision is taken by it within the said period of sixty days, the matter shall`
  line `be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (41132)
  sectionNo (14)
  orderNo 14
  title `The Pro-Vice-Chancellor.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41132&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_14_content:
  string
  line `The Pro-Vice-Chancellor shall be appointed in such manner and`
  line `shall exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (41133)
  sectionNo (15)
  orderNo 15
  title `Deans of Schools.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41133&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_15_content:
  string
  line `Every Dean of a School shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (41134)
  sectionNo (16)
  orderNo 16
  title `The Registrar.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41134&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_16_content:
  string
  line `(1) The Registrar shall be appointed in such manner as may be prescribed by the`
  line Statutes.
  line
  line `(2) The Registrar shall have the power to enter into agreement, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such powers and perform such duties as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (41135)
  sectionNo (17)
  orderNo 17
  title `The Finance Officer.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41135&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_17_content:
  string
  line `The Finance Officer shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (41136)
  sectionNo (18)
  orderNo 18
  title `Other officers.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41136&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_18_content:
  string
  line `The manner of appointment and powers and duties of the other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (41137)
  sectionNo (19)
  orderNo 19
  title `Authorities of the University.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41137&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_19_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(1) the Court;`
  line
  line `(2) the Executive Council;`
  line
  line `(3) the Academic Council;`
  line
  line `(4) the Planning Board;`
  line
  line `(5) the Boards of Schools;`
  line
  line `(6) the Finance Committee; and`
  line
  line `(7) such other authorities as may be declared by the Statutes to be the authorities of the`
  line University.
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (41138)
  sectionNo (20)
  orderNo 20
  title `The Court.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41138&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_20_content:
  string
  line `(1) The constitution of the Court and the term of office of its members shall be`
  line `prescribed by the Statutes.`
  line
  line `(2) Subject to the provisions of this Act, the Court shall have the following powers and functions,`
  line `namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the University`
  line `and the audit report on such accounts;`
  line
  line `(c) to advise the Visitor in respect of any matter which may be referred to it for advice; and`
  line
  line `(d) to perform such other functions as may be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (41139)
  sectionNo (21)
  orderNo 21
  title `The Executive Council.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41139&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_21_content:
  string
  line `(1) The Executive Council shall be the principal executive body of the`
  line University.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (41140)
  sectionNo (22)
  orderNo 22
  title `The Academic Council.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41140&sectionno=22&orderno=22&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_22_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and the Ordinances, co-ordinate`
  line `and exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (41141)
  sectionNo (23)
  orderNo 23
  title `The Planning Board.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41141&sectionno=23&orderno=23&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_23_content:
  string
  line `(1) The Planning Board shall be the principal planning body of the`
  line University.
  line
  line `(2) The constitution of the Planning Board, term of office of its members and its powers and functions`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (41142)
  sectionNo (24)
  orderNo 24
  title `The Boards of Schools.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41142&sectionno=24&orderno=24&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_24_content:
  string
  line `The constitution, powers and functions of the Boards of Schools shall`
  line `be prescribed by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (41143)
  sectionNo (25)
  orderNo 25
  title `The Finance Committee.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41143&sectionno=25&orderno=25&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_25_content:
  string
  line `The constitution, powers and functions of the Finance Committee`
  line `shall be prescribed by the Statutes.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (41144)
  sectionNo (26)
  orderNo 26
  title `Other authorities of the University.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41144&sectionno=26&orderno=26&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_26_content:
  string
  line `The constitution, powers and functions of other`
  line `authorities, as may be declared by the Statutes to be the authorities of the University, shall be prescribed`
  line `by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (41145)
  sectionNo (27)
  orderNo 27
  title `Power to make Statutes.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41145&sectionno=27&orderno=27&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_27_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all`
  line `or any of the following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of the authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the appointment and continuance in office of the members of the said authorities and bodies,`
  line `the filling up of vacancies of members, and all other matters relating to those authorities and other`
  line `bodies for which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments;`
  line
  line `(d) the appointment of teachers, academic staff and other employees of the University and their`
  line emoluments;
  line
  line `(e) the appointment of teachers, academic staff working in any other University or organisation`
  line `for a specific period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provision for pension, insurance and`
  line `provident fund, the manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing the seniority of service of the employees of the University;`
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and the`
  line University;
  line
  line `(i) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(j) the conferment of autonomous status on a College or an Institution or a Department;`
  line
  line `(k) the establishment and abolition of Schools, Departments, Centres, Halls, Colleges and`
  line Institutions;
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(n) the conditions under which Colleges and Institutions may be admitted to the privileges of the`
  line `University and the withdrawal of such privileges;`
  line
  line `(o) the institution of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(p) the delegation of powers vested in the authorities or officers of the University;`
  line
  line `(q) the maintenance of discipline among the employees and students;`
  line
  line `(r) all other matters which by this Act are to be or may be provided for by the Statutes.`
obj_root_law_sections_27_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (41146)
  sectionNo (28)
  orderNo 28
  title `Statutes how to be made.`
  content obj_root_law_sections_28_content
  footnotes obj_root_law_sections_28_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41146&sectionno=28&orderno=28&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_28_content:
  string
  line `(1) The first Statutes are those set out in the Schedule.`
  line
  line `(2) The Executive Council may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in sub-section (1):`
  line
  line `Provided that the Executive Council shall not make, amend or repeal any Statutes affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Executive Council.`
  line
  line `(3) Every new Statutes or addition to the Statute or any amendment or repeal of a Statute shall require`
  line `the assent of the Visitor who may assent thereto or withhold assent or remit to the Executive Council for`
  line consideration.
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity`
  line `unless it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may make new or`
  line `additional Statutes or amend or repeal the Statutes referred to in sub-section (1), during the period of three`
  line `years immediately after the commencement of this Act:`
  line
  line `Provided that the Visitor may, on the expiry of the said period of three years, make, within one year`
  line `from the date of such expiry, such detailed Statutes as he may consider necessary and such detailed`
  line `Statutes shall be laid before both Houses of Parliament.`
  line
  line `(6) Notwithstanding anything contained in the foregoing sub-section, the Visitor may direct the`
  line `University to make provisions in the Statutes in respect of any matter specified by him and if the`
  line `Executive Council is unable to implement such direction within sixty days of its receipt, the Visitor may,`
  line `after considering the reasons, if any, communicated by the Executive Council for its inability to comply`
  line `with such direction, make or amend the Statutes suitably.`
obj_root_law_sections_28_footnotes:
  string
  line
obj_root_law_sections_29:
  sectionId (41147)
  sectionNo (29)
  orderNo 29
  title `Power to make Ordinances.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41147&sectionno=29&orderno=29&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_29_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the`
  line `Ordinances may provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the medium of instruction and examination;`
  line
  line `(d) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(e) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(f) the conditions for award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(g) the conduct of examinations, including the term of office and manner of appointment and the`
  line `duties of examining bodies, examiners and moderators;`
  line
  line `(h) the conditions of residence of the students of the University;`
  line
  line `(i) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing of special courses of studies for them;`
  line
  line `(j) the appointment and emoluments of employees other than those for whom provision has been`
  line `made in the Statutes;`
  line
  line `(k) the establishment of Centres of Studies, Boards of Studies, Special Centres, Specialised`
  line `Laboratories and other Committee;`
  line
  line `(l) the manner of co-operation and collaboration with other Universities and authorities including`
  line `learned bodies or associations;`
  line
  line `(m) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(n) such other terms and conditions of service of teachers and other academic staff as are not`
  line `prescribed by the Statutes;`
  line
  line `(o) the management of Colleges and Institutions established by the University;`
  line
  line `(p) the supervision and management of Colleges and Institutions admitted to the privileges of the`
  line University;
  line
  line `(q) the setting up of a machinery for redressal of grievances of employees; and`
  line
  line `(r) all other matters which by this Act or the Statutes may be provided for by the Ordinances.`
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Central Government and the Ordinances so made may be amended, repealed or added to at any time by`
  line `the Executive Council in the manner prescribed by the Statutes.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (41148)
  sectionNo (30)
  orderNo 30
  title Regulations.
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41148&sectionno=30&orderno=30&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_30_content:
  string
  line `The authorities of the University may make Regulations, consistent with this Act,`
  line `the Statutes and the Ordinances for the conduct of their own business and that of the Committees`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances, in the manner`
  line `prescribed by the Statutes.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (41149)
  sectionNo (31)
  orderNo 31
  title `Annual report.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41149&sectionno=31&orderno=31&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_31_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Executive Council, which shall include, among other matters, the steps taken by the University`
  line `towards the fulfilment of its objects and shall be submitted to the Court on or after such date as may be`
  line `prescribed by the Statutes and the Court shall consider the report in its annual meeting.`
  line
  line `(2) The Court shall submit the annual report to the Visitor along with its comments, if any.`
  line
  line `(3) A copy of the annual report, as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (41150)
  sectionNo (32)
  orderNo 32
  title `Annual accounts.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41150&sectionno=32&orderno=32&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_32_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be`
  line `prepared under the directions of the Executive Council and shall, once at least every year and at intervals`
  line `of not more than fifteen months, be audited by the Comptroller and Auditor-General of India or by such`
  line `persons as he may authorise in this behalf.`
  line
  line `(2) A copy of the annual accounts together with the audit report thereon shall be submitted to the`
  line `Court and the Visitor along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Court and the observations of the Court, if any, shall, after being considered by the Executive Council, be`
  line `submitted to the Visitor.`
  line
  line `(4) A copy of the annual accounts together with the audit report as submitted to the Visitor, shall also`
  line `be submitted to the Central Government, which shall, as soon as may be, cause the same to be laid before`
  line `both Houses of Parliament.`
  line
  line `(5) The audited annual accounts after having been laid before both Houses of Parliament shall be`
  line `published in the Gazette of India.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (41151)
  sectionNo (33)
  orderNo 33
  title `Transfer of services of certain employees of the North-Eastern Hill University.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41151&sectionno=33&orderno=33&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_33_content:
  string
  line `(1) Subject`
  line `to the provisions of this Act, every person employed immediately before the commencement of this Act`
  line `by the North-Eastern Hill University in the State of Nagaland shall be given an option, to be exercised in`
  line `such manner and within such time as may be prescribed by the Statutes, to join the University on the`
  line `same terms and conditions and to the same rights and privileges as to pension, gratuity, provident fund`
  line `and other matters, as he would have had under the North-Eastern Hill University Act, 1973 (24 of 1973).`
  line
  line `(2) The option once exercised by the person under sub-section (1) shall be final.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (41152)
  sectionNo (34)
  orderNo 34
  title `Conditions of service of employees.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41152&sectionno=34&orderno=34&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_34_content:
  string
  line `(1) Every employee of the University shall be appointed`
  line `under a written contract, which shall be lodged with the University and a copy of which shall be furnished`
  line `to the employee concerned.`
  line
  line `(2) Any dispute arising out of the contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Executive Council, one member nominated by the employee concerned and an umpire appointed by`
  line `the Visitor.`
  line
  line `(3) The decision of the Tribunal shall be final, and no suit shall lie in any civil court in respect of the`
  line `matters decided by the Tribunal.`
  line
  line `(4) Every request made by the employee under sub-section (2), shall be deemed to be a submission to`
  line `arbitration upon the terms of this section within the meaning of the Arbitration Act, 1940 (2 of 1940).`
  line
  line `(5) The procedure for regulating the work of the Tribunal shall be prescribed by the Statutes.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (41153)
  sectionNo (35)
  orderNo 35
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41153&sectionno=35&orderno=35&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_35_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the case`
  line `may be, and who has been debarred from appearing at the examinations of the University for more than`
  line `one year, may; within ten days of the date of receipt of such orders or copy of such resolution by him,`
  line `appeal to the Executive Council and the Executive Council may confirm, modify or reverse the decision`
  line `of the Vice-Chancellor or the Committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of sub-sections`
  line `(2), (3), (4) and (5) of section 34 shall, as far as may be, apply to a reference made under this sub-section.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (41154)
  sectionNo (36)
  orderNo 36
  title `Right to appeal.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41154&sectionno=36&orderno=36&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_36_content:
  string
  line `Every employee or student of the University or of a College or Institution`
  line `maintained by the University or admitted to its privileges shall, notwithstanding anything contained in`
  line `this Act, have a right to appeal within such time as may be prescribed by the Statutes, to the Executive`
  line `Council against the decision of any officer or authority of the University or of the Principal or the`
  line `management of any College or an Institution, as the case may be, and thereupon the Executive Council`
  line `may confirm, modify or reverse the decision appealed against.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (41155)
  sectionNo (37)
  orderNo 37
  title `Provident and pension funds.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41155&sectionno=37&orderno=37&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_37_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such provident or pension fund or provide such insurance schemes as it may deem fit in such`
  line `manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident fund or pension fund has been so constituted, the Central Government may`
  line `declare that the provision of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund, as if it`
  line `were a Government provident fund.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (41156)
  sectionNo (38)
  orderNo 38
  title `Disputes as to constitution of University authorities and bodies.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41156&sectionno=38&orderno=38&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_38_content:
  string
  line `If any question arises as to`
  line `whether any person has been duly appointed as, or is entitled to be, a member of any authority or other`
  line `body of the University, the matter shall be referred to the Visitor whose decision thereon shall be final.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (41157)
  sectionNo (39)
  orderNo 39
  title `Constitution of Committees.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41157&sectionno=39&orderno=39&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_39_content:
  string
  line `Where any authority of the University is given power by this Act`
  line `or the Statutes to appoint Committees, such Committees shall, save as otherwise provided, consist of the`
  line `members of the authority concerned and of such other person, if any, as the authority in each case may`
  line `think fit.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (41158)
  sectionNo (40)
  orderNo 40
  title `Filling of casual vacancies.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41158&sectionno=40&orderno=40&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_40_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `members) of any authority or other body of the University shall be filled, as soon as may be, by the`
  line `person or body who appointed or co-opted the member whose place has become vacant and person`
  line `appointed or co-opted to a causal vacancy shall be a member of such authority or body for the residue of`
  line `the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (41159)
  sectionNo (41)
  orderNo 41
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41159&sectionno=41&orderno=41&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_41_content:
  string
  line `No act or`
  line `proceedings of any authority or other body of the University shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_sections_42:
  sectionId (41160)
  sectionNo (42)
  orderNo 42
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_42_content
  footnotes obj_root_law_sections_42_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41160&sectionno=42&orderno=42&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_42_content:
  string
  line `No suit or other legal proceedings shall lie against`
  line `any officer or other employee of the University for anything which is in good faith done or intended to be`
  line `done in pursuance of any of the provisions of this Act, the Statutes or the Ordinances.`
obj_root_law_sections_42_footnotes:
  string
  line
obj_root_law_sections_43:
  sectionId (41161)
  sectionNo (43)
  orderNo 43
  title `Mode of proof of University record.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41161&sectionno=43&orderno=43&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_43_content:
  string
  line `A copy of any receipt, application, notice, order,`
  line `proceeding, resolution of any authority or Committee of the University, or other documents in possession`
  line `of the University, or any entry in any register duly maintained by the University, if certified by the`
  line `Registrar, shall be received as prima facie evidence of such receipt, application, notice, order, proceeding,`
  line `resolution or documents or the existence of entry in the register and shall be admitted as evidence of the`
  line `matters and transactions therein where the original thereof would, if produced, have been admissible in`
  line `evidence, notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872) or in any`
  line `other law for the time being in force.`
obj_root_law_sections_43_footnotes:
  string
  line
obj_root_law_sections_44:
  sectionId (41162)
  sectionNo (44)
  orderNo 44
  title `Power to remove difficulties.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41162&sectionno=44&orderno=44&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_44_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order published in the Official Gazette, make such provisions,`
  line `not inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing`
  line `the difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_44_footnotes:
  string
  line
obj_root_law_sections_45:
  sectionId (41163)
  sectionNo (45)
  orderNo 45
  title `Transitional provisions.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41163&sectionno=45&orderno=45&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_45_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes,--`
  line
  line `(a) the first Chancellor and the first Vice-Chancellor shall be appointed by the Visitor and each of`
  line `the said officers shall hold office for a term of five years;`
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Visitor and each of`
  line `the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Court and the first Executive Council shall consist of not more than thirty members`
  line `and eleven members, respectively, who shall be nominated by the Visitor and shall hold office for a`
  line `term of three years;`
  line
  line `(d) the first Planning Board shall consist of not more than ten members, who shall be nominated`
  line `by the Visitor and they shall hold office for a term of three years;`
  line
  line `(e) the first Academic Council shall be constituted on the expiry of a period of six months from`
  line `the commencement of this Act and during the said period of six months, the powers of the Academic`
  line `Council shall be performed by the Planning Board constituted under section 23;`
  line
  line `(f) the first Academic Council shall consist of not more than twenty-one members, who shall be`
  line `nominated by the Visitor and they shall hold office for a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment or nomination, as the case may be, by the Visitor, and the person so appointed or nominated`
  line `shall hold office for so long as the officer or member in whose place he is appointed or nominated would`
  line `have held office, if such vacancy had not occurred.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (41164)
  sectionNo (46)
  orderNo 46
  title `Completion of courses of studies in Colleges or Institutions affiliated to the University.`
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41164&sectionno=46&orderno=46&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_46_content:
  string
  line `Notwithstanding anything contained in this Act, or in the Statutes or the Ordinances, any`
  line `student of College, Institution, School or Department, who, immediately before the admission of such`
  line `College, Institution, School or Department, to the privileges of the University, was studying for a degree,`
  line `diploma or certificate of the North-Eastern Hill University, shall be permitted by the University, to`
  line `complete his course for that degree, diploma or certificate, as the case may be, and the Nagaland`
  line `University and such College, Institution, School or Department, shall provide for the instructions and`
  line `examination of such student in accordance with the syllabus of studies of the North-Eastern Hill`
  line University.
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (41165)
  sectionNo (47)
  orderNo 47
  title `Statutes, Ordinances and Regulations to be published in the Official Gazette and to be laid before Parliament.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41165&sectionno=47&orderno=47&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_47_content:
  string
  line `(1) Every Statute, Ordinance or Regulation made under this Act shall be published`
  line `in the Official Gazette.`
  line
  line `(2) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however, that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.`
  line
  line `(3) The power to make Statutes, Ordinances or Regulations shall include the power to give`
  line `retrospective effect from a date not earlier than the date of commencement of this Act, to the Statutes,`
  line `Ordinances or Regulations or any of them but no retrospective effect shall be given to any Statute,`
  line `Ordinance or Regulation so as to prejudicially affect the interests of any person to whom such Statute,`
  line `Ordinance or Regulation may be applicable.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (41166)
  sectionNo (48)
  orderNo 48
  title Repealed.
  content obj_root_law_sections_48_content
  footnotes obj_root_law_sections_48_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00008_198935_1517807322669&sectionId=41166&sectionno=48&orderno=48&orgactid=AC_CEN_9_30_00008_198935_1517807322669
obj_root_law_sections_48_content:
  string
  line `[Amendment of Act 24 of 1973.]--Rep. by the Repealing and Amending Act, 2001 (30 of 2001),`
  line `s. 2 and the First Sch. (w.e.f. 3-9-2001).`
obj_root_law_sections_48_footnotes:
  string
  line
