obj_root_law_sections_1:
  sectionId (24677)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24677&sectionno=1&orderno=1&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Official Languages Act, 1963.`
  line
  line `(2) Section 3 shall come into force on the 26th day of January, 1965 and the remaining provisions of`
  line `this Act shall come into force on such date^1`
  line `as the Central Government may, by notification in the Official`
  line `Gazette, appoint and different dates may be appointed for different provisions of this Ac`
obj_root_law_sections_1_footnotes:
  string
  line `1. 10th January, 1965, vide notification No. S.O. 94, dated 4th January, 1965, in respect of section 5(1), see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
  line
  line `19th May, 1969, vide notification No. S.O. 1945, dated the 14th May, 1969, in respect of section 6, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
  line
  line `7th March, 1970, vide notification No. S.O. 841, dated the 26th February, 1970, in respect of section 7, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
  line
  line `1st October, 1976, vide notification No. S.O. 655(E), dated the 5th October, 1976, in respect of section 5(2), see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (24678)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24678&sectionno=2&orderno=2&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "appointed day", in relation to section 3, means the 26th day of January, 1965 and in relation`
  line `to any other provision of this Act, means the day on which that provision comes into force;`
  line
  line `(b) "Hindi" means Hindi in Devanagari Script.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (24679)
  sectionNo (3)
  orderNo 3
  title `Continuance of English language for official purposes of the Union and for use in Parliament.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 1 of 1968, s. 2, for section 3 (w.e.f. 8-1-1968).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24679&sectionno=3&orderno=3&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_3_content:
  string
  line `^1[3. Continuance of English language for official purposes of the Union and for use in`
  line `Parliament.— (1) Notwithstanding the expiration of the period of fifteen years from the commencement`
  line `of the Constitution, the English language may, as from the appointed day, continue to be used, in addition`
  line `to Hindi,—`
  line
  line `(a) for all the official purposes of the Union for which it was being used immediately before that`
  line `day; and`
  line
  line `(b) for the transaction of business in Parliament:`
  line
  line `Provided that the English language shall be used for purposes of communication between the Union`
  line `and a State which has not adopted Hindi as its official language:`
  line
  line `Provided further that where Hindi is used for purposes of communication between one State which`
  line `has adopted Hindi as its official language and another State which has not adopted Hindi as its official`
  line `language, such communication in Hindi shall be accompanied by a translation of the same in the English`
  line `language:`
  line
  line `Provided also that nothing in this sub-section shall be construed as preventing a State which has not`
  line `adopted Hindi as its official language from using Hindi for purposes of communication with the Union or`
  line `with a State which has adopted Hindi as its official language, or by agreement with any other State, and in`
  line `such a case, it shall not be obligatory to use the English language for purposes of communication with`
  line `that State.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where Hindi or the English language is`
  line `used for purposes of communication—`
  line
  line `(i) between one Ministry or Department or office of the Central Government and another;`
  line
  line `(ii) between one Ministry or Department or office of the Central Government and any corporation`
  line `or company owned or controlled by the Central Government or any office thereof;`
  line
  line `(iii) between any corporation or company owned or controlled by the Central Government or any`
  line `office thereof and another,`
  line
  line `a translation of such communication in the English language or, as the case may be, in Hindi shall also be`
  line `provided till such date as the staff of the concerned Ministry, Department, office or corporation or`
  line `company aforesaid have acquired a working knowledge of Hindi.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1), both Hindi and the English language shall`
  line `be used for—`
  line
  line `(i) resolutions, general orders, rules, notifications, administrative or other reports or press`
  line `communiques issued or made by the Central Government or by a Ministry, Department or office`
  line `thereof or by a corporation or company owned or controlled by the Central Government or by any`
  line `office of such corporation or company;`
  line
  line `(ii) administrative and other reports and official papers laid before a House or the Houses of`
  line Parliament;
  line
  line `(iii) contracts and agreements executed, and licences, permits, notices and forms of tender issued,`
  line `by or on behalf of the Central Government or any Ministry, Department or office thereof or by a`
  line `corporation or company owned or controlled by the Central Government or by any office of such`
  line `corporation or company.`
  line
  line `(4) Without prejudice to the provisions of sub-section (1) or sub-section (2) or sub-section (3), the`
  line `Central Government may, by rules made under section 8, provide for the language or languages to be`
  line `used for the official purpose of the Union, including the working of any Ministry, Department, section or`
  line `office, and in making such rules, due consideration shall be given to the quick and efficient disposal of the`
  line `official business and the interests of the general public and in particular, the rules so made shall ensure`
  line `that persons serving in connection with the affairs of the Union and having proficiency either in Hindi or`
  line `in the English language may function effectively and that they are not placed at a disadvantage on the`
  line `ground that they do not have proficiency in both the languages.`
  line
  line `(5) The provisions of clause (a) of sub-section (1), and the provisions of sub-section (2),`
  line `sub-section (3) and sub-section (4) shall remain in force until resolutions for the discontinuance of the use`
  line `of the English language for the purposes mentioned therein have been passed by the Legislatures of all the`
  line `States which have not adopted Hindi as their official language and until after considering the resolutions`
  line `aforesaid, a resolution for such discontinuance has been passed by each House of Parliament.]`
obj_root_law_sections_4:
  sectionId (24680)
  sectionNo (4)
  orderNo 4
  title `Committee on Official Language.`
  content obj_root_law_sections_4_content
  footnotes `1. The proviso added by Act 1 of 1968, s. 3 (w.e.f. 8-1-1968).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24680&sectionno=4&orderno=4&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_4_content:
  string
  line `(1) After the expiration of ten years from the date on which`
  line `section 3 comes into force, there shall be constituted a Committee on Official Language, on a resolution`
  line `to that effect being moved in either House of Parliament with the previous sanction of the President and`
  line `passed by both Houses.`
  line
  line `(2) The Committee shall consist of thirty members of whom twenty shall be members of the House of`
  line `the People and ten shall be members of the Council of States, to be elected respectively by the members`
  line `of the House of the People and the members of the Council of States in accordance with the system of`
  line `proportional representation by means of the single transferable vote.`
  line
  line `(3) It shall be the duty of the Committee to review the progress made in the use of Hindi for the`
  line `official purposes of the Union and submit a report to the President making recommendations thereon and`
  line `the President shall cause the report to be laid before each House of Parliament, and sent to all the State`
  line Governments.
  line
  line `(4) The President may, after consideration of the report referred to in sub-section (3), and the views, if`
  line `any, expressed by the State Governments thereon, issue directions in accordance with the whole or any`
  line `part of that report:`
  line
  line ^1[
  line `Provided that the directions so issued shall not be inconsistent with the provisions of section 3.]`
obj_root_law_sections_5:
  sectionId (24681)
  sectionNo (5)
  orderNo 5
  title `Authorised Hindi translations of Central Acts, etc.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24681&sectionno=5&orderno=5&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_5_content:
  string
  line `(1) A translation in Hindi published under`
  line `the authority of the President in the Official Gazette on and after the appointed day,—`
  line
  line `(a) of any Central Act or of any Ordinance promulgated by the President, or`
  line
  line `(b) of any order, rule, regulation or bye-law issued under the Constitution or under any Central`
  line Act,
  line
  line `shall be deemed to be the authoritative text thereof in Hindi.`
  line
  line `(2) As from the appointed day, the authoritative text in the English language of all Bills to be`
  line `introduced or amendments thereto to be moved in either House of Parliament shall be accompanied by a`
  line `translation of the same in Hindi authorised in such manner as may be prescribed by rules made under this`
  line Act.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (24682)
  sectionNo (6)
  orderNo 6
  title `Authorised Hindi translation of State Acts in certain cases.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24682&sectionno=6&orderno=6&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_6_content:
  string
  line `Where the Legislature of a State`
  line `has prescribed any language other than Hindi for use in Acts passed by the Legislature of the State or in`
  line `Ordinances promulgated by the Governor of the State, a translation of the same in Hindi, in addition to a`
  line `translation thereof in the English language as required by clause (3) of article 348 of the Constitution,`
  line `may be published on or after the appointed day under the authority of the Governor of the State in the`
  line `Official Gazette of that State and in such a case, the translation in Hindi of any such Act or Ordinance`
  line `shall be deemed to be the authoritative text thereof in the Hindi language.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (24683)
  sectionNo (7)
  orderNo 7
  title `Optional use of Hindi or other official language in judgments, etc., of High Courts.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24683&sectionno=7&orderno=7&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_7_content:
  string
  line `As from`
  line `the appointed day or any day thereafter the Governor of a State may, with the previous consent of the`
  line `President, authorise the use of Hindi or the official language of the State, in addition to the English`
  line `language, for the purposes of any judgment, decree or order passed or made by the High Court for that`
  line `State and where any judgment, decree or order is passed or made in any such language (other than the`
  line `English language), it shall be accompanied by a translation of the same in the English language issued`
  line `under the authority of the High Court.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (24684)
  sectionNo (8)
  orderNo 8
  title `Power to make rules.`
  content obj_root_law_sections_8_content
  footnotes `1. Subs. by Act 4 of 1986, s. 2 and the Schedule, for certain words (w.e.f. 15-5-1986).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24684&sectionno=8&orderno=8&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_8_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules for carrying out the purposes of this Act.`
  line
  line `(2) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament while it is in session for a total period of thirty days which may be comprised in one`
  line `session or ^1[`
  line `in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid], both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be, so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_9:
  sectionId (24685)
  sectionNo (9)
  orderNo 9
  title `Certain provisions not to apply to Jammu and Kashmir.`
  content `[Certain provisions not to apply to Jammu and Kashmir.]-- Omitted by the Jammu and Kashmir Reorganization (Adaptation of Central Laws) Order, 2020, vide notification No. S.O. 1123(E) dated (18-3-2020) and vide Union Territory of Ladakh Reorganisation (Adaptation of Central Laws) Order, 2020, notification No. S.O. 3774(E), dated (23-10-2020).`
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_39_00001_196319_1517807319151&sectionId=24685&sectionno=9&orderno=9&orgactid=AC_CEN_5_39_00001_196319_1517807319151
obj_root_law_sections_9_footnotes:
  string
  line
