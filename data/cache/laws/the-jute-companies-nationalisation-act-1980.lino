obj_root_law:
  object
  (str slug) (str the-jute-companies-nationalisation-act-1980)
  (str handle) (str 1756)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Jute Companies (Nationalisation) Act, 1980`)
  (str actNumber) (str 62)
  (str enactmentDate) (str 1980-12-21)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1756`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `जूट कंपनी (राष्‍ट्रीयकरण) अधिनियम, 1980`)
  (str actYear) (str 1980)
  (str ministry) (str `Ministry of Textiles`)
  (str department) (undefined)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the undertakings of the jute companies, specified in the First Schedule with a view to securing the proper management of such undertakings so as to subserve the interests of the general public by ensuring the continued manufacture, production and distribution of articles made of jute, which are essential to the needs of the economy of the country and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 21-12-1980)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T20:21:15.241Z`)
  (str translations) obj_root_law_translations
