obj_root_law:
  slug the-jute-companies-nationalisation-act-1980
  handle (1756)
  collectionHandle 123456789/1362
  title `The Jute Companies (Nationalisation) Act, 1980`
  actNumber (62)
  enactmentDate 1980-12-21
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1756`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `जूट कंपनी (राष्‍ट्रीयकरण) अधिनियम, 1980`
  actYear (1980)
  ministry `Ministry of Textiles`
  department undefined
  longTitle `An Act to provide for the acquisition and transfer of the undertakings of the jute companies, specified in the First Schedule with a view to securing the proper management of such undertakings so as to subserve the interests of the general public by ensuring the continued manufacture, production and distribution of articles made of jute, which are essential to the needs of the economy of the country and for matters connected therewith or incidental thereto.`
  enforcementDate 21-12-1980
  notification undefined
  fetchedAt `2026-05-09T20:21:15.241Z`
  translations obj_root_law_translations
