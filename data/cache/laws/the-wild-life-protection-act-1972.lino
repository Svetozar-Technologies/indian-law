obj_root_law_sections_17_a:
  sectionId (32613)
  sectionNo 17A
  orderNo 22
  title `Prohibition of picking, uprooting, etc. of specified plant.`
  content obj_root_law_sections_17_a_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32613&sectionno=17A&orderno=22&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_a_content:
  string
  line `^1[17A. Prohibition of picking, uprooting, etc. of specified plant.--Save as otherwise provided in this`
  line `Chapter, no person shall--`
  line
  line `(a) wilfully pick, uproot, damage, destroy, acquire or collect any specified plant from any forest`
  line `land and any area specified, by notification, by the Central Government;`
  line
  line `(b) posses, sell, offer for sale, or transfer by way of gift or otherwise, or transport any specified`
  line `plant, whether alive or dead, or part or derivative thereof:`
  line
  line `Provided that nothing in this section shall prevent a member of a scheduled tribe, subject to the`
  line `provisions of Chapter IV, from picking, collecting or possessing in the district he resides any`
  line `specified plant or part or derivative thereof for his bona fide personal use.]`
obj_root_law_sections_17_b:
  sectionId (32614)
  sectionNo 17B
  orderNo 23
  title `Grants of permit for special purposes.`
  content obj_root_law_sections_17_b_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32614&sectionno=17B&orderno=23&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_b_content:
  string
  line `^1[17B. Grants of permit for special purposes.-- The Chief Wild Life Warden may, with the previous`
  line `permission of the State Government, grant to any person a permit to pick, uproot, acquire or collect from`
  line `a forest land or the area specified under section 17A or transport, subject to such conditions as may be`
  line `specified therein, any specified plant for the purpose of--`
  line
  line `(a) education;`
  line
  line `(b) scientific research;`
  line
  line `(c) collection, preservation and display in a herbarium of any scientific institution; or`
  line
  line `(d) propagation by a person or an institution approved by the Central Government in this regard.]`
obj_root_law_sections_17_c:
  sectionId (32664)
  sectionNo 17C
  orderNo 24
  title `Cultivation of specified plants without licence prohibited.`
  content obj_root_law_sections_17_c_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32664&sectionno=17C&orderno=24&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_c_content:
  string
  line `^1[17C.Cultivation of specified plants without licence prohibited.-- (1) No person shall cultivate a`
  line `specified plant except under and in accordance with a licence granted by the Chief Wild Life Warden or`
  line `any other officer authorised by the State Government in this behalf:`
  line
  line `Provided that nothing in this section shall prevent a person, who immediately before the`
  line `commencement of the Wild Life (Protection) (Amendment) Act, 1991 (44 of 1991), was cultivating a`
  line `specified plant from carrying on such cultivation for a period of six months from such commencement or`
  line `where he has made an application within that period for the grant of a licence to him, until the licence is`
  line `granted to him or he is informed in writing that a licence cannot be granted to him.`
  line
  line `(2) Every licence granted under this section shall specify the area in which and the conditions, if any,`
  line `subject to which the licensee shall cultivate a specified plant.]`
obj_root_law_sections_17_d:
  sectionId (32708)
  sectionNo 17D
  orderNo 25
  title `Dealing in specified plants without licence prohibited.`
  content obj_root_law_sections_17_d_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32708&sectionno=17D&orderno=25&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_d_content:
  string
  line `^1[17D. Dealing in specified plants without licence prohibited.-- (1) No person shall, except under`
  line `and in accordance with a licence granted by the Chief Wild Life Warden or any other officer authorised`
  line `by the State Government in this behalf, commence or carry on business or occupation as a dealer in a`
  line `specified plant or part or derivate thereof:`
  line
  line `Provided that nothing in this section shall prevent a person, who, immediately before the`
  line `commencement of the Wild Life (Protection) (Amendment) Act, 1991 (44 of 1991), was carrying on such`
  line `business or occupation, from carrying on such business or occupation for a period of sixty days from such`
  line `commencement, or where he has made an application within that period for the grant of a licence to him,`
  line `until the licence is granted to him or he is informed in writing that a licence cannot be granted to him.`
  line
  line `(2) Every licence granted under this section shall specify the premises in which and the conditions, if`
  line `any, subject to which the licensee shall carry on his business.]`
obj_root_law_sections_17_e:
  sectionId (32829)
  sectionNo 17E
  orderNo 26
  title `Declaration of stock.`
  content obj_root_law_sections_17_e_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32829&sectionno=17E&orderno=26&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_e_content:
  string
  line `^1[17E. Declaration of stock.-- (1) Every person cultivating, or dealing in, a specified plant or part or`
  line `derivative thereof shall, within thirty days from the date of commencement of the Wild Life (Protection)`
  line `(Amendment) Act, 1991 (44 of 1991) declare to the Chief Wild Life Warden or any other officer`
  line `authorised by the State Government in this behalf, his stocks of such plants and part or derivative thereof,`
  line `as the case may be, on the date of such commencement.`
  line
  line `(2) The provisions of sub-sections (3) to (8) (both inclusive) of section 44, section 45, section 46 and`
  line `section 47 shall, as far as may be, apply in relation to an application and a licence referred to in`
  line `section 17C and section 17D as they apply in relation to the licence or business in animals or animal`
  line articles.]
obj_root_law_sections_17_f:
  sectionId (32830)
  sectionNo 17F
  orderNo 27
  title `Possession, etc., of plants by licensee`
  content obj_root_law_sections_17_f_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32830&sectionno=17F&orderno=27&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_f_content:
  string
  line `^1[17F. Possession, etc., of plants by licensee.-- No licensee under this Chapter shall--`
  line
  line `(a) keep in his control, custody or possession--`
  line
  line `(i) any specified plant, or part or derivative thereof in respect of which a declaration under the`
  line `provisions of section 17E has to be made but has not been made;`
  line
  line `(ii) any specified plant, or part or derivative thereof which has not been lawfully acquired`
  line `under the provisions of this Act or any rule or order made thereunder;`
  line
  line `(b) (i) pick, uproot, collect or acquire any specified plant, or`
  line
  line `(ii) acquire, receive, keep in his control, custody or possession, or sell, offer for sale or transport`
  line `any specified plant or part or derivative thereof,`
  line
  line `except in accordance with the conditions subject to which the licence has been granted and such rules as`
  line `may be made under this Act.]`
obj_root_law_sections_17_g:
  sectionId (32831)
  sectionNo 17G
  orderNo 28
  title `Purchase, etc., of specified plants.`
  content obj_root_law_sections_17_g_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32831&sectionno=17G&orderno=28&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_g_content:
  string
  line `^1[17G. Purchase, etc., of specified plants.--No person shall purchase, receive or acquire any specified`
  line `plant or part or derivative thereof otherwise than from a licensed dealer:`
  line
  line `Provided that nothing in this section shall apply to any person referred to in section 17B.]`
obj_root_law_sections_17_h:
  sectionId (32832)
  sectionNo 17H
  orderNo 29
  title `Plants to be Government property.`
  content obj_root_law_sections_17_h_content
  footnotes `1. Ins. by Act 44 of 1991, s. 13 (w.e.f. 20-4-1995).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32832&sectionno=17H&orderno=29&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_17_h_content:
  string
  line `^1[17H. Plants to be Government property.--(1) Every specified plant or part or derivative thereof, in`
  line `respect of which any offence against this Act or any rule or order made thereunder has been committed,`
  line `shall be the property of the State Government, and, where such plant or part or derivative thereof has been`
  line `collected or acquired from a sanctuary or National Park declared by the Central Government, such plant`
  line `or part or derivative thereof shall be the property of the Central Government.`
  line
  line `(2) The provisions of sub-sections (2) and (3) of section 39 shall, as far as may be, apply in relation to`
  line `the specified plant or part or derivative thereof or they apply in relation to wild animals and articles`
  line `referred to in sub-section (1) of that section.]`
obj_root_law_sections_18:
  sectionId (32833)
  sectionNo (18)
  orderNo 30
  title `Declaration of sanctuary.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32833&sectionno=18&orderno=30&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_18_content:
  string
  line `^1[18. Declaration of sanctuary.-- ^2[(1) The State Government may, by notification, declare its`
  line `intention to constitute any area other than an area comprised within any reserve forest or the territorial waters as a sanctuary if it considers that such area is of adequate ecological, faunal, floral,`
  line `geomorphological, natural or zoological significance, for the purpose of protecting, propagating or`
  line `developing wild life or its environment.]`
  line
  line `(2) The notification referred to in sub-section (1) shall specify, as nearly as possible, the situation and`
  line `limits of such area.`
  line
  line `Explanation.-- For the purposes of this section, it shall be sufficient to describe the area by roads,`
  line `rivers, ridges or other well-known or readily intelligible boundaries.]`
obj_root_law_sections_18_footnotes:
  string
  line `1. Subs. by Act 16 of 2003, s. 10 for the heading (w.e.f. 1-4-2003).`
  line
  line `2. Subs. by Act 44 of 1991, s. 15, for sub-section (1) (w.e.f. 2-10-1991).`
obj_root_law_sections_18_a:
  sectionId (32834)
  sectionNo 18A
  orderNo 31
  title `Protection to sanctuaries`
  content obj_root_law_sections_18_a_content
  footnotes `1. Ins. by Act 16 of 2003, s. 11 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32834&sectionno=18A&orderno=31&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_18_a_content:
  string
  line `^1[18A. Protection to sanctuaries.--(1) When the State Government declares its intention under`
  line `sub-section (1) of section 18 to constitute any area, not comprised within any reserve forest or territorial`
  line `waters under that sub-section, as a sanctuary, the provisions of sections 27 to 33A (both inclusive) shall`
  line `come into effect forthwith.`
  line
  line `(2) Till such time as the rights of affected persons are finally settled under sections 19 to 24 (both`
  line `inclusive), the State Government shall make alternative arrangements required for making available fuel,`
  line `fodder and other forest produce to the persons affected, in terms of their rights as per the Government`
  line records.]
obj_root_law_sections_18_b:
  sectionId (32835)
  sectionNo 18B
  orderNo 32
  title `Appointment of Collectors.`
  content obj_root_law_sections_18_b_content
  footnotes `1. Ins. by Act 16 of 2003, s. 11 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32835&sectionno=18B&orderno=32&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_18_b_content:
  string
  line `^1[18B. Appointment of Collectors.-- The State Government shall appoint, an officer to act as`
  line `Collector under the Act, within ninety days of coming into force of the Wild Life (Protection)`
  line `Amendment Act, 2002 (16 of 2003), or within thirty days of the issue of notification under section 18, to`
  line `inquire into and determine the existence, nature and extent of rights of any person in or over the land`
  line `comprised within the limits of the sanctuary which may be notified under sub-section (1) of section 18.]`
obj_root_law_sections_19:
  sectionId (32836)
  sectionNo (19)
  orderNo 33
  title `Collector to determine rights.`
  content obj_root_law_sections_19_content
  footnotes `1. Subs. by Act 44 of 1991, s. 16, for "Whenever any area is declared to be a sanctuary" (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32836&sectionno=19&orderno=33&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_19_content:
  string
  line `^1[When a notification has been issued under section 18,] the`
  line `Collector shall inquire into, and determine, the existence, nature and extent of the rights of any person in`
  line `or over the land comprised within the limits of the sanctuary.`
obj_root_law_sections_20:
  sectionId (32837)
  sectionNo (20)
  orderNo 34
  title `Bar of accrual of rights.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32837&sectionno=20&orderno=34&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_20_content:
  string
  line `After the issue of a notification under section 18, no right shall be`
  line `acquired in, on or over the land comprised within the limits of the area specified in such notification,`
  line `except by succession, testamentary or intestate.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (32838)
  sectionNo (21)
  orderNo 35
  title `Proclamation by Collector.`
  content obj_root_law_sections_21_content
  footnotes `1. Ins. by Act 16 of 2003, s. 12 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32838&sectionno=21&orderno=35&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_21_content:
  string
  line `When a notification has been issued under section 18, the`
  line `Collector shall^1[within a period of sixty days] publish in the regional language in every town and village`
  line `in or in the neighbourhood of the area comprised therein, a proclamation--`
  line
  line `(a) specifying, as nearly as possible, the situation and the limits of the sanctuary; and`
  line
  line `(b) requiring any person, claiming any right mentioned In section 19, to prefer before the`
  line `Collector, within two months from the date of such proclamation, a written claim in the prescribed form,`
  line `specifying the nature and extent of such right with necessary details and the amount and particulars of`
  line `compensation, if any, claimed in respect thereof.`
obj_root_law_sections_22:
  sectionId (32839)
  sectionNo (22)
  orderNo 36
  title `Inquiry by Collector.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32839&sectionno=22&orderno=36&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_22_content:
  string
  line `The Collector shall, after service of the prescribed notice upon the`
  line `claimant, expeditiously inquire into--`
  line
  line `(a) the claim preferred before him under clause (b) of section 21, and`
  line
  line `(b) the existence of any right mentioned in section 19 and not claimed under clause (b) of`
  line `section 21,`
  line
  line `so far as the same may be ascertainable from the records of the State Government and the evidence of any`
  line `person acquainted with the same.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (32840)
  sectionNo (23)
  orderNo 37
  title `Powers of Collector.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32840&sectionno=23&orderno=37&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_23_content:
  string
  line `For the purpose of such inquiry, the Collector may exercise the following`
  line `powers, namely:--`
  line
  line `(a) the power to enter in or upon any land and to survey, demarcate and make a map of the same`
  line `or to authorise any other officer to do so;`
  line
  line `(b) the same powers as are vested in a civil court for the trial of suits.`
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (32841)
  sectionNo (24)
  orderNo 38
  title `Acquisition of rights.`
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32841&sectionno=24&orderno=38&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_24_content:
  string
  line `(1) In the case of a claim to a right in or over any land referred to in`
  line `section 19, the Collector shall pass an order admitting or rejecting the same in whole or in part.`
  line
  line `(2) If such claim is admitted in whole or in part, the Collector may either--`
  line
  line `(a) exclude such land from the limits of the proposed sanctuary, or`
  line
  line `(b) proceed to acquire such land or rights, except where by an agreement between the owner of`
  line `such land or holder of rights and the Government, the owner or holder of such rights has agreed to`
  line `surrender his rights to the Government, in or over such land" and on payment of such compensation,`
  line `as is provided in the ^1[Right to Fair Compensation and Transparency in Land Acquisition,`
  line `Rehabilitation and Resettlement Act, 2013 (30 of 2013).]`
  line
  line `^2[(c) allow, in consultation with the Chief Wild Life Warden, the continuation of any right of any`
  line `person in or over any land within the limits of the sanctuary.]`
obj_root_law_sections_24_footnotes:
  string
  line `1. Sub. by Act 18 of 2022, s. 8, for "Land Acquisition Act, 1894 (1 of 1894)" (w.e.f. 1-4-2023).`
  line
  line `2. Ins. by Act 44 of 1991, s. 17 (w.e.f. 2-10-1991).`
obj_root_law_sections_25:
  sectionId (32842)
  sectionNo (25)
  orderNo 39
  title `Acquisition proceedings.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32842&sectionno=25&orderno=39&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_25_content:
  string
  line `(1) For the purpose of acquiring such land, or rights in or over such`
  line land,
  line
  line `(a) the Collector shall be deemed to be a Collector, proceeding under the ^1[Right to Fair`
  line `Compensation and Transparency in Land Acquisition, Rehabilitation and Resettlement Act, 2013 (30`
  line `of 2013);]`
  line
  line `(b) the claimant shall be deemed to be a person interested and appearing before him in pursuance`
  line `of a notice given under ^2[section 21ic] of that Act;`
  line
  line `(c) the provisions of the sections, preceding ^2[section 21] of that Act, shall be deemed to have`
  line `been complied with;`
  line
  line `(d) where the claimant does not accept the award made in his favour ha the matter of`
  line `compensation, he shall be deemed, within the meaning of ^3[section 64] of that Act, to be a person`
  line `interested who has not accepted the award, and shall be entitled to proceed to claim relief against the`
  line `award under the provisions of ^3[Chapter VIII] of that Act;`
  line
  line `(e) the Collector, with the consent of the claimant, or ^4[the Authority], with the consent of both`
  line `the parties, may award compensation in land or money or partly in land and partly in money; and`
  line
  line `(f) in the case of the stoppage of a public way or a common pasture, the Collector may, with the`
  line `previous sanction of the State Government, provide for an alternative public way or common pasture,`
  line `as far as may be practicable or convenient.`
  line
  line `^5[Explanation.--The expression "Authority" referred to in clause (e), shall mean the Land`
  line `Acquisition, Rehabilitation and Resettlement Authority established under section 51 of the Right to`
  line `Fair Compensation and Transparency in Land Acquisition, Rehabilitation and Resettlement Act, 2013`
  line `(30 of 2013).]`
  line
  line `(2) The acquisition under this Act of any land or interest therein shall be deemed to be acquisition for`
  line `a public purpose.`
obj_root_law_sections_25_footnotes:
  string
  line `1. Subs. by Act 18 of 2022, s. 9, for "Land Acquisition Act, 1894 (1 of 1894)" (w.e.f. 1-4-2023).`
  line
  line `2. Subs. by s. 9, ibid., for "ection 9" (w.e.f. 1-4-2023).`
  line
  line `3. Subs. by s. 9, ibid., for "section 18" and "Part III" (w.e.f. 1-4-2023).`
  line
  line `4. Subs. by s. 9, ibid., for "the Court" (w.e.f. 1-4-2023).`
  line
  line `5. Ins. by s. 9, ibid, (w.e.f. 1-4-2023).`
obj_root_law_sections_25_a:
  sectionId (32843)
  sectionNo 25A
  orderNo 40
  title `Time-limit for completion of acquisition proceedings.`
  content obj_root_law_sections_25_a_content
  footnotes `1. Ins. by Act 16 of 2003, s. 13 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32843&sectionno=25A&orderno=40&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_25_a_content:
  string
  line `^1[25A. Time-limit for completion of acquisition proceedings.--(1) The Collector shall, as far as`
  line `possible, complete the proceedings under sections 19 to 25 (both inclusive), within a period of two years`
  line `from the date of notification of declaration of sanctuary under section 18.`
  line
  line `(2) The notification shall not lapse if, for any reasons, the proceedings are not completed within a`
  line `period of two years.]`
obj_root_law_sections_26:
  sectionId (32844)
  sectionNo (26)
  orderNo 41
  title `Delegation of Collector's powers.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32844&sectionno=26&orderno=41&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_26_content:
  string
  line `The State Government may, by general or special order,`
  line `direct that the Powers exercisable or the functions to be performed by the Collector under sections 19 to`
  line `25 (both inclusive) may be exercised and performed by such other officer as may be specified in the`
  line order.
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_26_a:
  sectionId (32845)
  sectionNo 26A
  orderNo 42
  title `Declaration of area as sanctuary.`
  content obj_root_law_sections_26_a_content
  footnotes obj_root_law_sections_26_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32845&sectionno=26A&orderno=42&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_26_a_content:
  string
  line `^1[26A. Declaration of area as sanctuary.-- (1) When--`
  line
  line `(a) a notification has been issued under section 18 and the period for preferring claims has`
  line `elapsed, and all claims, if any, made in relation to any land in an area intended to be declared as a`
  line `sanctuary, have been disposed of by the State Government; or`
  line
  line `(b) any area comprised within any reserve forest or any part of the territorial waters, which is`
  line `considered by the State Government to be of adequate ecological faunal floral geomorphological,`
  line `natural or zoological significance for the purpose of protecting, propagating or developing wild life or`
  line `its environment, is to be included in a sanctuary,`
  line
  line `the State Government shall issue a notification specifying the limits of the area which shall be comprised`
  line `within the sanctuary and declare that the said area shall be sanctuary on and from such date as may be`
  line `specified in the notification:`
  line
  line `Provided that where any part of the territorial waters is to be so included, prior concurrence of the`
  line `Central Government shall be obtained by the State Government:`
  line
  line `Provided further that the limits of the area of the territorial waters to be included in the sanctuary shall`
  line `be determined in consultation with the Chief Naval Hydrographer of the Central Government and after`
  line `taking adequate measures to protect the occupational interests of the local fishermen.`
  line
  line `(2) Notwithstanding anything contained in sub-section(1), the right of innocent passage of any vessel`
  line `or boat through the territorial waters shall not be affected by the notification issued under sub-section (1).`
  line
  line `^2[(3) No alteration of the boundaries of a sanctuary shall be made by the State Government except on`
  line `a recommendation of the National Board.]`
obj_root_law_sections_26_a_footnotes:
  string
  line `1. Ins. by Act 44 of 1991, s. 18 (w.e.f. 2-10-1991).`
  line `2. Subs. by Act 16 of 2003, s. 14, for sub-section (3) (w.e.f. 1-4-2003).`
obj_root_law_sections_27:
  sectionId (32846)
  sectionNo (27)
  orderNo 43
  title `Restriction on entry in sanctuary.`
  content obj_root_law_sections_27_content
  footnotes `1. Ins. by Act 44 of 1991, s. 19 (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32846&sectionno=27&orderno=43&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_27_content:
  string
  line `(1) No person other than,--`
  line
  line `(a) a public servant on duty,`
  line
  line `(b) a person who has been permitted by the Chief Wild Life Warden or the authorised officer to`
  line `reside within the limits of the sanctuary,`
  line
  line `(c) a person who has any right over immovable property within the limits of the sanctuary,`
  line
  line `(d) a person passing through the sanctuary along a public highway, and`
  line
  line `(e) the dependants of the person referred to in clause (a), clause (b) or clause (c), shall enter or`
  line `reside in the sanctuary, except under and in accordance with the conditions of a permit granted under`
  line `section 28.`
  line
  line `(2) Every person shall, so long, as he resides in the sanctuary, be bound--`
  line
  line `(a) to prevent the commission, in the sanctuary, of an offence against this Act;`
  line
  line `(b) where there is reason to believe that any such offence against this Act has been committed in`
  line `such sanctuary, to help in discovering and arresting the offender;`
  line
  line `(c) to report the death of any wild animal and to safeguard its remains until the Chief Wild Life`
  line `Warden or the authorised officer takes charge thereof;`
  line
  line `(d) to extinguish any fire in such sanctuary of which he has knowledge or information and to`
  line `prevent from spreading, by any lawful means in his power, any fire within the vicinity of such`
  line `sanctuary of which he has knowledge or information; and`
  line
  line `(e) to assist any forest officer, Chief Wild Life. Warden, Wild Life Warden or police officer`
  line `demanding his aid for preventing the commission of any offence against this Act or in the`
  line `investigation of any such offence.`
  line
  line `^1[(3) No person shall, with intent to cause damage to any boundary-mark of a sanctuary or to cause`
  line `wrongful gain as defined in the Indian Penal Code, 1860 (45 of 1860), alter, destroy, move or deface such`
  line boundary-mark.
  line
  line `(4) No person shall tease or molest any wild animal or litter the grounds of sanctuary.]`
obj_root_law_sections_28:
  sectionId (32847)
  sectionNo (28)
  orderNo 44
  title `Grant of permit.`
  content obj_root_law_sections_28_content
  footnotes `1. Ins. by Act 18 of 2022, s. 10 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32847&sectionno=28&orderno=44&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_28_content:
  string
  line `(1) The Chief Wild Life Warden may, on application, grant to any person a`
  line `permit to enter or reside in a sanctuary for all or any of the following purposes, namely:--`
  line
  line `(a) investigation or study of wild life and purposes ancillary or incidental thereto;`
  line
  line `(b) photography ^1[and film-making without making any change in the habitat or causing any`
  line `adverse impact to the habitat or wild life;]`
  line
  line `(c) scientific research;`
  line
  line `(d) tourism;`
  line
  line `(e) transaction of lawful business with any person residing in the sanctuary.`
  line
  line `(2) A permit to enter or reside in a sanctuary shall be issued subject to such conditions and on`
  line `payment of such fee as may be prescribed.`
obj_root_law_sections_29:
  sectionId (32848)
  sectionNo (29)
  orderNo 45
  title `Destruction, etc., in a sanctuary prohibited without a permit.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32848&sectionno=29&orderno=45&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_29_content:
  string
  line `^1[29. Destruction, etc., in a sanctuary prohibited without a permit.--No person shall destroy,`
  line `exploit or remove any wild life including forest produce from a sanctuary or destroy or damage or divert`
  line `the habitat of any wild animal by any act whatsoever or divert, stop or enhance the flow of water into or`
  line `outside the sanctuary, except under and in accordance with a permit granted by the Chief Wild Life`
  line `Warden, and no such permit shall be granted unless the State Government being satisfied in consultation`
  line `with the ^2[National Board] that such removal of wild life from the sanctuary or the change in the flow of`
  line `water into or outside the sanctuary is necessary for the improvement and better management of wild life`
  line `therein, authorises the issue of such permit:`
  line
  line `Provided that where the forest produce is removed from a sanctuary the same may be used for`
  line `meeting the personal bona fide needs of the people living in and around the sanctuary and shall not be`
  line `used for any commercial purpose.`
  line
  line `^3[Explanation.--For the purposes of this section, grazing or movement of livestock permitted under`
  line `clause (d) of section 33, or hunting of wild animals under a permit granted under section 11 or hunting`
  line `without violating the conditions of a permit granted under section 12, or the exercise of any rights`
  line `permitted to continue under clause (c) of sub-section (2) of section 24, including the bona fide use of`
  line `drinking and household water by local communities until they are settled, shall not be deemed to be an act`
  line `prohibited under this section.]`
obj_root_law_sections_29_footnotes:
  string
  line `1. Subs. by Act 16 of 2003, s. 15, for section 29 (w.e.f. 1-4-2003).`
  line
  line `2. Subs. by Act 18 of 2022, s. 11, for "Board" (w.e.f. 1-4-2023).`
  line
  line `3. Subs. by s. 11, ibid., for "the Explanation" (w.e.f. 1-4-2023).`
obj_root_law_sections_30:
  sectionId (32849)
  sectionNo (30)
  orderNo 46
  title `Causing fire prohibited.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32849&sectionno=30&orderno=46&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_30_content:
  string
  line `No person shall set fire to a sanctuary, or kindle any fire, or leave any`
  line `fire burning, in a sanctuary, in such manner as to endanger such sanctuary.`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (32850)
  sectionNo (31)
  orderNo 47
  title `Prohibition of entry into sanctuary with weapon.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32850&sectionno=31&orderno=47&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_31_content:
  string
  line `No person shall enter a sanctuary with any`
  line `weapon except with the previous permission in writing of the Chief Wild Life Warden or the authorised`
  line officer.
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (32851)
  sectionNo (32)
  orderNo 48
  title `Ban on use of injurious substances.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32851&sectionno=32&orderno=48&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_32_content:
  string
  line `No person shall use, in a sanctuary, chemicals, explosives`
  line `or any other substances which may cause injury to, or endanger, any wild life in such sanctuary.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (32852)
  sectionNo (33)
  orderNo 49
  title `Control of sanctuaries.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32852&sectionno=33&orderno=49&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_33_content:
  string
  line `The Chief Wild Life Warden shall be the authority who shall control,`
  line `^1[manage and protect all sanctuaries in accordance with such management plans for the sanctuary`
  line `approved by him as per the guidelines issued by the Central Government and in case the sanctuary also`
  line `falls under the Scheduled Areas or areas where the Scheduled Tribes and Other Traditional Forest`
  line `Dwellers (Recognition of Forest Rights) Act, 2006 (2 of 2007) is applicable, in accordance with the`
  line `management plan for such sanctuary prepared after due consultation with the Gram Sabha concerned] and`
  line `for that purpose, within the limits of any sanctuary,--`
  line
  line `(a) may construct such roads, bridges, buildings, fences or barrier gates, and carry out such other`
  line `works as he may consider necessary for the purposes of such sanctuary:`
  line
  line `^2[Provided that no construction of ^3[tourist lodges, including Government lodges, for`
  line `commercial purposes], hotels, zoos and safari parks shall be undertaken inside a sanctuary except`
  line `with the prior approval of the National Board.]`
  line
  line `(b) shall take such steps as will ensure the security of wild animals in the sanctuary and the`
  line `preservation of the sanctuary and wild animals therein;`
  line
  line `(c) may take such measures, in the interests of wild life, as he may consider necessary for the`
  line `improvement of any habitat;`
  line
  line `(d) may regulate, control or prohibit, in keeping with the interests of wild life, the grazing or`
  line `movement of ^4[live-stock.]`
  line
  line ^5***
obj_root_law_sections_33_footnotes:
  string
  line `1. Subs. by Act 18 of 2022, s. 12, for "manage and maintain all sanctuaries" (w.e.f. 1-4-2023).`
  line
  line `2. Ins. by Act 16 of 2003, s. 16, (w.e.f. 1-4-2003).`
  line
  line `3. Sub. by Act 18 of 2022, s. 12, for "commercial tourist lodges" (w.e.f. 1-4-2023).`
  line
  line `4. Subs. by Act 44 of 1991, s. 21, for "cattle;" (w.e.f. 2-10-1991).`
  line
  line `5. Clause (e) omitted by s. 21, ibid. (w.e.f. 2-10-1991).`
obj_root_law_sections_33_a:
  sectionId (32853)
  sectionNo 33A
  orderNo 50
  title `Immunisation of live-stock.`
  content obj_root_law_sections_33_a_content
  footnotes `1. Ins. by s. 22, ibid. (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32853&sectionno=33A&orderno=50&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_33_a_content:
  string
  line `^1[33A. Immunisation of live-stock.-- (1) The Chief Wild Life Warden shall take such measures in`
  line `such manner, as may be prescribed, for immunisation against communicable diseases of the live-stock`
  line `kept in or within five kilometres of a sanctuary.`
  line
  line `(2) No person shall take, or cause to be taken or grazed, any live-stock in a sanctuary without getting`
  line `it immunised.]`
obj_root_law_sections_33_b:
  sectionId (32854)
  sectionNo 33B
  orderNo 51
  title `Advisory Committee.`
  content obj_root_law_sections_33_b_content
  footnotes `1. Ins. by Act 16 of 2003, s. 17 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32854&sectionno=33B&orderno=51&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_33_b_content:
  string
  line `^1[33B. Advisory Committee.-- (1) The State Government shall constitute an Advisory Committee`
  line `consisting of the Chief Wild Life Warden or his nominee not below the rank of Conservator of Forests as`
  line `its head and shall include a member of the State Legislature within whose constituency the sanctuary is`
  line `situated, three representatives of Panchayati Raj Institutions, two representatives of non-governmental`
  line `organisations and three individuals active in the field of wild life conservation, one representative each`
  line `from departments dealing with Home and Veterinary matters, Honorary Wild Life Warden, if any, and the`
  line `officer-in-charge of the sanctuary as Member-Secretary.`
  line
  line `(2) The Committee shall render advice on measures to be taken for better conservation and`
  line `management of the sanctuary including participation of the people living within and around the sanctuary.`
  line
  line `(3) The Committee shall regulate its own procedure including quorum.]`
obj_root_law_sections_34:
  sectionId (32927)
  sectionNo (34)
  orderNo 52
  title `Registration of certain persons in possession of arms.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32927&sectionno=34&orderno=52&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_34_content:
  string
  line `(1) Within three months from the`
  line `declaration of any area as a sanctuary, every person residing in or within ten kilometres of any such`
  line `sanctuary and holding a licence granted under the Arms Act, 1959(54 of 1959), for the possession of arms`
  line `or exempted from the provisions of that Act and possessing arms, shall apply in such form, on payment of`
  line `such fee and within such time as may be prescribed, to the Chief Wild Life Warden or the authorised`
  line `officer, for the registration of his name.`
  line
  line `(2) On receipt of an application under sub-section (1), the Chief Wild Life Warden or the authorised`
  line `officer shall register the name of the applicant in such manner as may be prescribed.`
  line
  line `^1[(3) No new licences under the Arms Act, 1959 (54 of 1959) shall be granted within a radius of ten`
  line `kilometres of a sanctuary without the prior concurrence of the Chief Wild Life Warden.]`
  line
  line `^2[(4) No renewal of any licence under the Arms Act, 1959, (54 of 1959) shall be granted to any`
  line `person residing within ten kilometres of a sanctuary except under the intimation to the Chief Wild Life`
  line `Warden or the authorised officer.]`
obj_root_law_sections_34_footnotes:
  string
  line `1. Ins. by Act 44 of 1991, s. 22A (w.e.f. 21-5-2001).`
  line
  line `2. Ins. by Act 18 of 2022, s. 13 (w.e.f. 1-4-2023).`
obj_root_law_sections_35:
  sectionId (32928)
  sectionNo (35)
  orderNo 53
  title `Declaration of National Parks.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32928&sectionno=35&orderno=53&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_35_content:
  string
  line `(1) Whenever it appears to the State Government that an area,`
  line `whether within a sanctuary or not, is, by reason of its ecological, faunal, floral, geomorphological or`
  line `zoological association or importance, needed to be constituted as a National Park for the purpose of`
  line `protecting, propagating or developing wild life therein or its environment, it may, by notification, declare`
  line `its intention to constitute such area as a National Park.`
  line
  line `^1[Provided that where any part of the territorial waters is proposed to be included in such National`
  line `Park, the provisions of section 26A shall, as far as may be, apply in relation to the declaration of a`
  line `National Park as they apply in relation to the declaration of a sanctuary.]`
  line
  line `(2) The notification referred to in sub-section (1) shall define the limits of the area which is intended`
  line `to be declared as a National Park.`
  line
  line `(3) Where any area is intended to be declared as a National Park, the provisions of sections ^2[19 to`
  line `26A (both inclusive except cause (c) of sub-section (2) of section 24)] shall, as far as may, be, apply to`
  line `the investigation and determination of claims, and extinguishment of rights, in relation to any land in such`
  line `area as they apply to the said matters in relation to any land in a sanctuary.`
  line
  line `^3[(3A) When the State Government declares its intention under sub-section (1) to constitute any area`
  line `as a National Park, the provisions of sections 27 to 33A (both inclusive), shall come into effect forthwith,`
  line `until the publication of the notification declaring such National Park under sub-section (4).`
  line
  line `(3B) Till such time as the rights of the affected persons are finally settled under sections 19 to 26A`
  line `[both inclusive except clause (c) of sub-section (2) of section 24], the State Government shall make`
  line `alternative arrangements required for making available fuel, fodder and other forest produce to the`
  line `persons affected, in terms of their rights as per the Government records.]`
  line
  line `(4) When the following events have occurred, namely,--`
  line
  line `(a) the period for preferring claims has elapsed, and all claims, if any, made in relation to any`
  line `land in an area intended to be declared as a National Park, have been disposed of by the State`
  line `Government, and`
  line
  line `(b) all rights in respect of lands proposed to be included in the National Park have become vested`
  line `in the State Government,`
  line
  line `the State Government shall publish a notification specifying the limits of the area which shall be`
  line `comprised within the National Park and declare that the said area shall be a National Park on and from`
  line `such date as may be specified in the notification.`
  line
  line `^4[(5) No alteration of the boundaries of a National Park by the State Government shall be made except`
  line `on a recommendation of the National Board.`
  line
  line `(6) No person shall destroy, exploit or remove any Wild Life including forest produce from a`
  line `National Park or destroy or damage or divert the habitat of any wild animal by any act whatsoever or`
  line `divert, stop or enhance the flow of water into or outside the National Park, except under and in`
  line `accordance with a permit granted by the Chief Wild Life Warden, and no such permit shall be granted`
  line `unless the State Government being satisfied in consultation with the National Board that such removal of`
  line `wild life from the National Park or the change in the flow of water into or outside the National Park is`
  line `necessary for the improvement and better management of wild life therein, authorises the issue of such`
  line `permit:`
  line
  line `Provided that where the forest produce is removed from a National Park, the same may be used for`
  line `meeting the personal bona fide needs of the people living in and around the National Park and shall not be`
  line `used for any commercial purpose.]`
  line
  line `(7) No grazing of any ^5[live-stock] shall be permitted in a National Park and no ^5[live-stock] shall be`
  line `allowed to enter therein except where such ^5[live-stock] is used as a vehicle by a person authorised to`
  line `enter such National Park.`
  line
  line `(8) The provisions of sections 27 and 28, sections 30 to 32 (both inclusive), and clauses (a), (b) and`
  line `(c) of ^6[section 33, section 33A] shall, as far as may be, apply in relation to a National Park as they apply`
  line `in relation to a sanctuary.`
  line
  line `^7[Explanation.--For the purposes of this section, in case of an area, whether within a sanctuary or`
  line `not, where the rights have been extinguished and the land has become vested in the State Government`
  line `under any Act or otherwise, such area may be notified by it, by a notification, as a National Park and the`
  line `proceedings under sections 19 to 26 (both inclusive) and the provisions of sub-sections (3) and (4) of this`
  line `section shall not apply.]`
  line
  line ^8***
obj_root_law_sections_35_footnotes:
  string
  line `1. Added by Act 44 of 1991, s. 23, (w.e.f. 2-10-1991).`
  line
  line `2. Subs. by s. 23, ibid., for "section 23, for "19 to 26 (both inclusive)" (w.e.f. 2-10-1991).`
  line
  line `3. Ins. by Act 18 of 2022, s. 14 (w.e.f. 1-4-2023).`
  line
  line `4. Subs. by Act 16 of 2003, s. 19, for sub-sections (5) and (6) (w.e.f. 1-4-2003).`
  line
  line `5. Subs. by Act 44 of 1991, s. 23, for "cattle" (w.e.f. 2-10-1991).`
  line
  line `6. Subs. by s. 23, ibid., for "section 33" (w.e.f. 2-10-1991).`
  line
  line `7. Ins. by Act 16 of 2003, s. 19 (w.e.f. 1-4-2003).`
  line
  line `8. The sub-heading "GAME RESERVE" omitted by Act 44 of 1991, s. 24 (w.e.f. 2-10-1991).`
obj_root_law_sections_36:
  sectionId (32929)
  sectionNo (36)
  orderNo 54
  title Omitted..
  content obj_root_law_sections_36_content
