obj_root_law_sections_1:
  sectionId (32547)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32547&sectionno=1&orderno=1&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Wild Life (Protection)`
  line `Act, 1972.`
  line
  line `^1[(2) It extends to the whole of India ^2***.]`
  line
  line `(3) It shall come into force in a State or Union territory to which it extends^3*** on such date as the`
  line `Central Government may, by notification, appoint, and different dates may be appointed for different`
  line `provisions of this Act or for different States or Union territories.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by s. 4, ibid., for sub-section (2) (w.e.f. 2-10-1991).`
  line
  line `2. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule`
  line `(w.e.f. 31-10-2019).`
  line `3. The words ",or may become extended in future," omitted by s. 4, ibid. (w.e.f. 2-10-1991).`
obj_root_law_sections_2:
  sectionId (32568)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32568&sectionno=2&orderno=2&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `^1[(1) "animal" includes amphibians, birds, mammals and reptiles and their young, and also`
  line `includes, in the cases of birds and reptiles, their eggs;]`
  line
  line `(2) "animal article" means an article made from any captive animal or wild animal, other than`
  line `vermin, and includes an article or object in which the whole or any part of such animal ^2[has been`
  line `used, and ivory imported into India and an article made therefrom];`
  line
  line `^3* * * *`
  line
  line `^4[(4) "Board" means a State Board for Wild Life constituted under sub-section (1) of section 6;]`
  line
  line `(5) "captive animal" means any animal, specified in ^5]Schedule I or Schedule II] which is`
  line `captured or kept or bred in captivity;`
  line
  line `^6* * * *`
  line
  line `(7) “Chief Wild Life Warden’ means the person appointed as such under clause (a) of`
  line `sub-section (1) of section 4;`
  line
  line `^7[(7A) "circus" means an establishment, whether stationary or mobile, where animals are kept or`
  line `used wholly or mainly for the purpose of performing tricks or manoeuvres;]`
  line
  line `^8* * * *`
  line
  line `^9[(9) "Collector" means the chief officer in charge of the revenue administration of a district or`
  line `any other officer not below the rank of a Deputy Collector as may be appointed by the State`
  line `Government under section 18B in this behalf;]`
  line
  line `(10) "commencement of this Act", in relation to--`
  line
  line `(a) a State, means commencement of this Act in that State,`
  line
  line `(b) any provision of this Act, means the commencement of that provision In the concerned`
  line State;
  line
  line `^10[(11) "dealer" in relation to any captive animal, animal article, trophy, uncured trophy, meat or`
  line `specified plant, means a person, who carries on the business of buying or selling any such animal or`
  line `article, and includes a person who undertakes business in any single transaction;]`
  line
  line `(12) "Director" means the person appointed as Director of Wild Life Preservation under`
  line `clause (a) of sub-section (1) of section 3;`
  line
  line `^11[(12A) "Forest officer" means the Forest officer appointed under clause (2) of section 2 of the`
  line `Indian Forest Act, 1927 (16 of 1927) or under any other Act for the time being in force in a State;`
  line
  line `(12B) "forest produce" shall have the same meaning as in sub-clause (b) of clause (4) of section 2`
  line `of the Indian Forest Act, 1927 (16 of 1927);ic]`
  line
  line `^12* * * *`
  line
  line `(14) "Government property" means any property referred to in section 39 ^13[or section 17H];`
  line
  line `(15) "habitat" includes land, water or vegetation which is the natural home of any wild animal`
  line `^14[or specified plant];`
  line
  line `(16) "hunting", with its grammatical variations and cognate expressions, includes,--`
  line
  line `^15[(a) killing or poisoning of any wild animal or captive animal and every attempt to do so;`
  line
  line `(b) capturing, coursing, snaring, trapping, driving or baiting any wild or captive animal and`
  line `every attempt to do so;]`
  line
  line `(c) injuring or destroying or taking any part of the body of any such animal or, in the case of`
  line `wild birds or reptiles, damaging the eggs of such birds or reptiles, or disturbing the eggs or nests`
  line `of such birds or reptiles;`
  line
  line `^16[(16A) "invasive alien species" means a species of animal or plant which is not native to India`
  line `and whose introduction or spread may threaten or adversely impact wild life or its habitat;]`
  line
  line `(17) "land" includes canals, creeks and other water channels, reservoirs, rivers, streams and lakes,`
  line `whether artificial or natural, ^17[marshes and wetlands and also includes boulders and rocks];`
  line
  line `(18) "licence" means a licence granted under this Act;`
  line
  line `^18](18A) "livestock" means farm animals and includes buffaloes, bulls, bullocks, camels, cows,`
  line `donkeys, goats, sheep, horses, mules, yaks, pigs, ducks, geese, poultry and their young but does not`
  line `include any animal specified in ^19]Schedules I, II and IV;]`
  line
  line `^20[(19) “manufacturer” means a person who manufactures articles from any animal or plant`
  line `specified in ^21[Schedules I, II and III], as the case may be;`
  line
  line `(20) "meat" includes blood, bones, sinew, eggs, shell or carapace, fat and flesh with or without`
  line `skin, whether raw or cooked, of any wild animal or captive animal, other than a vermin;`
  line
  line `(20A) "National Board" means the National Board for Wild Life constituted under section 5A;]`
  line
  line `(21) "National Park" means an area declared, whether under section 35 or section 38, or deemed,`
  line `under sub-section (3) of section 66, to be declared, as a National Park;`
  line
  line `(22) "notification" means a notification published in the Official Gazette;`
  line `(23) "permit" means a permit granted under this Act or any rule made thereunder;`
  line `^22[(24) "person" shall include any firm or company or any authority or association or body of`
  line `individuals whether incorporated or not;]`
  line
  line `^23[(24A) "protected area" means a National Park, a sanctuary, a conservation reserve or a`
  line `community reserve notified under sections 18, 35, 36A and 36C of the Act;]`
  line
  line `(25) "prescribed" means prescribed by rules made under this Act;`
  line
  line `^24[(25A) "recognised zoo" means a zoo recognised under section 38H;`
  line `^25[(25B) "reserve forest" means the forest declared to be reserved by the State Government under`
  line `section 20 of the Indian Forest Act, 1927 (16 of 1927), or declared as such under any other State Act;`
  line
  line `(26) "sanctuary" means an area declared as a sanctuary by notification under the provisions of`
  line `Chapter IV of this Act and shall also include a deemed sanctuary under sub-section (4) of section 66;]`
  line
  line `^26[(26A) "Schedule" means a Schedule appended to this Act;]`
  line
  line `^27[(27) "specified plant" means any plant specified in ^28[Schedule III];]`
  line
  line `^29* * * *`
  line
  line `(29) "State Government", in relation to a Union territory, means the Administrator of that Union`
  line `territory appointed by the President under article 239 of the Constitution;`
  line
  line `^30[(30) "taxidermy", with its grammatical variations and cognate expressions, means the curing,`
  line `preparation or preservation or mounting of trophies;]`
  line
  line `^31](30A) "territorial waters" shall have the same meaning as in section 3 of the Territorial Waters,`
  line `Continental Shelf, Exclusive Economic Zone and other Maritime Zones Act, 1976 (80 of 1976);]`
  line
  line `(31) "trophy" means the whole or any part of any captive animal or wild animal, other than`
  line `vermin, which has been kept or preserved by any means, whether artificial or natural, and`
  line includes--
  line
  line `(a) rugs, skins and specimens of such animal mounted in whole or in part through a process`
  line `of taxidermy, and`
  line
  line `^32[(b) antler, bone, carapace, shell, horn, rhinoceros horn, hair, feather, nail, tooth, tusk, musk,`
  line `eggs, nests and honeycomb;]`
  line
  line `(32) "uncured trophy" means the whole or any part of any captive animal or wild animal, other`
  line `than vermin, which has not undergone a process of taxidermy, and includes a ^33[freshly killed wild`
  line `animal, ambergris, musk and other animal products];`
  line
  line `(33) "vehicle" means any conveyance used for movement on land, water or air and includes`
  line `buffalo, bull, bullock, camel, donkey, elephant, horse and mule;`
  line
  line `^34[(34) "vermin" means any wild animal notified under section 62;]`
  line `(35) "weapon" includes ammunition, bows and arrows, explosives, firearms, hooks’ knives, nets`
  line `poison, snares and traps and any instrument or apparatus capable of anaesthetizing, decoying,`
  line `destroying, injuring or killing an animal;`
  line
  line `^35[(36) "wild animal" means any animal specified in ^36[Schedule I or Schedule II] and found wild`
  line `in nature;]`
  line
  line `^37[(37) "wild life" includes any animal, aquatic or land vegetation which forms part of any`
  line habitat;]
  line
  line `(38) "Wild Life Warden" means the person appointed as such under clause (b) of sub-section (1)`
  line `of section 4;`
  line
  line `^38[(39) "zoo" means an establishment, whether stationary or mobile, where captive animals are`
  line `kept for exhibiting to the public or ex-situ conservation and includes a circus and off-exhibit facilities`
  line `such as rescue centres and conservation breeding centres, but does not include an establishment of a`
  line `licensed dealer in captive animals.]`
