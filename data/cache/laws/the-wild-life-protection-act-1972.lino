  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32929&sectionno=36&orderno=54&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_36_content:
  string
  line `[Declaration of game reserve.]---Omitted by the Wild Life (Protection) Amendment Act, 1991`
  line `(44 of 1991), s. 24 (w.e.f. 2-10-1991).`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_36_a:
  sectionId (32930)
  sectionNo 36A
  orderNo 55
  title `Declaration and management of a conservation reserve.`
  content obj_root_law_sections_36_a_content
  footnotes `1. Ins. by Act 16 of 2003, s. 20 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=32930&sectionno=36A&orderno=55&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_36_a_content:
  string
  line `^1[36A. Declaration and management of a conservation reserve.--(1) The State Government may,`
  line `after having consultations with the local communities, declare any area owned by the Government, particularly the areas adjacent to National Parks and sanctuaries and those areas which link one protected`
  line `area with another, as a conservation reserve for protecting landscapes, seascapes, flora and fauna and their`
  line `habitat:`
  line
  line `Provided that where the conservation reserve includes any land owned by the Central Government, its`
  line `prior concurrence shall be obtained before making such declaration.`
  line
  line `(2) The provisions of sub-section (2) of section 18, sub-sections (2), (3) and (4) of section 27, sections`
  line `30, 32 and clauses (b) and (c) of section 33 shall, as far as may be, apply in relation to a conservation`
  line `reserve as they apply in relation to a sanctuary.]`
obj_root_law_sections_36_b:
  sectionId (33019)
  sectionNo 36B
  orderNo 56
  title `Conservation reserve management committee.`
  content obj_root_law_sections_36_b_content
  footnotes `1. Ins. by Act 16 of 2003, s. 20 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33019&sectionno=36B&orderno=56&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_36_b_content:
  string
  line `^1[36B. Conservation reserve management committee.--(1) The State Government shall constitute a`
  line `conservation reserve management committee to advise the Chief Wild Life Warden to conserve, manage`
  line `and maintain the conservation reserve.`
  line
  line `(2) The committee shall consist of a representative of the forest or Wild Life Department, who shall`
  line `be the Member-Secretary of the Committee, one representative of each Village Panchayat in whose`
  line `jurisdiction the reserve is located, three representatives of non-governmental organisations working in the`
  line `field of wild life conservation and one representative each from the Department of Agriculture and`
  line `Animal Husbandry.`
  line
  line `(3) The Committee shall regulate its own procedure including the quorum.]`
obj_root_law_sections_36_c:
  sectionId (33020)
  sectionNo 36C
  orderNo 57
  title `Declaration and management of community reserve.`
  content obj_root_law_sections_36_c_content
  footnotes `1. Ins. by Act 16 of 2003, s. 20 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33020&sectionno=36C&orderno=57&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_36_c_content:
  string
  line `^1[36C. Declaration and management of community reserve.-- (1) The State Government may,`
  line `where the community or an individual has volunteered to conserve wild life and its habitat, declare any`
  line `private or community land not comprised within a National Park, sanctuary or a conservation reserve, as a`
  line `community reserve, for protecting fauna, flora and traditional or cultural conservation values and`
  line practices.
  line
  line `(2) The provisions of sub-section (2) of section 18, sub-sections (2), (3) and (4) of section 27, sections`
  line `30, 32 and clauses (b) and (c) of section 33 shall, as far as may be, apply in relation to a community`
  line `reserve as they apply in relation to a sanctuary.`
  line
  line `(3) After the issue of notification under sub-section (1), no change in the land use pattern shall be`
  line `made within the community reserve, except in accordance with a resolution passed by the management`
  line `committee and approval of the same by the State Government.]`
obj_root_law_sections_36_d:
  sectionId (33021)
  sectionNo 36D
  orderNo 58
  title `Community reserve management committee.`
  content obj_root_law_sections_36_d_content
  footnotes obj_root_law_sections_36_d_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33021&sectionno=36D&orderno=58&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_36_d_content:
  string
  line `^1[36D. Community reserve management committee.-- (1) The State Government shall constitute a`
  line `Community Reserve management committee, which shall be the authority responsible for conserving,`
  line `maintaining and managing the community reserve.`
  line
  line `(2) The committee shall consist of ^2[not less than five representatives] nominated by the Village`
  line `Panchayat or where such Panchayat does not exist by the members of the Gram Sabha and one`
  line `representative of the State Forests or Wild Life Department under whose jurisdiction the community`
  line `reserve is located.`
  line
  line `^3[(2A) Where a community reserve is declared on private land under sub-section (1) of section 36C,`
  line `the community reserve management committee shall consist of the owner of the land, a representative of`
  line `the State Forests or Wild Life Department under whose jurisdiction the community reserve is located and`
  line `also the representative of the Panchayat concerned or the tribal community, as the case may be.]`
  line
  line `(3) The committee shall be the competent authority to prepare and implement the management plan`
  line `for the community reserve and to take steps to ensure the protection of wild life and its habitat in the`
  line reserve.
  line
  line `(4) The committee shall elect a Chairman who shall also be the Honorary Wild Life Warden on the`
  line `community reserve.`
  line
  line `(5) The committee shall regulate its own procedure including the quorum.]`
obj_root_law_sections_36_d_footnotes:
  string
  line `1. Ins. by Act 16 of 2003, s. 20 (w.e.f. 1-4-2003).`
  line
  line `2. Subs. by Act 18 of 2022, s. 15, for "five representatives" (w.e.f. 1-4-2023).`
  line
  line `3. Ins. by s. 15, ibid. (w.e.f. 1-4-2023).`
obj_root_law_sections_37:
  sectionId (33022)
  sectionNo (37)
  orderNo 59
  title Omitted..
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33022&sectionno=37&orderno=59&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_37_content:
  string
  line `[Declaration of closed area.]---Omitted by the Wild Life (Protection) Amendment Act, 2002`
  line `(16 of 2003), s. 21(w.e.f. 1-4-2003).`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (33023)
  sectionNo (38)
  orderNo 60
  title `Power of Central Government to declare areas as sanctuaries or National Parks or conservation reserves.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33023&sectionno=38&orderno=60&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_content:
  string
  line `38. Power of Central Government to declare areas as sanctuaries or National Parks ^1[or`
  line `conservation reserves].(1) Where the State Government leases or otherwise transfers any area under`
  line `its control, not being an area within a sanctuary, to the Central Government, the Central Government may,`
  line `if it is satisfied that the conditions specified in section 18 are fulfilled in relation to the area so transferred`
  line `to it, declare such area, by notification, to be a sanctuary and the provisions of ^2[sections 18 to 35] (both`
  line `inclusive), 54 and 55 shall apply in relation to such sanctuary as they apply in relation to a sanctuary`
  line `declared by the State Government.`
  line
  line `(2) The Central Government may, if it is satisfied that the conditions specified in section 35 are`
  line `fulfilled in relation to any area referred to in section (1), whether or not such area has been declared, to be`
  line `a sub sanctuary by the Central Government or the State Government, declare such area, by notification, to`
  line `be a National Park and the provisions of sections 35, 54 and 55 shall apply in relation to such National`
  line `Park as they apply in relation to a National Park declared by the State Government.`
  line
  line `^3[(2A) The Central Government may, if it is satisfied that the conditions specified in sub-section (1) of`
  line `section 36A are fulfilled in relation to any area referred to in sub-section (1), declare such area, by`
  line `notification, to be a conservation reserve and the provisions of sections 36A and 36B shall apply in`
  line `relation to such conservation reserve as they apply in relation to a conservation reserve declared by the`
  line `State Government.]`
  line
  line `(3) In relation to a sanctuary or National Park ^1[or conservation reserve] declared by the Central`
  line `Government, the powers and duties of the Chief Wild Life Warden under the sections referred to in`
  line `^4[sub-sections (1), (2) and (2A)], shall be exercised and discharged by the Director or by such other`
  line `officer as may be authorised by the Director in this behalf and references, in the sections aforesaid, to the`
  line `State Government shall be construed as references to the Central Government and reference therein to the`
  line `Legislature of the State shall be construed as a reference to Parliament.`
obj_root_law_sections_38_footnotes:
  string
  line `1. Ins. by Act 18 of 2022, s. 16, (w.e.f. 1-4-2023).`
  line
  line `2. Subs. by Act 44 of 1991, s. 25, for "sections 19 to 35" (w.e.f. 2-10-1991).`
  line
  line `3. Ins. by Act 18 of 2022, s. 16 (w.e.f. 1-4-2023).`
  line
  line `4. Subs. by s. 16, ibid, for "sub-sections (1) and (2)" (w.e.f. 1-4-2023).`
obj_root_law_sections_38_a:
  sectionId (33027)
  sectionNo 38A
  orderNo 61
  title `Constitution of Central Zoo Authority`
  content obj_root_law_sections_38_a_content
  footnotes `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33027&sectionno=38A&orderno=61&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_a_content:
  string
  line `^1[38A. Constitution of Central Zoo Authority.-- (1) The Central Government shall constitute a body`
  line `to be known as the Central Zoo Authority (hereinafter in this Chapter referred to as the Authority), to`
  line `exercise the powers conferred on, and to perform the functions assigned to it under this Act.`
  line
  line `(2) The Authority shall consist of--`
  line
  line `(a) chairperson;`
  line
  line `(b) such number of members not exceeding ten; and`
  line
  line `(c) Member-Secretary,`
  line
  line `to be appointed by the Central Government.`
obj_root_law_sections_38_b:
  sectionId (33061)
  sectionNo 38B
  orderNo 62
  title `Term of office and conditions of service of Chairperson and members, etc.`
  content obj_root_law_sections_38_b_content
  footnotes obj_root_law_sections_38_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33061&sectionno=38B&orderno=62&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_b_content:
  string
  line `^1[8B. Term of office and conditions of service of Chairperson and members, etc.-- (1) The`
  line `chairperson and every member ^2other than the Member-Secretary] shall hold office for such period, not`
  line `exceeding three years, as may be specified by the Central Government in this behalf.`
  line
  line `(2) The chairperson or a member may by writing under his hand addressed to the Central`
  line `Government, resign from the office of chairperson or, as the case may be, of the member.`
  line
  line `(3) The Central Government shall remove a person from the office of chairperson or member referred`
  line `to in sub-section (2) if that person`
  line
  line `(a) becomes an undischarged insolvent;`
  line
  line `(b) gets convicted and sentenced to imprisonment for an offence which in the opinion of the`
  line `Central Government involves moral turpitude;`
  line
  line `(c) becomes of unsound mind and stands so declared by a competent court;`
  line
  line `(d) refuses to act or becomes incapable of acting;`
  line
  line `(e) is, without obtaining leave of absence from the authority, absent from three consecutive`
  line `meetings of the Authority; or`
  line
  line `(f) in the opinion of the Central Government has so abused the position of chairperson or member`
  line `as to render that persons continuance in office detrimental to the public interest`
  line
  line `Provided that no person shall be removed under this clause unless that person has been given a`
  line `reasonable opportunity of being heard in the matter.`
  line
  line `(4) A vacancy caused under sub-section (2) or otherwise shall be filled by fresh appointment.`
  line
  line `(5) The salaries and allowances and other conditions of appointment of chairperson, members and`
  line `Member-Secretary of the Authority shall be such as may be prescribed.`
  line
  line `(6) The Authority shall, with the previous sanction of the Central Government, employ such officers`
  line `and other employees as it deems necessary to carry out the purposes of the Authority.`
  line
  line `(7) The terms and conditions of service of the officers and other employees of the Authority shall be`
  line `such as may be prescribed.`
  line
  line `(8) No act or proceeding of the Authority shall be questioned or shall be invalid on the ground merely`
  line `of the existence of any vacancies or defect in the constitution of the Authority.]`
obj_root_law_sections_38_b_footnotes:
  string
  line `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  line
  line `2. Ins. by Act 16 of 2003, s. 22 (w.e.f.1-4-2003).`
obj_root_law_sections_38_c:
  sectionId (33062)
  sectionNo 38C
  orderNo 63
  title `Functions of the Authority`
  content obj_root_law_sections_38_c_content
  footnotes `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33062&sectionno=38C&orderno=63&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_c_content:
  string
  line `^1[38C. Functions of the Authority.-- The Authority shall perform the following functions, namely:--`
  line
  line `(a) specify the minimum standards for housing, upkeep and veterinary care of the animals kept in`
  line `a zoo;`
  line
  line `(b) evaluate and assess the functioning of zoos with respect to the standards or the norms as may`
  line `be prescribed;`
  line
  line `(c) recognise or derecognise zoos;`
  line
  line `(d) identify endangered species of wild animals for purposes of captive breeding and assigning`
  line `responsibility in this regard to a zoo;`
  line
  line `(e) co-ordinate the acquisition, exchange and loaning of animals for breeding purposes;`
  line
  line `(f) ensure maintenance of stud-books of endangered species of wild animals bred in captivity;`
  line
  line `(g) identify priorities and themes with regard to display of captive animals in a zoo;`
  line
  line `(h) co-ordinate training of zoo personnel in India and outside India;`
  line
  line `(i) co-ordinate research in captive breeding and educational programmes for the purposes of zoos;`
  line
  line `(j) provide technical and other assistance to zoos for their proper management and development`
  line `on scientific lines;`
  line
  line `(k) perform such other functions as may be necessary to carry out the purposes of this Act with`
  line `regard to zoos.]`
obj_root_law_sections_38_d:
  sectionId (33063)
  sectionNo 38D
  orderNo 64
  title `Procedure to be regulated by the Authority.`
  content obj_root_law_sections_38_d_content
  footnotes `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33063&sectionno=38D&orderno=64&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_d_content:
  string
  line `^1[38D. Procedure to be regulated by the Authority.-- (1) The Authority shall meet as and when`
  line `necessary and shall meet at such time and place as the chairperson may think fit.`
  line
  line `(2) The Authority shall regulate its own procedure.`
  line
  line `(3) All orders and decisions of the Authority shall be authenticated by the Member-Secretary or any`
  line `other officer of the Authority duly authorised by the Member-Secretary in this behalf.]`
obj_root_law_sections_38_e:
  sectionId (33098)
  sectionNo 38E
  orderNo 65
  title `Grants and loans to Authority and Constitution of Fund.`
  content obj_root_law_sections_38_e_content
  footnotes `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33098&sectionno=38E&orderno=65&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_e_content:
  string
  line `^1[38E.Grants and loans to Authority and Constitution of Fund.-- (1) The Central Government may,`
  line `after due appropriation made by Parliament by law in this behalf, make to the Authority grants and loans`
  line `of such sums of money as that Government may consider necessary.`
  line
  line `(2) There shall be constituted a Fund to be called the Central Zoo Authority Fund and there shall be`
  line `credited thereto any grants and loans made to the Authority by the Central Government, all fees and`
  line `charges received by the Authority under this Act and all sums received by the Authority from such other`
  line `sources as may be decided upon by the Central Government.`
  line
  line `(3) The Fund referred to in sub-section (2) shall be applied for meeting salary, allowances and other`
  line `remuneration of the members, officers and other employees of the Authority and the expenses of the`
  line `Authority in the discharge of its functions under this Chapter and expenses on objects and for purposes`
  line `authorised by this Act.`
  line
  line `(4) The Authority shall maintain proper accounts and other relevant records and prepare an annual`
  line `statement of accounts in such form as may be prescribed by the Central Government in consultation with`
  line `the Comptroller and Auditor-General of India.`
  line
  line `(5) The accounts of the Authority shall be audited by the Comptroller and Auditor-General at such`
  line `intervals as may be specified by him and any expenditure incurred in connection with such audit shall be`
  line `payable by the Authority to the Comptroller and Auditor-General.`
  line
  line `(6) The Comptroller and Auditor-General and any person appointed by him in connection with the`
  line `audit of the accounts of the Authority under this Act shall have the same rights and privileges and the`
  line `authority in connection with such audit as the Comptroller and Auditor-General generally has in`
  line `connection with the audit of the Government accounts and, in particular, shall have the right to demand`
  line `the production of books, accounts, connected vouchers and other documents and papers and to inspect`
  line `any of the offices of the Authority.`
  line
  line `(7) The accounts of the Authority, as certified by the Comptroller and Auditor-General or any other`
  line `person appointed by him in this behalf, together with the audit report thereon, shall be forwarded annually`
  line `to the Central Government by the Authority.]`
obj_root_law_sections_38_f:
  sectionId (33099)
  sectionNo 38F
  orderNo 66
  title `Annual report.`
  content obj_root_law_sections_38_f_content
  footnotes `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33099&sectionno=38F&orderno=66&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_f_content:
  string
  line `^1[38F. Annual report.--The Authority shall prepare in such form and at such time, for each financial`
  line `year, as may be prescribed, its annual report, giving a full account of its activities during the previous`
  line `financial year and forward a copy thereof to the Central Government.]`
obj_root_law_sections_38_g:
  sectionId (33100)
  sectionNo 38G
  orderNo 67
  title `Annual report and audit report to be laid before Parliament.`
  content obj_root_law_sections_38_g_content
  footnotes `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33100&sectionno=38G&orderno=67&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_g_content:
  string
  line `^1[38G. Annual report and audit report to be laid before Parliament.-- The Central Government`
  line `shall cause the annual report together with a memorandum of action taken on the recommendations`
  line `contained therein, in so far as they relate to the Central Government, and the reasons for the nonacceptance, if any, of any of such recommendations and the audit report to be laid as soon as may be after`
  line `the reports are received before each House of Parliament.]`
obj_root_law_sections_38_h:
  sectionId (33101)
  sectionNo 38H
  orderNo 68
  title `Recognition of zoos.`
  content obj_root_law_sections_38_h_content
  footnotes obj_root_law_sections_38_h_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33101&sectionno=38H&orderno=68&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_h_content:
  string
  line `^1[38H. Recognition of zoos.--(1) No zoo shall be operated without being recognised by the Authority:`
  line
  line `Provided that a zoo being operated immediately before the date of commencement of the Wild Life`
  line `(Protection) (Amendment) Act, 1991(44 of 1991) may continue to operate without being recognised for a`
  line `period of^2[eighteen months from the date of such commencement] and if the application seeking`
  line `recognition is made within that period, the zoo may continue to be operated until the said application is`
  line `finally decided or withdrawn and in case of refusal for a further period of six months from the date of`
  line `such refusal.`
  line
  line `^3[(1A) On and after the commencement of the Wild Life (Protection) Amendment Act, 2002 (16 of`
  line `2003) a zoo shall not be established without obtaining the prior approval of the Authority.]`
  line
  line `(2) Every application for recognition of a zoo shall be made to the Authority in such form and on`
  line `payment of such fee as may be prescribed.`
  line
  line `(3) Every recognition shall specify the conditions, if any, subject to which the applicant shall operate`
  line `the zoo.`
  line
  line `(4) No recognition to a zoo shall be granted unless the Authority, having due regard to the interests of`
  line `protection and conservation of wild life, and such standards, norms and other matters as may be`
  line `prescribed, is satisfied that recognition should be granted.`
  line
  line `(5) No application for recognition of a zoo shall be rejected unless the applicant has been given a`
  line `reasonable opportunity of being heard.`
  line
  line `(6) The Authority may, for reasons to be recorded by it, suspend or cancel any recognition granted`
  line `under sub-section (4):`
  line
  line `Provided that no such suspension or cancellation shall be made except after giving the person`
  line `operating the zoo a reasonable opportunity of being heard.`
  line
  line `(7) An appeal from an order refusing to recognise a zoo under sub-section (5) or an order suspending`
  line `or cancelling a recognition under sub-section (6) shall lie to the Central Government.`
  line
  line `(8) An appeal under sub-section (7) shall be preferred within thirty days from the date of`
  line `communication to the applicant of the order appealed against:`
  line
  line `Provided that the Central Government may admit any appeal preferred after the expiry of the period`
  line `aforesaid if it is satisfied that the appellant had sufficient cause for not preferring the appeal in time.`
obj_root_law_sections_38_h_footnotes:
  string
  line `1. Ins. by s. 26, ibid. (w.e.f. 2-10-1991).`
  line
  line `2. Subs. by Act 26 of 1993, s. 2, for "six months from the date of such commencement " (w.e.f. 4-8-1992).`
  line
  line `3. Ins. by Act 16 of 2003, s. 23 (w.e.f. 1-4-2003).`
obj_root_law_sections_38_i:
  sectionId (33102)
  sectionNo 38I
  orderNo 69
  title `Acquisition of animals by a zoo.`
  content obj_root_law_sections_38_i_content
  footnotes obj_root_law_sections_38_i_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33102&sectionno=38I&orderno=69&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_i_content:
  string
  line `^1[38-I. Acquisition of animals by a zoo.-- (1) Subject to the other provisions of this Act, no zoo shall`
  line `acquire, sell or transfer any wild animal or captive animal specified in S Schedules I ^2*** except with the`
  line `previous permission of the Authority.`
  line
  line `(2) No zoo shall acquire, sell or transfer any wild or captive animal except from or to a recognised`
  line zoo.]
  line
  line `^3Provided that nothing in this sub-section shall apply to a conservation breeding centre.]`
obj_root_law_sections_38_i_footnotes:
  string
  line `1. Subs. by Act 16 of 2003, s. 24, for section 38-I (w.e.f. 1-4-2003).`
  line
  line `2. The word and figures "and II" omitted by Act 18 of 2022, s. 17 (w.e.f. 1-4-2023).`
  line
  line `3. Ins. by s. 17, ibid, (w.e.f. 1-4-2023).`
obj_root_law_sections_38_j:
  sectionId (33103)
  sectionNo 38J
  orderNo 70
  title `Prohibition of teasing, etc., in a zoo.`
  content obj_root_law_sections_38_j_content
  footnotes `1. Subs. by Act 16 of 2003, s. 24, for section 38-I (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33103&sectionno=38J&orderno=70&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_j_content:
  string
  line `^1[38J. Prohibition of teasing, etc., in a zoo.-- No person shall tease, molest, injure or feed any animal`
  line `or cause disturbance to the animals by noise or otherwise, or litter the grounds in a zoo.]`
obj_root_law_sections_38_k:
  sectionId (33104)
  sectionNo 38K
  orderNo 71
  title Definitions
  content obj_root_law_sections_38_k_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33104&sectionno=38K&orderno=71&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_k_content:
  string
  line `^138K. Definitions.-- In this Chapter,--`
  line
  line `(a) "National Tiger Conservation Authority" means the Tiger Conservation Authority constituted`
  line `under section 38L;`
  line
  line `(b) "Steering Committee" means the Committee constituted under section 38U;`
  line
  line `(c) "Tiger Conservation Foundation" means the foundation established under section 38X;`
  line
  line `(d) "tiger reserve State" means a State having tiger reserve;`
  line
  line `(e) "tiger reserve" means the areas notified as such under section 38V.`
obj_root_law_sections_38_l:
  sectionId (33107)
  sectionNo 38L
  orderNo 72
  title `Constitution of National Tiger Conservation Authority.`
  content obj_root_law_sections_38_l_content
  footnotes obj_root_law_sections_38_l_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33107&sectionno=38L&orderno=72&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_l_content:
  string
  line `^1[38L.Constitution of National Tiger Conservation Authority.-- (1) The Central Government shall`
  line `constitute a body to be known as the National Tiger Conservation Authority (hereinafter in this Chapter`
  line `referred to as the Tiger Conservation Authority), to exercise the powers conferred on, and to perform the`
  line `functions assigned to it under this Act.`
  line
  line `(2) The Tiger Conservation Authority shall consist of the following members, namely:--`
  line
  line `(a) the Minister in charge of the Ministry of Environment and Forests---Chairperson;`
  line
  line `(b) the Minister of State in the Ministry of Environment and Forests---Vice-Chairperson;`
  line
  line `(c) three members of Parliament of whom two shall be elected by the House of the People and`
  line `one by the Council of States;`
  line
  line `(d) eight experts or professionals having prescribed qualifications and experience in conservation`
  line `of wild life and welfare of people living in tiger reserve out of which at least two shall be from the`
  line `field of tribal development;`
  line
  line `(e) Secretary, Ministry of Environment and Forests;`
  line
  line `(f) Director General of Forests and Special Secretary, Ministry of Environment and Forests;`
  line
  line `(g) Director, Wild Life Preservation, Ministry of Environment and Forests;`
  line
  line `(h) six Chief Wild Life Wardens from the tiger reserve States in rotation for three years;`
  line
  line `(i) an officer not below the rank of Joint Secretary and Legislative Counsel from the Ministry of`
  line `Law and Justice;`
  line
  line `(j) Secretary, Ministry of Tribal Affairs;`
  line
  line `(k) Secretary, Ministry of Social Justice and Empowerment;`
  line
  line `(l) Chairperson, National Commission for the Scheduled Tribes;`
  line
  line `(m) Chairperson, National Commission for the Scheduled Castes;`
  line
  line `(n) Secretary, Ministry of Panchayati Raj;`
  line
  line `(o) ^2[an officer not below the rank of Inspector General of Forests] having at least ten years`
  line `experience in a tiger reserve or wildlife management, who shall be the Member-Secretary,,`
  line
  line `to be notified by the Central Government, in the Official Gazette.`
  line
  line `(3) It is hereby declared that the office of member of the Tiger Conservation Authority shall not`
  line `disqualify its holder for being chosen as, or for being, a member of either House of Parliament.]`
obj_root_law_sections_38_l_footnotes:
  string
  line `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  line
  line `2. Subs. by Act 18 of 2022, s. 18, for "Inspector General of Forests or an officer of the equivalent rank" (w.e.f. 1-4-2023).`
obj_root_law_sections_38_m:
  sectionId (33108)
  sectionNo 38M
  orderNo 73
  title `Term of office and conditions of service of members.`
  content obj_root_law_sections_38_m_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33108&sectionno=38M&orderno=73&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_m_content:
  string
  line `^1[38M. Term of office and conditions of service of members.-- (1) A member nominated under`
  line `clause (d) of sub-section (2) of section 38L shall hold office for such period not exceeding three years:`
  line
  line `Provided that a member may, by writing under his hand addressed to the Central Government, resign`
  line `from his office.`
  line
  line `(2) The Central Government shall remove a member referred to in clause (d) of sub-section (2) of`
  line `section 38L, from office if he--`
  line
  line `(a) is, or at any time has been, adjudicated as insolvent;`
  line
  line `(b) has been convicted of an offence which, in the opinion of the Central Government, involves`
  line `moral turpitude;`
  line
  line `(c) is of unsound mind and stands so declared by a competent court;`
  line
  line `(d) refuses to act or becomes incapable of acting;`
  line
  line `(e) is, without obtaining leave of absence from the Tiger Conservation Authority, absent from`
  line `three consecutive meetings of the said Authority; or`
  line
  line `(f) has, in the opinion of the Central Government, so abused his position as to render his`
  line `continuation in office detrimental to the public interest:`
  line
  line `Provided that no member shall be removed under this sub-section unless he has been given a`
  line `reasonable opportunity of being heard in the matter.`
  line
  line `(3) Any vacancy in the office of a member shall be filled by fresh appointment and such member`
  line `shall continue for the remainder of the term of the member in whose place he is appointed.`
  line
  line `(4) The salaries and allowances and other conditions of appointment of the members of the Tiger`
  line `Conservation Authority shall be such as may be prescribed.`
  line
  line `(5) No act or proceeding of the Tiger Conservation Authority shall be questioned or shall be invalid`
  line `on the ground merely of the existence of any vacancy or defect in the constitution of the Tiger`
  line `Conservation Authority.]`
obj_root_law_sections_38_n:
  sectionId (33110)
  sectionNo 38N
  orderNo 74
  title `Officers and employees of Tiger Conservation Authority.`
  content obj_root_law_sections_38_n_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33110&sectionno=38N&orderno=74&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_n_content:
  string
  line `^1[38N. Officers and employees of Tiger Conservation Authority.-- (1) The Tiger Conservation`
  line `Authority may, with the previous sanction of the Central Government, appoint such other officers and`
  line `employees as it considers necessary for the efficient discharge of its functions under this Act:`
  line
  line `Provided that the officers and employees holding office under the Directorate of Project Tiger and`
  line `dealing with Project Tiger immediately before the date of constitution of the Tiger Conservation`
  line `Authority shall continue to hold office in the said Authority by the same tenure and upon the same terms`
  line `and conditions of service or until the expiry of the period of six months from that date if such employee`
  line `opts not to be' the employee of that Authority.`
  line
  line `(2) The terms and conditions of service of the officers and other employees of the Tiger Conservation`
  line `Authority shall be such as may be prescribed.]`
obj_root_law_sections_38_o:
  sectionId (33186)
  sectionNo 38O
  orderNo 75
  title `Powers and functions of Tiger Conservation Authority.`
  content obj_root_law_sections_38_o_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33186&sectionno=38O&orderno=75&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_o_content:
  string
  line `^1[38O. Powers and functions of Tiger Conservation Authority.-- (1) The Tiger Conservation`
  line `Authority shall have the following powers and perform the following functions, namely:--`
  line
  line `(a) to approve the Tiger Conservation Plan prepared by the State Government under`
  line `sub-section (5) of section 38V of this Act;`
  line
  line `(b) evaluate and assess various aspects of sustainable ecology and disallow any ecologically`
  line `unsustainable land use such as, mining, industry and other projects within the tiger reserves;`
  line
  line `(c) lay down normative standards for tourism activities and guidelines for project tiger from time`
  line `to time for tiger conservation in the buffer and core area of tiger reserves and ensure their due`
  line compliance;
  line
  line `(d) provide for management focus and measures for addressing conflicts of men and wild animals`
  line `and to emphasise on co-existence in forest areas outside the National Parks, sanctuaries or tiger`
  line `reserve, in the working plan code;`
  line
  line `(e) provide information on protection measures including future conservation plan, estimation of`
  line `population of tiger and its natural prey species, status of habitats, disease surveillance, mortality`
  line `survey, patrolling, reports on untoward happenings and such other management aspects as it may`
  line `deem fit including future plan conservation;`
  line
  line `(f) approve, co-ordinate research and monitoring on tiger, co-predators, prey, habitat, related`
  line `ecological and socio-economic parameters and their evaluation;`
  line
  line `(g) ensure that the tiger reserves and areas linking one protected area or tiger reserve with another`
  line `protected area or tiger reserve are not diverted for ecologically unsustainable uses, except in public`
  line `interest and with the approval of the National Board for Wild Life and on the advice of the Tiger`
  line `Conservation Authority;`
  line
  line `(h) facilitate and support the tiger reserve management in the State for biodiversity conservation`
  line `initiatives through eco-development and peoples participation as per approved management plans`
  line `and to support similar initiatives in adjoining areas consistent with the Central and State laws;`
  line
  line `(i) ensure critical support including scientific, information technology and legal support for better`
  line `implementation of the tiger conservation plan;`
  line
  line `(j) facilitate ongoing capacity building programme for skill development of officers and staff of`
  line `tiger reserves; and`
  line
  line `(k) perform such other functions as may be necessary to carry out the purposes of this Act with`
  line `regard to conservation of tigers and their habitat.`
  line
  line `(2) The Tiger Conservation Authority may, in the exercise of its powers and performance of its`
  line `functions under this Chapter, issue directions in writing to any person, officer or authority for the`
  line `protection of tiger or tiger reserves and such person, officer or authority shall be bound to comply with`
  line `the directions:`
  line
  line `Provided that no such direction shall interfere with or affect the rights of local people particularly the`
  line `Scheduled Tribes.]`
obj_root_law_sections_38_p:
  sectionId (33187)
  sectionNo 38P
  orderNo 76
  title `Procedure to be regulated by Tiger Conservation Authority.`
  content obj_root_law_sections_38_p_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33187&sectionno=38P&orderno=76&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_p_content:
  string
  line `38P. Procedure to be regulated by Tiger Conservation Authority(1) The Tiger Conservation`
  line `Authority shall meet at such time and at such place as the Chairperson may think fit.`
  line
  line `(2) The Chairperson or in his absence the Vice-Chairperson shall preside over the meetings of the`
  line `Tiger Conservation Authority.`
  line
  line `(3) The Tiger Conservation Authority shall regulate its own procedure.`
  line
  line `(4) All orders and decisions of the Tiger Conservation Authority shall be authenticated by the`
  line `Member-Secretary or any other officer of the said Authority duly authorised by the Member-Secretary in`
  line `this behalf.`
obj_root_law_sections_38_q:
  sectionId (33188)
  sectionNo 38Q
  orderNo 77
  title `Grants and loans to Tiger Conservation Authority and Constitution of Fund.`
  content obj_root_law_sections_38_q_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33188&sectionno=38Q&orderno=77&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_q_content:
  string
  line `^1[38Q. Grants and loans to Tiger Conservation Authority and Constitution of Fund.-- (1) The`
  line `Central Government may, after due appropriation made by Parliament by law in this behalf, make to the`
  line `Tiger Conservation Authority grants and loans of such sums of money as that Government may consider`
  line necessary.
  line
  line `(2) There shall be constituted a Fund to be called the Tiger Conservation Authority Fund and there`
  line `shall be credited thereto--`
  line
  line `(i) any grants and loans made to the Tiger Conservation Authority by the Central Government;`
  line
  line `(ii) all fees and charges received by the Tiger Conservation Authority under this Act; and`
  line
  line `(iii) all sums received by the Authority from such other sources as may be decided upon by the`
  line `Central Government.`
  line
  line `(3) The Fund referred to in sub-section (2) shall be applied for meeting salary, allowances and other`
  line `remuneration of the members, officers and other employees of the Tiger Conservation Authority and the`
  line `expenses of the Tiger Conservation Authority incurred in the discharge of its functions under this`
  line Chapter.]
obj_root_law_sections_38_r:
  sectionId (33189)
  sectionNo 38R
  orderNo 78
  title `Accounts and audit of Tiger Conservation Authority.`
  content obj_root_law_sections_38_r_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33189&sectionno=38R&orderno=78&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_r_content:
  string
  line `^1[38R. Accounts and audit of Tiger Conservation Authority. -- (1) The Tiger Conservation`
  line `Authority shall maintain proper accounts and other relevant records and prepare an annual statement of`
  line `accounts in such form as may be prescribed by the Central Government in consultation with the`
  line `Comptroller and Auditor-General of India.`
  line
  line `(2) The accounts of the Tiger Conservation Authority shall be audited by the Comptroller and`
  line `Auditor-General of India at such intervals as may be specified by him and any expenditure incurred in`
  line `connection with such audit shall be payable by the Tiger Conservation Authority to the Comptroller and`
  line `Auditor-General of India.`
  line
  line `(3) The Comptroller and Auditor-General of India and any other person appointed by him in`
  line `connection with the audit of the accounts of the Tiger Conservation Authority shall have the same rights`
  line `and privileges and authority in connection with such audit as the Comptroller and Auditor-General`
  line `generally has in connection with the audit of the Government accounts and, in particular, shall have the`
  line `right to demand the production of books, accounts, connected vouchers and other documents and papers`
  line `and to inspect the office of the Tiger Conservation Authority.`
  line
  line `(4) The accounts of the Tiger Conservation Authority as certified by the Comptroller and AuditorGeneral of India or any other person appointed by him in this behalf together with the audit report`
  line `thereon, shall be forwarded annually to the Central Government by the Tiger Conservation Authority.]`
obj_root_law_sections_38_s:
  sectionId (33190)
  sectionNo 38S
  orderNo 79
  title `Annual report of Tiger Conservation Authority.`
  content obj_root_law_sections_38_s_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33190&sectionno=38S&orderno=79&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_s_content:
  string
  line `^1[38S. Annual report of Tiger Conservation Authority.-- The Tiger Conservation Authority shall`
  line `prepare in such form and at such time, for each financial year, as may be prescribed, its annual report,`
  line `giving a full account of its activities during the previous financial year and forward a copy thereof to the`
  line `Central Government.]`
obj_root_law_sections_38_t:
  sectionId (33222)
  sectionNo 38T
  orderNo 80
  title `Annual report and audit report to be laid before Parliament.`
  content obj_root_law_sections_38_t_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33222&sectionno=38T&orderno=80&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_t_content:
  string
  line `^1[38T. Annual report and audit report to be laid before Parliament.--- The Central Government`
  line `shall cause the annual report together with a memorandum of action taken on the recommendations`
  line `contained therein, insofar as they relate to the Central Government, and the reasons for the nonacceptance, if any, of any of such recommendations, and the audit report to be laid, as soon as may be`
  line `after the reports are received, before each House of Parliament.]`
obj_root_law_sections_38_u:
  sectionId (33223)
  sectionNo 38U
  orderNo 81
  title `Constitution of Steering Committee.`
  content obj_root_law_sections_38_u_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33223&sectionno=38U&orderno=81&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_u_content:
  string
  line `^1[38U. Constitution of Steering Committee.--(1) The State Government may constitute a Steering`
  line `Committee for ensuring co-ordination, monitoring, protection and conservation of tiger, co-predators and`
  line `prey animals within the tiger range States.`
  line
  line `(2) The Steering Committee shall consists of--`
  line
  line `(a) the Chief Minister ---Chairperson;`
  line
  line `(b) the Minister in-charge of Wild Life ---Vice-Chairperson;`
  line
  line `(c) such number of official members not exceeding five including at least two Field Directors of`
  line `tiger reserve or Director of National Park and one from the State Government's Departments dealing`
  line `with tribal affairs;`
  line
  line `(d) three experts or professionals having qualifications and experience in conservation of wild life`
  line `of which at least one shall be from the field of tribal development,`
  line
  line `(e) two members from the State's Tribal Advisory Council;`
  line
  line `(f) one representative each from State Government's Departments dealing with Panchayati Raj`
  line `and Social Justice and Empowerment;`
  line
  line `(g) Chief Wild Life Warden of the State shall be the Member-Secretary, ex officio,`
  line
  line `to be notified by the State Government, in the Official Gazette.`
obj_root_law_sections_38_v:
  sectionId (33224)
  sectionNo 38V
  orderNo 82
  title `Tiger Conservation Plan.`
  content obj_root_law_sections_38_v_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33224&sectionno=38V&orderno=82&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_v_content:
  string
  line `^1[38V. Tiger Conservation Plan.-- (1) The State Government shall, on the recommendation of the`
  line `Tiger Conservation Authority, notify an area as a tiger reserve.`
  line
  line `(2) The provisions of sub-section (2) of section 18, sub-sections (2), (3) and (4) of section 27, sections`
  line `30,32 and clauses (b) and (c) of section 33 of this Act shall, as far as may be, apply in relation to a tiger`
  line `reserve as they apply in relation to a sanctuary.`
  line
  line `(3) The State Government shall prepare a Tiger Conservation Plan including staff development and`
  line `deployment plan for the proper management of each area referred to in sub-section (1), so as to ensure--`
  line
  line `(a) protection of tiger reserve and providing site specific habitat inputs for a viable population of`
  line `tigers, co-predators and prey animals without distorting the natural prey-predator ecological cycle in`
  line `the habitat;`
  line
  line `(b) ecologically compatible land uses in the tiger reserves and areas linking one protected area or`
  line `tiger reserve with another for addressing the livelihood concerns of local people, so as to provide`
  line `dispersal habitats and corridor for spill over population of wild animals from the designated core`
  line `areas of tiger reserves or from tiger breeding habitats within other protected areas;`
  line
  line `(c) the forestry operations of regular forest divisions and those adjoining tiger reserves are not`
  line `incompatible with the needs of tiger conservation.`
  line
  line `(4) Subject to the provisions contained in this Act, the State Government shall, while preparing a`
  line `Tiger Conservation Plan, ensure the agricultural, livelihood, developmental and other interests of the`
  line `people living in tiger bearing forests or a tiger reserve,`
  line
  line `Explanation.-- For the purposes of this section, the expression "tiger reserve" includes--`
  line
  line `(i) core or critical tiger habitat areas of National Parks and sanctuaries, where it has been`
  line `established, on the basis of scientific and objective criteria, that such areas are required to be kept as`
  line `inviolate for the purposes of tiger conservation, without affecting the rights of the Scheduled Tribes`
  line `or such other forest dwellers, and. notified as such by the State Government in consultation with an`
  line `Expert Committee constituted for the purpose;`
  line
  line `(ii) buffer or peripheral area consisting of the area peripheral to critical tiger habitat or core area,`
  line `identified and established in accordance with the provisions contained in Explanation (i) above,`
  line `where a lesser degree of habitat protection is required to ensure the integrity of the critical tiger`
  line `habitat with adequate dispersal for tiger species, and which aim at promoting co-existence between`
  line `wildlife and human activity with due recognition of the livelihood, developmental, social and cultural`
  line `rights of the local people, wherein the limits of such areas are determined on the basis of scientific`
  line `and objective criteria in consultation with the concerned Gram Sabha and an Expert Committee`
  line `constituted for the purpose.`
  line
  line `(5) Save as for voluntary relocation on mutually agreed terms and conditions, provided that such`
  line `terms and conditions satisfy the requirements laid down in this sub-section, no Scheduled Tribes or other`
  line `forest dwellers shall be resettled or have their rights adversely affected for the purpose of creating`
  line `inviolate areas for tiger conservation unless--`
  line
  line `(i) the process of recognition and determination of rights and acquisition of land or forest rights of`
  line `the Scheduled Tribes and such other forest dwelling persons is complete;`
  line
  line `(ii) the concerned agencies of the State Government, in exercise of their powers under this Act,`
  line `establishes with the consent of the Scheduled Tribes and such other forest dwellers in the area, and in`
  line `consultation with an ecological and social scientist familiar with the area, that the activities of the`
  line `Scheduled Tribes and other forest dwellers or the impact of their presence upon wild animals is`
  line `sufficient to cause irreversible damage and shall threaten the existence of tigers and their habitat;`
  line
  line `(iii) the State Government, after obtaining the consent of the Scheduled Tribes and other forest`
  line `dwellers inhabiting the area, and in consultation with an independent ecological and social scientist`
  line `familiar with the area, has come to a conclusion that other reasonable options of co-existence, are not`
  line available;
  line
  line `(iv) resettlement or alternative package has been prepared providing for livelihood for the`
  line `affected individuals and communities and fulfils the requirements given in the National Relief and`
  line `Rehabilitation Policy;`
  line
  line `(v) the informed consent of the Gram Sabha concerned, and of the persons affected, to the`
  line `resettlement programme has been obtained; and`
  line
  line `(vi) the facilities and land allocation at the resettlement location are provided under the said`
  line `programme, otherwise their existing rights shall not be interfered with.]`
obj_root_law_sections_38_w:
  sectionId (33258)
  sectionNo 38W
  orderNo 83
  title `Alteration and de-notification of tiger reserves.`
  content obj_root_law_sections_38_w_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33258&sectionno=38W&orderno=83&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_w_content:
  string
  line `38W. Alteration and de-notification of tiger reserves.--(1) No alteration in the boundaries of a`
  line `tiger reserve shall be made except on a recommendation of the Tiger Conservation Authority and the`
  line `approval of the National Board for Wild Life.`
  line
  line `(2) No State Government shall de-notify a tiger reserve, except in public interest with the approval of`
  line `the Tiger Conservation Authority and the National Board for Wild Life.]`
obj_root_law_sections_38_x:
  sectionId (33259)
  sectionNo 38X
  orderNo 84
  title `Establishment of Tiger Conservation Foundation.`
  content obj_root_law_sections_38_x_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33259&sectionno=38X&orderno=84&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_x_content:
  string
  line `^1[38X. Establishment of Tiger Conservation Foundation.--(1) The State Government shall establish`
  line `a Tiger Conservation Foundation for tiger reserves within the State in order to facilitate and support their`
  line `management for conservation of tiger and biodiversity and, to take initiatives in eco-development by`
  line `involvement of people in such development process.`
  line
  line `(2) The Tiger Conservation Foundation shall, inter alia, have the following objectives:--`
  line
  line `(a) to facilitate ecological, economic, social and cultural development in the tiger reserves;`
  line
  line `(b) to promote eco-tourism with the involvement of local stake-holder communities and provide`
  line `support to safeguard the natural environment in the tiger reserves;`
  line
  line `(c) to facilitate the creation of, and or maintenance of, such assets as may be necessary for`
  line `fulfilling the above said objectives;`
  line
  line `(d) to solicit technical, financial, social, legal and other support required for the activities of the`
  line `Foundation for achieving the above said objectives;`
  line
  line `(e) to augment and mobilise financial resources including recycling of entry and such other fees`
  line `received in a tiger reserve, to foster stake-holder development and eco-tourism;`
  line
  line `(f) to support research, environmental education and training in the above related fields.]`
obj_root_law_sections_38_xa:
  sectionId (73292)
  sectionNo 38XA
  orderNo 85
  title `Provisions of Chapter to be in addition to provisions relating to sanctuaries and National Park.`
  content obj_root_law_sections_38_xa_content
  footnotes `1. Ins. by Act 18 of 2022, s. 19 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73292&sectionno=38XA&orderno=85&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_xa_content:
  string
  line `^1[38XA. Provisions of Chapter to be in addition to provisions relating to sanctuaries and`
  line `National Park.-- The provisions contained in this Chapter shall be in addition to, and not in derogation`
  line `of, the provisions relating to sanctuaries and National Parks (whether included and declared, or are in the`
  line `process of being so declared) included in a tiger reserve under this Act.]`
obj_root_law_sections_38_y:
  sectionId (33260)
  sectionNo 38Y
  orderNo 86
  title `Constitution of Wild Life Crime Control Bureau.`
  content obj_root_law_sections_38_y_content
  footnotes obj_root_law_sections_38_y_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33260&sectionno=38Y&orderno=86&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_y_content:
  string
  line `^1[38Y. Constitution of ^2[Wild Life] Crime Control Bureau.--The Central Government may, for the`
  line `purposes of this Act, by order published in the Official Gazette, constitute a 3*** Wildlife Crime Control`
  line `Bureau consisting of--`
  line
  line `(a) the Director of Wildlife Preservation---Director ex officio;`
  line
  line `(b) the Inspector-General of Police---Additional Director;`
  line
  line `(c) the Deputy Inspector-General of Police---Joint Director;`
  line
  line `(d) the Deputy Inspector-General of Forests---Joint Director;`
  line
  line `(e) the Additional Commissioner (Customs and ^4[Central Goods and Services Tax]---Joint`
  line `Director; and`
  line
  line `(f) such other officers as may be appointed from amongst the officers covered under sections 3`
  line `and 4 of this Act.]`
obj_root_law_sections_38_y_footnotes:
  string
  line `1. Subs. by s. 20, ibid., for "TIGER AND OTHER ENDANGERED SPECIES" (w.e.f. 1-4-2023).`
  line
  line `2. Subs. by s. 21, ibid., for "Tiger and other Endangered Species" (w.e.f. 1-4-2023).`
  line
  line `3. The words "Tiger and other Endangered Species Crime Control Bureau to be known as the" omitted by s. 21, ibid. (w.e.f. 1-4-`
  line `2023).`
  line
  line `4. Subs. by s. 21, ibid., for "Central Excise" (w.e.f. 1-4-2023).`
obj_root_law_sections_38_z:
  sectionId (33261)
  sectionNo 38Z
  orderNo 87
  title `Powers and functions of the Wildlife Crime Control Bureau.`
  content obj_root_law_sections_38_z_content
  footnotes `1. Ins. by Act 39 of 2006, s. 2 (w.e.f. 4-9-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33261&sectionno=38Z&orderno=87&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_38_z_content:
  string
  line `^1[38Z. Powers and functions of the Wildlife Crime Control Bureau.-- (1) Subject to the provisions`
  line `of this Act, the Wildlife Crime Control Bureau shall take measures with respect to--`
  line
  line `(i) collect and collate intelligence related to organized wildlife crime activities and to disseminate`
  line `the same to State and other enforcement agencies for immediate action, so as to apprehend the`
  line `criminals and to establish a centralised wildlife crime data bank;`
  line
  line `(ii) co-ordination of actions by various officers, State Governments and other authorities in`
  line `connection with the enforcement of the provisions of this Act, either directly or through regional and`
  line `border units set up by the Bureau;`
  line
  line `(iii) implementation of obligations under the various international Conventions and protocols that`
  line `are in force at present or which may be ratified or acceded to by India in future;`
  line
  line `(iv) assistance to concerned authorities in foreign countries and concerned international`
  line `organisations to facilitate co-ordination and universal action for wildlife crime control;`
  line
  line `(v) develop infrastructure and capacity building for scientific and professional investigation into`
  line `wildlife crimes and assist State Governments to ensure success in prosecutions related to wildlife`
  line crimes;
  line
  line `(vi) advice the Government of India on issues relating to wildlife crimes having national and`
  line `international ramifications, and suggest changes required in relevant policy and laws from time to`
  line time.
  line
  line `(2) The Wildlife Crime Control Bureau shall exercise--`
  line
  line `(i) such powers as may be delegated to it under sub-section (1) of section 5, sub-sections (1)`
  line `and (8) of section 50 and section 55 of this Act; and`
  line
  line `(ii) such other powers as may be prescribed.]`
obj_root_law_sections_39:
  sectionId (33262)
  sectionNo (39)
  orderNo 88
  title `Wild animals, etc., to be Government property.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33262&sectionno=39&orderno=88&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_39_content:
  string
  line `(1) Every--`
  line
  line `(a) wild animal, other than vermin, which is hunted under section 11 or sub-section (1) of section`
  line `29 or sub-section (6) of section 35 or kept or ^1[bred in captivity or hunted] in contravention of any`
  line `provision of this Act or any rule or order made thereunder or found dead, or killed ^2*** or by`
  line `mistake; and`
  line
  line `(b) animal article, trophy or uncured trophy or meat derived from any wild animal referred to in`
  line `clause (a) in respect of which any offence against this Act or any rule or order made thereunder has`
  line `been committed,`
  line
  line `^3[(c) ivory imported into India and an article made from such ivory in respect of which any`
  line `offence against this Act or any rule or order made thereunder has been committed;`
  line
  line `(d) vehicle, vessel, weapon, trap or tool that has been used for committing an offence and has`
  line `been seized under the provisions of this Act.]`
  line
  line `shall be the property of the State Government, and, wheresuch animal is hunted in a sanctuary or National`
  line `Park declared by the Central Government, such animal or any animal article, trophy, uncured trophy or`
  line `meat ^4[derived from such animal or any vehicle, vessel, weapon, trap or tool used in such hunting] shall`
  line `be the property of the Central Government.`
  line
  line `(2) Amy person who obtains, by any means, the possession of Government property, shall, within`
  line `forty-eight hours from obtaining such possession, make a report as to the obtaining of such possession to`
  line `the, nearest police station or the authorised officer and shall, if so required, hand over such property to the`
  line `officer-in-charge of such police station or such authorised officer, as the case may be.`
  line
  line `(3) No person shall, without the previous permission in writing of the Chief Wild Life Warden or the`
  line `authorised officer--`
  line
  line `(a) acquire or keep in his possession, custody or control, or`
  line
  line `(b) transfer to any person, whether by way of gift, sale or otherwise, or`
  line
  line `(c) destroy or damage, such Government property.`
  line
  line `^5[(4) Where any such Government property is a live animal, the State Government shall ensure that it`
  line `is housed and cared for by a recognised zoo or rescue centre when it can not be released to its natural`
  line habitat.
  line
  line `(5) Any such animal article, trophy or uncured trophy or meat derived from any wild animal, as`
  line `referred to in sub-sections (1) and (2) may be disposed of by the State Government or the Central`
  line `Government, as the case may be, in such manner as may be prescribed by the Central Government:`
  line
  line `Provided that such disposal shall not include any commercial sale or auction and no certificate of`
  line `ownership shall be issued for such disposal.]`
obj_root_law_sections_39_footnotes:
  string
  line `1. Subs. by Act 44 of 1991, s. 27, for "bred in captivity" (w.e.f. 2-10-1991).`
  line
  line `2. The words "without a licence or" omitted by s. 27, ibid. (w.e.f. 2-10-1991).`
  line
  line `3. Ins. by s. 27, ibid. (w.e.f. 2-10-1991).`
  line
  line `4. Subs. by Act 44 of 1991, s. 27, for "derived from such animal" (w.e.f. 2-10-1991).`
obj_root_law_sections_40:
  sectionId (33263)
  sectionNo (40)
  orderNo 89
  title Declarations
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33263&sectionno=40&orderno=89&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_40_content:
  string
  line `(1) Every person having at the commencement of this Act the control, custody or`
  line `possession of any captive animal specified in Schedule I ^1***,`
  line `^2[or animal article, trophy or uncured`
  line `trophy] derived from such animal or salted or dried skins of such animal or the musk of`
  line `a musk deer or the horn of a rhinoceros, shall, within thirty days from the commencement of this Act,`
  line `declare to the Chief Wild Life Warden or the authorised officer the number and description of the animal,`
  line `or article of the foregoing description under his control, custody or possession and the place where such`
  line `animal or article is kept.`
  line
  line `(2) No person shall, after the commencement of this Act, acquire, receive, keep in his control, custody`
  line `or possession, sell, offer for sale or 420 otherwise transfer or transport any animal specified in Schedule I`
  line `^3*** or any uncured trophy or meat derived from such animal, or the salted or dried skins of such animal`
  line `or the musk of a musk deer or the horn of a rhinoceros, except with the previous permission in writing of`
  line `the Chief Wild Life Warden or the authorised officer.`
  line
  line `^4[(2A) No person other than a person having a certificate of ownership, shall, after the commencement`
  line `of the Wild Life (Protection) Amendment Act, 2002 (16 of 2003) acquire, receive, keep in his control,`
  line `custody or possession any captive animal, animal article, trophy or uncured trophy specified in Schedule I`
  line `^3***, except by way of inheritance.`
  line
  line `(2B) Every person inheriting any captive animal, animal article, trophy or uncured trophy under`
  line `sub-section (2A) shall, within ninety days of such inheritance make a declaration to the Chief Wild Life`
  line `Warden or the authorised officer and the provisions of sections 41 and 42 shall apply as if the declaration`
  line `had been made under sub-section (1) of section 40:`
  line
  line `Provided that nothing in sub-sections (2A) and (2B) shall apply to the live elephant.].`
  line
  line `(2B) Every person inheriting any captive animal, animal article, trophy or uncured trophy under`
  line `sub-section (2A) shall, within ninety days of such inheritance make a declaration to the Chief Wild Life`
  line `Warden or the authorised officer and the provisions of sections 41 and 42 shall apply as if the declaration`
  line `had been made under sub-section (1) of section 40:`
  line
  line `Provided that nothing in sub-sections (2A) and (2B) shall apply to the live elephant.]`
  line
  line `^5[(3) Nothing in sub-section (1) or sub-section (2) shall apply to a recognised zoo subject to the`
  line `provisions of section 38-I or to a public museum.]`
  line
  line `(4) The State Government may, by notification, require any person to declare to the Chief Wild Life`
  line `Warden or the authorised officer ^6[any animal or animal article] or trophy (other than a musk of a musk`
  line `deer or horn of a rhinoceros) or salted or dried skins derived from an animal specified in Schedule I or`
  line `Part II of Schedule II in his control, custody or possession in such form, in such manner, and within such`
  line `time, as may be prescribed.`
obj_root_law_sections_40_footnotes:
  string
  line `1. The words and figures "or Part II of Schedule II" omitted by s. 23, ibid. (w.e.f. 1-4-2023).`
  line
  line `2. Subs. by Act 16 of 2003, s. 25, for "or any uncured trophy" (w.e.f. 1-4-2003).`
  line
  line `3. The words and figures "or Part II of Schedule II" omitted by Act 18 of 2022, s. 23 (w.e.f. 1-4-2023).`
  line
  line `4. Ins. by Act 16 of 2003, s. 25, (w.e.f. 1-4-2003).`
  line
  line `5. Subs. by Act 44 of 1991, s. 28, for sub-section (3) (w.e.f. 2-10-1991).`
  line
  line `6. Subs. by Act 16 of 2003, s. 25, for "any animal article" (w.e.f. 1-4-2003).`
obj_root_law_sections_40_a:
  sectionId (33264)
  sectionNo 40A
  orderNo 90
  title `Immunity in certain cases.`
  content obj_root_law_sections_40_a_content
  footnotes obj_root_law_sections_40_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33264&sectionno=40A&orderno=90&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_40_a_content:
  string
  line `^1[40A. Immunity in certain cases.-- (1) Notwithstanding anything contained in sub-sections (2) and`
  line `(4) of section 40 of this Act, the Central Government may, by notification, require any person to declare`
  line `to the Chief Wild Life Warden or the authorised officer, any captive animal, animal article, trophy or`
  line `uncured trophy derived from animals specified in Schedule I ^2*** in his control, custody or possession, in`
  line `respect of which no declaration had been made under sub-section (1) or`
  line `sub-section (4) of section 40, in such form, in such manner and within such time as may be prescribed.`
  line
  line `(2) Any action taken or purported to be taken for violation of section 40 of this Act at any time before`
  line `the commencement of the Wild Life (Protection) Amendment Act, 2002 (16 of 2003) shall not be`
  line `proceeded with and all pending proceedings shall stand abated.`
  line
  line `(3) Any captive animal, animal article, trophy or uncured trophy declared under sub-section (1), shall`
  line `be dealt with in such manner and subject to such conditions as may be prescribed.]`
obj_root_law_sections_40_a_footnotes:
  string
  line `1. Ins. by Act 16 of 2003, s. 26 (w.e.f. 1-4-2003).`
  line
  line `2. The words and figures "or Part II of Schedule II" omitted by s. 24, ibid. (w.e.f. 1-4-2023).`
obj_root_law_sections_41:
  sectionId (33265)
  sectionNo (41)
  orderNo 91
  title `Inquiry and preparation of inventories.`
  content obj_root_law_sections_41_content
  footnotes `1. The words and figures "and Part II of Schedule II" omitted by s. 25, ibid, (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33265&sectionno=41&orderno=91&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_41_content:
  string
  line `(1) On receipt of a declaration made under section`
  line `40, the Chief Wild Life Warden or the authorised officer may, after such notice, in such manner and at`
  line `such time, as may be prescribed,--`
  line
  line `(a) enter upon the premises of a person referred to in section 40;`
  line
  line `(b) make inquiries and prepare inventories of animal articles, trophies, uncured trophies, salted`
  line `and dried skins and captive animals specified in Schedule I ^1*** and found thereon; and`
  line
  line `(c) affix upon the animals, animal articles, trophies or uncured trophies identification marks in`
  line `such manner as may be prescribed.`
  line
  line `(2) No person shall obliterate or counterfeit any identification mark referred to in this Chapter.`
obj_root_law_sections_42:
  sectionId (33266)
  sectionNo (42)
  orderNo 92
  title `Certificate of ownership.`
  content obj_root_law_sections_42_content
  footnotes `1. Added by s. 27, ibid. (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33266&sectionno=42&orderno=92&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_42_content:
  string
  line `The Chief Wild Life Warden may, for the purposes of section 40,`
  line `issue a certificate of ownership in such form, as may be prescribed to any person who, in his opinion, is in`
  line `lawful possession of any wild animal or any animal article, trophy, uncured trophy and may, where`
  line `possible, mark, in the prescribed manner, such animal article, trophy or uncured trophy for purposes of`
  line identification.
  line
  line `^1[Provided that before issuing the certificate of ownership in respect of any captive animal, the Chief`
  line `Wild Life Warden shall ensure that the applicant has adequate facilities for housing, maintenance and`
  line `upkeep of the animal.]`
obj_root_law_sections_42_a:
  sectionId (73293)
  sectionNo 42A
  orderNo 93
  title `Surrender of captive animals, animal article, etc`
  content obj_root_law_sections_42_a_content
  footnotes `1. Ins. by Act 18 of 2022, s. 26 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73293&sectionno=42A&orderno=93&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_42_a_content:
  string
  line `^1[42A. Surrender of captive animals, animal article, etc.-- (1) Any person having a certificate of`
  line `ownership in respect of any captive animal, animal article, trophy or uncured trophy, meat or ivory`
  line `imported into India or an article made from such ivory, and who is not desirous of keeping it in his`
  line `control, custody or possession may, after giving notice of seven working days to the Chief Wild Life`
  line `Warden, surrender the same to him and any such certificate of ownership shall stand cancelled from the`
  line `date of such surrender.`
  line
  line `(2) No compensation shall be payable to any person for surrender of any such animal, article, trophy,`
  line `meat or ivory to the Chief Wild Life Warden under sub-section (1).`
  line
  line `(3) Any such animal, article, trophy, meat or ivory surrendered under this section shall become the`
  line `property of the State Government and the provisions of section 39 shall apply.]`
obj_root_law_sections_43:
  sectionId (33267)
  sectionNo (43)
  orderNo 94
  title `Regulation of transfer of animal, etc.`
  content obj_root_law_sections_43_content
  footnotes obj_root_law_sections_43_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33267&sectionno=43&orderno=94&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_43_content:
  string
  line `^1[43. Regulation of transfer of animal, etc.--(1) No person having in his possession captive animal,`
  line `animal article, trophy or uncured trophy in respect of which he has a certificate of ownership shall transfer`
  line `by way of sale or offer for sale or by any other mode of consideration of commercial nature, such animal`
  line `or article or trophy or uncured trophy.`
  line
  line `(2) Where a person transfers or transports from the State in which he resides to another State or`
  line `acquires by transfer from outside the State, any such animal, animal article, trophy or uncured trophy in`
  line `respect of which he has a certificate of ownership, he shall, within thirty days of the transfer or transport,`
  line `report the transfer or transport to the Chief Wild Life Warden or the authorised officer within whose`
  line `jurisdiction the transfer or transport is effected.`
  line
  line `^2[Provided that the transfer or transport of a captive elephant for a religious or any other purpose by a`
  line `person having a valid certificate of ownership shall be subject to such terms and conditions as may be`
  line `prescribed by the Central Government.]`
  line
  line `(3) Nothing in this section shall apply--`
  line
  line `(a) to tail feather of peacock and the animal article or trophies made therefrom;`
  line
  line `(b) to transfer of captive animals between recognised zoos subject to the provisions of`
  line `section 38-I, and transfer amongst zoos and public museums.]`
obj_root_law_sections_43_footnotes:
  string
  line `1. Subs. by Act 16 of 2003, s. 28, for section 43 (w.e.f. 1-4-2003).`
  line
  line `2. Ins. by Act 18 of 2022, s. 27 (w.e.f. 1-4-2023).`
obj_root_law_sections_44:
  sectionId (33268)
  sectionNo (44)
  orderNo 95
  title `Dealings in trophy and animal articles without licence prohibited.`
  content obj_root_law_sections_44_content
  footnotes obj_root_law_sections_44_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33268&sectionno=44&orderno=95&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_44_content:
  string
  line `^1(1) Subject to the`
  line `provisions of Chapter VA, no person shall, except under and in accordance with, a licence granted under`
  line `sub-section (4)]--`
  line
  line `(a) commence or carry on the business as--`
  line
  line ^2***
  line
  line `(i) a manufacturer of or dealer In, any animal article; or`
  line
  line `(ii) a taxidermist; or`
  line
  line `(iii) a dealer in trophy or uncured trophy; or`
  line
  line `(iv) a dealer In captive animals; or`
  line
  line `(v) a dealer In meat; or`
  line
  line `(b) cook or serve meat In any eating-house:`
  line
  line `^3[(c) derive, collect or prepare or deal in snake venom;]`
  line
  line `Provided that nothing in this sub-section shall prevent a person, who, immediately before the`
  line `commencement of this Act was carrying on the business or occupation specified in this sub-section, from`
  line `carrying on such business or occupation for a period of thirty days from such commencement, or where`
  line `he has made an application within that period for the grant of a licence to him, until the licence is granted`
  line `to him or he is informed In writing that a licence cannot be granted to him:`
  line
  line `^4[Provided further that nothing in this sub-section shall apply to the dealers in tail feathers of peacock`
  line `and articles made therefrom and the manufactures of such articles.]`
  line
  line `Explanation.--For the purposes of this section, "eating-house" includes a hotel, restaurant or any`
  line `other place where any eatable is served on payment, whether or not such payment is separately made for`
  line `such eatable or is included in the amount charged for board and lodging.`
  line
  line `(2) Every manufacturer of, or dealer in, animal article, or every dealer in captive animals, trophies or`
  line `uncured trophies, or every taxidermist shall, within fifteen days from the commencement of this Act,`
  line `declare to the Chief Wild Life Warden his stocks of animals articles, captive animals, trophies and`
  line `uncured trophies, as the case may be, as on the date of such declaration and the Chief Wild Life Warden`
  line `or the Authorised officer may place an identification mark on every animal article, captive animal, trophy`
  line `or uncured trophy, as the case may be.`
  line
  line `(3) Every person referred to in sub-section (1) who intends to obtain a licence, shall make an`
  line `application to the Chief Wild Life Warden or the authorised officer for the grant of a licence.`
  line
  line `(4) (a) Every application referred to in sub-section (3) shall be made In such form and on payment of`
  line `such fee as may be prescribed, to the Chief Wild Life Warden or the authorised officer.`
  line
  line `^5[(b) No licence referred to in sub-section (1) shall be granted unless the Chief Wild Life Warden or`
  line `the authorised officer having regard to the antecedents and previous experience of the applicant, the`
  line `implication which the grant of such licence would have on the status of wild life and to such other matters`
  line `as may be prescribed in this behalf and after making such inquiry in respect of those matters as he may`
  line `think fit, is satisfied that the licence should be granted.]`
  line
  line `(5) Every licence granted under this section shall specify the premises in which and the conditions, if`
  line `any, subject to, which the licensee shall carry on his business.`
  line
  line `(6) Every licence granted under this section shall--`
  line
  line `(a) be valid for one year from the date of its grant;`
  line
  line `(b) not be transferable; and`
  line
  line `(c) be renewable for a period not exceeding one year at a time.`
  line
  line `(7) No application for the renewal of a licence shall be rejected unless the holder of such licence has`
  line `been given a reasonable opportunity of presenting his case and unless the Chief Wild Life Warden or the`
  line `authorised officer is satisfied that--`
  line
  line `(i) the application for such renewal has been made after the expiry of the period specified`
  line `therefor, or`
  line
  line `(ii) any statement made by the applicant at the time of the grant or renewal of the licence was`
  line `incorrect or false in material particulars, or`
  line
  line `(iii) the applicant has contravened any term or condition of the licence or any provision of this`
  line `Act or any rule made thereunder, or`
  line
  line `(iv) the applicant does not fulfil the prescribed conditions.`
  line
  line `(8) Every order granting or rejecting an application for the grant or renewal of a licence shall be made`
  line `in writing.`
  line
  line `(9) Nothing in the foregoing sub-sections shall apply in relation to vermin.`
obj_root_law_sections_44_footnotes:
  string
  line `1. Subs. by Act 28 of 1986, s. 2, for certain words (w.e.f. 25-11-1986).`
  line
  line `2. Sub-clause (ia) omitted by Act 44 of 1991, s. 30 (w.e.f. 2-10-1991).`
  line
  line `3. Ins. by s. 30, ibid. (w.e.f. 2-10-1991).`
  line
  line `4. Subs. by s. 30, ibid., for the second proviso (w.e.f. 2-10-1991).`
  line
  line `5. Subs. by s.3, ibid., for clause (b) (w.e.f. 21-5-1982).`
obj_root_law_sections_45:
  sectionId (33269)
  sectionNo (45)
  orderNo 96
  title `Suspension or cancellation of licences.`
  content obj_root_law_sections_45_content
  footnotes obj_root_law_sections_45_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33269&sectionno=45&orderno=96&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_45_content:
  string
  line `Subject to any general or special order of the State`
  line `Government, the Chief Wild Life Warden or the authorised officer may, for reasons to be recorded by`
  line `him in writing, suspend or cancel any licence granted or renewed under section 44:`
  line
  line `Provided that no such suspension or cancellation shall be made except after giving the holder of the`
  line `licence a reasonable opportunity of being heard.`
obj_root_law_sections_45_footnotes:
  string
  line
obj_root_law_sections_46:
  sectionId (33270)
  sectionNo (46)
  orderNo 97
  title Purchase.
  content obj_root_law_sections_46_content
  footnotes obj_root_law_sections_46_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33270&sectionno=46&orderno=97&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_46_content:
  string
  line `(1) An appeal from an order refusing to grant or renew a licence under section 44 or`
  line `an order suspending or cancelling a licence under section 45 shall lie--`
  line
  line `(a) if the order is made by the authorised officer, to the Chief Wild Life Warden; or`
  line
  line `(b) if the order is made by the Chief Wild Life Warden, to the State Government.`
  line
  line `(2) In the case of an order passed in appeal by the Chief Wild Life Warden under clause (a) of`
  line `sub-section (1), a second appeal shall lie to the State Government.`
  line
  line `(3) Subject as aforesaid, every order passed in appeal under this section shall be final.`
  line
  line `(4) An appeal under this section shall be preferred within thirty days from the date of the`
  line `communication, to the applicant, of the order appealed against:`
  line
  line `Provided that the appellate authority may admit any appeal preferred after the expiry of the period`
  line `aforesaid if it is satisfied that the appellant had sufficient cause for not preferring the appeal in time.`
obj_root_law_sections_46_footnotes:
  string
  line
obj_root_law_sections_47:
  sectionId (33271)
  sectionNo (47)
  orderNo 98
  title `Maintenance of records.`
  content obj_root_law_sections_47_content
  footnotes obj_root_law_sections_47_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33271&sectionno=47&orderno=98&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_47_content:
  string
  line `A licensee under this Chapter shall--`
  line
  line `(a) keep records, and submit such returns of his dealings, as may be prescribed,--`
  line
  line `(i) to the Director or any other officer authorised by him in this behalf, and`
  line
  line `(ii) to the Chief Wild Life Warden or the authorised officer; and`
  line
  line `(b) make such records available on demand for inspection by such officers.`
obj_root_law_sections_47_footnotes:
  string
  line
obj_root_law_sections_48:
  sectionId (33272)
  sectionNo (48)
  orderNo 99
  title `Purchase of animals, etc., by licensee.`
  content obj_root_law_sections_48_content
  footnotes `1. The words and figures "or Part II of Schedule II" omitted by Act 18 of 2022, s. 28 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33272&sectionno=48&orderno=99&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_48_content:
  string
  line `No licensee under this Chapter shall--`
  line
  line `(a) keep in his control, custody or possession,--`
  line
  line `(i) any animal, animal article, trophy or uncured trophy in respect of which a declaration`
  line `under the provisions of sub-section (2) of section 44 has to be made but has not been made;`
  line
  line `(ii) any animal or animal article, trophy, uncured trophy or meat which has not been lawfully`
  line `acquired under the provisions of this Act or any rule or order made thereunder;`
  line
  line `(b) (i) capture any wild animal, or`
  line
  line `(ii) acquire, receive keep in his control, custody or possession, or sell, offer for sale or`
  line `transport, any captive animal specified in Schedule I ^1*** or any animal article trophy, uncured`
  line `trophy or meat derived therefrom or serve such meat, or put under a process of taxidermy or make`
  line `animal article containing part or whole of such animal,`
  line
  line `except in accordance with such rules as may be made tinder this Act;`
  line
  line `Provided that where the acquisition or, possession, control or custody of such animal or animal`
  line `article, trophy or uncured trophy entails the transfer or transport from one State to another, no such`
  line `transfer or transport shall be effected except with the previous permission in writing of the Director or`
  line `any other officer authorised by him in this behalf:`
  line
  line `Provided further that no such permission under the foregoing proviso shall be granted unless the`
  line `Director or the officer authorised by him is satisfied that the animal or article aforesaid has been lawfully`
  line acquired.
obj_root_law_sections_48_a:
  sectionId (33273)
  sectionNo 48A
  orderNo 100
  title `Restriction on transportation of wild life.`
  content obj_root_law_sections_48_a_content
  footnotes `1. Ins. by Act 44 of 1991, s. 31 (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33273&sectionno=48A&orderno=100&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_48_a_content:
  string
  line `^1[48A. Restriction on transportation of wild life.-- No person shall accept any wild animal (other`
  line `than vermin), or any animal article, or any specified plant or part or derivative thereof, for transportation`
  line `except after exercising due care to ascertain that permission from the Chief Wild Life Warden or any`
  line `other officer authorised by the State Government in this behalf has been obtained for such transportation.]`
obj_root_law_sections_49:
  sectionId (33274)
  sectionNo (49)
  orderNo 101
  title `Purchase of captive animal, etc., by a person other than a licensee.`
  content obj_root_law_sections_49_content
  footnotes `1. Subs. by s. 32, ibid., for the proviso (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33274&sectionno=49&orderno=101&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_content:
  string
  line `No person shall`
  line `purchase, receive or acquire any captive animal, wild animal, other than vermin, or any animal article,`
  line `trophy, uncured trophy or meat derived therefrom otherwise than from a dealer or from a person`
  line `authorised to sell or otherwise transfer the same under this Act:`
  line
  line `^1[Provided that nothing in this section shall apply to a recognised zoo subject to the provisions of`
  line `section 38-1 or to a public museum.]`
obj_root_law_sections_49_a:
  sectionId (33275)
  sectionNo 49A
  orderNo 102
  title Definitions.
  content obj_root_law_sections_49_a_content
  footnotes obj_root_law_sections_49_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33275&sectionno=49A&orderno=102&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_a_content:
  string
  line `^1[49A. Definitions.-- In this Chapter,--`
  line
  line `(a) "Scheduled animal" means an animal specified for the time being in Schedule I or Part II of`
  line `Schedule II;`
  line
  line `(b) "Scheduled animal article" means an article made from any Scheduled animal and includes an`
  line `article or object in which the whole or any part of such animal ^2[has been used but does not include`
  line `tail feather of peacook, an article or trophy made therefrom and snake venom or its derivative.]`
  line
  line `(c) "Specified date" means--`
  line
  line `(i) in relation to a scheduled animal on the commencement of the Wild Life (Protection)`
  line `(Amendment) Act, 1986, the date of expiry of two months from such commencement; ^3***`
  line
  line `(ii) in relation to any animal added or transferred to Scheduled I or Part II of Schedule II at`
  line `any time after such commencement, the date of expiry of two months from such addition or`
  line transfer.
  line
  line `^4[(iii) in relation ivory imported into India or an article made from such ivory, the date of`
  line `expiry of six months from the commencement of the Wild Life (Protection) (Amendment) Act,`
  line `1991 (44 of 1991).]`
obj_root_law_sections_49_a_footnotes:
  string
  line `1. Ins. by Act 28 of 1986, s. 3 (w.e.f. 25-11-1986).`
  line
  line `2. Subs. by Act 44 of 1991, s. 33, for "has been used" (w.e.f. 2-10-1991).`
  line
  line `3. The word “and” omitted by s. 33, ibid. (w.e.f. 2-10-1991).`
  line
  line `4. Ins. by Act 44 of 1991, s. 33 (w.e.f. 2-10-1991).`
obj_root_law_sections_49_b:
  sectionId (33276)
  sectionNo 49B
  orderNo 103
  title `Prohibition of dealings in trophies, animal articles, etc., derived from scheduled animals.`
  content obj_root_law_sections_49_b_content
  footnotes obj_root_law_sections_49_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33276&sectionno=49B&orderno=103&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_b_content:
  string
  line `^1[49B. Prohibition of dealings in trophies, animal articles, etc., derived from scheduled`
  line `animals.-- (1) Subject to the other provisions of this Section, on and after the specified date, no person`
  line shall--
  line
  line `(a) commence or carry on the business as--`
  line
  line `(i) a manufacturer of, or dealer in, scheduled animal articles; or`
  line
  line `^2[ia) a dealer in ivory imported into India or articles made therefrom or a manufacturer of`
  line `such articles; or]`
  line
  line `(ii) a taxidermist with respect to any scheduled animals or any parts of such animals; or`
  line
  line `(iii) a dealer in trophy or uncured trophy derived from any scheduled animal; or`
  line
  line `(iv) a dealer in any captive animals being scheduled animals; or`
  line
  line `(v) a dealer in meat derived from any scheduled animal; or`
  line
  line `(b) cook or serve meat derived from any scheduled animal in any eating-house.`
  line
  line `Explanation.--For the purposes of this sub-section, "eating-house" has the same meaning as`
  line `in the Explanation below sub-section (1) of Section 44.`
  line
  line `(2) Subject to the other provisions of this section, no licence granted or renewed under Section 44`
  line `before the specified date shall entitle the holder thereof or any other person to commence or carry on the`
  line `business referred to in clause (a) of sub-section (1) of this section or the occupation referred to in`
  line `clause (b) of that sub-section after such date.`
  line
  line `(3) Notwithstanding anything contained in sub-section (1) or sub-section (2), where the Central`
  line `Government is satisfied that it is necessary or expedient so to do in the public interest, it may, by general`
  line `or special order published in the official Gazette, exempt, for purposes of export, any corporation owned`
  line `or controlled by the Central Government (including a Government company within the meaning of`
  line `section 617 of the Companies Act, 1956 (1 of 1956), or any society registered under the Societies`
  line `Registration Act, 1860 (21 of 1860), or any other law for the time being in force, wholly or substantially`
  line `financed by the Central Government, from the provisions of sub-sections (1) and (2).`
  line `(4) Notwithstanding anything contained in sub-section (1) or sub-section (2), but subject to any rules`
  line `which may be made in this behalf, a person holding a licence under Section 44 to carry on the business as`
  line `a taxidermist may put under a process of taxidermy any scheduled animal or any part thereof--`
  line
  line `(a) for or on behalf of the Government or any corporation or society exempted under`
  line `sub-section (3), or`
  line
  line `(b) with the previous authorisation in writing of the Chief Wild Life Warden, for and on behalf of`
  line `any person for educational or scientific purposes.]`
obj_root_law_sections_49_b_footnotes:
  string
  line `1. Ins. by Act 28 of 1986, s. 3 (w.e.f. 25-11-1986).`
  line
  line `2. Ins. by s. 34, ibid. (w.e.f. 2-10-1991).`
obj_root_law_sections_49_c:
  sectionId (33277)
  sectionNo 49C
  orderNo 104
  title `Declaration by dealers.`
  content obj_root_law_sections_49_c_content
  footnotes obj_root_law_sections_49_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33277&sectionno=49C&orderno=104&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_c_content:
  string
  line `^1[49C. Declaration by dealers.--(1) Every person carrying on the business or occupation referred to`
  line `in sub-section (1) of Section 49B shall, within thirty days from the specified date declare to the Chief`
  line `Wild Life Warden or the authorised officer--`
  line
  line `(a) his stocks, if any, as at the end of the specified date of--`
  line
  line `(i) scheduled animal articles;`
  line
  line `(ii) scheduled animals and parts thereof;`
  line
  line `(iii) trophies and uncured trophies derived from scheduled animals;`
  line
  line `(iv) captive animals being scheduled animals;`
  line
  line `^2[(v) ivory imported into India or articles made therefrom;]`
  line
  line `(b) the place or places at which the stocks mentioned in the declaration are kept; and`
  line
  line `(c) the description of such items, if any, the stocks mentioned in the declaration which he desires`
  line `to retain with himself for his bona fide personal use.`
  line
  line `(2) On receipt of a declaration under sub-section (1), the Chief Wild Life Warden or the authorised`
  line `officer may take all or any of the measures specified in section 41 and for this purpose, the provisions of`
  line `section 41 shall, so far as may be, apply.`
  line
  line `(3) Where, in a declaration made under sub-section (1), the person making the declaration expresses`
  line `his desire to retain with himself any of the items of the stocks specified in the declaration for his bona fide`
  line `personal use, the Chief Wild Life Warden, with the prior approval of the Director, may, if he is satisfied`
  line `that the person is in lawful possession of such items, issue certificates of ownership in favour of such`
  line `person with respect to all, or as the case may be, such of the items as in the opinion of the Chief Wild Life`
  line `Warden, are required for the bona fide personal use of such person and affix upon such items`
  line `identification marks in such manner as may be prescribed:`
  line
  line `Provided that no such item shall be kept in any commercial premises.`
  line
  line `(4) No person shall obliterate or counterfeit any identification mark referred to in sub-section (3).`
  line
  line `(5) An appeal shall lie against any refusal to grant certificate of ownership under sub-section (3) and`
  line `the provisions of sub-sections (2), (3) and (4) of section 46 shall, so far as may be, apply in relation to`
  line `appeals under this sub-section.`
  line
  line `(6) Where a person who has been issued a certificate of ownership under sub-section (3) in respect of`
  line `any item--`
  line
  line `(a) transfers such item to any person, whether by way of gift, sale or otherwise, or`
  line
  line `(b) transfers or transports from the State in which he resides to another State any such item,`
  line
  line `he shall, within thirty days of such transfer or transport, report the transfer or transport to the Chief Wild`
  line `Life Warden or the authorised officer within whose jurisdiction the transfer or transport is effected.`
  line
  line `(7) No person, other than a person who has been issued a certificate of ownership under`
  line `sub-section (3), shall on and after the specified date keep under his control, sell or offer for sale or`
  line `transfer to any person ^3[any scheduled animal, a scheduled animal article, or ivory imported into India or`
  line `any article made therefrom.]]`
obj_root_law_sections_49_c_footnotes:
  string
  line `1. Ins. by Act 28 of 1986, s. 3 (w.e.f. 25-11-1986).`
  line
  line `2. Ins. by Act 44 of 1991, s. 35 (w.e.f. 2-10-1991).`
  line `3. Subs. by s. 35, ibid., for "any scheduled animal or a scheduled animal article" (w.e.f. 2-10-1991).`
obj_root_law_sections_49_d:
  sectionId (73294)
  sectionNo 49D
  orderNo 105
  title Definitions.
  content obj_root_law_sections_49_d_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73294&sectionno=49D&orderno=105&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_d_content:
  string
  line `^1[49D. Definitions. --In this Chapter, unless the context otherwise requires,--`
  line
  line `(a) "artificially propagated" means plants which have been grown under controlled conditions`
  line `from plant materials grown under similar conditions;`
  line
  line `(b) "bred in captivity" means produced from parents in captivity;`
  line
  line `(c) "Convention" means the Convention on International Trade in Endangered Species of Wild`
  line `Fauna and Flora signed at Washington D.C., in the United States of America on the 3rd of March,`
  line `1973, and amended at Bonn on the 22nd of June, 1979, its appendices, decisions, resolutions and`
  line `notifications made thereunder and its amendments, to the extent binding on India;`
  line
  line `(d) "export" means export from India to any other country of a specimen;`
  line
  line `(e) "import" means import into India from any other country of a specimen;`
  line
  line `(f) "introduction from the sea" means transportation into India of specimens of any species which`
  line `were taken from the marine environment not under the jurisdiction of India or any other country;`
  line
  line `(g) "Management Authority" means the Management Authority designated under section 49E;`
  line
  line `(h) "readily recognisable part or derivative" includes any specimen which appears from an`
  line `accompanying document, the packaging or a mark or label, or from any other circumstances, to be a`
  line `part or derivative of an animal or plant of a species listed in Schedule IV;`
  line
  line `(i) "re-export" means export of any specimen that has previously been imported;`
  line
  line `(j) "Scientific Authority" means a Scientific Authority designated under section 49F;`
  line
  line `(k) "scheduled specimen" means any specimen of a species listed in Appendices I, II or III of the`
  line `Convention and incorporated as such in Schedule IV;`
  line
  line `(l) "species" means any species, sub-species, or geographically separate population thereof;`
  line
  line `(m) "specimen" means--`
  line
  line `(i) any animal or plant, whether alive or dead;`
  line
  line `(ii) in the case of an animal,--`
  line
  line `(A) for species included in Appendices I and II of Schedule IV, any readily recognisable`
  line `part or derivative thereof;`
  line
  line `(B) for species included in Appendix III of Schedule IV, any readily recognisable part or`
  line `derivative thereof specified in Appendix III of Schedule IV in relation to the species; and`
  line
  line `(iii) in the case of a plant,--`
  line
  line `(A) for species included in Appendix I of Schedule IV, any readily recognisable part or`
  line `derivative thereof;`
  line
  line `(B) for species included in Appendices II and III of Schedule IV, any readily recognisable`
  line `part or derivative thereof specified in Appendices II and III of Schedule IV in relation to the`
  line species;
  line
  line `(n) "trade" means export, re-export, import and introduction from the sea.]`
obj_root_law_sections_49_e:
  sectionId (73295)
  sectionNo 49E
  orderNo 106
  title `Designation of Management Authority`
  content obj_root_law_sections_49_e_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73295&sectionno=49E&orderno=106&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_e_content:
  string
  line `^1[49E. Designation of Management Authority. -- (1) The Central Government shall, by notification,`
  line `designate an officer not below the rank of an Additional Director General of Forests as the Management`
  line `Authority for discharging the functions and exercising the powers under this Act.`
  line
  line `(2) The Management Authority shall be responsible for issuance of permits and certificates for trade`
  line `of scheduled specimens in accordance with the Convention, submission of reports, and shall perform such`
  line `other functions as may be necessary to implement the provisions of the Convention.`
  line
  line `(3) The Management Authority shall prepare and submit annual and biennial reports to the Central`
  line Government.
  line
  line `(4) The Central Government may appoint such officers and employees as may be necessary to assist`
  line `the Management Authority in discharging its functions or exercising its powers under this Chapter, on`
  line `such terms and conditions of service including salaries and allowances as may be prescribed.`
  line
  line `(5) The Management Authority may, with the prior approval of the Central Government, delegate its`
  line `functions or powers, to such officers not below the rank of the Assistant Inspector General of Forests, as it`
  line `may consider necessary for the purposes of this Chapter.]`
obj_root_law_sections_49_f:
  sectionId (73296)
  sectionNo 49F
  orderNo 107
  title `Designation of Scientific Authority.`
  content obj_root_law_sections_49_f_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73296&sectionno=49F&orderno=107&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_f_content:
  string
  line `^1[49F. Designation of Scientific Authority.--(1) The Central Government shall, by notification,`
  line `designate one or more institutes engaged in research on species as Scientific Authority for the purposes of`
  line `this Chapter, for fulfilling the functions under the Convention.`
  line
  line `(2) The designated Scientific Authority shall advise the Management Authority in such matters as`
  line `may be referred to it by the Management Authority.`
  line
  line `(3) The Scientific Authority shall monitor the export permits granted for specimens of species listed`
  line `in Appendix II of Schedule IV and the actual export of such specimens.`
  line
  line `(4) Whenever a Scientific Authority is of the opinion that the export of specimens of such species`
  line `requires to be limited in order to maintain that species throughout its range at a level consistent with its`
  line `role in the ecosystems in which it occurs and well above the level at which that species might become`
  line `eligible for inclusion in Appendix I of the Convention, it shall advise the Management Authority to take`
  line `such appropriate measures to limit the grant of export permits for specimens of that species as the`
  line `Scientific Authority may deem necessary for said purpose.]`
obj_root_law_sections_49_g:
  sectionId (73297)
  sectionNo 49G
  orderNo 108
  title `Directions of Central Government.`
  content obj_root_law_sections_49_g_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73297&sectionno=49G&orderno=108&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_g_content:
  string
  line `^1[49G. Directions of Central Government. --The Management Authority and the Scientific`
  line `Authorities, shall, while performing their duties and exercising powers under this Chapter, be subject to`
  line `such general or special directions, as the Central Government may, from time to time, give.]`
obj_root_law_sections_49_h:
  sectionId (73298)
  sectionNo 49H
  orderNo 109
  title `International trade in Scheduled specimen and restriction in respect thereof`
  content obj_root_law_sections_49_h_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73298&sectionno=49H&orderno=109&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_h_content:
  string
  line `^1[49H. International trade in scheduled specimen and restriction in respect thereof.--(1) No`
  line `person shall engage in trade of scheduled specimens except as provided for under this Chapter.`
  line
  line `(2) The Central Government shall prescribe the conditions and procedures by which the exemptions`
  line `contained in Article VII of the Convention may be availed.`
  line
  line `(3) Every person engaging in trade of a scheduled specimen shall report the details of the scheduled`
  line `specimen and the transaction to the Management Authority or the officer authorised by it in such manner`
  line `as may be prescribed.`
  line
  line `(4) Every person engaging in trade of a scheduled specimen, shall present it for clearance to the`
  line `Management Authority or the officer authorised by it or a customs officer only at the ports of exit and`
  line `entry as may be specified by the Central Government.`
  line
  line `(5) The form and manner of making an application for a permit or certificate to trade in a scheduled`
  line `specimen, the fee payable therefor, the conditions subject to which the permit or certificate may be`
  line `granted, and the procedure to be followed in granting or cancelling such permit or certificate, shall be`
  line `such as may be prescribed by the Central Government.]`
obj_root_law_sections_49_i:
  sectionId (73299)
  sectionNo 49-I
  orderNo 110
  title `Conditions for scheduled specimens.`
  content obj_root_law_sections_49_i_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73299&sectionno=49-I&orderno=110&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_i_content:
  string
  line `^1[49-I. Conditions for export of scheduled specimens.--(1) The export of any specimen of species`
  line `included in Appendices I or II of Schedule IV shall require the prior grant and presentation of an export`
  line permit.
  line
  line `(2) The export of any specimen of species included in Appendix III of Schedule IV shall require the`
  line `prior grant and presentation of an export permit if the species has been listed in Appendix III of the`
  line `Convention by India or a certificate of origin in other cases.`
  line
  line `(3) An export permit shall not be granted unless--`
  line
  line `(a) the Management Authority is satisfied that the specimen concerned has not been obtained in`
  line `contravention of any law for the time being in force relating to protection of fauna and flora;`
  line
  line `(b) the Management Authority is satisfied that any living specimen will be so prepared and`
  line `shipped as to minimise the risk of injury, damage to health or cruel treatment;`
  line
  line `(c) in the case of a specimen of a species listed in Appendices I or II of Schedule IV, the`
  line `Scientific Authority has advised that the export will not be detrimental to the survival of that species;`
  line and
  line
  line `(d) in the case of specimens of species listed in Appendix I of Schedule IV, an import permit has`
  line `been granted by the competent authority of the country of destination.]`
obj_root_law_sections_49_j:
  sectionId (73300)
  sectionNo 49J
  orderNo 111
  title `Conditions for import of scheduled specimens`
  content obj_root_law_sections_49_j_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73300&sectionno=49J&orderno=111&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_j_content:
  string
  line `^1[49J. Conditions for import of scheduled specimens.-- (1) The import of any specimen of a species`
  line `included in Appendix I of Schedule IV shall require the prior grant and presentation of an import permit`
  line `and either an export permit or a re-export certificate from the country of export.`
  line
  line `(2) An import permit for a specimen of a species listed in Appendix I of Schedule IV shall not be`
  line `granted unless--`
  line
  line `(a) the Management Authority is satisfied that the specimen concerned will not be used for`
  line `primarily commercial purposes;`
  line
  line `(b) the Scientific Authority has advised that the import will be for purposes which are not`
  line `detrimental to the survival of the species; and`
  line
  line `(c) the Scientific Authority is satisfied that the proposed recipient of a living specimen is suitably`
  line `equipped to house and care for it.`
  line
  line `(3) The import of any specimen of a species included in Appendix II of Schedule IV shall require the`
  line `prior presentation of either an export permit or a re-export certificate issued by the country of export.`
  line
  line `(4) The import of any specimen of a species included in Appendix III of Schedule IV shall require the`
  line `prior presentation of--`
  line
  line `(a) a certificate of origin; or`
  line
  line `(b) in the case where the import is from a country which has included the species in Appendix III`
  line `of the Convention, an export permit; or`
  line
  line `(c) a re-export certificate granted by the country of re-export.]`
obj_root_law_sections_49_k:
  sectionId (73301)
  sectionNo 49K
  orderNo 112
  title `Conditions for re-export of scheduled specimens.`
  content obj_root_law_sections_49_k_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73301&sectionno=49K&orderno=112&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_k_content:
  string
  line `^1[49K. Conditions for re-export of scheduled specimens.--(1) The re-export of any specimen of`
  line `species included in Appendices I or II of Schedule IV shall require the prior grant and presentation of a`
  line `re-export certificate.`
  line
  line `(2) A re-export certificate shall not be granted unless--`
  line
  line `(a) the Management Authority is satisfied that any specimen to be re-exported was imported in`
  line `accordance with the provisions of this Chapter and of the Convention;`
  line
  line `(b) the Management Authority is satisfied that any living specimen will be so prepared and`
  line `shipped as to minimise the risk of injury, damage to health or cruel treatment; and`
  line
  line `(c) in the case of any living specimen of species listed in Appendix I of Schedule IV, the`
  line `Management Authority is satisfied that an import permit has been granted.]`
obj_root_law_sections_49_l:
  sectionId (73302)
  sectionNo 49L
  orderNo 113
  title `Conditions for introfuction from sea of scheduled specimens.`
  content obj_root_law_sections_49_l_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73302&sectionno=49L&orderno=113&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_l_content:
  string
  line `^1[49L. Conditions for introduction from sea of scheduled specimens.--(1) The introduction from`
  line `the sea of a specimen of a species included in Appendices I or II of Schedule IV shall require the prior`
  line `grant and presentation of a certificate of introduction from the sea.`
  line
  line `(2) A certificate of introduction from the sea shall not be granted unless--`
  line
  line `(a) the Scientific Authority has advised that the introduction of any specimen will not be`
  line `detrimental to the survival of the species;`
  line
  line `(b) in the case of a specimen of a species listed in Appendix I of Schedule IV, the`
  line `Management Authority is satisfied that it is not to be used for primarily commercial purposes and`
  line `that the proposed recipient of any living specimen is suitably equipped to house and care for it;`
  line and
  line
  line `(c) in the case of a living specimen of a species listed in Appendix II of Schedule IV, the`
  line `Management Authority is satisfied that it will be so handled as to minimise the risk of injury,`
  line `damage to health or cruel treatment.]`
obj_root_law_sections_49_m:
  sectionId (73303)
  sectionNo 49M
  orderNo 114
  title `Possession transfer and breeding of living scheduled animal species.`
  content obj_root_law_sections_49_m_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73303&sectionno=49M&orderno=114&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_m_content:
  string
  line `^1[49M. Possession, transfer and breeding of living scheduled animal species. --- (1) Every person`
  line `possessing a living specimen of an animal species listed in Schedule IV shall report the details of such`
  line `specimen or specimens in his possession to the Management Authority or the authorised officer:`
  line
  line `Provided that the Central Government may exempt one or more specimens of any animal species`
  line `included in Schedule IV from such declaration for such quantity and for such period as it may deem fit.`
  line
  line `(2) The Management Authority or the authorised officer may, on being satisfied that a person was in`
  line `possession of a living specimen of an animal species listed in Schedule IV which had not been obtained in`
  line `contravention of any law relating to protection of fauna and flora, issue a registration certificate allowing`
  line `the owner to retain such specimen.`
  line
  line `(3) Any person who transfers possession, by any means whatsoever, of any living specimen of an`
  line `animal species listed in Schedule IV shall report the details to the Management Authority or the`
  line `authorised officer.`
  line
  line `(4) The Management Authority or the authorised officer shall register all transfers of living specimens`
  line `of animal species listed in Schedule IV and issue the transferee with a registration certificate.`
  line
  line `(5) Any person in possession of any living specimen of an animal species listed in Schedule IV which`
  line `bears any offspring shall report the birth of such offspring to the Management Authority or the authorised`
  line officer.
  line
  line `(6) The Management Authority or the authorised officer shall on receipt of the report under subsection (5) register any offspring born to any living specimen of an animal species listed in Schedule IV`
  line `and issue the owner with a registration certificate.`
  line
  line `(7) Any person in possession of any living specimen of an animal species listed in Schedule IV which`
  line `dies shall report such death to the Management Authority or the authorised officer.`
  line
  line `(8) No person shall possess, transfer or breed any living specimen of any animal species listed in`
  line `Schedule IV except in conformity with this section and the rules made by the Central Government in this`
  line behalf.
  line
  line `(9) The form, manner and period for reporting possession, transfers, and births, deaths, and`
  line `registration of the same under this section shall be as prescribed by the Central Government.]`
obj_root_law_sections_49_n:
  sectionId (73304)
  sectionNo 49N
  orderNo 115
  title `Application for Licence by breeders of Appendix I species`
  content obj_root_law_sections_49_n_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73304&sectionno=49N&orderno=115&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_n_content:
  string
  line `^1[49N. Application for Licence by breeders of Appendix I species.--(1) Every person who is`
  line `engaged in breeding in captivity or artificially propagating any scheduled specimen listed in Appendix I`
  line `of Schedule IV shall make, within a period of ninety days of the commencement of the Wild Life`
  line `(Protection) Amendment Act, 2022, an application for a licence to the Chief Wild Life Warden.`
  line
  line `(2) The form and manner of the application to be made to the Chief Wild Life Warden under`
  line `sub-section (1), the fee payable, the form of licence, the procedure to be followed in granting or`
  line `cancelling the licence shall be such as may be prescribed by the Central Government.]`
obj_root_law_sections_49_o:
  sectionId (73305)
  sectionNo 49-O
  orderNo 116
  title `Licence of breeders of Appendix I species.`
  content obj_root_law_sections_49_o_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73305&sectionno=49-O&orderno=116&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_o_content:
  string
  line `^1[49-O. Licence of breeders of Appendix I species.-- (1) On receipt of application under`
  line `sub-section (1) of section 49N, the Chief Wild Life Warden shall, if--`
  line
  line `(a) the application is in the prescribed form;`
  line
  line `(b) the resolutions of the Convention relating to breeding in captivity or artificial propagation of`
  line `species listed in Appendix I of Schedule IV are satisfied; and`
  line
  line `(c) the provisions of the Act and rules made thereunder have been duly complied with,`
  line `record an entry of the statement in a register and grant the applicant a licence.`
  line
  line `(2) The Chief Wild Life Warden shall, if the provisions or resolutions of the Convention or this Act`
  line `and any rules made hereunder have not been complied with, or if a false particular is furnished, refuse or`
  line `cancel the licence as the case may be after providing the applicant with an opportunity of being heard.`
  line
  line `(3) The licence under sub-section (1) shall be issued for a period of two years and may be renewed`
  line `after two years on payment of such fee as may be prescribed.`
  line
  line `(4) Any person aggrieved by the refusal of the Chief Wild Life Warden or cancellation of licence`
  line `under sub-section (2) may prefer an appeal to the State Government within a period of sixty days in such`
  line `manner as may be prescribed.]`
obj_root_law_sections_49_p:
  sectionId (73306)
  sectionNo 49P
  orderNo 117
  title `Prohibition on alteration, etc.`
  content obj_root_law_sections_49_p_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73306&sectionno=49P&orderno=117&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_p_content:
  string
  line `^1[49P. Prohibition on alteration, etc.-- No person shall alter, deface, erase or remove a mark of`
  line `identification affixed upon the scheduled specimen or its package.]`
obj_root_law_sections_49_q:
  sectionId (73307)
  sectionNo 49Q
  orderNo 118
  title `Species and scheduled specimens to be Government property`
  content obj_root_law_sections_49_q_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73307&sectionno=49Q&orderno=118&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_q_content:
  string
  line `^1[49Q. Species and scheduled specimens to be Government property.-- (1) Every species or`
  line `scheduled specimen, in respect of which any offence against this Act or rules made thereunder has been`
  line `committed, shall become the property of the Central Government and the provisions of section 39 shall,`
  line `without prejudice to the Customs Act, 1962 (52 of 1962), apply, mutatis mutandis, in relation to species`
  line `and scheduled specimens as they apply in relation to wild animals, captive animals and animal articles.`
  line
  line `(2) Where a living specimen of a species listed in Schedule IV has been seized under this Act or the`
  line `Customs Act, 1962 (52 of 1962) or any other law for the time being in force as a result of import into`
  line `India in contravention of this Act, the Management Authority shall, after consultation with the country of`
  line `export, return the specimen to that country at the expense of that country, or ensure that it is housed and`
  line `cared for by a recognised zoo or rescue centre in case it cannot be returned to the country of export.`
  line
  line `(3) The Management Authority may for such purposes consult the Scientific Authority as it deems`
  line appropriate.]
obj_root_law_sections_49_r:
  sectionId (73308)
  sectionNo 49R
  orderNo 119
  title `Application of provisions of Act in respect of species listed in Schedule I or II and Schedule IV.`
  content obj_root_law_sections_49_r_content
  footnotes `1. Ins. by Act 18 of 2022, s. 30 (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73308&sectionno=49R&orderno=119&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_49_r_content:
  string
  line `^1[49R. Application of provisions of Act in respect of species listed in Schedule I or II and`
  line `Schedule IV. -- (1) Where the same species is listed in Schedule I or II and Schedule IV, then, the`
  line `provisions of this Act applicable to such species listed in Schedule I or II and the rules made thereunder`
  line `shall apply.`
  line
  line `(2) Nothing in sections 49M, 49N or 49-O shall apply to a species listed in Schedule I or Schedule II`
  line `if the same species is also listed in Scheduled IV.`
  line
  line `(3) The provisions of this Chapter shall be subject to the provisions of Chapters III, IIIA, IVA, V, VA`
  line `and VIA and without prejudice to anything contained therein.]`
obj_root_law_sections_50:
  sectionId (33278)
  sectionNo (50)
  orderNo 120
  title `Power of entry, search, arrest and detention.`
  content obj_root_law_sections_50_content
  footnotes obj_root_law_sections_50_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33278&sectionno=50&orderno=120&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_50_content:
  string
  line `(1) Notwithstanding anything contained in any`
  line `other law for the time being in force, the Director or any other officer authorised by him in this behalf ^1[or`
  line `the Management Authority or any officer authorised by the Management Authority] or the Chief Wild`
  line `Life Warden or the authorised officer or any forest officer or any police officer not below the rank of a`
  line `sub- inspector ^2[or any customs officer not below the rank of an inspector or any officer of the coast guard`
  line `not below the rank of an Assistant Commandant], may, if he has reasonable grounds for believing that`
  line `any person has committed an offence against this Act,--`
  line
  line `(a) require any such person to produce for inspection any captive animal, wild animal, animal`
  line `article, meat, trophy or ^3[trophy, uncured trophy, specified plant or part or derivative thereof ^4[or scheduled specimen]] in his control, custody or possession, or any licence, permit or other`
  line `document granted to him or required to be kept by him under the provisions of this Act;`
  line
  line `(b) stop any vehicle or vessel in order to conduct search or inquiry or enter upon and search any`
  line `premises, land, vehicle or vessel, in the occupation of such person, and open and search any baggage`
  line `or other things in his possession;`
  line
  line `^5[(c) seize any captive animal, wild animal, animal article, meat, trophy or uncured trophy, or any`
  line `specified plant or part or derivative thereof, in respect of which an offence against this Act appears to`
  line `have been committed, in the possession of any person together with any trap, tool, vehicle, vessel or`
  line `weapon used for committing any such offence and, unless he is satisfied that such person will appear`
  line `and answer any charge which may be preferred against him, arrest him without warrant, anddetain`
  line `him:`
  line
  line `Provided that where a fisherman, residing within ten kilometres of a sanctuary or National Park,`
  line `inadvertently enters on a boat, not used for commercial fishing, in the territorial waters in that`
  line `sanctuary or National Park, a fishing tackle or net on such boat shall not be seized.]`
  line
  line `^6* * * * *`
  line
  line `(3) It shall be lawful for any of the officers referred to in sub-section (1) to stop and detainany person,`
  line `whom he sees doing any act for which a licence or permit is required under the provisions of this Act, for`
  line `the purposes of requiring such person to produce the licence or permit and if such person fails to produce`
  line `the licence or permit, as the case may be, he may be arrested without warrant, unless he furnishes his`
  line `name and address, and otherwise satisfies the officer arresting him that he will duly answer any summons`
  line `or other proceedings which may be taken against him.`
  line
  line `^7[(3A) Any officer of a rank not inferior to that of an Assistant Director of Wild Life Preservation or`
  line `^8[an Assistant Conservator of Forests who, or whose subordinate, has seized any captive animal or wild`
  line `animal under clause (c) of sub-section (1) may give the same for custody on the execution by any person`
  line `of a bond for the production of such animal if and when so required, before the Magistrate having`
  line `jurisdiction to try the offence on account of which the seizure has been made.]`
  line
  line `(4) Any person detained, or things seized under the foregoing power, shall forthwith be taken before a`
  line `Magistrate to be dealt with according to law ^6[under intimation to the Chief Wild Life Warden or the`
  line `officer authorised by him in this regard.]`
  line
  line `(5) Any person who, without reasonable cause, fails to produce anything, which he is required to`
  line `produce under this section, shall be guilty of an offence against this Act.`
  line
  line `^9[(6) Where any meat, uncured trophy, specified plant or part or derivative thereof is seized under the`
  line `provisions of this section, the Assistant Director of Wild Life Preservation or any other officer of a`
  line `gazetted rank authorised by him in this behalf or the Chief Wild Life Warden or the authorised officer`
  line `may arrange for the disposal of the same in such manner as may be prescribed.]`
  line
  line `(7) Whenever any person is approached by any of the officers referred to in sub-section (1) for`
  line `assistance in the prevention or detection of an offence against this Act, or in apprehending persons`
  line `charged with the violation of this Act, or for seizure in accordance with clause (c) of sub-section (1), it`
  line `shall be the duty of such person or persons to render such assistance.`
  line
  line `^10[(8) Notwithstanding anything contained in any other law for the time being in force, any officer not`
  line `below the rank of an Assistant Director of Wild Life Preservation[ or ^11[an officer not below the rank of`
  line `Assistant Conservator of Forests authorised by the State Government in this behalf] shall have the`
  line `powers, for purposes of making investigation into any offence against any provision of this Act--`
  line
  line `(a) to issue a search warrant;`
  line
  line `(b) to enforce the attendance of witnesses;`
  line
  line `(c) to compel the discovery and production of documents and material objects; and`
  line
  line `(d) to receive and record evidence.`
  line
  line `(9) Any evidence recorded under clause (d) of sub-section (8) shall be admissible in any subsequent`
  line `trial before a Magistrate provided that it has been taken in the presence of the accused person.]`
obj_root_law_sections_50_footnotes:
  string
  line `1. Ins. by Act 18 of 2022, s. 31 (w.e.f. 1-4-2023).`
  line
  line `2. Ins. by s. 31, ibid. (w.e.f. 1-4-2023).`
  line
  line `3. Subs. by s. 36, ibid., for "trophy or uncured trophy" (w.e.f. 2-10-1991).`
  line
  line `4. Ins. by Act 18 of 2022, s. 31 (w.e.f. 1-4-2023).`
  line
  line `5. Subs. by Act 44 of 1991, s. 36, for clause (c) (w.e.f. 2-10-1991).`
  line
  line `6. Sub-section (2) omitted by s. 36, ibid (w.e.f. 2-10-1991).`
  line
  line `7. Ins. by s. 36, ibid. (w.e.f. 2-10-1991).`
  line
  line `8. Subs. by Act 16 of 2003, s. 29, for "Wild Life Warden," (w.e.f. 1-4-2003).`
  line
  line `9. Ins. by s. 29, ibid. (w.e.f. 1-4-2003).`
  line
  line `10. Subs. by s. 29, ibid., for sub-section (6) (w.e.f. 1-4-2003).`
  line
  line `11. Ins. by Act 44 of 1991 s. 36 (w.e.f. 2-10-1991).`
obj_root_law_sections_51:
  sectionId (33279)
  sectionNo (51)
  orderNo 121
  title Penalties.
  content obj_root_law_sections_51_content
  footnotes obj_root_law_sections_51_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33279&sectionno=51&orderno=121&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_51_content:
  string
  line `(1) Any person who ^1[contravenes any provision of this Act ^2[(except Chapter VA`
  line `and section 38J)]]or any rule or order made thereunder or who commits a breach of any of the conditions`
  line `of any licence or permit granted under this Act, shall be guilty of an offence against this Act, and shall, on`
  line `conviction, be punishable with imprisonment for a term which may extend to ^3[three years], or with fine`
  line `which may extend to ^4[one lakh rupees], or with both:`
  line
  line `^5[Provided that where the offence committed is in relation to any animal specified in Schedule I`
  line `^6*** or meat of any such animal or animal article, trophy or uncured trophy derived from such animal or`
  line `where the offence relates to hunting in a sanctuary or a National Park or altering the boundaries of a`
  line `sanctuary or a National Park ^7[or where the offence relates to a specimen of a species listed on Appendix I`
  line `of Schedule IV], such offence shall be punishable with imprisonment for a term which shall not be less`
  line `than three years but may extend to seven years and also with fine which shall not be less than ^8[twentyfive thousand rupees]:`
  line
  line `Provided further that in the case of a second or subsequent offence of the nature mentioned in this`
  line `sub-section, the term of the imprisonment shall not be less than three years but may extend to seven years`
  line `and also with fine which shall not be less than ^9[one lakh rupees].]`
  line
  line `^10[(1A) Any person who contravenes any provisions of Chapter VA, shall be punishable with`
  line `imprisonment for a term which shall not be less than ^11[three years] but which may extend to seven years`
  line `and also with fine which shall not be less than ^12[twenty-five thousand rupees].]`
  line
  line `^13[(1B) Any person who contravenes the provisions of section 38J, shall be punishable with`
  line `imprisonment for a term which may extend to six months, or with fine which may extend to two thousand`
  line `rupees, or with both:`
  line
  line `Provided that in the case of a second or subsequent offence the term of imprisonment may extend to`
  line `one year or the fine may extend to five thousand rupees.]`
  line
  line `(2) When any person is convicted of an offence against this Act, the Court trying the offence may`
  line `order that any captive animal, wild animal, animal article, trophy,^14[uncured trophy, meat, ivory imported`
  line `into India or an article made from such ivory, any specified plant, or part or derivative thereof] in respect`
  line `of which the offence has been committed, and any trap, tool, vehicle, vessel or weapon, used in the`
  line `commission of the said offence be forfeited to the State Government and that any licence or permit, held`
  line `by such person under the provisions of this Act, be cancelled.`
  line
  line `(3) Such cancellation of licence or permit or such forfeiture shall be in addition to any other`
  line `punishment that may be awarded for such offence.`
  line
  line `(4) Where any person is convicted of an offence against this Act, the Court may direct that the`
  line `licence, if any, granted to such person under the Arms Act, 1959 (54 of 1959), for possession of any arm`
  line `with which an offence against this Act has been committed, shall be cancelled and that such person shall`
  line `not be eligible for a licence under the Arms Act, 1959, for a period of five years from the date of`
  line conviction.
  line
  line `^15[(5) Nothing contained in section 360 of the Code of Criminal Procedure, 1973 (2 of 1974), or in the`
  line `Probation of Offenders Act, 1958 (20 of 1958), shall apply to a person convicted of an offence with`
  line `respect to hunting in a sanctuary or a National Park or of an offence against any provision of Chapter VA`
  line `unless such person is under eighteen years of age.]`
  line
  line `STATE AMENDMENT`
  line
  line Assam
  line
  line `Amendment of section 51.--In the principal Act, in section 51, in sub-section (1),`
  line
  line `(i) in the first proviso,--`
  line
  line `(a) in between the words "hunting in" and "a sanctuary" the words "or outside the boundary of" shall be inserted;`
  line
  line `(b) for the words "three years", "seven years" and "ten thousand", the words"`
  line `seven years", "ten years" and "fifty thousand" respectively shall be substituted.`
  line
  line `(ii) in the second proviso, for the words "three years", "seven years" and "twenty five thousand", the words "ten years", "life imprisonment" and "seventy five thousand" respectively, shall be substituted.`
  line
  line `[Vide Assam Act 31 of 2010, s. 2].`
obj_root_law_sections_51_footnotes:
  string
  line `1. Subs. by Act 28 of 1986, s. 4, for "contravenes any provision of this Act" (w.e.f. 25-11-1986).`
  line
  line `2. Subs. by Act 44 of 1991, s. 37, ibid., for "(except Chapter VA)" (w.e.f. 2-10-1991).`
  line
  line `3. Subs. by s. 37, ibid., for "two years" (w.e.f. 2-10-1991).`
  line
  line `4. Subs. by Act 18 of 2022, s. 32, for "twenty-five thousand rupees" (w.e.f. 1-4-2023), earlier subs. by s. 37, Act 44 of 1991, for`
  line `"two thousand rupees" (w.e.f. 2-10-1991).`
  line
  line `5. Subs. by Act 16 of 2003, s. 30, for the first and second provisos (w.e.f. 1-4-2003).`
  line
  line `6. The words and figures "or Part II of Schedule II" omitted by Act 18 of 2022, s. 32 (w.e.f. 1-4-2023).`
  line
  line `7. Ins. by Act 18 of 2022, s. 32, ibid. (w.e.f. 1-4-2023).`
  line
  line `8. Subs. by s. 32, ibid., for "ten thousand rupees" (w.e.f. 1-4-2023).`
  line
  line `9. Subs. by s. 32, ibid., for "twenty-five thousand rupees" (w.e.f. 1-4-2023).`
  line
  line `10. Ins. by Act 28 of 1986, s. 4 (w.e.f. 25-11-1986).`
  line
  line `11. Subs. by Act 16 of 2003, s. 30, for "one year" (w.e.f. 1-4-2003).`
  line
  line `12. Subs. by s. 30, ibid., for "five thousand rupees" (w.e.f. 1-4-2003).`
  line
  line `13. Ins. by Act 44 of 1991, s. 37 (w.e.f. 2-10-1991).`
  line
  line `14. Subs. by s. 37,ibid., for "uncured trophy or meat" (w.e.f. 2-10-1991).`
  line
  line `15. Ins. by Act 44 of 1991, s. 37. (w.e.f. 2-10-1991).`
obj_root_law_sections_51_a:
  sectionId (33280)
  sectionNo 51A
  orderNo 122
  title `Certain conditions to apply while granting bail.`
  content obj_root_law_sections_51_a_content
  footnotes obj_root_law_sections_51_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33280&sectionno=51A&orderno=122&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_51_a_content:
  string
  line `^1[51A. Certain conditions to apply while granting bail.--When any person accused of, the`
  line `commission of any offence relating to Schedule I ^2*** or offences relating to hunting inside the`
  line `boundaries of National Park or wild life sanctuary or altering the boundaries of such parks and`
  line `sanctuaries, is arrested under the provisions of the Act, then notwithstanding anything contained in the`
  line `Code of Criminal Procedure, 1973 (2 of 1974) no such person who had been previously convicted of an`
  line `offence under this Act shall, be released on bail unless--`
  line
  line `(a) the Public Prosecutor has been given an opportunity of opposing the release on bail; and`
  line
  line `(b) where the Public Prosecutor opposes the application, the Court is satisfied that there are`
  line `reasonable grounds for believing that he is not guilty of such offence and that he is not likely to`
  line `commit any offence while on bail.]`
  line
  line `STATE AMENDMENT`
  line
  line Assam
  line
  line `Insertion of section 51B.--In the principal Act, after section 51A, the following new section 51B shall be inserted, namely:--`
  line
  line `51B. Offences to be cognizable, non bailabale and triable by the Court of Sessions.--(1) Every offence punishable under this Act shall be congnizable and non-bailable within the meaning of the Code of Criminal Procedure, 1973.`
  line
  line `(2) Notwithstanding anything contained in the Code of Criminal Procedure, 1973, no person accused of an offence punishable under this Act, shall be released on bail unless--`
  line
  line `(a) the Public Prosecutor has been given an opportunity to oppose the application for such release; and`
  line
  line `(b) where the Public Prosecutor opposes the application, the court is satisfied that there are reasonable grounds for believing that the accused is not likely to commit any offence while on bail.`
  line
  line `(3) The offences under this Act, shall be triable by the Court of Sessions of the respective jurisdiction.`
  line
  line `[Vide Assam Act 31 of 2010, s. 3].`
obj_root_law_sections_51_a_footnotes:
  string
  line `1. Ins. by Act 16 of 2003, s. 31 (w.e.f. 1-4-2003).`
  line
  line `2. The words and figures "or Part II of Schedule II" omitted by Act 18 of 2022, s. 33 (w.e.f. 1-4-2023).`
obj_root_law_sections_52:
  sectionId (33281)
  sectionNo (52)
  orderNo 123
  title `Attempts and abetment.`
  content obj_root_law_sections_52_content
  footnotes obj_root_law_sections_52_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33281&sectionno=52&orderno=123&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_52_content:
  string
  line `Whoever attempts to contravene, or abets the contravention of, any of`
  line `the provisions of this Act or of any rule or order made thereunder shall be deemed to have contravened`
  line `that provision or rule or order, as the case may be.`
obj_root_law_sections_52_footnotes:
  string
  line
obj_root_law_sections_53:
  sectionId (33282)
  sectionNo (53)
  orderNo 124
  title `Punishment for wrongful seizure.`
  content obj_root_law_sections_53_content
  footnotes obj_root_law_sections_53_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33282&sectionno=53&orderno=124&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_53_content:
  string
  line `If any person, exercising powers under this Act, vexatiously`
  line `and unnecessarily seizes the property of any other person on the pretence of seizing it for the reasons`
  line `mentioned in section 50 he shall, on conviction, be punishable with imprisonment for a term which may`
  line `extend to six months, or with fine which may extend to five hundred rupees, or with both.`
obj_root_law_sections_53_footnotes:
  string
  line
obj_root_law_sections_54:
  sectionId (42842)
  sectionNo (54)
  orderNo 125
  title `Power to compound offences.`
  content obj_root_law_sections_54_content
  footnotes obj_root_law_sections_54_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=42842&sectionno=54&orderno=125&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_54_content:
  string
  line `^1[54. Power to compound offence.-- (1) The Central Government may, by notification, empower the`
  line `Director of Wild Life Preservation or any other officer not below the rank of Assistant Director of Wild`
  line `Life Preservation and in the case of a State Government in the similar manner, empower the Chief Wild`
  line `Life Warden or any officer of a rank not below the rank of a Deputy Conservator of Forests, to accept`
  line `from any person against whom a reasonable suspicion exists that he has committed an offence against this`
  line `Act, payment of a sum of money by way of composition of the offence which such person is suspected to`
  line `have committed.`
  line
  line `(2) On payment of such sum of money to such officer, the suspected person, if in custody, shall be`
  line `discharged and no further proceedings in respect of the offence shall be taken against such person.`
  line
  line `(3) The officer compounding any offence may order the cancellation of any licence or permit granted`
  line `under this Act to the offender, or if not empowered to do so, may approach an officer so empowered, for`
  line `the cancellation of such licence or permit.`
  line
  line `(4) The sum of money accepted or agreed to be accepted as composition under sub-section (1) shall,`
  line `in no case, exceed the sum of ^2[five lakh rupees]:`
  line
  line `Provided that no offence, for which a minimum period of imprisonment has been prescribed in`
  line `section 51, shall be compounded.]`
obj_root_law_sections_54_footnotes:
  string
  line `1. Subs. by s. 32, ibid., for section 54 (w.e.f. 1-4-2003).`
  line
  line `2. Subs. by Act 18 of 2022, s. 34, for "twenty-five thousand rupees" (w.e.f. 1-4-2023).`
obj_root_law_sections_55:
  sectionId (33284)
  sectionNo (55)
  orderNo 126
  title `Cognizance of offences.`
  content obj_root_law_sections_55_content
  footnotes obj_root_law_sections_55_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33284&sectionno=55&orderno=126&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_55_content:
  string
  line `^1[55. Cognizance of offences.-- No court shall take cognizance of any offence against this Act on the`
  line `complaint of any person other than--`
  line
  line `(a) the Director of Wild Life Preservation or any other officer authorised in this behalf by the`
  line `Central Government; or`
  line
  line `^2[(aa) the Member-Secretary, Central Zoo Authority in matters relating to violation of the`
  line `provisions of Chapter IVA; or]`
  line
  line `^3[(ab) Member-Secretary, Tiger Conservation Authority; or]`
  line
  line `(ac) Director of the concerned tiger reserve; or`
  line
  line `^4[(ad) the Management Authority or any officer, including an officer of the Wild Life Crime`
  line `Control Bureau, authorised in this behalf by the Central Government; or]`
  line
  line `(b) the Chief Wild Life Warden, or any other officer authorised in this behalf by the State`
  line `Government ^5[subject to such conditions as may be specified by that Government]; or`
  line
  line `^5[(bb) the officer-in-charge of the zoo in respect of violation of provisions of section 38J; or]`
  line
  line `(c) any person who has given notice of not less than sixty days, in the manner prescribed, of the`
  line `alleged offence and of his intention to make a complaint, to the Central Government or the State`
  line `Government or the officer authorised as aforesaid.].`
  line
  line `(b) the Chief Wild Life Warden, or any other officer authorised in this behalf by the State`
  line `Government ^6[subject to such conditions as may be specified by that Government]; or`
  line
  line `^7[(bb) the officer-in-charge of the zoo in respect of violation of provisions of section 38J; or]`
  line
  line `(c) any person who has given notice of not less than sixty days, in the manner prescribed, of the`
  line `alleged offence and of his intention to make a complaint, to the Central Government or the State`
  line `Government or the officer authorised as aforesaid.]`
obj_root_law_sections_55_footnotes:
  string
  line `1. Subs. by Act 44 of 1991, s. 39, for section 55 (w.e.f. 2-10-1991).`
  line
  line `2. Ins. by Act 16 of 2003, s. 33 (w.e.f. 1-4-2003).`
  line
  line `3. Ins. by Act 39 of 2006, s. 4 (w.e.f. 4-9-2006).`
  line
  line `4. Ins. by Act 18 of 2022, s. 35 (w.e.f. 1-4-2023).`
  line
  line `5. Ins. by Act 16 of 2003, s. 33 (w.e.f. 1-4-2003).`
  line
  line `7. Ins. by Act 16 of 2003, s. 33 (w.e.f. 1-4-2003).`
obj_root_law_sections_56:
  sectionId (33285)
  sectionNo (56)
  orderNo 127
  title `Operation of other laws not barred.`
  content obj_root_law_sections_56_content
  footnotes obj_root_law_sections_56_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33285&sectionno=56&orderno=127&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_56_content:
  string
  line `Nothing in this Act shall be deemed to prevent any`
  line `person from being prosecuted under any other law for the time being in force, for any act or omission`
  line `which constitutes an offence against this Act or from being liable under such other law to any higher`
  line `punishment or penalty than that provided by this Act: Provided that no person shall be punished twice for`
  line `the same offence.`
obj_root_law_sections_56_footnotes:
  string
  line
obj_root_law_sections_57:
  sectionId (33286)
  sectionNo (57)
  orderNo 128
  title `Presumption to be made in certain cases.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33286&sectionno=57&orderno=128&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_57_content:
  string
  line `Where, in any prosecution for an offence against`
  line `this Act, it is established that a person is in possession, custody or control of any ^1[wild animal, captive`
  line `animal], animal article, meat, ^1[trophy, uncured trophy, specified plant, or part or derivative thereof ^2[or`
  line `scheduled specimen]] it shall be presumed, until the contrary is proved, the burden of proving which shall`
  line `lie on the accused, that such person is in unlawful possession, custody or control of such ^1[wild animal,`
  line `captive animal], animal article, meat, ^2[trophy, uncured trophy, specified plant, or part or derivative`
  line `thereof ^3[or scheduled specimen].]`
obj_root_law_sections_57_footnotes:
  string
  line `1. Subs. by Act 18 of 2022, s. 36, for "captive animal" (w.e.f. 1-4-2023).`
  line
  line `2. Subs. by Act 44 of 1991, s. 40, for "trophy or uncured trophy" (w.e.f. 2-10-1991).`
  line
  line `3. Ins. by Act 18 of 2022, s. 36 (w.e.f. 1-4-2023).`
obj_root_law_sections_58:
  sectionId (33287)
  sectionNo (58)
  orderNo 129
  title `Offences by Companies.`
  content obj_root_law_sections_58_content
  footnotes obj_root_law_sections_58_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33287&sectionno=58&orderno=129&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_content:
  string
  line `(1) Where an offence against this Act has been committed by a`
  line `company, every person who, at the time the offence was committed, was in charge of, and was`
  line `responsible to, the company for the conduct of the business of the company as well as the company, shall`
  line `be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he exercised all`
  line `due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where an offence against this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall also be deemed to be guilty`
  line `of that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section,--`
  line
  line `(a) "company" means any body corporate and includes a firm or other association of individuals;`
  line and
  line
  line `(b) "director", in relation to a firm, means a partner in the firm.`
obj_root_law_sections_58_footnotes:
  string
  line
obj_root_law_sections_58_a:
  sectionId (33288)
  sectionNo 58A
  orderNo 130
  title Application.
  content obj_root_law_sections_58_a_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33288&sectionno=58A&orderno=130&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_a_content:
  string
  line `^1[58A. Application.-- The provisions of this Chapter shall apply only to the following persons,`
  line `namely:--`
  line
  line `(a) every person who has been convicted of an offence punishable under this Act with`
  line `imprisonment for a term of three years or more;`
  line
  line `(b) every associate of a person referred to in clause (a);`
  line
  line `(c) any holder (hereafter in this clause referred to as the present holder) of any property which`
  line `was at any time previously held by a person referred to in clause (a) or clause (b) unless the present`
  line `holder or, as the case may be, any one who held such property after such person and before the`
  line `present holder, is or was a transferee in good faith for adequate consideration.]`
obj_root_law_sections_58_b:
  sectionId (33289)
  sectionNo 58B
  orderNo 131
  title Definitions.
  content obj_root_law_sections_58_b_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33289&sectionno=58B&orderno=131&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_b_content:
  string
  line `^1[58B. Definitions.-- In this Chapter, unless the context otherwise requires,--`
  line
  line `(a) "Appellate Tribunal" means the Appellate Tribunal for Forfeited Property constituted under`
  line `section 58N;`
  line
  line `(b) "associate" in relation to a person whose property is liable to be forfeited under this Chapter,`
  line includes--
  line
  line `(i) any individual who had been or is managing the affairs or keeping the accounts of such`
  line person;
  line
  line `(ii) any association of persons, body of individuals, partnership firm or private company`
  line `within the meaning of the Companies Act, 1956 (1 of 1956) of which such person had been or is a`
  line `member, partner or director;`
  line
  line `(iii) any individual who had been or is a member, partner or director of an association of`
  line `persons, body of individuals, partnership firm or private company referred to in sub-clause (ii) at`
  line `any time when such person had been or is a member, partner or director of such association,`
  line `body, partnership firm or private company;`
  line
  line `(iv) any person, who had been or is managing the affairs, or keeping the accounts of any`
  line `association of persons, body of individuals, partnership firm or private company referred to in`
  line `sub-clause (iii);`
  line
  line `(v) the trustee of any trust, where,--`
  line
  line `(1) the trust has been created by such person; or`
  line
  line `(2) the value of the assets contributed by such person (including the value of the assets, if`
  line `any, contributed by him earlier) to the trust amounts on the date on which contribution is`
  line `made, to not less than twenty per cent. of the value of the assets of the trust on that date;`
  line
  line `(vi) where the competent authority, for reasons to be recorded in writing, considers that any`
  line `properties of such person are held on his behalf by any other person, such other person;`
  line
  line `(c) "competent authority" means an officer authorised under section 58D;`
  line
  line `(d) "concealment" means the concealment or disguise of the nature, source, disposition,`
  line `movement or ownership of property and includes the movement or conversion of such property by`
  line `electronic transmission or by any other means;`
  line
  line `(e) "freezing" means temporarily prohibiting the transfer, conversion, disposition or movement of`
  line `property by an order issued under section 58F;`
  line
  line `(f) "identifying" includes establishment of proof that the property was derived from, or used in,`
  line `the illegal hunting and trade of wild life and its products;`
  line
  line `(g) "illegally acquired property" in relation to any person to whom this Chapter applies, means,--`
  line
  line `(i) any property acquired by such person, wholly or partly out of or by means of any income,`
  line `earnings or assets derived or obtained from or attributable to illegal hunting and trade of wild life`
  line `and its products and derivatives;`
  line
  line `(ii) any property acquired by such person, for a consideration or by any means, wholly or`
  line `partly traceable to any property referred to in sub-clause (i) or the income or earning from such`
  line property,
  line `and includes--`
  line
  line `(A) any property held by such person which would have been, in relation to any previous`
  line `holder thereof, illegally acquired property under this clause if such previous holder had not`
  line `ceased to hold it, unless such person or any other person who held the property at any time after`
  line `such previous holder or, where there are two or more such previous holders, the last of such`
  line `previous holders is or was a transferee in good faith for adequate consideration;`
  line
  line `(B) any property acquired by such person, for a consideration, or by any means, wholly or`
  line `partly traceable to any property falling under item (A), or the income or earnings therefrom;`
  line
  line `(h) "property" means property and assets of every description, whether corporeal or incorporeal,`
  line `movable or immovable, tangible or intangible and deeds and instruments evidencing title to, or`
  line `interest in, such property or assets, derived from the illegal hunting and trade of wild life and its`
  line products;
  line
  line `(i) "relative" means--`
  line
  line `(1) spouse of the person;`
  line
  line `(2) brother or sister of the person;`
  line
  line `(3) brother or sister of the spouse of the person;`
  line
  line `(4) any lineal ascendant or descendant of the person;`
  line
  line `(5) any lineal ascendant or descendant of the spouse of the person;`
  line
  line `(6) spouse of a person referred to in sub-clause (2), sub-clause (3), sub-clause (4) or`
  line `sub-clause (5);`
  line
  line `(7) any lineal descendant of a person referred to in sub-clause (2) or sub-clause (3);`
  line
  line `(j) "tracing" means determining the nature, source, disposition, movement, title or ownership of`
  line property;
  line
  line `(k) "trust" includes any other legal obligation.]`
obj_root_law_sections_58_c:
  sectionId (33290)
  sectionNo 58C
  orderNo 132
  title `Prohibition of holding illegally acquired property.`
  content obj_root_law_sections_58_c_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33290&sectionno=58C&orderno=132&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_c_content:
  string
  line `^1[58C. Prohibition of holding illegally acquired property. -- (1) From the date of commencement of`
  line `this Chapter, it shall not be lawful for any person to whom this Chapter applies to hold any illegally`
  line `acquired property either by himself or through any other person on his behalf.`
  line
  line `(2) Where any person holds such property in contravention of the provisions of sub-section (1), such`
  line `property shall be liable to be forfeited to the State Government concerned in accordance with the`
  line `provisions of this Chapter:`
  line
  line `Provided that no property shall be forfeited under this Chapter if such property was acquired by a`
  line `person to whom this Act applies before a period of six years from the date on which he was charged for`
  line `an offence relating to illegal hunting and trade of wild life and its products.]`
obj_root_law_sections_58_d:
  sectionId (33291)
  sectionNo 58D
  orderNo 133
  title `Competent authority.`
  content obj_root_law_sections_58_d_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33291&sectionno=58D&orderno=133&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_d_content:
  string
  line `^1[58D. Competent authority.-- The State Government may, by order published in the Official Gazette,`
  line `authorise any officer not below the rank of Chief Conservator of Forests to perform the functions of the`
  line `competent authority under this Chapter in respect of such persons or classes of persons as the State`
  line `Government may, direct].`
obj_root_law_sections_58_e:
  sectionId (33292)
  sectionNo 58E
  orderNo 134
  title `Identifying illegally acquired property.`
  content obj_root_law_sections_58_e_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33292&sectionno=58E&orderno=134&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_e_content:
  string
  line `^1[58E. Identifying illegally acquired property.-- (1) An officer not below the rank of Deputy`
  line `Inspector General of Police duly authorised by the Central Government or as the case may be, the State`
  line `Government, shall, on receipt of a complaint from the competent authority about any person having`
  line `illegally acquired property, proceed to take all steps necessary for tracing and identifying any property`
  line `illegally acquired by such person.`
  line
  line `(2) The steps referred to in sub-section (1) may include any inquiry, investigation or survey in respect`
  line `of any person, place, property, assets, documents, books of account in any bank or financial institution or`
  line `any other relevant step as may be necessary.`
  line
  line `(3) Any inquiry, investigation or survey referred to in sub-section (2) shall be carried out by an officer`
  line `mentioned in sub-section (1) in accordance with such directions or guidelines as the competent authority`
  line `may make or issue in this behalf.]`
obj_root_law_sections_58_f:
  sectionId (33293)
  sectionNo 58F
  orderNo 135
  title `Seizure or freezing of illegally acquired property.`
  content obj_root_law_sections_58_f_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33293&sectionno=58F&orderno=135&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_f_content:
  string
  line `^1[58F. Seizure or freezing of illegally acquired property.-- (1) Where any officer conducting an`
  line `inquiry or investigation under section 58E has reason to believe that any property in relation to which`
  line `such inquiry or investigation is being conducted is an illegally acquired property and such property is`
  line `likely to be concealed, transferred or dealt with in any manner which may result in frustrating any`
  line `proceeding relating to forfeiture of such property under this Chapter, he may make an order for seizing`
  line `such property and where it is not practicable to seize such property, he may make an order that such`
  line `property shall not be transferred or otherwise dealt with, except with the prior permission of the officer`
  line `making such order, or of the competent authority and a copy of such order shall be served on the person`
  line `concerned:`
  line
  line `Provided that a copy of such an order shall be sent to the competent authority within forty-eight hours`
  line `of its being made.`
  line
  line `(2) Any order made under sub-section (1) shall have no effect unless the said order is confirmed by an`
  line `order of the competent authority within a period of thirty days of its being made.`
  line
  line `Explanation.-- For the purposes of this section, "transfer of property" means any disposition,`
  line `conveyance, assignment, settlement, delivery, payment or other alienation of property and, without`
  line `limiting the generality of the foregoing, includes--`
  line
  line `(a) the creation of a trust in property;`
  line
  line `(b) the grant or creation of any lease, mortgage, charge, easement, licence, power, partnership or`
  line `interest in property;`
  line
  line `(c) the exercise of a power of appointment, of property vested in any person not the owner of the`
  line `property, to determine its disposition in favour of any person other than the donee of the power; and`
  line
  line `(d) any transaction entered into by any person with intent thereby to diminish directly or`
  line `indirectly the value of his own property and to increase the value of the property of any other person.]`
obj_root_law_sections_58_g:
  sectionId (33294)
  sectionNo 58G
  orderNo 136
  title `Management of properties seized or forfeited under this Chapter.`
  content obj_root_law_sections_58_g_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33294&sectionno=58G&orderno=136&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_g_content:
  string
  line `^1[58G. Management of properties seized or forfeited under this Chapter.-- (1) The State`
  line `Government may, by order published in the Official Gazette, appoint as many of its officers (not below`
  line `the rank of Conservator of Forests) as it thinks fit, to perform the functions of an Administrator.`
  line
  line `(2) The Administrator appointed under sub-section (1) shall receive and manage the property in`
  line `relation to which an order has been made under sub-section (1) of section 58F or under section 58-I in`
  line `such manner and subject to such conditions as may be prescribed.`
  line
  line `(3) The Administrator shall also take such measures as the State Government may direct, to dispose`
  line `of the property which is forfeited to the State Government.]`
obj_root_law_sections_58_h:
  sectionId (33295)
  sectionNo 58H
  orderNo 137
  title `Notice of forfeiture of property.`
  content obj_root_law_sections_58_h_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33295&sectionno=58H&orderno=137&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_h_content:
  string
  line `^1[58H. Notice of forfeiture of property.-- (1) If having regard to the value of the properties held by`
  line `any person to whom this Chapter applies, either by himself or through any other person on his behalf, his`
  line `known sources of income, earnings or assets, and any other information or material available to it as a`
  line `result of a report from any officer making an investigation under section 58E or otherwise, the competent`
  line `authority for reasons to be recorded in writing believes that all or any of such properties are illegally`
  line `acquired properties, it may serve a notice upon such person (hereinafter referred to as the person affected)`
  line `calling upon him within a period of thirty days specified in the notice to show cause why all or any of`
  line `such properties, as the case may be, should not be declared to be illegally acquired properties and`
  line `forfeited to the State Government under this Chapter and in support of his case indicate the sources of his`
  line `income, earnings or assets, out of which or by means of which he has acquired such property, the`
  line `evidence on which he relies and other relevant information and particulars.`
  line
  line `(2) Where a notice under sub-section (1) to any person specifies any property as being held on behalf`
  line `of such person by any other person, a copy of the notice shall also be served upon such other person.]`
obj_root_law_sections_58_i:
  sectionId (33296)
  sectionNo 58I
  orderNo 138
  title `Forfeiture of property in certain cases`
  content obj_root_law_sections_58_i_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33296&sectionno=58I&orderno=138&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_i_content:
  string
  line `^1[58-I. Forfeiture of property in certain cases.-- (1) The competent authority may, after considering`
  line `the explanation, if any, to the show cause notice issued under section 58H, and the materials available`
  line `before it and after giving to the person affected and in a case where the person affected holds any property`
  line `specified in the notice through any other person, to such other person, also a reasonable opportunity of`
  line `being heard, by order, record a finding whether all or any of the properties in question are illegally`
  line `acquired properties:`
  line
  line `Provided that if the person affected (and in a case where the person affected holds any property`
  line `specified in the notice through any other person, such other person also), does not appear before the`
  line `competent authority or represent his case before it within a period of thirty days specified in the show`
  line `cause notice, the competent authority may proceed to record a finding under this sub-section ex parte on`
  line `the basis of evidence available before it.`
  line
  line `(2) Where the competent authority is satisfied that some of the properties referred to in the show`
  line `cause notice are illegally acquired properties but is not able to identify specifically such properties, then,`
  line `it shall be lawful for the competent authority to specify the properties which, to the best of its judgment,`
  line `are illegally acquired properties and record a finding accordingly under sub-section (1) within a period of`
  line `ninety days.`
  line
  line `(3) Where the competent authority records a finding under this section to the effect that any property`
  line `is illegally acquired property, it shall declare that such property shall, subject to the provisions of this`
  line `Chapter stand forfeited to the State Government free from all encumbrances.`
  line
  line `(4) In case the person affected establishes that the property specified in the notice issued under`
  line `section 58H is not an illegally acquired property and therefore not liable to be forfeited under the Act, the`
  line `said notice shall be withdrawn and the property shall be released forthwith.`
  line
  line `(5) Where any shares in a company stand forfeited to the State Government under this Chapter, the`
  line `company shall, notwithstanding anything contained in the Companies Act, 1956 (1 of 1956) or the article`
  line `of association of the company, forthwith register the State Government as the transferee of such shares.]`
obj_root_law_sections_58_j:
  sectionId (33297)
  sectionNo 58J
  orderNo 139
  title `Burden of proof.`
  content obj_root_law_sections_58_j_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33297&sectionno=58J&orderno=139&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_j_content:
  string
  line `^1[58J. Burden of proof. -- In any proceedings under this Chapter, the burden of proving that any`
  line `property specified in the notice served under section 58H is not illegally acquired property shall be on the`
  line `person affected.]`
obj_root_law_sections_58_k:
  sectionId (33298)
  sectionNo 58K
  orderNo 140
  title `Fine in lieu of forfeiture.`
  content obj_root_law_sections_58_k_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33298&sectionno=58K&orderno=140&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_k_content:
  string
  line `^1[58K. Fine in lieu of forfeiture. -- (1) Where the competent authority makes a declaration that any`
  line `property stands forfeited to the State Government under section 58-I and it is a case where the source of`
  line `only a part of the illegally acquired property has not been proved to the satisfaction of the competent`
  line `authority, it shall make an order giving option to the person affected to pay, in lieu of forfeiture, a fine`
  line `equal to the market value of such part.`
  line
  line `(2) Before making an order imposing a fine under sub-section (1), the person affected shall be given a`
  line `reasonable opportunity of being heard.`
  line
  line `(3) Where the person affected pays the fine due under sub-section (1), within such time as may be`
  line `allowed in that behalf, the competent authority may, by order revoke the declaration of forfeiture under`
  line `section 58-I and thereupon such property shall stand released.]`
obj_root_law_sections_58_l:
  sectionId (33299)
  sectionNo 58L
  orderNo 141
  title `Procedure in relation to certain trust properties.`
  content obj_root_law_sections_58_l_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33299&sectionno=58L&orderno=141&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_l_content:
  string
  line `^1[58L. Procedure in relation to certain trust properties.-- In the case of any person referred to in`
  line `sub-clause (vi) of clause (b) of section 58B, if the competent authority, on the basis of the information and`
  line `materials available to it, for reasons to be recorded in writing believes that any property held in trust is`
  line `illegally acquired property, it may serve a notice upon the author of the trust, or as the case may be, the`
  line `contributor of the assets out of or by means of which such property was acquired by the trust and the`
  line `trustees, calling upon them within a period of thirty days specified in the notice, to explain the source of`
  line `money or other assets out of or by means of which such property was acquired or, as the case may be, the`
  line `source of money or other assets which were contributed to the trust for acquiring such property and`
  line `thereupon such notice shall be deemed to be a notice served under section 58H and all the other`
  line `provisions of this Chapter shall apply accordingly.`
  line
  line `Explanation.--For the purposes of this section "illegally acquired property" in relation to any`
  line `property held in trust, includes--`
  line
  line `(i) any property which if it had continued to be held by the author of the trust or the contributor of`
  line `such property to the trust would have been illegally acquired property in relation to such author or`
  line contributor;
  line
  line `(ii) any property acquired by the trust out of any contributions made by any person which would`
  line `have been illegally acquired property in relation to such person had such person acquired such`
  line `property out of such contributions.]`
obj_root_law_sections_58_m:
  sectionId (33300)
  sectionNo 58M
  orderNo 142
  title `Certain transfer to be null and void.`
  content obj_root_law_sections_58_m_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33300&sectionno=58M&orderno=142&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_m_content:
  string
  line `^1[58M. Certain transfers to be null and void.-- Where after the making of an order under`
  line `sub-section (1) of section 58F or the issue of a notice under section 58H or under section 58L, any`
  line `property referred to in the said order or notice is transferred by any mode whatsoever, such transfer shall,`
  line `for the purposes of the proceedings under this Chapter, be ignored and if such property is subsequently`
  line `forfeited to the State Government under section 58-I, then, the transfer of such property shall be deemed`
  line `to be null and void.]`
obj_root_law_sections_58_n:
  sectionId (33301)
  sectionNo 58N
  orderNo 143
  title `Constitution of Applellate Tribunal.`
  content obj_root_law_sections_58_n_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33301&sectionno=58N&orderno=143&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_n_content:
  string
  line `^1[58N. Constitution of Appellate Tribunal.-- (1) The State Government may, by notification in the`
  line `Official Gazette, constitute an Appellate Tribunal to be called the Appellate Tribunal for Forfeited`
  line `Property consisting of a Chairman, and such number of other members (being officers of the State`
  line `Government not below the rank of a Principal Secretary to the Government), as the State Government`
  line `thinks fit, to be appointed by that Government for hearing appeals against the orders made under section`
  line `58F, section 58-I, sub-section (1) of section 58K or section 58L.`
  line
  line `(2) The Chairman of the Appellate Tribunal shall be a person who is or has been or is qualified to be a`
  line `Judge of a High Court.`
  line
  line `(3) The terms and conditions of service of the Chairman and other members shall be such as may be`
  line prescribed.]
obj_root_law_sections_58_o:
  sectionId (33302)
  sectionNo 58O
  orderNo 144
  title Appeals.
  content obj_root_law_sections_58_o_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33302&sectionno=58O&orderno=144&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_o_content:
  string
  line `^1[58-O. Appeals.-- (1) Any person aggrieved by an order of the competent authority made under`
  line `section 58F, section 58-I, sub-section (1) of section 58K or section 58L may, within forty-five days from`
  line `the date on which the order is served on him prefer an appeal to the Appellate Tribunal:`
  line
  line `Provided that the Appellate Tribunal may entertain an appeal after the said period of forty-five days,`
  line `but not after sixty days, from the date aforesaid if it is satisfied that the appellant was prevented by`
  line `sufficient cause from filing the appeal in time.`
  line
  line `(2) On receipt of an appeal under sub-section (1), the Appellate Tribunal may, after giving an`
  line `opportunity of being heard to the appellant, if he so desires, and after making such further inquiry as it`
  line `deems fit, confirm, modify or set aside the order appealed against.`
  line
  line `(3) The Appellate Tribunal may regulate its own procedure.`
  line
  line `(4) On application to the Appellate Tribunal and on payment of the prescribed fee, the Appellate`
  line `Tribunal may allow a party to any appeal or any person authorised in this behalf by such party to inspect`
  line `at any time during office hours, any relevant records and registers of the Appellate Tribunal and obtain a`
  line `certified copy or any part thereof.]`
obj_root_law_sections_58_p:
  sectionId (33303)
  sectionNo 58P
  orderNo 145
  title `Notice or order not to be invalid for error in description.`
  content obj_root_law_sections_58_p_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33303&sectionno=58P&orderno=145&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_p_content:
  string
  line `^1[58P. Notice or order not to be invalid for error in description. -- No notice issued or served, no`
  line `declaration made, and no order passed under this Chapter shall be deemed to be invalid by reason of any`
  line `error in the description of the property or person mentioned therein if such property or person is`
  line `identifiable from the description so mentioned.]`
obj_root_law_sections_58_q:
  sectionId (33304)
  sectionNo 58Q
  orderNo 146
  title `Bar of Jurisdiction.`
  content obj_root_law_sections_58_q_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33304&sectionno=58Q&orderno=146&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_q_content:
  string
  line `^1[58Q. Bar of jurisdiction.-- No order passed or declaration made under this Chapter shall be`
  line `appealable except as provided therein and no civil court shall have jurisdiction in respect of any matter`
  line `which the Appellate Tribunal or any competent authority is empowered by or under this Chapter to`
  line `determine, and no injunction shall be granted by any court or other authority in respect of any action`
  line `taken or to be taken in pursuance of any power conferred by or under this Chapter.]`
obj_root_law_sections_58_r:
  sectionId (33305)
  sectionNo 58R
  orderNo 147
  title `Competent Authority and Appellate Tribunal to have powers of civil court.`
  content obj_root_law_sections_58_r_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33305&sectionno=58R&orderno=147&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_r_content:
  string
  line `^1[58R. Competent Authority and Appellate Tribunal to have powers of civil court.--The`
  line `competent authority and the Appellate Tribunal shall have all the powers of a civil court while trying a`
  line `suit under the Code of Civil Procedure, 1908 (5 of 1908) in respect of the following matters, namely:--`
  line
  line `(a) summoning and enforcing the attendance of any person and examining him on oath;`
  line
  line `(b) requiring the discovery and production of documents;`
  line
  line `(c) receiving evidence on affidavits;`
  line
  line `(d) requisitioning any public record or copy thereof from any court or office;`
  line
  line `(e) issuing commissions for examination of witnesses or documents;`
  line
  line `(f) any other matter which may be prescribed.]`
obj_root_law_sections_58_s:
  sectionId (33306)
  sectionNo 58S
  orderNo 148
  title `Information to competent authority.`
  content obj_root_law_sections_58_s_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33306&sectionno=58S&orderno=148&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_s_content:
  string
  line `^1[58S. Information to competent authority.-- (1) Notwithstanding anything contained in any other`
  line `law for the time being in force, the competent authority shall have power to require any officer or`
  line `authority of the Central Government or a State Government or a local authority to furnish information in`
  line `relation to such persons, on points or matters as in the opinion of the competent authority will be useful`
  line `for, or relevant to, the purposes of this Chapter.`
  line
  line `(2) Every officer referred to in section 58T may furnish suo motu any information available with him`
  line `to the competent authority if in the opinion of the officer such information will be useful to the competent`
  line `authority for the purposes of this Chapter.]`
obj_root_law_sections_58_t:
  sectionId (33307)
  sectionNo 58T
  orderNo 149
  title `Certain officers to assist Administrator, competent authority and Appellate Tribunal.`
  content obj_root_law_sections_58_t_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33307&sectionno=58T&orderno=149&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_t_content:
  string
  line `^1[58T. Certain officers to assist Administrator, competent authority and Appellate Tribunal.-- For the purposes of any proceedings under this Chapter, the following officers shall render such`
  line `assistance as may be necessary to the Administrator appointed under section 58G, competent authority`
  line `and the Appellate Tribunal, namely:--`
  line
  line `(a) officers of Police;`
  line
  line `(b) officers of the State Forest Departments;`
  line
  line `(c) officers of the Central Economic Intelligence Bureau;`
  line
  line `(d) officers of the Directorate of Revenue Intelligence;`
  line
  line `(e) such other officers as specified by the State Government in this behalf by notification in the`
  line `Official Gazette.`
obj_root_law_sections_58_u:
  sectionId (33308)
  sectionNo 58U
  orderNo 150
  title `Power to take possession.`
  content obj_root_law_sections_58_u_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33308&sectionno=58U&orderno=150&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_u_content:
  string
  line `^1[58U. Power to take possession. -- (1) Where any property has been declared to be forfeited to the`
  line `State Government under this Chapter, or where the person affected has failed to pay the fine due under`
  line `sub-section (1) of section 58K within the time allowed therefor under sub-section (3) of that section, the`
  line `competent authority may order the person affected as well as any other person who may be in possession`
  line `of the property to surrender or deliver possession thereof to the Administrator appointed under section`
  line `58G or to any person duly authorised by him in this behalf within thirty days of the service of the order.`
  line
  line `(2) If any person refuses or fails to comply with an order made under sub-section (1), the`
  line `Administrator may take possession of the property and may for that purpose use such force as may be`
  line necessary.
  line
  line `(3) Notwithstanding anything contained in sub-section (2), the Administrator may, for the purpose of`
  line `taking possession of any property referred to in sub-section (1) requisition the services of any police`
  line `officer to assist him and it shall be the duty of such officer to comply with such requisition.]`
obj_root_law_sections_58_v:
  sectionId (33309)
  sectionNo 58V
  orderNo 151
  title `Rectification of mistakes.`
  content obj_root_law_sections_58_v_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33309&sectionno=58V&orderno=151&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_v_content:
  string
  line `^1[58V. Rectification of mistakes.-- With a view to rectifying any mistake apparent from record, the`
  line `competent authority or the Appellate Tribunal, as the case may be, may amend any order made by it`
  line `within a period of one year from the date of the order:`
  line
  line `Provided that if any such amendment is likely to affect any person prejudicially and the mistake is not`
  line `of a clerical nature, it shall not be made without giving to such person a reasonable opportunity of being`
  line heard.]
obj_root_law_sections_58_w:
  sectionId (33310)
  sectionNo 58W
  orderNo 152
  title `Findings under other laws not conclusive for proceedings under this Chapter.`
  content obj_root_law_sections_58_w_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33310&sectionno=58W&orderno=152&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_w_content:
  string
  line `^1[58W. Findings under other laws not conclusive for proceedings under this Chapter. --No finding`
  line `of any officer or authority under any other law shall be conclusive for the purposes of any proceedings`
  line `under this Chapter.]`
obj_root_law_sections_58_x:
  sectionId (33311)
  sectionNo 58X
  orderNo 153
  title `Service of notices and orders.`
  content obj_root_law_sections_58_x_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33311&sectionno=58X&orderno=153&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_x_content:
  string
  line `^1[58X. Service of notices and orders.-- Any notice or order issued or made under this Chapter shall be`
  line served,
  line
  line `(a) by tendering the notice or order or sending it by registered post to the person for whom it is`
  line `intended or to his agent;`
  line
  line `(b) if the notice or order cannot be served in the manner provided in clause (a), then, by affixing`
  line `it on a conspicuous place in the property in relation to which the notice or order is issued or made or`
  line `on some conspicuous part of the premises in which the person for whom it is intended is known to`
  line `have last resided or carried on business or personally worked for gain.]`
obj_root_law_sections_58_y:
  sectionId (33312)
  sectionNo 58Y
  orderNo 154
  title `Punishment for acquiring property in relating to which proceeings have been taken under this Chapter.`
  content obj_root_law_sections_58_y_content
  footnotes `1. Ins. by Act 16 of 2003, s. 34 (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33312&sectionno=58Y&orderno=154&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_58_y_content:
  string
  line `^1[58Y.Punishment for acquiring property in relation to which proceedings have been taken under`
  line `this Chapter.-- Any person who knowingly acquires, by any mode whatsoever, any property in relation`
  line `to which proceedings are pending under this Chapter shall be punishable with imprisonment for a term`
  line `which may extend to five years and with fine which may extend to fifty thousand rupees.]`
obj_root_law_sections_59:
  sectionId (33313)
  sectionNo (59)
  orderNo 155
  title `Officers to be public servants.`
  content obj_root_law_sections_59_content
  footnotes obj_root_law_sections_59_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33313&sectionno=59&orderno=155&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_59_content:
  string
  line `Every officer referred to ^1[in Chapter II and the chairperson,`
  line `members, member-secretary and other officers and employees referred to in Chapter IVA],`
  line ^2[Chapter
  line `IVB] and every other officer exercising any of the powers conferred by this Act shall be deemed to be a`
  line `public servant within the meaning of section 21 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_59_footnotes:
  string
  line `1. Subs. by Act 44 of 1991, s. 41, for "in Chapter II and" (w.e.f. 2-10-1991).`
  line
  line `2. Ins. by Act 39 of 2006, s. 5 (w.e.f. 4-9-2006).`
obj_root_law_sections_60:
  sectionId (33314)
  sectionNo (60)
  orderNo 156
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_60_content
  footnotes obj_root_law_sections_60_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33314&sectionno=60&orderno=156&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_60_content:
  string
  line `(1) No-suit, prosecution or other legal proceeding`
  line `shall lie against any officer or other employee of the Central Government or the State Government for`
  line `anything which is in good faith done or intended to be done under this Act.`
  line
  line `(2) No suit or other legal proceeding shall lie against the Central Government or the State`
  line `Government or any of its officers or other employees for any damage caused or likely to be caused by`
  line `anything which is in good faith done or intended to be done under this Act.`
  line
  line `^1[(3) No suit or other legal proceeding shall lie against the Authority referred to in Chapter`
  line `IVA ^2[Chapter IVB and its chairperson, members, member-secretary, officers and other employees for`
  line `anything which is in good faith done or intended to be done under this Act.]`
obj_root_law_sections_60_footnotes:
  string
  line `1. Ins. by Act 44 of 1991, s. 42 (w.e.f. 2-10-1991).`
  line
  line `2. Ins. by Act 39 of 2006, s. 6 (w.e.f. 4-9-2006).`
obj_root_law_sections_60_a:
  sectionId (33315)
  sectionNo 60A
  orderNo 157
  title `Reward to persons.`
  content obj_root_law_sections_60_a_content
  footnotes obj_root_law_sections_60_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33315&sectionno=60A&orderno=157&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_60_a_content:
  string
  line `^1[60A. Reward to persons.-- (1) When a court imposes a sentence of fine or a sentence of which fine`
  line `forms a part, the Court may, when passing judgment, order that the reward be paid to a person who`
  line `renders assistance in the detection of the offence or the apprehension of the offenders out of the proceeds`
  line `of fine not exceeding ^2[fifty per cent. of such fine.]`
  line
  line `(2) Where a case is compounded under Sec. 54, the officer compounding may order reward to be paid`
  line `to a person who renders assistance in the detection of the offence or the apprehension of the offenders out`
  line `of the sum of money accepted by way of composition not exceeding ^3[fifty per cent. of such money].]`
obj_root_law_sections_60_a_footnotes:
  string
  line `1. Ins. by Act 44 of 1991, s. 43 (w.e.f. 2-10-1991).`
  line
  line `2. Subs. by Act 16 of 2003, s. 35, for "twenty per cent. of such fine" (w.e.f. 1-4-2003).`
  line
  line `3. Subs. by s. 35, ibid., for "twenty per cent. of such money" (w.e.f. 1-4-2003).`
obj_root_law_sections_60_b:
  sectionId (33316)
  sectionNo 60B
  orderNo 158
  title `Reward by State Government.`
  content obj_root_law_sections_60_b_content
  footnotes `1. Ins. by s. 36, ibid. (w.e.f. 1-4-2003).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33316&sectionno=60B&orderno=158&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_60_b_content:
  string
  line `^1[60B. Reward by State Government. -- The State Government may empower the Chief Wild Life`
  line `Warden to order payment of reward not exceeding ten thousand rupees to be paid to a person who renders`
  line `assistance in the detection of the offence or the apprehension of the offender, from such fund and in such`
  line `manner as may be prescribed.]`
obj_root_law_sections_61:
  sectionId (33317)
  sectionNo (61)
  orderNo 159
  title `Power to alter entries in Schedules`
  content obj_root_law_sections_61_content
  footnotes obj_root_law_sections_61_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33317&sectionno=61&orderno=159&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_61_content:
  string
  line `(1) The Central Government may, if it is of opinion that it`
  line `is expedient so to do, by notification, ^1[ ^2[amend any Schedule or add] or delete any entry to or from any`
  line `Schedule] or transfer any entry from one Part of a Schedule to another Part of the same Schedule or from`
  line `one Schedule to another.`
  line
  line `^3 * * * *`
  line
  line `(3) On the issue of a notification under sub-section (1), ^4*** the relevant Schedule shall be deemed to`
  line `be altered accordingly, provided that every such alteration shall be without prejudice to anything done or`
  line `omitted to be done before such alteration.`
  line
  line `^5* * * * *`
  line
  line `Provided that any such alteration made by the State Government, if it has been made with the`
  line `previous consent of the Central Government, shall prevail in that State:`
  line
  line `Provided further that nothing in the foregoing proviso shall prevent the Central Government from`
  line `modifying or cancelling, at any time, the alteration made by the State Government.`
obj_root_law_sections_61_footnotes:
  string
  line `1. Subs. by Act 44 of 1991, s. 44, for "add any entry to any Schedule" (w.e.f. 2-10-1991).`
  line
  line `2. Subs. by Act 18 of 2022, s. 37, for "add" (w.e.f. 1-4-2023).`
  line
  line `3. Sub-section (2) omitted by s. 44, ibid. (w.e.f. 2-10-1991).`
  line
  line `4. The words brackets and figure "or sub-section (2)" omitted by Act 44 of 1991, s. 44 (w.e.f. 2-10-1991).`
  line
  line `5. Sub-section (4) omitted by s. 44, ibid. (w.e.f. 2-10-1991).`
obj_root_law_sections_62:
  sectionId (33318)
  sectionNo (62)
  orderNo 160
  title `Declaration of certain wild animals to be vermin.`
  content obj_root_law_sections_62_content
  footnotes obj_root_law_sections_62_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33318&sectionno=62&orderno=160&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_62_content:
  string
  line `^1[The Central Government] may, by`
  line `notification, declare any wild animal ^2[specified in Schedule II] to be vermin for any area and for such`
  line `period as may be specified therein and so long as such notification is in force, such wild animal shall be`
  line `^3[deemed not to be included in Schedule II for such area and for such period as specified in the`
  line notification].
obj_root_law_sections_62_footnotes:
  string
  line `1. Subs. by Act 44 of 1991, s. 45, for certain words (w.e.f. 2-10-1991).`
  line `2. Subs. by Act 18 of 2022, s. 38, for "other than those specified in Schedule I and Part II of Schedule II" (w.e.f. 1-4-2023).`
  line `3. Subs. by s. 38, ibid., for "deemed to have been included in Schedule V" (w.e.f. 1-4-2023).`
obj_root_law_sections_62_a:
  sectionId (73309)
  sectionNo 62A
  orderNo 161
  title `Regulation or prohibition of import, etc., of invasive alien species.`
  content obj_root_law_sections_62_a_content
  footnotes `1. Ins. by s. 39, ibid (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73309&sectionno=62A&orderno=161&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_62_a_content:
  string
  line `^1[62A. Regulation or prohibition of import, etc., of invasive alien species.--(1) The Central`
  line `Government may, by notification, regulate or prohibit the import, trade, possession or proliferation of`
  line `invasive alien species which pose a threat to the wild life or habitat in India.`
  line
  line `(2) The Central Government may authorise the Director or any other officer to seize and dispose of,`
  line `including through destruction, the species referred to in the notification issued under sub-section (1).]`
obj_root_law_sections_62_b:
  sectionId (73310)
  sectionNo 62B
  orderNo 162
  title `Power to issue directions.`
  content obj_root_law_sections_62_b_content
  footnotes `1. Ins. by s. 39, ibid (w.e.f. 1-4-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=73310&sectionno=62B&orderno=162&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_62_b_content:
  string
  line `^1[62B. Power to issue directions.--Notwithstanding any other provision of this Act, the Central`
  line `Government may call for any information or report from a State Government or any such other agency or`
  line `body or issue any direction to a State Government or any such other agency or body for effective`
  line `implementation of the provisions of the Act for the protection, conservation and management of wild life`
  line `in the country.]`
obj_root_law_sections_63:
  sectionId (33319)
  sectionNo (63)
  orderNo 163
  title `Power of Central Government to make rules`
  content obj_root_law_sections_63_content
  footnotes obj_root_law_sections_63_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33319&sectionno=63&orderno=163&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_63_content:
  string
  line `^1[(1) The Central Government may, by`
  line `notification, make rules for all or any of the following matters, namely:--`
  line
  line `(a) conditions and other matters subject to which a licensee may keep any specified plant in his`
  line `custody or possession under section17F;`
  line
  line `^2[(ai) the term of office of members other than those who are members ex officio; the manner of`
  line `filling vacancies, the procedure to be followed by the National Board under sub-section (2) and`
  line `allowances of those members under sub-section (3) of section 5A;]`
  line
  line `^3[(aa) the matters to be prescribed under clause (b) of sub-section (4) of section 44;]`
  line
  line `(b) the salaries, allowances and other conditions of appointment of chairperson, members and`
  line `member-secretary under sub-section (5) of section 38B;`
  line
  line `(c) the terms and conditions of service of the officers and other employees of the Central Zoo`
  line `Authority under sub-section (7) of section 38B;`
  line
  line `(d) the form in which the annual statement of accounts of the Central Zoo Authority shall be`
  line `prepared under sub-section (4) of section 38E;`
  line
  line `(e) the form in which and the time at which the annual report of the Central Zoo Authority shall`
  line `be prepared under section 38F;`
  line
  line `(f) the form in which and the fee required to be paid with the application for recognition of a zoo`
  line `under sub-section (2) of section 38H;`
  line
  line `(g) the standards, norms and other matters to be considered for granting recognition under`
  line `sub-section (4) of section 38H;`
  line
  line `^4[(gi) qualifications and experience of experts or professionals under clause (d) of sub-section (2)`
  line `of section 38-1;`
  line
  line `(gii) the salaries and allowances and other conditions of appointment of the members under`
  line `sub-section (4) of section 38M;`
  line
  line `(giii) the terms and conditions of service of the officers and other employees of the Tiger`
  line `Conservation Authority under sub-section (2) of section 38N;`
  line
  line `(giv) the form in which the annual statement of accounts of Tiger Conservation Authority shall be`
  line `prepared under sub-section (1) of section 38R;`
  line
  line `(gv) the form in which and the time at which the annual report of Tiger Conservation Authority`
  line `shall be prepared under section 38S;`
  line
  line `(gvi) other powers of the Wild Life Crime Control Bureau under clause (ii) of sub-section (2) of`
  line `section 38Z.]`
  line
  line `^5[(gvii) the manner of disposal of Government property under sub-section (5) of section 39;`
  line `(gviii) the terms and conditions of a transfer or transport of a captive elephant by a person having`
  line `a valid certificate of ownership for a religious or any other purpose under the proviso to sub-section`
  line `(2) of section 43;]`
  line
  line `(h) the form in which declaration shall be made under sub-section (2) of section 44;`
  line
  line `(i) the matters to be prescribed under Cl. (b) of sub-section (4) of section 44;`
  line
  line `(j) the terms and conditions which shall govern transaction referred to in clause (b) of section 48;`
  line
  line `^6[(ji) the terms and conditions of service including salaries and allowances for appointment of the`
  line `officers and employees of the Management Authority under sub-section (4) of section 49E;`
  line
  line `(jii) the conditions and procedures subject to which any exemption provided for in Article VII of`
  line `the Convention may be availed under sub-section (2) of section 49H;`
  line
  line `(jiii) the reporting of details of scheduled specimens and the transaction as per`
  line `sub-section (3) of section 49H;`
  line
  line `(jiv) the form and manner of application, the fee payable, the conditions and the procedure to be`
  line `followed under sub-section (5) of section 49H;`
  line
  line `(jv) the matters provided for in sub-sections (8) and (9) of section 49M;`
  line
  line `(jvi) the form and manner of the application, the fee payable, the form of licence and the`
  line `procedure to be followed in granting or cancelling a licence as per sub-section (2) of section 49N;`
  line
  line `(jvii) the fee payable for renewal of licence as per sub-section (3), and manner of making appeal`
  line `under sub-section (4), of section 49-O;`
  line
  line `(jviii) any other matter for proper implementation of the Convention as may be required under`
  line `Chapter VB;]`
  line
  line `(k) the manner in which notice may be given by a person under clause (c) of section 55;`
  line
  line `(1) the matters specified in sub-section (2) of section 64 in so far as they relate to sanctuaries and`
  line `National Parks declared by the Central Government.]`
  line
  line `(2) Every rule made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament, while it is in session, for a total period of thirty days which may be comprised in`
  line `one session or in two or more successive sessions, and if before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_63_footnotes:
  string
  line `1. Subs. by s. 46, ibid., for sub-section (1) (w.e.f. 2-10-1991).`
  line
  line `2. Ins. by Act 16 of 2003, s. 37 (w.e.f. 1-4-2003).`
  line
  line `3. Ins. by Act 23 of 1982, s. 4 (w.e.f. 21-5-1982).`
  line
  line `4. Ins. by Act 39 of 2006, s. 7 (w.e.f. 4-9-2006).`
  line
  line `5. Ins. by Act 18 of 2022, s. 40 (w.e.f. 1-4-2023).`
  line
  line `6. Ins. by s. 40, ibid (w.e.f. 1-4-2023).`
obj_root_law_sections_64:
  sectionId (33320)
  sectionNo (64)
  orderNo 164
  title `Power of State Government to make rules.`
  content obj_root_law_sections_64_content
  footnotes obj_root_law_sections_64_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33320&sectionno=64&orderno=164&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_64_content:
  string
  line `(1) The State Government may, by notification,`
  line `make rules for carrying out the provisions of this Act in respect of matters which do not fall within the`
  line `purview of section 63.`
  line
  line `(2) In particular and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `^1[(a) the term of office of members other than those who are members, ex officio, the manner of`
  line `filling vacancies and the procedure to be followed by the Board under sub-section (2) of section 6;`
  line
  line `(b) allowances referred to in sub-section (3) of section 6;]`
  line
  line `(c)the forms to be used for any application, certificate, claim,declaration, licence, permit,`
  line `registration, return, or other document, made, granted, or submitted under the provisions of this Act`
  line `and the fees, if any, therefor;`
  line
  line `(d) the conditions subject to which any licence or permit may be granted under this Act;`
  line
  line `^2[(dd) the conditions subject to which the officers will be authorised to file cases in the court;]`
  line
  line `(e) the particulars of the record of wild animals (captured or killed) to be kept and submitted by`
  line `the licensee;`
  line
  line `^3[(ee) the manner in which measures for immunisation of live-stock shall be taken;]`
  line
  line `(f)regulation of the possession, transfer and the sale of captive animals, meat, animal articles,`
  line `trophies and uncured trophies;`
  line
  line `(g) regulation of taxidermy;`
  line
  line `^4[(ga) the manner and conditions subject to which the Administrator shall receive and manage the`
  line `property under sub-section (2) of section 58G;`
  line
  line `(gb) the terms and conditions of service of the Chairman and other members under`
  line `sub-section (3) of section 58N;`
  line
  line `(gc) the fund from which and the manner in which payment of reward under section 60B shall be`
  line made;]
  line
  line `(h) any other matter which has to be, or may be, prescribed under this Act.`
obj_root_law_sections_64_footnotes:
  string
  line `1. Subs. by Act 16 of 2003, s. 38, for clauses (a) and (b) (w.e.f. 1-4-2003).`
  line
  line `2. Ins. by s. 38, ibid. (w.e.f. 1-4-2003).`
  line
  line `3. Ins. by Act 44 of 1991, s. 47 (w.e.f. 2-10-1991).`
  line
  line `3. Ins. by Act 16 of 2003, s. 38 (w.e.f. 1-4-2003).`
obj_root_law_sections_65:
  sectionId (33321)
  sectionNo (65)
  orderNo 165
  title `Rights of Scheduled Tribes to be protected.`
  content obj_root_law_sections_65_content
  footnotes obj_root_law_sections_65_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33321&sectionno=65&orderno=165&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_65_content:
  string
  line `Nothing in this Act shall affect the hunting rights`
  line `conferred on the Scheduled Tribes of the Nicobar Islands in the Union territory of Andaman and Nicobar`
  line `Islands by notification of the Andaman and Nicobar Administration, No. 40,/67/F, No. G635, Vol. III,`
  line `dated the 28th April, 1967, published at pages 1 to 5 of the Extraordinary issue of the Andaman and`
  line `Nicobar Gazette, dated the 28th April, 1967.`
obj_root_law_sections_65_footnotes:
  string
  line
obj_root_law_sections_66:
  sectionId (33322)
  sectionNo (66)
  orderNo 166
  title `Repeal and savings.`
  content obj_root_law_sections_66_content
  footnotes `1. Ins. by Act 44 of 1991, s. 48 (w.e.f. 2-10-1991).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_16_18_00007_197253_1517807324579&sectionId=33322&sectionno=66&orderno=166&orgactid=AC_CEN_16_18_00007_197253_1517807324579
obj_root_law_sections_66_content:
  string
  line `(1) As from the commencement of this Act, every other Act relating to any`
  line `matter contained in this Act and in force in a State shall, to the extent to which that Act or any provision`
  line `contained therein corresponds, or is repugnant, to this Act or any provision contained in this Act, stand`
  line `repealed:`
  line
  line `Provided that such repeal shall not,--`
  line
  line `(i) affect the previous operation of the Act so repealed, or anything duly done or suffered`
  line thereunder;
  line
  line `(ii) affect any right, privilege, obligation or liability, acquired, accrued or incurred under the Act`
  line `so repealed;`
  line
  line `(iii) affect any penalty, forfeiture or punishment incurred in respect of any offence committed`
  line `against the Act so repealed; or`
  line
  line `(iv) affect any investigation, legal proceeding or remedy in respect of any such right, privilege,`
  line `obligation, liability, penalty, forfeiture, or punishment as aforesaid;`
  line
  line `and any such investigation, legal proceeding or remedy may be instituted, continued or enforced, and any`
  line `such penalty, forfeiture and. Punishment may be imposed, as if the aforesaid Act had not been repealed.`
  line
  line `(2) Notwithstanding such repeal,`
  line
  line `(a) anything done or any action taken under the Act so repealed, (including any notification,`
  line `order, certificate, notice or receipt issued, application made, or permit granted) which is not`
  line `inconsistent with the provisions of this Act, be deemed to have been done or taken under the`
  line `corresponding provisions of this Act as, if this Act were in force at the time such thing was done or`
  line `action was taken, and shall continue to be in force, unless and until superseded by anything done or`
  line `any action taken under this Act;`
  line
  line `(b) every licence granted under any Act so repealed and in force immediately before the`
  line `commencement of this Act shall be deemed to have been granted under the corresponding provisions`
  line `of this Act and shall, subject to the provisions of this Act, continue to be in force for the unexpired`
  line `portion. of the period for which such licence had been granted.`
  line
  line `(3) For the removal of doubts, it is hereby declared that any sanctuary or National Park declared by a`
  line `State Government under any Act repealed under sub-section (1) shall be deemed to be a sanctuary or`
  line `National Park, as, the case may be, declared by the State Government under this Act and where any right in or over any land in any such National Park which had not been extinguished under the said Act, at or`
  line `before the commencement of this Act, the extinguishment of such rights shall be made in accordance with`
  line `the provisions of this Act.`
  line
  line `^1[(4) For the removal of doubts, it is hereby further declared that where any proceeding under any`
  line `provision of section 19 to 25 (both inclusive) is pending on the date of commencement of the Wild Life`
  line `(Protection) Amendment Act, 1991 (44 of 1991), any reserve forest or a part of territorial waters`
  line `comprised within a sanctuary declared under section 18 to be a sanctuary before the date of such`
  line `commencement shall be deemed to be a sanctuary declared under section. 26A.]`
