obj_root_law_sections_1:
  sectionId (23955)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23955&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the University of Hyderabad`
  line `Act, 1974.`
  line
  line `(2) It shall come into force on such date as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (23956)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23956&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_2_content:
  string
  line `In this Act, and in all Statutes made hereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by`
  line `the Ordinances;`
  line
  line `(c) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(d) "Chancellor", "Vice-Chancellor" and "Pro-Vice-Chancellor" mean, respectively, the`
  line `Chancellor, Vice-Chancellor and Pro-Vice-Chancellor of the University;`
  line
  line `(e) "College" means a College maintained by the University;`
  line
  line `(f) "Court" means the Court of the University;`
  line
  line `(g) "Department" means a Department of Studies, and includes a Centre of Studies;`
  line
  line `(h) "employee" means any person appointed by the University, and includes teachers`
  line `and other staff of the University;`
  line
  line `(i) "Executive Council" means the Executive Council of the University;`
  line
  line `(j) "Hall" means a unit of residence or of corporate life for the students of the University, College`
  line `or Institution, provided, maintained or recognised by the University;`
  line
  line `(k) "Institution" means an academic institution, not being a College, maintained by the`
  line University;
  line
  line `(l) "Principal" means the Head of a College or an Institution;`
  line
  line `(m) "recognised institution" means an institution of higher learning recognised by the University;`
  line
  line `(n) "recognised teachers" means person working in any recognised institution or in any Institution`
  line `associated with the University and recognised by the University for the purpose of imparting`
  line `instruction or conducting research or both;`
  line
  line `(o) "School" means a School of Studies of the University;`
  line
  line `(p) "Statutes", "Ordinances" and "Regulations", mean, respectively, the Statutes, Ordinances and`
  line `Regulations of the University for the time being in force;`
  line
  line `(q) "teachers of the University" means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instruction or conducting research in the University or in any College`
  line `or Institution maintained by the University and designated as teachers by the Ordinances;`
  line
  line `(r) "University" means the University of Hyderabad.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (23957)
  sectionNo (3)
  orderNo 3
  title `The University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23957&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established, in the State of Andhra Pradesh, a University by`
  line `the name of "University of Hyderabad".`
  line
  line `(2) The headquarters of the University shall be at Hyderabad and it may establish campuses at`
  line `such other places within its jurisdiction as it may deem fit.`
  line
  line `(3) The first Chancellor and the first Vice-Chancellor and the first members of the Court, the`
  line `Executive Council and the Academic Council and all persons who may hereafter become such officers`
  line `or members, so long as they continue to hold such office or membership, are hereby constituted a`
  line `body corporate by the name of "University of Hyderabad".`
  line
  line `(4) The University shall have perpetual succession and a common seal, and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (23958)
  sectionNo (4)
  orderNo 4
  title Objects.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23958&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_4_content:
  string
  line `The objects of the University shall be to disseminate and advance knowledge by`
  line `providing instructional and research facilities in such branches of learning as it may deem fit and by the`
  line `example of its corporate life, and, in particular, to make special provisions for integrated courses in`
  line `humanities and science in the educational programmes of the University and to take appropriate measures`
  line `for promoting inter-disciplinary studies and research in the University.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (23959)
  sectionNo (5)
  orderNo 5
  title `Powers of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23959&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_5_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(1) to provide for instructions in such branches of learning as the University may, from time to`
  line `time, determine and to make provision for research and for the advancement and dissemination of`
  line knowledge;
  line
  line `(2) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees and other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing, on persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(3) to organise and to undertake extra-mural studies and extension services;`
  line
  line `(4) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(5) to provide instruction, including correspondence and such other courses, to such persons as`
  line `are not members of the University, as it may determine;`
  line
  line `(6) to institute Principalships, Professorships, Readerships, Lecturerships, and other teaching or`
  line `academic posts required by the University and to appoint persons to such Principalships,`
  line `Professorships, Readerships, Lecturerships or other posts;`
  line
  line `(7) to recognise an Institution of higher learning for such purposes as the University may`
  line `determine and to withdraw such recognition;`
  line
  line `(8) to recognise persons working in any recognised institution or in any Institution associated`
  line `with the University for imparting instruction or supervising research or both, and to withdraw such`
  line recognition;
  line
  line `(9) to appoint persons working in any other University ororganisation as teachers of the`
  line `University for a specified period;`
  line
  line `(10) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(11) to co-operate or collaborate or associate with any other University or authority or institution`
  line `of higher learning in such manner and for such purposes as the University may determine;`
  line
  line `(12) to establish such campuses, special centres, specialised laboratories or other units for`
  line `research and instruction as are, in the opinion of the University, necessary for the furtherance of its`
  line objects;
  line
  line `(13) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(14) to establish and maintain Colleges, Institutions and Halls;`
  line
  line `(15) to make provision for research and advisory services; and for that purpose to enter into such`
  line `arrangements with other Institutions or bodies as the University may deem necessary;`
  line
  line `(16) to declare a College an Institution or a Department as an autonomous College or Institution`
  line `or Department as the case may be;`
  line
  line `(17) to determine standards for admission into the University, which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(18) to demand and receive payment of fees and other charges;`
  line
  line `(19) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(20) to make special arrangements in respect of women students as the University may consider`
  line desirable;
  line
  line `(21) to regulate and enforce discipline among the employees and students of the University and`
  line `take such disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(22) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(23) to receive donations and to acquire, hold, manage and dispose of any property, movable or`
  line `immmovable, including trust and endowment properties for the purposes of the University;`
  line
  line `(24) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University;`
  line
  line `(25) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of the objects of the University.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (23960)
  sectionNo (6)
  orderNo 6
  title Jurisdiction.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23960&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_6_content:
  string
  line `(1) The jurisdiction of the University shall extend to the whole of the State of`
  line `Andhra Pradesh.`
  line
  line `(2) No institution affiliated to or associated with or maintained by any other University in the State of`
  line `Andhra Pradesh shall be recognised by the University of Hyderabad for any purpose except with the prior`
  line `approval of the Government of the State of Andhra Pradesh and the concerned University`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (23961)
  sectionNo (7)
  orderNo 7
  title `University open to all classes, castes and creed.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23961&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_7_content:
  string
  line `The University shall be open to persons of`
  line `either sex and of whatever race, creed, caste, or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person any test whatsoever of religious belief or profession in order to entitle him to be`
  line `admitted therein, as a teacher or student, or to hold any office therein, or to graduate thereat or to enjoy or`
  line `exercise any privilege thereof:`
  line hr1
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for admission of students of the weaker sections of the people and, in particular, of the`
  line `Scheduled Castes and the Scheduled Tribes.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (23962)
  sectionNo (8)
  orderNo 8
  title Visitor.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23962&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_8_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor shall have the right to cause an inspection to be made by such person or persons as he`
  line `may direct, of the University, its buildings, laboratories and equipment, and of any College or Institution`
  line `maintained by the University; and also of the examinations, teaching and other work conducted or done`
  line `by the University and to cause an inquiry to be made in like manner in respect of any matter connected`
  line `with the administration or finances of the University, Colleges or Institutions.`
  line
  line `(3) The Visitor shall, in every case, give notice to the University of his intention to cause an`
  line `inspection or inquiry to be made and on receipt of such notice, the University shall have the right to make`
  line `such representations to the Visitor, as it may consider necessary.`
  line
  line `(4) After considering the representations, if any, made by the University, the Visitor may cause to be`
  line `made such inspection or inquiry as is referred to in sub-section (2).`
  line
  line `(5) Where any inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative who shall have the right to be present and to be heard at such`
  line `inspection or inquiry.`
  line
  line `(6) The Visitor may, if the inspection or inquiry is made in respect of the University or any College or`
  line `Institution maintained by it, address the Vice-Chancellor with reference to the result of such inspection or`
  line `inquiry, and the Vice-Chancellor shall communicate to the Executive Council the views of the Visitor`
  line `with such advice as the Visitor may be pleased to offer upon the action to be taken thereon.`
  line
  line `(7) The Executive Council shall communicate through the Vice-Chancellor to the Visitor such action,`
  line `if any, as it proposes to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(8) Where the Executive Council does not, within a reasonable time, take action to the satisfaction of`
  line `the Visitor, the Visitor may, after considering any explanation furnished or representation made by the`
  line `Executive Council, issue such directions as he may think fit and the Executive Council shall comply with`
  line `such directions.`
  line
  line `(9) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in writing,`
  line `annul any proceeding of the University which is not in conformity with this Act, the Statutes`
  line `or Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the University to show cause why`
  line `such an order should not be made, and, if any cause is shown within a reasonable time, he shall consider`
  line `the same.`
  line
  line `(10) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (23963)
  sectionNo (9)
  orderNo 9
  title `Chief Rector.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23963&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_9_content:
  string
  line `The Governor of the State of Andhra Pradesh shall be the Chief Rector of the`
  line University.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (23964)
  sectionNo (10)
  orderNo 10
  title `Officers of the University.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23964&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_10_content:
  string
  line `The following shall be the officers of the University:--`
  line
  line `(1) The Chancellor;`
  line
  line `(2) The Vice-Chancellor;`
  line
  line `(3) The Pro-Vice-Chancellor or, if more than one are appointed, the Pro-Vice-Chancellors;`
  line
  line `(4) The Deans of Schools;`
  line
  line `(5) The Registrar;`
  line
  line `(6) The Finance Officer; and`
  line
  line `(7) Such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (23965)
  sectionNo (11)
  orderNo 11
  title `The Chancellor.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23965&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_11_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the Head of the University.`
  line
  line `(3) The Chancellor shall, if present, preside at the convocations of the University held for conferring`
  line degrees.
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (23966)
  sectionNo (12)
  orderNo 12
  title `The Vice-Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23966&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_12_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University, and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority the action taken by him on such matter:`
  line
  line `Provided that if the authority concerned is of opinion that such action ought not to have been taken, it`
  line `may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to appeal against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated`
  line `to him and thereupon the Executive Council may confirm, modify or reverse the action taken by the`
  line Vice-Chancellor.
  line
  line `(4) The Vice-Chancellor shall exercise such other powers and perform such other functions as may be`
  line `prescribed by the Statutes or Ordinances.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (23967)
  sectionNo (13)
  orderNo 13
  title `The Pro-Vice-Chancellors.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23967&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_13_content:
  string
  line `.Every Pro-Vice-Chancellor shall be appointed in such manner and`
  line `shall exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (23968)
  sectionNo (14)
  orderNo 14
  title `Deans of Schools.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23968&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_14_content:
  string
  line `Every Dean of a School shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (23969)
  sectionNo (15)
  orderNo 15
  title `The Registrar.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23969&sectionno=15&orderno=15&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_15_content:
  string
  line `(1) The Registrar shall be appointed in such manner as may be prescribed by the`
  line Statutes.
  line
  line `(2) The Registrar shall have the power to enter into agreements, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such other powers and perform such other duties as`
  line `may be prescribed by the Statutes.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (23970)
  sectionNo (16)
  orderNo 16
  title `The Finance Officer.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23970&sectionno=16&orderno=16&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_16_content:
  string
  line `The Finance Officer shall be appointed in such manner and shall exercise`
  line `such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_17:
  sectionId (23971)
  sectionNo (17)
  orderNo 17
  title `Other officers.`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23971&sectionno=17&orderno=17&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_17_content:
  string
  line `The manner of appointment and powers and duties of other officers of the`
  line `University shall be prescribed by the Statutes.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (23972)
  sectionNo (18)
  orderNo 18
  title `Authorities of the University.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23972&sectionno=18&orderno=18&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_18_content:
  string
  line `The following shall be the authorities of the University:--`
  line
  line `(1) The Court;`
  line
  line `(2) The Executive Council;`
  line
  line `(3) The Academic Council;`
  line
  line `(4) The Boards of Schools; and`
  line
  line `(5) Such other authorities as may be declared by the Statutes to be authorities of the University.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_19:
  sectionId (23973)
  sectionNo (19)
  orderNo 19
  title `The Court.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23973&sectionno=19&orderno=19&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_19_content:
  string
  line `(1) The constitution of the Court and the term of office of its members shall be`
  line `prescribed by the Statutes.`
  line
  line `(2) Subject to the provisions of this Act, the Court shall have the following powers and functions,`
  line `namely:--`
  line
  line `(a) to review, from time to time, the broad policies and programmes of the University and to`
  line `suggest measures for the improvement and development of the University;`
  line
  line `(b) to consider and pass resolutions on the annual report and the annual accounts of the University`
  line `and the audit report on such accounts;`
  line
  line `(c) to advise the Visitor in respect of any matter which may be referred to it for advice; and`
  line
  line `(d) to perform such other functions as may be prescribed by the Statutes.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (23974)
  sectionNo (20)
  orderNo 20
  title `The Executive Council.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23974&sectionno=20&orderno=20&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_20_content:
  string
  line `(1) The Executive Council shall be the principal Executive body of the`
  line University.
  line
  line `(2) The constitution of the Executive Council, the term of office of its members and its powers and`
  line `functions shall be prescribed by the Statutes.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (23975)
  sectionNo (21)
  orderNo 21
  title `The Academic Council.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23975&sectionno=21&orderno=21&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_21_content:
  string
  line `(1) The Academic Council shall be the principal academic body of the`
  line `University and shall, subject to the provisions of this Act, the Statutes and Ordinances, co-ordinate and`
  line `exercise general supervision over the academic policies of the University.`
  line
  line `(2) The constitution of the Academic Council, the term of office of its members and its powers and`
  line `functions shall he prescribed by the Statutes.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (23976)
  sectionNo (22)
  orderNo 22
  title `Other authorities of the University.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23976&sectionno=22&orderno=22&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_22_content:
  string
  line `The constitution, powers and functions of the Boards of`
  line `Schools and of such other authorities as may be declared by the Statutes to be authorities of the`
  line `University, shall be prescribed by the Statutes.`
obj_root_law_sections_22_footnotes:
  string
  line
obj_root_law_sections_23:
  sectionId (23977)
  sectionNo (23)
  orderNo 23
  title `Planning Board.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23977&sectionno=23&orderno=23&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_23_content:
  string
  line `(1) There shall be constituted a Planning Board of the University which shall`
  line `advise generally on the planning and development of the University and keep under review the standard`
  line `of education and research in the University.`
  line
  line `(2) The constitution of the Planning Board and the manner of appointment of its members shall be`
  line `prescribed by the Statutes.`
  line
  line `(3) The Visitor may determine a date with effect from which the Planning Board shall stand`
  line dissolved.
obj_root_law_sections_23_footnotes:
  string
  line
obj_root_law_sections_24:
  sectionId (23978)
  sectionNo (24)
  orderNo 24
  title Statutes.
  content obj_root_law_sections_24_content
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23978&sectionno=24&orderno=24&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_24_content:
  string
  line `Subject to the provisions of this Act, the Statutes may provide for all or any of the`
  line `following matters, namely:--`
  line
  line `(a) the constitution, powers and functions of the authorities and other bodies of the University, as`
  line `may be constituted from time to time;`
  line
  line `(b) the election and continuance in office of the members of the said authorities and bodies, the`
  line `filling of vacancies of members, and all other matters relative to those authorities and other bodies for`
  line `which it may be necessary or desirable to provide;`
  line
  line `(c) the appointment, powers and duties of the officers of the University and their emoluments and`
  line `other terms and conditions of service;`
  line
  line `(d) the appointment of teachers of the University and other academic staff and their emoluments`
  line `and other terms and conditions of service;`
  line
  line `(e) the appointment of teachers and other academic staff working in any other University or`
  line `organisation for a specified period for undertaking a joint project;`
  line
  line `(f) the conditions of service of employees including provision for pension, insurance and`
  line `provident fund, the manner of termination of service and disciplinary action;`
  line
  line `(g) the principles governing seniority of service of employees;`
  line
  line `(h) the procedure for arbitration in cases of dispute between employees or students and`
  line `the University;`
  line
  line `(i) the procedure for appeal to the Executive Council by any employee or student against the`
  line `action of any officer or authority of the University;`
  line
  line `(j) the establishment and recognition of Students Union or associations of teachers, academic`
  line `staff or other employees;`
  line
  line `(k) the participation of students in the affairs of the University;`
  line
  line `(l) the conferment of honorary degrees;`
  line
  line `(m) the withdrawal of degrees, diplomas, certificates and other academic distinctions;`
  line
  line `(n) the institution of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(o) the maintenance of discipline among the students;`
  line
  line `(p) the establishment and abolition of Schools, Departments, Halls, Colleges and Institutions;`
  line
  line `(q) the extent of autonomy which a College, Institution or Department may have and the matters`
  line `in relation to which such autonomy may be exercised;`
  line
  line `(r) the delegation of powers vested in the authorities or officers of the University; and`
  line
  line `(s) all other matters which by this Act are to be, or may be, provided by the Statutes.`
obj_root_law_sections_24_footnotes:
  string
  line
obj_root_law_sections_25:
  sectionId (23979)
  sectionNo (25)
  orderNo 25
  title `Statutes how made.`
  content obj_root_law_sections_25_content
  footnotes obj_root_law_sections_25_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23979&sectionno=25&orderno=25&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_25_content:
  string
  line `(1) The first Statutes are those set out in the Schedule.`
  line
  line `(2) The Executive Council may, from time to time, make new or additional Statutes or may amend or`
  line `repeal the Statutes referred to in the sub-section (1):`
  line
  line `Provided that the Executive Council shall not make, amend or repal any Statute affecting the status,`
  line `powers or constitution of any authority of the University until such authority has been given an`
  line `opportunity of expressing an opinion in writing on the proposed changes, and any opinion so expressed`
  line `shall be considered by the Executive Council.`
  line
  line `(3) Every new Statute or addition to the Statutes or any amendment or repeal of a Statute shall require`
  line `the approval of the Visitor who may assent thereto or withhold assent or remit the same to the Executive`
  line `Council for consideration.`
  line
  line `(4) A new Statute or a Statute amending or repealing an existing Statute shall have no validity unless`
  line `it has been assented to by the Visitor.`
  line
  line `(5) Notwithstanding anything contained in the foregoing sub-sections, the Visitor may make new or`
  line `additional Statutes or amend or repeal the Statutes referred to in sub-section (1) during the period of three`
  line `years immediately after the commencement of this Act:`
  line
  line `Provided that the Visitor may, on the expiry of the said period of three years make, within one year`
  line `from the date of such expiry, such detailed Statutes as he may consider necessary and such detailed`
  line `Statutes shall be laid before both Houses of Parliament.`
obj_root_law_sections_25_footnotes:
  string
  line
obj_root_law_sections_26:
  sectionId (23980)
  sectionNo (26)
  orderNo 26
  title Ordinances.
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23980&sectionno=26&orderno=26&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_26_content:
  string
  line `(1) Subject to the provisions of this Act and the Statutes, the Ordinances may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the admission of students to the University and their enrolment as such;`
  line
  line `(b) the courses of study to be laid down for all degrees, diplomas and certificates of the`
  line University;
  line
  line `(c) the award of degrees, diplomas, certificates and other academic distinctions, the qualifications`
  line `for the same and the means to be taken relating to the granting and obtaining of the same;`
  line
  line `(d) the fees to be charged for courses of study in the University and for admission to the`
  line `examinations, degrees and diplomas of the University;`
  line
  line `(e) the conditions of award of fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(f) the conduct of examinations, including the term of office and of appointment and the duties of`
  line `examining bodies, examiners and moderators;`
  line
  line `(g) the conditions of residence of the students of the University;`
  line
  line `(h) the special arrangements, if any, which may be made for the residence, discipline and teaching`
  line `of women students and the prescribing of special courses of studies for them;`
  line
  line `(i) the appointment and emoluments of employees other than those for whom provision has`
  line `been made in the Statutes;`
  line
  line `(j) the establishment of Centres of Studies, Boards of Studies, Special Centres, Specialised`
  line `Laboratories and other Committees;`
  line
  line `(k) the terms and conditions of the recognition of Institutions of higher learning and its`
  line withdrawal;
  line
  line `(l) the terms and conditions on which persons working in any recognised Institution or in`
  line `any Institution associated with the University may be recognised as teachers and for`
  line `withdrawing such recognition;`
  line
  line `(m) the manner of co-operation or collaboration or association with other Universities, authorities`
  line `or Institutions of higher learning;`
  line
  line `(n) the creation, composition and functions of any other body which is considered necessary for`
  line `improving the academic life of the University;`
  line
  line `(o) such other terms and conditions of service of teachers and other academic staff as are not`
  line `prescribed by the Statutes;`
  line
  line `(p) the management of Colleges and Institutions established by the University; and`
  line
  line `(q) all other matters which by this Act or the Statutes may be provided for by the Ordinances.`
  line
  line `(2) The first Ordinances shall be made by the Vice-Chancellor with the previous approval of the`
  line `Central Government and the Ordinances so made may be amended, repealed or added to at any time by`
  line `the Executive Council in the manner prescribed by the Statutes.`
obj_root_law_sections_26_footnotes:
  string
  line
obj_root_law_sections_27:
  sectionId (23981)
  sectionNo (27)
  orderNo 27
  title Regulations.
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23981&sectionno=27&orderno=27&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_27_content:
  string
  line `^1[(1)]The authorities of the University may make Regulations consistent with this`
  line `Act, the Statutes and the Ordinances for the conduct of their own business and that of the Committees`
  line `appointed by them and not provided for by this Act, the Statutes or the Ordinances in the manner`
  line `prescribed by the Statutes.`
  line
  line ^2
  line `[(2) Every Statute, Ordinance or Regulation made under this Act shall be published in the Official`
  line Gazette.
  line
  line `(3) Every Statute, Ordinance or Regulation made under this Act shall be laid, as soon as may be after`
  line `it is made, before each House of Parliament, while it is in session, for a total period of thirty days which`
  line `may be comprised in one session or in two or more successive sessions, and if, before the expiry of the`
  line `session immediately following the session or the successive sessions aforesaid, both Houses agree in`
  line `making any modification in the Statute, Ordinance or Regulation or both Houses agree that the Statute,`
  line `Ordinance or Regulation should not be made, the Statute, Ordinance or Regulation shall thereafter have`
  line `effect only in such modified form or be of no effect, as the case may be; so, however that any such`
  line `modification or annulment shall be without prejudice to the validity of anything previously done under`
  line `that Statute, Ordinance or Regulation.]`
obj_root_law_sections_27_footnotes:
  string
  line `1. Section 27 re-numbered as sub-section (1) thereof by Act 4 of 2005, s. 2 and the Schedule (w.e.f. 11-1-2005).`
  line
  line `2. Ins. by s. 2 and the Schedule, ibid. (w.e.f. 11-1-2005).`
obj_root_law_sections_28:
  sectionId (23982)
  sectionNo (28)
  orderNo 28
  title `Annual report.`
  content obj_root_law_sections_28_content
  footnotes `1. Ins. by Act 25 of 2008, s. 10 (w.e.f. 5-12-2008).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23982&sectionno=28&orderno=28&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_28_content:
  string
  line `(1) The annual report of the University shall be prepared under the direction of`
  line `the Executive Council and shall be submitted to the Court on or after such date as may be prescribed by`
  line `the Statutes and the Court shall consider the report in its annual meeting.`
  line
  line `(2) The Court shall submit the annual report to the Visitor along with its comments, if any.`
  line
  line ^3
  line `[(3) A copy of the annual report, as prepared under sub-section (1), shall also be submitted to the`
  line `Central Government, which shall, as soon as may be, cause the same to be laid before both Houses of`
  line Parliament.]
obj_root_law_sections_29:
  sectionId (23983)
  sectionNo (29)
  orderNo 29
  title `Annual accounts.`
  content obj_root_law_sections_29_content
  footnotes obj_root_law_sections_29_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23983&sectionno=29&orderno=29&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_29_content:
  string
  line `(1) The annual accounts and balance-sheet of the University shall be`
  line `prepared under the directions of the Executive Council and shall once at least every year and at interevals`
  line `of not more than fifteen months be audited by the Comptroller and Auditor-General of India.`
  line
  line `(2) The annual accounts when audited shall be published in the Gazette of India and a copy of the`
  line `accounts together with the report of the Comptroller and Auditor-General shall be submitted to the Court`
  line `and the Visitor along with the observations of the Executive Council.`
  line
  line `(3) Any observations made by the Visitor on the annual accounts shall be brought to the notice of the`
  line `Court and the observations of the Court, if any, shall, after being considered by the Executive Council,`
  line `be submitted to the Visitor.`
  line
  line `(4) A copy of the accounts together with the report of the Comptroller and Auditor-General of India,`
  line `as submitted to the Visitor, shall also be submitted to the Central Government who shall, as soon as may`
  line `be, cause the same to be laid before both Houses of Parliament.`
obj_root_law_sections_29_footnotes:
  string
  line
obj_root_law_sections_30:
  sectionId (23984)
  sectionNo (30)
  orderNo 30
  title `Conditions of service of employees.`
  content obj_root_law_sections_30_content
  footnotes obj_root_law_sections_30_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23984&sectionno=30&orderno=30&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_30_content:
  string
  line `(1) Every employee shall be appointed under a written`
  line `contract which shall be lodged with the University and a copy of which shall be furnished to the employee`
  line concerned.
  line
  line `(2) Any dispute arising out of a contract between the University and any employee shall, at the`
  line `request of the employee, be referred to a Tribunal of Arbitration consisting of one member appointed by`
  line `the Executive Council, one member nominated by the employee concerned and an umpire appointed by`
  line `the Visitor. The decision of the Tribunal shall be final, and no suit shall lie in any civil Court in respect of the matters decided by the Tribunal. Every such request shall be deemed to be a submission to arbitration,`
  line `upon the terms of this section, within the meaning of the Arbitration Act, 1940 (2 of 1940).`
obj_root_law_sections_30_footnotes:
  string
  line
obj_root_law_sections_31:
  sectionId (23985)
  sectionNo (31)
  orderNo 31
  title `Procedure of appeal and arbitration in disciplinary cases against students.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23985&sectionno=31&orderno=31&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_31_content:
  string
  line `(1) Any student`
  line `or candidate for an examination whose name has been removed from the rolls of the University by the`
  line `orders or resolution of the Vice-Chancellor, Discipline Committee or Examination Committee, as the case`
  line `may be, and who has been debarred from appearing at the examinations of the University for more than`
  line `one year, may, within ten days of the date of receipt of such orders or copy of such resolution by him,`
  line `appeal to the Executive Council and the Executive Council may confirm, modify or reverse the decision`
  line `of the Vice-Chancellor or the committee, as the case may be.`
  line
  line `(2) Any dispute arising out of any disciplinary action taken by the University against a student shall,`
  line `at the request of such student, be referred to a Tribunal of Arbitration and the provisions of`
  line `sub-section (2) of section 30 shall, as far as may be, apply to a reference made under this sub-section.`
obj_root_law_sections_31_footnotes:
  string
  line
obj_root_law_sections_32:
  sectionId (23986)
  sectionNo (32)
  orderNo 32
  title `Right to appeal.`
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23986&sectionno=32&orderno=32&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_32_content:
  string
  line `Every employee or student of the University shall, notwithstanding anything`
  line `contained in this Act, have a right to appeal, within such time as may be prescribed by the Statutes, to the`
  line `Executive Council against the decision of any officer or authority of the University and thereupon the`
  line `Executive Council may confirm, modify or reverse the decision appealed against.`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_33:
  sectionId (23987)
  sectionNo (33)
  orderNo 33
  title `Provident and pension funds.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23987&sectionno=33&orderno=33&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_33_content:
  string
  line `(1) The University shall constitute for the benefit of its`
  line `employees such pension or provident fund or provide such insurance schemes as it may deem fit in such`
  line `manner and subject to such conditions as may be prescribed by the Statutes.`
  line
  line `(2) Where such provident or pension fund has been so constituted, the Central Government may`
  line `declare that the provisions of the Provident Funds Act, 1925 (19 of 1925), shall apply to such fund, as if it`
  line `were a Government provident fund.`
obj_root_law_sections_33_footnotes:
  string
  line
obj_root_law_sections_34:
  sectionId (23988)
  sectionNo (34)
  orderNo 34
  title `Disputes as to constitution of University authorities and bodies.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23988&sectionno=34&orderno=34&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_34_content:
  string
  line `If any question arises as to`
  line `whether any person has been duly elected or appointed as, or is entitled to be, a member of any authority`
  line `or other body of the University, the matter shall be referred to the Visitor whose decision thereon shall be`
  line final.
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_35:
  sectionId (23989)
  sectionNo (35)
  orderNo 35
  title `Constitution of Committees.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23989&sectionno=35&orderno=35&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_35_content:
  string
  line `Where any authority of the University is given power by this Act`
  line `or the Statutes to appoint Committees, such Committees shall, save as otherwise provided, consist of the`
  line `members of the authority concerned and of such other persons (if any) as the authority in each case may`
  line `think fit.`
obj_root_law_sections_35_footnotes:
  string
  line
obj_root_law_sections_36:
  sectionId (23990)
  sectionNo (36)
  orderNo 36
  title `Filling of casual vacancies.`
  content obj_root_law_sections_36_content
  footnotes obj_root_law_sections_36_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23990&sectionno=36&orderno=36&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_36_content:
  string
  line `All casual vacancies among the members (other than ex officio`
  line `Members) of any authority or other body of the University shall be filled, as soon as conveniently may be,`
  line `by the person or body who appointed, elected or co-opted the member whose place has become vacant`
  line `and the person appointed, elected or co-opted to a casual vacancy shall be member of such authority or`
  line `body for the residue of the term for which the person whose place he fills would have been a member.`
obj_root_law_sections_36_footnotes:
  string
  line
obj_root_law_sections_37:
  sectionId (23991)
  sectionNo (37)
  orderNo 37
  title `Proceedings of University authorities or bodies not invalidated by vacancies.`
  content obj_root_law_sections_37_content
  footnotes obj_root_law_sections_37_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23991&sectionno=37&orderno=37&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_37_content:
  string
  line `No act or`
  line `proceedings of any authority or other body of the University shall be invalid merely by reason of the`
  line `existence of a vacancy or vacancies among its members.`
obj_root_law_sections_37_footnotes:
  string
  line
obj_root_law_sections_38:
  sectionId (23992)
  sectionNo (38)
  orderNo 38
  title `Protection of action taken in good faith.`
  content obj_root_law_sections_38_content
  footnotes obj_root_law_sections_38_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23992&sectionno=38&orderno=38&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_38_content:
  string
  line `No suit or other legal proceeding shall lie against any`
  line `officer or employee of the University for anything which is in good faith done or intended to be done in`
  line `pursuance of any of the provisions of this Act, the Statutes or Ordinances.`
obj_root_law_sections_38_footnotes:
  string
  line
obj_root_law_sections_39:
  sectionId (23993)
  sectionNo (39)
  orderNo 39
  title `Mode of proof of University record.`
  content obj_root_law_sections_39_content
  footnotes obj_root_law_sections_39_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23993&sectionno=39&orderno=39&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_39_content:
  string
  line `A copy of any receipt, application, notice, order,`
  line `proceeding, resolution of any authority or Committee of the University, or other documents in possession`
  line `of the University or any entry in any register duly maintained by the University, if certified by the`
  line `Registrar, shall be received as prima facie evidence of such receipt, application, notice, order, proceeding`
  line `or resolution, documents or the existence of entry in the register and shall be admitted as evidence of the matters and transactions therein where the original thereof would, if produced, have been admissible in`
  line `evidence, notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872) or in any`
  line `other law for the time being in force.`
obj_root_law_sections_39_footnotes:
  string
  line
obj_root_law_sections_40:
  sectionId (23994)
  sectionNo (40)
  orderNo 40
  title `Power to remove difficulties.`
  content obj_root_law_sections_40_content
  footnotes obj_root_law_sections_40_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23994&sectionno=40&orderno=40&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_40_content:
  string
  line `If any difficulty arises in giving effect to the provisions of this`
  line `Act, the Central Government may, by order published in the Official Gazette, make such provisions, not`
  line `inconsistent with the provisions of this Act, as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no such order shall be made under this section after the expiry of three years from the`
  line `commencement of this Act.`
obj_root_law_sections_40_footnotes:
  string
  line
obj_root_law_sections_41:
  sectionId (23995)
  sectionNo (41)
  orderNo 41
  title `Transitional provisions.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00004_197439_1517807320322&sectionId=23995&sectionno=41&orderno=41&orgactid=AC_CEN_9_30_00004_197439_1517807320322
obj_root_law_sections_41_content:
  string
  line `Notwithstanding anything contained in this Act and the Statutes--`
  line
  line `(a) the first Chancellor and the First Vice-Chancellor shall be appointed by the Visitor and each`
  line `of the said officers shall hold office for a term of five years;`
  line
  line `(b) the first Registrar and the first Finance Officer shall be appointed by the Visitor and each of`
  line `the said officers shall hold office for a term of three years;`
  line
  line `(c) the first Court and the first Executive Council shall consist of not more than thirty members`
  line `and eleven members respectively, who shall be nominated by the Visitor and shall hold office for a`
  line `term of three years;`
  line
  line `(d) the Academic Council shall consist of not more than twenty-one members, who shall be`
  line `nominated by the Visitor and shall hold office for a term of three years:`
  line
  line `Provided that if any vacancy occurs in the above offices or authorities, the same shall be filled by`
  line `appointment or nomination, as the case may be, by the Visitor, and the person so appointed or`
  line `nominated shall hold office for so long as the officer or member in whose place he is appointed or`
  line `nominated would have held office, if such vacancy had not occurred.`
  line
  line `(e) the first Academic Council shall be constituted on the expiry of a period of one year from the`
  line `commencement of this Act and during the said period of one year, the powers of the Academic`
  line `Council shall be performed by the Planning Board constituted under section 23.`
obj_root_law_sections_41_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
