obj_root_law:
  slug the-transplantation-of-human-organs-and-tissues-act-1994
  handle (1962)
  collectionHandle 123456789/1362
  title `The Transplantation of Human Organs and Tissues Act, 1994`
  actNumber (42)
  enactmentDate 1994-07-08
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1962`
  sources obj_root_law_sources
  sections obj_root_law_sections
  actYear (1994)
  ministry `Ministry of Health and Family Welfare`
  department `Department of Health and Family Welfare`
  longTitle `An Act to provide for the regulation of removal, storage and transplantation of human organs and tissues for therapeutic purposes and for the prevention of commercial dealings in human organs and tissues and for matters connected therewith or incidental thereto.`
  enforcementDate 04-02-1995
  notification `4th February, 1995, vide Notification No. S.O. 80(E), dated the 4th February, 1995, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
