obj_root_law_sections_1:
  sectionId (90951)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90951&sectionno=1&orderno=1&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Post Office Act, 2023.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 18th June, 2024, vide notification No. S.O. 2352(E), dated, 17th day of June, 2024, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii).`
obj_root_law_sections_2:
  sectionId (90952)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90952&sectionno=2&orderno=2&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) “Director General” means the Director General of Postal Services appointed by the Central`
  line `Government and includes any officer authorised by the Central Government to perform the duties of`
  line `the Director General;`
  line
  line `(b) “item” means an indivisible article which the Post Office accepts for providing a service;`
  line
  line `(c) “notification” means a notification published in the Official Gazette;`
  line
  line `(d) “Post Office” means the Department of Posts and includes every house, building, room, place`
  line `or any other asset used by the Post Office for providing any service;`
  line
  line `(e) “prescribe” means prescribe by rules made under this Act and the expression “prescribed”`
  line `shall be construed accordingly;`
  line
  line `(f) “regulations” means the regulations made under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (90953)
  sectionNo (3)
  orderNo 3
  title `Services to be provided by Post Office.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90953&sectionno=3&orderno=3&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_3_content:
  string
  line `(1) The Post Office shall provide such services as the`
  line `Central Government may prescribe.`
  line
  line `(2) The Director General may make regulations--`
  line
  line `(a) in respect of activities necessary to provide services referred to in sub-section (1); and`
  line
  line `(b) to fix charges for, and the terms and conditions in respect of, services referred to in`
  line `sub-section (1).`
  line
  line `(3) Any service provided by the Post Office shall be subject to any other law for the time being in`
  line force.
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (90954)
  sectionNo (4)
  orderNo 4
  title `Exclusive privilege in respect of postage stamps.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90954&sectionno=4&orderno=4&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_4_content:
  string
  line `(1) The Post Office shall have the exclusive`
  line `privilege of issuing postage stamps.`
  line
  line `(2) The Director General may make regulations relating to the supply and sale of postage stamps and`
  line `postal stationery.`
  line
  line `(3) In this section, the expressions—`
  line
  line `(a) “postage stamp” means any stamp provided by the Central Government, in any form, physical`
  line `or digital, for denoting sums payable in respect of such service provided by the Post Office, as may be`
  line `prescribed and includes stamps affixed, printed, embossed, embedded, impressed, or otherwise`
  line `indicated on an item;`
  line
  line `(b) “postal stationery” means stationery, issued by the Post Office such as envelopes, letter cards,`
  line `postcards, bearing imprinted stamps or inscriptions indicating that sum payable in respect of a service`
  line `provided by the Post Office has been prepaid.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (90955)
  sectionNo (5)
  orderNo 5
  title `Addresses and postcodes.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90955&sectionno=5&orderno=5&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_5_content:
  string
  line `(1) The Central Government may prescribe standards for addressing`
  line `on the items, address identifiers and usage of postcodes.`
  line
  line `(2) In this section, “postcode” means a series of digits, letters or digital code or a combination of`
  line `digits, letters or digital code used to identify a geographic area or location, and ease the process of sorting`
  line `and delivery of items and for other purposes.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (90956)
  sectionNo (6)
  orderNo 6
  title `Power to give effect to arrangements with other countries.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90956&sectionno=6&orderno=6&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_6_content:
  string
  line `The Central Government may`
  line `make rules to give effect to arrangements made with any foreign country or territory for services provided`
  line `by the Post Office between India and the said foreign country or territory`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (90957)
  sectionNo (7)
  orderNo 7
  title `Recovery of sums due in respect of services provided by Post Office.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90957&sectionno=7&orderno=7&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_7_content:
  string
  line `(1) Every person who`
  line `avails a service provided by the Post Office shall be liable to pay the charges in respect of such service.`
  line
  line `(2) If any person refuses or neglects to pay the charges referred to in sub-section (1), such amount`
  line `shall be recoverable as if it were an arrear of land revenue due from him.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (90958)
  sectionNo (8)
  orderNo 8
  title `Official mark to be evidence of certain facts denoted.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90958&sectionno=8&orderno=8&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_8_content:
  string
  line `The Central Government may prescribe`
  line `the conditions for denoting the official marks on items to be used as prima facie evidence of the facts so`
  line denoted.
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (90959)
  sectionNo (9)
  orderNo 9
  title `Power to intercept, open or detain any item or deliver item to customs authority.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90959&sectionno=9&orderno=9&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_9_content:
  string
  line `(1) The`
  line `Central Government may, by notification, empower any officer to cause any item in course of`
  line `transmission by the Post Office to be intercepted, opened or detained in the interest of the security of the`
  line `State, friendly relations with foreign states, public order, emergency, or public safety or upon the`
  line `occurrence of any contravention of any of the provisions of this Act or any other law for the time being in`
  line force.
  line
  line `(2) The Central Government may cause any item referred to in sub-section (1) to be disposed of in`
  line `such manner as it deems appropriate.`
  line
  line `(3) The Central Government may, by notification, empower any officer of the Post Office to deliver`
  line `an item, received from within or beyond the limits of India and reckoned to contain anything liable to`
  line `duty or which is suspected to contain any prohibited item to such customs authority or any other authority`
  line `as may be specified in the said notification, and such customs authority or any other authority shall deal`
  line `with such item in accordance with the provisions of any law for the time being in force.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (90960)
  sectionNo (10)
  orderNo 10
  title `Exemption from liability.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90960&sectionno=10&orderno=10&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_10_content:
  string
  line `(1) Notwithstanding anything in any other law for the time being in`
  line `force, the Post Office shall not incur any liability except such liability as may be prescribed with regard to`
  line `a service provided by the Post Office.`
  line
  line `(2) No officer of the Post Office shall incur any liability with regard to a service provided by the Post`
  line `Office, unless the officer has acted fraudulently or wilfully caused loss, delay or mis-delivery of service.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (90961)
  sectionNo (11)
  orderNo 11
  title `Delegation of power, other than rulemaking powers to Director General.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90961&sectionno=11&orderno=11&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_11_content:
  string
  line `The Central`
  line `Government may, by notification, authorise, either absolutely or subject to conditions, the Director`
  line `General to exercise any of the powers conferred upon the Central Government by this Act, other than the`
  line `power to make rules.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (90962)
  sectionNo (12)
  orderNo 12
  title `Power to make rules.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90962&sectionno=12&orderno=12&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_12_content:
  string
  line `The Central Government may, by notification, make rules for carrying`
  line `out the purposes of this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (90963)
  sectionNo (13)
  orderNo 13
  title `Power to make regulations.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90963&sectionno=13&orderno=13&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_13_content:
  string
  line `The Director General may, with the prior approval of the Central`
  line `Government, by notification, make regulations for carrying out the provisions of this Act.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (90964)
  sectionNo (14)
  orderNo 14
  title `Laying of rules and regulations in Parliament.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90964&sectionno=14&orderno=14&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_14_content:
  string
  line `Every rule or regulation made under this Act`
  line `shall be laid, as soon as may be after it is made, before each House of Parliament, while it is in session,`
  line `for a total period of thirty days which may be comprised in one session or in two or more successive`
  line `sessions, and if, before the expiry of the session immediately following the session or the successive`
  line `sessions aforesaid, both Houses agree in making any modification in the rule or regulation or both Houses`
  line `agree that the rule or regulation should not be made, the rule or regulation shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or annulment shall be without prejudice to the validity of anything previously done under that rule or`
  line regulation.
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (90965)
  sectionNo (15)
  orderNo 15
  title `Power to remove difficulties.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90965&sectionno=15&orderno=15&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_15_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order in the Official Gazette, make such provisions not`
  line `inconsistent with the provisions of this Act as appear to it to be necessary or expedient for removing the`
  line `difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of two years from the date of`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (90966)
  sectionNo (16)
  orderNo 16
  title `Repeal and savings.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_37_95_00003_2023-43_1718954617340&sectionId=90966&sectionno=16&orderno=16&orgactid=AC_CEN_37_95_00003_2023-43_1718954617340
obj_root_law_sections_16_content:
  string
  line `(1) The Indian Post Office Act, 1898 (6 of 1898) is hereby repealed.`
  line
  line `(2) Notwithstanding the repeal of the Act by sub-section (1), all rules, notifications and orders, made`
  line `or purported to have been made under the Indian Post Office Act, 1898 (6 of 1898), shall, in so far as they`
  line `relate to matters for which provision is made in this Act and are not inconsistent therewith, be deemed to`
  line `have been made under this Act and shall continue in force unless and until they are superseded by any`
  line `rules or notification or order made under this Act.`
obj_root_law_sections_16_footnotes:
  string
  line
