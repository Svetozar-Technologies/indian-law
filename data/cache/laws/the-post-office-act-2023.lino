obj_root_law_translations_hi_sections_1:
  kind ocr-page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
  ocrLanguages hin+eng
obj_root_law_translations_hi_sections_1_content:
  string
  line `अनुभाग ।क] भारत का राजपत्र असाधारण 233`
  line `डाकघर अधिनियम, 2023`
  line `(2023 का अधिनियम संख्यांक 43)`
  line `[24 दिसम्बर, 2023]`
  line `भारत में डाकघर से संबदूध विधि का समेकन और`
  line `संशोधन करने तथा उससे संबंधित या उसके`
  line `आनुष॑गिक विषयों का उपबंध`
  line `करने के लिए`
  line अधिनियम
  line `भारत गणराज्य के चाौँहत्तरवें वर्ष में संसद्‌ द्वारा निम्नलिखित रूप में यह`
  line `अधिनियमित हो :--`
  line `4. (|) इस अधिनियम का संक्षिप्त नाम डाकघर अधिनियम, 2023 है । संक्षिप्त aw`
  line `(2) यह उस तारीख को प्रवृत्त होगा, जो केंद्रीय सरकार, राजपत्र में अधिसूचना और प्रारंभ |`
  line `दूवारा, नियत करे |`
  line `2. इस अधिनियम में, जब तक कि संदर्भ से अन्यथा अपेक्षित न हो,-- परिभाषाएं |`
  line `(क) “महानिदेशक” से केंद्रीय सरकार द्वारा नियुक्त डाक सेवा महानिदेशक`
  line `अभिप्रेत है और इसके अंतर्गत केंद्रीय सरकार द्वारा महानिदेशक के कर्तव्यों का`
  line `निर्वहन करने के लिए प्राधिकृत कोई अधिकारी भी सम्मिलित है ;`
obj_root_law_translations_hi_sections_1_footnotes:
