  (str title) (str `The Police-Forces (Restriction of Rights) Act, 1966`)
  (str actNumber) (str 33)
  (str enactmentDate) (str 1966-12-02)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1704`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `पुलिस बल (अधिकारों का निर्बन्‍धन) अधिनियम, 1966`)
  (str actYear) (str 1966)
  (str ministry) (str `Ministry of Home Affairs`)
  (str department) (str `Department of Internal Security`)
  (str longTitle) (str `An Act to provide for the restriction of certain rights conferred by Part III of the Constitution in their application to the members of the Forces charged with the maintenance of public order so as to ensure the proper discharge of their duties and the maintenance of discipline among them.`)
  (str enforcementDate) (str 03-12-1966)
  (str notification) (str `3rd December, 1966, vide notification No. G.S.R. 1848, dated 3rd December, 1966, in respect of the Union territory of Delhi, see Gazette of India, Extraordinary, Part II, sec. 3(i). 2. 1st August, 1967, vide notification No. S.O. 1122(E), dated 20th July, 1967, in respect of the Union territories of Andaman and Nicobar Islands, Chandigarh, see Gazette of India, Extraordinary, Part II, sec. 3(ii). 3. 4th September, 1967, vide Panjab Govt. notification No. S.O. 67 C. A. 33/66/S. 1/67, dated 2nd, September, 1967, in respect of the State of Panjab, see Gazette of India, Extraordinary.`)
  (str fetchedAt) (str `2026-05-08T23:22:07.845Z`)
