  object
  (str slug) (str the-indira-gandhi-national-open-university-act-1985)
  (str handle) (str 1850)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Indira Gandhi National Open University Act, 1985`)
  (str actNumber) (str 50)
  (str enactmentDate) (str 1985-09-02)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1850`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `इन्‍दिरा गांधी राष्‍ट्रीय मुक्‍त विश्‍वविद्यालय अधिनियम, 1985`)
  (str actYear) (str 1985)
  (str ministry) (str `Ministry of Education`)
  (str department) (str `Department of Higher Education`)
  (str longTitle) (str `An Act to establish and incorporate an open University at the national level for the introduction and promotion of the open university and distance education systems in the educational pattern of the country and for the co-ordination and determination of standards in such systems.`)
  (str enforcementDate) (str 20-09-1985)
  (str notification) (str `20th September, 1985, vide notification No. S.O. 678(E), dated 19th September, 1985, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
