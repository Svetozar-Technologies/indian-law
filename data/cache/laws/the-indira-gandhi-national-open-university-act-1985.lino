obj_root_law:
  slug the-indira-gandhi-national-open-university-act-1985
  handle (1850)
  collectionHandle 123456789/1362
  title `The Indira Gandhi National Open University Act, 1985`
  actNumber (50)
  enactmentDate 1985-09-02
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1850`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `इन्‍दिरा गांधी राष्‍ट्रीय मुक्‍त विश्‍वविद्यालय अधिनियम, 1985`
  actYear (1985)
  ministry `Ministry of Education`
  department `Department of Higher Education`
  longTitle `An Act to establish and incorporate an open University at the national level for the introduction and promotion of the open university and distance education systems in the educational pattern of the country and for the co-ordination and determination of standards in such systems.`
  enforcementDate 20-09-1985
  notification `20th September, 1985, vide notification No. S.O. 678(E), dated 19th September, 1985, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T19:32:35.152Z`
  translations obj_root_law_translations
