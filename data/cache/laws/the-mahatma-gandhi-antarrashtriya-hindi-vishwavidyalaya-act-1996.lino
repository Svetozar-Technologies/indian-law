obj_root_law:
  slug the-mahatma-gandhi-antarrashtriya-hindi-vishwavidyalaya-act-1996
  handle (1987)
  collectionHandle 123456789/1362
  title `The Mahatma Gandhi Antarrashtriya Hindi Vishwavidyalaya Act, 1996`
  actNumber (03)
  enactmentDate 1997-01-08
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1987`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `महात्‍मा गांधी अन्‍तरराष्‍ट्रीय हिन्‍दी विश्‍वविद्यालय अधिनियम, 1996`
  actYear (1997)
  ministry `Ministry of Education`
  department `Department of Higher Education`
  longTitle `An Act to establish and incorporate a teaching University for the promotion and development of Hindi language and literature, through teaching and research, with a view to enabling Hindi to achieve greater functional efficiency and recognition as a major international language and to provide for matters connected therewith or incidental thereto.`
  enforcementDate 29-12-1997
  notification `29th December, 1997, vide notification No. S.O. 912(E), dated 29th November, 1997, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T23:04:04.052Z`
