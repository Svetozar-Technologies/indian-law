obj_root_law_sections_1:
  sectionId (36397)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36397&sectionno=1&orderno=1&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Religious Institutions (Prevention of Misuse) Act, 1988.`
  line
  line `(2) It extends to the whole of India ^1***.`
  line
  line `(3) It shall be deemed to have come into force on the 26th day of May, 1988.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule`
  line `(w.e.f. 31-10-2019).`
obj_root_law_sections_2:
  sectionId (36398)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36398&sectionno=2&orderno=2&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "ammunition" shall have the same meaning as in clause (b) of sub-section (1) of section2`
  line `of the Arms Act, 1959 (54 of 1959);`
  line
  line `(b) "arms" shall have the same meaning as in clause (c) of sub-section (1) of section 2 of the`
  line `Arms Act, 1959 (54 of 1959);`
  line
  line `(c) "manager", in relation to a religious institution, means every person, including any`
  line `religious functionary (by whatever name called), who, for the time being, either alone or in`
  line `association with other persons, administers, manages or otherwise controls the affairs of that`
  line `institution, its functions or properties;`
  line
  line `(d) "political activity" includes any activity promoting or propagating the aims or objects of`
  line `a political party or any cause, issue or question of a political nature by organising meetings,`
  line `demonstrations, processions, collection or disbursement of funds, or by the issue of directions or`
  line `decrees, or by any other means, and includes also such activity by or on behalf of a person`
  line `seeking election as a candidate for any election to Parliament, any State Legislature or any local`
  line authority;
  line
  line `(e) "political party" means an association or body of persons—`
  line
  line `(i) which is, or is deemed to be, registered, with the Election Commission of India as a`
  line `political party under the Election Symbols (Reservation and Allotment) Order, 1968, as in`
  line `force for the time being; or`
  line
  line `(ii) which has set up candidates for election to any legislature, but is not registered, or`
  line `deemed to be registered, as a political party, under the Election Symbols (Reservation and`
  line `Allotment) Order, 1968; or`
  line
  line `(iii) organised to carry on any political activity or to acquire or exercise political power`
  line `through election or otherwise;`
  line
  line `(f) "religious institution" means an institution for the promotion of any religion or`
  line `persuasion, and includes any place or premises used as a place of public religious worship, by`
  line `whatever name or designation known.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (36399)
  sectionNo (3)
  orderNo 3
  title `Prohibition of use of religious institutions for certain purposes.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36399&sectionno=3&orderno=3&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_3_content:
  string
  line `No religious institution`
  line `or manager thereof shall use or allow the use of any premises belonging to, or under the control of,`
  line `the institution—`
  line
  line `(a) for the promotion or propagation of any political activity; or`
  line
  line `(b) for the harbouring of any person accused or convicted of an offence under any law for the`
  line `time being in force; or`
  line
  line `(c) for the storing of any arms or ammunition; or`
  line
  line `(d) for keeping any goods or articles in contravention of any law for the time being in force;`
  line or
  line
  line `(e) for erecting or putting up of any construction or fortification, including basements,`
  line `bunkers, towers or walls without a valid licence or permission under any law for the time being`
  line `in force; or`
  line
  line `(f) for the carrying on of any unlawful or subversive act prohibited under any law for the`
  line `time being in force or in contravention of any order made by any court; or`
  line
  line `(g) for the doing of any act which promotes or attempts to promote disharmony or feelings of`
  line `enmity, hatred or ill-will between different religious, racial, language or regional groups or castes`
  line `or communities; or`
  line
  line `(h) for the carrying on of any activity prejudicial to the sovereignty, unity and integrity of`
  line `India; or`
  line
  line `(i) for the doing of any act in contravention of the provisions of the Prevention of Insults to`
  line `National Honour Act, 1971 (69 of1971).`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (36400)
  sectionNo (4)
  orderNo 4
  title `Restrictions on carrying arms and ammunition into a religious institution.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36400&sectionno=4&orderno=4&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_4_content:
  string
  line `No religious`
  line `institution or manager thereof shall allow the entry of any arms or ammunition or of any person`
  line `carrying any arms or ammunition into the religious institution:`
  line
  line `Provided that nothing in this section shall apply to—`
  line
  line `(a) the wearing and carrying of a Kirpan by any person professing the Sikh religion; or`
  line
  line `(b) any arms which are used, as part of any religious ceremony or ritual of the institution as`
  line `established by custom or usage.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (36401)
  sectionNo (5)
  orderNo 5
  title `Prohibition of use of funds of religious institutions for certain activities.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36401&sectionno=5&orderno=5&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_5_content:
  string
  line `No religious`
  line `institution or manager thereof shall use or allow the use of any funds or other properties belonging`
  line `to, or under the control of, the institution for the benefit of any political party or for the purpose of`
  line `any political activity or for the commission of any act which is punishable as an offence under any`
  line law.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (36402)
  sectionNo (6)
  orderNo 6
  title `Prohibition of religious for a for propagating political ideas.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36402&sectionno=6&orderno=6&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_6_content:
  string
  line `No religious institution or`
  line `manager thereof shall allow any ceremony, festival, congregation, procession or assembly organised`
  line `or held under its auspices to be used for any political activity.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (36403)
  sectionNo (7)
  orderNo 7
  title Penalties.
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36403&sectionno=7&orderno=7&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_7_content:
  string
  line `Where any religious institution or manager thereof contravenes the provisions of`
  line `section 3, section 4, section 5 or section 6, the manager and every person connected with such`
  line `contravention shall be punishable with imprisonment for a term which may extend to five years and`
  line `with fine which may extend to ten thousand rupees.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (36404)
  sectionNo (8)
  orderNo 8
  title `Disqualification of persons convicted or charge-sheeted under this Act.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36404&sectionno=8&orderno=8&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_8_content:
  string
  line `(1) Any manager`
  line `or other employee of a religious institution shall, upon conviction for an offence under this Act, stand`
  line `removed from his office or post and shall, notwithstanding anything to the contrary contained in any`
  line `other law, be disqualified for appointment in any religious institution as manager or in any other`
  line `capacity for a period of six years from the date of his conviction.`
  line
  line `(2) Where any manager or other employee of a religious institution is accused of an offence`
  line `under this Act and a charge-sheet for the prosecution of such person is filed in any court and the`
  line `court is of the opinion, after considering the charge-sheet and after hearing the prosecution and the`
  line `accused, that a prima facie case exists, it shall pass an order or direction restraining the person from`
  line `exercising the powers or discharging the duties of his office or post pending trial.`
  line
  line `(3) Where any manager or other employee has been removed under sub-section (1), or restrained`
  line `under sub-section (2), the vacancy arising out of such removal or restraint may be filled in the`
  line `manner provided in the law applicable to the said religious institution.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (36405)
  sectionNo (9)
  orderNo 9
  title `Certain persons bound to give information to police.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36405&sectionno=9&orderno=9&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_9_content:
  string
  line `Every manager or other employee of`
  line `a religious institution shall be bound to give information to the officer incharge of the police station`
  line `within whose local jurisdiction the religious institution is situate of any contravention or any`
  line `impending contravention of the provisions of this Act and any failure to do so shall be punishable`
  line `under section 176 of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (36406)
  sectionNo (10)
  orderNo 10
  title `Repeal and saving.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_24_00019_198841_1517807326149&sectionId=36406&sectionno=10&orderno=10&orgactid=AC_CEN_5_24_00019_198841_1517807326149
obj_root_law_sections_10_content:
  string
  line `(1) The Religious Institutions (Prevention of Misuse) Ordinance, 1988`
  line `(Ord. 3 of 1988) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance`
  line `shall be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_10_footnotes:
  string
  line
