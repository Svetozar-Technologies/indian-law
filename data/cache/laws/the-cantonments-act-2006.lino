obj_root_law_translations_hi_sections_8_content:
  string
  line viii
  line `िा राएं`
  line `जि, जि धनकास और अन्य कनेश न`
  line `198. तार, कनेश न आदद धबछाने की बोर्त की शधत।`
  line `199. िूधम की सतह के ऊपर धबछाए गए तार, आदद।`
  line `200. अनुज्ञा के धबना मेन से कनेश न का न दकया जाना।`
  line `201. फेरूि धवधहत करने तिा मीटर िगाने आदद की श धत।`
  line `202. धनरीिण करने की शधत।`
  line `203. रेट और प्र िार धनयत करने की शधत।`
  line `इस अध्या य का सरकारी जि प्र दायों को िागू होना`
  line `204. सरकारी जि प्र दाय।`
  line `205. घरेिू खपत के धिए जि प्र दाय।`
  line `206. प्र िारों की वसूिी।`
  line `207. सरकारी जि प्र दाय से बोर्त को जि का प्र दाय।`
  line `208. प्र पुंज प्र दाय के धवतरण के संबंि में बोर्त के कृत् य।`
  line `209. नाधियों और मि नाधियों से संबंधित धवशेष उपबंि 210. नाधियों और मि संग्रहण और धनपटान संकमों का सधन्न मातण`
  line `और धनयंत्रण।`
  line `210. नाधियों और मि संग्रहण और धनपटान संकमों का सधन्न मातण और धनयं त्र ण।`
  line `211. कधतपय पदािों का छावनी नाधियों में न र् ािा जाना।`
  line `212. स् वा धमयों और अधििोधगयों द्व ारा छावनी नािी से नािी जोडने के धिए आवेदन।`
  line `213. नािी रधहत पररसरों से जि की धनकासी।`
  line `214. नए पररसरों का नाधियों के धबना न बनाया जाना।`
  line `215. पररसरों के समूह या ब् िा क से संयुत संदक्रयाओं द्व ारा जि धनकास करने की शधत।`
  line `216. कधतपय दशाओं में प्र ाइवेट नाधियों को बन् द करने या उनका उपयोग सीधमत करने की शधत।`
  line `217. स् वा मी से धिन् न व् य धत द्व ारा नािी का उपयोग।`
  line `218. मि नाधियों और वषात जि नाधियों का पृिक् - पृिक् होना।`
  line `219. संतोषप्रद जि धनकास के धिए कधतपय संकमों का धनष्पा दन करने की स् वा मी से अपेिा करने की शधत।`
  line `220. नाधियों के धगरने और मि संग्रह के स् िा न धनयत करना। प्र`
  line कीणत
  line `221. अनुज्ञा के धबना दकसी जि संकमत और नाधियों से कनेश न न ददया जाना।`
  line `222. नाधियों या जि संकमों के ऊपर दकसी िवन, रेि और प्र ाइवेट पि का अनुज्ञा के धबना बनाया या धनर्मतत न दकया`
  line जाना।
  line `223. जिवाही सेतुओं, िाइनों, आदद के धिए सम्प धि के उपयोग के अधिकार।`
  line `224. अन्य व् य धत यों की िूधम से होकर पाइप और नाधियां र् ािने की पररसर के स् वा मी की शधत।`
  line `225. रेि की सतह, आदद को ऊंचा या नीचा करने की अपेिा करने की शधत।`
  line `226. दाधयत्वा िीन व् य धत को सूचना देने के पश्चा त् कायत का धनष्पा दन करने की शधत।`
  line `227. नाधियों या मि - कुंर्ों के संवातन के धिए शाफ्ट आदद िगाने की शधत।`
  line `228. ऐसी नाधियों, आदद की जांच और परीिण करने की शधत, धजनकी बाबत यह धवश्वा स है दक वे त्रु रटपूणत हैं।`
obj_root_law_translations_hi_sections_8_footnotes:
  string
  line
obj_root_law_translations_hi_sections_9:
  kind page
  sectionId pdf-page-9
  sectionNo (9)
  orderNo 9
  title `Page 9`
  content obj_root_law_translations_hi_sections_9_content
  footnotes obj_root_law_translations_hi_sections_9_footnotes
  sourcePage 9
obj_root_law_translations_hi_sections_9_content:
  string
  line ix
  line `िा राएं`
  line `229. बोर्त द्व ारा मि का िोक पररदान।`
  line `230. मरम्म त, आदद के धिए सरकारी अधिकरणों का धनयोजन।`
  line `231. कायत का अनुज्ञप् त निसाज द्व ारा दकया जाना।`
  line `232. कधत पय कायों का प्र धतषेि।`
  line `अध्या य 10`
  line `नगर योजना और िवनों आदद पर धनयंत्रण`
  line `233. िूधम उपयोग योजना तैयार करना।`
  line `234. िवन बनाने के धिए मंजूरी।`
  line `235. नए िवनों संबंिी सूचना।`
  line `236. धवधिमान्य सूचना की शतें।`
  line `237. कुछ िाराओं के अिीन बोर्त की शधत यों का मुख्य का यतपािक अधिकारी द्व ारा प्र योग दकया जाना।`
  line `238. मंजूरी देने या नामंजूर करने की बोर्त की शधत।`
  line `239. कधतपय मामिों में िवन धनमातण या संकमत को रोकने या हटाई गई चीजों के व् य यन का आदेश।`
  line `240. अधतसंकुिन आदद की सािारण स् की म की मंजूरी देने की शधत।`
  line `241. प्र धतकर।`
  line `242. पूरा करने की सूचना।`
  line `243. मंजूरी का व् य पगत होना।`
  line `244. िवनों के उपयोग पर धनबंिन।`
  line `245. िवन को पूरा करने के धिए कािावधि।`
  line `246. पूरा होने का प्र माणपत्र।`
  line `247. अवैि धनमातण और पुन: धनमातण।`
  line `248. िवन धनमातण या पुन: धनमातण रोकने या उसे ढा देने की शधत।`
  line `249. अप्राधिकृत संरचनाओं को सीि बंद करने की शधत।`
  line `250. कधतपय मामिों में न् या याियों द्व ारा कायतवाधहयों का ग्र हण न दकया जाना।`
  line `251. उपधवधियां बनाने की शधत।`
  line `252. ऐसी संरचनाओं या दफ स रों का प्र धतषेि जो गधियों में बािा करती है।`
  line `253. ना धियों आदद पर अनाधिकृत िवन।`
  line `254. नािी और मि नाधियों से कनेश न।`
  line `255. िैम्पों और अन्य उपसािनों के धिए िैदकट िगाने की शधत।`
  line `256. सडक का रख - रखाव।`
  line पि
  line `257. पि, िूधम आदद का अस्िा यी दखि।`
  line `258. पिों को बन् द करना और खोिना।`
  line `259. पिों के नाम और िवनों की संख्या।`
  line `260. सामूधहक आवास स् की में।`
obj_root_law_translations_hi_sections_9_footnotes:
  string
  line
obj_root_law_translations_hi_sections_10:
  kind page
  sectionId pdf-page-10
  sectionNo (10)
  orderNo 10
  title `Page 10`
  content obj_root_law_translations_hi_sections_10_content
  footnotes obj_root_law_translations_hi_sections_10_footnotes
  sourcePage 10
obj_root_law_translations_hi_sections_10_content:
  string
  line x
  line `िा राएं`
  line `261. सीमा दीवारें, झाडबन्दी और बाडें।`
  line `262. वृिों का धगराया जाना, शाखों का काटा जाना और उनकी छंटाई करना।`
  line `263. सावतजधनक िूधम की खुदाई।`
  line `264. िूधम का अनुधचत उपयोग।`
  line `अध्या य 11`
  line `बाजार, विशािाएं, व् या पार और व् य वसाय`
  line `265. िोक बाजार और विशािाएं।`
  line `266. िोक बाजार का उपयोग।`
  line `267. िोक नीिाम आदद द्व ारा अन्त रण करने की शधत।`
  line `268. तहबाजारी, िाटक आदद का प्र काधशत दकया जाना।`
  line `269. प्र ाइवेट बाजार और विशािाएं।`
  line `270. प्र ाइवेट बाजार या विशािा के धिए अनुज्ञधप्त के ददए जा ने की शतें।`
  line `271. अनुज्ञधप्त आदद के धबना बाजार या विशािा चिाने के धिए शाधस्त।`
  line `272. अननुज्ञप् त बाजार या विशािा का उपयोग करने के धिए शाधस्त।`
  line `273. विशािा के उपयोग का प्र धतषेि और धनबतन्ि न।`
  line `274. विशािाओं का धनरीिण करने के शधत।`
  line `275. कधतपय दक्रया किापों को धवधनयधमत करने की शधत। व्`
  line `या पार और व् य वसाय`
  line `276. कपडे िोने के स् िा नों का उपबन्ि।`
  line `277. कधतपय व् य वसाय चिाए जाने के धिए अनुज्ञधप्त यों का आवश्य क होना।`
  line `278. अनुज्ञधप्त यों के उल्िं घन में उपयोग दकए जाने वािे पररसरों के उपयोग को रोकने की शधत।`
  line `279. वे शतें जो अनुज्ञधप्त यों से संिग्न की जा सकेंगी।`
  line `सािारण उपबन्ि`
  line `280. अनुज्ञधप्त में फेरफार करने की शधत।`
  line `281. अनुज्ञधप्त के धबना अिवा िारा 280 के उल्िं घन में व् या पार आदद का दकया जाना।`
  line `282. पशुओं को कूडा करकट आदद पर चराना। प्र`
  line `वेश, धनरीिण और अधिग्रहण`
  line `283. प्र वेश और अधिग्रहण की शधत यां।`
  line `पशु और मांस का आयात`
  line `284. पशु और मांस का आयात।`
  line `अध्या य 12`
  line `आसव धिकर और मादक औषधि`
  line `285. आसव धिकर और मादक रव्य का अप्राधिकृत धवक्रय।`
  line `286. आसव धिकर का अप्राधिकृत कब्जा।`
obj_root_law_translations_hi_sections_10_footnotes:
  string
  line
obj_root_law_translations_hi_sections_11:
  kind page
  sectionId pdf-page-11
  sectionNo (11)
  orderNo 11
  title `Page 11`
  content obj_root_law_translations_hi_sections_11_content
  footnotes obj_root_law_translations_hi_sections_11_footnotes
  sourcePage 11
obj_root_law_translations_hi_sections_11_content:
  string
  line xi
  line `िा राएं`
  line `287. दो अंधतम पूवत गामी िाराओं के धवरुद्ध अपरािों के धिए व् य धत यों की धगरफ्तारी तिा वस्तु ओं का अधिग्रहण और`
  line अधिहरण।
  line `288. धचदकत्सी य प्र योजनों के धिए बेची गई या प्र दाय की गई वस्तु ओं की व् या वृधि।`
  line `अध्या य 13`
  line `सावतजधनक सुरिा तिा न् यू सेंसों का दमन`
  line `सािारण न् यू सेंस`
  line `289. न् यू सेंस काररत करने के धिए शाधस्त।`
  line कुिे
  line `290. कुिों का रधजस्री करण और उन पर धनयंत्रण।`
  line यातायात
  line `291. सडक मागत के यातायात के धनयम।`
  line `अधग्न, आदद का रोकना`
  line `292. ज् व िनशीि सामधग्रयों का धनमातण प्र योजनों के धिए उपयोग।`
  line `293. ज् व िनशीि सामधग्रयों का ढेर िगाना या संग्रह करना।`
  line `294. खुिी बधियों की देखिाि।`
  line `295. चिधचत्रों और नाटकों के प्रस् तु तीकरण का धवधनयमन।`
  line `296. आधतशबाजी, अग् न्या युि आदद को छोडना।`
  line `297. िवनों, कुओं आदद को सुरधित रखने की अपेिा करने की शधत।`
  line `298. जो उजाड िूधम अनुधचत प्र यो जनों के धिए काम में िाई जा रही है उसमें बाड िगाना।`
  line `अध्या य 14`
  line `छावधनयों में से धनकािना और अपवर्जतत करना तिा िैंधगक दुराचार का दमन`
  line `299. वेश्या गृहों को बन् द कर देने और वेश् या ओं को धनकाि देने की शधत।`
  line `300. वेश्या वृधि के प्र योजनों के धिए चक र काटना और अधतयाचना करना।`
  line `301. व् य धत यों का छावनी से धनकाि ददया जाना।`
  line `302. धवच्छृं खि व् य धत यों का छावनी से धनकािा जाना और अपवजतन।`
  line `303. राजरोही व् य धत यों का छावनी में से धनकािा जाना और छावनी से अपवजतन।`
  line `304. शाधस्त।`
  line `अध्या य 15`
  line `शध त यां, प्र दक्र या, शाधस्त यां और अपीिें प्र`
  line `वेश और धनरीिण`
  line `305. प्र वेश करने की शधत यां।`
  line `306. धनरीिण करने की बोर्त के सदस्य की शधत।`
  line `307. धनरीिण आदद की शधत।`
  line `308. धजस िूधम में काम चि रहा है उसकी पाश्वत स् ि िूधम में प्र वेश करने की शधत।`
  line `309. पररसर में ब िपूवतक प्र वेश करना।`
obj_root_law_translations_hi_sections_11_footnotes:
  string
  line
obj_root_law_translations_hi_sections_12:
  kind page
  sectionId pdf-page-12
  sectionNo (12)
  orderNo 12
  title `Page 12`
  content obj_root_law_translations_hi_sections_12_content
  footnotes obj_root_law_translations_hi_sections_12_footnotes
  sourcePage 12
obj_root_law_translations_hi_sections_12_content:
  string
  line xii
  line `िा राएं`
  line `310. ददन के समय प्र वेश का दकया जाना।`
  line `311. स् वा मी की सम्म धत का मामूिी तौर पर अधिप्राप्त दकया जाना।`
  line `312. सामाधजक और िार्मतक प्र िाओं का ध् या न रखा जाना।`
  line `313. बािा र् ािने के धिए शाधस्त।`
  line `पुधिस अधिकाररयों की शधत यां और कततव्य`
  line `314. वारंट के धबना धगरफ्तारी।`
  line `315. पुधिस अधिकाररयों के कततव्य।`
  line सूचनाएं
  line `316. सूचनाओं में युधत युत समय का धनयत दकया जाना।`
  line `317. बोर्त द्व ारा धनकािी गई सूचना का अधिप्रमाणीकरण और धवधिमान्य ता।`
  line `318. सूचना, आदद की तामीि।`
  line `319. सूचना देने की रीधत।`
  line `320. सूचना आदद के अननुपािन की दशा में बोर्त की शधत 321. दखिकार द्व ारा स् वा मी को, जब वह सूचना का अनुपािन`
  line `कर रहा हो, बािा न पहंचाना।`
  line `321. दखिकार द्व ारा स् वा मी को, जब वह सूचना का अनुपािन कर रहा हो, बािा न पहंचाना।`
  line `िनराधश की वसूिी`
  line `322. स् वा मी द्व ारा व् य धतक्रम दकए जाने की दशा में अदायगी करने का दखिकार का दाधयत्व।`
  line `323. अधिकतातओं या न् या धसयों की अवमुधत।`
  line `324. वसूिी की रीधत।`
  line `माध्य स् ि म् सधमधतयां`
  line `325. माध्य स् ि म् सधमधत के धिए आवेदन।`
  line `326. माध्य स् ि म् सधमधत संयोधजत करने की प्र दक्रया।`
  line `327. माध्य स् ि म् सधमधत का गठन।`
  line `328. ऐसे दकसी व् य धत को नामधनर्दतष्ट न दकया जाना जो प्रत् य ित: धहतबद्ध है या धजसकी सेवाएं अधविम्ब उपिब्ि`
  line `नहीं हैं।`
  line `329. माध्य स् ि म् सधमधतयों के अधिवेशन और शधत यां।`
  line `330. माध्य स् ि म् सधमधतयों के धवधनश्च य।`
  line `अधियो जन`
  line `331. अधियोजन।`
  line `332. अपराि का शमन।`
  line `सािारण शाधस्त धवषयक उपबन्ि`
  line `333. सािारण शाधस्त।`
  line `334. कम्प धनयों द्व ारा अपराि।`
  line `335. अनुज्ञधप्त यों आदद का रद्द दकया जाना या उनका धनिम्ब न।`
  line `336. छावनी सम्प धि को हए नुकसान की बाबत देय रकम की वसूिी।`
obj_root_law_translations_hi_sections_12_footnotes:
  string
  line
obj_root_law_translations_hi_sections_13:
  kind page
  sectionId pdf-page-13
  sectionNo (13)
  orderNo 13
  title `Page 13`
  content obj_root_law_translations_hi_sections_13_content
  footnotes obj_root_law_translations_hi_sections_13_footnotes
  sourcePage 13
obj_root_law_translations_hi_sections_13_content:
  string
  line xiii
  line `िा राएं`
  line `पररसी माकाि`
  line `337. अधियोजन के धिए पररसीमाकाि।`
  line वाद
  line `338. बोर्त आदद की कारतवाई के धिए संरिण।`
  line `339. वादों की सूचना का ददया जाना।`
  line `अपीि और पुनरीिण`
  line `340. कायतपािकीय आदेशों के धवरुद्ध अपीिें।`
  line `341. अपीि की अजी।`
  line `342. अपीि के िधम्ब त रहने तक कारतवाई का धनिम्ब न।`
  line `343. पुनरीिण।`
  line `344. अपीिीय आदेशों की अंधतमता।`
  line `345. अपीिािी का सुनवाई का अधिकार।`
  line `अध्या य 16`
  line `धनयम और उपधवधियां`
  line `346. धनयम बनाने की शधत।`
  line `347. धनयमों धवषयक अनुपूरक उपबन्ि।`
  line `348. उपधवधियां बनाने की शधत।`
  line `349. उपधवधियों के िंग के धिए शाधस्त।`
  line `350. उपधवधियां और धवधनयमों के संबंि में अनुपूरक उपबन्ि बनाने की शधत।`
  line `351. धनयमों और उपधवधियों का धनरीिण और खरीदे जाने के धिए उपिभ् य रहना।`
  line `अध्या य 17`
  line `अनुपूरक उपबन्ि`
  line `352. इस अधिधनयम के और धनयमों के कधतपय उपबन्िों का छावनी के बाहर के स् िा नों पर धवस्ता र।`
  line `353. प्र िान, आदद को कृत्यों को प्रत् या योधजत करने की शधत।`
  line `354. रधजस्री करण।`
  line `355. सूचनाओं और अन्य दस्ता वेजों की धवधिमान्य ता।`
  line `356. दस्ता वेज या प्र धवधष्ट की सायय के रू प में ग्र ाह्यता।`
  line `357. बोर्त के अधिकारी या सेवक द्व ारा सायय।`
  line `35 8. 1899 के अधिधनयम 4 का िागू होना।`
  line `359. करठनाइयों को दूर करने की शधत।`
  line `360. धनरसन और व् या वृधियां।`
  line `पहिी अनुसूची।`
  line `दूसरी अनुसूची।`
  line `तीसरी अनुसूची।`
  line `चौिी अनुसूची।`
  line `पांचवीं अनुसूची।`
obj_root_law_translations_hi_sections_13_footnotes:
