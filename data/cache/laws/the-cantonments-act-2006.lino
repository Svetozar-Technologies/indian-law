obj_root_law_translations_hi_sections_1:
  kind page
  sectionId pdf-page-1
  sectionNo (1)
  orderNo 1
  title `Page 1`
  content obj_root_law_translations_hi_sections_1_content
  footnotes obj_root_law_translations_hi_sections_1_footnotes
  sourcePage 1
obj_root_law_translations_hi_sections_1_content:
  string
  line `छावनी अधिधनयम, 2006`
  line _________
  line `िाराओं का क्र म`
  line _________
  line `िा राएं`
  line `अध्याय 1 प्र`
  line ारंधिक
  line `1. संधिप् त नाम, धवस्तार और प्र ारम्ि।`
  line `2. पररिाषाएं।`
  line `अध्याय 2`
  line `छावधनयों की पररिाषा और उनका पररसीमन`
  line `3. छावधनयों की पररिाषा।`
  line `4. छावधनयों की सीमाओं का पररवततन।`
  line `5. िेत्र को छावनी में सधम्मधित करने का प्र िाव।`
  line `6. जब िेत्र छावनी नहीं रह जाता तब छावनी धनधि और छावनी धवकास धनधि का व्य यन।`
  line `7. जब कोई िेत्र छावनी में सधम्मधित नहीं रह जाता तब छावनी धनधि और छावनी धवकास धनधि का व्य यन।`
  line `8. िारा 6 और िारा 7 के अिीन अंतररत धनधियों और सम्पधि का उपयोजन।`
  line `9. अधिधनयम के प्र वततन की पररसीमा।`
  line `अध्याय 3`
  line `छावनी बोर्त`
  line बोर्त
  line `10. छावनी बोर्त।`
  line `11. छावनी बोर्त का धनगमन।`
  line `12. छावनी बोर्ों का गठन।`
  line `13. धवशेष पररधस्िधतयों में बोर्ों के गठन में फेरफार करने की शधत।`
  line `14. सदस्यों की पदावधि।`
  line `15. रर धत यों का िरा जाना।`
  line `16. धवशेष दशाओं में ररधत यां।`
  line `17. शपि या प्र धतज्ञान।`
  line `18. त् यागपत्र।`
  line `19. अध्यि और उपाध्यि।`
  line `20. उपाध्यि की पदावधि।`
  line `21. अध्यि के कततव्य।`
  line `22. उपाध्यि के कततव्य।`
  line `23. उपाध्यि और सदस्यों को ििे।`
  line `24. मुख्य कायतपािक अधिकारी की धनयुधत।`
obj_root_law_translations_hi_sections_1_footnotes:
  string
  line
obj_root_law_translations_hi_sections_2:
  kind page
  sectionId pdf-page-2
  sectionNo (2)
  orderNo 2
  title `Page 2`
  content obj_root_law_translations_hi_sections_2_content
  footnotes obj_root_law_translations_hi_sections_2_footnotes
  sourcePage 2
obj_root_law_translations_hi_sections_2_content:
  string
  line ii
  line `िा राएं`
  line `25. मुख्य कायतपािक अधिकारी के कततव्य।`
  line `26. मुख्य कायतपािक अधिकारी की धवशेष शधत।`
  line धनवातचन
  line `27. धनवातचक नामाविी।`
  line `28. धनवातचकों की अहतता।`
  line `29. बोर्त का सदस्य होने के धिए अहतता।`
  line `30. धनवातचन।`
  line `31. धनवातचनों के धवधनयम न के धिए धनयम बनाने की शधत।`
  line सदस्य
  line `32. धजस बात में सदस्य धहतबद्ध है उस पर उसके द्व ारा मत न ददया जाना।`
  line `33. सदस्यों का दाधयत्व।`
  line `34. सदस्यों का हटाया जाना।`
  line `35. हटाए जाने के पररणाम।`
  line `36. बोर्त के सदस्य का िोक सेवक समझा जाना।`
  line कमतचारी
  line `37. बोर्त के कमतचा री के रू प में व्य धत की धनरहतता।`
  line `38. छावनी के कमतचाररयों को िोक सेवक समझा जाना। प्र`
  line दक्रया
  line `39. अधिवेशन।`
  line `40. संव्यवहृत दकया जाने वािा कामकाज।`
  line `41. गणपूर्तत।`
  line `42. पीठासीन अधिकारी।`
  line `43. कायतवृि।`
  line `44. अधिवेशनों का सावतजधनक होना।`
  line `45. प्रश् नों पर धवधन श् च य करने की रीधत।`
  line `46. धसधवि िेत्र।`
  line `47. धसधवि िेत्रों के धिए सधमधतयां।`
  line `48. धवधनयम बनाने की शधत।`
  line `49. अन्य स् िानीय प्र ाधिकारी के साि संयुत कारतवाई।`
  line `50. प्र शासन धवषयक ररपोटत।`
  line धनयंत्रण
  line `51. दस्तावेजों के पेश दकए जाने की अपेिा करने की केन्री य सरकार की शधत।`
  line `52. धनरीिण।`
  line `53. दस्तावेज मांगने की शधत।`
  line `54. संकमत आदद का धनष्पादन अपेधित करने की शधत।`
obj_root_law_translations_hi_sections_2_footnotes:
  string
  line
obj_root_law_translations_hi_sections_3:
  kind page
  sectionId pdf-page-3
  sectionNo (3)
  orderNo 3
  title `Page 3`
  content obj_root_law_translations_hi_sections_3_content
  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line iii
  line `िा राएं`
  line `55. िारा 54 के अिीन ददए गए धनदेश का प्र वततन करने के धिए उपबन्ि करने की शधत।`
  line `56. बोर्त के धवधनश्च य को अध्यारोही करने की श धत।`
  line `57. केन्रीय सरकार की पुनर्वतिोकन की शधत।`
  line `58. िारा 56 के अिीन या अन्यिा दकए गए धनदेश के बारे में कमान के मुख्य समादेशक अधिकारी की शधत।`
  line `59. िारा 56 के अिीन दकए गए धनदेश के बारे में केन्रीय सरकार की शधत।`
  line `60. बोर्त का अधिक्रमण।`
  line `कायत वाधहयों की धवधिमान्यता`
  line `61. कायतवाधहयों आदद की धवधिमान्यता।`
  line `अध्याय 4`
  line `बोर्त के कततव्य और वैवेदकक कृत्य`
  line `62. बोर्त के कततव्य।`
  line `63. सम्पधि का प्र बन्ि करने की शधत।`
  line `64. बोर्त के वैवेदकक कृत्य।`
  line `65. छावनी के बाहर शैधिक, स् वास््य संबंिी और अन्य प्र यो जनों के धिए व्य य करने की शधत।`
  line `अध्याय 5`
  line `कर और फीस`
  line `करािान का अधिरोपण`
  line `66. करािान की सािारण शधत।`
  line `67. फीस का प्र िारण।`
  line `68. सम्पधि कर के मानदंर्।`
  line `69. प्र ारंधिक प्रस् िापनाओं का तैयार दकया जाना।`
  line `70. आिेप और उनका धनपटारा।`
  line `71. कर का अधिरोपण।`
  line `72. केन्री य सरकार की बोर्त को धनदेश जारी कराने की शधत।`
  line `73. “ वार्षतक आनुपाधतक मूल्य ” की पररिाषा।`
  line `74. करों का िार।`
  line `धनिातरण सूची`
  line `75. धनिातरण सूची।`
  line `76. धनिातरण सूची का पुनरीिण 77. धनिातरण सूची का अधिप्रमाणीकरण।`
  line `77. धनिातरण सूची का अधिप्रमाणीकरण।`
  line `78. धनिातरण सूची का साधययक महत्व।`
  line `79. धनिातरण सूची का संशोिन।`
  line `80. नई धनिातरण सूची तैयार करना।`
  line `81. अन्तरणों की सूचना।`
  line `82. िवनों के पररधनमातण की सूचना।`
