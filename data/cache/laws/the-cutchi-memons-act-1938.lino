obj_root_law_sections_1:
  object
  (str sectionId) (str 29813)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and commencement.`)
  (str content) (str `(1) This Act may be called the Cutchi Memons Act, 1938.

(2) It shall come into force on the 1st day of November, 1938.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00075_193810_1535002780703&sectionId=29813&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00075_193810_1535002780703)
obj_root_law_sections_2:
  object
  (str sectionId) (str 29814)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Cutchi Memons to be governed in certain matters by Muhammadan Law.`)
  (str content) (str `Subject to the
provisions of section 3, all Cutchi Memons shall, in matters of succession and inheritance, be governed by
the Muhammadan Law.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00075_193810_1535002780703&sectionId=29814&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00075_193810_1535002780703)
obj_root_law_sections_3:
  object
  (str sectionId) (str 29815)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str Savings.)
  (str content) (str `Nothing in this Act shall affect any right or liability acquired or incurred before its
commencement, or any legal proceeding or remedy in respect of any such right or liability; and any such
legal proceeding or remedy may be continued or enforced as if this Act had not been passed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00075_193810_1535002780703&sectionId=29815&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00075_193810_1535002780703)
