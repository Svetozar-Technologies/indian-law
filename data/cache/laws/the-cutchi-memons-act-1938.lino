  sectionId (29816)
  sectionNo (4)
  orderNo 4
  title Repealed.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00075_193810_1535002780703&sectionId=29816&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00075_193810_1535002780703
obj_root_law_sections_4_content:
  string
  line `[Repealed.]--Rep. by the Repealing and Amending Act, 1942`
  line `(25 of 1942), s. 2 and the First`
  line `Schedule (w.e.f. 1-10-1942).`
obj_root_law_sections_4_footnotes:
  string
  line
