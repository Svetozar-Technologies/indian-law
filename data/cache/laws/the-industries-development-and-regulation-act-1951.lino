obj_root_law_sections_28:
  sectionId (14217)
  sectionNo (28)
  orderNo 51
  title `Burden of proof in certain cases.`
  content obj_root_law_sections_28_content
  footnotes `1. Subs. by Act 18 of 2023, s. 2 and Schedule, for "prosecuted" (w.e.f. 12-12-2023).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00006_195165_1517807327166&sectionId=14217&sectionno=28&orderno=51&orgactid=AC_CEN_11_61_00006_195165_1517807327166
obj_root_law_sections_28_content:
  string
  line `^1[28. Burden of proof in certain cases.--Where any person is 1`
  line `^1[imposed penalty] for contravening any`
  line `order made under section 18G which prohibits him from doing an act or being in possession of a thing`
  line `without lawful authority or without a permit, licence or other document, the burden of proving that he has`
  line `such authority, permit, licence or other document shall be on him.`
