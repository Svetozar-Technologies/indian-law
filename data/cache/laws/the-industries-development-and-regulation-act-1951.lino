  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_61_00006_195165_1517807327166&sectionId=14225&sectionno=31&orderno=59&orgactid=AC_CEN_11_61_00006_195165_1517807327166
obj_root_law_sections_31_content:
  string
  line `The provisions of this Act shall be in addition to and`
  line `not, save as otherwise expressly provided in this Act, in derogation of any other Central Act for the time`
  line `being in force, relating to any of the scheduled industries.`
obj_root_law_sections_31_footnotes:
