obj_root_law_sections_1:
  object
  (str sectionId) (str 42970)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str Title.)
  (str content) (str `This Act may be called the Suits Valuation Act, 1887 ^1[and it extends^2
to the
whole of India except the territories which, immediately before the 1st November, 1956,
were comprised in Part B States.]`)
  (str footnotes) (str `1. Added by the Adaptation of Laws (No. 2) Order, 1956.

2. Extended to the Union territory of Jammu and Kashmir and Union territory of Ladakh by Act 34 of 2019, s. 95 and Fifth
Schedule (w.e.f. 31-10-2019).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42970&sectionno=1&orderno=1&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_2:
  object
  (str sectionId) (str 42971)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Extent and commencement of Part I.`)
  (str content) (str `This Part shall extend to such local areas, and
come into force therein on such dates as the ^1[State Government], by notification in the Official
Gazette, directs.^2`)
  (str footnotes) (str `1. Subs. by the Adaption of Laws (No. 2) order, 1956, for "Government of a Part A State or a Part C State".

2. Part I of the Act has, under s. 2, been declared to extend to the Punjab, and to come into force therein on the 1st day of
March, 1889, see Gazette of India, 1889, Pt. I, p. 107.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42971&sectionno=2&orderno=2&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_3:
  object
  (str sectionId) (str 42972)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Power of State Government to make rules determining value of land for jurisdictional purposes.`)
  (str content) (str `(1) The State Government may ^1*** make rules for determining
the value of land for purposes of jurisdiction in the suits mentioned in the Court-fees
Act, 1870 (7 of 1870), section 7, paragraphs v and vi, and paragraph x, clause (d).

(2) The rules may determine the value of any class of land, or of any interest in land, in the
whole or any part of a local area, and may prescribe different values for different places within
the same local area.`)
  (str footnotes) (str `1. The words "subject to the control of the G. G. in C." rep. by the A.O. 1937.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42972&sectionno=3&orderno=3&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_4:
  object
  (str sectionId) (str 42973)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Valuation of relief in certain suits relating to land not to exceed the value of the land.`)
  (str content) (str `Where a suit mentioned in the Court-fees Act, 1870 (7 of 1870), section 7, paragraph
iv, or Schedule II, article 17, relates to land or an interest in land of whi ch the value has
been determined by rules under the last foregoing section, the amount at which for purposes
of jurisdiction the relief sought in the suit is valued shall not exceed the value of the land or
interest as determined by those rules.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42973&sectionno=4&orderno=4&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_5:
  object
  (str sectionId) (str 42974)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Making and enforcement of rules.`)
  (str content) (str `(1) The State Government shall, before making rules under
section 3, consult the High Court with respect thereto.

(2) A rule under that section shall not take effect till the expiration of one month after
the rule has been published in the Official Gazette.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42974&sectionno=5&orderno=5&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_6:
  object
  (str sectionId) (str 42975)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Repeal of section 14 of the Madras Civil Courts Act, 1873.`)
  (str content) (str `On and from the date
on which rules under section 3 take effect in any part of the territories under the
administration of the Governor of Fort Saint George in Council to which the Madras Civil Courts Act, 1873, (3 of 1873), extends, section 14 of that Act shall be repealed as regards
that part of those territories.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42975&sectionno=6&orderno=6&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_7:
  object
  (str sectionId) (str 42976)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Extent and commencement of Part II.`)
  (str content) (str `This Part ^1*** shall come into force on the first day of
July, 1887.`)
  (str footnotes) (str `1. The words "extends to the whole of India except Part B States and" omitted by the Adaptation of Laws
(No. 2) Order, 1956.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42976&sectionno=7&orderno=7&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_8:
  object
  (str sectionId) (str 42977)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str `Court-fee value and jurisdictional value to be the same in certain suits.`)
  (str content) (str `Where in
suits other than those referred to in the Court-fees Act, 1870 (7 of 1870),
section 7, paragraphs v, vi and ix, and paragraph x, clause (d), court-fees are payable ad
valorem under the Court-fees Act, 1870, the value as determinable for the computation of
court-fees and the value for purposes of jurisdiction shall be the same.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42977&sectionno=8&orderno=8&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_9:
  object
  (str sectionId) (str 42978)
  (str sectionNo) (str 9)
  (str orderNo) (int 9)
  (str title) (str `Determination of value of certain suits by High Court.`)
  (str content) (str `When the subject-matter of
suits of any class, other than suits mentioned in the Court-fees Act, 1870 (7 of 1870),
section 7, paragraphs v and vi, and paragraph x, clause (d), is such that in the opinion of the
High Court it does not admit of being satisfactorily valued, the High Court may, with the
previous sanction of the State Government, direct that suits of that class shall, for the
purposes of the Court-fees Act, 1870, and of this Act and any other enactment for the time
being in force, be treated as if their subject-matter were of such value as the High Court
thinks fit to specify in this behalf.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42978&sectionno=9&orderno=9&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_10:
  object
  (str sectionId) (str 42979)
  (str sectionNo) (str 10)
  (str orderNo) (int 10)
  (str title) (str [Repealed.].)
  (str content) (str `[Repeal of s. 32 of the Punjab Courts Act, 1884 (18 of 1884).] Rep. by the Repealing
and Amending Act, 1891 (12 of 1891), s. 2 and the First Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42979&sectionno=10&orderno=10&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_11:
  object
  (str sectionId) (str 42980)
  (str sectionNo) (str 11)
  (str orderNo) (int 11)
  (str title) (str `Procedure where objection is taken on appeal or revision that a suit or appeal was not properly valued for jurisdictional purposes.`)
  (str content) (str `(1) Notwithstanding anything
in ^1section 578 of the Code of Civil Procedure (14 of 1882), an objection that by reason of
the over-valuation or under-valuation of a suit or appeal a Court of first instance or lower
Appellate Court which had not jurisdiction with respect to the suit or appeal exercised
jurisdiction with respect thereto shall not be entertained by an Appellate Court unless--

(a) the objection was taken in the Court of first instance at or before the
hearing at which issues were first framed and recorded, or in the lower Appellate
Court in the memorandum of appeal to that Court, or

(b) the Appellate Court is satisfied, for reasons to be recorded by it in writing, that
the suit or appeal was over-valued or under-valued, an that the over-valuation or
under-valuation thereof has prejudicially affected the disposal of the s uit or appeal on its
merits.

(2) If the objection was taken in the manner mentioned in clause ( a) of sub-section (1),
but the Appellate Court is not satisfied as to both the matters mentioned in clause ( b) of that
sub-section and has before it the materials necessary for the determination of the other
grounds of appeal to itself, it shall dispose of the appeal as if there had been no defect of jurisdiction in
the Court of first instance or lower Appellate Court.

(3) If the objection was taken in that manner and the Appellate Court is satisfied as to both
those matters and has not those materials before it, it shall proceed to deal with the appeal under
the rules applicable to the Court with respect to the hearing of appeals; but if it remands the suit or
appeal, or frames and refers issues for trial, or requires additional evidence to be taken, it shall
direct its order to a Court competent to entertain the suit or appeal.

(4) The provisions of this section with respect to an Appellate Court shall, so far as they can
be made applicable, apply to a Court exercising revisional jurisdiction under ^2section 622 of the
Code of Civil Procedure (14 of 1882) or other enactment for the time being in force.

(5) This section ^3*** shall come into force on the first day of July, 1887.`)
  (str footnotes) (str `1. See now s. 99 of the Code of Civil Procedure, 1908 (Act 5 of 1908).

2. See now s. 115 of the Code of Civil Procedure, 1908 (Act 5 of 1908).

3. The words "extends to the whole of India except Part B States and" omitted by the Adaptation of Laws (No. 2)
Order, 1956.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42980&sectionno=11&orderno=11&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
obj_root_law_sections_12:
  object
  (str sectionId) (str 42981)
  (str sectionNo) (str 12)
  (str orderNo) (int 12)
  (str title) (str `Proceedings pending at commencement of Part I or Part II.`)
  (str content) (str `Nothing in Part I or Part II shall
be construed to affect the jurisdiction of any Court--

(a) with respect to any suit instituted before rules under Part I applicable to the
valuation of the suit take effect, or Part II has come into force, as the case may be, or

(b) with respect to any appeal arising out of any such suit.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_46_00009_188707_1523273588317&sectionId=42981&sectionno=12&orderno=12&orgactid=AC_CEN_3_46_00009_188707_1523273588317)
