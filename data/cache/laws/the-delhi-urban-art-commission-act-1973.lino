  (str title) (str `The Delhi Urban Art Commission Act, 1973`)
  (str actNumber) (str 01)
  (str enactmentDate) (str 1974-01-01)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1601`)
  (str sources) obj_root_law_sources
