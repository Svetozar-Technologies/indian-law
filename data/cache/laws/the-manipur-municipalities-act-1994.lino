  sectionNo (51)
  orderNo 51
  title `Page 51`
  content obj_root_law_translations_hi_sections_51_content
  footnotes obj_root_law_translations_hi_sections_51_footnotes
  sourcePage 51
obj_root_law_translations_hi_sections_51_content:
  string
  line 51
  line अनुसूची
  line `(िारा 36 देणिए)`
  line `1. नगरीय योजना णजसके अन्त गषत नगर योजना भी है।`
  line `2. भूणम उपयोग का णिणनयमन और भिन णनमाषि।`
  line `3. आर्थषक और सामाणजक णिकास योजना।`
  line `4. सडकें और पुि।`
  line `5. घरेिू, औद्योणगक और िाणिणज्य क प्र योजनों के णिए जि प्र दाय।`
  line `6. िोक स् िा स् ् य, स् ि च् छ ता, सफाई और कूडा - करकट प्र बन्ि न।`
  line `7. अणग्न शमन सेिाएं।`
  line `8. नगरीय िाणनकी, पयाषिरि का संरक्षि और पाररणस्थ णत की आयमों की अणभिृणद्ध।`
  line `9. समाज के दुबषि िगों के, णजसके अन्त गषत णिकिांग और मानणसक रू प से मंद व् य णक् त भी हैं, णहतों की रक्षा।`
  line `10. गन् दी बस्ती सुिा र और प्र ो न् न यन।`
  line `11. नगरीय णनिषनता उन्मू िन।`
  line `12. नगरीय सुि - सुणििाओं और सुणििाओं, जैसे पाकष, उद्यान और िेि के मैदानों की व् य िस्था।`
  line `13. सांस्कृ णतक, शैक्षणिक और सौंदयषपरक आयामों की अणभिृणद्ध।`
  line `14. शि गाडना और कणिस्ता न, शिदाह, म शान और णिद्युत शिदाह गृह।`
  line `15. कां जी हाउस, पशुओं के प्र णत क्रू रता का णनिारि।`
  line `16. जन्म - मरि सांणखय की णजसके अंतगषत जन्म और मृत्यु का रणजस्री करि भी है।`
  line `17. सािषजणनक सुि - सुणििाएं णजनके अन्त गषत सडकों पर प्र काश, पा र् कं ग स् थ ि, बस स् टा प और जन - सुणििाएं भी हैं।`
  line `18. ििशािाओं और चमषशोिन शािाओं का णिणनयमन।`
  line ______
obj_root_law_translations_hi_sections_51_footnotes:
  string
  line
