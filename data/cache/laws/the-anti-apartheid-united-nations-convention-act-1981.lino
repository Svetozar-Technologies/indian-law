obj_root_law_sections_1:
  sectionId (31949)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31949&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00017_198148_1517807326608
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called The Anti-Apartheid (United Nations`
  line `Convention) Act, 1981.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (31950)
  sectionNo (2)
  orderNo 2
  title `Application of the International Convention on the Suppression and Punishment of the Crime of Apartheid.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31950&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00017_198148_1517807326608
obj_root_law_sections_2_content:
  string
  line `(1) Notwithstanding anything to the contrary contained in any other law, such of`
  line `the provisions of the International Convention on the Suppression and Punishment of the Crime of`
  line `Apartheid as are setout in the Schedule shall have the force of law in India.`
  line
  line `(2) The Central Government may, from time to time, by notification in the Official Gazette, amend`
  line `the Schedule in conformity with any amendments, duly made and adopted, of the provisions of the said`
  line `Convention set out therein.`
  line
  line `(3) Every notification issued under sub-section (2) shall be laid, as soon as may be after it is issued,`
  line `before each House of Parliament.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (31951)
  sectionNo (3)
  orderNo 3
  title `Punishment for international criminal responsibility.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31951&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00017_198148_1517807326608
obj_root_law_sections_3_content:
  string
  line `Every person to whom international`
  line `criminal responsibility applies under article III of the said Convention, as set out in the Schedule, shall be`
  line `punished with death, or imprisonment for life, or imprisonment for a term which may extend to ten years,`
  line `and shall also be liable to fine.`
  line
  line `Explanation.--For the purposes of this section, the reference in clause (a) of article III of the said`
  line `Convention to "article II" shall be construed as a reference to the provisions of article II of that`
  line `Convention as set out in the Schedule.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (31952)
  sectionNo (4)
  orderNo 4
  title `Offences by companies, organisations or institutions.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31952&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00017_198148_1517807326608
obj_root_law_sections_4_content:
  string
  line `Where an offence under this Act has`
  line `been committed by a company or an organisation or an institution, every person who, at the time the`
  line `offence was committed, was in charge of, and was responsible to, the company, organisation or`
  line `institution, as the case may be, for the conduct of its business or affairs, shall be deemed to be guilty of`
  line `the offence and shall be liable to be proceeded against and punished accordingly:`
  line
  line `Provided that nothing contained in this section shall render any such person liable to any punishment`
  line `provided in this Act if he proves that the offence was committed without his knowledge or that he`
  line `exercised all due diligence to prevent the commission of such offence.`
  line
  line `Explanation.--For the purposes of this section, "company" means any body corporate and includes a`
  line `firm or other association of individuals.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (31953)
  sectionNo (5)
  orderNo 5
  title `Place of trial.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31953&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00017_198148_1517807326608
obj_root_law_sections_5_content:
  string
  line `Any person committing an offence under section 3 may be tried for the offence in`
  line `any place in which he may be found or in such other place as the Central Government may, by general or`
  line `special order, published in the Official Gazette, direct in this behalf.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (31954)
  sectionNo (6)
  orderNo 6
  title `Previous sanction of the Central Government for arrest or prosecution.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31954&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00017_198148_1517807326608
obj_root_law_sections_6_content:
  string
  line `No person shall be`
  line `arrested or prosecuted in respect of any offence under section 3 except with the previous sanction of the`
  line `Central Government or such officer or authority as may be authorised by that Government by order in`
  line `writing in this behalf.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (31955)
  sectionNo (7)
  orderNo 7
  title `Provisions as to Extradition Act.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31955&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00017_198148_1517807326608
obj_root_law_sections_7_content:
  string
  line `For the purposes of the Extradition Act, 1962 (34 of 1962),`
  line `the offence under section 3 shall not be considered to be an offence of a political character.`
obj_root_law_sections_7_footnotes:
  string
  line
