obj_root_law_sections_1:
  object
  (str sectionId) (str 31949)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title and extent.`)
  (str content) (str `(1) This Act may be called The Anti-Apartheid (United Nations
Convention) Act, 1981.

(2) It extends to the whole of India.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31949&sectionno=1&orderno=1&orgactid=AC_CEN_10_10_00017_198148_1517807326608)
obj_root_law_sections_2:
  object
  (str sectionId) (str 31950)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Application of the International Convention on the Suppression and Punishment of the Crime of Apartheid.`)
  (str content) (str `(1) Notwithstanding anything to the contrary contained in any other law, such of
the provisions of the International Convention on the Suppression and Punishment of the Crime of
Apartheid as are setout in the Schedule shall have the force of law in India.

(2) The Central Government may, from time to time, by notification in the Official Gazette, amend
the Schedule in conformity with any amendments, duly made and adopted, of the provisions of the said
Convention set out therein.

(3) Every notification issued under sub-section (2) shall be laid, as soon as may be after it is issued,
before each House of Parliament.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31950&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00017_198148_1517807326608)
obj_root_law_sections_3:
  object
  (str sectionId) (str 31951)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Punishment for international criminal responsibility.`)
  (str content) (str `Every person to whom international
criminal responsibility applies under article III of the said Convention, as set out in the Schedule, shall be
punished with death, or imprisonment for life, or imprisonment for a term which may extend to ten years,
and shall also be liable to fine.

Explanation.--For the purposes of this section, the reference in clause (a) of article III of the said
Convention to "article II" shall be construed as a reference to the provisions of article II of that
Convention as set out in the Schedule.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31951&sectionno=3&orderno=3&orgactid=AC_CEN_10_10_00017_198148_1517807326608)
obj_root_law_sections_4:
  object
  (str sectionId) (str 31952)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Offences by companies, organisations or institutions.`)
  (str content) (str `Where an offence under this Act has
been committed by a company or an organisation or an institution, every person who, at the time the
offence was committed, was in charge of, and was responsible to, the company, organisation or
institution, as the case may be, for the conduct of its business or affairs, shall be deemed to be guilty of
the offence and shall be liable to be proceeded against and punished accordingly:

Provided that nothing contained in this section shall render any such person liable to any punishment
provided in this Act if he proves that the offence was committed without his knowledge or that he
exercised all due diligence to prevent the commission of such offence.

Explanation.--For the purposes of this section, "company" means any body corporate and includes a
firm or other association of individuals.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31952&sectionno=4&orderno=4&orgactid=AC_CEN_10_10_00017_198148_1517807326608)
obj_root_law_sections_5:
  object
  (str sectionId) (str 31953)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Place of trial.`)
  (str content) (str `Any person committing an offence under section 3 may be tried for the offence in
any place in which he may be found or in such other place as the Central Government may, by general or
special order, published in the Official Gazette, direct in this behalf.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31953&sectionno=5&orderno=5&orgactid=AC_CEN_10_10_00017_198148_1517807326608)
obj_root_law_sections_6:
  object
  (str sectionId) (str 31954)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Previous sanction of the Central Government for arrest or prosecution.`)
  (str content) (str `No person shall be
arrested or prosecuted in respect of any offence under section 3 except with the previous sanction of the
Central Government or such officer or authority as may be authorised by that Government by order in
writing in this behalf.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31954&sectionno=6&orderno=6&orgactid=AC_CEN_10_10_00017_198148_1517807326608)
obj_root_law_sections_7:
  object
  (str sectionId) (str 31955)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Provisions as to Extradition Act.`)
  (str content) (str `For the purposes of the Extradition Act, 1962 (34 of 1962),
the offence under section 3 shall not be considered to be an offence of a political character.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00017_198148_1517807326608&sectionId=31955&sectionno=7&orderno=7&orgactid=AC_CEN_10_10_00017_198148_1517807326608)
