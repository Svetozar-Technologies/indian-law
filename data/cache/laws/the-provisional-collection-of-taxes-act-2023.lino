obj_root_law_sections_1:
  sectionId (80929)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Provisional Collection of Taxes Act, 2023.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202350_1704347596085&sectionId=80929&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00079_202350_1704347596085
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (80930)
  sectionNo (2)
  orderNo 2
  title Definition.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202350_1704347596085&sectionId=80930&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00079_202350_1704347596085
obj_root_law_sections_2_content:
  string
  line `In this Act, a “declared provision” means a provision in a Bill in respect of which a`
  line `declaration has been made under section 3.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (80931)
  sectionNo (3)
  orderNo 3
  title `Power of Central Government to make declaration.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202350_1704347596085&sectionId=80931&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00079_202350_1704347596085
obj_root_law_sections_3_content:
  string
  line `Where a Bill to be introduced in Parliament`
  line `on behalf of the Government provides for the imposition or increase of a duty of customs or excise with or`
  line `without change in tariff classification, the Central Government may cause to be inserted in the Bill a`
  line `declaration that it is expedient in the public interest that any provision of the Bill relating to such imposition`
  line `or increase shall have immediate effect under this Act.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (80932)
  sectionNo (4)
  orderNo 4
  title `Effect of declarations under this Act, and duration thereof.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202350_1704347596085&sectionId=80932&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00079_202350_1704347596085
obj_root_law_sections_4_content:
  string
  line `(1) A declared provision shall have`
  line `the force of law immediately on the expiry of the day on which the Bill containing it is introduced.`
  line
  line `(2) A declared provision shall cease to have the force of law under the provisions of this Act--`
  line
  line `(a) when it comes into operation as an enactment, with or without amendment;`
  line
  line `(b) when the Central Government, in pursuance of a motion passed by Parliament, directs, by`
  line `notification in the Official Gazette, that it shall cease to have the force of law; or`
  line
  line `(c) if it has not already ceased to have the force of law under clause (a) or clause (b), then on the`
  line `expiry of the seventy-fifth day after the day on which the Bill containing it was introduced.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (80933)
  sectionNo (5)
  orderNo 5
  title `Refunds to be made in certain cases.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202350_1704347596085&sectionId=80933&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00079_202350_1704347596085
obj_root_law_sections_5_content:
  string
  line `(1) Where a declared provision comes into operation as an`
  line `enactment in an amended form before the expiry of the seventy-fifth day after the day on which the Bill`
  line `containing it was introduced, refunds shall be made of all duties collected which would not have been`
  line `collected if the provision adopted in the enactment had been the declared provision:`
  line
  line `Provided that the rate at which refunds of any duty may be made under this sub-section shall not exceed`
  line `the difference between the rate of such duty proposed in the declared provision and the rate of such duty in`
  line `force when the Bill was introduced.`
  line
  line `(2) Where a declared provision ceases to have the force of law under clause (b) or clause (c) of`
  line `sub-section (2) of section 4, refunds shall be made of all duties collected which would not have been`
  line `collected if the declaration in respect of it had not been made.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (80934)
  sectionNo (6)
  orderNo 6
  title Repeal.
  content `The Provisional Collection of Taxes Act, 1931(16 of 1931) is hereby repealed.`
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00079_202350_1704347596085&sectionId=80934&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00079_202350_1704347596085
obj_root_law_sections_6_footnotes:
  string
  line
