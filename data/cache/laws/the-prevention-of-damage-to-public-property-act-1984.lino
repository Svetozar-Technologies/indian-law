obj_root_law_sections_1:
  sectionId (37145)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00018_198403_1517807325229&sectionId=37145&sectionno=1&orderno=1&orgactid=AC_CEN_5_23_00018_198403_1517807325229
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Prevention of`
  line `Damage to Public Property Act, 1984.`
  line
  line `(2) It extends to the whole of India ^1***.`
  line
  line `(3) It shall be deemed to have come into force on the 28th day of January, 1984.`
obj_root_law_sections_1_footnotes:
  string
  line `1. The words "except the State of Jammu and Kashmir" omitted by Act 34 of 2019, s. 95 and the Fifth Schedule`
  line `(w.e.f. 31-10-2019).`
obj_root_law_sections_2:
  sectionId (37146)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00018_198403_1517807325229&sectionId=37146&sectionno=2&orderno=2&orgactid=AC_CEN_5_23_00018_198403_1517807325229
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,—`
  line
  line `(a) "mischief" shall have the same meaning as in section 425 of the Indian Penal`
  line `Code (45 of 1860);`
  line
  line `(b) "public property" means any property, whether immovable or movable (including any`
  line `machinery) which is owned by, or in the possession of, or under the control of—`
  line
  line `(i) the Central Government; or`
  line
  line `(ii) any State Government; or`
  line
  line `(iii) any local authority; or`
  line
  line `(iv) any corporation established by, or under, a Central, Provincial or State Act; or`
  line
  line `(v) any company as defined in section 617 of the Companies Act, 1956 (1 of 1956); or`
  line
  line `(vi) any institution, concern or undertaking which the Central Government may, by`
  line `notification in the Official Gazette, specify in this behalf:`
  line
  line `Provided that the Central Government shall not specify any institution, concern or`
  line `undertaking under this sub-clause unless such institution, concern or undertaking is financed`
  line `wholly or substantially by funds provided directly or indirectly by the Central Government or`
  line `by one or more State Governments, or partly by the Central Government and partly by one or`
  line `more State Governments.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (37147)
  sectionNo (3)
  orderNo 3
  title `Mischief causing damage to public property.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00018_198403_1517807325229&sectionId=37147&sectionno=3&orderno=3&orgactid=AC_CEN_5_23_00018_198403_1517807325229
obj_root_law_sections_3_content:
  string
  line `(1) Whoever commits mischief by doing any`
  line `act in respect of any public property, other than public property of the nature referred to in sub-section`
  line `(2), shall be punished with imprisonment for a term which may extend to five years and with fine.`
  line
  line `(2) Whoever commits mischief by doing any act in respect of any public property being—`
  line
  line `(a) any building, installation or other property used in connection with the production,`
  line `distribution or supply of water, light, power or energy;`
  line
  line `(b) any oil installations;`
  line
  line `(c) any sewage works;`
  line
  line `(d) any mine or factory;`
  line
  line `(e) any means of public transportation or of tele-communications, or any building, installation`
  line `or other property used in connection therewith,`
  line
  line `shall be punished with rigorous imprisonment for a term which shall not be less than six months, but`
  line `which may extend to five years and with fine:`
  line
  line `Provided that the court may, for reasons to be recorded in its judgment, award a sentence of`
  line `imprisonment for a term of less than six months.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (37148)
  sectionNo (4)
  orderNo 4
  title `Mischief causing damage to public property by fire or explosive substance.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00018_198403_1517807325229&sectionId=37148&sectionno=4&orderno=4&orgactid=AC_CEN_5_23_00018_198403_1517807325229
obj_root_law_sections_4_content:
  string
  line Whoever
  line `commits an offence under sub-section (1) or sub-section (2) of section 3 by fire or explosive`
  line `substance shall be punished with rigrous imprisonment for a term which shall not be less than one`
  line `year, but which may extend to ten years and with fine:`
  line
  line `Provided that the court may, for special reasons to be recorded in its judgment, award a sentence`
  line `of imprisonment for a term of less than one year.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (37149)
  sectionNo (5)
  orderNo 5
  title `Special provisions regarding bail.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00018_198403_1517807325229&sectionId=37149&sectionno=5&orderno=5&orgactid=AC_CEN_5_23_00018_198403_1517807325229
obj_root_law_sections_5_content:
  string
  line `No person accused or convicted of an offence punishable`
  line `under section 3 or section 4 shall, if in custody, be released on bail or on his own bond unless the`
  line `prosecution has been given an opportunity to oppose the application for such release.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (37150)
  sectionNo (6)
  orderNo 6
  title Saving.
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00018_198403_1517807325229&sectionId=37150&sectionno=6&orderno=6&orgactid=AC_CEN_5_23_00018_198403_1517807325229
obj_root_law_sections_6_content:
  string
  line `The provisions of this Act shall be in addition to, and not in derogation of, the`
  line `provisions of any other law for the time being in force, and nothing contained in this Act shall exempt`
  line `any person from any proceeding (whether by way of investigation or otherwise) which might apart`
  line `from this Act, be instituted or taken against him.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (37151)
  sectionNo (7)
  orderNo 7
  title `Repeal and saving.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_23_00018_198403_1517807325229&sectionId=37151&sectionno=7&orderno=7&orgactid=AC_CEN_5_23_00018_198403_1517807325229
obj_root_law_sections_7_content:
  string
  line `(1) The Prevention of Damage to Public Property Ordinance,`
  line `1984 (Ord. 3 of 1984), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall`
  line `be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_7_footnotes:
  string
  line
