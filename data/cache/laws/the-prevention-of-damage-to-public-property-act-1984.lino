obj_root_law_translations_hi:
  object
  (str title) (str `लोक संपत्ति नुकसान निवारण अधिनियम, 1984`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1770/3/H1984-3.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T09:48:35.850Z`)
  (str pageCount) (int 2)
