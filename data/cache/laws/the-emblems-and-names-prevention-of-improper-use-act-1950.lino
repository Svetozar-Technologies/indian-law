  (str title) (str `संप्रतीक और नाम (अनुचित प्रयोगनिवारण) अधिनियम, 1950`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1896/2/h195012.pdf`)
