obj_root_law:
  slug the-indian-institutes-of-information-technology-act-2014
  handle (2135)
  collectionHandle 123456789/1362
  title `The Indian Institutes of Information Technology Act, 2014`
  actNumber (30)
  enactmentDate 2014-12-08
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2135`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `भारतीय सूचना प्रौद्योगिकी संस्थाधनअधिनियम, 2014`
  actYear (2014)
  ministry `Ministry of Education`
  department `Department of Higher Education`
  longTitle `An Act to declare certain institutions of information technology to be institutions of national importance, with a view to develop new knowledge in information technology and to provide manpower of global standards for the information technology industry and to provide for certain other matters connected with such institutions or incidental thereto.`
  enforcementDate 05-01-2015
  notification `5th January, 2015, vide notification No. S.O. 41(E) , dated 5th January, 2015, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-09T09:50:34.776Z`
  translations obj_root_law_translations
