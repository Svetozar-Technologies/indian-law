obj_root_law:
  slug the-banking-companies-acquisition-and-transfer-of-undertakings-act-1970
  handle (1373)
  collectionHandle 123456789/1362
  title `The Banking Companies (Acquisition and Transfer of Undertakings) Act, 1970`
  actNumber (5)
  enactmentDate 1970-03-31
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1373`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `बैंककारी कम्‍पनी (उपक्रमों का अर्जन और अन्‍तरण) अधिनियम, 1970`
  actYear (1970)
  ministry `Ministry of Finance`
  department `Department of Financial Services`
  longTitle `An Act to provide for the acquisition and transfer of the undertakings of certain banking companies, having regard to their size, resources, coverage and organisation, in order to control the heights of the economy and to meet progressively, and serve better, the needs of development of the economy in conformity with national policy and objectives and for matters connected therewith or incidental thereto.`
  enforcementDate 19-07-1969
  notification undefined
  fetchedAt `2026-05-09T18:02:47.830Z`
  translations obj_root_law_translations
