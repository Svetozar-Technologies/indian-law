obj_root_law_sections_1:
  sectionId (19167)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19167&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Banking Companies`
  line `(Acquisition and Transfer of Undertakings) Act, 1970.`
  line
  line `(2) The provisions of this Act (except section 21, which shall come into force on the appointed day)`
  line `shall be deemed to have come into force on the 19th day of July, 1969.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (19168)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes `1 Ins. by Act 37 of 1994, s. 2 (w.e.f. 15-7-1994).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19168&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means the 14th day of February, 1970, being the day on which the Banking`
  line `Companies (Acquisition and Transfer of Undertakings) Ordinance, 1970 (Ord. 3 of 1970), was`
  line promulgated;
  line
  line `(b) "banking company" does not include a foreign company within the meaning of section 591 of`
  line `the Companies Act, 1956 (1 of 1956);`
  line
  line `(c) "commencement of this Act" means the 19th day of July, 1969;`
  line
  line `(d) "corresponding new bank", in relation to an existing bank, means the body corporate specified`
  line `against such bank in column 2 of the First Schedule;`
  line
  line `(e) "Custodian" means the person who becomes, or is appointed, a Custodian under section 7;`
  line
  line `(f) "existing bank" means a banking company specified in column 1 of the First Schedule, being a`
  line `company the deposits of which, as shown in the return as on the last Friday of June, 1969, furnished`
  line `to the Reserve Bank under section 27 of the Banking Regulation Act, 1949 (10 of 1949), were not`
  line `less than rupees fifty crores;`
  line
  line ^1
  line `[(fa) "prescribed" means prescribed by regulations made under this Act;]`
  line
  line `(g) "Schedule" means a Schedule to this Act;`
  line
  line `(h) words and expressions used herein and not defined but defined in the Banking Regulation`
  line `Act, 1949 (10 of 1949), have the meanings respectively assigned to them in that Act;`
  line
  line ^1
  line `[(i) words and expressions used herein and not defined either in this Act or in the Banking`
  line `Regulation Act,1949 (10 of 1949) but defined in the Companies Act, 1956 (1 of 1956) shall have the`
  line `meanings respectively assigned to them in the Companies Act, 1956.]`
obj_root_law_sections_3:
  sectionId (19169)
  sectionNo (3)
  orderNo 3
  title `Establishment of corresponding new banks and business thereof.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19169&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_3_content:
  string
  line `^1[3. Establishment of corresponding new banks and business thereof.--(1) On the commencement`
  line `of this Act, there shall be constituted such corresponding new banks as are specified in the First Schedule.`
  line
  line `(2) The paid-up capital of every corresponding new bank constituted under sub-section (1) shall, until`
  line `any provision is made in this behalf in any scheme made under section 9, be equal to the paid-up capital`
  line `of the existing bank in relation to which it is the corresponding new bank.`
  line
  line ^2
  line [
  line ^3
  line `[(2A) Subject to the provisions of this Act, the authorised capital of every corresponding new bank`
  line `shall be three thousand crores of rupees divided into three hundred crores of fully paid-up shares of ten`
  line `rupees each:`
  line
  line `Provided that the corresponding new bank may reduce the nominal or face value of the shares, and`
  line `divide the authorised capital into such denomination as it may decide with the prior approval of the`
  line `Reserve Bank:`
  line
  line `Provided further that the Central Government may in consultation with the Reserve Bank and by`
  line `notification in the Official Gazette increase or reduce the authorised capital as it deems fit so however that`
  line `the shares in all cases shall be fully paid-up shares.]`
  line
  line `(2B) Notwithstanding anything contained in sub-section (2), the paid up capital of every`
  line `corresponding new bank constituted under sub-section (1) may from time to time be increased by--`
  line
  line `(a) such amounts as the Board of Directors of the corresponding new bank may, after consultation`
  line `with the Reserve Bank and with the previous sanction of the Central Government, transfer from the`
  line `reserve fund established by such bank to such paid-up capital;`
  line
  line `(b) such amounts as the Central Government may, after consultation with the Reserve Bank,`
  line `contribute to such paid up capital;`
  line
  line ^4
  line `[(c) such amounts as the Board of Directors of the corresponding new bank may, after`
  line `consultation with the Reserve Bank and with the previous sanction of the Central Government, raise`
  line `whether by public issue ^5`
  line `[or rights issue or by issue of bonus shares] or preferential allotment or`
  line `private placement, of equity shares or preference shares in accordance with the procedure as may be`
  line `prescribed, so, however, that the Central Government shall, at all times hold not less than fifty-one`
  line `per cent. of the paid-up capital consisting of equity shares of each corresponding new bank:`
  line
  line `Provided that the issue of preference shares shall be in accordance with the guidelines framed by`
  line `the Reserve Bank specifying the class of preference shares, the extent of issue of each class of such`
  line `preference shares (whether perpetual or irredeemable or redeemable) and the terms and conditions`
  line `subject to which, each class of preference shares may be issued.]`
  line
  line ^6
  line `[(2BB) Notwithstanding anything contained in sub-section (2) the paid-up capital of a corresponding`
  line `new bank constituted under sub-section (1) may, from time to time and before any paid-up capital`
  line `is ^7`
  line `[raised by public issue ^5`
  line `[or rights issue or by issue of bonus shares] or preferential allotment or private`
  line `placement] under clause (c) of sub-section (2B), be reduced by--`
  line
  line `(a) the Central Government, after consultation with the Reserve Bank, by cancelling any paid-up`
  line `capital which is lost, or is unrepresented by available assets;`
  line
  line `(b) the Board of Directors, after consultation with the Reserve Bank and with the previous`
  line `sanction of the Central Government, by paying off any paid-up capital which is in excess of the wants`
  line `of the corresponding new bank:`
  line
  line `Provided that in a case where such capital is lost, or is unrepresented by available assets because of`
  line `amalgamation of another corresponding new bank or a corresponding new bank as defined in clause (d) of`
  line `section 2 of the Banking Companies (Acquisition and Transfer of Undertakings) Act, 1980 (40 of 1980)`
  line `with the corresponding new bank, such reduction may be done, either prospectively or retrospectively, but`
  line `not from a date earlier than the date of such amalgamation.`
  line
  line `(2BBA)(a) A corresponding new bank may, from time to time and after any paid-up capital has`
  line `been ^8`
  line `[raised by public issue ^9`
  line `[or rights issue or by issue of bonus shares] or preferential allotment or`
  line `private placement] under clause (c) of sub-section (2B), by resolution passed at an annual general meeting`
  line `of the shareholders entitled to vote, voting in person, or, where proxies are allowed, by proxy, and the`
  line `votes cast in favour of the resolution are not less than three times the number of the votes, if any, cast`
  line `against the resolution by the shareholders so entitled and voting, reduce its paid-up capital in any way.`
  line
  line `(b) Without prejudice to the generality of the foregoing power, the paid-up capital may be reduced`
  line by--
  line
  line `(i) extinguishing or reducing the liability on any of its shares in respect of share capital not`
  line paid-up;
  line
  line `(ii) either with or without extinguishing or reducing liability on any of its paid-up shares,`
  line `cancelling any paid-up capital which is lost, or is unrepresented by available assets; or`
  line
  line `(iii) either with or without extinguishing or reducing liability on any of its paid-up shares, paying`
  line `off any paid-up share capital which is in excess of the wants of the corresponding new bank.`
  line
  line `(2BBB) Notwithstanding anything contained in sub-section (2BB) or sub-section (2BBA), the`
  line `paid-up capital of a corresponding new bank shall not be reduced at any time so as to render it below`
  line `twenty-five per cent. of the paid-up capital of that bank as on the date of commencement of the Banking`
  line `Companies (Acquisition and Transfer of Undertakings) Amendment Act, 1995 (8 of 1995).]`
  line
  line `(2C) The entire paid-up capital of a corresponding new bank, except the paid-up capital ^8`
  line `[raised from`
  line `public by public issue ^9`
  line `[or rights issue or by issue of bonus shares] or preferential allotment or private`
  line `placement] under clause (c) of sub-section (2B), shall stand vested in, and allotted to, the Central`
  line Government.
  line
  line `(2D) The shares of every corresponding new bank not held by the Central Government shall be freely`
  line `transferable:`
  line
  line `Provided that no individual or company resident outside India or any company incorporated under`
  line `any law not in force in India or any branch of such company, whether resident outside India or not, shall`
  line `at any time hold or acquire by transfer or otherwise shares of the corresponding new bank so that such`
  line `investment in aggregate exceed the percentage, not being more than twenty per cent. of the paid-up`
  line `capital, as may be specified by the Central Government by notification in the Official Gazette.`
  line
  line `Explanation.--For the purposes of this clause, "company" means any body corporate and includes a`
  line `firm or other association of individuals.`
  line
  line `(2E) No shareholder of the corresponding new bank, other than the Central Government, shall be`
  line `entitled to exercise voting rights in respect of any shares held by him in excess of ^10`
  line `[ten per cent.] of the`
  line `total voting rights of all the shareholders of the corresponding new bank.`
  line
  line ^11
  line `[Provided that the shareholder holding any preference share capital in the corresponding new bank`
  line `shall, in respect of such capital, have a right to vote only on resolutions placed before such`
  line `corresponding new bank which directly affects the rights attached to his preference shares:`
  line
  line `Provided further that ^12`
  line `[no preference shareholder, other than the Central Government, shall be entitled`
  line `to exercise voting rights in respect of preference shares held by him in excess of ten per cent.] of the total`
  line `voting rights of all the shareholders holding preference share capital only.]`
  line
  line `(2F) Every corresponding new bank shall keep at its head office a register, in one or more books, of`
  line `the shareholders (in this Act referred to as the register) and shall enter therein the following particulars:--`
  line
  line `(i) the names, addresses and occupations, if any, of the shareholders and a statement of the shares`
  line `held by each shareholder, distinguishing each share by its denoting number;`
  line
  line `(ii) the date on which each person is so entered as a shareholder;`
  line
  line `(iii) the date on which any person ceases to be a shareholder; and`
  line
  line `(iv) such other particulars as may be prescribed:`
  line
  line ^13
  line `[Provided that nothing in this sub-section shall apply to the shares held with a depository.]`
  line
  line `(2G) Notwithstanding anything contained in sub-section (2F), it shall be lawful for every`
  line `corresponding new bank to keep the register in computer floppies or diskettes subject to such safeguards`
  line `as may be prescribed.`
  line
  line `(3) Notwithstanding anything contained in the Indian Evidence Act, 1872 (1 of 1872) a copy of, or`
  line `extract from, the register, certified to be a true copy under the hand of an officer of the corresponding new`
  line `bank authorised in this behalf by it, shall, in all legal proceedings, be admissible in evidence.]`
  line
  line `(4) Every corresponding new bank shall be a body corporate with perpetual succession and a common`
  line `seal with power, subject to the provisions of this Act, to acquire, hold and dispose of property, and to`
  line `contract, and may sue and be sued in its name.`
  line
  line `(5) Every corresponding new bank shall carry on and transact the business of banking as defined in`
  line `clause (b) of section 5 of the Banking Regulation Act, 1949 (10 of 1949) and may engage in ^14`
  line `[one or`
  line `more of the other forms of business] specified in sub-section (1) of section 6 of that Act.`
  line
  line `(6) Every corresponding new bank shall establish a reserve fund to which shall be transferred the`
  line `share premiums and the balance, if any, standing to the credit of the reserve fund of the existing bank in`
  line `relation to which it is the corresponding new bank, and such further sums, if any, as may be transferred in`
  line `accordance with the provisions of section 17 of the Banking Regulation Act, 1949 (10 of 1949).`
  line
  line ^15
  line `[(7) (i) The corresponding new bank shall, if so required by the Reserve Bank, act as agent of the`
  line `Reserve Bank at all places in India where it has a branch, for--`
  line
  line `(a) paying, receiving, collecting and remitting money, bullion and securities on behalf of any`
  line `Government in India; and`
  line
  line `(b) undertaking and transacting any other business which the Reserve Bank may from time to`
  line `time entrust to it.`
  line
  line `(ii) The terms and conditions on which any such agency business shall be carried on by the`
  line `corresponding new bank on behalf of the Reserve Bank shall be such as may be agreed upon.`
  line
  line `(iii) If no agreement can be reached on any matter referred to in clause (ii), or if a dispute arises`
  line `between the corresponding new bank and the Reserve Bank as to the interpretation of any agreement between them, the matter shall be referred to the Central Government and the decision of the Central`
  line `Government thereon shall be final.`
  line
  line `(iv) The corresponding new bank may transact any business or perform any functions entrusted to it`
  line `under clause (i), by itself or through any agent approved by the Reserve Bank.]`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by Act 37 of 1994, s. 3, for the heading (w.e.f. 15-7-1994).`
  line
  line `2. Subs. by s. 4, ibid., for sub-sections (2A) and (3) (w.e.f. 15-7-1994).`
  line
  line `3. Subs. by Act 4 of 2013, s. 15, for sub-section (2A) (w.e.f. 18-1-2013).`
  line
  line `4. Subs. by Act 45 of 2006, s. 2, for clause (c) (w.e.f. 16-10-2006).`
  line
  line `5. Ins. by Act 4 of 2013, s. 15 (w.e.f. 18-1-2013).`
  line
  line `6. Ins. by Act 8 of 1995, s. 2 (w.e.f. 21-1-1995).`
  line
  line `7. Subs. by Act 45 of 2006, s. 2, for "raised by public issue" (w.e.f. 16-10-2006).`
  line
  line `8. Subs. by Act 45 of 2006, s. 2, for "raised by public issue" (w.e.f. 16-10-2006).`
  line
  line `9. Ins. by Act 4 of 2013, s. 15 (w.e.f. 18-1-2013).`
  line
  line `10. Subs. by s.15, ibid., for “one per cent.” (w.e.f. 18-1-2013).`
  line
  line `11. Ins. by Act 45 of 2006, s. 2 (w.e.f. 16-10-2006).`
  line
  line `12. Subs. by Act 4 of 2013, s. 15, for certain words (w.e.f. 18-1-2013).`
  line
  line `13. Ins. by Act 8 of 1997, s. 16 (w.e.f. 15-1-1997).`
  line
  line `14. Subs. by Act 1 of 1984, s. 65, for "one or more forms of business" (w.e.f.15-2-1984).`
  line
  line `15. Ins. by s. 65, ibid. (w.e.f. 15-2-1984).`
obj_root_law_sections_3_a:
  sectionId (19170)
  sectionNo 3A
  orderNo 4
  title `Trust not to be entered on the register.`
  content obj_root_law_sections_3_a_content
  footnotes obj_root_law_sections_3_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19170&sectionno=3A&orderno=4&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_3_a_content:
  string
  line ^1
  line `[3A. Trust not to be entered on the register.--Notwithstanding anything contained in`
  line `sub-section (2F) of section 3, no notice of any trust, express, implied or constructive, shall be entered on`
  line `the register, or be receivable, by the corresponding new bank:]`
  line
  line ^2
  line `[Provided that nothing in this section shall apply to a depository in respect of shares held by it as a`
  line `registered owner on behalf of the beneficial owners.]`
obj_root_law_sections_3_a_footnotes:
  string
  line `1. Ins. by Act 37 of 1994, s. 5 (w.e.f. 15-7-1994).`
  line
  line `2. Ins. by Act 8 of 1997, s. 17 (w.e.f. 15-1-1997).`
obj_root_law_sections_3_b:
  sectionId (19171)
  sectionNo 3B
  orderNo 5
  title `Register of beneficial owners`
  content obj_root_law_sections_3_b_content
  footnotes `1. Ins. by s. 18, ibid. (w.e.f. 15-1-1997).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19171&sectionno=3B&orderno=5&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_3_b_content:
  string
  line ^1
  line `[3B. Register of beneficial owners.--The register of beneficial owners maintained by a depository`
  line `under section 11 of the Depositories Act, 1996 (22 of 1996), shall be deemed to be a register of`
  line `shareholders for the purpose of this Act.`
  line
  line `Explanation.--For the purposes of section 3, section 3A and this section, the expressions "beneficial`
  line `owner", "depository" and "registered owner" shall have the meanings respectively assigned to them in`
  line `clauses (a), (e) and (j) of sub-section (1) of section 2 of the Depositories Act, 1996 (22 of 1996).]`
obj_root_law_sections_4:
  sectionId (19172)
  sectionNo (4)
  orderNo 6
  title `Undertaking of existing banks to vest in corresponding new banks`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19172&sectionno=4&orderno=6&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_4_content:
  string
  line `On the commencement of`
  line `this Act, the undertaking of every existing bank shall be transferred to, and shall vest in, the`
  line `corresponding new bank.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (19173)
  sectionNo (5)
  orderNo 7
  title `General effect of vesting.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19173&sectionno=5&orderno=7&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_5_content:
  string
  line `(1) The undertaking of each existing bank shall be deemed to include`
  line `all assets, rights, powers, authorities and privileges and all property, movable and immovable, cash`
  line `balances, reserve funds, investments and all other rights and interests in, or arising out of, such property`
  line `as were immediately before the commencement of this Act in the ownership, possession, power or control`
  line `of the existing bank in relation to the undertaking, whether within or without India, and all books of`
  line `account, registers, records and all other documents of whatever nature relating thereto and shall also be`
  line `deemed to include all borrowings, liabilities and obligations of whatever kind then subsisting of the`
  line `existing bank in relation to the undertaking.`
  line
  line `(2) If, according to the laws of any country outside India, the provisions of this Act by themselves are`
  line `not effective to transfer or vest any asset or liability situated in that country which forms part of the`
  line `undertaking of an existing bank to, or in, the corresponding new bank, the affairs of the existing bank in`
  line `relation to such asset or liability shall, on and from the commencement of this Act, stand entrusted to the`
  line `chief executive officer for the time being of the corresponding new bankand the chief executive officer`
  line `may exercise all powers and do all such acts and things as may be exercised or done by the existing bank`
  line `for the purpose of effectively transferring such assets and discharging such liabilities.`
  line
  line `(3) The chief executive officer of the corresponding new bank shall, in exercise of the powers`
  line `conferred on him by sub-section (2), take all such steps as may be required by the laws of any such`
  line `country outside India for the purpose of effecting such transfer or vesting, and may either himself or`
  line `through any person authorised by him in this behalf realise any asset and discharge any liability of the`
  line `existing bank.`
  line
  line `(4) Unless otherwise expressly provided by this Act, all contracts, deeds, bonds, agreements, powers`
  line `of attorney, grants of legal representation and other instruments of whatever nature subsisting or having`
  line `effect immediately before the commencement of this Act and to which the existing bank is a party or`
  line `which are in favour of the existing bank shall be of as full force and effect against or in favour of the`
  line `corresponding new bank, and may be enforced or acted upon as fully and effectually as if in the place of`
  line `the existing bank the corresponding new bank had been a party thereto or as if they had been issued in`
  line `favour of the corresponding new bank.`
  line
  line `(5) If, on the appointed day, any suit, appeal or other proceeding of whatever nature in relation to any`
  line `business of the undertaking which has been transferred under section 4, is pending by or against the`
  line `existing bank, the same shall not abate, be discontinued or be, in any way, prejudicially affected by reason`
  line `of the transfer of the undertaking of the existing bank or of anything contained in this Act but the suit,`
  line `appeal or other proceeding may be continued, prosecuted and enforced by or against the corresponding`
  line `new bank.`
  line
  line `(6) Nothing in this Act shall be construed as applying to the assets, rights, powers, authorities and`
  line `privileges and property, movable and immovable, cash balances and investments in any country outside`
  line `India (and other rights and interests in, or arising out of, such property) and borrowings, liabilities and`
  line `obligations of whatever kind subsisting at the commencement of this Act, of any existing bank operating`
  line `in that country if, under the laws in force in that country, it is not permissible for a banking company,`
  line `owned or controlled by Government, to carry on the business of banking there.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (19174)
  sectionNo (6)
  orderNo 8
  title `Payment of compensation.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19174&sectionno=6&orderno=8&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_6_content:
  string
  line `(1) Every existing bank shall be given by the Central Government`
  line `such compensation in respect of the transfer, under section 4, to the corresponding new bank of the`
  line `undertaking of the existing bank as is specified against each such bank in the Second Schedule.`
  line
  line `(2) The amount of compensation referred to in sub-section (1) shall be given to every existing bank,`
  line `at its option,--`
  line
  line `(a) in case (to be paid by cheque drawn on the Reserve Bank) in three equal annual instalments,`
  line `the amount of each instalment carrying interest at the rate of four per cent. per annum from the`
  line `commencement of this Act, or`
  line
  line `(b) in saleable or otherwise transferable promissory notes or stock certificates of the Central`
  line `Government issued and repayable at par, and maturing at the end of--`
  line
  line `(i) ten years from the commencement of this Act and carrying interest from such`
  line `commencement at the rate of four and a half per cent. per annum, or`
  line
  line `(ii) thirty years from the commencement of this Act and carrying interest from such`
  line `commencement at the rate of five and a half per cent. per annum, or`
  line
  line `(c) partly in cash (to be paid by cheque drawn on the Reserve Bank) and partly in such number of`
  line `securities specified in sub-clause (i) or sub-clause (ii), or both, of clause (b), as may be required by`
  line `the existing bank, or`
  line
  line `(d) partly in such number of securities specified in sub-clause (i) of clause (b) and partly in such`
  line `number of securities specified in sub-clause (ii) of that clause, as may be required by the existing`
  line bank.
  line
  line `(3) The first of the three equal annual instalments referred to in clause (a) of sub-section (2) shall be`
  line `paid, and the securities referred to in clause (b) of that sub-section shall be issued, within sixty days from`
  line `the date of receipt by the Central Government of the option referred to in that sub-section, or where no`
  line `such option has been exercised, from the latest date before which such option ought to have been`
  line exercised.
  line
  line `(4) The option referred to in sub-section (2) shall be exercised by every existing bank before the`
  line `expiry of a period of three months from the appointed day (or within such further time, not exceeding`
  line `three months, as the Central Government may, on the application of the existing bank, allow) and the`
  line `option so exercised shall be final and shall not be altered or rescinded after it has been exercised.`
  line
  line `(5) Any existing bank which omits or fails to exercise the option referred to in sub-section (2), within`
  line `the time specified in sub-section (4), shall be deemed to have opted for payment in securities specified in`
  line `sub-clause (i) of clause (b) of sub-section (2).`
  line
  line `(6) Notwithstanding anything contained in this section, any existing bank may, before the expiry of`
  line `three months from the appointed day (or within such further time, not exceeding three months, as the Central Government may, on the application of the existing bank, allow) make an application in writing to`
  line `the Central Government for an interim payment of an amount equal to seventy-five per cent. of the`
  line `amount of the paid-up capital of such bank, as on the commencement of this Act, indicating therein`
  line `whether the payment is desired in cash or in securities specified in sub-section (2), or in both.`
  line
  line `(7) The Central Government shall, within sixty days from the receipt of the application referred to in`
  line `sub-section (6), make the interim payment to the existing bank in accordance with the option indicated in`
  line `such application.`
  line
  line `(8) The interim payment made to an existing bank under sub-section (7) shall be set off against the`
  line `total amount of compensation payable to such existing bank under this Act and the balance of the`
  line `compensation remaining outstanding after such payment shall be given to the existing bank in accordance`
  line `with the option exercised, or deemed to have been exercised, under sub-section (4) or sub-section (5), as`
  line `the case may be:`
  line
  line `Provided that where any part of the interim payment is obtained by an existing bank in cash, the`
  line `payment so obtained shall be set off, in the first instance, against the first instalment of the cash payment`
  line `referred in sub-section (2), and in case the payment so obtained exceeds the amount of the first`
  line `instalment, the excess amount shall be adjusted against the second instalment and the balance of such`
  line `excess amount, if any, against the third instalment of the cash payment.`
  line
  line `(9) Any payment purported to have been made to an existing bank under sub-section (3) of section 15`
  line `of the Banking Companies (Acquisition and Transfer of Undertakings) Act, 1969 (22 of 1969), shall be`
  line `deducted by the Central Government from the amount of the interim payment made to such existing bank`
  line `under sub-section (7), or where no such interim payment has been made, from the total amount of the`
  line `compensation due to such existing bank, and the amount so deducted shall be paid by the Central`
  line `Government to the corresponding new bank.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (19175)
  sectionNo (7)
  orderNo 9
  title `Head office and management.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19175&sectionno=7&orderno=9&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_7_content:
  string
  line `(1) The head office of each corresponding new bank shall be at`
  line `such place as the Central Government may, by notification in the Official Gazette, specify in this behalf,`
  line `and, until any such place is so specified, shall be at such place at which the head office of the existing`
  line `bank, in relation to which it is the corresponding new bank, is on the commencement of this Act, located.`
  line
  line `(2) The general superintendence, direction and management of the affairs and business of a`
  line `corresponding new bank shall vest in a Board of Directors which shall be entitled to exercise all such`
  line `powers and do all such acts and things as the corresponding new bank is authorised to exercise and do.`
  line
  line `(3) (a) As soon as may be after the appointed day, the Central Government shall, in consultation with`
  line `the Reserve Bank, constitute the first Board of Directors of a corresponding new bank, consisting of not`
  line `more than seven persons, to be appointed by the Central Government, and every director so appointed`
  line `shall hold office until the Board of Directors of such corresponding new bank is constituted in accordance`
  line `with the scheme made under section 9:`
  line
  line `Provided that the Central Government may, if it is of opinion that it is necessary in the interests of the`
  line `corresponding new bank so to do, remove a person from the membership of the first Board of Directors`
  line `and appoint any other person in his place.`
  line
  line `(b) Every member of the first Board of Directors (not being an officer of the Central Government or`
  line `of the Reserve Bank) shall receive such remuneration as is equal to the remuneration which a member of`
  line `the Board of Directors of the existing bank was entitled to receive immediately before the commencement`
  line `of this Act.`
  line
  line `(4) Until the first Board of Directors is appointed by the Central Government under sub-section (3),`
  line `the general superintendence, direction and management of the affairs and business of a corresponding`
  line `new bank shall vest in a Custodian, who shall be the chief executive officer of that bank and may exercise`
  line `all powers and do all acts and things as may be exercised or done by that bank.`
  line
  line `(5) The Chairman of an existing bank holding office as such immediately before the commencement`
  line `of this Act, shall be the Custodian of the corresponding new bank and shall receive the same emoluments`
  line `as he was receiving immediately before such commencement:`
  line
  line `Provided that the Central Government may, if the Chairman of an existing bank declines to become,`
  line `or to continue to function as, a Custodian of the corresponding new bank, or, if it is of opinion that it is`
  line `necessary in the interests of the corresponding new bank so to do, appoint any other person as the`
  line `Custodian of a corresponding new bank and the Custodian so appointed shall receive such emoluments as`
  line `the Central Government may specify in this behalf.`
  line
  line `(6) The Custodian shall hold office during the pleasure of the Central Government.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (19176)
  sectionNo (8)
  orderNo 10
  title `Corresponding new banks to be guided by the directions of the Central Government.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19176&sectionno=8&orderno=10&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_8_content:
  string
  line Every
  line `corresponding new bank shall, in the discharge of its functions, be guided by such directions in regard to`
  line `matters of policy involving public interest as the Central Government may, after consultation with the`
  line `Governor of the Reserve Bank, give.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (19177)
  sectionNo (9)
  orderNo 11
  title `Power of Central Government to make scheme.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19177&sectionno=9&orderno=11&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_9_content:
  string
  line `(1) The Central Government may, after`
  line `consultation with the Reserve Bank, make a scheme for carrying out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, the said scheme may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the capital structure of the corresponding new bank ^1***.`
  line
  line `(b) the constitution of the Board of Directors, by whatever name called, of the corresponding new`
  line `bank and all such matters in connection therewith or incidental thereto as the Central Government`
  line `may consider to be necessary or expedient;`
  line
  line `(c) the reconstitution of any corresponding new bank into two or more corporations, the`
  line `amalgamation of any corresponding new bank with any other corresponding new bank or with`
  line `another banking institution, the transfer of the whole or any part of the undertaking of a`
  line `^2[corresponding new bank to any other corresponding new bank or banking institution] or the transfer`
  line `of the whole or any part of the undertaking of any other banking institution to a corresponding new`
  line bank;
  line
  line `^3[(ca) the manner in which the excess number of directors shall retire under second proviso to`
  line `clause (i) of sub-section (3);]`
  line
  line `(d) such incidental, consequential and supplemental matters as may be necessary to carry out the`
  line `provisions of this Act.`
  line
  line `^4[(3) Every Board of Directors of a corresponding new bank constituted under any scheme made`
  line `under sub-section (1), shall include--`
  line
  line `^5[(a) not more than five whole-time directors to be appointed by the Central Government after`
  line `consultation with the Reserve Bank:`
  line
  line `Provided that the Central Government, may, after consultation with the Reserve Bank, by`
  line `notification published in the Official Gazette, post a whole-time director so appointed to any other`
  line `corresponding new bank.`
  line
  line `Explanation. -- For the purposes of this clause, the expression "corresponding new bank" shall`
  line `include a "corresponding new bank" as defined in clause (b) of section 2 of the Banking Companies`
  line `(Acquisition and Transfer of Undertakings) Act, 1980;]`
  line
  line `(b) one Director who is an official of the Central Government to be nominated by the`
  line `Central Government:`
  line
  line `Provided that no such Director shall be a Director of any other corresponding new bank.`
  line
  line `Explanation.--For the purposes of this clause, the expression "corresponding new bank" shall include`
  line `a corresponding new bank within the meaning of the Banking Companies (Acquisition and Transfer of`
  line `Undertakings) Act, 1980 (40 of 1980);`
  line
  line `^6[(c) one director, possessing necessary expertise and experience in matters relating to regulation`
  line `or supervision of commercial banks, to be nominated by the Central Government on there`
  line `commendation of the Reserve Bank;]`
  line
  line `Explanation.--For the purpose of this clause, an officer of the Reserve Bank includes an`
  line `officer of the Reserve Bank who is deputed by that bank under section 54AA of the Reserve Bank of`
  line `India Act, 1934 (2 of 1934) to any institution referred to therein;`
  line
  line `^7* * * * *`
  line
  line `(e) one Director, from among such of the employees of the corresponding new bank who are`
  line `workmen under clause (s) of section 2 of the Industrial Disputes Act, 1947 (14 of 1947), to be`
  line `nominated by the Central Government in such manner as may be specified in a scheme made under`
  line `this section;`
  line
  line `(f) one Director, from among the employees of the corresponding new bank who are not workmen`
  line `under clause(s) of section 2 of the Industrial Disputes Act, 1947 (14 of 1947), to be nominated by the`
  line `Central Government after consultation with the Reserve Bank;`
  line
  line `(g) one Director who has been a Chartered Accountant for not less than fifteen years to be`
  line `nominated by the Central Government after consultation with the Reserve Bank;`
  line
  line `(h) subject to the provisions of clause (i), not more than six directors to be nominated by the`
  line `Central Government;`
  line
  line `^8[(i) where the capital issued under clause (c) of sub-section (2B) of section 3 is--`
  line
  line `(I) not more than sixteen per cent. of the total paid-up capital, one director;`
  line
  line `(II) more than sixteen per cent. but not more than thirty-two per cent. of the total paid-up`
  line `capital, two directors;`
  line
  line `(III) more than thirty-two per cent. of the total paid-up capital, three directors,`
  line
  line `to be elected by the shareholders, other than the Central Government, from amongst themselves:`
  line
  line `Provided that on the assumption of charge after election of any such director under this clause,`
  line `equal number of directors nominated under clause (h) shall retire in such manner as may be specified`
  line `in the scheme:`
  line
  line `Provided further that in case the number of directors elected, on or before the commencement of`
  line `the Banking Companies (Acquisition and Transfer of Undertakings) and Financial Institutions Laws`
  line `(Amendment) Act, 2006 (45 of 2006), in a corresponding new bank exceed the number of directors`
  line `specified in sub-clause (I) or sub-clause (II) or sub-clause (III), as the case may be, such excess`
  line `number of directors elected before such commencement shall retire in such manner as may be`
  line `specified in the scheme and such directors shall not be entitled to claim any compensation for the`
  line `premature retirement of their term of office.]`
  line
  line `(3A) The directors to be nominated under clause (h) or to be elected under clause (i) of`
  line `sub-section (3) shall--`
  line
  line `(A) have special knowledge or practical experience in respect of one or more of the following`
  line `Matters, namely:--`
  line
  line `(i) agricultural and rural economy,`
  line
  line `(ii) banking,`
  line
  line `(iii) co-operation,`
  line
  line `(iv) economics,`
  line
  line `(v) finance,`
  line
  line `(vi) law,`
  line
  line `(vii) small scale industry,`
  line
  line `(viii) any other matter the special knowledge of, and practical experience in, which would, in`
  line `the opinion of the Reserve Bank, be useful to the corresponding new bank;`
  line
  line `(B) represent the interests of depositors; or`
  line
  line `(C) represent the interest of farmers, workers and artisans.`
  line
  line `^9[(3AA) Without prejudice to the provisions of sub-section (3A) and notwithstanding anything to the`
  line `contrary contained in this Act or in any other law for the time being in force, no person shall be eligible to`
  line `be elected as director under clause (i) of sub-section (3) unless he is a person having fit and proper status`
  line `based upon track record, integrity and such other criteria as the Reserve Bank may notify from time to`
  line `time in this regard.`
  line
  line `(3AB) The Reserve Bank may also specify in the notification issued under sub-section (3AA), the`
  line `authority to determine the fit and proper status, the manner of such determination, the procedure to be`
  line `followed for such determination and such other matters as may be considered necessary or incidental`
  line thereto;]
  line
  line `(3B) Where the Reserve Bank is of the opinion that any director of a corresponding new Bank elected`
  line `under clause (i) of sub-section (3) does not fulfil the requirements of ^10[sub-sections (3A) and (3AA)] it`
  line `may, after giving to such director and the bank a reasonable opportunity of being heard, by order, remove`
  line `such director and on such removal, the Board of Directors shall co-opt any other person fulfilling the`
  line `requirements of ^10[sub-sections (3A) and (3AA)] as a director in place of the person so removed till a`
  line `director is duly elected by the shareholders of the corresponding new bank in the next annual general`
  line `meeting and the person so co-opted shall be deemed to have been duly elected by the shareholders of the`
  line `corresponding new bank as a director.]`
  line
  line `(4) The Central Government may, after consultation with the Reserve Bank, make a scheme to amend`
  line `or vary any scheme made under sub-section (1).`
  line
  line `^11[(5) On and from the date of coming into operation of a scheme made under this section with respect`
  line `to any of the matters referred to in clause (c) of sub-section (2) or any matters incidental, consequential`
  line `and supplemental thereto,--`
  line
  line `(a) the scheme shall be binding on the corresponding new bank or corporations or banking`
  line `institutions, and also on the members, if any, the depositors, and other creditors and employees of`
  line `each of them and on any other persons having any right or liability in relation to any of them`
  line `including the trustees or other persons, managing or in any other manner connected with, any`
  line `provident fund or other fund maintained by any of them;`
  line
  line `(b) the properties and assets of the corresponding new bank, or as the case may be, of the banking`
  line `institution shall, by virtue of and to the extent provided in the scheme, stand transferred to, and vested`
  line `in, and the liabilities of the corresponding new bank, or, as the case may be, of the banking institution`
  line `shall, by virtue of, and to the extent provided in the scheme, stand transferred to, and become the`
  line `liabilities of, the corporation or corporations brought into existence by reconstitution of the banking`
  line `institution or the corresponding new bank, as the case may be.`
  line
  line `^12[Explanation I].-- In this section, "banking institution" means a banking company and includes`
  line `the State Bank of India or a subsidiary bank].`
  line
  line `^13[Explanation II.-- For the purposes of this section, the expression "corresponding new bank" shall include a corresponding new bank within the meaning of the Banking Companies (Acquisition`
  line `and Transfer of Undertakings) Act, 1980 (40 of 1980)].`
  line
  line `^14[(6)] Every scheme made by the Central Government under this Act shall be laid, as soon as may be`
  line `after it is made, before each House of Parliament while it is in session for a total period of thirty days`
  line `^15[which may be comprised in one session or in two or more successive sessions, and if, before the expiry`
  line `of the session immediately following the session or the successive sessions aforesaid], both Houses agree`
  line `in making any modification in the scheme or both Houses agree that the scheme should not be made, the`
  line `scheme shall thereafter have effect only in such modified form or be of no effect, as the case may be; so,`
  line `however, that any such modification or annulment shall be without prejudice to the validity of anything`
  line `previously done under that scheme.`
obj_root_law_sections_9_footnotes:
  string
  line `1. Certain words omitted by Act 37 of 1994, s. 6 (w.e.f. 3-4-1995).`
  line
  line `2. Subs. by Act 66 of 1988, s. 31, for "corresponding new bank to any other banking institution" (w.e.f. 30-12-1988).`
  line
  line `3. Ins. by Act 45 of 2006, s. 3 (w.e.f. 16-10-2006).`
  line
  line `4. Subs. by Act 37 of 1994, s. 6, for sub-section (3) (w.e.f. 3-4-1995).`
  line
  line `5. Subs. by Act 23 of 2019, s. 148, for clause (a) (w.e.f. 9-8-2019).`
  line
  line `6. Subs. by Act 45 of 2006, s. 3, for clause (c) (w.e.f. 16-10-2006).`
  line
  line `7. Clause (d) omitted by s. 3, ibid. (w.e.f. 16-10-2006).`
  line
  line `8. Subs. by s. 3, ibid., for clause (i) (w.e.f. 16-10-2006).`
  line
  line `9. Ins. by Act 45 of 2006, s. 3 (w.e.f. 16-10-2006).`
  line
  line `10. Subs. by s. 3, ibid., for "sub-section (3A)" (w.e.f. 16-10-2006).`
  line
  line `11. Ins. by Act 1 of 1984, s. 66 (w.e.f. 15-2-1984).`
  line
  line `12. Explanation numbered as Explanation I thereof by Act 66 of 1988, s. 31 (w.e.f. 30-12-1988).`
  line
  line `13. Ins. by Act 66 of 1988, s. 31 (w.e.f. 30-12-1988).`
  line
  line `14. Sub-section (5) re-numbered as sub-section (6) thereof by Act 1 of 1984, s. 66 (w.e.f. 15-2-1984).`
  line
  line `15. Subs. by s. 66, ibid., for certain words (w.e.f. 15-2-1984).`
obj_root_law_sections_9_a:
  sectionId (19178)
  sectionNo 9A
  orderNo 12
  title `Power of Reserve Bank to appoint additional director`
  content obj_root_law_sections_9_a_content
  footnotes `1.Ins. by Act 45 of 2006, s. 4 (w.e.f. 16-10-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19178&sectionno=9A&orderno=12&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_9_a_content:
  string
  line ^1
  line `[9A. Power of Reserve Bank to appoint additional director.--(1) If the Reserve Bank is of the`
  line `opinion that in the interest of banking policy or in the public interest or in the interests of the`
  line `corresponding new bank or its depositors, it is necessary so to do, it may, from time to time, by order in`
  line `writing appoint, with effect from such date as may be specified in the order, one or more persons to hold`
  line `office as additional directors of the corresponding new bank.`
  line
  line `(2) Any person appointed as an additional director in pursuance of this section--`
  line
  line `(a) shall hold office during the pleasure of the Reserve Bank and subject thereto for a period not`
  line `exceeding three years or such further periods not exceeding three years at a time as the Reserve Bank`
  line `may specify;`
  line
  line `(b) shall not incur any obligation or liability by reason only of his being a director or for anything`
  line `done or omitted to be done in good faith in the execution of the duties of his office or in relation`
  line `thereto; and`
  line
  line `(c) shall not be required to hold qualification shares in the corresponding new bank.`
  line
  line `(3) For the purpose of reckoning any proportion of the total number of directors of the corresponding`
  line `new bank, any additional director appointed under this section shall not be taken into account.]`
obj_root_law_sections_10:
  sectionId (19179)
  sectionNo (10)
  orderNo 13
  title `Closure of accounts and disposal of profits.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19179&sectionno=10&orderno=13&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_10_content:
  string
  line `(1) Every corresponding new bank shall cause its`
  line `books to be closed and balanced on the 31st day of December ^1[or such other date in each year as the`
  line `Central Government may by notification in the Official Gazette, specify] and shall appoint, with the`
  line `previous approval of the Reserve Bank, and auditors for the audit of its accounts:`
  line
  line `^2[Provided that with a view to facilitating the transition from one period of accounting to another`
  line `period of accounting under this sub-section, the Central Government may, by order published in the`
  line `Official Gazette, make such provisions as it considers necessary or expedient for the closing and`
  line `balancing of, or for other matters relating to the books in respect of the concerned years.]`
  line
  line `(2) Every auditor of a corresponding new bank shall be a person who is qualified to act as an auditor`
  line `of a company under ^3[section 141 of the Companies Act, 2013 (18 of 2013)] section 226 of the`
  line `Companies Act, 1956 (1 of 1956), and shall receive such remuneration as the ^4[corresponding new bank`
  line `may fix].`
  line
  line `(3) Every auditor shall be supplied with a copy of the annual balance-sheet and profit and loss`
  line `account and a list of all books kept by the corresponding new bank, and it shall be the duty of the auditor to examine the balance-sheet and profit and loss account with the accounts and vouchers relating thereto,`
  line `and in the performance of his duties, the auditor---`
  line
  line `(a) shall have, at all reasonable times, access to the books, accounts and other documents of the`
  line `corresponding new bank,`
  line
  line `(b) may, at the expense of the corresponding new bank, employ accountants or other persons to`
  line `assist him in investigating such accounts, and`
  line
  line `(c) may, in relation to such accounts, examine the Custodian or any officer or employee of the`
  line `corresponding new bank.`
  line
  line `(4) Every auditor of a corresponding new bank shall make a report to the Central Government upon`
  line `the annual balance-sheet and accounts and in every such report shall state--`
  line
  line `(a) whether, in his opinion, the balance-sheet is a full and fair balance-sheet containing all the`
  line `necessary particulars and is properly drawn up so as to exhibit a true and fair view of the affairs of the`
  line `corresponding new bank, and in case he had called for any explanation or information, whether it has`
  line `been given and whether it is satisfactory;`
  line
  line `(b) whether or not the transactions of the corresponding new bank, which have come to his notice,`
  line `have been within the powers of that bank;`
  line
  line `(c) whether or not the returns received from the offices and branches of the corresponding new`
  line `bank have been found adequate for the purpose of his audit;`
  line
  line `(d) whether the profit and loss account shows a true balance of profit or loss for the period`
  line `covered by such account; and`
  line
  line `(e) any other matter which he considers should be brought to the notice of the Central`
  line Government.
  line
  line `^5[Explanation I.---For the purposes of this Act---`
  line
  line `(a) the balance-sheet shall not be treated as not disclosing a true and fair view of the affairs of`
  line `the corresponding new bank, and`
  line
  line `(b) the profit and loss account shall not be treated as not showing a true balance of profit or`
  line `loss for the period covered by such account,`
  line
  line `merely by reason of the fact that the balance-sheet or, as the case may be, the profit and loss account`
  line `does not disclose any matters which are by the provisions of the Banking Regulation Act, 1949`
  line `(10 of 1949), read with the relevant provisions of this Act or any other Act, not required to be`
  line disclosed.
  line
  line `Explanation II.---For the purposes of this Act the accounts of the corresponding new bank shall`
  line `not be deemed as having not been properly drawn up on the ground merely that they do not disclose`
  line `certain matters if--`
  line
  line `(i) those matters are such as the corresponding new bank is, by virtue of any provision`
  line `contained in the Banking Regulation Act, 1949 (10 of 1949), read with the relevant provisions of`
  line `this Act, or any other Act, not required to disclose; and`
  line
  line `(ii) the provisions referred to in clause (i) are specified in the balance-sheet and profit and`
  line `loss account of the corresponding new bank or in the auditor's report.]`
  line
  line `(5) The report of the auditor shall be verified, signed and transmitted to the Central Government.`
  line
  line `(6) The auditor shall also forward a copy of the audit report to the corresponding new bank and to the`
  line `Reserve Bank.`
  line
  line `(7) After making provision for bad and doubtful debts, depreciation in assets, contributions to staff`
  line `and superannuation funds and all other matters for which provision is necessary under any law, or which are usually provided for by banking companies, a corresponding new bank ^6[may, out of its net profits,`
  line `declare a dividend and retain the surplus, if any].`
  line
  line `^7[(7A) Every corresponding new bank shall furnish to the Central Government ^8[and to the Reserve`
  line `Bank] the annual balance-sheet, the profit and loss account, and the auditor's report and a report by its`
  line `Board of directors on the working and activities of the bank during the period covered by the accounts.]`
  line
  line `(8) The Central Government shall cause every auditor's report and report on the working and`
  line `activities of each corresponding new bank to be laid ^9[as soon as may be after they are received before`
  line `each House of Parliament ^10***].`
  line
  line `^7[(9) Without prejudice to the foregoing provisions, the Central Government may, at any time,`
  line `appoint such number of auditors as it thinks fit to examine and report on the accounts of a corresponding`
  line `new bank and the auditors so appointed shall have all the rights, privileges and authority in relation to the`
  line `audit of the accounts of the corresponding new bank which an auditor appointed by the corresponding`
  line `new bank has under this section.]`
obj_root_law_sections_10_footnotes:
  string
  line `1. Subs. by Act 66 of 1988, s. 32, for "of each year" (w.e.f. 30-12-1988).`
  line
  line `2. Ins. by s. 32, ibid. (w.e.f. 30-12-1988).`
  line
  line `3. Subs. by Act 16 of 2025, s. 17, for "section 226 of the Companies Act, 1956 (1 of 1956)" (w.e.f. 1-8-2025).`
  line
  line `4. Subs. by s. 17, ibid., for "Reserve Bank may fix in consultation with the Central Government" (w.e.f. 1-8-2025).`
  line
  line `5. Ins. by Act 1 of 1984, s. 67 (w.e.f. 15-2-1984).`
  line
  line `6. Subs. by Act 37 of 1994, s. 7, for certain words (w.e.f. 15-7-1994).`
  line
  line `7. Ins. by Act 1 of 1984, s. 67 (w.e.f. 15-2-1984).`
  line
  line `8. Ins. by Act 37 of 1994, s. 7 (w.e.f. 15-7-1994).`
  line
  line `9. Subs. by Act 1 of 1984, s. 67, for certain words (w.e.f. 15-2-1984).`
  line
  line `10. Certain words omitted by Act 81 of 1985, s. 9 (w.e.f. 1-5-1986).`
obj_root_law_sections_10_a:
  sectionId (19180)
  sectionNo 10A
  orderNo 14
  title `Annual general meeting.`
  content obj_root_law_sections_10_a_content
  footnotes obj_root_law_sections_10_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19180&sectionno=10A&orderno=14&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_10_a_content:
  string
  line ^1
  line `[10A. Annual general meeting.--(1) A general meeting (in this Act referred to as an annual general`
  line `meeting) of every corresponding new bank which has issued capital under clause (c) of`
  line `sub-section (2B) of section 3 shall be held at the place of the head office of the bank in each year at such`
  line `time as shall from time to time be specified by the Board of Directors:`
  line
  line `Provided that such annual general meeting shall be held before the expiry of six weeks from the date`
  line `on which the balance sheet, together with the profit and loss account and auditor's report is under`
  line `sub-section (7A) of section 10, forwarded to the Central Government or to the Reserve Bank whichever`
  line `date is earlier.`
  line
  line `(2) The shareholders present at an annual general meeting ^2`
  line `[shall be entitled to discuss, approve and`
  line `adopt] the balance-sheet and the profit and loss account of the corresponding new bank made up to the`
  line `previous 31st day of March, the report of the Board of Directors on the working and activities of the`
  line `corresponding new bank for the period covered by the accounts and the auditor’s report on the`
  line `balance-sheet and accounts.]`
  line
  line ^3
  line `[(3) Nothing contained in this section shall apply during the period for which the Board of Directors`
  line `of a corresponding new bank had been superseded under sub-section (1) of section 18A:`
  line
  line `Provided that the Administrator may, if he considers it appropriate in the interest of the corresponding`
  line `new bank whose Board of Directors had been superseded, call annual general meeting in accordance with`
  line `the provisions of this section.]`
obj_root_law_sections_10_a_footnotes:
  string
  line `1. Ins. by Act 37 of 1994, s. 8 (w.e.f. 15-7-1994).`
  line
  line `2. Subs. by Act 45 of 2006, s. 5, for certain words (w.e.f. 16-10-2006).`
  line
  line `3. Ins. by s. 5, ibid. (w.e.f. 16-10-2006).`
obj_root_law_sections_10_b:
  sectionId (19181)
  sectionNo 10B
  orderNo 15
  title `Transfer of unpaid or unclaimed money.`
  content obj_root_law_sections_10_b_content
  footnotes obj_root_law_sections_10_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19181&sectionno=10B&orderno=15&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_10_b_content:
  string
  line `^1[10B. Transfer of unpaid or unclaimed ^2[money].--- (1) Where, after the commencement of the`
  line `Banking Companies (Acquisition and Transfer of Undertakings) and Financial Institutions Laws`
  line `(Amendment) Act, 2006 (45 of 2006), a dividend has been declared by a corresponding new bank but has`
  line `not been paid or claimed within thirty days from the date of declaration, to, or by, any shareholder entitled`
  line `to the payment of the dividend, the corresponding new bank shall, within seven days from the date of the`
  line `expiry of such period of thirty days, transfer the total amount of dividend which remains unpaid or`
  line `unclaimed within the said period of thirty days, to a special account to be called "Unpaid Dividend`
  line `Account of ... (the name of the corresponding new bank)".`
  line
  line `Explanation.--- In this sub-section, the expression "dividend which remains unpaid" means any`
  line `dividend the warrant in respect thereof has not been encashed or which has otherwise not been paid or`
  line claimed.
  line
  line `(2) Where the whole or any part of any dividend, declared by a corresponding new bank before the`
  line `commencement of the Banking Companies (Acquisition and Transfer of Undertakings) and Financial`
  line `Institutions Laws (Amendment) Act, 2006 (45 of 2006), remains unpaid at such commencement, the`
  line `corresponding new bank shall, within a period of six months from such commencement, transfer such`
  line `unpaid amount to the account referred to in sub-section (1).`
  line
  line `^3[(3) The corresponding new bank shall transfer, in accordance with the rules made under section 124`
  line `of the Companies Act, 2013 (18 of 2013), to the Investor Education and Protection Fund established`
  line `under section 125 of the said Act,-`
  line
  line `(i) any money which remains unpaid or unclaimed for a period of seven years from the date of its`
  line `transfer in the Unpaid Dividend Account of the corresponding new bank;`
  line
  line `(ii) all shares in respect of which dividend has not been paid or claimed for a period of seven`
  line `consecutive years, along with a statement thereof containing the details specified in the said rules;`
  line
  line `(iii) any interest or redemption amount upon any bond issued by the corresponding new bank`
  line `which remain unpaid or unclaimed for a period of seven years from the date such interest or such`
  line `redemption amount became due for payment.`
  line
  line `(3A) Any person whose shares or unclaimed or unpaid money has been transferred to the Investor`
  line `Education and Protection Fund under sub-section (3), shall be entitled to claim the transfer or refund from`
  line `the said Fund, in accordance with the rules made under section 124 and section 125 of the Companies`
  line `Act, 2013 (18 of 2013).]`
  line
  line `(4) The money transferred under sub-section (3) to the Investor Education and Protection Fund shall`
  line `be utilised for the purposes and in the manner specified in ^4[section 125 of the Companies act, 2013`
  line `(18 of 2013)].]`
obj_root_law_sections_10_b_footnotes:
  string
  line `1. Ins. by Act 45 of 2006, s. 6 (w.e.f. 16-10-2006).`
  line
  line `2. Subs. by Act 16 of 2025, s. 18, for "dividend to Unpaid Dividend Account" (w.e.f. 1-8-2025).`
  line
  line `3. Subs. by Act 16 of 2025, s. 18, for sub-section 3 (w.e.f. 1-8-2025).`
  line
  line `4. Subs. by s. 18, ibid., for "section 205C of the Companies Act, 1956 (1 of 1956)" (w.e.f. 1-8-2025).`
obj_root_law_sections_11:
  sectionId (19182)
  sectionNo (11)
  orderNo 16
  title `Corresponding new bank deemed to be an Indian company`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19182&sectionno=11&orderno=16&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_11_content:
  string
  line `For the purposes of the`
  line `Income-tax Act, 1961 (43 of 1961), every corresponding new bank shall be deemed to be an Indian`
  line `company and a company in which the public are substantially interested.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (19183)
  sectionNo (12)
  orderNo 17
  title `Removal of Chairman from office`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19183&sectionno=12&orderno=17&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_12_content:
  string
  line `(1) Every person holding office, immediately before the`
  line `commencement of this Act, as Chairman of an existing bank shall, if he becomes Custodian of the`
  line `corresponding new bank, be deemed, on such commencement, to have vacated office as such Chairman.`
  line
  line `(2) Save as otherwise provided in sub-section (1), every officer or other employee of an existing bank`
  line `shall become, on the commencement of this Act, an officer or other employee, as the case may be, of the`
  line `corresponding new bank and shall hold his office or service in that bank on the same terms and conditions`
  line `and with the same rights to pension, gratuity and other matters as would have been admissible to him if`
  line `the undertaking of the existing bank had not been transferred to and vested in the corresponding new bank`
  line `and continue to do so unless and until his employment in the corresponding new bank is terminated or`
  line `until his remuneration, terms or conditions are duly altered by the corresponding new bank.`
  line
  line `(3) For the persons who immediately before the commencement of this Act were the trustees for any`
  line `pension, provident, gratuity or other like fund constituted for the officers or other employees of an`
  line `existing bank, there shall be substituted as trustees such persons as the Central Government may, by`
  line `general or special order, specify.`
  line
  line `(4) Notwithstanding anything contained in the Industrial Disputes Act, 1947 (14 of 1947), or in any`
  line `other law for the time being in force, the transfer of the services of any officer or other employee from an`
  line `existing bank to a corresponding new bank shall not entitle such officer or other employee to any`
  line `compensation under this Act or any other law for the time being in force and no such claim shall be`
  line `entertained by any court, tribunal or other authority.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_12_a:
  sectionId (19184)
  sectionNo 12A
  orderNo 18
  title Bonus.
  content obj_root_law_sections_12_a_content
  footnotes `1. Ins. by Act 64 of 1984, s. 4 (w.e.f. 11-9-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19184&sectionno=12A&orderno=18&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_12_a_content:
  string
  line ^1
  line `[12A. Bonus.--(1) No officer or other employee [other than an employee within the meaning of`
  line `clause (13) of section 2 of the Payment of Bonus Act, 1965 (21 of 1965)] of a corresponding new bank`
  line `shall be entitled to be paid any bonus.`
  line
  line `(2) No employee of a corresponding new bank, being an employee within the meaning of clause (13)`
  line `of section 2 of the Payment of Bonus Act, 1965 (21 of 1965), shall be entitled to be paid any bonus except`
  line `in accordance with the provisions of that Act.`
  line
  line `(3) The provisions of this section shall have effect notwithstanding any judgment, decree or order of`
  line `any court, tribunal or other authority and notwithstanding anything contained in any other provision of`
  line `this Act or in the Industrial Disputes Act, 1947 (14 of 1947), or any other law for the time being in force`
  line `or any practice, usage or custom or any contract, agreement, settlement, award or other instrument.]`
obj_root_law_sections_13:
  sectionId (19185)
  sectionNo (13)
  orderNo 19
  title `. Obligations as to fidelity and secrecy.`
  content obj_root_law_sections_13_content
  footnotes `1. Ins. by Act 30 of 2005, s. 34 and Sch. (w.e.f. 14-12-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19185&sectionno=13&orderno=19&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_13_content:
  string
  line `(1) Every corresponding new bank shall observe, except`
  line `as otherwise required by law, the practices and usages customary among bankers, and, in particular, it`
  line `shall not divulge any information relating to or to the affairs of its constituents except in circumstances in`
  line `which it is, in accordance with law or practices and usages customary among bankers, necessary or`
  line `appropriate for the corresponding new bank to divulge such information.`
  line
  line `(2) Every director, member of a local board or a committee, or auditor, adviser, officer or other`
  line `employee of a corresponding new bank shall, before entering upon his duties, make a declaration of`
  line `fidelity and secrecy in the form set out in the Third Schedule.`
  line
  line `(3) Every Custodian of a corresponding new bank shall, as soon as possible, make a declaration of`
  line `fidelity and secrecy in the form set out in the Third Schedule.`
  line
  line ^1
  line `[(4) Nothing contained in this section shall apply to the credit information disclosed under the Credit`
  line `Information Companies (Regulation) Act, 2005 (30 of 2005).]`
obj_root_law_sections_14:
  sectionId (19186)
  sectionNo (14)
  orderNo 20
  title `Custodian to be public servant`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19186&sectionno=14&orderno=20&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_14_content:
  string
  line `Every Custodian of a corresponding new bank shall be`
  line `deemed to be a public servant for the purposes of Chapter IX of the Indian Penal Code (45 of 1860).`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (19187)
  sectionNo (15)
  orderNo 21
  title `Certain defects not to invalidate acts or proceedings`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19187&sectionno=15&orderno=21&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_15_content:
  string
  line `(1) All acts done by the Custodian,`
  line `acting in good faith, shall, notwithstanding any defect in his appointment or in the procedure, be valid.`
  line
  line `(2) No act or proceeding of any Board of Directors or a local board or committee of a corresponding`
  line `new bank shall be invalid merely on the ground of the existence of any vacancy in, or defect in the`
  line `constitution of, such board or committee, as the case may be.`
  line
  line `(3) All acts done by a person acting in good faith as a director or member of a local board or`
  line `committee of a corresponding new bank shall be valid, notwithstanding that it may afterwards be`
  line `discovered that his appointment was invalid by reason of any defect or disqualification or had terminated`
  line `by virtue of any provision contained in any law for the time being in force:`
  line
  line `Provided that nothing in this section shall be deemed to give validity to any act by a director or`
  line `member of a local board or committee of a corresponding new bank after his appointment has been shown`
  line `to the corresponding new bank to be invalid or to have terminated.`
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (19188)
  sectionNo (16)
  orderNo 22
  title Indemnity
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19188&sectionno=16&orderno=22&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_16_content:
  string
  line `(1) Every Custodian of a corresponding new bank and every officer of the Central`
  line `Government or of the Reserve Bank and every officer or other employee of a corresponding new bank,`
  line `shall be indemnified by such bank against all losses and expenses incurred by him in or in relation to the`
  line `discharge of his duties except such as have been caused by his own wilful act or default.`
  line
  line `(2) A director or member of a local board or committee of a corresponding new bank shall not be`
  line `responsible for any loss or expense caused to such bank by the insufficiency or deficiency of the value of,`
  line `or title to, any property or security acquired or taken on behalf of the corresponding new bank, or by the`
  line `insolvency or wrongful act of any customer or debtor, or by anything done in or in relation to the`
  line `execution of the duties of his office, unless such loss, expense, insufficiency or deficiency was due to any`
  line `wilful act or default on the part of such director or member.`
obj_root_law_sections_16_footnotes:
  string
  line
obj_root_law_sections_16_a:
  sectionId (19189)
  sectionNo 16A
  orderNo 23
  title `Arrangement with corresponding new bank on appointment of directors to prevail`
  content obj_root_law_sections_16_a_content
  footnotes `1. Ins. by Act 1 of 1984, s. 68 (w.e.f. 15-2-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19189&sectionno=16A&orderno=23&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_16_a_content:
  string
  line `^1[16A. Arrangement with corresponding new bank on appointment of directors to prevail.--(1)`
  line `Where any arrangement entered into by a corresponding new bank with a company provides for the`
  line `appointment by the corresponding new bank of one or more directors of such company, such provision`
  line `and any appointment of directors made in pursuance thereof shall be valid and effective notwithstanding`
  line `anything to the contrary contained in the Companies Act, 1956 (1 of 1956), or in any other law for the`
  line `time being in force or in the memorandum, articles of association or any other instrument relating to the`
  line `Company, and any provision regarding share qualification, age limit, number of directorships, removal`
  line `from office of directors and such like conditions contained in any such law or instrument aforesaid, shall`
  line `not apply to any director appointed by the corresponding new bank in pursuance of the arrangement as`
  line aforesaid.
  line
  line `(2) Any director appointed as aforesaid shall--`
  line
  line `(a) hold office during the pleasure of the corresponding new bank and may be removed or`
  line `substituted by any person by order in writing of the corresponding new bank;`
  line
  line `(b) not incur any obligation or liability by reason only of his being a director or for anything done`
  line `or omitted to be done in good faith in the discharge of his duties as a director or anything in relation`
  line thereto;
  line
  line `(c) not be liable to retirement by rotation and shall not be taken into account for computing the`
  line `number of directors liable to such retirement.]`
obj_root_law_sections_17:
  sectionId (19190)
  sectionNo (17)
  orderNo 24
  title `References to existing banks on and from the commencement of this Act.—`
  content obj_root_law_sections_17_content
  footnotes obj_root_law_sections_17_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19190&sectionno=17&orderno=24&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_17_content:
  string
  line `Any reference to`
  line `any existing bank in any law, other than this Act, or in any contract or other instrument shall, in so far as`
  line `it relates to the undertaking which has been transferred by section 4, be construed as a reference to the`
  line `corresponding new bank.`
obj_root_law_sections_17_footnotes:
  string
  line
obj_root_law_sections_18:
  sectionId (19191)
  sectionNo (18)
  orderNo 25
  title Dissolution
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19191&sectionno=18&orderno=25&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_18_content:
  string
  line `No provision of law relating to winding up of corporations shall apply to a`
  line `corresponding new bank and no corresponding new bank shall be placed in liquidation save by order of`
  line `the Central Government and in such manner as it may direct.`
obj_root_law_sections_18_footnotes:
  string
  line
obj_root_law_sections_18_a:
  sectionId (19192)
  sectionNo 18A
  orderNo 26
  title `Supersession of Board in certain cases`
  content obj_root_law_sections_18_a_content
  footnotes `1. Ins. by Act 45 of 2006, s. 7 (w.e.f. 16-10-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19192&sectionno=18A&orderno=26&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_18_a_content:
  string
  line `^1[18A. Supersession of Board in certain cases.--(1) Where the Central Government, on the`
  line `recommendation of the Reserve Bank, is satisfied that in the public interest or for preventing the affairs of`
  line `any corresponding new bank being conducted in a manner detrimental to the interest of the depositors or`
  line `the corresponding new bank or for securing the proper management of any corresponding new bank, it is`
  line `necessary so to do, the Central Government may, for reasons to be recorded in writing, by order,`
  line `supersede the Board of Directors of such corresponding new bank for a period not exceeding six months`
  line `as may be specified in the order:`
  line
  line `Provided that the period of supersession of the Board of Directors may be extended from time to time,`
  line `so, however, that the total period shall not exceed twelve months.`
  line
  line `(2) The Central Government may, on supersession of the Board of Directors of the corresponding`
  line `new bank under sub-section (1), appoint, in consultation with the Reserve Bank, for such period as it may`
  line `determine, an Administrator (not being an officer of the Central Government or a State Government) who`
  line `has experience in law, finance, banking, economics or accountancy.`
  line
  line `(3) The Central Government may issue such directions to the Administrator as it may deem`
  line `appropriate and the Administrator shall be bound to follow such directions.`
  line
  line `(4) Upon making the order of supersession of the Board of Directors of the corresponding new bank,`
  line `notwithstanding anything contained in this Act,--`
  line
  line `(a) the chairman, managing directors and other directors shall, as from the date of supersession,`
  line `vacate their offices as such;`
  line
  line `(b) all the powers, functions and duties which may, by or under the provisions of this Act or any`
  line `other law for the time being in force, be exercised and discharged by or on behalf of the Board of`
  line `Directors of such corresponding new bank, or by a resolution passed in general meeting of such`
  line `corresponding new bank, shall, until the Board of Directors of such corresponding new bank is`
  line `reconstituted, be exercised and discharged by the Administrator appointed by the Central Government`
  line `under sub-section (2):`
  line
  line `Provided that the power exercised by the Administrator shall be valid notwithstanding that such`
  line `power is exercisable by a resolution passed in the general meeting of the corresponding new bank.`
  line
  line `(5) The Central Government may constitute, in consultation with the Reserve Bank, a committee of`
  line `three or more persons who have experience in law, finance, banking, economics or accountancy to assist`
  line `the Administrator in the discharge of his duties.`
  line
  line `(6) The committee shall meet at such times and places and observe such rules of procedure as may be`
  line `specified by the Central Government.`
  line
  line `(7) The salary and allowances payable to the Administrator and the members of the committee`
  line `constituted under sub-section (5) by the Central Government shall be such as may be specified by the`
  line `Central Government and be payable by the concerned corresponding new bank.`
  line
  line `(8) On and before the expiration of two months before expiry of the period of supersession of the`
  line `Board of Directors as specified in the order issued under sub-section (1), the Administrator of the`
  line `corresponding new bank, shall call the general meeting of the corresponding new bank to elect new`
  line `directors and reconstitute its Board of Directors.`
  line
  line `(9) Notwithstanding anything contained in any other law or in any contract, the memorandum or`
  line `articles of association, no person shall be entitled to claim any compensation for the loss or termination of`
  line `his office.`
  line
  line `(10) The Administrator appointed under sub-section (2) shall vacate office immediately after the`
  line `Board of Directors of the corresponding new bank has been reconstituted.]`
obj_root_law_sections_19:
  sectionId (19193)
  sectionNo (19)
  orderNo 27
  title `Power to make regulations.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19193&sectionno=19&orderno=27&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_19_content:
  string
  line `(1) The Board of Directors of a corresponding new bank may,`
  line `after consultation with the Reserve Bank and with the previous sanction of the Central Government, ^1`
  line [by
  line `notification in the Official Gazette,] make regulations, not inconsistent with the provisions of this Act or`
  line `any scheme made thereunder, to provide for all matters for which provision is expedient for the purpose`
  line `of giving effect to the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, the regulations may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the powers, functions and duties of local boards and restrictions, conditions or limitations, if`
  line `any, subject to which they may be exercised or performed, the formation and constitution of local`
  line `committees and committees of local board (including the number of members of any such`
  line `committee), the powers, functions and duties of such committees, the holding of meetings of local`
  line `committees and committees, of local boards and the conduct of business thereat;`
  line
  line `(b) the manner in which the business of the local boards shall be transacted and the procedure in`
  line `connection therewith;`
  line
  line ^2
  line `[(ba) the nature of shares of the corresponding new bank, the manner in which and the`
  line `conditions subject to which shares may be held and transferred and generally all matters relating to`
  line `the rights and duties of shareholders;`
  line
  line `(bb) the maintenance of register, and the particulars to be entered in the register in addition to`
  line `those specified in sub-section (2F) of section 3, the safeguards to be observed in the maintenance of`
  line `register on computer floppies or diskettes, inspection and closure of the register and all other matters`
  line `connected therewith:`
  line
  line `(bc) the manner in which general meetings shall be convened, the procedure to be followed`
  line `thereat and the manner in which voting rights may be exercised;`
  line
  line `(bd) the holding of meetings of shareholders and the business to be transacted thereat;`
  line
  line `(be) the manner in which notices may be served on behalf of the corresponding new bank upon`
  line `shareholders or other persons;`
  line
  line `(bf) the manner in which the directors nominated under clause (h) of sub-section (3) of section 9`
  line `shall retire;]`
  line
  line `(c) the delegation of powers and functions of the board of directors of a corresponding new bank`
  line `to the general manager, director, officer or other employee of that bank;`
  line
  line `(d) the conditions or limitations subject to which the corresponding new bank may appoint`
  line `advisers, officers or other employees and fix their remuneration and other terms and conditions of`
  line service;
  line
  line `(e) the duties and conduct of advisers, officers or other employees of the corresponding new`
  line bank;
  line
  line `(f) the establishment and maintenance of superannuation, pension, provident or other funds for`
  line `the benefit of officers or other employees of the corresponding new bank or of the dependants of such`
  line `officers or other employees and the granting of superannuation allowances, annuities and pensions`
  line `payable out of such funds;`
  line
  line `(g) the conduct and defence of legal proceedings by or against the corresponding new bank and`
  line `the manner of signing pleadings;`
  line
  line `(h) the provision of a seal for the corresponding new bank and the manner and effect of its use;`
  line
  line `(i) the form and manner in which contracts binding on the corresponding new bank may be`
  line executed;
  line
  line `(j) the conditions and the requirements subject to which loans or advances may be made or bills`
  line `may be discounted or purchased by the corresponding new bank;`
  line
  line `(k) the persons or authorities who shall administer any pension, provident or other fund`
  line `constituted for the benefit of officers or other employees of the corresponding new bank or their`
  line dependants;
  line
  line `(l) the preparation and submission of statements of programmes of activities and financial`
  line `statements of the corresponding new bank and the period for which and the time within which such`
  line `statements and estimates are to be prepared and submitted; and`
  line
  line `(m) generally for the efficient conduct of the affairs of the corresponding new bank.`
  line `(3) Until any regulation is made under sub-section (1), the articles of association of the existing bank`
  line `and every regulation, rule, bye-law or order made by the existing bank shall, if in force at the`
  line `commencement of this Act, be deemed to be the regulations made under sub-section (1) and shall have`
  line `effect accordingly and any reference therein to any authority of the existing bank shall be deemed to be a`
  line `reference to the corresponding authority of the corresponding new bank and until any such corresponding`
  line `authority is constituted under this Act, shall be deemed to refer to the Custodian.`
  line
  line ^3
  line `[(4) Every regulation shall, as soon as may be after it is made under this Act by the Board of`
  line `directors, of a corresponding new bank, be forwarded to the Central Government and that Government`
  line `shall cause a copy of the same to be laid before each House of Parliament, while it is in session, for a total`
  line `period of thirty days which may be comprised in one session or in two or more successive sessions, and`
  line `if, before the expiry of the session immediately following the session or the successive sessions aforesaid,`
  line `both Houses agree in making any modification in the regulation or both Houses agree that the regulation`
  line `should not be made, the regulation shall thereafter have effect only in such modified form or be of no`
  line `effect, as the case may be; so, however, that any such modification or annulment shall be without`
  line `prejudice to the validity of anything previously done under that regulation.]`
obj_root_law_sections_19_footnotes:
  string
  line `1. Ins. by Act 4 of 1986, s. 2 and the Sch. (w.e.f. 5-5-1986).`
  line
  line `2. Ins. by Act 37 of 1994, s. 9 (w.e.f. 15-7-1994).`
  line
  line `3. Ins. by Act 1 of 1984, s. 69 (w.e.f. 15-2-1984).`
obj_root_law_sections_20:
  sectionId (19194)
  sectionNo (20)
  orderNo 28
  title `Amendment of certain enactments`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19194&sectionno=20&orderno=28&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_20_content:
  string
  line `(1) In the Banking Regulation Act, 1949 (10 of 1949),--`
  line
  line `(a) in section 34A, in sub-section (3), for the words "and any subsidiary bank", the words, figures`
  line `and brackets "a corresponding new bank constituted under section 3 of the Banking Companies`
  line `(Acquisition and Transfer of Undertakings) Act, 1970 (5 of 1970) and any subsidiary bank" shall be`
  line substituted;
  line
  line `(b) in section 36AD, in sub-section (3), for the words "and any subsidiary bank", the words,`
  line `figures and brackets "a corresponding new bank constituted under section 3 of the Banking Companies (Acquisition and Transfer of Undertakings) Act, 1970 (5 of 1970), and any subsidiary`
  line `bank" shall be substituted;`
  line
  line `(c) in section 51, for the words "or any other banking institution notified by the Central`
  line `Government in this behalf", the words, figures and brackets "or any corresponding new bank`
  line `constituted under section 3 of the Banking Companies (Acquisition and Transfer of Undertakings)`
  line `Act, 1970 (5 of 1970), or any other banking institution notified by the Central Government in this`
  line `behalf" shall be substituted;`
  line
  line `(d) in the Fifth Schedule, in Part I of paragraph 1, in clause (e), the Explanations shall be deemed`
  line `never to have been inserted.`
  line
  line `(2) In the Industrial Disputes Act, 1947 (14 of 1947), in section 2, in clause (bb), for the words "and`
  line `any subsidiary bank", the words, figures and brackets "a corresponding new bank constituted under`
  line `section 3 of the Banking Companies (Acquisition and Transfer of Undertakings) Act, 1970 (5 of 1970),`
  line `and any subsidiary bank" shall be substituted.`
  line
  line `(3) In the Banking Companies (Legal Practitioners, Clients, Accounts) Act, 1949 (46 of 1949), in`
  line `section 2, in clause (a), for the words "and any subsidiary bank", the words, figures and brackets "a`
  line `corresponding new bank constituted under section 3 of the Banking Companies (Acquisition and Transfer`
  line `of Undertakings) Act, 1970 (5 of 1970), and any subsidiary bank" shall be substituted.`
  line
  line `(4) In the Deposit Insurance Corporation Act, 1961 (47 of 1961),--`
  line
  line `(a) in section 2,--`
  line
  line `(i) after clause (e), the following clause shall be inserted, namely:--`
  line
  line `(ee) "corresponding new bank" means a corresponding new bank constituted under`
  line `section 3 of the Banking Companies (Acquisition and Transfer of Undertakings) Act, 1970`
  line `(5 of 1970);`
  line
  line `(ii) in clause (g),--`
  line
  line `(a) for the words "or a banking company", the words "a corresponding new bank or a`
  line `banking company", and`
  line
  line `(b) for the words "with a banking company", the words "with a corresponding new bank`
  line `or with a banking company",`
  line
  line `shall be substituted;`
  line
  line `(iii) in clause (i), after the words "banking company", the words "or a corresponding new`
  line `bank" shall be inserted;`
  line
  line `(b) section 13 shall be re-numbered as sub-section (1) thereof and after sub-section (1) as so`
  line `re-numbered, the following sub-section shall be inserted, namely:--`
  line
  line `"(2) The provisions of clauses (a), (b), (c), (d) and (h) of sub-section (1) shall apply to a`
  line `corresponding new bank as they apply to a banking company."`
  line
  line `(5) In the State Agricultural Credit Corporations Act, 1968 (60 of 1968),--`
  line
  line `(a) in section 2, after clause (i), the following clause shall be inserted, namely:--`
  line
  line `(ii) "corresponding new bank" means a corresponding new bank constituted under section 3`
  line `of the Banking Companies (Acquisition and Transfer of Undertakings) Act, 1970 (5 of 1970)';`
  line
  line `(b) after the words "subsidiary banks" or "subsidiary bank", as the case may be, occurring in`
  line `clause (d) of sub-section (3) of section 5, in clause (b) of section 9 and in the proviso to section 18,`
  line `the words "corresponding new banks" or "corresponding new bank", as the case may be, shall be`
  line inserted.
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (19195)
  sectionNo (21)
  orderNo 29
  title `Repeal and savings`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00023_197005_1517807321575&sectionId=19195&sectionno=21&orderno=29&orgactid=AC_CEN_2_11_00023_197005_1517807321575
obj_root_law_sections_21_content:
  string
  line `(1) The Banking Companies (Acquisition and Transfer of Undertakings)`
  line `Ordinance, 1970 (Ord. 3 of 1970), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal and notwithstanding any judgment, decree or order of any court or`
  line tribunal,--
  line
  line `(a) any action taken, or purported to have been taken, or anything done, or purported to have been`
  line `done, between the 19th day of July, 1969, and the 10th day of February, 1970, by any corresponding`
  line `new bank purported to have been constituted under the Banking Companies (Acquisition and Transfer`
  line `of Undertakings) Ordinance, 1969 (8 of 1969), or the Banking Companies (Acquisition and Transfer`
  line `of Undertakings) Act, 1969 (22 of 1969), or by any person purporting to act on behalf of such bank`
  line `and any right, obligation or liability acquired or incurred, between the said dates, by or on behalf of`
  line `such corresponding new bank shall be deemed to have been taken, done, acquired or incurred under`
  line `the provisions of this Act by or on behalf of the corresponding new bank constituted thereunder;`
  line
  line `(b) any action taken, or purported to have been taken, or anything done, or purported to have been`
  line `done, between the 10th day of February, 1970, and the appointed day, by an existing bank or by any`
  line `person acting on behalf of such bank, and any right, obligation or liability acquired or incurred,`
  line `between the said dates, by or on behalf of such existing bank shall be deemed to have been taken,`
  line `done, acquired or incurred under the provisions of this Act by or on behalf of the corresponding new`
  line `bank constituted thereunder;`
  line
  line `(c) anything done or any action taken, including any order made, notification issued or directions`
  line `given under the Banking Companies (Acquisition and Transfer of Undertakings) Ordinance, 1970`
  line `(3 of 1970), shall be deemed to have been done, taken, made, issued or given, as the case may be,`
  line `under the corresponding provisions of this Act.`
  line
  line `(3) Any suit, appeal or other proceeding of whatever nature instituted on or after the 19th day of July,`
  line `1969, by or against a corresponding new bank purported to have been constituted by the Banking`
  line `Companies (Acquisition and Transfer of Undertakings) Ordinance, 1969 (8 of 1969), or the Banking`
  line `Companies (Acquisition and Transfer of Undertakings) Act, 1969 (22 of 1969), shall not abate, be`
  line `discontinued, or be, in any way, prejudicially affected by reason of the expiry of the said Ordinance or the`
  line `invalidation of the said Act, as the case may be, but such suit, appeal or other proceeding may be`
  line `continued, prosecuted and enforced by or against the corresponding new bank as if such suit, appeal or`
  line `other proceeding had been instituted by or against the corresponding new bank constituted under this Act.`
obj_root_law_sections_21_footnotes:
  string
  line
