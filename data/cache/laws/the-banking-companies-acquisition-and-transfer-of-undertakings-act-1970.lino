  (str title) (str `The Banking Companies (Acquisition and Transfer of Undertakings) Act, 1970`)
  (str actNumber) (str 5)
  (str enactmentDate) (str 1970-03-31)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1373`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `बैंककारी कम्‍पनी (उपक्रमों का अर्जन और अन्‍तरण) अधिनियम, 1970`)
  (str actYear) (str 1970)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Financial Services`)
  (str longTitle) (str `An Act to provide for the acquisition and transfer of the undertakings of certain banking companies, having regard to their size, resources, coverage and organisation, in order to control the heights of the economy and to meet progressively, and serve better, the needs of development of the economy in conformity with national policy and objectives and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 19-07-1969)
  (str notification) (undefined)
