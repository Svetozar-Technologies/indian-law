  footnotes obj_root_law_translations_hi_sections_3_footnotes
  sourcePage 3
obj_root_law_translations_hi_sections_3_content:
  string
  line iii
  line धाराएं
  line `अध्या य 11 स्`
  line `था िीय जैव ववववधता विवध`
  line `42. जैव ववववधता विवध को अिुदाि।`
  line `43. स् था िीय जैव वववव धता विवध का गठि।`
  line `44. स् था िीय जैव ववववधता विवध का उपयोजि।`
  line `45. जैव ववववधता प्र िंध सवमवत की वार्षडक ररपोटड।`
  line `46. जैव ववववधता प्र िंध सवमवत के लेखाओं की लेखापरीिा।`
  line `47. जैव ववववधता प्र िंध सवमवतयों की वार्षडक ररपोटड, आक्रद का वजला मवजस्रे ट को प्रस् तु त क्र कया जािा।`
  line `अध्या य 12 प्र`
  line कीणड
  line `48. राष्‍टरी य जैव ववववधता प्र ावधकरण का, केन्री य सरकार द्व ारा क्र दए गए विदेशों से आिि होिा।`
  line `49. राज्य सरकार की विदेश देिे की शवत।`
  line `50. राज्य ववववधता िोर्ों के िीच वववादों का विपटाि।`
  line `51. राष्‍टरी य जैव ववववधता प्र ा वधकरण और राज्य जैव ववववधता िोर्ड के सदस्यों, अवधकाररयों आक्रद का लोक सेवक समझा`
  line जािा।
  line `52. अपील।`
  line `52 क. राष्‍टरी य हररत अवधकरण को अपील।`
  line `53. अवधारण या आदेश का विष्‍टपा दि।`
  line `54. सद्भावपूवडक की गई कारडवाई के वलए संरिण।`
  line `55. शावस्त यां।`
  line `56. केन्री य सरकार, राज्य सरकार, राष्‍टरी य जैव ववववधता प्र ावधकरण और राज्य जैव ववववधता िोर्ों के विदेशों या आदेशों`
  line `के उल्लं घि के वलए शावस्त।`
  line `57. कंपवियों द्व ारा अपराध।`
  line `58. अपराधों का संज्ञेय और अजमाितीय होिा।`
  line `59. अवधवियम का प्र िाव अन्य अवधवियमों के अवतररत होगा।`
  line `60. राज्य सरकार को विदेश देिे की केन्री य सरकार की शवत।`
  line `61. अपराधों का संज्ञाि।`
  line `62. केन्री य सरकार की वियम ििािे की शवत।`
  line `63. राज्य सरकार की वियम ििािे की शवत।`
  line `64. वववियम ििािे की शवत।`
  line `65. करठिाइयों को दूर करिे की शवत।`
obj_root_law_translations_hi_sections_3_footnotes:
  string
  line
obj_root_law_translations_hi_sections_4:
  kind page
  sectionId pdf-page-4
  sectionNo (4)
