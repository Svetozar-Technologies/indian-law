obj_root_law:
  object
  (str slug) (str the-india-international-arbitration-centre-act-2019)
  (str handle) (str 11413)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The India International Arbitration Centre Act, 2019`)
  (str actNumber) (str 17)
  (str enactmentDate) (str 2019-07-26)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/11413`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `नई दिल्ली अन्तरराष्ट्रीदय माध्यस्थम् केंद्र अधिनियम, 2019`)
  (str actYear) (str 2019)
  (str ministry) (str `Ministry of Law and Justice`)
  (str department) (str `Department of Legal Affairs`)
  (str longTitle) (str `An Act to provide for the establishment and incorporation of the New Delhi International Arbitration Centre for the purpose of creating an independent and autonomous regime for institutionalised arbitration and for acquisition and transfer of the undertakings of the International Centre for Alternative Dispute Resolution and to vest such undertakings in the New Delhi International Arbitration Centre for the better management of arbitration so as to make it a hub for institutional arbitration and to declare the New Delhi International Arbitration Centre to be an institution of national importance and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 02-03-2019)
  (str notification) (undefined)
  (str fetchedAt) (str `2026-05-09T15:52:45.570Z`)
  (str translations) obj_root_law_translations
