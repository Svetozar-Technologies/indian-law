obj_root_law:
  slug the-india-international-arbitration-centre-act-2019
  handle (11413)
  collectionHandle 123456789/1362
  title `The India International Arbitration Centre Act, 2019`
  actNumber (17)
  enactmentDate 2019-07-26
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/11413`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `नई दिल्ली अन्तरराष्ट्रीदय माध्यस्थम् केंद्र अधिनियम, 2019`
  actYear (2019)
  ministry `Ministry of Law and Justice`
  department `Department of Legal Affairs`
  longTitle `An Act to provide for the establishment and incorporation of the New Delhi International Arbitration Centre for the purpose of creating an independent and autonomous regime for institutionalised arbitration and for acquisition and transfer of the undertakings of the International Centre for Alternative Dispute Resolution and to vest such undertakings in the New Delhi International Arbitration Centre for the better management of arbitration so as to make it a hub for institutional arbitration and to declare the New Delhi International Arbitration Centre to be an institution of national importance and for matters connected therewith or incidental thereto.`
  enforcementDate 02-03-2019
  notification undefined
  fetchedAt `2026-05-09T15:52:45.570Z`
  translations obj_root_law_translations
