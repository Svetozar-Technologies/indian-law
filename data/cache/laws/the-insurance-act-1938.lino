  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18323&sectionno=110A&orderno=230&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_110_a_content:
  string
  line `^1[110A. Delegation of powers and duties of ^2[Chairperson of the Authority]. -- The ^2[Chairperson of`
  line `the Authority] may by general or special order delegate any of his powers or duties under this Act to any`
  line `person subordinate to him. The exercise or discharge of any of the powers or duties so delegated shall be`
  line `subject to such restrictions, limitations and conditions, if any, as the ^2[Chairperson of the Authority] may`
  line `impose, and shall be subject to his control and revision.`
obj_root_law_sections_110_a_footnotes:
  string
  line `1. Ins. by Act 20 of 1940, s. 14 (w.e.f. 10-4-1940).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule (serial no. 43), for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_110_b:
  sectionId (18324)
  sectionNo 110B
  orderNo 231
  title `Signature of documents.`
  content obj_root_law_sections_110_b_content
  footnotes obj_root_law_sections_110_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18324&sectionno=110B&orderno=231&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_110_b_content:
  string
  line `^1[110B. Signature of documents. --Every document which is required by this Act or by any rule`
  line `made thereunder to be signed by the ^2[Chairperson of the Authority] or by any person subordinate to him`
  line `or by any officer authorised by him under sub-section (1) of section 42 shall be deemed to be properly`
  line `signed, if it bears a facsimile of the signature of such ^2[Chairperson of the Authority], person or officer`
  line `printed, engraved, lithographed or impressed by any other mechanical process approved by the Central`
  line Government.]
obj_root_law_sections_110_b_footnotes:
  string
  line `1. Ins. by Act 20 of 1940, s. 14 (w.e.f. 10-4-1940).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule (serial no. 43), for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_110_c:
  sectionId (18325)
  sectionNo 110C
  orderNo 232
  title `Power to call for information.`
  content obj_root_law_sections_110_c_content
  footnotes obj_root_law_sections_110_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18325&sectionno=110C&orderno=232&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_110_c_content:
  string
  line `^2[110C. Power to call for information. --(1) The ^1[Chairperson of the Authority] may, by notice in`
  line `writing, require any insurer to supply him with any information relating to his insurance business, and the`
  line `insurer shall comply with such requirement within such period after receipt of the notice as may be`
  line `specified therein.`
  line
  line `(2) Any information supplied under this section shall be certified by a principal officer of the insurer`
  line `and if the notice so requires also by an auditor.]`
obj_root_law_sections_110_c_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the First Schedule (serial no. 43), for "Controller" (w.e.f. 19-4-2000).`
  line
  line `2. Ins. by Act 47 of 1950, s. 59 (w.e.f. 1-6-1950)`
obj_root_law_sections_110_d:
