  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18133&sectionno=25&orderno=39&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_25_content:
  string
  line `No insurer shall publish in ^2[India] any return in a`
  line `form other than that in which it has been furnished to the ^1[Authority]:`
  line
  line `Provided that nothing contained in this section shall prevent an insurer from publishing a true and`
  line `accurate abstract from such returns for the purposes of publicity.`
obj_root_law_sections_25_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by Act 62 of 1956, s. 2 and the Schedule, for "the States" (w.e.f. 1-11-1956).`
obj_root_law_sections_26:
  sectionId (18134)
  sectionNo (26)
  orderNo 40
  title `Alterations in the particulars furnished with application for registration to be reported.`
  content obj_root_law_sections_26_content
  footnotes obj_root_law_sections_26_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18134&sectionno=26&orderno=40&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_26_content:
  string
  line `Whenever any alteration occurs or is made which affects any of the matters which are required under the`
  line `provisions of sub-section (2) of section 3 to accompany an application by an insurer for registration, the`
  line `insurer shall forthwith furnish to the ^1[Authority] full particulars of such alteration. ^2[All such particulars`
  line `shall be authenticated in the manner required by that sub-section for the authentication of the matters`
  line `therein referred to, and, where the alteration affects the assured rates, advantages, terms and conditions`
  line `offered in connection with life insurance policies the actuarial certificate referred to in clause (f) of the`
  line `said sub-section shall accompany the particulars of the alteration.]`
obj_root_law_sections_26_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `2. Added by Act 13 of 1941, s. 17 (w.e.f. 8-4-1941).`
obj_root_law_sections_27:
  sectionId (18135)
  sectionNo (27)
  orderNo 41
  title `Investment of assets.`
  content obj_root_law_sections_27_content
  footnotes obj_root_law_sections_27_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18135&sectionno=27&orderno=41&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_27_content:
  string
  line `^1[27. Investment of assets. --(1) Every insurer shall invest and at all times keep invested assets`
  line `equivalent to not less than the sum of--`
  line
  line `(a) the amount of his liabilities to holders of life insurance policies in India on account of matured`
  line `claims, and`
  line
  line `(b) the amount required to meet the liability on policies of life insurance maturing for payment in`
  line India,
  line
  line less--
  line
  line `(i) the amount of premiums which have fallen due to the insurer on such policies but have not`
  line `been paid and the days of grace for payment of which have not expired, and`
  line
  line `(ii) any amount due to the insurer for loans granted on and within the surrender values of policies`
  line `of life insurance maturing for payment in India issued by him or by an insurer whose business he has`
  line `acquired and in respect of which he has assumed liability in the following manner, namely: --`
  line
  line `(a) twenty-five per cent. of the said sum in Government securities, a further sum equal to not`
  line `less than twenty-five per cent. of the said sum in Government securities or other approved`
  line `securities; and`
  line
  line `(b) the balance in any of the approved investments,`
  line
  line `as may be specified by the regulations subject to the limitations, conditions and restrictions specified`
  line therein.
  line
  line `(2) In the case of an insurer carrying on general insurance business, twenty per cent. of the assets in`
  line `Government Securities, a further sum equal to not less than ten per cent. of the assets in Government`
  line `Securities or other approved securities and the balance in any other investment in accordance with the`
  line `regulations of the Authority and subject to such limitations, conditions and restrictions as may be`
  line `specified by the Authority in this regard.`
  line
  line `Explanation. --In this section, the term assets means all the assets of insurer at their carrying value`
  line `but does not include any assets specifically held against any fund or portion thereof in respect of which`
  line `the Authority is satisfied that such fund or portion thereof, as the case may be, is regulated by the law of`
  line `any country outside India or miscellaneous expenditure or in respect of which the Authority is satisfied`
  line `that it would not be in the interest of the insurer to apply the provisions of this section.`
  line
  line `(3) For the purposes of sub-sections (1) and (2), any specified assets shall, subject to such conditions,`
  line `if any, as may be specified, be deemed to be assets invested or kept invested in approved investments`
  line `specified by regulations.`
  line
  line `(4) In computing the assets referred to in sub-sections (1) and (2), any investment made with`
  line `reference to any currency other than the Indian rupee which is in excess of the amount required to meet`
  line `the liabilities of the insurers in India with reference to that currency, to the extent of such excess, shall not`
  line `be taken into account:`
  line
  line `Provided that nothing contained in this sub-section shall affect the operation of sub-section (2):`
  line
  line `Provided further that the Authority may, either generally or in any particular case, direct that any`
  line `investment shall, subject to such conditions as may be imposed, be taken into account, in such manner as`
  line `may be specified in computing the assets referred to in sub-sections (1) and (2) and where any direction has been issued under this proviso, copies thereof shall be laid before each house of Parliament as soon as`
  line `may be after it is issued.`
  line
  line `(5) Where an insurer has accepted re-insurance in respect of any policies of life insurance issued by`
  line `another insurer and maturing for payment in India or has ceded re-insurance to another insurer in respect`
  line `of any such policies issued by himself, the sum referred to in sub-section (1) shall be increased by the`
  line `amount of the liability involved in such acceptance and decreased by the amount of the liability involved`
  line `in such cession.`
  line
  line `(6) The Government securities and other approved securities in which assets are under sub-section (1)`
  line `or sub-section (2) to be invested and kept invested shall be held by the insurer free of any encumbrance,`
  line `charge, hypothecation or lien.`
  line
  line `(7) The assets required by this section to be held invested by an insurer incorporated or domiciled`
  line `outside India shall, except to the extent of any part thereof which consists of foreign assets held outside`
  line `India, be held in India and all such assets shall be held in trust for the discharge of the liabilities of the`
  line `nature referred to in sub-section (1) and shall be vested in trustees resident in India and approved by the`
  line `Authority, and the instrument of trust under this sub-section shall be executed by the insurer with the`
  line `approval of the Authority and shall define the manner in which alone the subject-matter of the trust shall`
  line `be dealt with.`
  line
  line ^2*****
obj_root_law_sections_27_footnotes:
  string
  line `1. Subs. by Act 5 of 2015, s. 26, for sections 27, 27A, 27B, 27C and 27D (w.e.f. 26-12-2014).`
  line
  line `2. Explanation omitted by Act 6 of 2021, s. 3 (w.e.f. 1-4-2021).`
obj_root_law_sections_27_a:
  sectionId (18136)
  sectionNo 27A
  orderNo 42
  title `Further provisions regarding investments.`
  content obj_root_law_sections_27_a_content
  footnotes obj_root_law_sections_27_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18136&sectionno=27A&orderno=42&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_27_a_content:
  string
  line `(1) No insurer carrying on life insurance`
  line `business shall invest or keep invested any part of his controlled fund and no insurer carrying on general`
  line `business shall invest or keep invested any part of his assets otherwise than in any of the approved`
  line `investments as may be specified by the regulations subject to such limitations, conditions and restrictions`
  line therein.
  line
  line `(2) Notwithstanding anything contained in sub-section (1) or sub-section (2) of section 27, an insurer`
  line `may, subject to the provisions contained in the next succeeding sub-sections, invest or keep invested any`
  line `part of his controlled fund or assets otherwise than in an approved investment, if--`
  line
  line `(i) after such investment, the total amounts of all such investments of the insurer do not exceed`
  line `fifteen per cent. of the sum referred to in sub-section (1) of section 27 or fifteen per cent. of the assets`
  line `referred to in sub-section (2) as the case may be;`
  line
  line `(ii) the investment is made, or, in the case of any investment already made, the continuance of`
  line `such investment is with the consent of all the directors present at a meeting and eligible to vote,`
  line `special notice of which has been given to all the directors then in India, and all such investments,`
  line `including investments in which any director is interested, are reported without delay to the Authority`
  line `with full details of the investments and the extent of the director's interest in any such investment.`
  line
  line `(3) An insurer shall not out of his controlled fund or assets as referred to in section 27, --`
  line
  line `(a) invest in the shares of any one banking company; or`
  line
  line `(b) invest in the shares or debentures of any one company,`
  line
  line `more than the percentage specified by the regulations.`
  line
  line `(4) An insurer shall not out of his controlled fund or assets as referred to in sub-section (2) of`
  line `section 27 invest or keep invested in the shares or debentures of any private limited company.`
  line
  line `(5) All assets forming the controlled fund or assets as referred to in sub-section (2) of section 27, not`
  line `being Government securities or other approved securities in which assets are to be invested or held invested in accordance with this section, shall (except for a part thereof not exceeding one-tenth of the`
  line `controlled fund or assets as referred to in sub-section (2) thereof in value which may, subject to such`
  line `conditions and restrictions as may be prescribed, be offered as security for any loan taken for purposes of`
  line `any investment), be held free of any encumbrance, charge, hypothecation or lien.`
  line
  line `(6) If at any time the Authority considers any one or more of the investments of an insurer to be`
  line `unsuitable or undesirable, the Authority may, after giving the insurer an opportunity of being heard, direct`
  line `him to realise the investment or investments, and the insurer shall comply with the direction within such`
  line `time as may be specified in this behalf by the Authority.`
  line
  line `(7) Nothing contained in this section shall be deemed to affect in any way the manner in which any`
  line `moneys relating to the provident fund of any employee or to any security taken from any employee or`
  line `other moneys of a like nature are required to be held by or under any Central Act, or Act of a State`
  line legislature.
  line
  line `Explanation. --In this section "controlled fund" means--`
  line
  line `(a) in the case of any insurer carrying on life insurance business--`
  line
  line `(i) all his funds, if he carries on no other class of insurance business;`
  line
  line `(ii) all the funds in India appertaining to his life insurance business if he carries on some`
  line `other class of insurance business also.`
  line
  line `Explanation.--For the purposes of sub-clauses (i) and (ii), the fund does not include any fund or`
  line `portion thereof in respect of which the Authority is satisfied that such fund or portion, as the case may`
  line `be, is regulated by the law in force of any country outside India or it would not be in the interest of`
  line `the insurer to apply the provisions of this section;`
  line
  line `(b) in the case of any other insurer carrying on life insurance business--`
  line
  line `(i) all his funds in India, if he carries on no other class of insurance business;`
  line
  line `(ii) all the funds in India appertaining to his life insurance business if he carries on some`
  line `other class of insurance business also; but does not include any fund or portion thereof in respect`
  line `of which the Authority is satisfied that such fund or portion thereof, as the case may be, is`
  line `regulated by the law of any country outside India or in respect of which the Authority is satisfied`
  line `that it would not be in the interest of the insurer to apply the provisions of this section.`
obj_root_law_sections_27_a_footnotes:
  string
  line
obj_root_law_sections_27_b:
  sectionId (18137)
  sectionNo 27B
  orderNo 43
  title `Provisions regarding investments of assets of insurer carrying general insurance business.`
  content obj_root_law_sections_27_b_content
  footnotes obj_root_law_sections_27_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18137&sectionno=27B&orderno=43&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_27_b_content:
  string
  line `(1) All assets of an insurer carrying on general insurance business shall, subject to such`
  line `conditions, if any, as may be prescribed, be deemed to be assets invested or kept invested in approved`
  line `investments specified in section 27.`
  line
  line `(2) All assets shall (except for a part thereof not exceeding one-tenth of the total assets in value which`
  line `may subject to such conditions and restrictions as may be prescribed, be offered as security for any loan`
  line `taken for purposes of any investment or for payment of claims, or which may be kept as security deposit`
  line `with the banks for acceptance of policies) be held free of any encumbrance, charge, hypothecation or lien.`
  line
  line `(3) Without prejudice to the powers conferred on the Authority by sub-section (5) of section 27A`
  line `nothing contained in this section shall be deemed to require any insurer to realise any investment made in`
  line `conformity with the provisions of sub-section (1) of section 27 after the commencement of the Insurance`
  line `(Amendment) Act, 1968 (62 of 1968), which, after the making thereof, has ceased to be an approved`
  line `investment within the meaning of this section.`
obj_root_law_sections_27_b_footnotes:
  string
  line
obj_root_law_sections_27_c:
  sectionId (18138)
  sectionNo 27C
  orderNo 44
  title `Investment by insurer in certain cases.`
  content obj_root_law_sections_27_c_content
  footnotes obj_root_law_sections_27_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18138&sectionno=27C&orderno=44&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_27_c_content:
  string
  line `An insurer may invest not more than five per cent.`
  line `in aggregate of his controlled fund or assets as referred to in sub-section (2) of section 27 in the`
  line `companies belonging to the promoters, subject to such conditions as may be specified by the regulations.`
obj_root_law_sections_27_c_footnotes:
  string
  line
obj_root_law_sections_27_d:
  sectionId (18139)
  sectionNo 27D
  orderNo 45
  title `Manner and conditions of investment.`
  content obj_root_law_sections_27_d_content
  footnotes obj_root_law_sections_27_d_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18139&sectionno=27D&orderno=45&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_27_d_content:
  string
  line `(1) Without prejudice to anything contained in this`
  line `section, the Authority may, in the interests of the policyholders, specify by the regulations, the time,`
  line `manner and other conditions of investment of assets to be held by an insurer for the purposes of this Act.`
  line
  line `(2) The Authority may give specific directions for the time, manner and other conditions subject to`
  line `which the funds of policyholders shall be invested in the infrastructure and social sector as may be`
  line `specified by the regulations and such regulations shall apply uniformly to all the insurers carrying on the`
  line `business of life insurance, general insurance, or health insurance or re-insurance in India on or after the`
  line `commencement of the Insurance Regulatory and Development Authority Act, 1999 (41 of 1999).`
  line
  line `(3) The Authority may, after taking into account the nature of business and to protect the interests of`
  line `the policyholders, issue to an insurer the directions relating to the time, manner and other conditions of`
  line `investment of assets to be held by him:`
  line
  line `Provided that no direction under this sub-section shall be issued unless the insurer concerned has been`
  line `given a reasonable opportunity of being heard.`
obj_root_law_sections_27_d_footnotes:
  string
  line
obj_root_law_sections_27_e:
  sectionId (18140)
  sectionNo 27E
  orderNo 46
  title `Prohibition for investment of funds outside India.`
  content obj_root_law_sections_27_e_content
  footnotes obj_root_law_sections_27_e_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18140&sectionno=27E&orderno=46&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_27_e_content:
  string
  line `No insurer shall directly or indirectly`
  line `invest outside India the funds of the policyholders.`
obj_root_law_sections_27_e_footnotes:
  string
  line
obj_root_law_sections_28:
  sectionId (18141)
  sectionNo (28)
  orderNo 47
  title `Statement and return of investment of assets.`
  content obj_root_law_sections_28_content
  footnotes `1. Subs. by Act 5 of 2015, s. 27, for section 28, section 28A and section 28B (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18141&sectionno=28&orderno=47&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_28_content:
  string
  line `^1[28. Statement and return of investment of assets.--Every insurer shall submit to the Authority`
  line `returns giving details of investments made, in such form, time and manner including its authentication as`
  line `may be specified by the regulations.]`
obj_root_law_sections_29:
  sectionId (18142)
  sectionNo (29)
  orderNo 48
  title `Prohibition of loans.`
  content obj_root_law_sections_29_content
  footnotes `1. Subs. by s. 27, ibid., for section 29 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18142&sectionno=29&orderno=48&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_29_content:
  string
  line `^1[29. Prohibition of loans.--(1) No insurer shall grant loans or temporary advances either on`
  line `hypothecation of property or on personal security or otherwise, except loans on life insurance policies`
  line `issued by him within their surrender value, to any director, manager, actuary, auditor or officer of the`
  line `insurer, if a company or to any other company or firm in which any such director, manager, actuary or`
  line `officer holds the position of a director, manager, actuary, officer or partner:`
  line
  line `Provided that nothing contained in this sub-section shall apply to such loans, made by an insurer to a`
  line `banking company, as may be specified by the Authority:`
  line
  line `Provided further that nothing in this section shall prohibit a company from granting such loans or`
  line `advances to a subsidiary company or to any other company of which the company granting the loan or`
  line `advance is a subsidiary company if the previous approval of the Authority is obtained for such loan or`
  line advance.
  line
  line `(2) The provisions of section 185 of the Companies Act, 2013 (18 of 2013) shall not apply to a loan`
  line `granted to a director of an insurer being a company, if the loan is one granted on the security of a policy`
  line `on which the insurer bears the risk and the policy was issued to the director on his own life, and the loan`
  line `is within the surrender value of the policy.`
  line
  line `(3) Subject to the provisions of sub-section (1), no insurer shall grant--`
  line
  line `(a) any loans or temporary advances either on hypothecation of property or on personal security`
  line `or otherwise, except such loans as may be specified by the regulations including the loans sanctioned`
  line `as part of their salary package to the full-time employees of the insurer as per the scheme duly`
  line `approved by its Board of Directors;`
  line
  line `(b) temporary advances to any insurance agent to facilitate the carrying out of his functions as`
  line `such except in cases where such advances do not exceed in the aggregate the renewal commission`
  line `earned by him during the immediately preceding year.`
  line
  line `(4) Where any event occurs giving rise to circumstances, the existence of which at the time of grant`
  line `of any subsisting loan or advance would have made such grant a contravention of this section, such loan`
  line `or advance shall, notwithstanding anything in any contract to the contrary, be repaid within three months`
  line `from the occurrence of such event.`
  line
  line `(5) In case of default in complying with the provisions of sub-section (4), the director, manager,`
  line `auditor, actuary, officer or insurance agent concerned shall, without prejudice to any other penalty which`
  line `he may incur, cease to hold office under, or to act for, the insurer granting the loan on the expiry of three`
  line months.]
obj_root_law_sections_30:
  sectionId (18143)
  sectionNo (30)
  orderNo 49
  title `Liability of directors, etc.,for loss due to contravention of section 27,27A,27B,27C,27D or section 29.`
  content obj_root_law_sections_30_content
  footnotes `1. Subs. by Act 5 of 2015, s. 29, for section 30 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18143&sectionno=30&orderno=49&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_30_content:
  string
  line `^1[30. Liability of directors, etc., for loss due to contravention of section 27, 27A, 27B, 27C, 27D`
  line `or section 29.--If by reason of a contravention of any of the provisions of section 27, 27A, 27B, 27C,`
  line `27D or section 29, any loss is sustained by the insurer or by the policyholders, every director, manager or`
  line `officer who is knowingly a party to such contravention shall, without prejudice to any other penalty to`
  line `which he may be liable under this Act, be jointly and severally liable to make good the amount of such`
  line loss.]
obj_root_law_sections_31:
  sectionId (18144)
  sectionNo (31)
  orderNo 50
  title `Assets of insurer how to be kept.`
  content obj_root_law_sections_31_content
  footnotes obj_root_law_sections_31_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18144&sectionno=31&orderno=50&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_31_content:
  string
  line `^1 [(1) None of the assets in India of any insurer shall, except`
  line `in so far as assets are required to be vested in trustees under sub-section (7) of section 27, be kept`
  line `otherwise than in the name of a public officer approved by the Authority, or in the corporate name of the`
  line `undertaking, if a company or an insurance co-operative society, as the case may be.]`
  line
  line `^2[(2) Nothing contained in this section shall be deemed to prohibit the endorsement in favour of a`
  line `banking company of any security or other document solely for the purpose of collection or for realisation`
  line `of interest, bonus or dividend.]`
obj_root_law_sections_31_footnotes:
  string
  line `1 Subs. by s. 30, ibid., for sub-section (1) (w.e.f. 26-12-2014).`
  line
  line `2 Subs. by Act 47 of 1950, s. 22, for sub-section (2) (w.e.f. 1-6-1950). Earlier ins. by Act 6 of 1946, s. 18 (w.e.f. 20-3-1946).`
obj_root_law_sections_31_a:
  sectionId (18145)
  sectionNo 31A
  orderNo 51
  title `Provisions relating to managers, etc.`
  content obj_root_law_sections_31_a_content
  footnotes obj_root_law_sections_31_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18145&sectionno=31A&orderno=51&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_31_a_content:
  string
  line `^1[31A. Provisions relating to managers, etc.--(1) Notwithstanding anything to the contrary`
  line `contained in ^2[the Companies Act, 2013 (18 of 2013)], or in the articles of association of the insurer, if a`
  line `company, or in any contract or agreement, no insurer shall after expiry of one year from the`
  line `commencement of the Insurance (Amendment) Act, 1950 ( 47 of 1950 ), --`
  line
  line `(a) be directed or managed by, or employ as manager or officer,`
  line
  line `(b) be directed or managed by, or employ as manager or officer or in any capacity, any person`
  line `whose remuneration or any part thereof takes the form of commission or bonus or a share in the`
  line `valuation surplus in respect of the life insurance business of the insurer, or`
  line
  line `(c) be directed or managed by, or employ as manager or officer or in any capacity, any person`
  line `whose remuneration or any part thereof takes the form of commission or bonus in respect of the`
  line `general insurance business of the insurer:`
  line
  line `Provided that nothing in this sub-section shall be deemed to prohibit --`
  line
  line `^3[(i) the payment of commission to an insurance agent, in respect of insurance business procured`
  line `by or through him;]`
  line
  line `^4* * * * *`
  line
  line `(iv) the employment of any individual in a clerical or other subordinate capacity who, as an`
  line `insurance agent, receives commission in respect of insurance business procured by him;`
  line
  line `(v) the employment as an officer of any individual who receives renewal commission in respect`
  line `of life insurance business procured by hi m in hi s capacity as an insurance agent or as an employer of`
  line `agents before such employment, or before the commencement of the Insurance (Amendment) Act,`
  line `1950 ( 47 of 1950 ), whichever is later;`
  line
  line `(vi) the payment of a share in the profits of general insurance business;`
  line
  line `(vii) the payment of bonus in any year on a uniform basis to all salaried employees or any class of`
  line `them by way of additional remuneration ^5***.`
  line
  line `(2) Notwithstanding anything to the contrary contained in the Indian Companies Act, 1913 (7 of`
  line `1913), or in the articles of association of the insurer, being a company, or in any contract or agreement, no`
  line `manager, managing director or any other person concerned in the management of an insurer's business`
  line `shall be entitled to nominate a successor to hi s office, and no person so nominated, whether before or`
  line `after the commencement of the Insurance (Amendment) Act, 1950 (47 of 1950), shall be entitled to hold`
  line `or to continue in such office.`
  line
  line `(3) If in the case of any insurance company provision is made by the articles of association of the`
  line `company or by an agreement entered into between any person and the company for empowering a`
  line `director or manager or other officer of the company to assign hi s office to any other person, any`
  line `assignment of office made in pursuance of the said provision, shall, notwithstanding anything to the`
  line `contrary contained in the said provision ^6[or in any other law for the time being in force] be void.`
  line
  line `(4) No person shall have any right, whether in contract or otherwise, to any compensation for any loss`
  line `incurred by reason of the operation of any provision of this section.]`
obj_root_law_sections_31_a_footnotes:
  string
  line `1. Ins. by Act 47 of 1950, s. 23 (w.e.f. 1-6-1950).`
  line
  line `2. Subs. by Act 5 of 2015, s. 2, for "the Indian Companies Act, 1913 (7 of 1913)" (w.e.f. 26-12-2014).`
  line
  line `3. Subs. by s. 31, ibid., for sub-clause (i) and (ii) (w.e.f. 26-12-2014).`
  line
  line `4. Clause (iii) omitted by Act 5 of 2015, s. 31 (w.e.f. 26-12-2014).`
  line
  line `5. Certain words omitted by Act 62 of 1968, s. 14.`
  line
  line `6. Subs. by Act 5 of 2015, s. 31 for "or in section 86B of the Indian Companies Act, 1913 (7 of 1913)" (w.e.f. 26-12-2014).`
obj_root_law_sections_31_b:
  sectionId (18146)
  sectionNo 31B
  orderNo 52
  title `Power to restrict payment of excessive remuneration.`
  content obj_root_law_sections_31_b_content
  footnotes `1. Subs. by s. 32, ibid., for section 31B (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18146&sectionno=31B&orderno=52&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_31_b_content:
  string
  line `^1[31B. Power to restrict payment of excessive remuneration. -- No insurer shall in respect of`
  line `insurance business transacted by him, shall pay to any person by way of remuneration, whether by way of`
  line `commission or otherwise in excess of such sum as may be specified by the regulations.]`
obj_root_law_sections_32:
  sectionId (18147)
  sectionNo (32)
  orderNo 53
  title [Omitted.].
  content obj_root_law_sections_32_content
  footnotes obj_root_law_sections_32_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18147&sectionno=32&orderno=53&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_32_content:
  string
  line `[Limitation on employment of managing agents and on the remuneration payable to`
  line `them]. --Omitted by the Insurance Laws (Amendment) Act, 2015 (5 of 2015), s. 33 (w.e.f. 26-12-2014).`
obj_root_law_sections_32_footnotes:
  string
  line
obj_root_law_sections_32_a:
  sectionId (18148)
  sectionNo 32A
  orderNo 54
  title `Prohibition of common officers and requirement as to whole-time officers.`
  content obj_root_law_sections_32_a_content
  footnotes obj_root_law_sections_32_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18148&sectionno=32A&orderno=54&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_32_a_content:
  string
  line `^1[32A. Prohibition of common officers and requirement as to whole-time officers. --(1) A`
  line `managing director or other officer of an insurer ^2*** carrying on life insurance business shall not be a`
  line `managing director or other officer of any other insurer carrying on life insurance business or of a banking`
  line `company or of an investment company:`
  line
  line `Provided that the ^3[Authority] may permit such managing director or other officer to be a managing`
  line `director or other officer of any other insurer carrying on life insurance business for the purpose of`
  line `amalgamating the business of the two insurers or transferring the business of one insurer to the other.`
  line
  line `^4* * * * *`
obj_root_law_sections_32_a_footnotes:
  string
  line `1. Ins. by Act 47 of 1950, s. 24 (w.e.f. 1-6-1950).`
  line
  line `2. The words, brackets, letter and figures "specified in sub-clause (b) of clause (9) of section 2 and," omitted by Act 5 of 2015,`
  line `s. 34 (w.e.f. 26-12-2014).`
  line
  line `3. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Central Government" (w.e.f. 19-4-2000).`
  line
  line `4. Sub-sections (2) and (3) omitted by Act 5 of 2015, s. 34 (w.e.f. 26-12-2014).`
obj_root_law_sections_32_b:
  sectionId (18149)
  sectionNo 32B
  orderNo 55
  title `Insurance business in rural and social sectors.`
  content obj_root_law_sections_32_b_content
  footnotes obj_root_law_sections_32_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18149&sectionno=32B&orderno=55&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_32_b_content:
  string
  line `^1[32B. Insurance business in ^2[rural and social sectors].--Every insurer shall, after the`
  line `commencement of the Insurance Regulatory and Development Authority Act, 1999 , undertake such`
  line `percentages of life insurance business and general insurance business in the ^2[rural and social sectors], as`
  line `may by specified, in the Official Gazette by the Authority, in this behalf.]`
obj_root_law_sections_32_b_footnotes:
  string
  line `1. Ins. by Act 41 of 1999, s. 30 and the First Schedule (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by Act 5 of 2015, s. 35, for "rural or social sector" (w.e.f. 26-12-2014).`
obj_root_law_sections_32_c:
  sectionId (18150)
  sectionNo 32C
  orderNo 56
  title `Obligations of insurer in respect of rural or unorganised sector and backward classes.`
  content obj_root_law_sections_32_c_content
  footnotes `1. Ins. by Act 41 of 1999, s. 30 and the First Schedule (w.e.f. 19-4-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18150&sectionno=32C&orderno=56&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_32_c_content:
  string
  line `^1[32C. Obligations of insurer in respect of rural or unorganised sector and backward classes. --`
  line `Every insurer shall, after the commencement of the Insurance Regulatory and Development Authority`
  line `Act, 1999, discharge the obligations specified under section 32B to provide life insurance or general`
  line `insurance policies to the persons residing in the rural sector, workers in the unorganised or informal sector`
  line `or for economically vulnerable or backward classes of the society and other categories of persons as may`
  line `specified by regulations made by the Authority and such insurance policies shall include insurance for`
  line crops.]
obj_root_law_sections_32_d:
  sectionId (18151)
  sectionNo 32D
  orderNo 57
  title `Obligation of insurer in respect of insurance business in third party risks of motor vehicles.`
  content obj_root_law_sections_32_d_content
  footnotes `1. Ins. by, s. 36, ibid. (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18151&sectionno=32D&orderno=57&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_32_d_content:
  string
  line `^1[32D. Obligation of insurer in respect of insurance business in third party risks of motor`
  line `vehicles. -- Every insurer carrying on general insurance business shall, after the commencement of the`
  line `Insurance Laws (Amendment) Act, 2015 (5 of 2015), underwrite such minimum percentage of insurance`
  line `business in third party risks of motor vehicles as may be specified by the regulations:`
  line
  line `Provided that the Authority may, by regulations, exempt any insurer who is primarily engaged in the`
  line `business of health, re-insurance, agriculture, export credit guarantee, from the application of this section.]`
obj_root_law_sections_33:
  sectionId (18152)
  sectionNo (33)
  orderNo 58
  title `Power of investigation and inspection by Authority.`
  content obj_root_law_sections_33_content
  footnotes obj_root_law_sections_33_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18152&sectionno=33&orderno=58&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_33_content:
  string
  line `^1[ ^2[33. Power of investigation and inspection by Authority. --(1) The Authority may, at any time, if`
  line `it considers expedient to do so by order in writing, direct any person (herein referred to as "Investigating`
  line `Officer") specified in the order to investigate the affairs of any insurer or intermediary or insurance`
  line `intermediary, as the case may be, and to report to the Authority on any investigation made by such`
  line `Investigating Officer:`
  line
  line `Provided that the Investigating Officer may, wherever necessary, employ any auditor or actuary or`
  line `both for the purpose of assisting him in any investigation under this section.`
  line
  line `(2) Notwithstanding anything to the contrary contained in section 210 of the Companies Act, 2013`
  line `(18 of 2013), the Investigating Officer may, at any time, and shall, on being directed so to do by the`
  line `Authority, cause an inspection to be made by one or more of his officers of the books of account of any`
  line `insurer or intermediary or insurance intermediary, as the case may be, and the Investigating Officer shall`
  line `supply to the insurer or intermediary or insurance intermediary, as the case may be, a copy of the report`
  line `on such inspection.`
  line
  line `(3) It shall be the duty of every manager, managing director or other officer of the insurer including a`
  line `service provider, contractor of an insurer where services are outsourced by the insurer, or intermediary or`
  line `insurance intermediary, as the case may be, to produce before the Investigating Officer directed to make`
  line `the investigation under sub-section (1), or inspection under sub-section (2), all such books of account,`
  line `registers, other documents and the database in his custody or power and to furnish him with any statement`
  line `and information relating to the affairs of the insurer or intermediary or insurance intermediary, as the case`
  line `may be, as the Investigating Officer may require of him within such time as the said Investigating Officer`
  line `may specify.`
  line
  line `(4) Any Investigating Officer, directed to make an investigation under subsection (1), or inspection`
  line `under sub-section (2), may examine on oath, any manager, managing director or other officer of the`
  line `insurer including a service provider or contractor where the services are outsourced by the insurer or`
  line `intermediary or insurance intermediary, as the case may be, in relation to his business.`
  line
  line `(5) The Investigating Officer shall, if he has been directed by the Authority to cause an inspection to`
  line `be made, make a report to the Authority on such inspection.`
  line
  line `(6) On receipt of any report under sub-section (1) or sub-section (5), the Authority may, after giving`
  line `such opportunity to the insurer or intermediary or insurance intermediary, as the case may be, to make a`
  line `representation in connection with the report as, in the opinion of the Authority, seems reasonable, by`
  line `order in writing, --`
  line
  line `(a) require the insurer, to take such action in respect of any matter arising out of the report as the`
  line `Authority may think fit; or`
  line
  line `(b) cancel the registration of the insurer or intermediary or insurance intermediary, as the case`
  line `may be; or`
  line
  line `(c) direct any person to apply to the court for the winding up of the insurer or intermediary or`
  line `insurance intermediary, as the case may be, if it is a company, whether the registration of the insurer`
  line `or intermediary or insurance intermediary, as the case may be, has been cancelled under clause (b) or`
  line not.
  line
  line `(7) The Authority may by the regulations made by it specify the minimum information to be`
  line `maintained by insurers or intermediary or insurance intermediary, as the case may be, in their books, the`
  line `manner in which such information shall be maintained, the checks and other verifications to be adopted`
  line `by insurers or intermediary or insurance intermediary, as the case may be, in that connection and all other`
  line `matters incidental thereto as are, in its opinion, necessary to enable the Investigating Officer to discharge`
  line `satisfactorily his functions under this section.`
  line
  line `Explanation.-- For the purposes of this section, the expression "insurer" shall include in the case of`
  line `an insurer incorporated in India--`
  line
  line `(a) all its subsidiaries formed for the purpose of carrying on the business of insurance exclusively`
  line `outside India; and`
  line
  line `(b) all its branches whether situated in India or outside India.`
  line
  line `(8) Any insurer or intermediary or insurance intermediary aggrieved by any order made under this`
  line `section may prefer an appeal to the Securities Appellate Tribunal.`
  line
  line `(9) All expenses of, and incidental to, any investigation made under this section shall be defrayed by`
  line `the insurer or intermediary or insurance intermediary, as the case may be, shall have priority over the`
  line `debts due from the insurer and shall be recoverable as an arrear of land revenue.]]`
obj_root_law_sections_33_footnotes:
  string
  line `1. Subs. by Act 25 of 1942, s. 3 and the Second Schedule, for "Inspection".`
  line
  line `2. Subs. by Act 5 of 2015, s. 37, for section 33 (w.e.f. 26-12-2014).`
obj_root_law_sections_33_a:
  sectionId (18153)
  sectionNo 33A
  orderNo 59
  title `Power to appoint staff.`
  content obj_root_law_sections_33_a_content
  footnotes obj_root_law_sections_33_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18153&sectionno=33A&orderno=59&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_33_a_content:
  string
  line `^1[33A. Power to appoint staff. --The ^2*** ^3[Authority] may appoint such staff, and at such places at it`
  line `or he may consider necessary, for the scrutiny of the returns, statements and information furnished by insurers under this Act and generally to ensure the efficient performance of the functions of`
  line `the ^4`
  line `[Authority] under this Act.]`
obj_root_law_sections_33_a_footnotes:
  string
  line `1. Ins. by Act 62 of 1968, s. 16 (w.e.f. 1-6-1969).`
  line
  line `2. The words "Central Government or the" omitted by Act 41 of 1999, s. 30 and the First Schedule (w.e.f. 19-4-2000).`
  line
  line `3. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `4. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_34:
  sectionId (18154)
  sectionNo (34)
  orderNo 60
  title `Power of the Authority to issue directions.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18154&sectionno=34&orderno=60&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_34_content:
  string
  line `^1[34. Power of the ^2[Authority] to issue directions. --(1) Where the ^2[Authority] is satisfied that--`
  line
  line `(a) in the public interest; or`
  line
  line `(b) to prevent the affairs of any insurer being conducted in a manner detrimental to the interests`
  line `of the policy-holders or in a manner prejudicial to the interests of the insurer; or`
  line
  line `(c) generally to secure the proper management of any insurer,`
  line
  line `it is necessary to issue directions to insurers generally or to any insurer in particular, he may, from time to`
  line `time, issue such directions as he deems fit, and the insurers or the insurer, as the case may be, shall be`
  line `bound to comply with such directions:`
  line
  line `Provided that no such direction shall be issued to any insurer in particular unless such insurer has`
  line `been given a reasonable opportunity of being heard.`
  line
  line `(2) The ^2[Authority] may, on representation made to him or on his own motion, modify or cancel any`
  line `direction issued under sub-section (1), and in so modifying or cancelling any direction, may impose such`
  line `conditions as he thinks fit, subject to which the modification or cancellation shall have effect.]`
obj_root_law_sections_34_footnotes:
  string
  line `1. Ins. by Act 62 of 1968, s. 16 (w.e.f. 1-6-1969).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_34_a:
  sectionId (18155)
  sectionNo 34A
  orderNo 61
  title `Amendment of provisions relating to appointments of managing directors, etc., to be subject to previous approval of the Controller.`
  content obj_root_law_sections_34_a_content
  footnotes obj_root_law_sections_34_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18155&sectionno=34A&orderno=61&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_34_a_content:
  string
  line `34A. Amendment of provisions relating to appointments of managing directors, etc., to be`
  line `subject to previous approval of the ^1[Authority]. -- (1) In the case of an insurer, --`
  line
  line `(a) no amendment made after the commencement of the Insurance (Amendment) Act, 1968, of`
  line `any provision relating to the appointment, reappointment, termination of appointment or`
  line `remuneration of a managing or whole-time director, or of a manager or a chief executive officer, by`
  line `whatever name called, whether that provision be contained in the insurer's memorandum or articles`
  line `of association, or in an agreement entered into by him, or in any resolution passed by the insurer in`
  line `general meeting or by his Board of directors shall have effect unless approved by the ^1[Authority];`
  line
  line `(b) no appointment, re-appointment or termination of appointment, made after the`
  line `commencement of the Insurance (Amendment) Act, 1968 , of a managing or whole-time director, or a`
  line `manager or a chief executive officer, by whatever name called, shall have effect unless such`
  line `appointment, reappointment or termination of appointment is made with the previous approval of the`
  line ^139[Authority].
  line
  line `Explanation-- For the purposes of this sub-section, any provision conferring any benefit or providing`
  line `any amenity or perquisite, in whatever form, whether during or after the termination of the term of office`
  line `of the manager or the chief executive officer, by whatever name called, or a managing or whole-time`
  line `director, shall be deemed to be a provision relating to his remuneration.`
  line
  line `(2) Nothing contained in sections 268 and 269 , the proviso to sub-section (3) of section 309, sections`
  line `310 and 311 , the proviso to section 387 , and section 388 (in so far as section 388 makes the provisions`
  line `of sections 310 and 311 apply in relation to the manager of a company) of the Companies Act, 1956`
  line
  line `(1 of 1956), shall apply to any matter in respect of which the approval of the ^2[authority] has to be`
  line `obtained under sub-section (1).`
  line
  line `(3) No act done by a person as a managing or whole-time director or a director not liable to retire by`
  line `rotation or a manager or a chief executive officer, by whatever name called, shall be deemed to be invalid`
  line `on the ground that it is subsequently discovered that hi s appointment or re-appointment had not taken`
  line `effect by reason of any of the provisions of this Act; but nothing in this sub-section shall be construed as`
  line `rendering valid any act done by such person after hi s appointment or re-appointment has been shown to`
  line `the insurer not to have had effect.`
obj_root_law_sections_34_a_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_34_b:
  sectionId (18156)
  sectionNo 34B
  orderNo 62
  title `Power of Authority to remove managerial persons from office.`
  content obj_root_law_sections_34_b_content
  footnotes obj_root_law_sections_34_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18156&sectionno=34B&orderno=62&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_34_b_content:
  string
  line `34B. Power of ^1[Authority] to remove managerial persons from office. --(1) Where the`
  line `^1[Authority] is satisfied that in the public interest or for preventing the affairs of an insurer being`
  line `conducted in a manner detrimental to the interests of the policy-holders or for securing the proper`
  line `management of any insurer it is necessary so to do, he may, for reasons to be recorded in writing, by`
  line `order, remove from office, with effect from such date as may be specified in the order, any director or the`
  line `chief executive officer, by whatever name called, of the insurer.`
  line
  line `(2) No order under sub-section (1) shall be made unless the director or chief executive officer`
  line `concerned has been given a reasonable opportunity of making a representation to the ^1[Authority] against`
  line `the proposed order:`
  line
  line `Provided that if, in the opinion of the ^1[Authority], any delay would be detrimental to the interests of`
  line `the insurer or his policy-holders, he may, at the time of giving the opportunity aforesaid or at any time`
  line `thereafter, by order direct that, pending the consideration of the representation aforesaid, if any, the`
  line `director or, as the case may be, chief executive officer, shall not, with effect from the date of such`
  line `order, --`
  line
  line `(a) act as such director or chief executive officer of the insurer;`
  line
  line `(b) in any way, whether directly or indirectly, be concerned with, or take part in, the management`
  line `of the insurer.`
  line
  line `(3) Where any order is made in respect of a director or chief executive officer of an insurer under`
  line `sub-section (1), he shall cease to be a director or, as the case may be, chief executive officer of the insurer`
  line `and shall not, in any way, whether directly or indirectly, be concerned with, or take part it, the`
  line `management of any insurer for such period not exceeding five years as may be specified in the order.`
  line
  line `^2[(4) If any person in respect of whom an order is made by the Authority under`
  line `sub-section (1) or under the proviso to sub-section (2), contravenes the provisions of this section, he shall`
  line `be liable to a penalty of one lakh rupees for each day during which such contravention continues or`
  line `one crore rupees, whichever is less.]`
  line
  line `(5) Where an order under subsection (1) has been made, the ^1[Authority] may, by order in writing,`
  line `appoint a suitable person in place of the director or chief executive officer who has been removed from`
  line `his office under that sub-section, with effect from such date as may be specified in the order.`
  line
  line `(6) Any person appointed as director or chief executive officer under this section shall--`
  line
  line `(a) hold office during the pleasure of the ^1[Authority] and subject thereto for a period not`
  line `exceeding three years or such farther periods not exceeding three years at a time as the ^1[Authority]`
  line `may specify;`
  line
  line `(b) not insure any obligation or liability by reason only of hi s being a director or chief executive`
  line `officer or for anything done or omitted to be done in good faith in the execution of the duties of his`
  line `office or in relation thereto.`
  line
  line `(7) Notwithstanding anything contained in any law or in any contract, memorandum or articles of`
  line `association, on the removal of a person from office under this section, that person shall not be entitled to`
  line `claim any compensation for the loss or termination of office.]`
obj_root_law_sections_34_b_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by Act 5 of 2015, s. 38, for sub-section (4) (w.e.f. 26-12-2014).`
obj_root_law_sections_34_c:
  sectionId (18157)
  sectionNo 34C
  orderNo 63
  title `Power of Authority to appoint additional directors.`
  content obj_root_law_sections_34_c_content
  footnotes obj_root_law_sections_34_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18157&sectionno=34C&orderno=63&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_34_c_content:
  string
  line `34C. Power of ^1[Authority] to appoint additional directors. -- ^2`
  line `(1) If the Authority is of opinion`
  line `that in the public interest or in the interest of an insurer, or his policyholders it is necessary so to do, it`
  line `may, from time to time, by order in writing, appoint, in consultation with the Central Government with`
  line `effect from such date as may be specified in the order, one or more persons to hold office as additional`
  line `directors of the insurer:`
  line
  line `Provided that the number of additional directors so appointed shall not, at any time, exceed five or`
  line `one-third of the maximum strength fixed for the Board by the articles of association of the insurer,`
  line `whichever is less.`
  line
  line `(2) Any person appointed as additional director in pursuance of this section,--`
  line
  line `(a) shall hold office during the pleasure of the ^1[Authority], and subject thereto for a period not`
  line `exceeding three years or such further periods not exceeding three years at a time as the ^1[Authority]`
  line `may specify;`
  line
  line `(b) shall not incur any obligation or liability by reason only of his being a director or for anything`
  line `done or omitted to be done in good faith in the execution of the duties of his office or in relation`
  line `thereto; and`
  line
  line `(c) shall not be required to hold qualification shares of the insurer.`
  line
  line `(3) For the purpose of reckoning any proportion of the total number of directors of the insurer, any`
  line `additional director appointed under this section shall not be taken into account.`
obj_root_law_sections_34_c_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by Act 5 of 2015, s. 39, for sub-section (1) (w.e.f. 26-12-2014).`
obj_root_law_sections_34_d:
  sectionId (18158)
  sectionNo 34D
  orderNo 64
  title `Sections 34B and 34C to override other laws.`
  content obj_root_law_sections_34_d_content
  footnotes obj_root_law_sections_34_d_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18158&sectionno=34D&orderno=64&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_34_d_content:
  string
  line `Any appointment or removal of a director or`
  line `executive officer in pursuance of section 34B or section 34 C shall have effect notwithstanding anything`
  line `the contrary contained in the Companies Act, 1956 (1 of 1956), or any other law for the time being in`
  line `force or any contract or any other instrument.`
obj_root_law_sections_34_d_footnotes:
  string
  line
obj_root_law_sections_34_e:
  sectionId (18159)
  sectionNo 34E
  orderNo 65
  title `Further powers.`
  content obj_root_law_sections_34_e_content
  footnotes obj_root_law_sections_34_e_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18159&sectionno=34E&orderno=65&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_34_e_content:
  string
  line `The ^142[Authority] may, -- (a) caution or prohibit insurers, generally or any`
  line `insurer in particular against entering into any particular transaction or class of transactions, and generally`
  line `give advice to any insurer;`
  line
  line `(b) at any time, if it is satisfied that in the public interest or in the interests of the insurer or for`
  line `preventing the affairs of the insurer being conducted in a manner detrimental to the interests of the insurer`
  line `or hi s policy-holders, it is necessary so to do, by order in writing and on such terms and conditions as`
  line `may be specified therein,--`
  line
  line `(i) require the insurer to call a meeting of hi s directors for the purpose of considering any matter`
  line `relating to or arising out of the affairs of the insurer;`
  line
  line `(ii) depute one or more of his officers to watch the proceedings at any meeting of the Board of`
  line `directors of the insurer or of any committee or of any other body constituted by it; require the insurer`
  line `to give an opportunity to the officers so deputed to be heard at such meetings and also require such`
  line `officers to send a report of such proceedings to the ^1[Authority];`
  line
  line `(iii) require the Board of directors of the insurer or any committee or any other body constituted`
  line `by it to give in writing to any officer specified by the ^2[Authority] in this behalf at hi s usual address`
  line `all notices if, and other communications relating to, any meeting of the Board, committee or other`
  line `body constituted by it;`
  line
  line `(iv) appoint one or more of hi s officers to observe the manner in which the affairs of the insurer`
  line `or of hi s offices or branches are being conducted and make a report thereon;`
  line
  line `(v) require the insurer to make, within such time as may be specified in the order, such changes in`
  line `the management as the`
  line `^2[Authority] may consider necessary.]`
obj_root_law_sections_34_e_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_34_f:
  sectionId (18160)
  sectionNo 34F
  orderNo 66
  title `Power of Authority to issue directions regarding re-insurance treaties, etc.`
  content obj_root_law_sections_34_f_content
  footnotes `1. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18160&sectionno=34F&orderno=66&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_34_f_content:
  string
  line `34F. Power of ^1`
  line `[Authority] to issue directions regarding re-insurance treaties, etc. —--(1)`
  line `Without prejudice to the generality of the powers conferred by sub-section (1) of section 34, the`
  line `^1[Authority] may, if he is of opinion that the terms or conditions of any re-insurance treaty or other reinsurance`
  line `contract entered into by an insurer are not favourable to the insurer or are detrimental to the`
  line `public interest, he may, by order, require the insurer to make, at the time when the renewal of such treaty`
  line `or contract becomes next due, such modifications in the terms and conditions of such treaty or contract as`
  line `he may specify in the order or not to renew such treaty or contract, and, if the insurer fails to comply with`
  line `such order, he shall be deemed to have failed to comply with the provisions of this Act.`
  line
  line `(2) The ^1[Authority] may, if he has reason to believe that an insurer is entering into or is likely to`
  line `enter into re-insurance treaties or other re-insurance contracts which are not favourable to the insurer or`
  line `are detrimental to the public interest, he may, by order, direct that the insurer shall not enter into such`
  line `re-insurance treaty or other re-insurance contract unless a copy of such treaty or contract has been`
  line `furnished to him in advance and the terms and conditions thereof have been approved by him and if the`
  line `insurer fails to comply with such order he shall be deemed to have failed to comply with the requirements`
  line `of this Act.]`
obj_root_law_sections_34_g:
  sectionId (18161)
  sectionNo 34G
  orderNo 67
  title Omitted.
  content obj_root_law_sections_34_g_content
