obj_root_law_sections_48_a:
  sectionId (18186)
  sectionNo 48A
  orderNo 92
  title `. Insurance agent or intermediary or insurance intermediary not to be director in insurance company.`
  content obj_root_law_sections_48_a_content
  footnotes `1. Subs. by Act 5 of 2015, s. 57 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18186&sectionno=48A&orderno=92&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_48_a_content:
  string
  line `^1[48A. Insurance agent or intermediary or insurance intermediary not to be director in`
  line `insurance company. --No insurance agent or intermediary or insurance intermediary shall be eligible to`
  line `be or remain a director in insurance company:`
  line
  line `Provided that any director holding office at the commencement of the Insurance Laws (Amendment)`
  line `Act, 2015 (5 of 2015) shall not become ineligible to remain a director by reason of this section until the`
  line `expiry of six months from the date of commencement of the said Act:`
  line
  line `Provided further that the Authority may permit an agent or intermediary or insurance intermediary to`
  line `be on the Board of an insurance company subject to such conditions or restrictions as it may impose to`
  line `protect the interest of policyholders or to avoid conflict of interest.`
  line ]
obj_root_law_sections_48_b:
  sectionId (18187)
  sectionNo 48B
  orderNo 93
  title `Further provision regarding directors.`
  content obj_root_law_sections_48_b_content
  footnotes obj_root_law_sections_48_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18187&sectionno=48B&orderno=93&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_48_b_content:
  string
  line `^1[48B. Further provision regarding directors.--(1) An insurer specified in sub-clause (b) of clause`
  line `(9) of section 2 and carrying on life insurance business shall not have a common director with another`
  line `such insurer.`
  line
  line `(2) The ^2[Authority] may, for such period, to such extent and subject to such conditions as it may`
  line `specify, exempt from the operation of the section--`
  line
  line `(a) any insurer, who is a subsidiary company of another insurer, or`
  line
  line `(b) two or more insurers, for the purpose of facilitating their amalgamation or the transfer of`
  line `business of one insurer to the other.]`
obj_root_law_sections_48_b_footnotes:
  string
  line `1. ns. by Act 47 of 1950, s. 40 (w.e.f. 1-6-1950).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Central Government" (w.e.f. 19-4-2000).`
