obj_root_law_sections_6_b:
  sectionId (18112)
  sectionNo 6B
  orderNo 18
  title `Provision for securing compliance with requirements relating to capital structure.`
  content obj_root_law_sections_6_b_content
  footnotes obj_root_law_sections_6_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18112&sectionno=6B&orderno=18&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_6_b_content:
  string
  line `(1) For the purpose of enabling any public company carrying on ^1[life or general or health insurance or`
  line `re-insurance business] to bring its capital structure into conformity with the requirements of section 6A,`
  line `an officer appointed on this behalf by the ^2[Authority] may, notwithstanding anything contained in the`
  line `Indian Companies Act, 1913 (7 of 1913): --`
  line
  line `(a) examine any scheme proposed for the purpose aforesaid by the directors of the company:`
  line
  line `Provided that--`
  line
  line `(i) the scheme has been placed before a meeting of the share holders for their opinion and has`
  line `been forwarded to the officer together with the opinion of the shareholders thereon, and`
  line
  line `(ii) the scheme does not involve any diminution of the liability of the shareholders in respect`
  line `of unpaid-up share capital;`
  line
  line `(b) invite objections and suggestions in respect of the scheme so proposed; and`
  line
  line `(c) after considering such objections and suggestions to the scheme so proposed, sanction it with`
  line `such modifications as he may consider necessary or desirable.`
  line
  line `(2) Any shareholder or other person aggrieved by the decision of the officer sanctioning a scheme`
  line `under sub-section (1) may, within ninety days of date of the order sanctioning the scheme, prefer an`
  line `appeal to the ^3[Securities Appellate Tribunal] within whose jurisdiction the registered office of the insurer`
  line `is situate for the purpose of modifying or correcting any such scheme for the purpose specified in`
  line `sub-section (1).`
  line
  line `(3) The decision of the ^4[Securities Appellate Tribunal] where an appeal has been preferred to it under`
  line `sub-section (2), or of the officer aforesaid where no such appeal has been preferred, shall be final and`
  line `binding on all the shareholders and other persons concerned.`
  line
  line `^5* * * * *`
obj_root_law_sections_6_b_footnotes:
