  string
  line
obj_root_law_sections_101_a:
  sectionId (18305)
  sectionNo 101A
  orderNo 212
  title `Re-insurance with Indian re-insurers.`
  content obj_root_law_sections_101_a_content
  footnotes obj_root_law_sections_101_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18305&sectionno=101A&orderno=212&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_101_a_content:
  string
  line `^1[101A. Re-insurance with Indian re-insurers.--(1) Every insurer shall re-insure with Indian`
  line `re-insurers such percentage of the sum assured on each policy as may be specified by the ^2[the Authority`
  line `with the previous approval of the Central Government] under sub-section (2).`
  line
  line `(2) For the purposes of sub-section (1), ^3[the Authority] may, by notification in the Official`
  line `Gazette, --`
  line
  line `(a) specify the percentage of the sum assured on each policy to be re-insured and different`
  line `percentages may be specified for different classes of insurance:`
  line
  line `Provided that no percentage so specified shall exceed thirty per cent. of the sum assured on such`
  line `policy; and`
  line
  line `(b) also specify the proportions in which the said percentage shall be allocated among the Indian`
  line re-insurers.
  line
  line `(3) Notwithstanding anything contained in sub-section (1), an insurer carrying on fire insurance`
  line `business in India may, in lieu of re-insuring the percentage specified under sub-section (2) of the sum`
  line `assured on each policy in respect of such business, re-insure with Indian re-insurers such amount out of`
  line `the first surplus in respect of that business as he thinks fit, so however that, the aggregate amount of the`
  line `premiums payable by hi m on such re-insurance in any year is not less than the said percentage of the`
  line `premium income (without taking into account premiums on re-insurance ceded or accepted) in respect of`
  line `such business during that year.`
  line
  line `Explanation.--For the purposes of this sub-section, the year 1961 shall be deemed to mean the period`
  line `from 1st April to-the 31st December of that year.`
  line
  line `(4) A notification under sub-section (2) may also specify the terms and conditions in respect of any`
  line `business of re-insurance required to be transacted under this section and such terms and conditions shall`
  line `be binding on Indian re-insurers and other insurers.`
  line
  line `(5) No notification under sub-section (2) shall be issued except after consultation with the Advisory`
  line `Committee constituted under section 101B.`
  line
  line `(6) Every notification issued under this section shall be laid before each House of Parliament, as soon`
  line `as may be, after it is made.`
  line
  line `(7) For the removal of doubts, it is hereby declared that nothing in sub-section (1) shall be construed`
  line `as preventing an insurer from re-insuring with any Indian re-insurer or other insurer the entire sum`
  line `assured on any policy or any portion thereof in excess of the percentage specified under sub-section (2).`
  line
  line `(8) In this section,`
  line
  line `(i) "policy" means a policy issued or renewed on or after the 1st day of April, 1961 , in respect of`
  line `general insurance business transacted in India and does not include a re-insurance policy; and`
  line
  line `^4 [(ii) "Indian re-insurer" means an Indian insurance company which has been granted a certificate`
  line `of registration under sub-section (2A) of section 3 by the Authority to carry on exclusively the reinsurance`
  line `business in India.]]`
obj_root_law_sections_101_a_footnotes:
  string
  line `1. Ins. by Act 11 of 1961, s. 2 (w.e.f. 1-4-1961).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and The First Schedule, for "the Central Government" (w.e.f. 19-4-2000).`
  line
  line `3. Subs. by s. 30 and the First Schedule, ibid., for "the Central Government" (w.e.f. 19-4-2000).`
  line
  line `4. Subs. by Act 42 of 2002, s. 15, for cause (ii) (w.e.f. 23-9-2002).`
obj_root_law_sections_101_b:
  sectionId (18306)
  sectionNo 101B
  orderNo 213
  title `Advisory Committee.`
  content obj_root_law_sections_101_b_content
  footnotes obj_root_law_sections_101_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18306&sectionno=101B&orderno=213&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_101_b_content:
  string
  line `(1) ^1[The Authority with the previous approval of the Central`
  line `Government] shall, for the purposes of section 101 A, constitute an Advisory Committee consisting of not`
  line `more than five persons having special knowledge and experience of the business of insurance.`
  line
  line `(2) The term of office of, and the allowances payable to, members of the Advisory Committee, the`
  line `procedure to be followed by, and the quorum necessary for the transaction of business of, the Committee`
  line `and the manner of filling casual vacancies therein shall be such as may be ^2[determined by the regulations`
  line `made by the Authority].`
obj_root_law_sections_101_b_footnotes:
  string
  line `1. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "The Central Government" (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by s. 30 and the First Schedule, ibid., for "prescribed" (w.e.f. 19-4-2000).`
obj_root_law_sections_101_c:
  sectionId (18307)
  sectionNo 101C
  orderNo 214
  title `Examination of re-insurance treaties.`
  content obj_root_law_sections_101_c_content
  footnotes obj_root_law_sections_101_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18307&sectionno=101C&orderno=214&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_101_c_content:
  string
  line `^1[101C. Examination of re-insurance treaties.--The ^2[Authority] may, at any time, --`
  line
  line `(a) call upon an insurer to submit for his examination at the principal place of business of the`
  line `insurer in India all re-insurance treaties and other re-insurance contracts entered into by the insurer;`
  line
  line `(b) examine any officer of the insurer on oath in relation to any such document as is referred to in`
  line `clause (a) above; or`
  line
  line `(c) by notice in writing, require any insurer to supply him with copies of any of the documents`
  line `referred to in clause (a), certified by a principal officer of the insurer.]`
obj_root_law_sections_101_c_footnotes:
  string
  line `1. Ins. by Act 62 of 1968, s. 33 (w.e.f. 1-6-1969).`
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_102:
  sectionId (18308)
  sectionNo (102)
  orderNo 215
  title `Penalty for default in complying with, or act in contravention of this Act.`
  content obj_root_law_sections_102_content
  footnotes obj_root_law_sections_102_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18308&sectionno=102&orderno=215&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_102_content:
  string
  line `^1[102. Penalty for default in complying with, or act in contravention of, this Act. --If any person,`
  line `who is required under this Act, or rules or regulations made thereunder, --`
  line
  line `(a) to furnish any document, statement, account, return or report to the Authority, fails to furnish`
  line `the same; or`
  line
  line `(b) to comply with the directions, fails to comply with such directions;`
  line
  line `(c) to maintain solvency margin, fails to maintain such solvency margin;`
  line
  line `(d) to comply with the directions on the insurance treaties, fails to comply with such directions on`
  line `the insurance treaties,`
  line
  line `he shall be liable to a penalty ^2[of one lakh rupees for each day during which such failure continues or one`
  line `crore rupees, whichever is less].`
obj_root_law_sections_102_footnotes:
  string
  line `1. Subs. by s. 30 and the First Schedule, ibid., for sections 102 to 105 (w.e.f. 19-4-2000).`
  line
  line `2. Subs. by Act 5 of 2015, s. 87, for "not exceeding five lakh rupees for each such failure and punishable with fine"`
  line `(w.e.f. 26-12-2014).`
obj_root_law_sections_103:
  sectionId (18309)
  sectionNo (103)
  orderNo 216
  title `Penalty for carrying on insurance business in contravention of sections 3.`
  content obj_root_law_sections_103_content
  footnotes `1. Subs. by s. 88, ibid., for sections 103 and 104 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18309&sectionno=103&orderno=216&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_103_content:
  string
  line `^1[103. Penalty for carrying on insurance business in contravention of section 3.--If a person`
  line `carries on the business of insurance without obtaining a certificate of registration under section 3, he shall`
  line `be liable to a penalty not exceeding rupees twenty-five crores and with imprisonment which may extend`
  line `to ten years.]`
obj_root_law_sections_104:
  sectionId (18310)
  sectionNo (104)
  orderNo 217
  title `Penalty for contravention of sections 27, 27A, 27B, 27D and 27E.`
  content obj_root_law_sections_104_content
  footnotes `1. Subs. by s. 88, ibid., for sections 103 and 104 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18310&sectionno=104&orderno=217&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_104_content:
  string
  line `^1[104. Penalty for contravention of sections 27, 27A, 27B, 27D and 27E. --If a person fails to`
  line `comply with the provisions of section 27, section 27A, section 27B, section 27D and section 27E, he shall`
  line `be liable to a penalty not exceeding twenty-five crore rupees.]`
obj_root_law_sections_105:
  sectionId (18311)
  sectionNo (105)
  orderNo 218
  title `Wrongfully obtaining or withholding property.`
  content obj_root_law_sections_105_content
  footnotes `1. Subs. by Act 5 of 2015, s. 89, for "not exceeding two lakh rupees for each such failure" (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18311&sectionno=105&orderno=218&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_105_content:
  string
  line `If any director, managing director, manager`
  line `or other officer or employee of an insurer wrongfully obtains possession of any property or wrongfully`
  line `applies to any purpose of the Act, he shall be liable to a penalty ^1[not exceeding one crore rupees].`
obj_root_law_sections_105_a:
  sectionId (18312)
  sectionNo 105A
  orderNo 219
  title `Offences by companies.`
  content obj_root_law_sections_105_a_content
  footnotes obj_root_law_sections_105_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18312&sectionno=105A&orderno=219&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_105_a_content:
  string
  line `(1) Where any offence under this Act has been committed by a`
  line `company, every person who, at the time the offence was committed, was in charge of, and was`
  line `responsible to, the company for the conduct of the business of the company as well as the company shall`
  line `be deemed to be guilty of the offence and shall be liable to be proceeded against and punished`
  line `accordingly:`
  line
  line `Provided that nothing contained in this sub-section shall render any such person liable to any`
  line `punishment, if he proves that the offence was committed without his knowledge or that he had exercised`
  line `all due diligence to prevent the commission of such offence.`
  line
  line `(2) Notwithstanding anything contained in sub-section (1), where any offence under this Act has been`
  line `committed by a company and it is proved that the offence has been committed with the consent or`
  line `connivance of, or is attributable to any neglect on the part of, any director, manager, secretary or other`
  line `officer of the company, such director, manager, secretary or other officer shall be deemed to be guilty of`
  line `that offence and shall be liable to be proceeded against and punished accordingly.`
  line
  line `Explanation.--For the purposes of this section, --`
  line
  line `(a) "company" means any body corporate, and includes--`
  line
  line `(i) a firm; and`
  line
  line `(ii) an association of persons or a body of individuals whether incorporated or not; and`
  line
  line `(b) "director", in relation to--`
  line
  line `(i) a firm, means a partner in the firm;`
  line
  line `(ii) an association of persons or a body of individuals, means any member controlling the`
  line `affairs thereof.`
obj_root_law_sections_105_a_footnotes:
  string
  line
obj_root_law_sections_105_b:
  sectionId (18313)
  sectionNo 105B
  orderNo 220
  title `Penalty for failure to comply with sections 32B, 32C and 32D.`
  content obj_root_law_sections_105_b_content
  footnotes `1. Subs. by s. 90, ibid., for sections 105B and 105C (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18313&sectionno=105B&orderno=220&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_105_b_content:
  string
  line `^1[105B. Penalty for failure to comply with sections 32B, 32C and 32D. --If an insurer fails to`
  line `comply with the provisions of section 32B, section 32C and section 32D, he shall be liable to a penalty`
  line `not exceeding twenty-five crore rupees.]`
obj_root_law_sections_105_c:
  sectionId (18314)
  sectionNo 105C
  orderNo 221
  title `Power to adjudicate.`
  content obj_root_law_sections_105_c_content
  footnotes `1. Subs. by s. 90, ibid., for sections 105B and 105C (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18314&sectionno=105C&orderno=221&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_105_c_content:
  string
  line `^1[105C. Power to adjudicate. --(1) For the purpose of adjudication under sub-section (2) of section`
  line `2CB, sub-section (4) of section 34B, sub-section (3) of section 40, sub-section (2) of section 41,`
  line `sub-sections (4) and (5) of section 42, sub-sections (8) and (9) of section 42D, section 52F and section`
  line `105B, the Authority, shall appoint any officer not below the rank of a Joint Director or an equivalent`
  line `officer to be an adjudicating officer for holding an inquiry in the prescribed manner after giving any`
  line `person concerned a reasonable opportunity of being heard.`
  line
  line `(2) Upon receipt of the inquiry report from the officer so appointed, the Authority, after giving an`
  line `opportunity of being heard to the person concerned, may impose any penalty provided in sections`
  line aforesaid.
  line
  line `(3) While holding an inquiry, the adjudicating officer shall have power to summon and enforce the`
  line `attendance of any person acquainted with the facts and circumstances of the case to give evidence or to`
  line `produce any document which in the opinion of the adjudicating officer, may be useful for or relevant to`
  line `the subject matter of the inquiry and if on such inquiry, is satisfied that the person has failed to comply`
  line `with the provisions of any of the sections specified in sub-section (1), he may recommend such penalty as`
  line `he thinks fit in accordance with the provisions of any of those sections.]`
obj_root_law_sections_105_d:
  sectionId (18315)
  sectionNo 105D
  orderNo 222
  title `Factors to be taken into account by the adjudicating officer.`
  content obj_root_law_sections_105_d_content
  footnotes `1. Subs. by s. 90, ibid., for sections 105B and 105C (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18315&sectionno=105D&orderno=222&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_105_d_content:
  string
  line `^1[105D. Factors to be taken into account by the adjudicating officer.--While recommending the`
  line `quantum of penalty under section 105C, the adjudicating officer and while imposing such penalty, the`
  line `Authority shall have due regard to the following factors, namely: --`
  line
  line `(a) the amount of disproportionate gain or unfair advantage, wherever quantifiable, made as a`
  line `result of the default;`
  line
  line `(b) the amount of loss caused to the policyholders as a result of the default; and`
  line
  line `(c) the repetitive nature of default.]`
obj_root_law_sections_106:
  sectionId (18316)
  sectionNo (106)
  orderNo 223
  title `Power of Court to order restoration of property of insurer or compensation in certain cases.`
  content obj_root_law_sections_106_content
  footnotes obj_root_law_sections_106_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18316&sectionno=106&orderno=223&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_106_content:
  string
  line `^1[106 . Power of court to order restoration of property of insurer or compensation in certain`
  line `cases. -- (1) If, on the application of the ^276[Authority] or an Administrator appointed under section 52 A or`
  line `an insurer or any policy-holder or any member of an insurance company or the liquidator of an insurance`
  line `company (in the event of the insurance company being in liquidation), the court is satisfied--`
  line
  line `(a) that any insurer (including in any case where the insurer is an insurance company any person who`
  line `has taken part in the promotion or formation of the insurance company or any past or present director,`
  line `managing agent, manager, secretary or liquidator) or any officer, employee or agent of the insurer, --`
  line
  line `(i) has misapplied or retained or become liable or become accountable for any money or property`
  line `of the insurer; or`
  line
  line `(ii) has been guilty of any misfeasance or breach of trust in relation to the insurer; or`
  line
  line `(b) that any person, whether he is or has been in any way connected with the affairs of the insurer not,`
  line `is in wrongful possession of any money or property of the insurer or having any such money or property`
  line `in hi s possession wrongfully withholds it or has converted it to any use other than that of the insurer; or`
  line
  line `(c) that by reason of any contravention of the provisions of this Act, the amount of the life insurance`
  line `fund has been diminished,`
  line
  line `the court may examine any such insurer, director, managing agent, manager, secretary or liquidator or any`
  line `such officer, employee or agent of the insurer or such other person, as the case may be, and may compel`
  line `hi m to contribute such sums to the assets of the insurer by way of compensation in respect of the`
  line `misapplication, retainer, misfeasance or breach of trust as the court thinks fit, or to pay such sum as may`
  line `be found due from hi m in respect of any money or property of the insurer for which he is liable or`
  line `accountable or to restore any money or property of the insurer or any part thereof, as the case may be; and`
  line `where the amount of the life insurance fund has been diminished by reason of any contravention of the`
  line `provisions of this Act, the court shall have power to assess the sum by which the amount of the fund has`
  line `been diminished and to order the person guilty of such contravention to contribute to the fund the whole`
  line
  line `or any part of that sum by way of compensation; and in any of the aforesaid cases the court shall have`
  line `power to order interest to be paid at such rate and from such time as the court may deem fit.`
  line
  line `(2) Without prejudice to the provisions contained in sub-section (1) or subsection (3), where it is`
  line `proved that any money or property of an insurer has disappeared or has been lost, the court shall presume`
  line `that every person in charge of, or having a disposing power over, such money or property at the relevant`
  line `time (whether a director, manager, principal officer or any other officer) has become accountable for such`
  line `money or property within the meaning of sub-clause (1) of clause (a) of sub-section (1), and the`
  line `provisions of that sub-section shall apply accordingly, unless such person proves that the money or`
  line `property has been utilised or disposed of in the ordinary course of the business of the insurer and for the`
  line `purpose of that business or that he took all reasonable steps to prevent the disappearance or loss of such`
  line `money or all property or otherwise satisfactorily accounts for such disappearance or loss.`
  line
  line `(3) Where the insurer is an insurance company and any of the acts referred to in clauses (a), (b) and`
  line `(c) of sub-section (1) has been committed by any person, every person who was at the relevant time a`
  line `director, managing agent, manager, liquidator, secretary or other officer of the insurance company shall,`
  line `for the purposes of that sub-section, be deemed to be liable for that act in the same manner and to the`
  line `same extent as the person who has committed the act, unless he proves that the act was committed`
  line `without hi s consent or connivance and was not facilitated by any neglect or omission on hi s part.`
  line
  line `(4) Where at any stage of the proceedings against any person under this section (he rein after referred`
  line `to as the delinquent), the Court is satisfied by affidavit or otherwise--`
  line
  line `(a) that a prima facie case has been made out against the delinquent; and`
  line
  line `(b) that it is just and proper so to do in the interests of the policy-holders of an insurer or of the`
  line `members of an insurance company,`
  line
  line `the court may direct the attachment of--`
  line
  line `(i) any property of the insurer in the possession of the delinquent;`
  line
  line `(ii) any property of the delinquent which belongs to hi m or is deemed to belong to hi m`
  line `within the meaning of sub-section (5);`
  line
  line `(iii) any property transferred by the delinquent within two years before the commencement of`
  line `proceedings under sub-section (1) or during the pendency of such proceedings, if the Court is`
  line `satisfied by affidavit or otherwise that the transfer was otherwise than in good faith and for`
  line consideration.
  line
  line `(5) For the purposes of sub-section (4), the following classes of property shall be deemed to belong to`
  line `a delinquent: --`
  line
  line `(a) any property standing in the name of any person which is reason of the person being`
  line `connected with the delinquent, whether by way of relationship or otherwise, or on account of any`
  line `other relevant circumstances appears to belong to the delinquent;`
  line
  line `(b) the property of a private company in respect of the affairs of which the delinquent, by himself`
  line `or through hi s nominees, relatives, partners or persons interested in any shares of the company is able`
  line `to exercise or is entitled to acquire control, whether direct or indirect.`
  line
  line `Explanation. --For the purposes of this section a person shall be deemed to be a nominee of a`
  line `delinquent, if, whether directly or indirectly, he possesses on behalf of the delinquent, or may be required to exercise on the direction or on behalf of the delinquent, any right or power which is of such a nature as`
  line `to enable the delinquent to exercise or to entitle the delinquent to acquire control over the company's`
  line affairs.
  line
  line `(6) Any claim to any property attached under this section or any objection to such attachment shall`
  line `be made by an application to the court, and it shall be for the claimant or objector to adduce evidence to`
  line `show that the property is not liable to attachment under this section, and the court shall proceed to`
  line `investigate the claim or objection in a summary manner.`
  line
  line `(7) When disposing of an application under sub-section (1), the court shall, after giving all persons`
  line `who appear to it to be interested in any property attached under this section an opportunity of being heard,`
  line `make such order as it thinks fit respecting the disposal of any such property for the purpose of effectually`
  line `enforcing any liability under this section, and all such persons shall be deemed to be parties to the`
  line `proceedings under this section.`
  line
  line `(8) In any proceedings under this section the court shall have full power and exclusive jurisdiction to`
  line `decide all questions of any nature whatsoever arising thereunder and, in particular, with respect to any`
  line `property attached Under this section, and no other court shall have jurisdiction to decide any such`
  line `question in any suit or other legal proceeding.`
  line
  line `(9) In making any order with respect to the disposal of the property of any private company referred`
  line `to in clause (b) of sub-section (5), the court shall have due regard to the interests of all persons interested`
  line `in such property other than the delinquent and persons referred to in that clause.`
  line
  line `(10) This section shall apply notwithstanding that the act is one for which the person concerned may`
  line `be criminally liable.`
  line
  line `(11) In proceedings under this section the court shall have all the powers which a Court has under`
  line `section 237 of the Indian Companies Act, 1913 (7 of 1913).`
  line
  line `(12) This section shall apply in respect of a provident society as defined in Part III as it applies in`
  line `respect of an insurer.`
  line
  line `(13) On and from and commencement of the Insurance (Second Amendment) Act, 1955, the Court`
  line `entitled to exercise jurisdiction under this section shall be the High Court within whose jurisdiction the`
  line `registered office of the insurer is situate (he rein after referred to as the High Court) and any proceedings`
  line `under this section pending at such commencement in any Court other than the High Court shall, on such`
  line `commencement, stand transferred to the High Court.`
  line
  line `(14) The High Court may make rules providing for--`
  line
  line `(a) the manner in which enquiries and proceedings may be held under this section;`
  line
  line `(b) any other matter for which provision has to be made for enabling the High Court to effectively`
  line `exercise its jurisdiction under this section.]`
obj_root_law_sections_106_footnotes:
  string
  line `1. Subs. by Act 54 of 1955, s. 4, for section 106 (w.e.f. 1-11-1955).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
obj_root_law_sections_106_a:
  sectionId (18317)
  sectionNo 106A
  orderNo 224
  title `Notice to and hearing of Authority.`
  content obj_root_law_sections_106_a_content
  footnotes obj_root_law_sections_106_a_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18317&sectionno=106A&orderno=224&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_106_a_content:
  string
  line `^1[106A. Notice to and hearing of ^2[Authority].--(1) When application is made to the court for the`
  line `making of any order to which this section applies, the court shall, unless the ^2[Authority] has himself`
  line `made the application or has been made a party thereto, send a copy of the application together with intimation of the date fixed for the hearing thereof to the ^4[Authority], and shall give him an opportunity`
  line `of being heard.`
  line
  line `(2) The orders to which this section applies are the following, namely: --`
  line
  line `^3* * * * *`
  line
  line `^4* * * * *`
  line
  line `(c) an order under section 36 sanctioning any arrangement for the transfer or amalgamation of life`
  line `insurance business or any order consequential thereon;`
  line
  line `(d) an order for the winding up of an insurance company ^5***;`
  line
  line `(e) an order under section 58 confirming a scheme for the partial winding up of an insurance`
  line company;
  line
  line `^6* * * * *`
obj_root_law_sections_106_a_footnotes:
  string
  line `1. Ins. by Act 20 of 1940, s. 14 (w.e.f. 10-4-1940).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the First Schedule, for "Controller" (w.e.f. 19-4-2000).`
  line
  line `3. Clause (a) omitted by Act 5 of 2015, s. 91 (w.e.f. 26-12-2014).`
  line
  line `4. Clause (b) omitted by s. 91, ibid. (w.e.f. 26-12-2014).`
  line
  line `5. The words "r a provident society" omitted by s. 91, ibid. (w.e.f. 26-12-2014).`
  line
  line `6. Clause (f) omitted by s. 91, ibid. (w.e.f. 26-12-2014).`
