obj_root_law_sections_40_a_content:
  string
  line `[Limitation of expenditure on commission.] -- Omitted by the Insurance Laws (Amendment)`
  line `Act, 2015 (5 of 2015), s. 46 (w.e.f. 26-12-2014)].`
obj_root_law_sections_40_a_footnotes:
  string
  line
obj_root_law_sections_40_b:
  sectionId (18171)
  sectionNo 40B
  orderNo 77
  title `Limitation of expenses of management in life insurance business.`
  content obj_root_law_sections_40_b_content
  footnotes `1. Subs. by Act 5 of 2015, s. 47, for sections 40B and 40C (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18171&sectionno=40B&orderno=77&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_40_b_content:
  string
  line `^1[40B. Limitation of expenses of management in life insurance business. --No insurer shall, in`
  line `respect of insurance business transacted by him in India, spend as expenses of management in any`
  line `financial year any amount exceeding the amount as may be specified by the regulations made under this`
  line Act;]
obj_root_law_sections_40_c:
  sectionId (18172)
  sectionNo 40C
  orderNo 78
  title `Limitation of expenses of management in general insurance business.`
  content obj_root_law_sections_40_c_content
  footnotes `1. Subs. by Act 5 of 2015, s. 47, for sections 40B and 40C (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18172&sectionno=40C&orderno=78&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_40_c_content:
  string
  line `^1[40C. Limitation of expenses of management in general, health insurance and re-insurance`
  line `business. --Every insurer transacting insurance business in India shall furnish to the Authority, the`
  line `details of expenses of management in such manner and form as may be specified by the regulations made`
  line `under this Act.]`
obj_root_law_sections_41:
  sectionId (18173)
  sectionNo (41)
  orderNo 79
  title `Prohibition of rebates.`
  content obj_root_law_sections_41_content
  footnotes obj_root_law_sections_41_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18173&sectionno=41&orderno=79&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_41_content:
  string
  line `(1) No person shall allow or offer to allow, either directly or`
  line `indirectly, as an inducement to any person to ^1[take out or renew or continue] an insurance in respect of`
  line `any kind of risk relating to lives or property in India, any rebate of the whole or part of the commission`
  line `payable or any rebate of the premium shown on the policy, nor shall any person taking out or renewing`
  line `^2[or continuing] a policy accept any rebate, except such rebate as may be allowed in accordance with the`
  line `published prospectuses or tables of the insurer:`
  line
  line `^1[Provided that acceptance by an insurance agent of commission in connection with a policy of life`
  line `insurance taken out by himself on his own life shall not be deemed to be acceptance of a rebate of`
  line `premium within the meaning of this sub-section if at the time of such acceptance the insurance agent`
  line `satisfies the prescribed conditions establishing that he is a bona fide insurance agent employed by the`
  line insurer.]
  line
  line `^3[(2) Any person making default in complying with the provisions of this section shall be liable for a`
  line `penalty which may extend to ten lakh rupees.]`
obj_root_law_sections_41_footnotes:
  string
  line `1. Subs. by Act 13 of 1941, s. 27, for effect or renew (w.e.f. 8-4-1941).`
  line
  line `2. Ins. by s. 27, ibid, (w.e.f. 8-4-1941).`
  line
  line `3. Subs. by Act 5 of 2015, s. 48, for sub-section (2) (w.e.f. 26-12-2014).`
obj_root_law_sections_42:
  sectionId (18174)
  sectionNo (42)
  orderNo 80
  title `Appointment of insurance agents.`
  content obj_root_law_sections_42_content
  footnotes `1. Subs. by s. 49, ibid., for section 42 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18174&sectionno=42&orderno=80&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_42_content:
  string
  line `^1[42. Appointment of insurance agents. --(1) An insurer may appoint any person to act as insurance`
  line `agent for the purpose of soliciting and procuring insurance business:`
  line
  line `Provided that such person does not suffer from any of the disqualifications mentioned in`
  line `sub-section (3).`
  line
  line `(2) No person shall act as an insurance agent for more than one life insurer, one general insurer, one`
  line `health insurer and one of each of the other mono-line insurers:`
  line
  line `Provided that the Authority shall, while framing regulations, ensure that no conflict of interest is`
  line `allowed to arise for any agent in representing two or more insurers for whom he may be an agent.`
  line
  line `(3) The disqualifications referred to in the proviso to sub-section (1) shall be the following: --`
  line
  line `(a) that the person is a minor;`
  line
  line `(b) that he is found to be of unsound mind by a court of competent jurisdiction;`
  line
  line `(c) that he has been found guilty of criminal misappropriation or criminal breach of trust or`
  line `cheating or forgery or an abetment of or attempt to commit any such offence by a court of competent`
  line `jurisdiction:`
  line
  line `Provided that where at least five years have elapsed since the completion of the sentence imposed`
  line `on any person in respect of any such offence, the Authority shall ordinarily declare in respect of such`
  line `person that his conviction shall cease to operate as a disqualification under this clause;`
  line
  line `(d) that in the course of any judicial proceeding relating to any policy of insurance or the winding`
  line `up of an insurer or in the course of an investigation of the affairs of an insurer it has been found that`
  line `he has been guilty of or has knowingly participated in or connived at any fraud, dishonesty or`
  line `misrepresentation against an insurer or insured;`
  line
  line `(e) that in the case of an individual, who does not possess the requisite qualifications or practical`
  line `training or passed the examination, as may be specified by the regulations;`
  line
  line `(f) that in the case of a company or firm making, a director or a partner or one or more of its`
  line `officers or other employees so designated by it and in the case of any other person the chief`
  line `executive, by whatever name called, or one or more of his employees designated by him, do not`
  line `possess the requisite qualifications or practical training and have not passed such an examination as`
  line `required under clauses (e) and (g);`
  line
  line `(g) that he has not passed such examination as may be specified by the regulations;`
  line
  line `(h) that he has violated the code of conduct as may be specified by the regulations.`
  line
  line `(4) Any person who acts as an insurance agent in contravention of the provision of this Act, shall be`
  line `liable to a penalty which may extend to ten thousand rupees and any insurer or any person acting on`
  line `behalf of an insurer, who appoints any person as an insurance agent not permitted to act as such or`
  line `transacts any insurance business in India through any such person shall be liable to penalty which may`
  line `extend to one crore rupees.`
  line
  line `(5) The insurer shall be responsible for all the acts and omissions of its agents including violation of`
  line `code of conduct specified under clause (h) of sub-section (3) and liable to a penalty which may extend to`
  line `one crore rupees.]`
obj_root_law_sections_42_a:
  sectionId (18175)
  sectionNo 42A
  orderNo 81
  title `Prohibition of insurance business through principal agent, special agent and multilevel marketing.`
  content obj_root_law_sections_42_a_content
  footnotes `1. Subs. by Act 5 of 2015, s. 50, for sections 42A, 42B and 42C (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18175&sectionno=42A&orderno=81&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_42_a_content:
  string
  line `^1[42A. Prohibition of insurance business through principal agent, special agent and multilevel`
  line `marketing. --(1) No insurer shall, on or after the commencement of the Insurance Laws (Amendment)`
  line `Act, 2015 (5 of 2015), appoint any principal agent, chief agent, and special agent and transact any`
  line `insurance business in India through them.`
  line
  line `(2) No person shall allow or offer to allow, either directly or indirectly, as an inducement to any`
  line `person to take out or renew or continue an insurance policy through multilevel marketing scheme.`
  line
  line `(3) The Authority may, through an officer authorised in this behalf, make a complaint to the`
  line `appropriate police authorities against the entity or persons involved in the multilevel marketing scheme.`
  line
  line `Explanation. --For the purpose of this section "multilevel marketing scheme" means any scheme or`
  line `programme or arrangement or plan (by whatever name called) for the purpose of soliciting and procuring`
  line `insurance business through persons not authorised for the said purpose with or without consideration of`
  line `whole or part of commission or remuneration earned through such solicitation and procurement and`
  line `includes enrolment of persons into a multilevel chain for the said purpose either directly or indirectly.]`
obj_root_law_sections_42_d:
  sectionId (18176)
  sectionNo 42D
  orderNo 82
  title `Issue of registration to intermediary or insurance intermediary.`
  content obj_root_law_sections_42_d_content
  footnotes obj_root_law_sections_42_d_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18176&sectionno=42D&orderno=82&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_42_d_content:
  string
  line `^1[42D. Issue of ^2[registration] to intermediary or insurance intermediary. -- (1) The Authority`
  line `or an officer authorised by it in this behalf shall, in the manner determined by the regulations made by the`
  line `Authority and on payment of the fees determined by the regulations made by the Authority, issue to any`
  line `person making an application in the manner determined by the regulations, and not suffering from any of`
  line `the disqualifications herein mentioned, a ^2[registration] to act as an intermediary or an insurance`
  line `intermediary under this Act:`
  line
  line `Provided that--`
  line
  line `(a) in the case of an individual, he does not suffer from any of the disqualifications mentioned`
  line `in ^3[sub-section (3)] of section 42, or`
  line
  line `(b) in the case of a company, or firm, any of its directors of partners does not suffer from any of`
  line `the said disqualifications.`
  line
  line `(2) A ^4[registration made] under this section shall entitle the holder thereof to act as an intermediary`
  line `or insurance intermediary .`
  line
  line `(3) A ^4[registration made] under this section shall remain in force for a period of three years only`
  line `from the date of issue, but shall, if the applicant, being an individual does not, or being a company or firm`
  line `any of its directors or partners ^5[or one or more of its officers or other employees so designated by it and`
  line `in the case of any other person, the chief executive by whatever name called, or one or more of his`
  line `employees designated by him] does not suffer from any of the disqualifications mentioned ^6[in clauses`
  line `(b), (c), (d), (e) and (g) of sub-section (3) of section 42] and the application for renewal of`
  line ^2[registration]
  line `reaches the issuing authority at least thirty days before the date on which the ^2registration] ceases to`
  line `remain in force, be renewed for a period of three years at any one time on payment of the fee, determined`
  line `by the regulations, made by the Authority and additional fee for an amount determined by the regulations,`
  line `not exceeding one hundred rupees by way of penalty, if the application for renewal of the ^2[registration]`
  line `does not reach the issuing authority at least thirty days before the date on which the ^2[registration] ceases`
  line `to remain in force.`
  line
  line `(4) No application for the renewal of a ^2[registration] under this section shall be entertained if the`
  line `application does not reach the issuing authority before the ^2[registration] ceases to remain in force:`
  line
  line `Provided that the Authority may, if satisfied that undue hardship would be caused otherwise, accept`
  line `any application in contravention of this sub-section on payment by the application of a penalty of seven`
  line `hundred and fifty rupees.`
  line
  line `(5) The disqualifications above referred to shall be the following: --`
  line
  line `(a) that the person is a minor;`
  line
  line `(b) that he is found to be of unsound mind by a Court of competent jurisdiction;`
  line
  line `(c) that he has been found guilty of criminal misappropriation or criminal breach of trust or`
  line `cheating or forgery or an abetment of or attempt to commit any such offence by a Court of competent`
  line `jurisdiction:`
  line
  line `Provided that, Where at least five years have elapsed since the completion of the sentence imposed on`
  line `any person in respect of any such offence, the Authority shall ordinarily declare in respect of such person`
  line `that hi s conviction shall cease to operate as a disqualification under this clause;`
  line
  line `(d) that in the course of any judicial proceeding relating to any policy of insurance of the winding`
  line `up of an insurance company or in the course of an investigation of the affairs of an insurer it has been`
  line `found that he has been guilty of or has knowingly participated in or connived at any fraud dishonestly`
  line `or misrepresentation against an insurer or an insured;`
  line
  line `(e) that he does not possess the requisite qualifications and practical training for a period not`
  line `exceeding twelve months, as may be specified by the regulations made by the Authority in this`
  line behalf;
  line
  line `(f) that he has not passed such examinations as may be specified by the regulations made by the`
  line `Authority in this behalf;`
  line
  line `(g) that he violates the code of conduct as may be specified by the regulations made by the`
  line Authority.
  line
  line `(6) If it be found that an intermediary or an insurance intermediary suffers from any of the foregoing`
  line `is qualifications , without prejudice to any other penalty to which he may be liable, the Authority shall,`
  line `and if the intermediary or an insurance intermediary has knowingly contravened any provision of this Act`
  line `may cancel the ^7[registration made] to the intermediary or insurance intermediary under this section .`
  line
  line `(7) The Authority may issue a duplicate ^8[registration] to replace a ^8[registration] lost, destroyed or`
  line `mutilated, on payment of such fee, as may be determined by the regulations made by the Authority.`
  line
  line `^9[(8) Any person who acts as an intermediary or an insurance intermediary without being registered`
  line `under this section to act as such, shall be liable to a penalty which may extend to ten lakh rupees and any`
  line `person who appoints as an intermediary or an insurance intermediary or any person not registered to act`
  line `as such or transacts any insurance business in India through any such person, shall be liable to a penalty`
  line `which may extend to one crore rupees.`
  line
  line `(9) Where the person contravening sub-section (8) is a company or a firm, then, without prejudice to`
  line `any other proceedings which may be taken against the company or firm, every director, manager,`
  line `secretary or other officer of the company, and every partner of the firm who is knowingly a party to such`
  line `contravention shall be liable to a penalty which may extend to ten lakh rupees.]`
