obj_root_law_sections_1:
  sectionId (18095)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18095&sectionno=1&orderno=1&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Insurance Act, 1938.`
  line
  line `^1[(2) It extends to the whole of India ^2***.]`
  line
  line `(3) It shall come into force on such date^3`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint in this behalf.`
obj_root_law_sections_1_footnotes:
  string
  line `1. Subs. by Act 47 of 1950, s. 2, for sub-section (2) (w.e.f. 1-6-1950).`
  line
  line `2. The words "except the State of Jammu and Kashmir" omitted by Act 62 of 1956, s. 2 and the Schedule (w.e.f. 1-11-1956).`
  line
  line `3. 1st July, 1939: see notification no. 589-(4)/38, dated the 1st April, 1939, Gazette of India, 1939, Pt. I, p. 631.`
obj_root_law_sections_2:
  sectionId (18096)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18096&sectionno=2&orderno=2&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_content:
  string
  line `In this Act, unless there is anything repugnant in the subject or context, --`
  line
  line `^1[(1) actuary means an actuary as defined in clause (a) of sub-section (1) of section 2 of the`
  line `Actuaries Act, 2006 (35 of 2006);`
  line
  line `(1A) Authority means the Insurance Regulatory and Development Authority of India`
  line `established under sub-section (1) of section 3 of the Insurance Regulatory and Development`
  line `Authority Act, 1999 (41 of 1999);]`
  line
  line `^2[(2) policy-holder includes a person to whom the whole of the interest of the policy-holder in`
  line `the policy is assigned once and for all, but does not include an assignee thereof whose interest in the`
  line `policy is defeasible or is for the time being subject to any condition ;]`
  line
  line `^3[(3) approved securities means--`
  line
  line `(i) Government securities and other securities charged on the revenues of the Central`
  line `Government or of the Government of a ^4*** State or guaranteed fully as regards principal and`
  line `interest by the Central Government, or the Government of any ^2*** State ;`
  line
  line `(ii) debentures or other securities for money issued under the authority of any Central Act or`
  line `Act of a State Legislature by or on behalf of a port trust or municipal corporation or city`
  line `improvement trust in any presidency-town ;`
  line
  line `(iii) shares of a corporation established by law and guaranteed fully by the Central`
  line `Government or the Government of a ^5*** State as to the repayment of the principal and the`
  line `payment of dividend ;`
  line
  line `(iv) securities issued or guaranteed fully as regards principal and interest by the Government`
  line `of any Part B State and specified as approved securities for the purposes of this Act by the`
  line `Central Government by notification in the Official Gazette ; and`
  line
  line `^6* * * * *`
  line
  line `Provided that securities or debentures specified in item (v) shall be recognished as approved`
  line `securities only for such purposes and for such period and subject to such conditions as may be`
  line `prescribed ;]`
  line
  line `^7[Explanation. -- In sub-clauses (i) and (iii), Government of a State in relation to any`
  line `period before the 1st November, 1956, means the Government of a Part A State.]`
  line
  line `^8[(4) auditor means a person qualified under the Chartered Accountants Act, 1949 (38 of 1949),`
  line `to act as an auditor of companies;]`
  line
  line `^9[(4A) banking company and company shall have the meanings respectively assigned to them`
  line `in clauses (c) and (d) of sub-section (1) of section 5 of the Banking Companies Act, 1949 (10 of`
  line `1949) ^10***;]`
  line
  line `(5) certified in relation to any copy or translation of a document required to be furnished by or`
  line `on behalf of ^11[an insurer or a provident society as defined in Part III] means certified by a principal`
  line `officer of ^12[such insurer or provident society] to be a true copy or a correct translation, as the case`
  line `may be;`
  line
  line `^13* * * * *`
  line
  line `^14[(5B) Controller of Insurance means the officer appointed by the Central Government under`
  line `section 2B to exercise all the powers, discharge the functions and perform the duties of the Authority`
  line `under this Act or the Life Insurance Corporation Act, 1956 (31 of 1956) or the General Insurance`
  line `Business (Nationalisation) Act, 1972 (57 of 1972) or the Insurance Regulatory and Development`
  line `Authority Act, 1999 (41 of 1999);]`
  line
  line `(6) Court means the principal Civil Court of original jurisdiction in a district, and includes the`
  line `High Court in exercise of its ordinary original civil jurisdiction;`
  line
  line `^15[(6A) fire insurance business means the business of effecting, otherwise than incidentally to`
  line `some other class of insurance business, contracts of insurance against loss by or incidental to fire or`
  line `other occurrence customarily included among the risks insured against in fire insurance policies;`
  line
  line `(6B) general insurance business means fire, marine or miscellaneous insurance business,`
  line `whether carried on singly or in combination with one or more of them;]`
  line
  line `^16[(6C) health insurance business means the effecting of contracts which provide for sickness`
  line `benefits or medical, surgical or hospital expense benefits, whether in-patient or out-patient travel`
  line `cover and personal accident cover;]`
  line
  line `^17[(7) Government security means a Government security as defined in the Public Debt Act,`
  line `1944 (18 of 1944);]`
  line
  line `^18[(7A) Indian insurance company means any insurer, being a company which is limited by`
  line `shares, and, --`
  line
  line `(a) which is formed and registered under the Companies Act, 2013 (18 of 2013) as a public`
  line `company or is converted into such a company within one year of the commencement of the`
  line `Insurance Laws (Amendment) Act, 2015 (5 of 2015);`
  line
  line `^19[(b) in which the aggregate holdings of equity shares by foreign investors including portfolio`
  line `investors, do not exceed seventy-four per cent. of the paid-up equity capital of such Indian`
  line `insurance company, and the foreign investment in which shall be subject to such conditions and`
  line `manner, as may be prescribed. ]`
  line
  line `Explanation. --For the purposes of this sub-clause, the expression control shall include the`
  line `right to appoint a majority of the directors or to control the management or policy decisions`
  line `including by virtue of their shareholding or management rights or shareholders agreements or`
  line `voting agreements;`
  line
  line `(c) whose sole purpose is to carry on life insurance business or general insurance business or`
  line `re-insurance business or health insurance business;]`
  line
  line `^20* * * * *`
  line
  line `^21[(8A) insurance co-operative society means any insurer being a co-operative society, --`
  line
  line `(a) which is registered on or after the commencement of the Insurance (Amendment) Act,`
  line `2002 (42 of 2002), as a co-operative society under the Co-operative Societies Act, 1912 (2 of`
  line `1912) or under any other law for the time being in force in any State relating to Co-operative`
  line `Societies or under the Multi-State Co-operative Societies Act, 1984 (51 of 1984);`
  line
  line `^22[(b) having a minimum paid-up capital of rupees one hundred crore in case of life insurance`
  line `business, general insurance business and health insurance business;]`
  line
  line `(c) in which no body corporate, whether incorporated or not, formed or registered outside`
  line `India, either by itself or through its subsidiaries or nominees, at any time, holds more than`
  line `twenty-six per cent of the capital of such Co-operative Society;`
  line
  line `(d) whose sole purpose is to carry on life insurance business or general insurance`
  line `business ^23[or health insurance business] in India;]`
  line
  line `^24[(9) insurer means--`
  line
  line `(a) an Indian Insurance Company, or`
  line
  line `(b) a statutory body established by an Act of Parliament to carry on insurance business, or`
  line
  line `(c) an insurance co-operative society, or`
  line
  line `(d) a foreign company engaged in re-insurance business through a branch established in`
  line India.
  line
  line `Explanation. -- For the purposes of this sub-clause, the expression foreign company shall`
  line `mean a company or body established or incorporated under a law of any country outside India`
  line `and includes Lloyd's established under the Lloyd's Act, 1871 (United Kingdom) or any of its`
  line Members;]
  line
  line `(10) insurance agent means an insurance agent ^25*** ^26*** who receives or agrees to receive`
  line `payment by way of commission or other remuneration in consideration of his soliciting or procuring`
  line `insurance business ^27[including business relating to the continuance, renewal or revival of policies of`
  line insurance];
  line
  line `^28[(10A) investment company means a company whose principal business is the acquisition of`
  line `shares, stocks, debentures or other securities ;]`
  line
  line `^29[(10B) intermediary or insurance intermediary shall have the meaning assigned to it in`
  line `clause (f) of sub-section (1) of section 2 of the Insurance Regulatory and Development Authority`
  line `Act, 1999 (41 of 1999);]`
  line
  line `^30[(11) life insurance business means the business of effecting contracts of insurance upon`
  line `human life, including any contract whereby the payment of money is assured on death (except death`
  line `by accident only) or the happening of any contingency dependent on human life, and any contract which is subject to payment of premiums for a term dependent on human life and shall be deemed to`
  line include--
  line
  line `(a) the granting of disability and double or triple indemnity accident benefits, if so provided`
  line `in the contract of insurance,`
  line
  line `(b) the granting of annuities upon human life ; and`
  line
  line `(c) the granting of superannuation allowances and ^31[benefit payable out of any fund]`
  line `applicable solely to the relief and maintenance of persons engaged or who have been engaged in`
  line `any particular profession, trade or employment or of the dependents of such persons ;]`
  line
  line `^32[Explanation. -- For the removal of doubts, it is hereby declared that life insurance`
  line `business shall include any unit linked insurance policy or scrips or any such instrument or unit,`
  line `by whatever name called, which provides a component of investment and a component of`
  line `insurance issued by an insurer referred to in clause (9) of this section.]`
  line
  line `^33* * * * *`
  line
  line `^32* * * * *`
  line
  line `^34[(13A) marine insurance business means the business of effecting contracts of insurance upon`
  line `vessels of any description, including cargoes, freights and other interests which may be legally`
  line `insured, in or in relation to such vessels, cargoes and freights, goods, wares, merchandise and`
  line `property of whatever description insured for any transit by land or water, or both, and whether or not`
  line `including warehouse risks or similar risks in addition, or as incidental to such transit, and includes`
  line `any other risks customarily included among the risks insured against in marine insurance policies ;`
  line
  line `(13B) miscellaneous insurance business means the business of effecting contracts of insurance`
  line `which is not principally or wholly of any kind or kinds included in clauses (6A), (11) and (13A);]`
  line
  line `^35[(13BA) National Company Law Tribunal means the National Company Law Tribunal`
  line `constituted under section 10FB of the Companies Act, 1956 (1 of 1956);`
  line
  line `(13BB) the National Company Law Appellate Tribunal means the National Company Law`
  line `Appellate Tribunal constituted under sub-section (1) of section 10FR of the Companies Act, 1956`
  line `(1 of 1956);]`
  line
  line `(14) prescribed means prescribed by rules made under ^36[this Act]; and`
  line
  line `^37* * * * *`
  line
  line `^38* * * * *`
  line
  line `(16) private company and public company have the meanings respectively assigned to them`
  line `in ^39[clause (68) and clause (72) of section 2 of the Companies Act, 2013 (18 of 2013)];`
  line
  line `^40[(16A) regulations means the regulations framed by the Insurance Regulatory and`
  line `Development Authority of India established under the Insurance Regulatory and Development`
  line `Authority Act, 1999 (41 of 1999);`
  line
  line `(16B) re-insurance means the insurance of part of one insurers risk by another insurer who`
  line `accepts the risk for a mutually acceptable premium;`
  line
  line `(16C) Securities Appellate Tribunal means the Securities Appellate Tribunal established`
  line `under section 15K of the Securities and Exchange Board of India Act, 1992 (15 of 1992);]`
  line
  line ^41
  line `* * * * *`
