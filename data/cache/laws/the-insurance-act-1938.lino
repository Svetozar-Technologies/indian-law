obj_root_law_sections_2_a:
  sectionId (18097)
  sectionNo 2A
  orderNo 3
  title `Interpretation of certain words and expressions.`
  content obj_root_law_sections_2_a_content
  footnotes `1. Ins. by Act 41 of 1999, s. 30 and the Fifth Schedule (w.e.f. 19-4-2000).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18097&sectionno=2A&orderno=3&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_a_content:
  string
  line `^1[2A. Interpretation of certain words and expressions. --Words and expressions used and not`
  line `defined in this Act but defined in the Life Insurance Corporation Act, 1956 (31 of 1956), the General`
  line `Insurance Business (Nationalisation) Act, 1972 (57 of 1972) and the Insurance Regulatory and`
  line `Development Authority Act, 1999 shall have the meanings respectively assigned to them in those Acts.]`
obj_root_law_sections_2_b:
  sectionId (18098)
  sectionNo 2B
  orderNo 4
  title `Appointment of Controller of Insurance.`
  content obj_root_law_sections_2_b_content
  footnotes obj_root_law_sections_2_b_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18098&sectionno=2B&orderno=4&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_b_content:
  string
  line `^1[2B. Appointment of Controller of Insurance. -- ^2[(1) If at any time, the Authority is superseded`
  line `under sub-section (1) of section 19 of the Insurance Regulatory and Development Authority Act, 1999,`
  line `the Central Government may, by notification in the Official Gazette, appoint a person to be the Controller`
  line `of Insurance till such time the Authority is reconstituted under sub-section (3) of section 19 of that Act.]`
  line
  line `(2) In making any appointment under this section, the Central Government shall have due regard`
  line `to the following considerations, namely, whether the person to be appointed has had experience in`
  line `industrial, commercial or insurance matters and whether such person has actuarial qualifications.]`
obj_root_law_sections_2_b_footnotes:
  string
  line `1. Ins. by Act 47 of 1950, s. 5 (w.e.f. 1-6-1950).`
  line
  line `2. Subs. by Act 41 of 1999, s. 30 and the Fifth Schedule, for sub-section (1) (w.e.f. 19-4-2000).`
obj_root_law_sections_2_c:
  sectionId (18099)
  sectionNo 2C
  orderNo 5
  title `Prohibition of transaction of insurance business by certain persons.`
  content obj_root_law_sections_2_c_content
  footnotes obj_root_law_sections_2_c_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18099&sectionno=2C&orderno=5&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_c_content:
  string
  line `^1[2C. Prohibition of transaction of insurance business by certain persons. -- (1) Save as`
  line `hereinafter provided, no person shall, after the commencement of the Insurance (Amendment) Act, 1950`
  line `(47 of 1950), begin to carry on any class of insurance business in ^2[India] and no insurer carrying on any`
  line `class of insurance business in ^2[India] shall after the expiry of one year from such commencement,`
  line `continue to carry on any such business unless he is--`
  line
  line `(a) a public company, or`
  line
  line `(b) a society registered under the Co-operative Societies Act, 1912 (2 of 1912), or under any`
  line `other law for the time being in force in any State relating to co-operative societies, or`
  line
  line `(c) a body corporate incorporated under the law of any country outside ^3[India] not being of the`
  line `nature of a private company :`
  line
  line `Provided that the Central Government may, by notification in the Official Gazette, exempt from the`
  line `operation of this section to such extent for such period and subject to such conditions as it may specify,`
  line `any person or insurer for the purpose of carrying on the business of granting superannuation allowances`
  line `and annuities of the nature specified in sub-clause (c) of clause (11) of section 2 or for the purpose of`
  line `carrying on any general insurance business :`
  line
  line `Provided further that in the case of an insurer carrying on any general insurance business no such`
  line `notification shall be issued having effect for more than three year at any one time.`
  line
  line `^4[Provided also that no insurer other than an Indian insurance company shall begin to carry on any`
  line `class of insurance business in India under this Act on or after the commencement of the Insurance`
  line `Regulatory and Development Authority Act, 1999 (41 of 1999).]`
  line
  line `^5[Provided also an insurer, being an Indian Insurance Company, insurance co-operative society or, a`
  line `body corporate referred to in clause (c) of this sub-section carrying on the business of insurance,`
  line `may carry on any business of insurance in any Special Economic Zone as defined in clause (za) of section`
  line `2 of the Special Economic Zones Act, 2005 (28 of 2005).]`
  line
  line `(2) Every notification issued under sub-section (1) shall be laid before Parliament as soon as may be`
  line `after it is issued.]`
  line
  line `^6[(3) Notwithstanding anything contained in sub-section (1), an insurance co-operative society may`
  line `carry on any class of insurance business in India under this Act on or after the commencement of the`
  line `Insurance (Amendment) Act, 2002 (42 of 2002).]`
obj_root_law_sections_2_c_footnotes:
  string
  line `1. Ins. by Act 47 of 1950, s. 6 (w.e.f. 1-6-1950).`
  line
  line `2. Subs. by Act 62 of 1956, s. 2 the Schedule, for "the States" (w.e.f. 1-11-1956).`
  line
  line `3. Subs. by Act 62 of 1956, s. 2 the Schedule, for "the States" (w.e.f. 1-11-1956).`
  line
  line `4. The proviso ins. by Act 41 of 1999, s. 30 and the First Schedule (w.e.f. 19-4-2000).`
  line
  line `5. The proviso ins. by Act 28 of 2005, s. 57 and the Third Schedule (w.e.f. 10-2-2006).`
  line
  line `6. Ins. by Act 42 of 2002, s. 3 (w.e.f. 23-9-2002).`
obj_root_law_sections_2_ca:
  sectionId (18100)
  sectionNo 2CA
  orderNo 6
  title `Power of Central Government to apply provisions of this Act to Special Economic Zones.`
  content obj_root_law_sections_2_ca_content
  footnotes `1. Ins. by Act 28 of 2005, s. 57 and the Third Schedule (w.e.f. 10-2-2006).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18100&sectionno=2CA&orderno=6&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_ca_content:
  string
  line `^1[2CA. Power of Central Government to apply provisions of this Act to Special Economic`
  line `Zones.--The Central Government may, by notification, direct that any of the provisions of this Act, --`
  line
  line `(a) shall not apply to insurer, being an Indian Insurance Company, insurance co-operative society`
  line `or a body corporate referred to in clause (c) of sub-section (1) of section 2C, carrying on the business`
  line `of insurance, in any Special Economic Zone as defined in clause (za) of section 2 of the Special`
  line `Economic Zones Act, 2005 (28 of 2005); or`
  line
  line `(b) shall apply to any insurer, being an Indian Insurance Company, insurance co-operative society`
  line `or a body corporate referred to in clause (c) of sub-section (1) of section 2C, carrying on the business`
  line `of insurance, in any Special Economic Zone as defined in clause (za) of section 2 of the Special`
  line `Economic Zones Act, 2005 (28 of 2005) only with such exceptions, modifications and adaptations as`
  line `may be specified in the notification.]`
obj_root_law_sections_2_cb:
  sectionId (18101)
  sectionNo 2CB
  orderNo 7
  title `Properties in India not to be insured with foreign insurers except with the permission of Authority.`
  content obj_root_law_sections_2_cb_content
  footnotes `1. Ins. by Act 5 of 2015, s. 4, (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18101&sectionno=2CB&orderno=7&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_cb_content:
  string
  line `^1[2CB. Properties in India not to be insured with foreign insurers except with the permission of`
  line `Authority. --(1) No person shall take out or renew any policy of insurance in respect of any property in`
  line `India or any ship or other vessel or aircraft registered in India with an insurer whose principal place of`
  line `business is outside India save with the prior permission of the Authority.`
  line
  line `(2) If any person contravenes the provision of sub-section (1), he shall be liable to a penalty which`
  line `may extend to five crore rupees.]`
obj_root_law_sections_2_d:
  sectionId (18102)
  sectionNo 2D
  orderNo 8
  title `Insurers to be subject to this Act while liabilities remain unsatisfied.`
  content obj_root_law_sections_2_d_content
  footnotes obj_root_law_sections_2_d_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18102&sectionno=2D&orderno=8&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_d_content:
  string
  line `^1[2D. Insurers to be subject to this Act while liabilities remain unsatisfied. -- Every insurer shall`
  line `be subject to all the provisions of this Act in relation to any class of insurance business so long as his`
  line `liabilities in ^2[India] in respect of business of that class remain unsatisfied or not otherwise provided for.]`
obj_root_law_sections_2_d_footnotes:
  string
  line `1. Sections (2A) and (2B) renumbered as sections (2D) and (2E) thereof by Act 47 of 1950, s. 6 (w.e.f. 1-6-1950).`
  line
  line `2. Subs. by Act 62 of 1956, s. 2 the Schedule, for "the States" (w.e.f. 1-11-1956).`
obj_root_law_sections_2_e:
  sectionId (18103)
  sectionNo 2E
  orderNo 9
  title [Omitted.].
  content obj_root_law_sections_2_e_content
  footnotes obj_root_law_sections_2_e_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18103&sectionno=2E&orderno=9&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_2_e_content:
  string
  line `2E. [This Act not to apply to certain insurers, ceasing to enter into new contracts before`
  line `commencement of Act].-- Omitted by the Insurance Laws (Amendment) Act, 2015 (5 of 2015), s. 5`
  line `(w.e.f. 26-12-2014).`
