  (str sectionNo) (str 64-O)
  (str orderNo) (int 142)
  (str title) (str Omitted..)
  (str content) (str `[Power of General Insurance Council to regulate rates of insurance, etc.]--Omitted by the
Insurance (Amendment) Act, 1968 (62 of 1968), s. 27 (w.e.f. 1-6-1969).`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18236&sectionno=64-O&orderno=142&orgactid=AC_CEN_2_33_00044_193804_1523351752525)
