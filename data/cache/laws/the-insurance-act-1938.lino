  sectionNo 110D
  orderNo 233
  title `Certain claims for compensation barred.`
  content obj_root_law_sections_110_d_content
  footnotes `1. Ins. by Act 62 of 1968, s. 37 (w.e.f. 1-6-1969).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18326&sectionno=110D&orderno=233&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_110_d_content:
  string
  line `^1[110D. Certain claims for compensation barred. --No person shall have any right, whether in`
  line `contract or otherwise, to any compensation for any loss incurred by reason of the operation of any of the`
  line `provisions contained in section 34 or section 34A or section 34E or section 37A or by reason of the`
  line `compliance by an insurer with any order or direction given to hi m under this Act.]`
