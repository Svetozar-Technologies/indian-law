obj_root_law_sections_108:
  sectionId (18320)
  sectionNo (108)
  orderNo 227
  title `Power of Court to grant relief.`
  content obj_root_law_sections_108_content
  footnotes obj_root_law_sections_108_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18320&sectionno=108&orderno=227&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_108_content:
  string
  line `If any proceedings, civil or criminal, it appears to the court`
  line `hearing the case that a person is or may be liable in respect of negligence, default, breach of duty or`
  line `breach of trust but that he has acted honestly and reasonably and that having regard to all the`
  line `circumstances of the case he ought fairly to be excused for the negligence, default, breach of duty or`
  line `breach of trust, the court may relievehim either wholly or partly from his liability on such terms as it may`
  line `think fit.`
obj_root_law_sections_108_footnotes:
  string
  line
obj_root_law_sections_109:
  sectionId (18321)
  sectionNo (109)
  orderNo 228
  title `Cognizance of offences.`
  content obj_root_law_sections_109_content
  footnotes `1. Subs. by s. 93, ibid., for section 109 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18321&sectionno=109&orderno=228&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_109_content:
  string
  line `^1[109. Cognizance of offence. -- No court shall take cognizance of any offence punishable under`
  line `this Act or any rules or any regulations made thereunder, save on a complaint made by an officer of the`
  line `Authority or by any person authorised by it.]`
obj_root_law_sections_110:
  sectionId (18322)
  sectionNo (110)
  orderNo 229
  title `Appeal to Securities Appellate Tribunal.`
  content obj_root_law_sections_110_content
  footnotes `1. Subs. by s. 94, ibid., for section 110 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18322&sectionno=110&orderno=229&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_110_content:
  string
  line `^1 [110. Appeal to Securities Appellate Tribunal. -- (1) Any person aggrieved--`
  line
  line `(a) by an order of the Authority made on and after the commencement of the Insurance Laws`
  line `(Amendment) Act, 2015 (5 of 2015), or under this Act, the rules or regulations made thereunder; or`
  line
  line `(b) by an order made by the Authority by way of adjudication under this Act,`
  line `may prefer an appeal to the Securities Appellate Tribunal having jurisdiction in the matter.`
  line
  line `(2) Every appeal made under sub-section (1) shall be filed within a period of forty-five days from the`
  line `date on which a copy of the order made by the Authority is received by him and it shall be in such a form`
  line `and be accompanied by such fees as may be prescribed:`
  line
  line `Provided that the Securities Appellate Tribunal may entertain an appeal after the expiry of the said`
  line `period of forty-five days if it is satisfied that there was sufficient cause for not filing it within that period.`
  line
  line `(3) On receipt of an appeal under sub-section (1), the Securities Appellate Tribunal may, after giving`
  line `parties to the appeal an opportunity of being heard, pass such orders thereon as it thinks fit, conforming,`
  line `modifying or setting aside the order appealed against.`
  line
  line `(4) The Securities Appellate Tribunal shall make available copy of order made by it to the Authority`
  line `and parties.`
  line
  line `(5) The appeal filed before the Securities Appellate Tribunal under sub-section (1) shall be dealt with`
  line `by it as expeditiously as possible and endeavour shall be made by it to dispose of the appeal finally within`
  line `six months from the date of receipt of appeal.`
  line
  line `(6) The procedure for filing and disposing of an appeal shall be such as may be prescribed.`
  line
  line `(7) The provision contained in section 15U, section 15V, section 15W, section 15Y and section`
  line `15Z of the Securities and Exchange Board of India Act, 1992 (15 of 1992) shall apply to the appeals`
  line `arising out of the provisions of this Act, as they apply to the appeals under the Securities and Exchange`
  line `Board of India Act, 1992 (15 of 1992).]`
obj_root_law_sections_110_a:
  sectionId (18323)
  sectionNo 110A
  orderNo 230
  title `Delegation of powers and duties of Chairperson of the Authority.`
  content obj_root_law_sections_110_a_content
