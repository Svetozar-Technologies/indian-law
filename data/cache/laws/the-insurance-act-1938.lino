  sectionId (18178)
  sectionNo (43)
  orderNo 84
  title `Register of insurance agents.`
  content obj_root_law_sections_43_content
  footnotes `1.Subs. by Act 5 of 2015, s. 53, for section 43 (w.e.f. 26-12-2014).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_33_00044_193804_1523351752525&sectionId=18178&sectionno=43&orderno=84&orgactid=AC_CEN_2_33_00044_193804_1523351752525
obj_root_law_sections_43_content:
  string
  line `^1[43. Record of insurance agents. --(1) Every insurer and every person who, acting on behalf of an`
  line `insurer employs insurance agents shall maintain a record showing the name and address of every`
  line `insurance agent appointed by him and the date on which his appointment began and the date, if any, on`
  line `which his appointment ceased.`
  line
  line `(2) The record prepared by the insurer under sub-section (1), shall be maintained as long as the`
  line `insurance agent is in service and for a period of five years after the cessation of appointment.]`
