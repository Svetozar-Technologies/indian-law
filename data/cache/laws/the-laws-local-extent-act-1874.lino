obj_root_law_sections_1:
  sectionId (68201)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content `This Act may be called the Laws Local Extent Act, 1874.`
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68201&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (68202)
  sectionNo (2)
  orderNo 2
  title `Interpretation clause.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68202&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_2_content:
  string
  line `In this Act the expression “Scheduled Districts” means the territories`
  line `mentioned in the sixth schedule hereto annexed.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (68203)
  sectionNo (3)
  orderNo 3
  title `Local extent of Acts in first schedule.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68203&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_3_content:
  string
  line `The Acts mentioned in the first schedule hereto annexed`
  line `are now in force ^1[in the whole of India except ^2[the territories which, immediately before the`
  line `1st November, 1956, were comprised in Part B States] and] the Scheduled Districts.`
obj_root_law_sections_3_footnotes:
  string
  line `1. Subs. by the A.O. 1950 for "throughout all the Provinces of India, except".`
  line
  line `2. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part B States" (w.e.f. 1-11-1956).`
obj_root_law_sections_4:
  sectionId (68204)
  sectionNo (4)
  orderNo 4
  title `Local extent of enactments in second schedule.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68204&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_4_content:
  string
  line `The enactments mentioned in the second`
  line `schedule hereto annexed are now in force throughout the whole of the territories now subject to the`
  line `government of the Governor of Fort St. George in Council, except the Scheduled Districts subject to such`
  line government.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (68205)
  sectionNo (5)
  orderNo 5
  title `Local extent of enactments in third schedule.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68205&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_5_content:
  string
  line `The enactments mentioned in the third schedule`
  line `hereto annexed are now in force throughout the whole of the territories now subject to the government of`
  line `the Governor of Bombay in Council, except the Scheduled Districts subject to such government.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (68206)
  sectionNo (6)
  orderNo 6
  title `Local extent of enactments in fourth schedule.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68206&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_6_content:
  string
  line `The enactments mentioned in the fourth schedule`
  line `hereto annexed are now in force throughout the whole of the territories now subject to the government of`
  line `the Lieutenant-Governor of Bengal, except the Scheduled Districts subject to such government.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (68207)
  sectionNo (7)
  orderNo 7
  title `Local extent of enactments in fifth schedule.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68207&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_7_content:
  string
  line `The enactments mentioned in the fifth schedule`
  line `hereto annexed are now in force throughout the whole of the territories now subject to the government of`
  line `the Lieutenant-Governor of the North-Western Provinces of the Presidency of Fort William, except the`
  line `Scheduled Districts subject to such government.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (68208)
  sectionNo (8)
  orderNo 8
  title Savings.
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68208&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_000100_187415_1663830097653
obj_root_law_sections_8_content:
  string
  line `Nothing herein contained shall---`
  line
  line `(a) bar the power of the Central Government or the State Government under any law for the time being`
  line `in force, to extend to any place any Act mentioned in the said first schedule;`
  line
  line `(b) extend any Act empowering the State Government to extend the same or any part thereof, or affect`
  line `in any manner the exercise of such power;`
  line
  line `(c) affect the operation of any Act or Regulation heretofore extended to or declared to be in force in`
  line `any of the Scheduled Districts;`
  line
  line `(d) revive any enactment which has been repealed either generally or with reference to some special`
  line subject;
  line
  line `^1* * * * *`
  line
  line `(j) extend to any of the towns of Calcutta, Madras and Bombay any law not now in force therein;`
  line
  line `^2[(jj) extend to Pargana Bhadohi or Pargana Kera Mangror in the Mirzapur district, or to Pargana Kaswa`
  line `Raja in the Benares district, any law not now in force therein];`
  line
  line `(k) affect the operation of any enactment not mentioned in any of the schedules hereto annexed.`
obj_root_law_sections_8_footnotes:
  string
  line `1. Clauses (e) and (h) were rep. by Act 8 of 1887, clause (f) by Act 12 of 1891, clause (g) by Act 8 of 1890 and clause (i) by Act 4`
  line `of 1894.`
  line
  line `2. Ins. by Act 14 of 1881, s.15.`
