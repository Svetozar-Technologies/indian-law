obj_root_law_sections_1:
  object
  (str sectionId) (str 68201)
  (str sectionNo) (str 1)
  (str orderNo) (int 1)
  (str title) (str `Short title.`)
  (str content) (str `This Act may be called the Laws Local Extent Act, 1874.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68201&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
obj_root_law_sections_2:
  object
  (str sectionId) (str 68202)
  (str sectionNo) (str 2)
  (str orderNo) (int 2)
  (str title) (str `Interpretation clause.`)
  (str content) (str `In this Act the expression “Scheduled Districts” means the territories
mentioned in the sixth schedule hereto annexed.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68202&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
obj_root_law_sections_3:
  object
  (str sectionId) (str 68203)
  (str sectionNo) (str 3)
  (str orderNo) (int 3)
  (str title) (str `Local extent of Acts in first schedule.`)
  (str content) (str `The Acts mentioned in the first schedule hereto annexed
are now in force ^1[in the whole of India except ^2[the territories which, immediately before the
1st November, 1956, were comprised in Part B States] and] the Scheduled Districts.`)
  (str footnotes) (str `1. Subs. by the A.O. 1950 for "throughout all the Provinces of India, except".

2. Subs. by the Adaptation of Laws (No. 2) Order, 1956, for "Part B States" (w.e.f. 1-11-1956).`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68203&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
obj_root_law_sections_4:
  object
  (str sectionId) (str 68204)
  (str sectionNo) (str 4)
  (str orderNo) (int 4)
  (str title) (str `Local extent of enactments in second schedule.`)
  (str content) (str `The enactments mentioned in the second
schedule hereto annexed are now in force throughout the whole of the territories now subject to the
government of the Governor of Fort St. George in Council, except the Scheduled Districts subject to such
government.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68204&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
obj_root_law_sections_5:
  object
  (str sectionId) (str 68205)
  (str sectionNo) (str 5)
  (str orderNo) (int 5)
  (str title) (str `Local extent of enactments in third schedule.`)
  (str content) (str `The enactments mentioned in the third schedule
hereto annexed are now in force throughout the whole of the territories now subject to the government of
the Governor of Bombay in Council, except the Scheduled Districts subject to such government.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68205&sectionno=5&orderno=5&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
obj_root_law_sections_6:
  object
  (str sectionId) (str 68206)
  (str sectionNo) (str 6)
  (str orderNo) (int 6)
  (str title) (str `Local extent of enactments in fourth schedule.`)
  (str content) (str `The enactments mentioned in the fourth schedule
hereto annexed are now in force throughout the whole of the territories now subject to the government of
the Lieutenant-Governor of Bengal, except the Scheduled Districts subject to such government.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68206&sectionno=6&orderno=6&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
obj_root_law_sections_7:
  object
  (str sectionId) (str 68207)
  (str sectionNo) (str 7)
  (str orderNo) (int 7)
  (str title) (str `Local extent of enactments in fifth schedule.`)
  (str content) (str `The enactments mentioned in the fifth schedule
hereto annexed are now in force throughout the whole of the territories now subject to the government of
the Lieutenant-Governor of the North-Western Provinces of the Presidency of Fort William, except the
Scheduled Districts subject to such government.`)
  (str footnotes) (str )
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68207&sectionno=7&orderno=7&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
obj_root_law_sections_8:
  object
  (str sectionId) (str 68208)
  (str sectionNo) (str 8)
  (str orderNo) (int 8)
  (str title) (str Savings.)
  (str content) (str `Nothing herein contained shall---

(a) bar the power of the Central Government or the State Government under any law for the time being
in force, to extend to any place any Act mentioned in the said first schedule;

(b) extend any Act empowering the State Government to extend the same or any part thereof, or affect
in any manner the exercise of such power;

(c) affect the operation of any Act or Regulation heretofore extended to or declared to be in force in
any of the Scheduled Districts;

(d) revive any enactment which has been repealed either generally or with reference to some special
subject;

^1* * * * *

(j) extend to any of the towns of Calcutta, Madras and Bombay any law not now in force therein;

^2[(jj) extend to Pargana Bhadohi or Pargana Kera Mangror in the Mirzapur district, or to Pargana Kaswa
Raja in the Benares district, any law not now in force therein];

(k) affect the operation of any enactment not mentioned in any of the schedules hereto annexed.`)
  (str footnotes) (str `1. Clauses (e) and (h) were rep. by Act 8 of 1887, clause (f) by Act 12 of 1891, clause (g) by Act 8 of 1890 and clause (i) by Act 4
of 1894.

2. Ins. by Act 14 of 1881, s.15.`)
  (str query) (str abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_000100_187415_1663830097653&sectionId=68208&sectionno=8&orderno=8&orgactid=AC_CEN_5_5_000100_187415_1663830097653)
