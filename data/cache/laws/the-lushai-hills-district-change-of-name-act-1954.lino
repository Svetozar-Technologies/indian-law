obj_root_law_sections_1:
  sectionId (39430)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00022_195418_1517807321290&sectionId=39430&sectionno=1&orderno=1&orgactid=AC_CEN_5_5_00022_195418_1517807321290
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Lushai Hills District (Change`
  line `of Name) Act, 1954.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1 1st September, 1954, vide notification No. S.R.O. 2832 (E), dated 1stSeptember, 1954, see Gazette of India,`
  line `Extraordinary, Part II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (39431)
  sectionNo (2)
  orderNo 2
  title `Lushai Hills District to be known as Mizo District.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00022_195418_1517807321290&sectionId=39431&sectionno=2&orderno=2&orgactid=AC_CEN_5_5_00022_195418_1517807321290
obj_root_law_sections_2_content:
  string
  line `The tribal area in Assam now known as`
  line `the Lushai Hills District shall, as from the commencement of this Act, be known as the Mizo District.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (39432)
  sectionNo (3)
  orderNo 3
  title `Amendment of the Sixth Schedule to the Constitution.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00022_195418_1517807321290&sectionId=39432&sectionno=3&orderno=3&orgactid=AC_CEN_5_5_00022_195418_1517807321290
obj_root_law_sections_3_content:
  string
  line `In the Sixth Schedule to the`
  line `Constitution , in paragraph 20,—`
  line
  line `(a) after sub-paragraph (2), the following sub-paragraph shall be inserted namely:—`
  line
  line `"(2A) The Mizo District shall comprise the area which at the commencement of this`
  line `Constitution was known as the Lushai Hills District.";`
  line
  line `(b) in sub-paragraph (3), after the words "United Khasi Jaintia Hills District" the words "and the`
  line `Mizo District" shall be inserted; and`
  line
  line `(c) in Part A of the table, for the words "The Lushai Hills District", the words "The Mizo`
  line `District" shall be substituted.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (39433)
  sectionNo (4)
  orderNo 4
  title `Reference to Lushai Hills District to be construed as reference to Mizo District.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00022_195418_1517807321290&sectionId=39433&sectionno=4&orderno=4&orgactid=AC_CEN_5_5_00022_195418_1517807321290
obj_root_law_sections_4_content:
  string
  line Any
  line `reference to the Lushai Hills District in any law, instrument or other document shall, unless the context`
  line `otherwise requires, be construed as a reference to the Mizo District.`
obj_root_law_sections_4_footnotes:
  string
  line
