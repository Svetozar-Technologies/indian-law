  (str title) (str `कृषक उधार अधिनियम, 1884`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/19140/3/H1884-12.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:32:52.859Z`)
