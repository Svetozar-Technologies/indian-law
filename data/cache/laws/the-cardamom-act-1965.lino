obj_root_law_sections_1:
  sectionId (47846)
  sectionNo (1)
  orderNo 1
  title `Short title, extent and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00002_196542_1517807318367&sectionId=47846&sectionno=1&orderno=1&orgactid=AC_CEN_11_12_00002_196542_1517807318367
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Cardamom Act, 1965.`
  line
  line `(2) It extends to the whole of India:`
  line
  line `Provided that it shall not apply to the State of Jammu and Kashmir* except to the extent to which the`
  line `provisions of this Act relate to the control of export of cardamom from India and import thereof into`
  line India.
  line
  line `(3) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint:`
  line
  line `Provided that different dates may be appointed for different provisions of this Act.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 5th April, 1966, vide notification No. G.S.R. 543, dated the 5th April, 1966, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(i) except Chapter III.`
  line `11th April, 1966, vide notification No. G.S.R. 380, dated 5th March, 1966, see Gazette of India, Extraordinary, Part II, sec. 3(i)`
  line `in respect of ss. 14 and 15.`
  line `12th July, 1966, vide notification No. S.O. 2166(E), dated 12th July, 1966, see Gazette of India, Extraordinary, Part II,`
  line `sec. 3(ii) in respect of Chapter III.`
  line
  line `*. Vide notification No. S.O. 3912(E), dated 30th October, 2019, this Act is made applicable to the Union territory of Jammu and Kashmir and the Union territory of Ladakh.`
obj_root_law_sections_2:
  sectionId (47847)
  sectionNo (2)
  orderNo 2
  title `Declaration as to expediency of control by the Union.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_11_12_00002_196542_1517807318367&sectionId=47847&sectionno=2&orderno=2&orgactid=AC_CEN_11_12_00002_196542_1517807318367
obj_root_law_sections_2_content:
  string
  line `It is hereby declared that it is expedient`
  line `in the public interest that the Union should take under its control the cardamom industry.`
obj_root_law_sections_2_footnotes:
  string
  line
