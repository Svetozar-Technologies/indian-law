obj_root_law_sections_1:
  sectionId (47955)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47955&sectionno=1&orderno=1&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Former Secretary of State`
  line `Service Officers (Conditions of Service) Act, 1972.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 1st October, 1972, vide notification No. G.S.R. 420(E), dated 28th September, 1972, see Gazette of India, Extraordinary, Part`
  line `II, sec. 3(i).`
obj_root_law_sections_2:
  sectionId (47956)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47956&sectionno=2&orderno=2&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires,--`
  line
  line `(a) "appointed day" means the date on which this Act comes into force;`
  line
  line `(b) "former Secretary of State Service officer" means a person referred to in sub-clause (a) or`
  line `sub-clause (b) of clause (1) of article 312A of the Constitution;`
  line
  line `(c) "I.C.S. member of the Indian Administrative Service" means a person who was appointed to`
  line `the Civil Service of the Crown in India known as the Indian Civil Service and who on the appointed`
  line `day is a member of the Indian Administrative Service;`
  line
  line `(d) "I.P. member of the Indian Police Service" means a person who was appointed to the Police`
  line `Service of the Crown in India known as the Indian Police and who on the appointed day is a member`
  line `of the Indian Police Service;`
  line
  line `(e) "pension" has the meaning assigned to it in clause (17) of article 366 of the Constitution.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (47957)
  sectionNo (3)
  orderNo 3
  title `Conditions of service of I.C.S. members of the Indian Administrative Service.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47957&sectionno=3&orderno=3&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_3_content:
  string
  line `Subject to the`
  line `other provisions of this Act, on and from the appointed day,--`
  line
  line `(a) the conditions of service as respects,--`
  line
  line `(i) remuneration,`
  line
  line `(ii) leave, and`
  line
  line `(iii) pension;`
  line
  line `(b) the rights as respects disciplinary matters; and`
  line
  line `(c) the conditions of service and the rights as respects all other matters,`
  line
  line `of the I.C.S. members of the Indian Administrative Service shall be the same as those of the other`
  line `members of that Service and accordingly and subject as aforesaid, the provisions of the All-India Services`
  line `Act, 1951 (61 of 1951) and the rules and regulations made or deemed to have been made thereunder, as in`
  line `force from time to time, shall apply to and in relation to the I.C.S. members of the Indian Administrative`
  line `Service as they apply to and in relation to the other members of that Service.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (47958)
  sectionNo (4)
  orderNo 4
  title `Conditions of service of I.P. members of the Indian Police Service.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47958&sectionno=4&orderno=4&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_4_content:
  string
  line `Subject to the other`
  line `provisions of this Act, on and from the appointed day,--`
  line
  line `(a) the conditions of service as respects,--`
  line
  line `(i) remuneration,`
  line
  line `(ii) leave, and`
  line
  line `(iii) pension;`
  line
  line `(b) the rights as respects disciplinary matters; and`
  line
  line `(c) the conditions of service and the rights as respects all other matters,`
  line
  line `of the I.P. members of the Indian Police Service shall be the same as those of the other members of`
  line `that Service and accordingly and subject as aforesaid, the provisions of the All-India Services`
  line `Act, 1951 (61 of 1951) and the rules and regulations made or deemed to have been made thereunder, as in`
  line `force from time to time, shall apply to and in relation to the I.P. members of the Indian Police Service as`
  line `they apply to and in relation to the other members of that Service.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47959)
  sectionNo (5)
  orderNo 5
  title `Pay of I.C.S. members of Indian Administrative Service and I.P. members of Indian Police Service.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47959&sectionno=5&orderno=5&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_5_content:
  string
  line `Notwithstanding anything contained in section 3 or section 4, an I.C.S. member of the Indian`
  line `Administrative Service or an I.P. member of the Indian Police Service, as the case may be, holding a post`
  line `specified in the Schedule or a post declared by the Central Government to be equivalent to such post`
  line `shall, for so long as he holds that post, be entitled to draw pay as indicated against the post in the`
  line Schedule.
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (47960)
  sectionNo (6)
  orderNo 6
  title `Retirement of I.C.S. members of Indian Administrative Service and I.P. members of Indian Police Service.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47960&sectionno=6&orderno=6&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_6_content:
  string
  line `Notwithstanding anything contained in section 3 or section 4,--`
  line
  line `(a) an I.C.S. member of the Indian Administrative Service, unless his service has been extended`
  line `before the appointed day in accordance with the rules and regulations then applicable or is extended`
  line `on or after that day in accordance with the rules and regulations applicable to the other members of`
  line `the Indian Administrative Service, shall retire compulsorily,--`
  line
  line `(i) where he attains the age of fifty-eight years before the expiry of six months from the`
  line `appointed day, on the date of expiry of the said period of six months or on the date on which he`
  line `shall retire compulsorily in accordance with the rules applicable to him immediately before the`
  line `appointed day, whichever date is earlier;`
  line
  line `(ii) in any other case, on his attaining the age of fifty-eight years;`
  line
  line `(b) the Central Government shall have and shall be deemed always to have had the power to`
  line `require an I.C.S. member of the Indian Administrative Service or an I.P. member of the Indian Police`
  line `Service, in consultation with the Government of the State on whose cadre he is borne and after giving`
  line `to such member at least three months previous notice in writing, to retire in public interest from`
  line `service on the date on which such member completes thirty years of qualifying service or attains fifty`
  line `years of age or on any date thereafter to be specified in the notice;`
  line
  line `(c) an I.C.S. member of the Indian Administrative Service or an I.P. member of the Indian Police`
  line `Service may, after giving at least three months previous notice in writing to the Government of the`
  line `State on whose cadre he is borne, retire from service on the date on which such member completes`
  line `thirty years of qualifying service or attains fifty years of age or on any date thereafter to be specified`
  line `in the notice:`
  line
  line `Provided that no member under suspension shall retire from service except with the specific`
  line `approval of the Government of the State on whose cadre he is borne.`
  line
  line `Explanation.--For the purposes of clause (b) and clause (c), "qualifying service" means service`
  line `qualifying for purposes of pension.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47961)
  sectionNo (7)
  orderNo 7
  title `Pension of I.C.S. members of Indian Administrative Service.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47961&sectionno=7&orderno=7&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_7_content:
  string
  line `(a) an I.C.S. member of the Indian Administrative Service shall, subject to the provisions of`
  line `section 8 and subject to the same provisions in regard to the right of the Central Government to`
  line `withdraw the whole or any part of pension or to order recovery of pension and the same conditions`
  line `for grant of retirement benefits, as are applicable for the time being in the case of other members of`
  line `the Indian Administrative Service, be entitled on his retirement from service in accordance with the provisions of section 6, to receive by way of annuity rupees thirteen thousand three hundred and`
  line `thirty-three and one-third;`
  line
  line `(b) no death-cum-retirement gratuity benefits shall be available to or in respect of an I.C.S.`
  line `member of the Indian Administrative Service unless such member has exercised his option for such`
  line `benefits before the appointed day in accordance with the orders of the Central Government in that`
  line `behalf and the benefits admissible to or in relation to an I.C.S. member of the Service who so`
  line `exercised his option shall be subject to the conditions specified in the said orders and to the same`
  line `conditions for grant of retirement benefits as are applicable for the time being in the case of other`
  line `members of the Indian Administrative Service;`
  line
  line `(c) no family pension benefits shall be admissible in relation to an I.C.S. member of the Indian`
  line `Administrative Service unless such member exercised his option in respect of such benefits before the`
  line `appointed day in accordance with the orders of the Central Government in that behalf and the benefits`
  line `admissible in relation to an I.C.S. member of the service who so exercised his option shall be subject`
  line `to the conditions specified in the said orders;`
  line
  line `(d) the Provident Fund account of an I.C.S. member of the Indian Administrative Service shall be`
  line `credited, on his retirement or previous death, with the same amount, if any, as would have been`
  line `credited by way of contribution in accordance with the rules in force immediately before the`
  line `appointed day`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47962)
  sectionNo (8)
  orderNo 8
  title `Pension payable to former Secretary of State Service officers in Indian currency only.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47962&sectionno=8&orderno=8&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_8_content:
  string
  line `(1) No former Secretary of State Service officer shall be entitled, or be deemed ever to have been`
  line `entitled, to claim,--`
  line
  line `(a) pension in sterling; or`
  line
  line `(b) that his pension shall be paid outside India; or`
  line
  line `(c) where his pension was expressed in sterling or a fixed sterling minimum was applicable in`
  line `respect of the pension payable to him, that his pension shall be computed in the rupee equivalent of`
  line `the amount fixed in sterling at a rate of exchange exceeding the rate of rupees thirteen and one-third`
  line `to the pound sterling:`
  line
  line `^1[Provided that in relation to every former Secretary of State Service officer who, having been in`
  line `service on the 1st day of February, 1921, and domiciled in India on that date, is entitled immediately`
  line `before the appointed day to claim his pension computed in the rupee equivalent of the amount fixed in`
  line `sterling at a rate of exchange of rupees fifteen to a pound sterling, clause (c) shall have effect as if for`
  line `the words thirteen and one-third, the word fifteen were substituted:`
  line
  line `Provided further that every former Secretary of State Service officer whose pension was`
  line `expressed in sterling or in respect of whose pension a fixed sterling minimum was applicable, and`
  line `who, immediately before the appointed day, is a foreigner having taken up permanent residence`
  line `outside India, shall, so long as he continues to be a foreigner permanently residing outside India, be`
  line `allowed to convert the annuity of rupees thirteen thousand three hundred and thirty-three and`
  line `one-third or the annuity actually payable to him in rupees, whichever is less, into pound sterling at the`
  line `rate of rupees thirteen and one-third to a pound sterling, and the annuity so converted into pound`
  line `sterling shall be paid outside India.`
  line
  line `Explanation 1.--Nothing contained in the foregoing proviso shall be deemed to entitle any former`
  line `Secretary of State Service officer to claim conversion of amounts representing the annuity or the`
  line `commuted value thereof, already drawn in rupees before the commencement of the Former Secretary`
  line `of State Service Officers (Conditions of Service) Amendment Act, 1975 (24 of 1975), into pound`
  line sterling.
  line
  line `Explanation 2.--In this sub-section, the expression foreigner means a person who is not a`
  line `citizen of India.]`
  line
  line `(2) Notwithstanding any judgment, decree or order of any court, every former Secretary of State`
  line `Service officer ^2[[not being an officer to whom the first proviso or the second proviso to`
  line `sub-section (1) applies]] who has been paid the rupee equivalent or, as the case may be, the pound`
  line `sterling equivalent of his pension by calculating such pension with reference to a rate of exchange`
  line `exceeding the rate of exchange of rupees thirteen and one-third to the pound sterling, shall refund to`
  line `the Central Government or, as the case may be, the State Government, the sum by which the amount`
  line `paid to him exceeds the amount which would have been payable to him if the calculation had been`
  line `made at the rate of exchange of rupees thirteen and one-third to the pound sterling and the Central`
  line `Government or the State Government may set off, in such manner as it may deem fit, the amount`
  line `required to be so refunded to it by any such officer against any sum (including pension) which is or`
  line `which may become due from that Government to such officer.`
  line
  line `(3) For the removal of doubts, it is hereby declared that the provisions of sub-sections (1) and (2)`
  line `shall apply to a former Secretary of State Service officer who is holding or has held the office of the`
  line `Chief Justice or other Judge of the Supreme Court or a High Court, the Comptroller and`
  line `Auditor-General of India, the Chairman or other member of the Union or a State Public Service`
  line `Commission or the Chief Election Commissioner as they apply to other former Secretary of State`
  line `Service officers.`
obj_root_law_sections_8_footnotes:
  string
  line `1. The provisos and Explanations ins. by Act 24 of 1975, s. 2 (w.e.f. 9-5-1975).`
  line
  line `2. Ins. by Act 24 of 1975, s. 2 (w.e.f. 9-5-1975).`
obj_root_law_sections_9:
  sectionId (47963)
  sectionNo (9)
  orderNo 9
  title `Power of Central Government to adapt certain rules, regulations and orders.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47963&sectionno=9&orderno=9&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_9_content:
  string
  line `(1) For the`
  line `purpose of bringing the provisions of any rules and regulations made or deemed to have been made under`
  line `the All-India Services Act, 1951 (61 of 1951) or any rules, regulations or orders (including any other`
  line `instrument having the force of law) applicable immediately before the appointed day to or in relation to`
  line `former Secretary of State Service officers into accord with the provisions of this Act, the Central`
  line `Government may, before the expiry of two years from the appointed day, by order published in the`
  line `Official Gazette, make such adaptations and modifications of such rules, regulations or orders, whether by`
  line `way of repeal or amendment, as may be necessary.`
  line
  line `(2) The provisions of sub-section (1) shall be in addition to and not in derogation of any power under`
  line `any other law to amend or repeal the rules, regulations and orders referred to in that sub-section.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47964)
  sectionNo (10)
  orderNo 10
  title `Power to construe rules, regulations and orders.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47964&sectionno=10&orderno=10&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_10_content:
  string
  line `Notwithstanding that no provision or`
  line `insufficient provision has been made under section 9 for the adaptation of any rule, regulation or order`
  line `referred to in that section, any court, tribunal or authority, required or empowered to enforce such rule,`
  line `regulation or order may construe it with such modifications as may be necessary to bring it into accord`
  line `with the provisions of this Act.`
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_10_a:
  sectionId (47965)
  sectionNo 10A
  orderNo 11
  title `Power of Central Government to make orders in certain cases to ensure parity.`
  content obj_root_law_sections_10_a_content
  footnotes `1. Ins. by s. 3, ibid. (w.e.f. 9-5-1975).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47965&sectionno=10A&orderno=11&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_10_a_content:
  string
  line `^1[10A. Power of Central Government to make orders in certain cases to ensure parity.--(1) If`
  line `the Central Government is satisfied that the conditions of service as respects any matter applicable to, or`
  line `in relation to, any class or category of former Secretary of State Service officers under section 6, 7 or 8 or`
  line `as respects any benefits by way of compensation for the increase in cost of living or any other reason,`
  line `have become less favourable than those applicable to or in relation to any corresponding class or category`
  line `of other officers of the Indian Administrative Service or the Indian Police Service or, as the case may be,`
  line `any comparable service, it may, notwithstanding anything contained in those sections, by general or`
  line `special order and subject to such conditions and restrictions (including conditions as to refund adjustment`
  line `or recovery), as may be specified therein, make such provisions as it may deem fit for securing, so far as`
  line `may be, parity in such cases.`
  line
  line `(2) Any order under sub-section (1) may be made so as to have retrospective effect.`
  line
  line `(3) Every order made under sub-section (1) shall be laid, as soon as may be after it is made, before`
  line `each House of Parliament while it is in session, for a total period of thirty days which may be comprised`
  line `in one session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the order or both Houses agree that the order should not be made, the order shall thereafter have effect only in such modified form or be of no effect, as the case may be; so, however, that any such modification`
  line `or annulment shall be without prejudice to the validity of anything previously done under that order.]`
obj_root_law_sections_11:
  sectionId (47966)
  sectionNo (11)
  orderNo 12
  title `Power to remove difficulties.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47966&sectionno=11&orderno=12&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_11_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by general or special order published in the Official Gazette, for`
  line `the purpose of removing the difficulty, make such provisions not inconsistent with the provisions of this`
  line `Act as appear to it to be necessary or expedient:`
  line
  line `Provided that no such order shall be made under this sub-section after the expiry of three years from`
  line `the appointed day.`
  line
  line `(2) Every order made under sub-section (1) shall, as soon as may be after it is made, be laid before`
  line `each House of Parliament.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (47967)
  sectionNo (12)
  orderNo 13
  title `Act to have overriding effect.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47967&sectionno=12&orderno=13&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_12_content:
  string
  line `The provisions of this Act or of any order made thereunder shall`
  line `have effect notwithstanding anything inconsistent therewith contained in any law other than this Act or in`
  line `any rule, regulation or order or other instrument having effect by virtue of any law other than this Act.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (47968)
  sectionNo (13)
  orderNo 14
  title `Saving of orders in respect of disciplinary matters.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_26_36_00009_197259_1517807325044&sectionId=47968&sectionno=13&orderno=14&orgactid=AC_CEN_26_36_00009_197259_1517807325044
obj_root_law_sections_13_content:
  string
  line `Any order in respect of disciplinary`
  line `matters in relation to any I.C.S. member of the Indian Administrative Service or any I.P. member of the`
  line `Indian Police Service in force immediately before the appointed day shall continue in force as from the`
  line `appointed day:`
  line
  line `Provided that nothing in this section shall derogate from the powers of the competent authority to`
  line `vary or rescind such order.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
obj_root_law_translations_hi:
  title `भूतपूर्व सेक्रेटरी आफ स्‍टेट सेवा अधिकारी (सेवा शर्तें)अधिनियम, 1972`
