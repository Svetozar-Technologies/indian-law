  (str ministry) (str `Ministry of Personnel, Public Grievances and Pensions`)
  (str department) (str `Department of Personnel and Training`)
  (str longTitle) (str `An Act to provide for the variation or revocation of the conditions of service of former Secretary of State Service officers in respect of certain matters and for matters connected therewith or incidental thereto.`)
