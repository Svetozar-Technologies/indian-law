obj_root_law_sections_1:
  sectionId (47045)
  sectionNo (1)
  orderNo 1
  title [Repealed.].
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47045&sectionno=1&orderno=1&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_1_content:
  string
  line `[Repeal of parts of Bengal Regulation 19 of 1810 and Madras Regulation 7 of 1817].--[Rep. by the`
  line `Repealing Act, 1870 (14 of 1870), s. 1 and the Schedule.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (47046)
  sectionNo (2)
  orderNo 2
  title `Interpretation clause.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47046&sectionno=2&orderno=2&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_2_content:
  string
  line `In this Act,---`
  line
  line `1* * * * *`
  line
  line `"Civil Court" and "Court".--The words "Civil Court" and "Court" shall ^2]save as provided in section`
  line `10] mean the principal Court of original civil jurisdiction in the district in which ^1]or any other Court`
  line `empowered in that behalf by the State Government within the local limits of the jurisdiction of which] the`
  line `mosque, temple or religious establishment is situate, relating to which, or to the endowment whereof, any suit`
  line `shall be instituted or application made under the provisions of this Act.`
obj_root_law_sections_2_footnotes:
  string
  line `1. The clauses relating to "number" and "gender" rep. by Act 10 of 1914, s. 3 and the Second Schedule (w.e.f. 17-3-1914).`
  line
  line `2. Ins. by Act 21 of 1925, s. 2 (w.e.f. 11-9-1925).`
obj_root_law_sections_3:
  sectionId (47047)
  sectionNo (3)
  orderNo 3
  title `Government to make special provision respecting mosques, etc.`
  content obj_root_law_sections_3_content
  footnotes `1. Subs. by Act 12 of 1891, s. 2 and the Second Schedule, for "section 1" (w.e.f. 21-3-1891).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47047&sectionno=3&orderno=3&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_3_content:
  string
  line `In the case of every mosque,`
  line `temple or other religious establishment to which the provisions of either of the Regulations specified`
  line `in ^1[the preamble to this Act] are applicable, and nomination of the trustee, manager or superintendent`
  line `thereof, at the time of the passing of this Act, is vested in, or may be exercised by, the Government, or any`
  line `public officer, or in which the nomination of such trustee, manager or superintendent shall be subject to the`
  line `confirmation of the Government or any public officer, the State Government shall, as soon as possible after`
  line `the passing of this Act, make special provision as hereinafter provided.`
obj_root_law_sections_4:
  sectionId (47048)
  sectionNo (4)
  orderNo 4
  title `Transfer to trustees, etc., of trust-property in charge of Revenue Board.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47048&sectionno=4&orderno=4&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_4_content:
  string
  line `In the case of every`
  line `such mosque, temple or other religious establishment which, at the time of the passing of this Act, shall be`
  line `under the management of any trustee, manager or superintendent, whose nomination shall not vest in, nor be`
  line `exercised by, nor be subject to the confirmation of, the Government, or any public officer, the State Government shall, as soon as possible after the passing of this Act, transfer to such trustee, manager or`
  line `superintendent, all the landed or other property which, at the time of the passing of this Act, shall be under`
  line `the superintendence or in the possession of the Board of Revenue, or any local agent, and belonging to such`
  line `mosque, temple of other religious establishment, except such property as is hereinafter provided;`
  line
  line `Cessation of Board's powers as to such property.--and the powers and responsibilities of the Board of`
  line `Revenue, and the local agents, in respect to such mosque, temple or other religious establishment, and to all`
  line `land and other property so transferred, except as regards acts done and liabilities incurred by the said Board`
  line `of Revenue or any local agent, previous to such transfer, shall cease and determine.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (47049)
  sectionNo (5)
  orderNo 5
  title `Procedure in case of dispute as to right of succession to vacated trusteeship.`
  content obj_root_law_sections_5_content
  footnotes `1. Section 5 shall not apply to any wakf to which the Wakf Act, 1954 (29 of 1954) applies (w.e.f. 1-10-1962).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47049&sectionno=5&orderno=5&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_5_content:
  string
  line `^45. Procedure in case of dispute as to right of succession to vacated trusteeship.---Whenever from`
  line `any cause a vacancy shall occur in the office of any trustee, manager, or superintendent, to whom any`
  line `property shall have been transferred under the last preceding section, and any dispute shall arise respecting`
  line `the right of succession to such office, it shall be lawful for any person interested in the mosque, temple or religious establishment, to which such property shall belong, or in the performance of the worship or of the`
  line `service thereof, or the trusts relating thereto, to apply to the Civil Court to appoint a manager of such mosque,`
  line `temple or other religious establishment, and thereupon such Court may appoint such manager, to act until`
  line `some other person shall by suit have established his right of succession to such office.`
  line
  line `Powers of managers appointed by Court.--The manager so appointed by the Civil Court shall have,`
  line `and shall exercise, all the powers which, under this or any other Act, the former trustee, manager, or`
  line `superintendent, in whose place such manager is appointed, by the Court, had or could exercise, in relation to`
  line `such mosque, temple or religious establishment, or the property belonging thereto.`
obj_root_law_sections_6:
  sectionId (47050)
  sectionNo (6)
  orderNo 6
  title `Rights, etc., of trustees to whom property is transferred under section 4.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47050&sectionno=6&orderno=6&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_6_content:
  string
  line `The rights, powers, and`
  line `responsibilities of every trustee, manager or superintendent, to whom the land and other property of any`
  line `mosque, temple or other religious establishment is transferred in the manner prescribed in section 4 of this`
  line `Act, as well as the conditions of their appointment, election and removal, shall be the same as if this Act had`
  line `not been passed, except in respect of the liability to be sued under this Act, and except in respect of the`
  line `authority of the Board of Revenue, and local agents, given by the Regulations hereby repealed, over such mosque, temple or religious establishment, and over such trustee, manager, or superintendent, which`
  line `authority is hereby determined and repealed.`
  line `All the powers which might be exercised by any Board or local agent, for the recovery of the rent of land`
  line `or other property transferred under the said section 4 of this Act, may, from the date of such transfer, be`
  line `exercised by any trustee, manager or superintendent to whom such transfer is made.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (47051)
  sectionNo (7)
  orderNo 7
  title `Appointment of committees.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47051&sectionno=7&orderno=7&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_7_content:
  string
  line `In all cases described in section 3 of this Act the State Government`
  line `shall once for all appoint one or more committees in every division or district to take the place, and to`
  line `exercise the powers, of the Board of Revenue and the local agents under the Regulations hereby repealed.`
  line
  line `Constitution and duties of committees.--Such committee shall consist of three or more persons, and`
  line `shall perform all the duties imposed on such Board and local agents, except in respect of any property which`
  line `is specially provided for under section 21 of this Act.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (47052)
  sectionNo (8)
  orderNo 8
  title `Qualifications of member of committee.`
  content obj_root_law_sections_8_content
  footnotes `1. Ins. by Act 20 of 1983, s. 2 and the Schedule (w.e.f. 15-3-1984).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47052&sectionno=8&orderno=8&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_8_content:
  string
  line `The members of the said committee shall be appointed`
  line `from among persons professing the religion for the purposes of which the mosque, temple or other religious`
  line `establishment was founded or is now maintained, and in accordance, so far as can be ascertained, with the`
  line `general wishes of those who are interested in the maintenance of such mosque, temple or other religious`
  line establishment.
  line
  line `The appointment of the committee shall be notified in the Official Gazette.`
  line
  line `Ascertaining wishes of persons interested.--In order to ascertain the general wishes of such persons in`
  line `respect of such appointment, the State Government may cause an election to be held, under such rules ^1[, by`
  line `notification in the Official Gazette,] (not inconsistent with the provisions of this Act) as shall be framed by`
  line `such State Government.`
  line
  line `^1[Every rule framed under this section shall be laid, as soon as it is framed, before the State Legislature.]`
obj_root_law_sections_9:
  sectionId (47053)
  sectionNo (9)
  orderNo 9
  title `Tenure of office.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47053&sectionno=9&orderno=9&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_9_content:
  string
  line `Every member of a committee appointed as above shall hold his office for life,`
  line `unless removed for misconduct or unfitness;`
  line
  line `Removal.--and no such member shall be removed except by an order of the Civil Court as hereinafter`
  line provided.
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (47054)
  sectionNo (10)
  orderNo 10
  title `Vacancies to be filled.`
  content obj_root_law_sections_10_content
  footnotes `1. Added by Act 21 of 1925, s. 3 (w.e.f. 11-9-1925).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47054&sectionno=10&orderno=10&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_10_content:
  string
  line `Whenever any vacancy shall occur among the members of a committee`
  line `appointed as above, a new member shall be elected to fill the vacancy by the persons interested as above`
  line provided.
  line
  line `Procedure.--The remaining members of the committee shall, as soon as possible, give public notice of`
  line `such vacancy, and shall fix a day, which shall not be later than three months from the date of such vacancy,`
  line `for an election of a new member by the persons interested as above provided, under rules for elections which`
  line `shall be framed by the State Government;`
  line
  line `and whoever shall be then elected, under the said rules, shall be a member of the committee to fill such`
  line vacancy.
  line
  line `When Court may fill vacancy.--If any vacancy as aforesaid shall not be filled up by such election as`
  line `aforesaid within three months after it has occurred, the Civil Court, on the application of any person`
  line `whatever, may appoint a person to fill the vacancy or may order that the vacancy be forthwith filled up by the`
  line `remaining members of the committee, with which order it shall then be the duty of such remaining members to comply; and if this order be not complied with, the Civil Court may appoint a member to fill the said`
  line vacancy.
  line
  line `^1[Explanation.--In this section "Civil Court" means the principal Court of original civil jurisdiction in`
  line `the district in which the mosques, temples or religious establishments for which the committee has been`
  line `appointed or any of them are situate.]`
obj_root_law_sections_11:
  sectionId (47055)
  sectionNo (11)
  orderNo 11
  title `No member of Committee to be also trustee, etc., of mosque, etc.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47055&sectionno=11&orderno=11&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_11_content:
  string
  line `No member of a committee`
  line `appointed under this Act shall be capable of being, or shall act, also as a trustee, manager or superintendent of`
  line `the mosque, temple or other religious establishment for the management of which such committee shall have`
  line `been appointed.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (47056)
  sectionNo (12)
  orderNo 12
  title `On appointment of Committee, Board and local agents to transfer property.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47056&sectionno=12&orderno=12&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_12_content:
  string
  line `Immediately on`
  line `the appointment of a committee as above provided for the superintendence of any such mosque, temple or`
  line `religious establishment, and for the management of its affairs, the Board of Revenue, or the local agents`
  line `acting under the authority of the said Board, shall transfer to such committee all landed or other property`
  line `which at the time of appointment shall be under the superintendence, or in the possession of the said Board or`
  line `local agents, and belonging to the said religious establishment, except as is hereinafter provided for,`
  line
  line `Termination of powers and responsibilities of Board and agents.--and thereupon the powers and`
  line `responsibilities of the Board and the local agents, in respect to such mosque, temple or religious`
  line `establishment, and to all land and other property so transferred except as above, and except as regards acts`
  line `done and liabilities incurred by the said Board or agents previous to such transfer, shall cease and determine.`
  line
  line `Commencement of powers of committee.--All the powers which might be exercised by any Board or`
  line `local agent for the recovery of the rent of land or other property transferred under this section may from the`
  line `date of such transfer be exercised by such committee to whom such transfer is made.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (47057)
  sectionNo (13)
  orderNo 13
  title `Duty of trustee, etc., as to accounts.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47057&sectionno=13&orderno=13&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_13_content:
  string
  line `It shall be the duty of every trustee, manager and`
  line `superintendent of a mosque, temple or religious establishment of which the provisions of this Act shall apply`
  line `to keep regular accounts of his receipts and disbursements in respect of the endowments and expenses of such`
  line `mosque, temple or other religious establishment;`
  line
  line `and of committee.--and it shall be the duty of every committee of management, appointed or acting`
  line `under the authority of this Act, to require from every trustee, manager and superintendent of such mosque,`
  line `temple or other religious establishment, the production of such regular accounts of such receipts and`
  line `disbursements at least once in every year; and every such committee of management shall themselves keep`
  line `such accounts thereof.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (47058)
  sectionNo (14)
  orderNo 14
  title `Persons interested may singly sue in case of breach of trust, etc.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47058&sectionno=14&orderno=14&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_14_content:
  string
  line `Any person or persons`
  line `interested in any mosque, temple or religious establishment, or in the performance of the worship or of the`
  line `service thereof, or the trusts relating thereto, may, without joining as plaintiff any of the other persons`
  line `interested therein, sue before the Civil Court the trustee, manager or superintendent of such mosque, temple`
  line `or religious establishment or the member of any committee appointed under this Act, for any misfeasance,`
  line `breach of trust or neglect of duty, committed by such trustee, manager, superintendent or member of such`
  line `committee, in respect of the trusts vested in, or confided to, them respectively;`
  line
  line `Powers of Civil Court.--and the Civil Court may direct the specific performance of any act by such`
  line `trustee, manager, superintendent or member of a committee,`
  line
  line `and may decree damages and costs against such trustee, manager, superintendent or member of a`
  line committee,
  line
  line `and may also direct the removal of such trustee, manager, superintendent or member of a committee.`
obj_root_law_sections_14_footnotes:
  string
  line
obj_root_law_sections_15:
  sectionId (47059)
  sectionNo (15)
  orderNo 15
  title `Nature of interest entitling person to sue.`
  content obj_root_law_sections_15_content
  footnotes obj_root_law_sections_15_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47059&sectionno=15&orderno=15&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_15_content:
  string
  line `The interest required in order to entitle a person to sue`
  line `under the last preceding section need not be a pecuniary, or a direct or immediate, interest or such an interest`
  line `as would entitle the person suing to take any part in the management or superintendence of the trusts.`
  line `Any person having a right of attendance, or having been in the habit of attending, at the performance of`
  line `the worship or service of any mosque, temple or religious establishment, or of partaking in the benefit of any`
  line `distribution of alms, shall be deemed to be a person interested within the meaning of the last preceding`
  line section.
obj_root_law_sections_15_footnotes:
  string
  line
obj_root_law_sections_16:
  sectionId (47060)
  sectionNo (16)
  orderNo 16
  title `Reference to arbitrators.`
  content obj_root_law_sections_16_content
  footnotes obj_root_law_sections_16_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47060&sectionno=16&orderno=16&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_16_content:
  string
  line `In any suit or proceeding instituted under this Act it shall be lawful for`
  line `the Court before which such suit or proceeding is pending to order any matter in difference in such suit to be`
  line `referred for decision to one or more arbitrators.`
  line
  line `Act 10 of 1940 applied.--Whenever any such order shall be made, the provisions of ^1[Chapter IV of the`
  line `Arbitration Act, 1940 (10 of 1940)] shall in all respects apply to such order and arbitration, in the same`
  line `manner as if such order had been made on the application of the parties under ^2[section 21 of the said Act].`
obj_root_law_sections_16_footnotes:
  string
  line `1. Subs. by Act 10 of 1940, s. 49 and the Fourth Schedule, for "Chapter VI of the Code of Civil Procedure" (w.e.f. 1-7-1940).`
  line
  line `2. Subs. by s. 49 and the Fourth Schedule, ibid., for "section 312 of the said Code" (w.e.f. 1-7-1940).`
obj_root_law_sections_17:
  sectionId (47061)
  sectionNo (17)
  orderNo 17
  title `Reference under Act 10 of 1940.`
  content obj_root_law_sections_17_content
  footnotes `1. Subs. by s. 49 and the Fourth Schedule, ibid., for "section 312 of the said Code of Civil Procedure" (w.e.f. 1-7-1940).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47061&sectionno=17&orderno=17&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_17_content:
  string
  line `Nothing in the last preceding section shall prevent the parties`
  line `from applying to the Court, or the Court from making the order of reference, under the said ^1]section 21 of the`
  line `Arbitration Act, 1940].`
obj_root_law_sections_18:
  sectionId (47062)
  sectionNo (18)
  orderNo 18
  title `Application for leave to institute suits.`
  content obj_root_law_sections_18_content
  footnotes obj_root_law_sections_18_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47062&sectionno=18&orderno=18&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_18_content:
  string
  line `No suit shall be entertained under this Act without a`
  line `preliminary application being first made to the Court for leave to institute such suit ^1***.`
  line `The Court, on the perusal of the application, shall determine whether there are sufficient prima facie`
  line `grounds for the institution of a suit, and, if in the judgment of the Court there are such grounds, leave shall be`
  line `given for its institution.`
  line
  line `Costs.--^2*** If the Court shall be of opinion that the suit has been for the benefit of the trust, and that no`
  line `party to the suit is in fault, the Court may order the costs or such portion as it may consider just to be paid out`
  line `of the estate.`
obj_root_law_sections_18_footnotes:
  string
  line `1. The words "The application may be made upon unstamped paper." rep. by Act 7 of 1870, s. 2 and the Third Schedule`
  line `(w.e.f. 1-4-1870).`
  line
  line `2. The words "In calculating the costs at the termination of the suit, the stamp duty on the preliminary application shall be estimated,`
  line `and shall be added to the costs of the suit.", rep. by s. 2 and the Third Schedule, ibid.`
obj_root_law_sections_19:
  sectionId (47063)
  sectionNo (19)
  orderNo 19
  title `Court may require accounts of trust to be filed.`
  content obj_root_law_sections_19_content
  footnotes obj_root_law_sections_19_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47063&sectionno=19&orderno=19&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_19_content:
  string
  line `Before giving leave for institution of a suit, or,`
  line `after leave has been given, before any proceeding is taken, or at any time when the suit is pending, the Court`
  line `may order the trustee, manager or superintendent, or any member of a committee, as the case may be, to file`
  line `in Court the accounts of the trust, or such part thereof as to the Court may seem necessary.`
obj_root_law_sections_19_footnotes:
  string
  line
obj_root_law_sections_20:
  sectionId (47064)
  sectionNo (20)
  orderNo 20
  title `Proceedings for criminal breach of trust.`
  content obj_root_law_sections_20_content
  footnotes obj_root_law_sections_20_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47064&sectionno=20&orderno=20&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_20_content:
  string
  line `No suit or proceeding before any Civil Court under the`
  line `preceding sections shall in any way affect or interfere with any proceeding in a Criminal Court for criminal`
  line `breach of trust.`
obj_root_law_sections_20_footnotes:
  string
  line
obj_root_law_sections_21:
  sectionId (47065)
  sectionNo (21)
  orderNo 21
  title `Cases in which endowments are partly for religious and partly for secular purposes.`
  content obj_root_law_sections_21_content
  footnotes obj_root_law_sections_21_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47065&sectionno=21&orderno=21&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_21_content:
  string
  line `In any`
  line `case in which any land or other property has been granted for the support of an establishment partly of a`
  line `religious and partly of a secular character,`
  line
  line `or in which the endowment made for the support of an establishment is appropriated partly to religious`
  line `and partly to secular uses,`
  line
  line `the Board of Revenue, before transferring to any trustee, manager or superintendent, or to any committee`
  line `of management appointed under this Act, shall determine what portion, if any, of the said land or other`
  line `property shall remain under the superintendence of the said Board for application to secular uses,`
  line
  line `and what portion shall be transferred to the superintendence of the trustee, manager or superintendent, or`
  line `of the committee,`
  line
  line `and also what annual amount, if any, shall be charged on the land or other property which may be so`
  line `transferred to the superintendence of the said trustee, manager or superintendent, or of the committee, and`
  line `made payable to the said Board or to the local agents, for secular uses as aforesaid.`
  line
  line `In every such case the provisions of this Act shall take effect only in respect to such land and other`
  line `property as may be so transferred.`
obj_root_law_sections_21_footnotes:
  string
  line
obj_root_law_sections_22:
  sectionId (47066)
  sectionNo (22)
  orderNo 22
  title `Government not to hold charge henceforth of property for support of any mosque, temple, etc.`
  content obj_root_law_sections_22_content
  footnotes obj_root_law_sections_22_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47066&sectionno=22&orderno=22&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_22_content:
  string
  line `Except as provided in this Act, it shall not be lawful ^1*** for ^2[the Central Government or any State`
  line `Government], or for any officer of any Government in his official character,`
  line
  line `to undertake or resume the superintendence of any land or other property granted for the support of, or`
  line `otherwise belonging to, any mosque, temple or other religious establishment, or`
  line
  line `to take any part in the management or, appropriation of any endowment made for the maintenance of any`
  line `such mosque, temple or other establishment, or`
  line
  line `to nominate or appoint any trustee, manager or superintendent thereof, or to be in any way concerned`
  line therewith^3
  line .
obj_root_law_sections_22_footnotes:
  string
  line `1. The words "after the passing of this Act" rep. by Act 16 of 1874, s. 1 and the Schedule (w.e.f. 16-12-1874).`
  line
  line `2. Subs. by the A.O. 1948, for "any Govt. in Indiadb".`
  line
  line `3. A proviso to s. 22 has been added to apply only to Bengal by the Bengal Waqf Act, 1934 (Ben. Act 13 of 1934).`
obj_root_law_sections_23:
  sectionId (47067)
  sectionNo (23)
  orderNo 23
  title `Effect of Act in respect of Regulations therein mentioned, and of buildings of antiquity, etc.`
  content obj_root_law_sections_23_content
  footnotes obj_root_law_sections_23_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47067&sectionno=23&orderno=23&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_23_content:
  string
  line `Nothing in this Act shall be held to affect the provisions the ^4Regulations mentioned in this Act, except in so`
  line `far as they relate to mosques, Hindu temples and other religious establishments; or to prevent the Government`
  line `from taking such steps as it may deem necessary, under the provisions of the said Regulations, to prevent`
  line `injury to and preserve buildings^1`
  line `remarkable for their antiquity, or for their historical or architectural value, or`
  line `required for the convenience of the public.^2`
obj_root_law_sections_23_footnotes:
  string
  line `1. Namely the Bengal Charitable Endowments, Public Buildings and Escheats Regulation, 1810 (Ben. Reg. 19 of 1810), and Madras`
  line `Endowments and Escheats Regulation, 1817 (Mad. Reg. 7 of 1817).`
  line
  line `2. See now also the Ancient Monuments Preservation Act, 1904 (7 of 1904) (w.e.f. 18-3-1904).`
  line
  line `3. A new section 23A has been added to apply only to Bengal by the Bengal Waqf Act, 1934 (Ben. Act 13 of 1934).`
obj_root_law_sections_24:
  sectionId (47068)
  sectionNo (24)
  orderNo 24
  title [Repealed.].
  content `["India".]Rep. by the A.O. 1948.`
  footnotes obj_root_law_sections_24_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_20_00032_186320_1523267123192&sectionId=47068&sectionno=24&orderno=24&orgactid=AC_CEN_3_20_00032_186320_1523267123192
obj_root_law_sections_24_footnotes:
  string
  line
