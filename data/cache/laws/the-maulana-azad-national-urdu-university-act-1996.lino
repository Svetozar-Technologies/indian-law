obj_root_law_sections_1:
  sectionId (23432)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23432&sectionno=1&orderno=1&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Maulana Azad National Urdu`
  line `University Act, 1996.`
  line
  line `(2) It shall come into force on such date^1`
  line `as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line `1. 9th January, 1998, vide notification No. S.O 1(E), dated 1st January, 1998, see Gazette of India, Extraordinary, Part II, sec.`
  line `3(ii).`
obj_root_law_sections_2:
  sectionId (23433)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23433&sectionno=2&orderno=2&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_2_content:
  string
  line `In this Act, and the Statutes made hereunder, unless the context otherwise`
  line requires,--
  line
  line `(a) "Academic Council" means the Academic Council of the University;`
  line
  line `(b) "academic staff" means such categories of staff as are designated as academic staff by the`
  line Ordinances;
  line
  line `(c) "Board of Studies" means the Board of Studies of the University;`
  line
  line `(d) "Chancellor", "Vice-Chancellor" and "Pro-Vice-Chancellor" mean, respectively, the`
  line `Chancellor, Vice-Chancellor and Pro-Vice Chancellor of the University;`
  line
  line `(e) "Court" means the Court of the University;`
  line
  line `(f) "Department" means a Department of Studies; and includes a Centre of Studies;`
  line
  line `(g) "distance education system" means the system of imparting education through any means of`
  line `communication such as broadcasting, telecasting, correspondence courses, seminars, contact`
  line `programmes or the combination of any two or more of such means;`
  line
  line `(h) "employee" means any person appointed by the University and includes teachers and other`
  line `staff of the University;`
  line
  line `(i) "Executive Council" means the Executive Council of the University;`
  line
  line `(j) "Finance Committee" means the Finance Committee of the University;`
  line
  line `(k) "Hall" means a unit of residence or of corporate life for the students of the University, or of an`
  line `Institution, maintained by the University;`
  line
  line `(l) "Institution" means an academic institution maintained by the University;`
  line
  line `(m) "recognised Institution" means an institution of higher learning recognised by the University;`
  line
  line `(n) "Regulations" means the Regulations made by any authority of the University under this Act`
  line `for the time being force;`
  line
  line `(o) "School" means a school of Studies of the University;`
  line
  line `(p) "Statutes" and "Ordinances" mean, respectively, the Statutes and Ordinances of the University`
  line `for the time being in force;`
  line
  line `(q) "Teachers of the University" means Professors, Readers, Lecturers and such other persons as`
  line `may be appointed for imparting instruction or conducting research in the University or in any`
  line `Institution maintained by the University and who are designated as teachers by the Ordinances;`
  line
  line `(r) "University" means the Maulana Azad National Urdu University established and incorporated`
  line `as a University under this Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (23434)
  sectionNo (3)
  orderNo 3
  title `Establishment of the University.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23434&sectionno=3&orderno=3&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_3_content:
  string
  line `(1) There shall be established a University by the name of`
  line `"Maulana Azad National Urdu University".`
  line
  line `(2) The headquarters of the University shall be at Hyderabad.`
  line
  line `(3) The first Chancellor and the first Vice-Chancellor and the first members of the Court, the`
  line `Executive Council and the Academic Council and all persons who may hereafter become such officers or`
  line `members, so long as they continue to hold such office or membership, are hereby constituted a body`
  line `corporate by the name of "Maulana Azad National Urdu University".`
  line
  line `(4) The University shall have perpetual succession and a common seal and shall sue and be sued by`
  line `the said name.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (23435)
  sectionNo (4)
  orderNo 4
  title `Objects of the University.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23435&sectionno=4&orderno=4&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_4_content:
  string
  line `The objects of the University shall be to promote and develop Urdu`
  line `language; to impart education and training in vocational and technical subjects through the medium of`
  line `Urdu; to provide wider access to people desirous of pursuing programmes of higher education and`
  line `training in Urdu medium through teaching on the Campus as well as at a distance and to provide focus on`
  line `women education.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (23436)
  sectionNo (5)
  orderNo 5
  title `Powers of the University.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23436&sectionno=5&orderno=5&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_5_content:
  string
  line `The University shall have the following powers, namely:--`
  line
  line `(i) to provide for instructions and research in such branches of learning as are relevant for`
  line `furtherance of the objects of the University.`
  line
  line `(ii) to grant, subject to such conditions as the University may determine, diplomas or certificates`
  line `to, and confer degrees or other academic distinctions on the basis of examinations, evaluation or any`
  line `other method of testing, on persons, and to withdraw any such diplomas, certificates, degrees or other`
  line `academic distinctions for good and sufficient cause;`
  line
  line `(iii) to organise and to undertake extra-mural studies, training and extension services;`
  line
  line `(iv) to confer honorary degrees or other distinctions in the manner prescribed by the Statutes;`
  line
  line `(v) to institute Professorships, Readerships, Lecturerships and other teaching or academic`
  line `positions, required by the University and to appoint persons to such Professorships, Readerships,`
  line `Lecturerships or other teaching or academic positions;`
  line
  line `(vi) to appoint persons working in any other University or organisation as teacher or the`
  line `University for a specified period;`
  line
  line `(vii) to create administrative, ministerial and other posts and to make appointments thereto;`
  line
  line `(viii) to co-operate or collaborate or associate with any other University or authority or institution`
  line `of higher learning in such manner and for such purposes as the University may determine;`
  line
  line `(ix) to establish, with the prior approval of the Central Government, such centres and specialised`
  line `laboratories, within or outside India, as are, in the opinion of the University necessary for the`
  line `furtherance of its objects;`
  line
  line `(x) to institute and award fellowships, scholarships, studentships, medals and prizes;`
  line
  line `(xi) to establish and maintain Institutions and Halls;`
  line
  line `(xii) to make provision for research and advisory services and for that purpose to enter into such`
  line `arrangements with other institutions, industrial or other organisations as the University may deem`
  line necessary;
  line
  line `(xiii) to organise and conduct refresher courses, workshops, seminars and other programmes for`
  line `teachers, evaluators and other academic staff;`
  line
  line `(xiv) to make special arrangements in respect of the residence, discipline and teaching of women`
  line `students as the University may consider desirable;`
  line
  line `(xv) to appoint, on contract or otherwise, visiting Professors, Emeritus Professors, Consultants,`
  line `Scholars and such other persons who may contribute to the advancement of the objects of the`
  line University;
  line
  line `(xvi) to confer autonomous status on a Department in accordance with the Statutes;`
  line
  line `(xvii) to determine standards of admission to the University which may include examination,`
  line `evaluation or any other method of testing;`
  line
  line `(xviii) to demand and receive payment of fees and other charges;`
  line
  line `(xix) to supervise the residences of the students of the University and to make arrangements for`
  line `promoting their health and general welfare;`
  line
  line `(xx) to lay down conditions of service of all categories of employees including their code of`
  line conduct;
  line
  line `(xxi) to regulate and enforce discipline among the students and the employees and to take such`
  line `disciplinary measures in this regard as may be deemed by the University to be necessary;`
  line
  line `(xxii) to make arrangements for promoting the health and general welfare of the employees;`
  line
  line `(xxiii) to receive benefactions, donations and gifts and to acquire, hold, manage and dispose of`
  line `any property, movable or immovable, including trust and endowment properties for the purposes of`
  line `the University;`
  line
  line `(xxiv) to borrow, with the approval of the Central Government, on the security of the property of`
  line `the University, money for the purposes of the University;`
  line
  line `(xxv) to organise suitable distance education programmes;`
  line
  line `(xxvi) to establish maintain or recognise Study Centres for the delivery of the distance education`
  line `system in the manner laid down by the Ordinances;`
  line
  line `(xxvii) to provide for the preparation of instructional materials including films, cassettes, tapes,`
  line `video cassettes and other software in collaboration with various Open Universities and other`
  line `Institutions dealing with the distance education system;`
  line
  line `(xxviii) to devise and implement suitable schemes for providing a base for promotion and`
  line `dissemination of Urdu and to bring about the essential continuity in education with special reference`
  line `to the delivery system in distance education consistent with the objectives of the University; and`
  line
  line `(xxix) to do all such other acts and things as may be necessary, incidental or conducive to the`
  line `attainment of all or any of its objects.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (23437)
  sectionNo (6)
  orderNo 6
  title Jurisdiction.
  content `The jurisdiction of the University shall extend to the whole of India.`
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23437&sectionno=6&orderno=6&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_sections_7:
  sectionId (23438)
  sectionNo (7)
  orderNo 7
  title `University open to all classes, castes and creeds.`
  content obj_root_law_sections_7_content
  footnotes obj_root_law_sections_7_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23438&sectionno=7&orderno=7&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_7_content:
  string
  line `The University shall be open to persons of`
  line `either sex and of whatever caste, creed, race or class, and it shall not be lawful for the University to adopt`
  line `or impose on any person any test whatsoever of religious belief or profession in order to entitle him to be`
  line `appointed as a teacher of the University or to hold any other office therein or to be admitted as a student`
  line `in the University or to graduate thereat or to enjoy or exercise any privilege thereof:`
  line
  line `Provided that nothing in this section shall be deemed to prevent the University from making special`
  line `provisions for the employment or admission of women, physically handicapped or of persons belonging`
  line `to the weaker sections of the society and, in particular, of the Scheduled Castes and the Scheduled Tribes.`
obj_root_law_sections_7_footnotes:
  string
  line
obj_root_law_sections_8:
  sectionId (23439)
  sectionNo (8)
  orderNo 8
  title `The Visitor.`
  content obj_root_law_sections_8_content
  footnotes obj_root_law_sections_8_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23439&sectionno=8&orderno=8&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_8_content:
  string
  line `(1) The President of India shall be the Visitor of the University.`
  line
  line `(2) The Visitor may, from time to time, appoint one or more persons to review the work and progress`
  line `of the University, including Institution managed by it, and to submit a report thereon; and upon receipt of`
  line `that report the Visitor may, after obtaining the views of the Executive Council thereon through the ViceChancellor, take such action and issue such directions as he considers necessary in respect of any of the`
  line `matters dealt with in the report and the University shall be bound to comply with such directions.`
  line
  line `(3) The Visitor shall have the right to cause an inspection to be made by such person or persons as he`
  line `may direct of the University, its buildings, laboratories and equipment and of any Institution maintained`
  line `by the University and also of the examinations, teaching and other work conducted or done by the`
  line `University and to cause an inquiry to be made in like manner in respect of any matter connected with the`
  line `administration or finances of the University or Institutions.`
  line
  line `(4) The Visitor shall, in every matter referred to in sub-section (3), give notice of his intention to`
  line `cause an inspection or inquiry to be made to the University and the University shall have the right to`
  line `make such representations to the Visitor, as it may consider necessary.`
  line
  line `(5) After considering the representations, if any, made by the University, the Visitor may cause to be`
  line `made such inspection or inquiry as is referred to in sub-section (3).`
  line
  line `(6) Where any inspection or inquiry has been caused to be made by the Visitor, the University shall`
  line `be entitled to appoint a representative who shall have the right to be present and be heard at such`
  line `inspection or inquiry.`
  line
  line `(7) The Visitor may, if the inspection or inquiry is made in respect of the University or any Institution`
  line `maintained by it, address the Vice-Chancellor with reference to the result of such inspection or inquiry`
  line `together with such views and advice with regard to the action to be taken thereon, as the Visitor may be`
  line `pleased to offer, and on receipt of address made by the Visitor, the Vice-Chancellor shall communicate to`
  line `the Executive Council, the views of the Visitor with such advice as the Visitor may offer upon the action`
  line `to be taken thereon.`
  line
  line `(8) The Executive Council shall communicate, through the Vice-Chancellor, to the Visitor such`
  line `action, if any, as it proposes to take or has been taken upon the result of such inspection or inquiry.`
  line
  line `(9) Where the Executive Council does not, within a reasonable time, take action to the satisfaction of`
  line `the Visitor, the Visitor may, after considering any explanation furnished or representation made by the`
  line `Executive Council, issue such directions as he may think fit and the Executive Council shall comply with`
  line `such directions.`
  line
  line `(10) Without prejudice to the foregoing provisions of this section, the Visitor may, by order in`
  line `writing, annul any proceeding of the University which is not in conformity with this Act, the Statutes or`
  line `the Ordinances:`
  line
  line `Provided that before making any such order, he shall call upon the Registrar to show cause why such`
  line `an order should not be made, and, if any cause is shown within a reasonable time, he shall consider the`
  line same.
  line
  line `(11) The Visitor shall have such other powers as may be prescribed by the Statutes.`
obj_root_law_sections_8_footnotes:
  string
  line
obj_root_law_sections_9:
  sectionId (23440)
  sectionNo (9)
  orderNo 9
  title `Officers of the University.`
  content obj_root_law_sections_9_content
  footnotes obj_root_law_sections_9_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23440&sectionno=9&orderno=9&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_9_content:
  string
  line `The Following shall be the officers of the University:--`
  line
  line `(1) the Chancellor;`
  line
  line `(2) the Vice-Chancellor;`
  line
  line `(3) the Pro-Vice-Chancellor;`
  line
  line `(4) the Deans of Schools;`
  line
  line `(5) the Registrar;`
  line
  line `(6) the Finance Officer;`
  line
  line `(7) the Librarian; and`
  line
  line `(8) such other officers as may be declared by the Statutes to be officers of the University.`
obj_root_law_sections_9_footnotes:
  string
  line
obj_root_law_sections_10:
  sectionId (23441)
  sectionNo (10)
  orderNo 10
  title `The Chancellor.`
  content obj_root_law_sections_10_content
  footnotes obj_root_law_sections_10_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23441&sectionno=10&orderno=10&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_10_content:
  string
  line `(1) The Chancellor shall be appointed by the Visitor in such manner as may be`
  line `prescribed by the Statutes.`
  line
  line `(2) The Chancellor shall, by virtue of his office, be the Head of the University.`
  line
  line `(3) The Chancellor shall, if present, preside at the convocation of the University held for conferring`
  line degrees.
obj_root_law_sections_10_footnotes:
  string
  line
obj_root_law_sections_11:
  sectionId (23442)
  sectionNo (11)
  orderNo 11
  title `The Vice-Chancellor.`
  content obj_root_law_sections_11_content
  footnotes obj_root_law_sections_11_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23442&sectionno=11&orderno=11&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_11_content:
  string
  line `(1) The Vice-Chancellor shall be appointed by the Visitor in such`
  line `manner and on such terms and conditions of service as may be prescribed by the Statutes.`
  line
  line `(2) The Vice-Chancellor shall be the principal executive and academic officer of the University and`
  line `shall exercise general supervision and control over the affairs of the University and give effect to the`
  line `decisions of all the authorities of the University.`
  line
  line `(3) The Vice-Chancellor may, if he is of opinion that immediate action is necessary on any matter,`
  line `exercise any power conferred on any authority of the University by or under this Act and shall report to`
  line `such authority the action taken by him on such matters:`
  line
  line `Provided that if the authority concerned is of the opinion that such action ought not to have been`
  line `taken, it may refer the matter to the Visitor whose decision thereon shall be final:`
  line
  line `Provided further that any person in the service of the University who is aggrieved by the action taken`
  line `by the Vice-Chancellor under this sub-section shall have the right to appeal against such action to the`
  line `Executive Council within three months from the date on which decision on such action is communicated`
  line `to him and thereupon the Executive Council may confirm, modify or reverse the action taken by the ViceChancellor.`
  line
  line `(4) The Vice-Chancellor, if he is of the opinion that any decision of any authority of the University is`
  line `beyond the powers of the authority conferred by the provisions of this Act, the Statutes or the Ordinances`
  line `or that any decision taken is not in the interest of the University, may ask the authority concerned to`
  line `review its decision within sixty days of such decision and if the authority refuses to review the decision`
  line `either in whole or in part or no decision is taken by it within the said period of sixty days, the matter shall`
  line `be referred to the Visitor whose decision thereon shall be final.`
  line
  line `(5) The Vice-Chancellor shall exercise such other powers and perform such other duties as may be`
  line `prescribed by the Statutes or the Ordinances.`
obj_root_law_sections_11_footnotes:
  string
  line
obj_root_law_sections_12:
  sectionId (23443)
  sectionNo (12)
  orderNo 12
  title `The Pro-Vice-Chancellor.`
  content obj_root_law_sections_12_content
  footnotes obj_root_law_sections_12_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23443&sectionno=12&orderno=12&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_12_content:
  string
  line `The Pro-Vice-Chancellor shall be appointed in such manner and`
  line `shall exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_12_footnotes:
  string
  line
obj_root_law_sections_13:
  sectionId (23444)
  sectionNo (13)
  orderNo 13
  title `The Deans of Schools.`
  content obj_root_law_sections_13_content
  footnotes obj_root_law_sections_13_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23444&sectionno=13&orderno=13&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_13_content:
  string
  line `Every Dean of a School shall be appointed in such manner and shall`
  line `exercise such powers and perform such duties as may be prescribed by the Statutes.`
obj_root_law_sections_13_footnotes:
  string
  line
obj_root_law_sections_14:
  sectionId (23445)
  sectionNo (14)
  orderNo 14
  title `The Registrar.`
  content obj_root_law_sections_14_content
  footnotes obj_root_law_sections_14_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_9_30_00013_199702_1517807323852&sectionId=23445&sectionno=14&orderno=14&orgactid=AC_CEN_9_30_00013_199702_1517807323852
obj_root_law_sections_14_content:
  string
  line `(1) The Registrar shall be appointed in such manner as may be prescribed by the`
  line Statutes.
  line
  line `(2) The Registrar shall have the power to enter into agreement, sign documents and authenticate`
  line `records on behalf of the University and shall exercise such powers and perform such duties as may be`
  line `prescribed by the Statutes.`
obj_root_law_sections_14_footnotes:
  string
  line
