  object
  (str slug) (str the-maulana-azad-national-urdu-university-act-1996)
  (str handle) (str 1975)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Maulana Azad National Urdu University Act, 1996`)
  (str actNumber) (str 02)
  (str enactmentDate) (str 1997-01-08)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1975`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `मौलाना आजाद राष्‍ट्रीय उर्दू विश्‍वविद्यालयअधिनियम, 1996`)
  (str actYear) (str 1997)
  (str ministry) (str `Ministry of Education`)
  (str department) (str `Department of Higher Education`)
  (str longTitle) (str `An Act to establish and incorporate in University at the national level mainly to promote and develop Urdu language and to import vocational and technical education in Urdu medium through conventional teaching and distance education system and to provide for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 09-01-1998)
  (str notification) (str `9th January, 1998, vide notification No. S.O 1(E), dated 1st January, 1998, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-08T22:23:12.814Z`)
