obj_root_law:
  slug the-maulana-azad-national-urdu-university-act-1996
  handle (1975)
  collectionHandle 123456789/1362
  title `The Maulana Azad National Urdu University Act, 1996`
  actNumber (02)
  enactmentDate 1997-01-08
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/1975`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `मौलाना आजाद राष्‍ट्रीय उर्दू विश्‍वविद्यालयअधिनियम, 1996`
  actYear (1997)
  ministry `Ministry of Education`
  department `Department of Higher Education`
  longTitle `An Act to establish and incorporate in University at the national level mainly to promote and develop Urdu language and to import vocational and technical education in Urdu medium through conventional teaching and distance education system and to provide for matters connected therewith or incidental thereto.`
  enforcementDate 09-01-1998
  notification `9th January, 1998, vide notification No. S.O 1(E), dated 1st January, 1998, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`
  fetchedAt `2026-05-08T22:23:12.814Z`
  translations obj_root_law_translations
