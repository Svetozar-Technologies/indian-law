  (str title) (str `दिल्‍ली सिख गुरुद्वारा अधिनियम,1971`)
  (str sourceUrl) (str `https://www.indiacode.nic.in/bitstream/123456789/1598/2/hH1971-82.pdf`)
  (str sourceKind) (str pdf)
  (str fetchedAt) (str `2026-05-10T11:23:40.284Z`)
