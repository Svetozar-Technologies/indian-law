obj_root_law_sections_57:
  sectionId (88640)
  sectionNo (57)
  orderNo 57
  title `Transitory provisions.`
  content obj_root_law_sections_57_content
  footnotes obj_root_law_sections_57_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_12_13_00025_202326_1710407531189&sectionId=88640&sectionno=57&orderno=57&orgactid=AC_CEN_12_13_00025_202326_1710407531189
obj_root_law_sections_57_content:
  string
  line `(1) The National Commission shall be the successor in interest to the`
  line `Indian Nursing Council including its subsidiaries or owned trusts and all the assets and liabilities of the`
  line `Indian Nursing Council shall be deemed to have been transferred to the National Commission.`
  line
  line `(2) Notwithstanding the repeal of the Indian Nursing Council Act, 1947 (48 of 1947), the educational`
  line `standards, requirements and other provisions of the said Act and the rules and regulations made thereunder`
  line `shall continue to be in force and operate till new standards or requirements are specified under this Act or`
  line `the rules and regulations made thereunder:`
  line
  line `Provided that anything done, or any action taken, as regards the educational standards and requirements`
  line `under the enactment under repeal and the rules and regulations made thereunder, shall be deemed to have`
  line `been done or taken under the corresponding provisions of this Act and shall continue in force accordingly`
  line `unless and until superseded by anything done or by any action taken under this Act.`
obj_root_law_sections_57_footnotes:
  string
  line
