obj_root_law_translations_hi:
  title `सशस्‍त्र बल (विशेष शक्‍तियां) अधिनियम, 1958`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/1527/3/H1958-28.pdf`
