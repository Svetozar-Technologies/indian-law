obj_root_law:
  object
  (str slug) (str the-narcotic-drugs-and-psychotropic-substances-act-1985)
  (str handle) (str 1791)
  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Narcotic Drugs and Psychotropic Substances Act, 1985`)
  (str actNumber) (str 61)
  (str enactmentDate) (str 1985-09-16)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/1791`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `स्वािपक ओषधि और मन:प्रभावी पदार्थ अधिनियम, 1985`)
  (str actYear) (str 1985)
  (str ministry) (str `Ministry of Finance`)
  (str department) (str `Department of Revenue`)
  (str longTitle) (str `An Act to consolidate and amend the law relating to narcotic drugs, to make stringent provisions for the control and regulation of operations relating to narcotic drugs and psychotropic substances , to provide for the forfeiture of property derived from, or used in, illicit traffic in narcotic drugs and psychotropic substances, to implement the provisions of the International Conventions on Narcotic Drugs and Psychotropic Substances and for matters connected therewith.`)
  (str enforcementDate) (str 14-11-1985)
  (str notification) (str `14th November, 1985, vide notification No. S.O. 821(E), dated 14th November, 1985, see Gazette of India, Extraordinary, Part II, sec. 3(ii).`)
  (str fetchedAt) (str `2026-05-10T14:10:00.597Z`)
  (str translations) obj_root_law_translations
