obj_root_law_sections_1:
  sectionId (35555)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00019_196146_1517807321153&sectionId=35555&sectionno=1&orderno=1&orgactid=AC_CEN_2_2_00019_196146_1517807321153
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Voluntary Surrender of Salaries`
  line `(Exemption from Taxation) Act, 1961.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (35556)
  sectionNo (2)
  orderNo 2
  title `Exemption from taxes on income in respect of salaries surrendered in favour of Government.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00019_196146_1517807321153&sectionId=35556&sectionno=2&orderno=2&orgactid=AC_CEN_2_2_00019_196146_1517807321153
obj_root_law_sections_2_content:
  string
  line `Notwithstanding anything contained in the Indian Income-tax Act, 1922 (11 of 1922), or`
  line `in any other law for the time being in force relating to taxation on income, no income-tax or super-tax`
  line `shall be payable by any person--`
  line
  line `(a) where his salary is paid out of the Consolidated Fund of India or of the Consolidated Fund of`
  line `a State, in respect of that part of the salary due to him for any period after the`
  line `31st day of March, 1961 which he has, by a declaration in writing, volunteered to forego in the public`
  line interest;
  line
  line `(b) in any other case, in respect of that part of the salary which is due to him for any period after`
  line `the 31st day of March, 1961 which has been, in the public interest, surrendered in favour of, and paid`
  line `to, the Central Government in accordance with the rules made in this behalf by that Government;`
  line
  line `and such part of the salary shall not be included in his total income for the purposes of any law relating to`
  line `taxation on income.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (35557)
  sectionNo (3)
  orderNo 3
  title `Provisions of section 2 to apply to allowances.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00019_196146_1517807321153&sectionId=35557&sectionno=3&orderno=3&orgactid=AC_CEN_2_2_00019_196146_1517807321153
obj_root_law_sections_3_content:
  string
  line `The provision of section 2 shall apply in relation`
  line `to any allowances due to any such person as is referred to therein for any period after the`
  line `31st day of March, 1961 as they apply in relation to his salary.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (35558)
  sectionNo (4)
  orderNo 4
  title `Power to make rule.`
  content obj_root_law_sections_4_content
  footnotes `1. Subs. by Act 4 of 1986, s. 2 and the Schedule, for certain words (w.e.f. 15-5-1986).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00019_196146_1517807321153&sectionId=35558&sectionno=4&orderno=4&orgactid=AC_CEN_2_2_00019_196146_1517807321153
obj_root_law_sections_4_content:
  string
  line `(1) The Central Government may, by notification in the Official Gazette,`
  line `make rules to carry out the purposes of this Act.`
  line
  line `(2) Every rule made under this section shall be laid as soon as may be after it is made before each`
  line `House of Parliament while it is in session for a total period of thirty days which may be comprised in one`
  line `session or ^1[in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid] both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified from or be of no effect, as the case may be; so however that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_5:
  sectionId (35559)
  sectionNo (5)
  orderNo 5
  title Repeal.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_2_00019_196146_1517807321153&sectionId=35559&sectionno=5&orderno=5&orgactid=AC_CEN_2_2_00019_196146_1517807321153
obj_root_law_sections_5_content:
  string
  line `(1) The Voluntary Surrender of Salaries (Exemption from Taxation)`
  line `Act, 1950 (61 of 1950), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal any declaration made under the said Act shall be deemed to be a`
  line `declaration made for the purposes of this Act.`
obj_root_law_sections_5_footnotes:
  string
  line
