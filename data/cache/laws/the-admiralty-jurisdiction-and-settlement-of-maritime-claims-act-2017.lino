obj_root_law_translations_hi:
  title `नावधिकरण (समुद्री दावा की अधिकारिता और निपटारा) अधिनियम,2017`
  sourceUrl `https://www.indiacode.nic.in/bitstream/123456789/2256/3/H2017-22.pdf`
  sourceKind pdf
  fetchedAt `2026-05-10T11:26:49.850Z`
