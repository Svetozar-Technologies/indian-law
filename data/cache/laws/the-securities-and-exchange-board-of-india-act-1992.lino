obj_root_law_sections_34:
  sectionId (31488)
  sectionNo (34)
  orderNo 90
  title `Power to remove difficulties.`
  content obj_root_law_sections_34_content
  footnotes obj_root_law_sections_34_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00014_199215_1517807319932&sectionId=31488&sectionno=34&orderno=90&orgactid=AC_CEN_2_11_00014_199215_1517807319932
obj_root_law_sections_34_content:
  string
  line `(1) If any difficulty arises in giving effect to the provisions of`
  line `this Act, the Central Government may, by order, published in the Official Gazette, make such provisions`
  line `not inconsistent with the provisions of this Act as may appear to be necessary for removing the difficulty:`
  line
  line `Provided that no order shall be made under this section after the expiry of five years from the`
  line `commencement of this Act.`
  line
  line `(2) Every order made under this section shall be laid, as soon as may be after it is made, before each`
  line `House of Parliament.`
obj_root_law_sections_34_footnotes:
  string
  line
obj_root_law_sections_34_a:
  sectionId (31489)
  sectionNo 34A
  orderNo 91
  title `Validation of certain acts.`
  content obj_root_law_sections_34_a_content
  footnotes `1. Ins. by s. 23, ibid. (w.e.f. 18-7-2013).`
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00014_199215_1517807319932&sectionId=31489&sectionno=34A&orderno=91&orgactid=AC_CEN_2_11_00014_199215_1517807319932
obj_root_law_sections_34_a_content:
  string
  line `^1[34A. Validation of certain acts.--Any act or thing done or purporting to have been done under the`
  line `principal Act, in respect of calling for information from, or furnishing information to, other authorities,`
  line `whether in India or outside India, having functions similar to those of the Board and in respect of`
  line `settlement of administrative and civil proceedings, shall, for all purposes, be deemed to be valid and`
  line `effective as if the amendments made to the principal Act had been in force at all material times.]`
obj_root_law_sections_35:
  sectionId (31490)
  sectionNo (35)
  orderNo 92
  title `Repeal and saving.`
  content obj_root_law_sections_35_content
  footnotes obj_root_law_sections_35_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00014_199215_1517807319932&sectionId=31490&sectionno=35&orderno=92&orgactid=AC_CEN_2_11_00014_199215_1517807319932
obj_root_law_sections_35_content:
  string
  line `(1) The Securities and Exchange Board of India Ordinance, 1992`
  line `(Ord. 5 of 1992), is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance, shall be`
  line `deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_35_footnotes:
  string
  line
