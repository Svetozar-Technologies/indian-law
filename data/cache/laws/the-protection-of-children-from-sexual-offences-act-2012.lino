  (str collectionHandle) (str 123456789/1362)
  (str title) (str `The Protection of Children from Sexual Offences Act, 2012`)
  (str actNumber) (str 32)
  (str enactmentDate) (str 2012-06-19)
  (str sourceUrl) (str `https://www.indiacode.nic.in/handle/123456789/2079`)
  (str sources) obj_root_law_sources
  (str sections) obj_root_law_sections
  (str hindiTitle) (str `लैंगिक अपराधों से बालकों का संरक्षण अधिनियम, 2012`)
  (str actYear) (str 2012)
  (str ministry) (str `Ministry of Women and Child Development`)
  (str longTitle) (str `An Act to protect children from offences of sexual assault, sexual harassment and pornography and provide for establishment of Special Courts for trial of such offences and for matters connected therewith or incidental thereto.`)
  (str enforcementDate) (str 14-11-2012)
  (str notification) (str `14th November, 2012, vide notification No.S.O. 2705 (E), dated 9th November, 2012, see Gazette of India Extraordinary, Part II, sec. 3(ii).`)
