obj_root_law_sections_1:
  sectionId (42396)
  sectionNo (1)
  orderNo 1
  title `Short title.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00022_195341_1517807328250&sectionId=42396&sectionno=1&orderno=1&orgactid=AC_CEN_3_3_00022_195341_1517807328250
obj_root_law_sections_1_content:
  string
  line `This Act may be called the Calcutta High Court (Extension of Jurisdiction) Act,`
  line 1953.
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (42397)
  sectionNo (2)
  orderNo 2
  title `Extension of jurisdiction of Calcutta High Court to Chandernagore and Andaman and Nicobar Islands.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00022_195341_1517807328250&sectionId=42397&sectionno=2&orderno=2&orgactid=AC_CEN_3_3_00022_195341_1517807328250
obj_root_law_sections_2_content:
  string
  line `The jurisdiction of the High Court at Calcutta shall extend to Chandernagore and`
  line `Andaman and Nicobar Islands and shall, as from the 2nd day of May, 1950, be deemed to have`
  line `extended to Chandernagore, and the said High Court shall, for all purposes be deemed to be the High`
  line `Court for Chandernagore and the Andaman and Nicobar Islands.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (42398)
  sectionNo (3)
  orderNo 3
  title `Effect of certain orders.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00022_195341_1517807328250&sectionId=42398&sectionno=3&orderno=3&orgactid=AC_CEN_3_3_00022_195341_1517807328250
obj_root_law_sections_3_content:
  string
  line `Any order made—`
  line
  line `(i) by the highest court of appeal in relation to Chandernagore before the 2nd day of May,`
  line `1950, or in any proceeding pending before that Court on that day; or`
  line
  line `(ii) by the Chief Commissioner of the Andaman and Nicobar Islands before the`
  line `commencement of this Act in the discharge of his functions as the High Court for those Islands,`
  line
  line `shall for all purposes have effect, not only as an order of that Court, or as the case may be, of the`
  line `Chief Commissioner, but also as if it were an order made by the High Court at Calcutta.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (42399)
  sectionNo (4)
  orderNo 4
  title `Power to make rules.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_3_3_00022_195341_1517807328250&sectionId=42399&sectionno=4&orderno=4&orgactid=AC_CEN_3_3_00022_195341_1517807328250
obj_root_law_sections_4_content:
  string
  line `Subject to the provisions of any law for the time being in force, the`
  line `High Court at Calcutta may make rules to carry out the purposes of this Act and for the purpose of`
  line `effectively exercising its jurisdiction in or in relation to Chandernagore and the Andaman and Nicobar`
  line Islands.
obj_root_law_sections_4_footnotes:
  string
  line
