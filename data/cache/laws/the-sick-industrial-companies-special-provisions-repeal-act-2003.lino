obj_root_law_sections_1:
  sectionId (5102)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_200401_1517807322103&sectionId=5102&sectionno=1&orderno=1&orgactid=AC_CEN_2_11_00026_200401_1517807322103
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Sick Industrial Companies`
  line `(Special Provisions) Repeal Act, 2003.`
  line
  line `(2) It shall come into force on such date as the Central Government may, by notification in the`
  line `Official Gazette, appoint.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (5103)
  sectionNo (2)
  orderNo 2
  title Definitions.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_200401_1517807322103&sectionId=5103&sectionno=2&orderno=2&orgactid=AC_CEN_2_11_00026_200401_1517807322103
obj_root_law_sections_2_content:
  string
  line `In this Act, unless the context otherwise requires--,`
  line
  line `(a) "Appellate Authority'' means the Appellate Authority for Industrial and Financial`
  line `Reconstruction constituted under section 5 of the Sick Industrial Companies (Special Provisions) Act,`
  line `1985 (1 of 1986);`
  line
  line `(b) "Board'' means the Board for Industrial and Financial Reconstruction established under`
  line `section 4 of the Sick Industrial Companies (Special Provisions) Act, 1985 (1 of 1986);`
  line
  line `(c) words and expressions used herein and not defined but defined in the Sick Industrial`
  line `Companies (Special Provisions) Act, 1985 (1 of1986), shall have the meanings respectively assigned`
  line `to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (5104)
  sectionNo (3)
  orderNo 3
  title `Repeal of Act 1 of 1986 and dissolution of Appellate Authority and Board.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_200401_1517807322103&sectionId=5104&sectionno=3&orderno=3&orgactid=AC_CEN_2_11_00026_200401_1517807322103
obj_root_law_sections_3_content:
  string
  line `The Sick`
  line `Industrial Companies (Special Provisions) Act, 1985(hereinafter referred to as the repealed enactment) is`
  line `hereby repealed and the Appellate Authority and the Board stand dissolved.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (5105)
  sectionNo (4)
  orderNo 4
  title `Consequential provisions.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_200401_1517807322103&sectionId=5105&sectionno=4&orderno=4&orgactid=AC_CEN_2_11_00026_200401_1517807322103
obj_root_law_sections_4_content:
  string
  line `On the dissolution of the Appellate Authority and the Board,--`
  line
  line `(a) (i) the persons appointed as Chairman and Member of the Appellate Authority or the Board;`
  line and
  line
  line `(ii) every other person appointed by the Central Government, Appellate Authority or the Board,`
  line `and holding office as such immediately before the commencement of this Act, shall vacate his office and`
  line `no such Chairman, Member or other person shall be entitled to claim any compensation for premature`
  line `termination of the term of his office or of any contract of service:`
  line
  line `Provided that every officer or employee who has been, immediately before the dissolution of the`
  line `Appellate Authority or the Board, appointed on deputation basis to the Appellate Authority or the Board,`
  line `shall stand reverted to his parent cadre, Ministry or Department, as the case may be:`
  line
  line `Provided further that every officer or employee who has been, immediately before the dissolution of`
  line `the Appellate Authority or the Board, employed on regular basis by the Appellate Authority or the Board,`
  line `shall become, on and from the date of such dissolution, the officer and employee, respectively, of the`
  line `Central Government with the same rights and privileges as to pension, gratuity and other like matters as`
  line `would have been admissible to him if the rights in relation to such Appellate Authority or the Board had`
  line `not been transferred to, and vested in, the Central Government and shall continue to do so unless and until`
  line `his employment in the Central Government is duly terminated or until his remuneration, terms and`
  line `conditions of employment are duly altered by that Government:`
  line
  line `Provided also that notwithstanding anything contained in the Industrial Disputes Act, 1947`
  line `(14 of 1947), or in any other law for the time being in force, the transfer of the services of any officer or other employee, employed in the Appellate Authority or the Board, to the Central Government, shall not entitle such officer or employee to any compensation under this Act or any other law for the time being in force and no such claim shall be entertained by any court, tribunal or other authority:`
  line
  line `Provided also that where the Appellate Authority or the Board has established a provident fund,`
  line `superannuation, welfare or other fund for the benefit of the officers and employees employed in the`
  line `Appellate Authority or the Board, the monies relatable to the officers and employees whose services have been transferred by or under this Act to the Central Government shall, out of the monies standing, on the dissolution of the Appellate Authority or the Board, to the credit of such provident fund, superannuation, welfare or other fund, stand transferred to, and vest in, the Central Government and such monies which stand so transferred shall be dealt with by that Government in such manner as may be prescribed;`
  line
  line `^1[(b) On such date as may be notified by the Central Government in this behalf, any appeal preferred`
  line `to the Appellate Authority or any reference made or inquiry pending to or before the Board or any`
  line `proceeding of whatever nature pending before the Appellate Authority or the Board under the Sick`
  line `Industrial Companies (Special Provisions) Act, 1985 (1 of 1986) shall stand abated:`
  line
  line `Provided that a company in respect of which such appeal or reference or inquiry stands abated under`
  line `this clause may make reference to the National Company Law Tribunal under the Insolvency and`
  line `Bankruptcy Code, 2016 within one hundred and eighty days from the commencement of the Insolvency`
  line `and Bankruptcy Code, 2016 in accordance with the provisions of the Insolvency and Bankruptcy Code,`
  line `2016:`
  line
  line `Provided further that no fees shall be payable for making such reference under Insolvency and`
  line `Bankruptcy Code, 2016 by a company whose appeal or reference or inquiry stands abated under this`
  line clause.]
  line
  line `^2[Provided also that any scheme sanctioned under sub-section (4) or any scheme under`
  line `implementation under sub-section (12) of section 18 of the Sick Industrial Companies (Special`
  line `Provisions) Act, 1985 shall be deemed to be an approved resolution plan under sub-section (1) of section`
  line `31 of the Insolvency and Bankruptcy Code, 2016 and the same shall be dealt with, in accordance with the`
  line `provisions of Part II of the said Code:`
  line
  line `Provided also that in case, the statutory period within which an appeal was allowed under the Sick`
  line `Industrial Companies (Special Provisions) Act, 1985 against an order of the Board had not expired as on`
  line `the date of notification of this Act, an appeal against any such deemed approved resolution plan may be`
  line `preferred by any person before National Company Law Appellate Tribunal within ninety days from the`
  line `date of publication of this order.]`
  line
  line `(c) the balance of all monies (including any fee) received by, or advanced to the Appellate`
  line `Authority or the Board, as the case may be, and not spent by it before the commencement of this Act`
  line `shall, on the commencement of this Act, stand transferred to, and vest in, the Central Government and`
  line `shall be utilised for the purposes of clauses (e) and (f);`
  line
  line `(d) all property of whatever kind owned by, or vested in, the Appellate Authority or the Board, as`
  line `the case may be, and not spent by it before the commencement of this Act shall, on the`
  line `commencement of this Act, stand transferred to, and shall vest in the Central Government;`
  line
  line `(e) all liabilities and obligations of whatever kind incurred by the Appellate Authority or the`
  line `Board and subsisting immediately before the commencement of this Act shall, on and from the`
  line `commencement of this Act, be deemed to be the liabilities or obligations, as the case maybe, of the`
  line `Central Government; and any proceeding or cause of action, pending or existing immediately before`
  line `the commencement of this Act by or against the Appellate Authority or the Board in relation to such`
  line `liability or obligation may, as from the commencement of this Act, be continued or enforced by or`
  line `against the Central Government;`
  line
  line `(f) all monies vested in the Central Government under clause (c) shall, after deducting the amount`
  line `incurred for discharging the liabilities and obligations referred to in that clause, be refunded by the`
  line `Central Government to the person to whom such amount is due.`
obj_root_law_sections_4_footnotes:
  string
  line `1. Subs. by Act 31 of 2016, s. 252 and the Eighth Schedule, for sub-clause (@i/i@) (w.e.f. 1-11-2016).`
  line
  line `2. Ins. by vide the Insolvency and Bankruptcy Code (Removal of Difficulties) Order, 2017 vide Notification No. SO1683(E)`
  line `dated 24-05-2017.`
obj_root_law_sections_5:
  sectionId (5106)
  sectionNo (5)
  orderNo 5
  title Saving.
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_200401_1517807322103&sectionId=5106&sectionno=5&orderno=5&orgactid=AC_CEN_2_11_00026_200401_1517807322103
obj_root_law_sections_5_content:
  string
  line `(1) The repeal by this Act of the repealed enactment shall not--`
  line
  line `(a) affect any other enactment in which the repealed enactment has been applied, incorporated or`
  line `referred to;`
  line
  line `(b) affect the previous operation of the repealed enactment or anything duly done or suffered`
  line thereunder;
  line
  line `(c) affect any right, privilege, obligation or liability acquired, accrued, or incurred under the`
  line `repealed enactment;`
  line
  line `(d) affect any order made by the Board for sanction of the schemes;`
  line
  line `(e) affect the validity, invalidity, effect or consequences of anything already done or suffered, or`
  line `any right, title, obligation or liability already acquired, accrued or incurred or any remedy or`
  line `proceeding in respect thereof or any release or discharge of or from any debt, penalty, obligation,`
  line `liability, claim or demand, or any indemnity already granted, or the proof of any past act or thing;`
  line
  line `(f) affect any penalty, forfeiture or punishment incurred in respect of any offence committed`
  line `against the repealed enactment, affect any investigation, legal proceedings or remedy in respect of`
  line `any such right, privilege, obligation, liability, penalty, forfeiture or punishment as aforesaid, and any`
  line `such investigation, legal proceeding or remedy may be instituted, continued or enforced, and any such`
  line `privilege, forfeiture or punishment may be imposed as if this Act had not been passed;`
  line
  line `(g) affect any principle or rule of law, or established jurisdiction, form or course of pleading,`
  line `practice or procedure, or existing usage, custom, privilege, restriction, exemption, office or`
  line `appointment, notwithstanding that the same respectively may have been in any manner affirmed or`
  line `recognised or derived by, in, or from, the repealed enactment;`
  line
  line `(h) revive or restore any jurisdiction, office, custom, liability, right, title, privilege, restriction,`
  line `exemption, usage, practice, procedure or other matter or thing not now existing or in force.`
  line
  line `(2) Save as otherwise provided in section 4 and in sub-section (1) of this section, the mention of`
  line `particular matters in the said section and sub-section shall not be held to prejudice or affect the general`
  line `application of section 6 of the General Clauses Act, 1897 (10 of 1897),with regard to the effect of repeal.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (5107)
  sectionNo (6)
  orderNo 6
  title `Power to make rules.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_2_11_00026_200401_1517807322103&sectionId=5107&sectionno=6&orderno=6&orgactid=AC_CEN_2_11_00026_200401_1517807322103
obj_root_law_sections_6_content:
  string
  line `(1) The Central Government may, by notification, make rules for carrying`
  line `out the provisions of this Act.`
  line
  line `(2) In particular, and without prejudice to the generality of the foregoing power, such rules may`
  line `provide for all or any of the following matters, namely:--`
  line
  line `(a) the manner in which the monies standing to the credit of provident fund, superannuation,`
  line `welfare or other fund of officers and employees on their transfer to the Central Government, shall be`
  line `dealt with by that Government under the fourth proviso to clause (a) of section 4;`
  line
  line `(b) any other matter which is to be, or may be, prescribed, or in respect of which provision is to`
  line `be made, by rules.`
  line
  line `(3) Every rule made under this Act shall be laid, as soon as may be after it is made, before each House`
  line `of Parliament, while it is in session, for a total period of thirty days which may be comprised in one`
  line `session or in two or more successive sessions, and if, before the expiry of the session immediately`
  line `following the session or the successive sessions aforesaid, both Houses agree in making any modification`
  line `in the rule or both Houses agree that the rule should not be made, the rule shall thereafter have effect only`
  line `in such modified form or be of no effect, as the case may be; so, however, that any such modification or`
  line `annulment shall be without prejudice to the validity of anything previously done under that rule.`
obj_root_law_sections_6_footnotes:
  string
  line
obj_root_law_translations:
  hi obj_root_law_translations_hi
