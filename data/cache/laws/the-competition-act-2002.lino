  slug the-competition-act-2002
  handle (2010)
  collectionHandle 123456789/1362
  title `The Competition Act, 2002`
  actNumber (12)
  enactmentDate 2003-01-13
  sourceUrl `https://www.indiacode.nic.in/handle/123456789/2010`
  sources obj_root_law_sources
  sections obj_root_law_sections
  hindiTitle `प्रतिस्पर्धा अधिनियम, 2002`
  actYear (2003)
  ministry `Ministry of Corporate Affairs`
  department undefined
  longTitle `An Act to provide, keeping in view of the economic development of the country, for the establishment of a Commission to prevent practices having adverse effect on competition, to promote and sustain competition in markets, to protect the interests of consumers and to ensure freedom of trade carried on by other participants in markets, in India, and for matters connected therewith or incidental thereto.`
  enforcementDate 31-03-2003
  notification undefined
  fetchedAt `2026-05-09T09:41:25.658Z`
