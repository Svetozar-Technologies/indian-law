obj_root_law_sections_2:
  sectionId (31967)
  sectionNo (2)
  orderNo 2
  title `Measures under Art 41 of the Charter of the United Nations.`
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_10_10_00007_194743_1517807321027&sectionId=31967&sectionno=2&orderno=2&orgactid=AC_CEN_10_10_00007_194743_1517807321027
obj_root_law_sections_2_content:
  string
  line `If, under Article 41 of the`
  line `Charter of the United Nations signed at San Francisco on the 26th day of June 1945 the Security Council`
  line `of the United Nations calls upon the Central Government to apply any measures, not involving the use of`
  line `armed force, to give effect to any decision of that Council, the Central Government may, by order`
  line `published in the Official Gazette, make such provisions (including provisions having extra-territorial`
  line `operation) as appear to it necessary or expedient for enabling those measures to be effectively applied,`
  line `and without prejudice to the generality of the foregoing power, provision may be made for the`
  line `punishment of persons offending against the order.`
obj_root_law_sections_2_footnotes:
  string
  line
