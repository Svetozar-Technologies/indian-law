obj_root_law_sections_1:
  sectionId (67720)
  sectionNo (1)
  orderNo 1
  title `Short title and commencement.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_0_00036_1999_1657709827568&sectionId=67720&sectionno=1&orderno=1&orgactid=AC_CEN_17_0_00036_1999_1657709827568
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Urban Land`
  line `(Ceiling and Regulation) Repeal Act, 1999.`
  line
  line `(2) It applies in the first instance to the whole of the States of Haryana and Punjab and to all the`
  line `Union territories; and it shall apply to such other State which adopts this Act by resolution passed in`
  line `that behalf under clause (2) of article 252 of the Constitution.`
  line
  line `(3) It shall be deemed to have come into force in the States of Haryana and Punjab and in all the`
  line `Union territories on the 11th day of January, 1999 and in any other State which adopts this Act under`
  line `clause (2) of article 252 of the Constitution on the date of such adoption; and the reference to repeal of`
  line `the Urban Land (Ceiling and Regulation) Act, 1976 shall, in relation to any State or Union territory,`
  line `mean the date on which this Act comes into force in such State or Union territory.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (67722)
  sectionNo (3)
  orderNo 2
  title `Repeal of Act.`
  content `The Urban Land (Ceiling and Regulation) Act, 1976 (hereinafter referred to as the principal Act) is hereby repealed.`
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_0_00036_1999_1657709827568&sectionId=67722&sectionno=3&orderno=2&orgactid=AC_CEN_17_0_00036_1999_1657709827568
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (67723)
  sectionNo (4)
  orderNo 3
  title Savings.
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_0_00036_1999_1657709827568&sectionId=67723&sectionno=4&orderno=3&orgactid=AC_CEN_17_0_00036_1999_1657709827568
obj_root_law_sections_4_content:
  string
  line `(1) The repeal of the principal Act shall not affect--`
  line
  line `(a) the vesting of any vacant land under sub-section (3) of section 10, possession of which has`
  line `been taken over by the State Government or any person duly authorised by the State Government`
  line `in this behalf or by the competent authority;`
  line
  line `(b) the validity of any order granting exemption under sub-section (1) of section 20 or any`
  line `action taken thereunder, notwithstanding any judgment of any court to the contrary;`
  line
  line `(c) any payment made to the State Government as a condition for granting exemption under`
  line `sub-section (1) of section 20.`
  line
  line `(2) Where--`
  line
  line `(a) any land is deemed to have vested in the State Government under sub-section (3) of`
  line `section 10 of the principal Act but possession of which has not been taken over by the State`
  line `Government or any person duly authorised by the State Government in this behalf or by the`
  line `competent authority; and`
  line
  line `(b) any amount has been paid by the State Government with respect to such land,`
  line
  line `then, such land shall not be restored unless the amount paid, if any, has been refunded to the State`
  line Government.
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (67724)
  sectionNo (5)
  orderNo 4
  title `Abatement of legal proceedings.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_0_00036_1999_1657709827568&sectionId=67724&sectionno=5&orderno=4&orgactid=AC_CEN_17_0_00036_1999_1657709827568
obj_root_law_sections_5_content:
  string
  line `All proceedings relating to any order made or purported to`
  line `be made under the principal Act pending immediately before the commencement of this Act, before`
  line `any court, tribunal or other authority shall abate:`
  line
  line `Provided that this section shall not apply to the proceedings relating to section 11, 12, 13 ad 14 of`
  line `the principal Act in so far as such proceedings are relatable to the land, possession of which has been`
  line `taken over by the State Government or any person duly authorised by the State Government in this`
  line `behalf or by the competent authority.`
obj_root_law_sections_5_footnotes:
  string
  line
obj_root_law_sections_6:
  sectionId (67725)
  sectionNo (6)
  orderNo 5
  title `Repeal and saving.`
  content obj_root_law_sections_6_content
  footnotes obj_root_law_sections_6_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_17_0_00036_1999_1657709827568&sectionId=67725&sectionno=6&orderno=5&orgactid=AC_CEN_17_0_00036_1999_1657709827568
obj_root_law_sections_6_content:
  string
  line `(1) The Urban Land (Ceiling and Regulation) Repeal Ordinance, 1999`
  line `(Ord. 5 of 1999) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall`
  line `be deemed to have been done or taken under the corresponding provisions of this Act.`
obj_root_law_sections_6_footnotes:
  string
  line
