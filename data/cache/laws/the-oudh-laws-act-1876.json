      {
        "sectionId": "71788",
        "sectionNo": "41",
        "orderNo": 42,
        "title": "Repealed.",
        "content": "41. ic95610Continuance of prior rules as to matters for which rules may be made under the Act].---- Rep.\nby the Repealing and Amending Act, 1891 (12 of 1891).",
        "footnotes": "",
        "query": "abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00109_187618_1666091274292&sectionId=71788&sectionno=41&orderno=42&orgactid=AC_CEN_5_5_00109_187618_1666091274292"
      },
      {
        "sectionId": "71789",
        "sectionNo": "42",
        "orderNo": 43,
        "title": "Penalty for breach of rules.",
        "content": "Whoever breaks any rule made or continued under this Act, not\nbeing a rule made by the ^1[High Court], shall, on conviction before a Magistrate; be punishable with fine\nwhich may extend to fifty rupees, or with imprisonment for a term which may extend to six months, or\nwith both.",
        "footnotes": "1. Subs. by the A.O. 1950 for \"Chief Court\".",
        "query": "abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00109_187618_1666091274292&sectionId=71789&sectionno=42&orderno=43&orgactid=AC_CEN_5_5_00109_187618_1666091274292"
      },
      {
        "sectionId": "71790",
        "sectionNo": "43",
        "orderNo": 44,
        "title": ". Repealed.",
        "content": "[Power to invest taluqdars with civil jurisdiction].— Rep. by the Oudh Civil Courts Acts, 1879\n(13 of 1879.)",
        "footnotes": "",
        "query": "abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00109_187618_1666091274292&sectionId=71790&sectionno=43&orderno=44&orgactid=AC_CEN_5_5_00109_187618_1666091274292"
      },
      {
        "sectionId": "71791",
        "sectionNo": "44",
        "orderNo": 45,
        "title": "Honorary police-officers",
        "content": "The State Government may, from time to time, confer on any\nperson whom it thinks fit any power which may be exercised by a police-officer under any Act for the\ntime being in force, and withdraw any power so conferred.",
        "footnotes": "",
        "query": "abv=CEN&statehandle=123456789/1362&actid=AC_CEN_5_5_00109_187618_1666091274292&sectionId=71791&sectionno=44&orderno=45&orgactid=AC_CEN_5_5_00109_187618_1666091274292"
      },
      {
