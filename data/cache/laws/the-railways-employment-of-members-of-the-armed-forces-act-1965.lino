obj_root_law_sections_1:
  sectionId (38223)
  sectionNo (1)
  orderNo 1
  title `Short title and extent.`
  content obj_root_law_sections_1_content
  footnotes obj_root_law_sections_1_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00002_196540_1517807319909&sectionId=38223&sectionno=1&orderno=1&orgactid=AC_CEN_1_1_00002_196540_1517807319909
obj_root_law_sections_1_content:
  string
  line `(1) This Act may be called the Railways (Employment of Members of the`
  line `Armed Forces) Act, 1965.`
  line
  line `(2) It extends to the whole of India.`
obj_root_law_sections_1_footnotes:
  string
  line
obj_root_law_sections_2:
  sectionId (38224)
  sectionNo (2)
  orderNo 2
  title Interpretation.
  content obj_root_law_sections_2_content
  footnotes obj_root_law_sections_2_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00002_196540_1517807319909&sectionId=38224&sectionno=2&orderno=2&orgactid=AC_CEN_1_1_00002_196540_1517807319909
obj_root_law_sections_2_content:
  string
  line `Words and expressions used in this Act and defined in the Indian Railways Act,`
  line `1890(9 of 1890), shall have the meanings respectively assigned to them in that Act.`
obj_root_law_sections_2_footnotes:
  string
  line
obj_root_law_sections_3:
  sectionId (38225)
  sectionNo (3)
  orderNo 3
  title `Employment of members of Armed Forces of the Union to assist a railway administration in connection with the service of a railway.`
  content obj_root_law_sections_3_content
  footnotes obj_root_law_sections_3_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00002_196540_1517807319909&sectionId=38225&sectionno=3&orderno=3&orgactid=AC_CEN_1_1_00002_196540_1517807319909
obj_root_law_sections_3_content:
  string
  line `(1) When any member of the Armed Forces of the Union is`
  line `employed to assist a railway administration in connection with the service of a railway, then, whether`
  line `such employment was before or is after the commencement of this Act,--`
  line
  line `(a) any provision of the Indian Railways Act, 1890(9 of 1890), or of the rules made thereunder,`
  line `which confers a power, status or immunity, or imposes a duty or liability, upon a railway servant, in`
  line `connection with the working, use, management and maintenance of railways, shall be construed as`
  line `conferring the same power, status or immunity or imposing the same duty or liability, as the case may`
  line `be, upon such member of the Armed Forces of the Union when so employed;`
  line
  line `(b) the employment of a member of the Armed Forces of the Union, in addition to or in the place`
  line `of any railway servant, shall not affect any liability that would have attached to the railway`
  line `administration had such member been a railway servant.`
  line
  line `(2) Nothing in sub-section (1) shall be construed as making applicable to the members of the Armed`
  line `Forces of the Union employed to assist a railway administration the provisions of Chapter VIA of the`
  line `Indian Railways Act, 1890(9 of 1890), or as derogating from any provision of a law regulating the`
  line `governance, control and discipline of the members of the Armed Forces of the Union.`
obj_root_law_sections_3_footnotes:
  string
  line
obj_root_law_sections_4:
  sectionId (38226)
  sectionNo (4)
  orderNo 4
  title `Employment of members of Armed Forces of the Union to replace railway administration in working a railway.`
  content obj_root_law_sections_4_content
  footnotes obj_root_law_sections_4_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00002_196540_1517807319909&sectionId=38226&sectionno=4&orderno=4&orgactid=AC_CEN_1_1_00002_196540_1517807319909
obj_root_law_sections_4_content:
  string
  line `If at any time the whole of the working, management and maintenance of a`
  line `railway, or of a specific portion or section of a railway, is assumed by the Armed Forces of the Union, the`
  line `Central Government may notify the fact of such assumption in the Official Gazette, and thereupon, so`
  line `long as such assumption continues, the Indian Railways Act, 1890(9 of 1890), shall cease to be applicable`
  line `to the Railway or the portion or section of the Railway concerned.`
obj_root_law_sections_4_footnotes:
  string
  line
obj_root_law_sections_5:
  sectionId (38227)
  sectionNo (5)
  orderNo 5
  title `Repeal and saving.`
  content obj_root_law_sections_5_content
  footnotes obj_root_law_sections_5_footnotes
  query abv=CEN&statehandle=123456789/1362&actid=AC_CEN_1_1_00002_196540_1517807319909&sectionId=38227&sectionno=5&orderno=5&orgactid=AC_CEN_1_1_00002_196540_1517807319909
obj_root_law_sections_5_content:
  string
  line `(1) The Railways (Employment of Members of the Armed Forces)`
  line `Ordinance, 1965 (Ord. 4 of 1965) is hereby repealed.`
  line
  line `(2) Notwithstanding such repeal, anything done or any action taken under the said Ordinance shall be`
  line `deemed to have been done or taken under this Act as if this Act had commenced on the 29th day of`
  line `September, 1965.`
obj_root_law_sections_5_footnotes:
  string
  line
